---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://compareexpatplans.com";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "About" }
  ]
};
---

<Layout title="About Compare Expat Plans" description="Learn about Compare Expat Plans, our mission to help expats find the right international health insurance, and the person behind the site.">
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <section class="bg-white border-b border-neutral-100 py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-neutral-500">
          <li><a href="/" class="hover:text-neutral-900">Home</a></li>
          <li class="flex items-center gap-2">
            <span aria-hidden="true">/</span>
            <span class="text-neutral-700">About</span>
          </li>
        </ol>
      </nav>

      <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-6">
        About Compare Expat Plans
      </h1>
      <p class="text-xl text-neutral-600">
        Helping expats, digital nomads, and global citizens navigate international health insurance without the confusion.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-neutral max-w-none">
        <h2>Why This Site Exists</h2>
        <p>
          Moving abroad is exciting. Figuring out health insurance? Not so much.
        </p>
        <p>
          When you search for international health insurance, you're met with dozens of providers, confusing plan tiers, and marketing speak that makes everything sound the same. Most comparison sites are thinly veiled sales funnels that push whatever pays the highest commission.
        </p>
        <p>
          Compare Expat Plans takes a different approach. We research each provider, explain the trade-offs honestly, and help you understand what actually matters for your situation. We won't tell you one plan is "the best" because there isn't one—there's only what's best for your destination, budget, health needs, and risk tolerance.
        </p>

        <h2>What We Cover</h2>
        <ul>
          <li><strong>Country guides</strong> — Healthcare systems, visa requirements, and insurance options for popular expat destinations</li>
          <li><strong>Provider reviews</strong> — Honest assessments of major international health insurers, including who they're good for and who should look elsewhere</li>
          <li><strong>Comparison pages</strong> — Side-by-side breakdowns of similar plans to help you decide</li>
          <li><strong>How-to guides</strong> — Practical advice on topics like filing claims, understanding waiting periods, and choosing deductibles</li>
          <li><strong>Research reports</strong> — Data-driven analysis with downloadable datasets</li>
        </ul>

        <h2>Who's Behind This</h2>
      </div>

      <!-- Author Section -->
      <div class="my-8 flex flex-col sm:flex-row gap-6 p-6 bg-neutral-50 rounded-xl border border-neutral-200">
        <div class="flex-shrink-0">
          <img
            src="/images/john-spencer.png"
            alt="John Spencer"
            class="w-24 h-24 rounded-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="text-xl font-semibold text-neutral-900 mb-2">John Spencer</h3>
          <p class="text-neutral-600 mb-3">
            I'm the founder of Compare Expat Plans. I started this site after spending too many hours researching health insurance options for my own move abroad—and realizing how hard it was to find straightforward, unbiased information.
          </p>
          <p class="text-neutral-600">
            My goal is to make the research I wish I'd had available to everyone. I'm not an insurance broker or licensed agent—just someone who believes you shouldn't need a finance degree to understand your health coverage options.
          </p>
        </div>
      </div>

      <div class="prose prose-neutral max-w-none">
        <h2>How We Make Money</h2>
        <p>
          Transparency matters, so here's how this site sustains itself:
        </p>
        <p>
          We earn affiliate commissions when you apply for insurance through links on this site. If you click a link to a provider and end up purchasing a plan, we may receive a referral fee. This doesn't cost you anything extra—the price is the same whether you come through our site or go directly.
        </p>
        <p>
          This model has a potential conflict of interest, and we acknowledge that. Here's how we handle it:
        </p>
        <ul>
          <li>We review providers whether or not they have affiliate programs</li>
          <li>We include providers we can't monetize if they're genuinely good options</li>
          <li>We point out drawbacks and alternatives, even when it might cost us a commission</li>
          <li>We never rank providers based on commission rates</li>
        </ul>
        <p>
          If our recommendations ever feel off to you, call us out. Our credibility is worth more than any single referral fee.
        </p>

        <h2>What We Don't Do</h2>
        <ul>
          <li>We don't sell insurance directly</li>
          <li>We don't provide medical, legal, or financial advice</li>
          <li>We don't guarantee accuracy—insurance requirements and pricing change frequently</li>
          <li>We don't have access to your personal information when you apply through our links</li>
        </ul>
        <p>
          Always verify details directly with insurance providers and consult professionals when making important decisions about your coverage.
        </p>

        <h2>Get in Touch</h2>
        <p>
          Have a question, correction, or suggestion? I'd like to hear from you.
        </p>
        <p>
          <a href="/contact">Contact us here</a> — I read every message and respond when I can.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 bg-neutral-50 border-t border-neutral-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Ready to Compare Plans?</h2>
      <p class="text-neutral-600 mb-6">
        Browse our guides and comparisons to find coverage that fits your situation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/best/expat-health-insurance" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors">
          See Top-Rated Plans
        </a>
        <a href="/countries" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-neutral-700 bg-white border border-neutral-300 hover:bg-neutral-50 rounded-lg transition-colors">
          Browse by Country
        </a>
      </div>
    </div>
  </section>
</Layout>
