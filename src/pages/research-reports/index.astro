---
import Layout from '../../layouts/Layout.astro';

const reports = [
  {
    title: 'Expat Health Insurance Requirements by Country',
    description: 'Data on which countries require private health insurance for residency and how public healthcare access works for expats. Covers 20 countries.',
    href: '/research-reports/expat-health-insurance-requirements-by-country',
    lastUpdated: '2026-01-26',
    countries: 20,
    image: '/images/research/requirements-by-country.png',
  },
];

// Placeholder for future filter functionality
const sortOptions = ['Newest', 'Most Referenced'];
---

<Layout title="Research Reports" description="Data-driven research reports on international health insurance for expats. Downloadable datasets, methodology, and sources.">
  <!-- Hero Section -->
  <section class="bg-white border-b border-neutral-100 py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 text-xs font-medium bg-blue-50 text-blue-700 rounded-full mb-4">
        Research
      </span>
      <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
        Research Reports
      </h1>
      <p class="text-xl text-neutral-600 max-w-2xl mx-auto">
        Data-driven reports on international health insurance. Each report includes methodology, downloadable datasets, and source documentation.
      </p>
    </div>
  </section>

  <!-- Reports Section -->
  <section class="py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filter/Sort Placeholder -->
      <div class="flex items-center justify-between mb-8">
        <p class="text-neutral-600">
          {reports.length} {reports.length === 1 ? 'report' : 'reports'} available
        </p>
        <div class="flex items-center gap-2">
          <span class="text-sm text-neutral-500">Sort by:</span>
          <select class="text-sm border border-neutral-200 rounded-lg px-3 py-1.5 bg-white focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            {sortOptions.map(option => (
              <option>{option}</option>
            ))}
          </select>
        </div>
      </div>

      <!-- Report Cards -->
      <div class="space-y-6">
        {reports.map((report) => (
          <a
            href={report.href}
            class="block bg-white border border-neutral-200 rounded-xl p-6 hover:border-neutral-300 hover:shadow-sm transition-all group"
          >
            <div class="flex gap-6">
              <!-- Placeholder for report image -->
              <div class="hidden sm:block w-48 h-32 bg-neutral-100 rounded-lg flex-shrink-0 overflow-hidden">
                {report.image ? (
                  <img
                    src={report.image}
                    alt=""
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-12 h-12 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>
                )}
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="text-xl font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors mb-2">
                      {report.title}
                    </h2>
                    <p class="text-neutral-600 mb-4">
                      {report.description}
                    </p>
                  </div>
                  <svg class="w-5 h-5 text-neutral-400 group-hover:text-primary-600 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>

                <div class="flex items-center gap-4 text-sm text-neutral-500">
                  <span class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Updated {report.lastUpdated}
                  </span>
                  {report.countries && (
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {report.countries} countries
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Coming Soon placeholder -->
      <div class="mt-12 p-8 bg-neutral-50 border border-dashed border-neutral-300 rounded-xl text-center">
        <svg class="w-12 h-12 text-neutral-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="font-semibold text-neutral-700 mb-2">More Reports Coming</h3>
        <p class="text-neutral-500 text-sm max-w-md mx-auto">
          We're working on additional research reports covering insurance pricing trends, claim approval rates, and coverage comparisons.
        </p>
      </div>
    </div>
  </section>

  <!-- Related BOFU Links -->
  <section class="py-12 bg-neutral-50 border-t border-neutral-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-semibold text-neutral-900 mb-6">Looking for Insurance?</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/best/expat-health-insurance" class="p-4 bg-white border border-neutral-200 rounded-lg hover:border-primary-300 transition-colors">
          <h3 class="font-medium text-neutral-900 mb-1">Best Expat Insurance</h3>
          <p class="text-sm text-neutral-500">Top-rated plans for 2026</p>
        </a>
        <a href="/compare" class="p-4 bg-white border border-neutral-200 rounded-lg hover:border-primary-300 transition-colors">
          <h3 class="font-medium text-neutral-900 mb-1">Compare Plans</h3>
          <p class="text-sm text-neutral-500">Side-by-side comparisons</p>
        </a>
        <a href="/countries" class="p-4 bg-white border border-neutral-200 rounded-lg hover:border-primary-300 transition-colors">
          <h3 class="font-medium text-neutral-900 mb-1">Country Guides</h3>
          <p class="text-sm text-neutral-500">Insurance by destination</p>
        </a>
        <a href="/providers" class="p-4 bg-white border border-neutral-200 rounded-lg hover:border-primary-300 transition-colors">
          <h3 class="font-medium text-neutral-900 mb-1">Provider Reviews</h3>
          <p class="text-sm text-neutral-500">Detailed insurer profiles</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
