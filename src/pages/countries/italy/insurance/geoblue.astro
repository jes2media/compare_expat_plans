---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Italy', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'italy-benefits', text: 'Italy-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Italy', href: '/countries/italy/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Aetna', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'italyPrice', header: 'Italy (Age 40)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Core coverage', italyPrice: '€140-190/mo' },
  { plan: 'Xplorer Premier', coverage: 'Comprehensive', italyPrice: '€200-280/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Italy"
  description="Guide to using GeoBlue in Italy. Blue Cross Blue Shield network, US expat focus."
  headline="GeoBlue Health Insurance in Italy"
  subheadline="GeoBlue for US expats in Italy—Blue Cross Blue Shield network access and strong US coverage."
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in Italy</h2>
  <p>
    GeoBlue, backed by Blue Cross Blue Shield, offers US expats in Italy access to one of America's largest provider networks when they return home. For Americans who want the familiarity of Blue Cross coverage abroad, GeoBlue provides that bridge.
  </p>
  <p>
    GeoBlue's mobile app and telemedicine features make it particularly convenient for tech-savvy expats.
  </p>

  <CTABox
    title="Get an Italy Quote"
    description="See GeoBlue pricing for US expats in Italy."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="italy-benefits">Italy-Specific Benefits</h2>
  <ul>
    <li><strong>Blue Cross network:</strong> Access to BCBS providers in the US</li>
    <li><strong>Mobile app:</strong> Find doctors, file claims, access ID cards</li>
    <li><strong>Telemedicine:</strong> 24/7 virtual doctor access</li>
    <li><strong>Visa compliance:</strong> Xplorer Premier meets Italian requirements</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose GeoBlue in Italy</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens with BCBS familiarity</li>
        <li>Tech-savvy expats who value app features</li>
        <li>Those who return to the US regularly</li>
        <li>Expats wanting telemedicine access</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens</li>
        <li>Those who won't use US coverage</li>
        <li>Budget-focused expats</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Italy?"
    description="Get a personalized GeoBlue quote."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />
</PageShell>
