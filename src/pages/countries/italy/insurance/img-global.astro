---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Italy', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'italy-benefits', text: 'Italy-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Italy', href: '/countries/italy/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'italyPrice', header: 'Italy (Age 40)' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Comprehensive', italyPrice: '€100-150/mo' },
  { plan: 'Global Medical + Outpatient', coverage: 'Full coverage', italyPrice: '€140-200/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Italy"
  description="Guide to using IMG Global in Italy. Budget-friendly international coverage for expats."
  headline="IMG Global Health Insurance in Italy"
  subheadline="IMG Global for expats in Italy—budget-friendly international coverage that meets visa requirements."
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Italy</h2>
  <p>
    IMG Global offers one of the most budget-friendly options for international health insurance in Italy. For expats who need visa-compliant coverage without premium pricing, IMG provides solid value.
  </p>
  <p>
    IMG is particularly popular with expats who plan to transition to Italy's SSN but need coverage for the initial period and visa application.
  </p>

  <CTABox
    title="Get an Italy Quote"
    description="See IMG Global pricing for expats in Italy."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    IMG typically costs 20-40% less than Cigna or BUPA while providing solid coverage. The trade-off is slightly less premium service and a smaller direct-billing network.
  </p>

  <h2 id="italy-benefits">Italy-Specific Benefits</h2>
  <ul>
    <li><strong>Visa compliance:</strong> Meets Italian visa insurance requirements</li>
    <li><strong>Budget-friendly:</strong> Lower premiums than premium competitors</li>
    <li><strong>Flexible terms:</strong> Various deductible options available</li>
    <li><strong>Worldwide coverage:</strong> Good for expats who travel frequently</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose IMG in Italy</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Those planning to transition to SSN</li>
        <li>Visa applicants needing coverage</li>
        <li>Expats comfortable with reimbursement</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium service</li>
        <li>Expats with pre-existing conditions</li>
        <li>Those needing extensive direct billing</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Italy?"
    description="Get a personalized IMG Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />
</PageShell>
