---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Italy', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'italy-benefits', text: 'Italy-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Italy', href: '/countries/italy/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'italyPrice', header: 'Italy (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient only', italyPrice: '€100-140/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', italyPrice: '€160-220/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', italyPrice: '€240-320/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Italy"
  description="Guide to using Allianz Care in Italy. Plans, pricing, and how it works for expats in Italy."
  headline="Allianz Care Health Insurance in Italy"
  subheadline="Allianz Care for expats in Italy—high-deductible savings, EU expertise, and flexible coverage options."
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Italy</h2>
  <p>
    Allianz Care is a strong choice for expats in Italy, particularly those who want high-deductible plans to reduce premiums or value working with a European-headquartered insurer with deep EU regulatory expertise.
  </p>
  <p>
    As a German company, Allianz understands European healthcare systems well and offers plans designed to work alongside or instead of public systems like Italy's SSN.
  </p>

  <CTABox
    title="Get an Italy Quote"
    description="See Allianz Care pricing for expats in Italy."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Options</h3>
  <p>
    Allianz offers deductibles up to €10,000. For expats who plan to use Italy's SSN for routine care but want international coverage for major medical events, a high-deductible Allianz plan can significantly reduce premiums.
  </p>

  <h2 id="italy-benefits">Italy-Specific Benefits</h2>
  <ul>
    <li><strong>EU regulatory expertise:</strong> Plans designed for European compliance</li>
    <li><strong>Visa compliance:</strong> Classic and Premium plans meet Italian visa requirements</li>
    <li><strong>Network hospitals:</strong> Coverage at major Italian private hospitals</li>
    <li><strong>Multilingual support:</strong> English, Italian, and other languages available</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Allianz in Italy</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those wanting high-deductible savings</li>
        <li>Expats who value EU insurer expertise</li>
        <li>People using SSN for routine care</li>
        <li>Those needing visa-compliant coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting lower deductibles</li>
        <li>Expats prioritizing US network access</li>
        <li>Budget-focused digital nomads</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Italy?"
    description="Get a personalized Allianz Care quote."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />
</PageShell>
