---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Italy', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'italy-benefits', text: 'Italy-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Italy', href: '/countries/italy/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs GeoBlue', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'italyPrice', header: 'Italy (Age 40)' },
];

const planRows = [
  { plan: 'Pioneer', coverage: 'Inpatient focused', italyPrice: '€150-200/mo' },
  { plan: 'Navigator', coverage: 'Comprehensive', italyPrice: '€220-300/mo' },
  { plan: 'Vantage', coverage: 'Premium + USA', italyPrice: '€300-420/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Italy"
  description="Guide to using Aetna International in Italy. US expat focus, integrated US coverage options."
  headline="Aetna International Health Insurance in Italy"
  subheadline="Aetna International for US expats in Italy—integrated US coverage, CVS Health network, and familiar American insurer."
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Quote"
  ctaButtonHref="/providers/aetna-international"
>
  <h2 id="overview">Aetna International in Italy</h2>
  <p>
    Aetna International is particularly well-suited for US citizens moving to Italy who want seamless coverage when returning to the US. As part of CVS Health, Aetna offers integration with US healthcare that other international insurers can't match.
  </p>
  <p>
    For American expats who travel back to the US regularly or have ongoing US healthcare relationships, Aetna provides valuable continuity.
  </p>

  <CTABox
    title="Get an Italy Quote"
    description="See Aetna International pricing for US expats in Italy."
    buttonText="Get Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="italy-benefits">Italy-Specific Benefits</h2>
  <ul>
    <li><strong>US return coverage:</strong> Seamless care when visiting the US</li>
    <li><strong>CVS integration:</strong> Pharmacy benefits in the US</li>
    <li><strong>Visa compliance:</strong> Navigator and Vantage meet Italian requirements</li>
    <li><strong>US customer service:</strong> Familiar American service style</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Aetna in Italy</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens moving to Italy</li>
        <li>Those who return to the US regularly</li>
        <li>Expats wanting US insurer familiarity</li>
        <li>Those with ongoing US healthcare needs</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens (other insurers may be better value)</li>
        <li>Those who won't return to the US</li>
        <li>Budget-focused expats</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Italy?"
    description="Get a personalized Aetna International quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />
</PageShell>
