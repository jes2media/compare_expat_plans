---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Italy', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'italy-benefits', text: 'Italy-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Italy', href: '/countries/italy/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'italyPrice', header: 'Italy (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient focused', italyPrice: '€120-160/mo' },
  { plan: 'Standard', coverage: 'Inpatient + Outpatient', italyPrice: '€180-250/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', italyPrice: '€260-350/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Italy"
  description="Guide to using AXA Global in Italy. EU-regulated, French insurer with strong European presence."
  headline="AXA Global Health Insurance in Italy"
  subheadline="AXA Global for expats in Italy—EU-regulated French insurer with strong European healthcare expertise."
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in Italy</h2>
  <p>
    AXA Global, headquartered in France, brings deep European expertise to international health insurance. For expats in Italy, AXA offers the familiarity of a major EU insurer with plans designed for European regulations and healthcare systems.
  </p>
  <p>
    AXA's strong presence in Italy through its local subsidiary means better integration with Italian healthcare providers.
  </p>

  <CTABox
    title="Get an Italy Quote"
    description="See AXA Global pricing for expats in Italy."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="italy-benefits">Italy-Specific Benefits</h2>
  <ul>
    <li><strong>EU regulation:</strong> Compliant with European insurance standards</li>
    <li><strong>Local presence:</strong> AXA has Italian subsidiary for local support</li>
    <li><strong>Visa compliance:</strong> Standard and Comprehensive meet Italian requirements</li>
    <li><strong>Multilingual:</strong> Italian, French, English support</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose AXA in Italy</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those who value EU insurer expertise</li>
        <li>Expats wanting local Italian support</li>
        <li>Those familiar with AXA brand</li>
        <li>Expats staying within Europe</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>US expats (Aetna or GeoBlue better)</li>
        <li>Those needing US coverage</li>
        <li>Budget-focused nomads</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Italy?"
    description="Get a personalized AXA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />
</PageShell>
