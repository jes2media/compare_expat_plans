---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Italy', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'italy-benefits', text: 'Italy-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Italy', href: '/countries/italy/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'italyPrice', header: 'Italy (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Day-patient', italyPrice: '€180-240/mo' },
  { plan: 'Gold', coverage: 'Comprehensive', italyPrice: '€260-350/mo' },
  { plan: 'Platinum', coverage: 'Premium + Wellness', italyPrice: '€350-480/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Italy"
  description="Guide to using BUPA Global in Italy. Premium coverage, mental health benefits, and pre-existing condition options."
  headline="BUPA Global Health Insurance in Italy"
  subheadline="BUPA Global for expats in Italy—premium coverage, strong mental health benefits, and pre-existing condition options."
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">BUPA Global in Italy</h2>
  <p>
    BUPA Global is known for premium service and better handling of pre-existing conditions and mental health coverage. For expats in Italy who want comprehensive coverage beyond what the SSN provides, BUPA offers a high-quality option.
  </p>
  <p>
    BUPA's strength is its service quality and willingness to cover conditions that other insurers might exclude or limit.
  </p>

  <CTABox
    title="Get an Italy Quote"
    description="See BUPA Global pricing for expats in Italy."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    BUPA offers some of the best mental health coverage in international insurance, with higher limits and fewer restrictions than competitors. Important for expats dealing with relocation stress or ongoing mental health needs.
  </p>

  <h2 id="italy-benefits">Italy-Specific Benefits</h2>
  <ul>
    <li><strong>Pre-existing conditions:</strong> More flexible underwriting than competitors</li>
    <li><strong>Mental health:</strong> Comprehensive psychological and psychiatric coverage</li>
    <li><strong>Network hospitals:</strong> Major private hospitals throughout Italy</li>
    <li><strong>Direct billing:</strong> Available at many Italian facilities</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose BUPA in Italy</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those with pre-existing conditions</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those wanting premium service</li>
        <li>Families needing comprehensive care</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Those who will primarily use SSN</li>
        <li>Digital nomads (SafetyWing cheaper)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Italy?"
    description="Get a personalized BUPA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />
</PageShell>
