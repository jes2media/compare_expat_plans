---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Ecuador', level: 2 },
  { id: 'why-axa', text: 'Why AXA for Ecuador', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Ecuador', href: '/countries/ecuador/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 55)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Core inpatient', price: '$190-250/mo' },
  { plan: 'Comfort', coverage: 'Inpatient + outpatient', price: '$250-320/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', price: '$320-400/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Ecuador"
  description="Guide to AXA Global international health insurance for expats in Ecuador. European insurance giant with comprehensive coverage."
  headline="AXA Global in Ecuador"
  subheadline="European insurance powerhouse with strong global network. Reliable coverage for Ecuador expats and retirees."
  heroBackgroundImage="/images/countries/ecuador-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in Ecuador</h2>
  <p>
    AXA is one of the world's largest insurance companies, bringing scale and stability to expats in Ecuador. For those who value major insurer backing, AXA provides reliable, comprehensive coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$250-400</p>
      <p class="text-sm text-neutral-600">Monthly (Age 55)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global Giant</p>
      <p class="text-sm text-neutral-600">Major insurer backing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">LATAM Presence</p>
      <p class="text-sm text-neutral-600">Regional expertise</p>
    </div>
  </div>

  <CTABox
    title="Get Your AXA Ecuador Quote"
    description="Comprehensive coverage from a global leader."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="why-axa">Why AXA for Ecuador</h2>

  <h3>Financial Stability</h3>
  <p>
    As one of the world's largest insurers, AXA's financial strength provides confidence for long-term coverage planning.
  </p>

  <h3>Latin America Expertise</h3>
  <ul>
    <li>Strong regional presence</li>
    <li>Understanding of Latin American healthcare</li>
    <li>Spanish-language support</li>
  </ul>

  <h3>Flexible Plans</h3>
  <ul>
    <li>Multiple coverage tiers</li>
    <li>Deductible options</li>
    <li>Optional dental, vision add-ons</li>
    <li>Regional or worldwide coverage</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 55-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Comfort+)</li>
    <li><strong>Emergency:</strong> Worldwide coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation and repatriation</li>
    <li><strong>Mental health:</strong> Coverage with limits</li>
    <li><strong>Chronic conditions:</strong> Covered after waiting period</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Moratorium or underwriting</li>
    <li>Maternity: Waiting period, optional</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>European Expats</h3>
  <p>
    Those familiar with AXA from Europe appreciate the continuity.
  </p>

  <h3>Long-term Residents</h3>
  <p>
    AXA's financial stability suits expats planning extended Ecuador stays.
  </p>

  <h3>Those Valuing Stability</h3>
  <p>
    If major insurer backing matters—financial strength, scale, long history—AXA delivers.
  </p>

  <CTABox
    title="Compare AXA Plans for Ecuador"
    description="Find comprehensive coverage from a global leader."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
