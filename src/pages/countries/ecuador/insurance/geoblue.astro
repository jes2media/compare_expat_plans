---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Ecuador', level: 2 },
  { id: 'why-geoblue', text: 'Why GeoBlue for Ecuador', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Ecuador', href: '/countries/ecuador/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/cigna-global-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 55)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Core coverage', price: '$200-250/mo' },
  { plan: 'Xplorer Select', coverage: 'Enhanced coverage', price: '$250-320/mo' },
  { plan: 'Xplorer Premier', coverage: 'Comprehensive', price: '$320-380/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Ecuador"
  description="Guide to GeoBlue international health insurance for American retirees in Ecuador. BCBS network access."
  headline="GeoBlue in Ecuador"
  subheadline="Blue Cross Blue Shield network for American retirees. Seamless coverage in Ecuador and back home in the US."
  heroBackgroundImage="/images/countries/ecuador-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in Ecuador</h2>
  <p>
    GeoBlue is the international arm of Blue Cross Blue Shield, making it particularly attractive for American retirees in Ecuador. The BCBS network access when visiting the US creates seamless care for those maintaining US ties.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$250-380</p>
      <p class="text-sm text-neutral-600">Monthly (Age 55)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">BCBS Network</p>
      <p class="text-sm text-neutral-600">US coverage included</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Made for US Expats</p>
      <p class="text-sm text-neutral-600">American-focused</p>
    </div>
  </div>

  <CTABox
    title="Get Your GeoBlue Ecuador Quote"
    description="BCBS-backed coverage for Americans in Ecuador."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="why-geoblue">Why GeoBlue for Ecuador</h2>

  <h3>BCBS Network Access</h3>
  <p>
    When you return to the US for family visits or preferred care:
  </p>
  <ul>
    <li>Over 90% of US hospitals in-network</li>
    <li>Hundreds of thousands of providers</li>
    <li>Negotiated rates, no balance billing</li>
  </ul>

  <h3>Designed for Americans</h3>
  <ul>
    <li>US-style customer service</li>
    <li>Familiar terminology and processes</li>
    <li>Easy coordination if you return to US</li>
  </ul>

  <h3>Ecuador Coverage</h3>
  <ul>
    <li>Access to Cuenca, Quito, Guayaquil facilities</li>
    <li>Global network of vetted providers</li>
    <li>24/7 emergency support</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 55-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> To US or appropriate facility</li>
    <li><strong>Prescriptions:</strong> Covered with benefits</li>
    <li><strong>Telehealth:</strong> Virtual doctor visits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Underwriting applies</li>
    <li>Primarily for Americans</li>
    <li>Maternity: Waiting periods and limits</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>American Retirees</h3>
  <p>
    US citizens who visit the US regularly for family or prefer US care for certain conditions.
  </p>

  <h3>Retirees with US Ties</h3>
  <p>
    Those maintaining family, property, or healthcare relationships in the US.
  </p>

  <h3>Those Planning to Eventually Return</h3>
  <p>
    If you might return to the US, GeoBlue provides easier transition.
  </p>

  <h3>Not Ideal For</h3>
  <p>
    Non-Americans generally find better value elsewhere.
  </p>

  <CTABox
    title="Compare GeoBlue Plans for Ecuador"
    description="Find coverage for Americans abroad."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
