---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Ecuador', level: 2 },
  { id: 'why-bupa', text: 'Why BUPA for Ecuador', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Ecuador', href: '/countries/ecuador/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 55)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Core inpatient', price: '$210-260/mo' },
  { plan: 'Comprehensive', coverage: 'Inpatient + outpatient', price: '$260-340/mo' },
  { plan: 'Elite', coverage: 'Full coverage', price: '$340-400/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Ecuador"
  description="Guide to BUPA Global international health insurance for expats in Ecuador. Premium service for retirees."
  headline="BUPA Global in Ecuador"
  subheadline="Trusted international insurer with excellent customer service. Comprehensive coverage for Ecuador's retiree community."
  heroBackgroundImage="/images/countries/ecuador-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">BUPA Global in Ecuador</h2>
  <p>
    BUPA Global is known for excellent customer service—important for retirees who may need more support navigating healthcare. With responsive claims processing and care coordination, BUPA delivers a premium experience.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$260-400</p>
      <p class="text-sm text-neutral-600">Monthly (Age 55)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Great Service</p>
      <p class="text-sm text-neutral-600">Excellent support</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Lifetime Renew</p>
      <p class="text-sm text-neutral-600">Guaranteed renewability</p>
    </div>
  </div>

  <CTABox
    title="Get Your BUPA Ecuador Quote"
    description="Premium coverage with excellent service."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="why-bupa">Why BUPA for Ecuador</h2>

  <h3>Customer Service Excellence</h3>
  <ul>
    <li>24/7 multilingual support</li>
    <li>Dedicated care coordinators</li>
    <li>Fast claims processing</li>
    <li>Proactive health management</li>
  </ul>

  <h3>Retiree-Focused</h3>
  <ul>
    <li>Lifetime renewability guarantee</li>
    <li>Wellness programs for older adults</li>
    <li>Care coordination for complex cases</li>
    <li>Medical evacuation included</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 55-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Comprehensive+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation included</li>
    <li><strong>Mental health:</strong> Comprehensive coverage</li>
    <li><strong>Wellness:</strong> Annual health checks</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Underwriting or moratorium</li>
    <li>Maternity: 12-month waiting period</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Service-Oriented Retirees</h3>
  <p>
    If responsive support matters—quick answers, care coordination, claims help—BUPA excels.
  </p>

  <h3>Those with Complex Health Needs</h3>
  <p>
    BUPA's care coordination is valuable for retirees managing multiple conditions or needing specialist referrals.
  </p>

  <h3>Long-term Planners</h3>
  <p>
    Lifetime renewability means you won't be dropped if health issues develop—important for retirement planning.
  </p>

  <CTABox
    title="Compare BUPA Plans for Ecuador"
    description="Find the right coverage level."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
