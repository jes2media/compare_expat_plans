---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Ecuador', level: 2 },
  { id: 'why-allianz', text: 'Why Allianz for Ecuador', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Ecuador', href: '/countries/ecuador/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 55)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient only', price: '$170-220/mo' },
  { plan: 'Classic', coverage: 'Inpatient + outpatient', price: '$220-290/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', price: '$290-350/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Ecuador"
  description="Guide to Allianz Care international health insurance for expats in Ecuador. Strong value coverage for retirees."
  headline="Allianz Care in Ecuador"
  subheadline="Excellent value from a trusted global insurer. Comprehensive coverage at competitive prices for Ecuador expats."
  heroBackgroundImage="/images/countries/ecuador-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Quote"
  ctaButtonHref="/providers/allianz-care"
>
  <h2 id="overview">Allianz Care in Ecuador</h2>
  <p>
    Allianz Care offers strong value for Ecuador expats and retirees—comprehensive international coverage at prices 10-20% below premium competitors. As one of the world's largest insurers, Allianz brings financial stability.
  </p>
  <p>
    For budget-conscious retirees who want quality coverage without top-tier pricing, Allianz delivers excellent balance.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$220-350</p>
      <p class="text-sm text-neutral-600">Monthly (Age 55)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Good Value</p>
      <p class="text-sm text-neutral-600">Competitive pricing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global Network</p>
      <p class="text-sm text-neutral-600">Worldwide coverage</p>
    </div>
  </div>

  <CTABox
    title="Get Your Allianz Ecuador Quote"
    description="Quality coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <h2 id="why-allianz">Why Allianz for Ecuador</h2>

  <h3>Price-to-Coverage Ratio</h3>
  <p>
    Allianz typically offers 10-20% lower premiums than Cigna or BUPA—meaningful savings for retirees on fixed incomes.
  </p>

  <h3>Flexible Plans</h3>
  <ul>
    <li>Multiple coverage tiers</li>
    <li>Adjustable deductibles</li>
    <li>Optional add-ons</li>
    <li>Regional or worldwide coverage</li>
  </ul>

  <h3>Latin America Presence</h3>
  <p>
    Allianz has strong operations in Latin America with understanding of regional healthcare systems.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 55-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Classic+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation and repatriation</li>
    <li><strong>Mental health:</strong> Coverage with limits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Moratorium or underwriting</li>
    <li>Maternity: Waiting period</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Value-Conscious Retirees</h3>
  <p>
    Those who want comprehensive coverage without premium prices. Savings add up over years of retirement.
  </p>

  <h3>Long-term Residents</h3>
  <p>
    Allianz's competitive pricing makes it sustainable for extended Ecuador stays.
  </p>

  <h3>Those Combining with IESS</h3>
  <p>
    Allianz pairs well with IESS enrollment—use IESS for routine local care, Allianz for major issues and care abroad.
  </p>

  <CTABox
    title="Compare Allianz Plans for Ecuador"
    description="Find the right coverage at the right price."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
