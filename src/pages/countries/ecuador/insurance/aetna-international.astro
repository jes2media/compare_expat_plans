---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Ecuador', level: 2 },
  { id: 'why-aetna', text: 'Why Aetna for Ecuador', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Ecuador', href: '/countries/ecuador/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs GeoBlue', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 55)' },
];

const planRows = [
  { plan: 'Pioneer', coverage: 'Core inpatient', price: '$220-280/mo' },
  { plan: 'Voyager', coverage: 'Inpatient + outpatient', price: '$280-360/mo' },
  { plan: 'Navigator', coverage: 'Comprehensive', price: '$360-440/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Ecuador"
  description="Guide to Aetna International health insurance for expats in Ecuador. US-backed coverage with global reach."
  headline="Aetna International in Ecuador"
  subheadline="US-backed international coverage with CVS Health resources. Strong choice for American retirees in Ecuador."
  heroBackgroundImage="/images/countries/ecuador-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Quote"
  ctaButtonHref="/go/aetna-international"
>
  <h2 id="overview">Aetna International in Ecuador</h2>
  <p>
    Aetna International, backed by CVS Health, serves many American retirees in Ecuador. For those who want coverage from a familiar US brand with strong US network access, Aetna provides continuity and reliability.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$280-440</p>
      <p class="text-sm text-neutral-600">Monthly (Age 55)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">CVS Health</p>
      <p class="text-sm text-neutral-600">Major US backing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">US Coverage</p>
      <p class="text-sm text-neutral-600">Strong US network</p>
    </div>
  </div>

  <CTABox
    title="Get Your Aetna Ecuador Quote"
    description="US-backed coverage for American retirees."
    buttonText="Get Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <h2 id="why-aetna">Why Aetna for Ecuador</h2>

  <h3>US Brand Familiarity</h3>
  <p>
    For American retirees, Aetna is a known quantity with familiar processes and customer service.
  </p>

  <h3>CVS Health Integration</h3>
  <ul>
    <li>CVS resources when in the US</li>
    <li>MinuteClinic visits covered</li>
    <li>Pharmacy integration</li>
    <li>Digital health tools</li>
  </ul>

  <h3>Strong US Coverage</h3>
  <p>
    Valuable for retirees who return to the US for family visits or prefer US care for certain conditions.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 55-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Voyager+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation included</li>
    <li><strong>Prescriptions:</strong> Covered with benefits</li>
    <li><strong>Wellness:</strong> Preventive care</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Underwriting or exclusions</li>
    <li>Maternity: Waiting periods apply</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>American Retirees</h3>
  <p>
    US citizens wanting familiar coverage with strong US network when visiting home.
  </p>

  <h3>Frequent US Visitors</h3>
  <p>
    Those returning to the US often benefit from Aetna's domestic network access.
  </p>

  <CTABox
    title="Compare Aetna Plans for Ecuador"
    description="Find US-backed coverage for your needs."
    buttonText="Get Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
