---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Australia', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Australia', href: '/countries/australia/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs Cigna', href: '/compare/aetna-international-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ausPrice', header: 'Australia (Age 35)' },
];

const planRows = [
  { plan: 'Core', coverage: 'Inpatient essential', ausPrice: '$170-220/mo' },
  { plan: 'Navigator', coverage: 'Inpatient + Outpatient', ausPrice: '$260-340/mo' },
  { plan: 'Pioneer', coverage: 'Comprehensive', ausPrice: '$340-440/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Australia"
  description="Guide to using Aetna International in Australia. US-based insurer with strong global presence and comprehensive coverage."
  headline="Aetna International Health Insurance in Australia"
  subheadline="US-based global coverage backed by CVS Health. Premium international insurance for Australia expats."
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Australia Quote"
  ctaButtonHref="/go/aetna-international"
>
  <h2 id="overview">Aetna International in Australia</h2>
  <p>
    Aetna International, backed by CVS Health, offers comprehensive global health insurance with strong presence in the Asia-Pacific region. For Australia expats, Aetna provides premium coverage with a network-focused approach.
  </p>
  <p>
    Aetna's strengths include robust coverage, good customer service, and a focus on wellness and preventive care. The pricing sits in the premium tier alongside Cigna and BUPA.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">CVS Backed</p>
      <p class="text-sm text-neutral-600">Financial strength</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">APAC Focus</p>
      <p class="text-sm text-neutral-600">Regional expertise</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Wellness</p>
      <p class="text-sm text-neutral-600">Preventive care</p>
    </div>
  </div>

  <CTABox
    title="Get an Aetna Quote for Australia"
    description="Premium international coverage from a US healthcare leader."
    buttonText="Get Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    Aetna International plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital stays, surgery, specialist treatment</li>
    <li><strong>Outpatient care:</strong> Physician visits, diagnostics (Navigator/Pioneer)</li>
    <li><strong>Mental health:</strong> Good coverage across plans</li>
    <li><strong>Maternity:</strong> Covered after waiting period</li>
    <li><strong>Wellness programs:</strong> Preventive care, health coaching</li>
    <li><strong>Chronic condition management:</strong> Ongoing support programs</li>
  </ul>

  <h3>Wellness Focus</h3>
  <p>
    Aetna emphasizes preventive care and wellness:
  </p>
  <ul>
    <li>Annual health screenings</li>
    <li>Wellness incentive programs</li>
    <li>Digital health tools and apps</li>
    <li>Chronic condition support</li>
  </ul>

  <h3>How It Works in Australia</h3>
  <p>
    Aetna has relationships with major Australian hospitals and can arrange direct billing in many cases. For smaller providers, standard reimbursement applies. Pre-authorization is required for planned hospitalizations.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Pricing Position</h3>
  <p>
    Aetna International sits in the premium tier, typically priced between Cigna and BUPA. For comprehensive coverage with wellness benefits, expect $260-400/month depending on plan selection.
  </p>

  <h2 id="who-its-for">Who Should Choose Aetna in Australia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US expats (familiar brand)</li>
        <li>Those valuing wellness programs</li>
        <li>Corporate assignees</li>
        <li>Families wanting comprehensive care</li>
        <li>Expats with chronic conditions</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious (Allianz, IMG)</li>
        <li>UK expats (BUPA familiarity)</li>
        <li>Short-term travelers (SafetyWing)</li>
        <li>Students (need OSHC)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium US-Style Coverage?"
    description="Get a personalized Aetna International quote for Australia."
    buttonText="Get Your Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Actual premiums depend on age, health history, and coverage selections.
    </p>
  </div>
</PageShell>
