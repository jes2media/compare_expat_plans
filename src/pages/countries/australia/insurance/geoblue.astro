---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Australia', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Australia', href: '/countries/australia/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/geoblue-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ausPrice', header: 'Australia (Age 35)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Inpatient + limited outpatient', ausPrice: '$180-240/mo' },
  { plan: 'Xplorer Select', coverage: 'Comprehensive', ausPrice: '$280-360/mo' },
  { plan: 'Xplorer Premier', coverage: 'Premium + US coverage', ausPrice: '$400-550/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Australia"
  description="Guide to using GeoBlue in Australia. Blue Cross Blue Shield international coverage popular with US expats."
  headline="GeoBlue Health Insurance in Australia"
  subheadline="Blue Cross Blue Shield's international arm. Strong option for US expats in Australia."
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Australia Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in Australia</h2>
  <p>
    GeoBlue is the international insurance arm of Blue Cross Blue Shield, one of America's most recognized health insurance brands. For US expats in Australia, GeoBlue offers familiar coverage style with global reach.
  </p>
  <p>
    GeoBlue's Xplorer plans provide comprehensive international coverage that can include US coverage—valuable for expats who return to the US frequently or maintain ties there.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">BCBS</p>
      <p class="text-sm text-neutral-600">Brand backing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">US Coverage</p>
      <p class="text-sm text-neutral-600">Available option</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Strong App</p>
      <p class="text-sm text-neutral-600">Digital tools</p>
    </div>
  </div>

  <CTABox
    title="Get a GeoBlue Quote for Australia"
    description="Blue Cross Blue Shield international coverage."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    GeoBlue Xplorer plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital, surgery, specialist treatment</li>
    <li><strong>Outpatient care:</strong> Physician visits, labs, imaging</li>
    <li><strong>Prescription drugs:</strong> Covered with formulary</li>
    <li><strong>Mental health:</strong> Coverage varies by plan</li>
    <li><strong>Maternity:</strong> Available with waiting period</li>
    <li><strong>US coverage:</strong> Optional add-on or included (Premier)</li>
  </ul>

  <h3>US Coverage Option</h3>
  <p>
    Unlike most international insurers, GeoBlue can include meaningful US coverage through the BCBS network. For expats who:
  </p>
  <ul>
    <li>Return to the US frequently</li>
    <li>Have family in the US</li>
    <li>May eventually repatriate</li>
  </ul>
  <p>
    This US coverage option is a significant differentiator from competitors.
  </p>

  <h3>Digital Experience</h3>
  <p>
    GeoBlue's mobile app and digital tools are well-regarded:
  </p>
  <ul>
    <li>Provider finder worldwide</li>
    <li>Digital ID cards</li>
    <li>Claims submission via app</li>
    <li>Telehealth options</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>US Coverage Pricing Impact</h3>
  <p>
    Plans including US coverage cost significantly more due to US healthcare costs. If you don't need US coverage, GeoBlue's pricing without it is more competitive with other international insurers.
  </p>

  <h2 id="who-its-for">Who Should Choose GeoBlue in Australia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US expats needing US coverage</li>
        <li>Those familiar with BCBS</li>
        <li>Expats returning to US frequently</li>
        <li>Tech-savvy users (good app)</li>
        <li>Families with US ties</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US expats (other insurers often better value)</li>
        <li>Budget-focused (Allianz, AXA)</li>
        <li>UK expats (BUPA familiarity)</li>
        <li>Short-term stays (SafetyWing)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for BCBS International Coverage?"
    description="Get a personalized GeoBlue quote for Australia."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates. US coverage significantly affects pricing. Get a personalized quote for accurate costs.
    </p>
  </div>
</PageShell>
