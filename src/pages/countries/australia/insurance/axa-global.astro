---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Australia', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Australia', href: '/countries/australia/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ausPrice', header: 'Australia (Age 35)' },
];

const planRows = [
  { plan: 'Comfort', coverage: 'Essential coverage', ausPrice: '$130-170/mo' },
  { plan: 'Standard', coverage: 'Standard + Outpatient', ausPrice: '$180-240/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', ausPrice: '$250-320/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Australia"
  description="Guide to using AXA Global in Australia. EU-regulated international coverage with competitive pricing."
  headline="AXA Global Health Insurance in Australia"
  subheadline="EU-regulated international coverage with strong value. Budget-friendly option for Australia expats."
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Australia Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in Australia</h2>
  <p>
    AXA Global offers EU-regulated international health insurance with competitive pricing. For budget-conscious expats in Australia who still want comprehensive international coverage, AXA provides solid value.
  </p>
  <p>
    AXA typically prices 20-30% below premium competitors like Cigna and BUPA while offering comparable core coverage. This makes it attractive for expats who want quality coverage without premium pricing.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU Regulated</p>
      <p class="text-sm text-neutral-600">Consumer protections</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">20-30%</p>
      <p class="text-sm text-neutral-600">Below premium tier</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Coverage area</p>
    </div>
  </div>

  <CTABox
    title="Get an AXA Quote for Australia"
    description="Quality international coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    AXA Global plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital stays, surgery, cancer treatment</li>
    <li><strong>Outpatient care:</strong> GP and specialist visits (Standard+)</li>
    <li><strong>Mental health:</strong> Covered on higher tiers</li>
    <li><strong>Maternity:</strong> Available with 12-month waiting period</li>
    <li><strong>Emergency evacuation:</strong> Included (rarely needed in Australia)</li>
    <li><strong>Dental and vision:</strong> Optional add-ons</li>
  </ul>

  <h3>How It Works in Australia</h3>
  <p>
    AXA operates primarily on a reimbursement basis in Australia. You'll typically pay for care and submit claims for reimbursement. Some larger hospitals may offer direct billing with advance arrangement.
  </p>
  <p>
    Claims processing is generally efficient through the online portal or mobile app.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    AXA's pricing advantage makes it competitive with mid-tier options while offering coverage comparable to premium plans. For a 35-year-old, you might save $50-100/month compared to Cigna or BUPA.
  </p>
  <p>
    The trade-off: less extensive direct billing network and potentially less hand-holding on complex claims.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA in Australia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Self-sufficient individuals</li>
        <li>Those comfortable with reimbursement</li>
        <li>EU expats (familiar brand)</li>
        <li>Long-term residents seeking value</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium service (Cigna)</li>
        <li>Corporate packages (BUPA, Cigna)</li>
        <li>US expats needing US coverage (GeoBlue)</li>
        <li>Short-term travelers (SafetyWing)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized AXA Global quote for Australia."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Verify coverage details directly with AXA before purchasing.
    </p>
  </div>
</PageShell>
