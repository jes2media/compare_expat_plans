---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Australia', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Australia', href: '/countries/australia/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/allianz-care-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ausPrice', header: 'Australia (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', ausPrice: '$140-180/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', ausPrice: '$200-260/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', ausPrice: '$280-350/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Australia"
  description="Guide to using Allianz Care in Australia. German-backed international coverage with strong value for long-term expats."
  headline="Allianz Care Health Insurance in Australia"
  subheadline="German reliability meets Australian healthcare. Strong value for expats seeking comprehensive international coverage."
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Australia Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Australia</h2>
  <p>
    Allianz Care offers German-backed international health insurance with competitive pricing for Australia. As one of the world's largest insurers, Allianz provides the financial stability and service quality expats need, often at 15-25% less than premium competitors.
  </p>
  <p>
    For long-term expats in Australia, Allianz balances comprehensive coverage with reasonable pricing. The plan meets visa requirements and travels with you if you relocate.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">€2M+</p>
      <p class="text-sm text-neutral-600">Maximum coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">15-25%</p>
      <p class="text-sm text-neutral-600">Below premium competitors</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Coverage area</p>
    </div>
  </div>

  <CTABox
    title="Get an Allianz Quote for Australia"
    description="Comprehensive coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    Allianz Care plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital stays, surgery, cancer treatment</li>
    <li><strong>Outpatient care:</strong> GP and specialist visits (Classic/Premium)</li>
    <li><strong>Mental health:</strong> Covered on higher tiers</li>
    <li><strong>Maternity:</strong> Available with waiting period</li>
    <li><strong>Emergency evacuation:</strong> Included (though rarely needed in Australia)</li>
  </ul>

  <h3>How It Works in Australia</h3>
  <p>
    Allianz operates primarily on a reimbursement model in Australia. You pay for care and submit claims for reimbursement. Some larger hospitals may offer direct billing if pre-arranged.
  </p>
  <p>
    Claims processing is typically efficient, with most claims processed within 5-10 business days. The mobile app allows easy claim submission.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Comparison</h3>
  <p>
    Allianz typically costs 15-25% less than Cigna or BUPA for similar coverage levels. For a healthy 35-year-old, you might save $50-100/month while getting comparable core benefits.
  </p>
  <p>
    The trade-off: slightly smaller direct billing network and potentially longer claims processing for complex cases.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Australia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Long-term Australia residents</li>
        <li>EU expats (familiar brand)</li>
        <li>Those comfortable with reimbursement</li>
        <li>Expats who travel regionally</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting extensive direct billing (Cigna)</li>
        <li>Corporate packages with premium service</li>
        <li>Digital nomads (SafetyWing)</li>
        <li>Students (need OSHC)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized Allianz Care quote for Australia."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Actual premiums depend on age, health history, and coverage selections.
    </p>
  </div>
</PageShell>
