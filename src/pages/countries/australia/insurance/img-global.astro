---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Australia', level: 2 },
  { id: 'coverage', text: 'Coverage Options', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Australia', href: '/countries/australia/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs SafetyWing', href: '/compare/img-global-vs-safetywing' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ausPrice', header: 'Australia (Age 35)' },
];

const planRows = [
  { plan: 'Global Medical', coverage: 'Essential inpatient', ausPrice: '$120-160/mo' },
  { plan: 'Global Medical Plus', coverage: 'Inpatient + Outpatient', ausPrice: '$180-240/mo' },
  { plan: 'Global Medical Platinum', coverage: 'Comprehensive', ausPrice: '$240-320/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Australia"
  description="Guide to using IMG Global in Australia. Flexible international coverage with competitive pricing for expats."
  headline="IMG Global Health Insurance in Australia"
  subheadline="Flexible international coverage with competitive pricing. Good mid-range option for Australia expats."
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Australia Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in Australia</h2>
  <p>
    IMG (International Medical Group) offers flexible international health insurance at competitive prices. For Australia expats, IMG provides a solid mid-tier option between budget travel medical and premium international plans.
  </p>
  <p>
    IMG's Global Medical Insurance plans meet Australian visa requirements while offering the flexibility to customize coverage and deductibles to fit your budget.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$8M</p>
      <p class="text-sm text-neutral-600">Maximum available</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Flexible</p>
      <p class="text-sm text-neutral-600">Deductible options</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Good Value</p>
      <p class="text-sm text-neutral-600">Price point</p>
    </div>
  </div>

  <CTABox
    title="Get an IMG Quote for Australia"
    description="Flexible coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Options</h2>
  <p>
    IMG Global Medical Insurance includes:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital, surgery, intensive care</li>
    <li><strong>Outpatient care:</strong> Doctor visits, specialists (Plus/Platinum)</li>
    <li><strong>Prescription drugs:</strong> Covered per plan terms</li>
    <li><strong>Mental health:</strong> Available on higher tiers</li>
    <li><strong>Maternity:</strong> Optional rider with waiting period</li>
    <li><strong>Emergency evacuation:</strong> Included</li>
  </ul>

  <h3>Customization</h3>
  <p>
    IMG allows significant customization:
  </p>
  <ul>
    <li>Deductibles from $250 to $25,000</li>
    <li>Coverage limits from $1M to $8M</li>
    <li>Optional riders for dental, vision, maternity</li>
    <li>Area of coverage selection</li>
  </ul>

  <h3>How It Works in Australia</h3>
  <p>
    IMG primarily operates on a reimbursement basis in Australia. Pay for care at any provider and submit claims for reimbursement. Some pre-authorization may be required for major procedures.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Saving with Higher Deductibles</h3>
  <p>
    IMG's flexible deductible options can significantly reduce premiums:
  </p>
  <ul>
    <li><strong>$250 deductible:</strong> Prices shown above</li>
    <li><strong>$2,500 deductible:</strong> 20-30% savings</li>
    <li><strong>$5,000 deductible:</strong> 30-40% savings</li>
  </ul>
  <p>
    For healthy individuals comfortable with higher out-of-pocket costs, a high-deductible plan can make comprehensive coverage more affordable.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in Australia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats wanting real coverage</li>
        <li>Those comfortable with reimbursement model</li>
        <li>Healthy individuals (high deductible)</li>
        <li>Expats wanting flexible options</li>
        <li>Mid-term stays (1-3 years)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium direct billing (Cigna)</li>
        <li>Corporate packages (BUPA, Cigna)</li>
        <li>Very short stays (SafetyWing)</li>
        <li>Students (need OSHC)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Flexible Coverage?"
    description="Get a personalized IMG Global quote for Australia."
    buttonText="Get Your Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old with moderate deductible. Actual costs depend on specific selections.
    </p>
  </div>
</PageShell>
