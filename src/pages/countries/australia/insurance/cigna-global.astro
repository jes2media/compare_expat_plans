---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in Australia', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'network', text: 'Hospital Network', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Cigna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Australia', href: '/countries/australia/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs BUPA Global', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ausPrice', header: 'Australia (Age 35)' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Inpatient only', ausPrice: '$180-220/mo' },
  { plan: 'Gold', coverage: 'Inpatient + Outpatient', ausPrice: '$280-350/mo' },
  { plan: 'Platinum', coverage: 'Comprehensive', ausPrice: '$350-450/mo' },
];
---

<PageShell
  title="Cigna Global Health Insurance in Australia"
  description="Guide to using Cigna Global in Australia. Premium international coverage with excellent hospital networks in Sydney, Melbourne, Brisbane, and Perth."
  headline="Cigna Global Health Insurance in Australia"
  subheadline="Premium international coverage with strong Australian hospital networks. Ideal for executives and families."
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Australia Quote"
  ctaButtonHref="/providers/cigna-global"
>
  <h2 id="overview">Cigna Global in Australia</h2>
  <p>
    Cigna Global is a top choice for expats in Australia seeking premium international health coverage. With established relationships with major private hospitals across Sydney, Melbourne, Brisbane, and Perth, Cigna offers seamless care in Australia's excellent healthcare system.
  </p>
  <p>
    For corporate expats and families, Cigna's comprehensive coverage and service quality justify the premium pricing. The plan travels with you if you relocate and provides visa-compliant coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$2M+</p>
      <p class="text-sm text-neutral-600">Maximum coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Direct Billing</p>
      <p class="text-sm text-neutral-600">Major hospitals</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Visa Compliant</p>
      <p class="text-sm text-neutral-600">Meets requirements</p>
    </div>
  </div>

  <CTABox
    title="Get a Cigna Australia Quote"
    description="Premium coverage for Australia's expensive healthcare market."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    Cigna Global plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Private rooms, surgery, ICU, cancer treatment</li>
    <li><strong>Outpatient care:</strong> GP visits, specialists, diagnostics (Gold/Platinum)</li>
    <li><strong>Mental health:</strong> Inpatient and outpatient coverage</li>
    <li><strong>Maternity:</strong> Covered after waiting period (10-12 months)</li>
    <li><strong>Dental and vision:</strong> Optional add-ons available</li>
    <li><strong>Wellness benefits:</strong> Health screenings, vaccinations</li>
  </ul>

  <h3>Australia-Specific Benefits</h3>
  <p>
    Cigna's coverage works well in Australia because:
  </p>
  <ul>
    <li>Direct billing at most major private hospitals</li>
    <li>24/7 support with Australia-aware staff</li>
    <li>Cashless treatment at network facilities</li>
    <li>Letter for visa compliance available on request</li>
  </ul>

  <h2 id="network">Hospital Network</h2>
  <p>
    Cigna has relationships with Australia's leading private hospital groups:
  </p>
  <ul>
    <li><strong>Sydney:</strong> St Vincent's Private, Prince of Wales Private, Mater Hospital</li>
    <li><strong>Melbourne:</strong> Epworth, Cabrini, St Vincent's Private</li>
    <li><strong>Brisbane:</strong> Mater Private, St Andrew's, Wesley Hospital</li>
    <li><strong>Perth:</strong> St John of God, Hollywood Private</li>
  </ul>
  <p>
    Direct billing is available at most network hospitals. For smaller clinics or regional facilities, you may need to pay and claim reimbursement.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Deductible Options</h3>
  <p>
    Adding a deductible reduces premiums significantly:
  </p>
  <ul>
    <li><strong>$0 deductible:</strong> Full pricing as shown</li>
    <li><strong>$500 deductible:</strong> 15-20% premium reduction</li>
    <li><strong>$2,500 deductible:</strong> 25-35% premium reduction</li>
  </ul>
  <p>
    Given Australia's high healthcare costs, even a moderate deductible gets used quickly if you need care.
  </p>

  <h2 id="who-its-for">Who Should Choose Cigna in Australia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Corporate expats and executives</li>
        <li>Families with children</li>
        <li>Those wanting premium service</li>
        <li>Expats needing visa compliance letters</li>
        <li>People who value direct billing</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats (try Allianz, AXA)</li>
        <li>Digital nomads on short stays (SafetyWing)</li>
        <li>Students (need OSHC instead)</li>
        <li>Those prioritizing lowest price</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized Cigna Global quote for Australia."
    buttonText="Get Your Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Actual premiums depend on age, health history, and coverage selections. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
