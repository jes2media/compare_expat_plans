---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in Japan', level: 2 },
  { id: 'why-cigna', text: 'Why Cigna for Japan', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Japan', href: '/countries/japan/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs BUPA', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 40)' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Core inpatient', price: '$220-280/mo' },
  { plan: 'Gold', coverage: 'Inpatient + outpatient', price: '$280-350/mo' },
  { plan: 'Platinum', coverage: 'Comprehensive', price: '$350-420/mo' },
];
---

<PageShell
  title="Cigna Global Health Insurance in Japan"
  description="Guide to Cigna Global international health insurance for expats in Japan. English-speaking care coordination and comprehensive coverage."
  headline="Cigna Global in Japan"
  subheadline="Premium international coverage with strong Japan presence. English-speaking support and international hospital access."
  heroBackgroundImage="/images/countries/japan-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Quote"
  ctaButtonHref="/providers/cigna-global"
>
  <h2 id="overview">Cigna Global in Japan</h2>
  <p>
    Cigna Global is one of the strongest international insurance options for Japan expats. With established relationships at English-speaking hospitals and dedicated care coordination, Cigna helps navigate Japan's excellent but Japanese-language healthcare system.
  </p>
  <p>
    For expats who want comprehensive coverage with genuine support in English, Cigna delivers a premium experience that complements mandatory NHI enrollment.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$280-420</p>
      <p class="text-sm text-neutral-600">Monthly (Age 40)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">English Support</p>
      <p class="text-sm text-neutral-600">Care coordination</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Direct Billing</p>
      <p class="text-sm text-neutral-600">International hospitals</p>
    </div>
  </div>

  <CTABox
    title="Get Your Cigna Japan Quote"
    description="Comprehensive coverage for Japan expats."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <h2 id="why-cigna">Why Cigna for Japan</h2>

  <h3>Hospital Network</h3>
  <p>
    Cigna has relationships with Japan's international hospitals:
  </p>
  <ul>
    <li><strong>St. Luke's International Hospital:</strong> Direct billing, English-speaking staff</li>
    <li><strong>Tokyo Medical and Surgical Clinic:</strong> Primary care in English</li>
    <li><strong>International clinics:</strong> Throughout Tokyo, Osaka, major cities</li>
  </ul>

  <h3>Care Coordination</h3>
  <p>
    Cigna's Japan support includes:
  </p>
  <ul>
    <li>English-speaking assistance finding providers</li>
    <li>Help navigating Japanese healthcare system</li>
    <li>Translation and interpretation services</li>
    <li>Appointment scheduling assistance</li>
  </ul>

  <h3>Global Coverage</h3>
  <ul>
    <li>Worldwide coverage when traveling</li>
    <li>US coverage available as option</li>
    <li>Medical evacuation if needed</li>
    <li>Coverage continues if you relocate</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 40-year-old. Japan's high healthcare costs mean higher premiums than Southeast Asia.
  </p>

  <h3>Cost Factors</h3>
  <ul>
    <li><strong>Age:</strong> Significant increases after 50</li>
    <li><strong>US coverage:</strong> Adding US increases premiums 30-50%</li>
    <li><strong>Deductible:</strong> Higher deductibles reduce costs 20-30%</li>
    <li><strong>Coverage area:</strong> Asia-only cheaper than worldwide</li>
  </ul>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Gold+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation if needed</li>
    <li><strong>Cancer:</strong> Full treatment coverage</li>
    <li><strong>Mental health:</strong> Coverage included</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: 2-year moratorium or underwriting</li>
    <li>Dental/vision: Optional add-on</li>
    <li>NHI still required for most visa categories</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Long-term Expats</h3>
  <p>
    Those settling in Japan for years benefit from Cigna's care coordination and comprehensive coverage as a supplement to NHI.
  </p>

  <h3>Corporate Expats</h3>
  <p>
    Many companies provide Cigna as part of Japan expat packages. If offered, it's an excellent choice.
  </p>

  <h3>Those Wanting English Support</h3>
  <p>
    If navigating Japanese healthcare in Japanese feels daunting, Cigna's English-language support provides peace of mind.
  </p>

  <CTABox
    title="Compare Cigna Plans for Japan"
    description="Find the right coverage level."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
