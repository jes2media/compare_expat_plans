---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Japan', level: 2 },
  { id: 'why-bupa', text: 'Why BUPA for Japan', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Japan', href: '/countries/japan/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 40)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Core inpatient', price: '$200-250/mo' },
  { plan: 'Comprehensive', coverage: 'Inpatient + outpatient', price: '$250-320/mo' },
  { plan: 'Elite', coverage: 'Full coverage', price: '$320-380/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Japan"
  description="Guide to BUPA Global international health insurance for expats in Japan. Premium service and comprehensive coverage."
  headline="BUPA Global in Japan"
  subheadline="Trusted international insurer with excellent customer service. Strong Japan presence and English-language support."
  heroBackgroundImage="/images/countries/japan-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Japan</h2>
  <p>
    BUPA Global is known for excellent customer service and has a strong presence in Japan's expat market. For those who value responsive support and help navigating Japanese healthcare, BUPA delivers a premium experience.
  </p>
  <p>
    With decades of experience serving expats worldwide and established Japan relationships, BUPA provides reliable coverage to complement mandatory NHI.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$250-380</p>
      <p class="text-sm text-neutral-600">Monthly (Age 40)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Great Service</p>
      <p class="text-sm text-neutral-600">Excellent support</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Japan Presence</p>
      <p class="text-sm text-neutral-600">Strong local network</p>
    </div>
  </div>

  <CTABox
    title="Get Your BUPA Japan Quote"
    description="Premium coverage with excellent service."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="why-bupa">Why BUPA for Japan</h2>

  <h3>Customer Service Excellence</h3>
  <ul>
    <li>24/7 multilingual support</li>
    <li>Dedicated care coordinators for Japan</li>
    <li>Fast claims processing</li>
    <li>Help navigating Japanese healthcare system</li>
  </ul>

  <h3>Japan Network</h3>
  <ul>
    <li><strong>St. Luke's International Hospital:</strong> Direct billing</li>
    <li><strong>International clinics:</strong> Throughout major cities</li>
    <li><strong>English-speaking providers:</strong> Network access</li>
  </ul>

  <h3>Comprehensive Benefits</h3>
  <ul>
    <li>Lifetime renewability guarantee</li>
    <li>Mental health coverage</li>
    <li>Wellness programs</li>
    <li>Global coverage for travel</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 40-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Comprehensive+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation included</li>
    <li><strong>Mental health:</strong> Comprehensive coverage</li>
    <li><strong>Wellness:</strong> Annual health checks</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Underwriting or moratorium</li>
    <li>Maternity: 12-month waiting period</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Service-Oriented Expats</h3>
  <p>
    If responsive customer service matters—quick answers, care coordination, claims support—BUPA excels.
  </p>

  <h3>Long-term Expats</h3>
  <p>
    BUPA's lifetime renewability and strong Japan presence suit those planning extended stays.
  </p>

  <h3>Families</h3>
  <p>
    BUPA's family plans and maternity coverage make it solid for expat families in Japan.
  </p>

  <CTABox
    title="Compare BUPA Plans for Japan"
    description="Find the right coverage level."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
