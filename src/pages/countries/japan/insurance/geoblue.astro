---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Japan', level: 2 },
  { id: 'why-geoblue', text: 'Why GeoBlue for Japan', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Japan', href: '/countries/japan/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/cigna-global-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 40)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Core coverage', price: '$190-240/mo' },
  { plan: 'Xplorer Select', coverage: 'Enhanced coverage', price: '$240-300/mo' },
  { plan: 'Xplorer Premier', coverage: 'Comprehensive', price: '$300-360/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Japan"
  description="Guide to GeoBlue international health insurance for American expats in Japan. BCBS network access and seamless US coverage."
  headline="GeoBlue in Japan"
  subheadline="Blue Cross Blue Shield network for American expats. Seamless coverage in Japan and back home in the US."
  heroBackgroundImage="/images/countries/japan-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Quote"
  ctaButtonHref="/providers/geoblue"
>
  <h2 id="overview">GeoBlue in Japan</h2>
  <p>
    GeoBlue is the international arm of Blue Cross Blue Shield, making it attractive for American expats in Japan. The BCBS network access when in the US—combined with solid international coverage—creates seamless care for those splitting time between Japan and home.
  </p>
  <p>
    For Americans who want familiar brand comfort with genuine international capabilities, GeoBlue bridges the gap as a supplement to mandatory NHI.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$240-360</p>
      <p class="text-sm text-neutral-600">Monthly (Age 40)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">BCBS Network</p>
      <p class="text-sm text-neutral-600">US coverage included</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Made for US Expats</p>
      <p class="text-sm text-neutral-600">American-focused</p>
    </div>
  </div>

  <CTABox
    title="Get Your GeoBlue Japan Quote"
    description="BCBS-backed coverage for Americans in Japan."
    buttonText="Get Quote"
    buttonHref="/providers/geoblue"
    variant="highlight"
  />

  <h2 id="why-geoblue">Why GeoBlue for Japan</h2>

  <h3>BCBS Network Access</h3>
  <p>
    When you return to the US, you have access to the Blue Cross Blue Shield network:
  </p>
  <ul>
    <li>Over 90% of US hospitals in-network</li>
    <li>Hundreds of thousands of providers</li>
    <li>Negotiated rates, no balance billing</li>
    <li>Familiar experience for Americans</li>
  </ul>

  <h3>Designed for Americans</h3>
  <ul>
    <li>US-style customer service</li>
    <li>Familiar terminology and processes</li>
    <li>Easy coordination if you return to US</li>
  </ul>

  <h3>Japan Coverage</h3>
  <ul>
    <li>Access to international hospitals</li>
    <li>Direct billing at network facilities</li>
    <li>Global network of vetted providers</li>
    <li>24/7 emergency support</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 40-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> To US or appropriate facility</li>
    <li><strong>Prescriptions:</strong> Covered with benefits</li>
    <li><strong>Telehealth:</strong> Virtual doctor visits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Underwriting applies</li>
    <li>Primarily for Americans</li>
    <li>Maternity: Waiting periods and limits</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>American Expats</h3>
  <p>
    US citizens in Japan who travel back to the US regularly for family or business.
  </p>

  <h3>Expats with US Ties</h3>
  <p>
    Americans with family, property, or business in the US benefit from GeoBlue's dual focus.
  </p>

  <h3>Those Planning to Return</h3>
  <p>
    If you might eventually return to the US, GeoBlue provides easier transition.
  </p>

  <h3>Not Ideal For</h3>
  <p>
    Non-Americans generally find better value elsewhere. GeoBlue's US focus is wasted without US coverage needs.
  </p>

  <CTABox
    title="Compare GeoBlue Plans for Japan"
    description="Find coverage for Americans abroad."
    buttonText="Get Quote"
    buttonHref="/providers/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
