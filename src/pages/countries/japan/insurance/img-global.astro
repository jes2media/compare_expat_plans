---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Japan', level: 2 },
  { id: 'why-img', text: 'Why IMG for Japan', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Japan', href: '/countries/japan/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs SafetyWing', href: '/compare/img-global-vs-safetywing' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 40)' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Inpatient + outpatient', price: '$180-230/mo' },
  { plan: 'Global Medical Insurance Plus', coverage: 'Comprehensive', price: '$230-280/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Japan"
  description="Guide to IMG Global international health insurance for expats in Japan. Flexible, affordable coverage."
  headline="IMG Global in Japan"
  subheadline="Flexible international coverage at competitive prices. Good middle-ground option for Japan expats."
  heroBackgroundImage="/images/countries/japan-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in Japan</h2>
  <p>
    IMG Global offers a strong middle ground between budget travel insurance and premium international plans. For Japan expats who want comprehensive coverage without top-tier prices, IMG delivers solid value.
  </p>
  <p>
    With flexible options and competitive pricing, IMG works well as a supplement to mandatory NHI for expats seeking English-language care options.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$180-280</p>
      <p class="text-sm text-neutral-600">Monthly (Age 40)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Flexible</p>
      <p class="text-sm text-neutral-600">Customizable plans</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Good Value</p>
      <p class="text-sm text-neutral-600">Competitive pricing</p>
    </div>
  </div>

  <CTABox
    title="Get Your IMG Japan Quote"
    description="Flexible coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="why-img">Why IMG for Japan</h2>

  <h3>Price-Performance Balance</h3>
  <p>
    IMG sits between budget options and premium insurers—comprehensive coverage at reasonable prices for Japan's higher-cost market.
  </p>

  <h3>Plan Flexibility</h3>
  <ul>
    <li>Multiple deductible options ($0 to $25,000)</li>
    <li>Regional or worldwide coverage</li>
    <li>Annual or semi-annual payments</li>
    <li>Add or exclude specific benefits</li>
  </ul>

  <h3>Hospital Access</h3>
  <ul>
    <li>Coverage at international hospitals in Japan</li>
    <li>Access to English-speaking facilities</li>
    <li>Worldwide network for travel</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 40-year-old. Higher deductibles can reduce premiums significantly.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation included</li>
    <li><strong>Prescriptions:</strong> Outpatient medications</li>
    <li><strong>Mental health:</strong> Coverage with limits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: 12-month exclusion</li>
    <li>Maternity: Optional, requires waiting period</li>
    <li>Less Japan-specific support than Cigna/BUPA</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Cost-Conscious Expats</h3>
  <p>
    Those wanting comprehensive coverage without premium prices find IMG hits the sweet spot.
  </p>

  <h3>Medium-term Stays</h3>
  <p>
    For 1-5 year Japan stays, IMG provides appropriate coverage without long-term premium commitments.
  </p>

  <h3>Self-Sufficient Expats</h3>
  <p>
    If you don't need extensive hand-holding and are comfortable managing some things independently, IMG offers good value.
  </p>

  <CTABox
    title="Compare IMG Plans for Japan"
    description="Find flexible coverage at the right price."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
