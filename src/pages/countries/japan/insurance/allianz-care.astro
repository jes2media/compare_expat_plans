---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Japan', level: 2 },
  { id: 'why-allianz', text: 'Why Allianz for Japan', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Japan', href: '/countries/japan/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient only', price: '$170-220/mo' },
  { plan: 'Classic', coverage: 'Inpatient + outpatient', price: '$220-280/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', price: '$280-340/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Japan"
  description="Guide to Allianz Care international health insurance for expats in Japan. Strong value coverage with global reach."
  headline="Allianz Care in Japan"
  subheadline="Excellent value from a trusted global insurer. Comprehensive coverage at competitive prices for Japan expats."
  heroBackgroundImage="/images/countries/japan-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Quote"
  ctaButtonHref="/providers/allianz-care"
>
  <h2 id="overview">Allianz Care in Japan</h2>
  <p>
    Allianz Care offers strong value for Japan expats—comprehensive international coverage at prices 10-20% below premium competitors. As one of the world's largest insurers, Allianz brings financial stability and global reach.
  </p>
  <p>
    For expats seeking quality coverage to supplement mandatory NHI without top-tier pricing, Allianz delivers good balance.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$220-340</p>
      <p class="text-sm text-neutral-600">Monthly (Age 40)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Good Value</p>
      <p class="text-sm text-neutral-600">Competitive pricing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global Network</p>
      <p class="text-sm text-neutral-600">Worldwide coverage</p>
    </div>
  </div>

  <CTABox
    title="Get Your Allianz Japan Quote"
    description="Quality coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <h2 id="why-allianz">Why Allianz for Japan</h2>

  <h3>Price-to-Coverage Ratio</h3>
  <p>
    Allianz typically costs 10-20% less than Cigna or BUPA for comparable coverage—meaningful savings over time in Japan's high-cost insurance market.
  </p>

  <h3>Hospital Access</h3>
  <ul>
    <li>Access to international hospitals in Tokyo, Osaka</li>
    <li>Coverage at St. Luke's and other English-speaking facilities</li>
    <li>Direct billing at network hospitals</li>
  </ul>

  <h3>Flexible Plans</h3>
  <ul>
    <li>Multiple coverage tiers</li>
    <li>Adjustable deductibles</li>
    <li>Optional add-ons for dental, vision</li>
    <li>Regional or worldwide coverage</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 40-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Classic+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation and repatriation</li>
    <li><strong>Mental health:</strong> Coverage with limits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Moratorium or underwriting</li>
    <li>Maternity: Waiting period, optional</li>
    <li>Less Japan-specific support than Cigna/BUPA</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Value-Conscious Expats</h3>
  <p>
    Those who want comprehensive international coverage without premium prices.
  </p>

  <h3>Long-term Residents</h3>
  <p>
    Allianz's competitive pricing makes it sustainable for extended Japan stays.
  </p>

  <h3>Self-Sufficient Expats</h3>
  <p>
    If you're comfortable navigating some things independently and don't need extensive hand-holding, Allianz provides excellent coverage at better value.
  </p>

  <CTABox
    title="Compare Allianz Plans for Japan"
    description="Find the right coverage at the right price."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
