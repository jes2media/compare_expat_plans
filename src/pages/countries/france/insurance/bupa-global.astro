---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in France', level: 2 },
  { id: 'visa-coverage', text: 'Pre-PUMA Visa Coverage', level: 2 },
  { id: 'france-network', text: 'Network Coverage', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs French Options', level: 2 },
  { id: 'claims', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in France', href: '/countries/france/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'francePrice', header: 'France (Age 40)' },
  { key: 'mentalHealth', header: 'Mental Health' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Inpatient + Day-patient', francePrice: '€180-240/mo', mentalHealth: 'Limited' },
  { plan: 'Complete', coverage: 'Essentials + Outpatient', francePrice: '€260-340/mo', mentalHealth: 'Full parity' },
  { plan: 'Premier', coverage: 'Complete + Dental/Vision', francePrice: '€350-460/mo', mentalHealth: 'Full parity' },
  { plan: 'Elite', coverage: 'Maximum coverage', francePrice: '€440-570/mo', mentalHealth: 'Full parity' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'french', header: 'French System' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 40)', bupa: '€260-340', french: '€50-150 (mutuelle)' },
  { factor: 'Mental Health Parity', bupa: 'Full parity', french: 'Varies by mutuelle' },
  { factor: 'Pre-existing Conditions', bupa: 'Often covered', french: 'PUMA covers all' },
  { factor: 'Pre-PUMA Coverage', bupa: 'Full coverage', french: 'Not available' },
  { factor: 'No-Claims Discount', bupa: 'Up to 30%', french: 'Rarely' },
  { factor: 'Coverage Outside France', bupa: 'Worldwide', french: 'EU (EHIC) only' },
  { factor: 'Dental Included', bupa: 'Premier+ plans', french: 'Limited' },
];
---

<PageShell
  title="BUPA Global Health Insurance in France"
  description="Complete guide to using BUPA Global in France. Premium coverage with mental health parity, pre-existing conditions, and pre-PUMA visa coverage."
  headline="BUPA Global Health Insurance in France"
  subheadline="Premium international coverage for expats in France. Mental health parity, pre-existing conditions, and when it makes sense over PUMA."
  heroBackgroundImage="/images/countries/france-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA France Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">BUPA Global in France</h2>
  <p>
    BUPA Global is the premium choice for expats in France who want comprehensive coverage without gaps. While France's public system is excellent, BUPA offers what PUMA doesn't: immediate coverage, mental health parity, worldwide portability, and favorable handling of pre-existing conditions.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">4.4/5</p>
      <p class="text-sm text-neutral-600">Trustpilot rating</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">30%</p>
      <p class="text-sm text-neutral-600">No-claims discount</p>
    </div>
  </div>

  <CTABox
    title="Get a France-Specific Quote"
    description="See what BUPA Global costs for expats living in France."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="visa-coverage">Pre-PUMA Visa Coverage</h2>
  <p>
    BUPA Global Complete, Premier, and Elite plans meet French visa requirements. Their comprehensive coverage typically exceeds minimum requirements.
  </p>

  <h3>Visa Types</h3>
  <ul>
    <li><strong>Long-stay visa (VLS-TS):</strong> BUPA Complete or higher recommended</li>
    <li><strong>Talent passport:</strong> BUPA meets requirements</li>
    <li><strong>Student visa:</strong> Complete plan works</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">Pre-Existing Conditions Advantage</h3>
    <p class="text-green-800">
      Unlike most insurers, BUPA often covers pre-existing conditions from day one. If you have health conditions other insurers exclude, BUPA may accept you with full or partial coverage — valuable before PUMA enrollment.
    </p>
  </div>

  <h2 id="france-network">Network Coverage in France</h2>
  <p>
    BUPA Global has a good network in France, with direct billing at major private hospitals.
  </p>

  <h3>Key Network Points</h3>
  <ul>
    <li><strong>Paris:</strong> American Hospital of Paris, major private clinics</li>
    <li><strong>Major cities:</strong> Network coverage in Lyon, Nice, Bordeaux, Marseille</li>
    <li><strong>Mental health:</strong> Access to psychiatric care and therapy networks</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Add 50-70% for US coverage.</em>
  </p>

  <h3>What Makes BUPA Different</h3>
  <ul>
    <li><strong>Mental health parity:</strong> Same limits as physical health</li>
    <li><strong>Pre-existing conditions:</strong> Often covered from day one</li>
    <li><strong>No-claims discount:</strong> Up to 30% savings</li>
    <li><strong>Dental/vision included:</strong> Premier and Elite plans</li>
  </ul>

  <CTABox
    title="Worth the Premium?"
    description="Get a personalized quote to see the actual cost difference."
    buttonText="Get a Quote"
    buttonHref="/go/bupa-global"
  />

  <h2 id="vs-local-options">vs French Options</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Keep BUPA Global If:</h3>
  <ul>
    <li>Mental health coverage is essential</li>
    <li>You have pre-existing conditions</li>
    <li>You want dental/vision included</li>
    <li>You travel outside France frequently</li>
    <li>You might relocate</li>
  </ul>

  <h3>Switch to PUMA + Mutuelle If:</h3>
  <ul>
    <li>You're staying in France long-term</li>
    <li>Budget is a concern</li>
    <li>You're comfortable with French healthcare</li>
  </ul>

  <p>
    <a href="/countries/france/insurance">See all France insurance options →</a>
  </p>

  <h2 id="claims">Using Your Insurance in France</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, present your BUPA card for cashless treatment.
  </p>

  <h3>MembersWorld Portal</h3>
  <p>
    BUPA's app lets you find providers, submit claims, track status, and chat with support.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in France</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those needing mental health coverage</li>
        <li>Expats with pre-existing conditions</li>
        <li>Families wanting all-inclusive plans</li>
        <li>Those who value premium service</li>
        <li>Expats who may relocate</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Long-term France residents</li>
        <li>Those comfortable with PUMA + mutuelle</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Do I need BUPA after PUMA enrollment?</h3>
  <p>
    Not necessarily. But if you need mental health coverage, have pre-existing conditions PUMA handles poorly, travel frequently, or might relocate, keeping BUPA makes sense.
  </p>

  <h3>Will BUPA cover my pre-existing condition?</h3>
  <p>
    Possibly. BUPA often covers pre-existing conditions from day one with full disclosure. Once you have PUMA, it covers all conditions anyway.
  </p>

  <h3>How does mental health parity work?</h3>
  <p>
    BUPA covers mental health at the same limits as physical health. French mutuelles may have separate, lower limits for mental health.
  </p>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for France."
    buttonText="Get Your Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements and PUMA rules change. Verify all information with BUPA Global and French authorities.
    </p>
  </div>
</PageShell>
