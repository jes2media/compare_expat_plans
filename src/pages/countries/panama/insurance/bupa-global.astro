---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Panama', level: 2 },
  { id: 'why-bupa', text: 'Why BUPA for Panama', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'retiree-considerations', text: 'Retiree Considerations', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Panama', href: '/countries/panama/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 55)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Core inpatient', price: '$250-320/mo' },
  { plan: 'Select', coverage: 'Inpatient + outpatient', price: '$320-420/mo' },
  { plan: 'Elite', coverage: 'Comprehensive', price: '$400-520/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Panama"
  description="Guide to BUPA Global international health insurance for expats and retirees in Panama. Premium coverage with strong customer service."
  headline="BUPA Global in Panama"
  subheadline="Premium international insurer with excellent reputation. Popular with long-term expats in Panama."
  heroBackgroundImage="/images/countries/panama-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Panama</h2>
  <p>
    BUPA Global is a leading international health insurer known for excellent customer service and comprehensive coverage. For Panama expats, particularly those planning long-term stays, BUPA offers premium-level service and reliability.
  </p>
  <p>
    With a focus on customer experience and straightforward claims processes, BUPA appeals to those who prioritize service quality alongside coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$300-480</p>
      <p class="text-sm text-neutral-600">Monthly (Age 55)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Premium</p>
      <p class="text-sm text-neutral-600">Service quality</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Coverage network</p>
    </div>
  </div>

  <CTABox
    title="Get Your BUPA Panama Quote"
    description="Premium coverage with excellent service."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="why-bupa">Why BUPA for Panama</h2>

  <h3>Service Excellence</h3>
  <p>
    BUPA consistently receives high marks for customer service:
  </p>
  <ul>
    <li>Dedicated customer service teams</li>
    <li>Quick claims processing</li>
    <li>Easy-to-use member portal</li>
    <li>24/7 multilingual support line</li>
  </ul>

  <h3>Long-term Reliability</h3>
  <p>
    BUPA has decades of experience in international health insurance. For retirees committing to Panama long-term, this track record matters:
  </p>
  <ul>
    <li>Lifetime renewal guarantee</li>
    <li>Stable premium increases</li>
    <li>No arbitrary policy cancellations</li>
  </ul>

  <h3>Panama Hospital Network</h3>
  <p>
    BUPA works with Panama's major private hospitals:
  </p>
  <ul>
    <li>Hospital Punta Pacífica</li>
    <li>Hospital Nacional</li>
    <li>Centro Médico Paitilla</li>
    <li>Hospital Santa Fe</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-3">Member Experience</h3>
    <p class="text-blue-800">
      BUPA members frequently cite the ease of dealing with the company as a major benefit. When you're dealing with health issues in a foreign country, responsive customer service can make a significant difference.
    </p>
  </div>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 55-year-old. Premium varies by age, health status, and coverage options.
  </p>

  <h3>Plan Tiers</h3>
  <ul>
    <li><strong>Essential:</strong> Inpatient care, emergency treatment, evacuation</li>
    <li><strong>Select:</strong> Adds outpatient, specialists, diagnostics</li>
    <li><strong>Elite:</strong> Comprehensive coverage including wellness, maternity options</li>
  </ul>

  <h3>Deductible Options</h3>
  <p>
    BUPA offers various deductible levels:
  </p>
  <ul>
    <li>$0 - Full coverage, highest premium</li>
    <li>$2,500 - Moderate savings</li>
    <li>$5,000 - Significant premium reduction</li>
    <li>$10,000 - Catastrophic coverage, lowest premium</li>
  </ul>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, intensive care, rehabilitation</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists, tests (Select+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Cancer:</strong> Comprehensive cancer treatment</li>
    <li><strong>Evacuation:</strong> Medical evacuation to nearest appropriate facility</li>
    <li><strong>Mental health:</strong> Better coverage than most competitors (Elite)</li>
  </ul>

  <h3>Notable Features</h3>
  <ul>
    <li>Second medical opinion service</li>
    <li>Virtual GP consultations</li>
    <li>Health and wellness support</li>
    <li>Chronic condition management programs</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Moratorium or underwriting required</li>
    <li>Dental/vision: Limited coverage, separate add-on</li>
    <li>Cosmetic procedures: Not covered</li>
  </ul>

  <h2 id="retiree-considerations">Retiree Considerations</h2>

  <h3>Age-Related Pricing</h3>
  <p>
    BUPA's premiums increase with age, as with all insurers:
  </p>
  <ul>
    <li><strong>Age 55:</strong> $300-480/month</li>
    <li><strong>Age 65:</strong> $450-700/month</li>
    <li><strong>Age 75:</strong> $650-950/month</li>
  </ul>

  <h3>Pre-existing Conditions</h3>
  <p>
    BUPA offers two approaches:
  </p>
  <ul>
    <li><strong>Moratorium:</strong> Pre-existing conditions excluded for 2 years</li>
    <li><strong>Medical History Disregarded:</strong> Higher premium, but covers pre-existing conditions from day one (limited availability)</li>
  </ul>

  <h3>US Coverage</h3>
  <p>
    American retirees often want US coverage options. BUPA offers worldwide plans including the US, though this adds significantly to premiums.
  </p>

  <h3>Couples and Families</h3>
  <p>
    BUPA may offer modest discounts for couples enrolling together, which is relevant for the many couples who retire to Panama together.
  </p>

  <CTABox
    title="Compare BUPA Plans for Panama"
    description="Premium coverage and service for Panama expats."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage are estimates. Contact BUPA for accurate quotes based on your specific situation and needs.
    </p>
  </div>
</PageShell>
