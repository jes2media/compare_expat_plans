  { id: 'recommended-plans', text: 'Recommended Plans', level: 2 },
  { id: 'costs', text: 'Expected Costs', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global in Indonesia', href: '/countries/indonesia/insurance/cigna-global' },
  { title: 'Allianz Care in Indonesia', href: '/countries/indonesia/insurance/allianz-care' },
  { title: 'SafetyWing in Indonesia', href: '/countries/indonesia/insurance/safetywing' },
  { title: 'IMG Global in Indonesia', href: '/countries/indonesia/insurance/img-global' },
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
