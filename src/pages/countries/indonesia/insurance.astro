const planRows = [
  { provider: 'SafetyWing', type: 'Travel Medical', bestFor: 'Digital nomads', startingPrice: '$45/mo' },
  { provider: 'IMG Global', type: 'International', bestFor: 'Budget expats', startingPrice: '$85/mo' },
  { provider: 'Allianz Care', type: 'International', bestFor: 'Flexible coverage', startingPrice: '$120/mo' },
  { provider: 'Cigna Global', type: 'International', bestFor: 'Comprehensive', startingPrice: '$160/mo' },
  { provider: 'BUPA Global', type: 'International', bestFor: 'Premium coverage', startingPrice: '$200/mo' },
  { provider: 'AXA Global', type: 'International', bestFor: 'Value seekers', startingPrice: '$110/mo' },
