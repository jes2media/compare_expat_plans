---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Indonesia', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Indonesia', href: '/countries/indonesia/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Cigna', href: '/compare/axa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'indoPrice', header: 'Indonesia (Age 35)' },
];

const planRows = [
  { plan: 'Comfort', coverage: 'Essential coverage', indoPrice: '$85-115/mo' },
  { plan: 'Standard', coverage: 'Standard + Outpatient', indoPrice: '$115-155/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', indoPrice: '$165-220/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Indonesia"
  description="Guide to using AXA Global in Indonesia. EU-regulated international coverage with competitive pricing for Bali expats."
  headline="AXA Global Health Insurance in Indonesia"
  subheadline="EU-regulated international coverage with strong value for Indonesia expats."
  heroBackgroundImage="/images/countries/indonesia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Indonesia Quote"
  ctaButtonHref="/go/axa-global"
>
  <h2 id="overview">AXA Global in Indonesia</h2>
  <p>
    AXA Global offers EU-regulated international health insurance with competitive pricing. For Indonesia expats, AXA provides solid coverage at a lower price point than premium competitors, with the security of EU regulatory protections.
  </p>
  <p>
    AXA has local presence in Indonesia through AXA Indonesia, making claims and support more accessible.
  </p>

  <CTABox
    title="Get an Indonesia-Specific Quote"
    description="See what AXA Global costs for expats in Indonesia."
    buttonText="Get Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    AXA typically costs 20-30% less than premium competitors while offering comparable core coverage. For value-conscious expats who want international coverage, AXA delivers.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA in Indonesia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Those who travel to Europe/Asia</li>
        <li>Long-term residents wanting international coverage</li>
        <li>Families seeking affordable coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing US network access</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Short-term nomads (SafetyWing)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized AXA Global quote for Indonesia."
    buttonText="Get Your Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with AXA before purchasing.
    </p>
  </div>
</PageShell>
