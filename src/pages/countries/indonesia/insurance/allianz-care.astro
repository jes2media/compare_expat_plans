---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Indonesia', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Indonesia', href: '/countries/indonesia/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'indoPrice', header: 'Indonesia (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', indoPrice: '$90-120/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', indoPrice: '$120-160/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', indoPrice: '$180-240/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Indonesia"
  description="Guide to using Allianz Care in Indonesia. Modular international coverage with flexible options for Bali expats."
  headline="Allianz Care Health Insurance in Indonesia"
  subheadline="Flexible, modular international coverage for Indonesia expats at competitive prices."
  heroBackgroundImage="/images/countries/indonesia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Indonesia Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Indonesia</h2>
  <p>
    Allianz Care offers modular international health insurance that's popular with Indonesia expats who want flexibility. You can customize coverage by selecting modules—adding or removing outpatient, dental, or other coverage as needed.
  </p>
  <p>
    In Indonesia, Allianz provides good value with solid coverage at lower prices than premium competitors. Their high-deductible options work well since routine care is affordable.
  </p>

  <CTABox
    title="Get an Indonesia-Specific Quote"
    description="See what Allianz Care costs for expats in Indonesia."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Modular Design</h3>
  <p>
    Build your plan by selecting:
  </p>
  <ul>
    <li>Core inpatient coverage (required)</li>
    <li>Optional outpatient module</li>
    <li>Optional dental and vision</li>
    <li>Maternity add-on</li>
    <li>Coverage area (Asia vs worldwide)</li>
  </ul>

  <h3>High-Deductible Options</h3>
  <p>
    Allianz offers deductibles up to €10,000. In Indonesia, where routine care is cheap, this can reduce premiums by 30-50% while keeping catastrophic coverage intact.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Indonesia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Those who want customizable plans</li>
        <li>Expats comfortable with high deductibles</li>
        <li>Long-term residents wanting international coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting all-inclusive plans</li>
        <li>US expats needing US network access</li>
        <li>Short-term digital nomads (SafetyWing)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Flexible Coverage?"
    description="Get a personalized Allianz Care quote for Indonesia."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with Allianz before purchasing.
    </p>
  </div>
</PageShell>
