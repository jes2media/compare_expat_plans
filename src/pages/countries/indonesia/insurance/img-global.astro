---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Indonesia', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Indonesia', href: '/countries/indonesia/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'indoPrice', header: 'Indonesia (Age 35)' },
];

const planRows = [
  { plan: 'Global Select', coverage: 'Core international', indoPrice: '$70-100/mo' },
  { plan: 'Global Premier', coverage: 'Enhanced benefits', indoPrice: '$100-140/mo' },
  { plan: 'Global Elite', coverage: 'Comprehensive', indoPrice: '$140-190/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Indonesia"
  description="Guide to using IMG Global in Indonesia. Budget-friendly international coverage with high-deductible options for cost-conscious expats."
  headline="IMG Global Health Insurance in Indonesia"
  subheadline="Budget-friendly international coverage with flexible deductible options."
  heroBackgroundImage="/images/countries/indonesia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Indonesia Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in Indonesia</h2>
  <p>
    IMG Global offers budget-friendly international health insurance for Indonesia expats who want more coverage than SafetyWing but don't need premium options. Their high-deductible plans can significantly reduce premiums while providing solid catastrophic coverage.
  </p>
  <p>
    For cost-conscious expats planning longer stays in Indonesia, IMG bridges the gap between travel medical insurance and comprehensive international coverage.
  </p>

  <CTABox
    title="Get an Indonesia-Specific Quote"
    description="See what IMG Global costs for expats in Indonesia."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    IMG offers deductibles up to $25,000. In Indonesia, where routine care is very affordable, this approach makes sense:
  </p>
  <ul>
    <li>Pay routine care out of pocket (cheap in Indonesia)</li>
    <li>Save significantly on premiums</li>
    <li>Still have catastrophic and evacuation coverage</li>
  </ul>

  <h3>50% Deductible Waiver</h3>
  <p>
    IMG waives 50% of your deductible for care outside the US. Since you're in Indonesia, this effectively cuts your out-of-pocket maximum in half.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in Indonesia</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals</li>
        <li>Those comfortable with high deductibles</li>
        <li>Long-term expats wanting international coverage</li>
        <li>Step up from travel medical insurance</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing mental health coverage</li>
        <li>Expats with pre-existing conditions</li>
        <li>Those wanting premium service</li>
        <li>Short-term nomads (SafetyWing cheaper)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for Indonesia."
    buttonText="Get Your Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with IMG before purchasing.
    </p>
  </div>
</PageShell>
