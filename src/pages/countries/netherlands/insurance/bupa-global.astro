---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When BUPA Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Inpatient only', nlPrice: '€160-210/mo' },
  { plan: 'Comprehensive', coverage: 'Inpatient + Outpatient', nlPrice: '€260-340/mo' },
  { plan: 'Elite', coverage: 'Full coverage + extras', nlPrice: '€340-440/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Netherlands"
  description="Guide to using BUPA Global in the Netherlands. UK-based international coverage for British expats and those exempt from Dutch insurance."
  headline="BUPA Global Health Insurance in Netherlands"
  subheadline="UK-based international coverage with strong mental health benefits. Popular with British expats."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Netherlands Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Netherlands</h2>
  <p>
    BUPA Global offers UK-based international health insurance with particularly strong mental health coverage. For British expats in the Netherlands exempt from mandatory Dutch insurance, BUPA provides familiar brand quality and comprehensive benefits.
  </p>
  <p>
    Post-Brexit, British expats in the Netherlands face different healthcare considerations than before. BUPA Global can provide continuity of coverage style for those used to UK private healthcare.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Premium</p>
      <p class="text-sm text-neutral-600">Service level</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Strong</p>
      <p class="text-sm text-neutral-600">Mental health coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">UK Brand</p>
      <p class="text-sm text-neutral-600">Familiar to Brits</p>
    </div>
  </div>

  <CTABox
    title="Get a BUPA Quote"
    description="UK-quality international coverage."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="when-to-use">When BUPA Makes Sense</h2>

  <h3>Post-Brexit British Expats</h3>
  <p>
    Since Brexit, British citizens in the Netherlands have different healthcare rights than EU citizens. BUPA Global provides:
  </p>
  <ul>
    <li>Continuity of UK-style coverage</li>
    <li>Coverage during UK visits</li>
    <li>Familiar claims and service processes</li>
    <li>Strong mental health benefits</li>
  </ul>

  <h3>For Those Exempt from Dutch Insurance</h3>
  <p>
    Like other international insurers, BUPA works as primary coverage for:
  </p>
  <ul>
    <li>Posted workers with A1 certificates</li>
    <li>Short-term assignees</li>
    <li>International organization staff</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    BUPA's mental health coverage is notably comprehensive—often better than Dutch supplementary insurance options. This includes:
  </p>
  <ul>
    <li>Psychiatrist consultations</li>
    <li>Psychologist sessions</li>
    <li>Inpatient psychiatric care</li>
    <li>No strict session limits on higher plans</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose BUPA in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>British expats (brand familiarity)</li>
        <li>Those prioritizing mental health coverage</li>
        <li>Families exempt from Dutch insurance</li>
        <li>Posted workers from UK</li>
        <li>Those who travel to UK frequently</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those required to have Dutch insurance</li>
        <li>Budget-conscious (Dutch basic cheaper)</li>
        <li>Non-UK expats (may prefer other brands)</li>
        <li>Long-term NL residents</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for BUPA Global?"
    description="Get a personalized quote for Netherlands."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify your Dutch insurance obligations. Post-Brexit rules may affect your requirements.
    </p>
  </div>
</PageShell>
