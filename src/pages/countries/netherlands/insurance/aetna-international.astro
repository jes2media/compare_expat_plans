---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When Aetna Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs Cigna', href: '/compare/aetna-international-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Core', coverage: 'Inpatient essential', nlPrice: '€170-220/mo' },
  { plan: 'Navigator', coverage: 'Inpatient + Outpatient', nlPrice: '€270-350/mo' },
  { plan: 'Pioneer', coverage: 'Comprehensive', nlPrice: '€350-450/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Netherlands"
  description="Guide to using Aetna International in the Netherlands. US-based insurer with wellness focus."
  headline="Aetna International Health Insurance in Netherlands"
  subheadline="US-based global coverage with wellness programs. For those exempt from Dutch insurance."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Netherlands Quote"
  ctaButtonHref="/providers/aetna-international"
>
  <h2 id="overview">Aetna International in Netherlands</h2>
  <p>
    Aetna International, backed by CVS Health, offers comprehensive global health insurance with a focus on wellness and preventive care. For US expats in the Netherlands or those seeking American-style coverage, Aetna provides a familiar approach.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">CVS Backed</p>
      <p class="text-sm text-neutral-600">Financial strength</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Wellness</p>
      <p class="text-sm text-neutral-600">Preventive focus</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">US Style</p>
      <p class="text-sm text-neutral-600">Familiar approach</p>
    </div>
  </div>

  <CTABox
    title="Get an Aetna Quote"
    description="US-style international coverage."
    buttonText="Get Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <h2 id="when-to-use">When Aetna Makes Sense</h2>

  <h3>For US Expats</h3>
  <p>
    Aetna is particularly relevant for:
  </p>
  <ul>
    <li>Americans posted to Netherlands</li>
    <li>US company employees on assignment</li>
    <li>Those familiar with US-style coverage</li>
    <li>Expats who travel to US frequently</li>
  </ul>

  <h3>Wellness Programs</h3>
  <p>
    Aetna emphasizes preventive care:
  </p>
  <ul>
    <li>Health screenings and checkups</li>
    <li>Wellness incentive programs</li>
    <li>Digital health tools</li>
    <li>Chronic condition management</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Pricing Position</h3>
  <p>
    Aetna sits in the premium tier alongside Cigna and BUPA. The premium includes wellness benefits and comprehensive coverage.
  </p>

  <h2 id="who-its-for">Who Should Choose Aetna in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US expats exempt from Dutch insurance</li>
        <li>Those valuing wellness programs</li>
        <li>Corporate assignees from US companies</li>
        <li>Those traveling to US frequently</li>
        <li>Families wanting comprehensive care</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those required to have Dutch insurance</li>
        <li>Budget-conscious expats</li>
        <li>Non-US expats (other brands may suit)</li>
        <li>Long-term NL residents</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for US-Style Coverage?"
    description="Get a personalized Aetna International quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify your Dutch insurance obligations before choosing international coverage.
    </p>
  </div>
</PageShell>
