---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When AXA Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Comfort', coverage: 'Essential coverage', nlPrice: '€130-170/mo' },
  { plan: 'Standard', coverage: 'Standard + Outpatient', nlPrice: '€190-250/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', nlPrice: '€260-340/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Netherlands"
  description="Guide to using AXA Global in the Netherlands. EU-regulated international coverage with competitive pricing."
  headline="AXA Global Health Insurance in Netherlands"
  subheadline="EU-regulated international coverage at competitive prices. Budget-friendly international option."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Netherlands Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in Netherlands</h2>
  <p>
    AXA Global offers EU-regulated international health insurance with competitive pricing. For budget-conscious expats in the Netherlands who are exempt from mandatory Dutch insurance, AXA provides solid international coverage at lower premiums than many competitors.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU Regulated</p>
      <p class="text-sm text-neutral-600">Consumer protections</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">20-30%</p>
      <p class="text-sm text-neutral-600">Below premium tier</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Strong</p>
      <p class="text-sm text-neutral-600">EU presence</p>
    </div>
  </div>

  <CTABox
    title="Get an AXA Quote"
    description="Competitive international coverage."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="when-to-use">When AXA Makes Sense</h2>

  <h3>Budget International Coverage</h3>
  <p>
    AXA works well for those who:
  </p>
  <ul>
    <li>Are exempt from Dutch insurance</li>
    <li>Want international coverage at reasonable cost</li>
    <li>Value EU regulatory protections</li>
    <li>Travel frequently within Europe</li>
  </ul>

  <h3>EU Presence</h3>
  <p>
    AXA's strong European operations mean:
  </p>
  <ul>
    <li>Understanding of EU healthcare coordination</li>
    <li>Experience with European claims</li>
    <li>Strong provider relationships in EU</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Position</h3>
  <p>
    AXA typically costs 20-30% less than premium competitors. The savings come with trade-offs—less extensive direct billing and potentially less hand-holding on complex claims.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Those exempt from Dutch insurance</li>
        <li>EU travelers seeking value</li>
        <li>Self-sufficient individuals</li>
        <li>French expats (familiar brand)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those required to have Dutch insurance</li>
        <li>Those wanting premium service</li>
        <li>US expats needing US coverage</li>
        <li>Those preferring extensive direct billing</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value Coverage?"
    description="Get a personalized AXA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify your Dutch insurance obligations before choosing international coverage.
    </p>
  </div>
</PageShell>
