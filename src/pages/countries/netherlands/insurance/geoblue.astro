---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When GeoBlue Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/geoblue-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Inpatient + limited outpatient', nlPrice: '€190-250/mo' },
  { plan: 'Xplorer Select', coverage: 'Comprehensive', nlPrice: '€300-390/mo' },
  { plan: 'Xplorer Premier', coverage: 'Premium + US coverage', nlPrice: '€420-550/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Netherlands"
  description="Guide to using GeoBlue in the Netherlands. Blue Cross Blue Shield international coverage for US expats."
  headline="GeoBlue Health Insurance in Netherlands"
  subheadline="Blue Cross Blue Shield's international arm. Strong choice for Americans in Netherlands."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Netherlands Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in Netherlands</h2>
  <p>
    GeoBlue is the international insurance arm of Blue Cross Blue Shield—one of America's most recognized health insurance names. For US expats in the Netherlands, GeoBlue offers familiar coverage style with the unique advantage of BCBS network access when visiting the US.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">BCBS</p>
      <p class="text-sm text-neutral-600">Brand backing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">US Network</p>
      <p class="text-sm text-neutral-600">BCBS access</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Strong App</p>
      <p class="text-sm text-neutral-600">Digital tools</p>
    </div>
  </div>

  <CTABox
    title="Get a GeoBlue Quote"
    description="BCBS international coverage."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="when-to-use">When GeoBlue Makes Sense</h2>

  <h3>US Expats with US Ties</h3>
  <p>
    GeoBlue is particularly valuable for Americans who:
  </p>
  <ul>
    <li>Return to the US frequently</li>
    <li>Have family in the US</li>
    <li>Want BCBS network access when home</li>
    <li>May eventually repatriate</li>
  </ul>

  <h3>Digital Experience</h3>
  <p>
    GeoBlue's app and digital tools are well-regarded:
  </p>
  <ul>
    <li>Provider finder worldwide</li>
    <li>Digital ID cards</li>
    <li>Mobile claims submission</li>
    <li>Telehealth options</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>US Coverage Impact</h3>
  <p>
    Plans with comprehensive US coverage cost more due to US healthcare costs. If you don't need US coverage, other insurers may offer better value.
  </p>

  <h2 id="who-its-for">Who Should Choose GeoBlue in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US expats needing US coverage</li>
        <li>Those familiar with BCBS</li>
        <li>Frequent US travelers</li>
        <li>Tech-savvy users (strong app)</li>
        <li>Americans exempt from Dutch insurance</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US expats (better value elsewhere)</li>
        <li>Those required to have Dutch insurance</li>
        <li>Budget-focused expats</li>
        <li>Those not traveling to US</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for BCBS International?"
    description="Get a personalized GeoBlue quote."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify your Dutch insurance obligations before choosing international coverage.
    </p>
  </div>
</PageShell>
