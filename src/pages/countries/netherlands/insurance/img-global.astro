---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When IMG Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Global Medical', coverage: 'Essential inpatient', nlPrice: '€130-170/mo' },
  { plan: 'Global Medical Plus', coverage: 'Inpatient + Outpatient', nlPrice: '€190-260/mo' },
  { plan: 'Global Medical Platinum', coverage: 'Comprehensive', nlPrice: '€260-350/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Netherlands"
  description="Guide to using IMG Global in the Netherlands. Flexible international coverage with customizable options."
  headline="IMG Global Health Insurance in Netherlands"
  subheadline="Flexible international coverage with customizable deductibles. For those exempt from Dutch insurance."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Netherlands Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Netherlands</h2>
  <p>
    IMG (International Medical Group) offers flexible international health insurance with customizable options. For expats in the Netherlands exempt from mandatory Dutch insurance, IMG provides a mid-tier option with significant flexibility in deductibles and coverage limits.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$8M</p>
      <p class="text-sm text-neutral-600">Maximum available</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Flexible</p>
      <p class="text-sm text-neutral-600">Deductible options</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Mid-Range</p>
      <p class="text-sm text-neutral-600">Price point</p>
    </div>
  </div>

  <CTABox
    title="Get an IMG Quote"
    description="Flexible international coverage options."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="when-to-use">When IMG Makes Sense</h2>

  <p>
    IMG works well for those who:
  </p>
  <ul>
    <li>Are exempt from Dutch insurance requirements</li>
    <li>Want flexibility in coverage customization</li>
    <li>Prefer controlling costs with higher deductibles</li>
    <li>Need coverage that can adapt to changing situations</li>
  </ul>

  <h3>Customization Advantage</h3>
  <p>
    IMG's flexibility allows you to:
  </p>
  <ul>
    <li>Choose deductibles from $250 to $25,000</li>
    <li>Select coverage limits from $1M to $8M</li>
    <li>Add or remove optional coverage modules</li>
    <li>Adjust area of coverage as needed</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Saving with Deductibles</h3>
  <p>
    High-deductible options can reduce premiums significantly:
  </p>
  <ul>
    <li><strong>$250 deductible:</strong> Prices as shown</li>
    <li><strong>$2,500 deductible:</strong> 20-30% savings</li>
    <li><strong>$5,000+ deductible:</strong> 30-40% savings</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose IMG in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those exempt from Dutch insurance</li>
        <li>Budget-conscious seeking real coverage</li>
        <li>Healthy individuals (high deductible)</li>
        <li>Those wanting customizable options</li>
        <li>Short to mid-term stays</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those required to have Dutch insurance</li>
        <li>Those wanting premium service</li>
        <li>Those needing extensive direct billing</li>
        <li>Long-term NL residents</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Flexible Coverage?"
    description="Get a personalized IMG Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify your Dutch insurance obligations before choosing international coverage.
    </p>
  </div>
</PageShell>
