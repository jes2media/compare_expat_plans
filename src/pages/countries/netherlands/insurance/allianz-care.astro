---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When Allianz Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/allianz-care-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', nlPrice: '€140-180/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', nlPrice: '€210-280/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', nlPrice: '€290-380/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Netherlands"
  description="Guide to using Allianz Care in the Netherlands. German-backed international coverage for expats exempt from Dutch insurance."
  headline="Allianz Care Health Insurance in Netherlands"
  subheadline="German-backed international coverage with strong EU presence. For those exempt from mandatory Dutch insurance."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Netherlands Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Netherlands</h2>
  <p>
    Allianz Care offers German-backed international health insurance with strong European presence. For expats in the Netherlands who are exempt from mandatory Dutch insurance, Allianz provides comprehensive coverage at competitive prices.
  </p>
  <p>
    As a major European insurer, Allianz understands EU healthcare systems well, making claims and coordination straightforward for Netherlands-based expats.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">€2M+</p>
      <p class="text-sm text-neutral-600">Maximum coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU Expertise</p>
      <p class="text-sm text-neutral-600">European presence</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">15-20%</p>
      <p class="text-sm text-neutral-600">Below premium tier</p>
    </div>
  </div>

  <CTABox
    title="Get an Allianz Quote"
    description="Value-driven international coverage."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="when-to-use">When Allianz Makes Sense</h2>

  <h3>For Those Exempt from Dutch Insurance</h3>
  <p>
    Allianz Care works well as primary coverage if you're:
  </p>
  <ul>
    <li>Posted to Netherlands temporarily with A1 certificate</li>
    <li>Working for international organizations</li>
    <li>On short-term assignments</li>
    <li>Maintaining coverage from another EU country</li>
  </ul>

  <h3>EU Integration Advantage</h3>
  <p>
    Allianz's European roots mean:
  </p>
  <ul>
    <li>Understanding of EU healthcare coordination</li>
    <li>Experience with cross-border claims</li>
    <li>Strong provider relationships across Europe</li>
    <li>German regulatory oversight</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Position</h3>
  <p>
    Allianz typically costs 15-20% less than premium competitors like Cigna while offering comparable core coverage. For EU expats who value coverage quality over brand prestige, Allianz offers strong value.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>EU expats exempt from Dutch insurance</li>
        <li>Posted workers with A1 certificates</li>
        <li>Value-conscious international coverage seekers</li>
        <li>Those traveling frequently within Europe</li>
        <li>German expats (familiar brand)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those required to have Dutch insurance</li>
        <li>Long-term NL residents working locally</li>
        <li>Those wanting premium brand/service</li>
        <li>Budget seekers (Dutch basic is cheaper)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for EU-Backed Coverage?"
    description="Get a personalized Allianz Care quote."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify your Dutch insurance obligations before choosing international coverage.
    </p>
  </div>
</PageShell>
