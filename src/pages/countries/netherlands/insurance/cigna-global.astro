---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in Netherlands', level: 2 },
  { id: 'when-to-use', text: 'When Cigna Makes Sense', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Cigna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Netherlands', href: '/countries/netherlands/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs Allianz', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'nlPrice', header: 'Netherlands (Age 35)' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Inpatient only', nlPrice: '€180-230/mo' },
  { plan: 'Gold', coverage: 'Inpatient + Outpatient', nlPrice: '€280-360/mo' },
  { plan: 'Platinum', coverage: 'Comprehensive', nlPrice: '€360-460/mo' },
];
---

<PageShell
  title="Cigna Global Health Insurance in Netherlands"
  description="Guide to using Cigna Global in the Netherlands. When international insurance makes sense versus mandatory Dutch coverage."
  headline="Cigna Global Health Insurance in Netherlands"
  subheadline="Premium international coverage for expats exempt from Dutch insurance or wanting additional benefits."
  heroBackgroundImage="/images/countries/netherlands-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Netherlands Quote"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Cigna Global in Netherlands</h2>
  <p>
    Cigna Global offers premium international health insurance, but in the Netherlands, the key question is whether you actually need it. Dutch basic insurance is mandatory for most residents—Cigna Global is primarily relevant for those exempt from this requirement.
  </p>
  <p>
    For posted workers, temporary assignees, and executives seeking premium supplementary coverage, Cigna provides comprehensive international benefits.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$2M+</p>
      <p class="text-sm text-neutral-600">Maximum coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Coverage area</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Premium</p>
      <p class="text-sm text-neutral-600">Service level</p>
    </div>
  </div>

  <CTABox
    title="Get a Cigna Quote"
    description="For those exempt from Dutch mandatory insurance."
    buttonText="Get Quote"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="when-to-use">When Cigna Makes Sense</h2>

  <h3>Primary Coverage (Exempt from Dutch Insurance)</h3>
  <p>
    Cigna Global works as your primary insurance if you're:
  </p>
  <ul>
    <li><strong>Posted workers:</strong> Temporarily assigned to NL with A1 certificate, remaining under home country social security</li>
    <li><strong>Short-term assignees:</strong> In Netherlands less than expected residency period</li>
    <li><strong>Diplomats and international organization staff:</strong> Often exempt from local requirements</li>
  </ul>

  <h3>Supplementary Coverage</h3>
  <p>
    Some expats maintain Cigna alongside Dutch basic insurance for:
  </p>
  <ul>
    <li>Access to private facilities worldwide</li>
    <li>Coverage during frequent international travel</li>
    <li>No referral requirements for specialists</li>
    <li>Higher coverage limits and fewer restrictions</li>
  </ul>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-3">Important: Check Your Obligations</h3>
    <p class="text-amber-800">
      If you work for a Dutch employer or are self-employed in NL, you likely need Dutch basic insurance regardless of any international coverage. Cigna Global doesn't replace mandatory Dutch insurance for most workers.
    </p>
  </div>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Cost Comparison</h3>
  <p>
    Cigna Global costs significantly more than Dutch basic insurance (€120-150/mo). The premium buys you global coverage, no referral requirements, and access to private facilities worldwide. Whether this value makes sense depends on your situation and travel patterns.
  </p>

  <h2 id="who-its-for">Who Should Choose Cigna in Netherlands</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Posted workers exempt from Dutch insurance</li>
        <li>Short-term assignees (under 2 years)</li>
        <li>Executives wanting global premium coverage</li>
        <li>Frequent international travelers</li>
        <li>Those who may relocate again soon</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Long-term NL residents (Dutch insurance required)</li>
        <li>Those working for Dutch employers</li>
        <li>Self-employed in Netherlands</li>
        <li>Budget-conscious expats</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Exempt from Dutch Insurance?"
    description="Get a personalized Cigna Global quote."
    buttonText="Get Your Quote"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Dutch insurance requirements depend on your work and residency status. Verify your obligations with the SVB before choosing international over Dutch insurance.
    </p>
  </div>
</PageShell>
