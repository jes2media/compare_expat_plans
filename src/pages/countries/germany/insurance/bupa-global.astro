---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Germany', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'germany-benefits', text: 'Germany-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Germany', href: '/countries/germany/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'germanyPrice', header: 'Germany (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Day-patient', germanyPrice: '€190-260/mo' },
  { plan: 'Gold', coverage: 'Comprehensive', germanyPrice: '€280-370/mo' },
  { plan: 'Platinum', coverage: 'Premium + Wellness', germanyPrice: '€380-500/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Germany"
  description="Guide to using BUPA Global in Germany. Premium service, mental health coverage, pre-existing condition options."
  headline="BUPA Global Health Insurance in Germany"
  subheadline="BUPA Global for expats in Germany—premium service, strong mental health benefits, and flexible pre-existing condition coverage."
  heroBackgroundImage="/images/countries/germany-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">BUPA Global in Germany</h2>
  <p>
    BUPA Global offers premium international health insurance with particularly strong mental health coverage and more flexible handling of pre-existing conditions. For expats in Germany who need these features, BUPA provides options that German PKV might not.
  </p>
  <p>
    While most long-term Germany residents eventually need GKV or German PKV, BUPA works well for initial periods and as supplementary coverage.
  </p>

  <CTABox
    title="Get a Germany Quote"
    description="See BUPA Global pricing for expats in Germany."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    BUPA offers comprehensive psychological and psychiatric coverage with higher limits than most competitors. This can be particularly valuable given Germany's long wait times for mental health appointments in the public system.
  </p>

  <h2 id="germany-benefits">Germany-Specific Benefits</h2>
  <ul>
    <li><strong>Pre-existing conditions:</strong> More flexible underwriting than German PKV</li>
    <li><strong>Mental health:</strong> Skip long GKV wait times for therapy</li>
    <li><strong>Direct billing:</strong> Available at major German hospitals</li>
    <li><strong>English support:</strong> 24/7 English customer service</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose BUPA in Germany</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those with pre-existing conditions</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those wanting premium service</li>
        <li>Families needing comprehensive care</li>
        <li>Expats who may relocate</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Long-term residents (GKV better value)</li>
        <li>Those comfortable with German system</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Germany?"
    description="Get a personalized BUPA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />
</PageShell>
