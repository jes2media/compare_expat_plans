---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Germany', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'germany-benefits', text: 'Germany-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Germany', href: '/countries/germany/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'germanyPrice', header: 'Germany (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient focused', germanyPrice: '€130-180/mo' },
  { plan: 'Standard', coverage: 'Inpatient + Outpatient', germanyPrice: '€200-270/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', germanyPrice: '€280-380/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Germany"
  description="Guide to using AXA Global in Germany. EU-regulated French insurer with strong European presence."
  headline="AXA Global Health Insurance in Germany"
  subheadline="AXA Global for expats in Germany—EU-regulated French insurer with strong European healthcare expertise."
  heroBackgroundImage="/images/countries/germany-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in Germany</h2>
  <p>
    AXA Global, headquartered in France, offers EU-regulated international health insurance with deep European expertise. For expats in Germany, AXA provides an alternative to German insurers with strong EU compliance.
  </p>
  <p>
    AXA's European roots mean good understanding of EU healthcare systems and regulations, making it a solid choice for expats moving within Europe.
  </p>

  <CTABox
    title="Get a Germany Quote"
    description="See AXA Global pricing for expats in Germany."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="germany-benefits">Germany-Specific Benefits</h2>
  <ul>
    <li><strong>EU regulation:</strong> Compliant with European insurance standards</li>
    <li><strong>European expertise:</strong> Understands EU healthcare well</li>
    <li><strong>Visa compliance:</strong> Standard and Comprehensive meet German requirements</li>
    <li><strong>Multilingual:</strong> German, French, English support</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose AXA in Germany</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those who value EU insurer expertise</li>
        <li>Expats who may move within Europe</li>
        <li>Those familiar with AXA brand</li>
        <li>French expats in Germany</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>US expats (Aetna or GeoBlue)</li>
        <li>Those wanting German company (Allianz)</li>
        <li>Long-term residents (GKV/PKV)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Germany?"
    description="Get a personalized AXA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />
</PageShell>
