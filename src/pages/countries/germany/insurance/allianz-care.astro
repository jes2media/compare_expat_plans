---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Germany', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'germany-benefits', text: 'Germany-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Germany', href: '/countries/germany/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'germanyPrice', header: 'Germany (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient only', germanyPrice: '€110-150/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', germanyPrice: '€170-230/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', germanyPrice: '€260-350/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Germany"
  description="Guide to using Allianz Care in Germany. German company, EU expertise, high-deductible options."
  headline="Allianz Care Health Insurance in Germany"
  subheadline="Allianz Care for expats in Germany—a German company's international arm with deep EU healthcare expertise."
  heroBackgroundImage="/images/countries/germany-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Germany</h2>
  <p>
    Allianz Care is the international health insurance arm of Allianz, one of Germany's largest insurers. For expats in Germany, this means working with a company that deeply understands German healthcare and EU regulations.
  </p>
  <p>
    While Allianz Care is international insurance (not German PKV), its German roots mean better integration with German healthcare providers and processes.
  </p>

  <CTABox
    title="Get a Germany Quote"
    description="See Allianz Care pricing for expats in Germany."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    Allianz offers deductibles up to €10,000. For expats who plan to use GKV for routine care but want international coverage for major events, a high-deductible Allianz plan can work as supplementary coverage.
  </p>

  <h2 id="germany-benefits">Germany-Specific Benefits</h2>
  <ul>
    <li><strong>German company:</strong> Allianz understands German healthcare deeply</li>
    <li><strong>EU regulatory expertise:</strong> Plans designed for European compliance</li>
    <li><strong>German-speaking support:</strong> Native German support available</li>
    <li><strong>Strong network:</strong> Excellent hospital network in Germany</li>
    <li><strong>Allianz brand recognition:</strong> German providers know Allianz well</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Allianz in Germany</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those who value German company expertise</li>
        <li>Expats wanting high-deductible savings</li>
        <li>Those using GKV + supplementary coverage</li>
        <li>Freelancers in initial period</li>
        <li>Expats who may move within EU</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Long-term residents (GKV or German PKV)</li>
        <li>US expats (Aetna or GeoBlue)</li>
        <li>Budget-focused nomads</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Germany?"
    description="Get a personalized Allianz Care quote."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />
</PageShell>
