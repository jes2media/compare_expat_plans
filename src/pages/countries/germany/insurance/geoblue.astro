---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Germany', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'germany-benefits', text: 'Germany-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Germany', href: '/countries/germany/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Aetna', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'germanyPrice', header: 'Germany (Age 40)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Core coverage', germanyPrice: '€150-200/mo' },
  { plan: 'Xplorer Premier', coverage: 'Comprehensive', germanyPrice: '€220-300/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Germany"
  description="Guide to using GeoBlue in Germany. Blue Cross Blue Shield network, US expat focus."
  headline="GeoBlue Health Insurance in Germany"
  subheadline="GeoBlue for US expats in Germany—Blue Cross Blue Shield network access and strong US coverage."
  heroBackgroundImage="/images/countries/germany-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Quote"
  ctaButtonHref="/providers/geoblue"
>
  <h2 id="overview">GeoBlue in Germany</h2>
  <p>
    GeoBlue, backed by Blue Cross Blue Shield, provides US expats in Germany access to America's largest provider network when they return home. For Americans familiar with Blue Cross coverage, GeoBlue extends that familiarity abroad.
  </p>
  <p>
    With a strong mobile app and telemedicine features, GeoBlue works well for tech-savvy American expats in Germany's digital-forward environment.
  </p>

  <CTABox
    title="Get a Germany Quote"
    description="See GeoBlue pricing for US expats in Germany."
    buttonText="Get Quote"
    buttonHref="/providers/geoblue"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="germany-benefits">Germany-Specific Benefits</h2>
  <ul>
    <li><strong>Blue Cross network:</strong> Access to BCBS providers in the US</li>
    <li><strong>Mobile app:</strong> Find doctors, file claims, access ID cards</li>
    <li><strong>Telemedicine:</strong> 24/7 virtual doctor access</li>
    <li><strong>Visa compliance:</strong> Xplorer Premier meets German requirements</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose GeoBlue in Germany</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens with BCBS familiarity</li>
        <li>Tech-savvy expats who value app features</li>
        <li>Those who return to the US regularly</li>
        <li>Expats wanting telemedicine access</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens</li>
        <li>Those who won't use US coverage</li>
        <li>Long-term residents (GKV/PKV)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Germany?"
    description="Get a personalized GeoBlue quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/geoblue"
    variant="highlight"
  />
</PageShell>
