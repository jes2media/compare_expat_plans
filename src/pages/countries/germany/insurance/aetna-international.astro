---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Germany', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'germany-benefits', text: 'Germany-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Germany', href: '/countries/germany/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs GeoBlue', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'germanyPrice', header: 'Germany (Age 40)' },
];

const planRows = [
  { plan: 'Pioneer', coverage: 'Inpatient focused', germanyPrice: '€160-220/mo' },
  { plan: 'Navigator', coverage: 'Comprehensive', germanyPrice: '€240-320/mo' },
  { plan: 'Vantage', coverage: 'Premium + USA', germanyPrice: '€320-450/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Germany"
  description="Guide to using Aetna International in Germany. US expat focus, integrated US coverage."
  headline="Aetna International Health Insurance in Germany"
  subheadline="Aetna International for US expats in Germany—integrated US coverage and familiar American insurer support."
  heroBackgroundImage="/images/countries/germany-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Quote"
  ctaButtonHref="/providers/aetna-international"
>
  <h2 id="overview">Aetna International in Germany</h2>
  <p>
    Aetna International is ideal for US citizens moving to Germany who want seamless coverage when returning to the US. As part of CVS Health, Aetna offers US healthcare integration that European insurers can't match.
  </p>
  <p>
    Germany has a large American expat community, particularly in cities like Frankfurt, Munich, and Berlin. Aetna serves this community with familiar American service.
  </p>

  <CTABox
    title="Get a Germany Quote"
    description="See Aetna International pricing for US expats in Germany."
    buttonText="Get Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="germany-benefits">Germany-Specific Benefits</h2>
  <ul>
    <li><strong>US return coverage:</strong> Seamless care when visiting the US</li>
    <li><strong>CVS integration:</strong> Pharmacy benefits in the US</li>
    <li><strong>Visa compliance:</strong> Navigator and Vantage meet German requirements</li>
    <li><strong>American service style:</strong> Familiar US customer experience</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Aetna in Germany</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens moving to Germany</li>
        <li>Those who return to the US regularly</li>
        <li>Expats wanting US insurer familiarity</li>
        <li>Those with ongoing US healthcare needs</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens (Allianz may be better)</li>
        <li>Those who won't return to the US</li>
        <li>Long-term residents (GKV/PKV)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Germany?"
    description="Get a personalized Aetna International quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />
</PageShell>
