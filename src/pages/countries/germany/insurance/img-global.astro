---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Germany', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'germany-benefits', text: 'Germany-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Germany', href: '/countries/germany/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'germanyPrice', header: 'Germany (Age 40)' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Comprehensive', germanyPrice: '€110-160/mo' },
  { plan: 'Global Medical + Outpatient', coverage: 'Full coverage', germanyPrice: '€150-210/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Germany"
  description="Guide to using IMG Global in Germany. Budget-friendly international coverage for expats."
  headline="IMG Global Health Insurance in Germany"
  subheadline="IMG Global for expats in Germany—budget-friendly international coverage for visa applications and initial periods."
  heroBackgroundImage="/images/countries/germany-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in Germany</h2>
  <p>
    IMG Global offers budget-friendly international health insurance that works well for expats in Germany during visa applications and initial establishment periods. It's typically 20-40% cheaper than premium competitors.
  </p>
  <p>
    For expats who plan to transition to Germany's GKV or PKV system, IMG provides affordable coverage for the interim period.
  </p>

  <CTABox
    title="Get a Germany Quote"
    description="See IMG Global pricing for expats in Germany."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    IMG costs significantly less than Cigna or BUPA while providing solid coverage. Good for expats who don't need premium service features and plan to transition to the German system.
  </p>

  <h2 id="germany-benefits">Germany-Specific Benefits</h2>
  <ul>
    <li><strong>Visa compliance:</strong> Meets German visa insurance requirements</li>
    <li><strong>Budget-friendly:</strong> Lower premiums than premium competitors</li>
    <li><strong>Flexible terms:</strong> Various deductible options available</li>
    <li><strong>Worldwide coverage:</strong> Good for expats who travel</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose IMG in Germany</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Those planning to transition to GKV</li>
        <li>Job seekers (6-month visa period)</li>
        <li>Freelancers in first year</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium service</li>
        <li>Expats with pre-existing conditions</li>
        <li>Those needing extensive direct billing</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in Germany?"
    description="Get a personalized IMG Global quote."
    buttonText="Get Your Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />
</PageShell>
