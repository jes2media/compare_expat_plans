  { title: 'Allianz Care in Germany', href: '/countries/germany/insurance/allianz-care' },
  { title: 'BUPA Global in Germany', href: '/countries/germany/insurance/bupa-global' },
  { title: 'IMG Global in Germany', href: '/countries/germany/insurance/img-global' },
