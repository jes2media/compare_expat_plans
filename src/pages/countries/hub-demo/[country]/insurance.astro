---
/**
 * Demo route for CountryInsuranceHub template.
 *
 * This generates preview pages at:
 * - /countries/hub-demo/spain/insurance
 * - /countries/hub-demo/portugal/insurance
 * - /countries/hub-demo/mexico/insurance
 *
 * These are for internal review only. Once approved, the template
 * can be used to refactor the real country routes.
 */

import CountryInsuranceHub from '../../../../templates/CountryInsuranceHub.astro';
import { countriesSeed, getCountryBySlug, getAllCountrySlugs } from '../../../../data/countries.seed';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return getAllCountrySlugs().map(slug => ({
    params: { country: slug },
    props: { country: getCountryBySlug(slug)! },
  }));
};

const { country } = Astro.props;
---

<CountryInsuranceHub country={country} />
