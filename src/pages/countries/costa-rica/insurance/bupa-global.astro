---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Costa Rica', level: 2 },
  { id: 'caja-strategy', text: 'CAJA + BUPA Strategy', level: 2 },
  { id: 'costa-rica-network', text: 'Network Coverage', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Local Options', level: 2 },
  { id: 'claims', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Costa Rica', href: '/countries/costa-rica/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'crPrice', header: 'Costa Rica (Age 50)' },
  { key: 'mentalHealth', header: 'Mental Health' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Inpatient + Day-patient', crPrice: '$160-210/mo', mentalHealth: 'Limited' },
  { plan: 'Complete', coverage: 'Essentials + Outpatient', crPrice: '$230-300/mo', mentalHealth: 'Full parity' },
  { plan: 'Premier', coverage: 'Complete + Dental/Vision', crPrice: '$315-410/mo', mentalHealth: 'Full parity' },
  { plan: 'Elite', coverage: 'Maximum coverage', crPrice: '$395-510/mo', mentalHealth: 'Full parity' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'local', header: 'CAJA + INS' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', bupa: '$230-300', local: '~$135 combined' },
  { factor: 'Mental Health Parity', bupa: 'Full parity', local: 'Limited' },
  { factor: 'Pre-existing Conditions', bupa: 'Often covered', local: 'Usually excluded' },
  { factor: 'No-Claims Discount', bupa: 'Up to 30%', local: 'No' },
  { factor: 'Private Hospital Access', bupa: 'Yes', local: 'INS network only' },
  { factor: 'Portability', bupa: 'Worldwide', local: 'Costa Rica only' },
  { factor: 'Dental Included', bupa: 'Premier+ plans', local: 'CAJA: limited' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'San José', hospitals: 'CIMA Hospital, Clínica Bíblica, Hospital La Católica', directBilling: true },
  { city: 'Escazú', hospitals: 'Hospital Metropolitano, CIMA San José', directBilling: true },
  { city: 'Heredia', hospitals: 'Hospital Heredia (private)', directBilling: true },
  { city: 'Guanacaste', hospitals: 'Clínica Bíblica Santa Cruz', directBilling: true },
];
---

<PageShell
  title="BUPA Global Health Insurance in Costa Rica"
  description="Complete guide to using BUPA Global in Costa Rica. Premium coverage with mental health parity and pre-existing condition handling."
  headline="BUPA Global Health Insurance in Costa Rica"
  subheadline="Premium international coverage for expats in Costa Rica. Mental health parity, pre-existing conditions, and how it works with CAJA."
  heroBackgroundImage="/images/countries/costa-rica-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Costa Rica Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Costa Rica</h2>
  <p>
    BUPA Global is the premium choice for expats in Costa Rica who want comprehensive coverage without gaps. Their standout features — mental health parity and favorable pre-existing condition handling — address common concerns that other insurers don't.
  </p>
  <p>
    While CAJA is mandatory for residents, BUPA Global provides what CAJA lacks: immediate private care, mental health treatment on par with physical health, and worldwide coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">4.4/5</p>
      <p class="text-sm text-neutral-600">Trustpilot rating</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">30%</p>
      <p class="text-sm text-neutral-600">No-claims discount</p>
    </div>
  </div>

  <CTABox
    title="Get a Costa Rica-Specific Quote"
    description="See what BUPA Global costs for expats living in Costa Rica."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="caja-strategy">CAJA + BUPA Strategy</h2>
  <p>
    Even with BUPA Global's comprehensive coverage, you still need CAJA as a resident. Here's how to use both effectively:
  </p>

  <h3>Use CAJA For:</h3>
  <ul>
    <li>Prescriptions (often free or very low cost)</li>
    <li>Routine preventive care</li>
    <li>Non-urgent issues where you don't mind waiting</li>
  </ul>

  <h3>Use BUPA For:</h3>
  <ul>
    <li>Urgent care and specialists (no wait)</li>
    <li>Mental health treatment</li>
    <li>Pre-existing conditions (if covered)</li>
    <li>Private hospital stays</li>
    <li>Care outside Costa Rica</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">Mental Health Coverage in Costa Rica</h3>
    <p class="text-green-800">
      Mental health services in Costa Rica can be limited through public options, and many private insurers have low sub-limits. BUPA Global's mental health parity means therapy, psychiatric care, and hospitalization are covered at the same level as physical health conditions.
    </p>
  </div>

  <h2 id="costa-rica-network">Network Coverage in Costa Rica</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Key Network Points</h3>
  <ul>
    <li><strong>Central Valley:</strong> Excellent coverage at CIMA, Clínica Bíblica, Hospital La Católica</li>
    <li><strong>Mental health facilities:</strong> Access to psychiatric care and therapy networks</li>
    <li><strong>Reimbursement:</strong> Use any provider and submit for reimbursement</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Add 50-70% for US coverage.</em>
  </p>

  <h3>What Makes BUPA Different</h3>
  <ul>
    <li><strong>Mental health parity:</strong> Same limits as physical health</li>
    <li><strong>Pre-existing conditions:</strong> Often covered from day one with disclosure</li>
    <li><strong>No-claims discount:</strong> Up to 30% savings for healthy years</li>
    <li><strong>Dental/vision included:</strong> Premier and Elite plans</li>
  </ul>

  <h3>Which Plan for Costa Rica?</h3>
  <ul>
    <li><strong>Complete:</strong> The practical choice. Full coverage with mental health parity.</li>
    <li><strong>Premier:</strong> Adds dental and vision. Good for families.</li>
    <li><strong>Elite:</strong> Maximum coverage for comprehensive protection.</li>
  </ul>

  <CTABox
    title="Worth the Premium?"
    description="Get a personalized quote to see the actual cost difference."
    buttonText="Get a Quote"
    buttonHref="/providers/bupa-global"
  />

  <h2 id="vs-local-options">vs Local Options</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose BUPA Global If:</h3>
  <ul>
    <li>Mental health coverage is essential</li>
    <li>You have pre-existing conditions</li>
    <li>You want dental/vision included</li>
    <li>No-claims discounts appeal to you</li>
    <li>You may relocate</li>
  </ul>

  <h3>Rely on CAJA + INS If:</h3>
  <ul>
    <li>Budget is the primary concern</li>
    <li>Mental health isn't a priority</li>
    <li>You're healthy without pre-existing conditions</li>
  </ul>

  <p>
    <a href="/countries/costa-rica/insurance">See all Costa Rica insurance options →</a>
  </p>

  <h2 id="claims">Using Your Insurance in Costa Rica</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, present your BUPA card for cashless treatment.
  </p>

  <h3>MembersWorld Portal</h3>
  <p>
    BUPA's app lets you find providers, submit claims, track status, and chat with support.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in Costa Rica</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those needing mental health coverage</li>
        <li>Expats with pre-existing conditions</li>
        <li>Families wanting all-inclusive plans</li>
        <li>Those who value premium service</li>
        <li>Expats who may relocate</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Young, healthy individuals</li>
        <li>Permanent Costa Rica residents</li>
        <li>Those comfortable with CAJA</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Do I still need CAJA with BUPA?</h3>
  <p>
    Yes. CAJA is mandatory for all legal residents in Costa Rica. BUPA is a supplement.
  </p>

  <h3>Will BUPA cover my pre-existing condition?</h3>
  <p>
    Possibly. BUPA often covers pre-existing conditions from day one with full disclosure. You may get full coverage, coverage with limits, or a waiting period.
  </p>

  <h3>How does mental health parity work?</h3>
  <p>
    BUPA covers mental health at the same limits as physical health. If your plan has a $2M limit, that applies equally to psychiatric care and therapy.
  </p>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for Costa Rica."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. CAJA requirements change. Verify all information with BUPA Global and Costa Rican authorities.
    </p>
  </div>
</PageShell>
