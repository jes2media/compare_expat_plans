---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Costa Rica', level: 2 },
  { id: 'caja-strategy', text: 'CAJA + IMG Strategy', level: 2 },
  { id: 'costa-rica-network', text: 'Network Coverage', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Local Options', level: 2 },
  { id: 'claims', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Costa Rica', href: '/countries/costa-rica/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'crPrice', header: 'Costa Rica (Age 50)' },
  { key: 'effectiveDed', header: 'Effective Deductible' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Inpatient + Outpatient', crPrice: '$100-140/mo', effectiveDed: '50% waiver' },
  { plan: 'With $2,500 Deductible', coverage: 'Inpatient + Outpatient', crPrice: '$75-105/mo', effectiveDed: '$1,250 effective' },
  { plan: 'With $5,000 Deductible', coverage: 'Inpatient + Outpatient', crPrice: '$60-85/mo', effectiveDed: '$2,500 effective' },
  { plan: 'With $10,000 Deductible', coverage: 'Inpatient + Outpatient', crPrice: '$50-70/mo', effectiveDed: '$5,000 effective' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'img', header: 'IMG Global' },
  { key: 'local', header: 'CAJA + INS' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', img: '$100-140', local: '~$135 combined' },
  { factor: 'With High Deductible', img: '$50-85', local: 'Limited options' },
  { factor: 'Deductible Waiver', img: '50% outside US', local: 'No' },
  { factor: 'Annual Maximum', img: 'Up to $8M', local: 'Varies' },
  { factor: 'Medical Evacuation', img: 'Up to $500K', local: 'Not included' },
  { factor: 'Portability', img: 'Worldwide', local: 'Costa Rica only' },
  { factor: 'Network', img: 'Reimbursement', local: 'INS network' },
];

const savingsColumns = [
  { key: 'scenario', header: 'Coverage Scenario' },
  { key: 'img', header: 'IMG Global' },
  { key: 'premium', header: 'Premium Insurers' },
  { key: 'savings', header: 'Annual Savings' },
];

const savingsRows = [
  { scenario: 'Standard deductible', img: '$1,200-1,680/yr', premium: '$2,760-3,600/yr', savings: '$1,560-1,920' },
  { scenario: '$2,500 deductible', img: '$900-1,260/yr', premium: '$2,040-2,760/yr', savings: '$1,140-1,500' },
  { scenario: '$5,000 deductible', img: '$720-1,020/yr', premium: 'Limited options', savings: '$1,000+' },
];
---

<PageShell
  title="IMG Global Health Insurance in Costa Rica"
  description="Complete guide to using IMG Global in Costa Rica. Budget-friendly international coverage with the 50% deductible waiver advantage."
  headline="IMG Global Health Insurance in Costa Rica"
  subheadline="Budget-friendly international coverage for expats in Costa Rica. How IMG's 50% deductible waiver makes high-deductible plans practical."
  heroBackgroundImage="/images/countries/costa-rica-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Costa Rica Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in Costa Rica</h2>
  <p>
    IMG Global offers a budget-friendly path to international health insurance for expats in Costa Rica. Combined with mandatory CAJA for routine care, IMG's high-deductible options and 50% deductible waiver provide maximum savings.
  </p>
  <p>
    The strategy: CAJA handles prescriptions and basic care (it's required anyway), IMG covers private hospitals and major expenses with worldwide portability.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$8M</p>
      <p class="text-sm text-neutral-600">Max annual limit</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">50%</p>
      <p class="text-sm text-neutral-600">Deductible waiver outside US</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$500K</p>
      <p class="text-sm text-neutral-600">Medical evacuation</p>
    </div>
  </div>

  <CTABox
    title="Get a Costa Rica-Specific Quote"
    description="See what IMG Global costs for expats living in Costa Rica."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="caja-strategy">CAJA + IMG Strategy</h2>
  <p>
    The most cost-effective approach combines mandatory CAJA with IMG's high-deductible plans.
  </p>

  <h3>The Numbers</h3>
  <ul>
    <li><strong>CAJA:</strong> ~$75/month (required)</li>
    <li><strong>IMG with $5,000 deductible:</strong> ~$60-85/month</li>
    <li><strong>Total:</strong> ~$135-160/month for comprehensive coverage</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">The 50% Deductible Waiver</h3>
    <p class="text-green-800">
      IMG's standout feature: treatment outside the US gets 50% off your deductible. A $5,000 deductible becomes $2,500 effective in Costa Rica. Combined with CAJA for routine care, you're unlikely to hit even this reduced amount except for major events.
    </p>
  </div>

  <h2 id="costa-rica-network">Network Coverage in Costa Rica</h2>
  <p>
    IMG uses primarily a reimbursement model in Costa Rica. Pay providers directly, then submit claims.
  </p>

  <h3>How It Works</h3>
  <ul>
    <li><strong>Any licensed provider:</strong> See any doctor or hospital</li>
    <li><strong>Private hospitals:</strong> CIMA, Clínica Bíblica, Hospital La Católica</li>
    <li><strong>Pay and submit:</strong> Reimbursement typically in 5-10 days</li>
    <li><strong>Freedom:</strong> No network restrictions</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Age 50 shown.</em>
  </p>

  <h3>Savings Comparison</h3>
  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={savingsColumns} rows={savingsRows} />
  </div>

  <CTABox
    title="Calculate Your Savings"
    description="See how much you can save with IMG's high-deductible options."
    buttonText="Get a Quote"
    buttonHref="/go/img-global"
  />

  <h2 id="vs-local-options">vs Local Options</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose IMG Global If:</h3>
  <ul>
    <li>Budget is a major consideration</li>
    <li>High-deductible strategy appeals to you</li>
    <li>You're comfortable with reimbursement</li>
    <li>You travel outside Costa Rica</li>
    <li>Medical evacuation is important</li>
    <li>Maximum coverage limits matter ($8M)</li>
  </ul>

  <h3>Rely on CAJA + INS If:</h3>
  <ul>
    <li>You want direct billing networks</li>
    <li>You're under 70 (INS age limit)</li>
    <li>You don't travel internationally</li>
  </ul>

  <p>
    <a href="/countries/costa-rica/insurance">See all Costa Rica insurance options →</a>
  </p>

  <h2 id="claims">Using Your Insurance in Costa Rica</h2>

  <h3>Reimbursement Process</h3>
  <ol class="list-decimal list-inside space-y-2">
    <li>See any licensed provider</li>
    <li>Pay at time of service (get receipt)</li>
    <li>Submit via IMG app or portal</li>
    <li>Processing: 5-10 business days</li>
    <li>Reimbursement to your bank account</li>
  </ol>

  <h3>Medical Evacuation</h3>
  <p>
    IMG includes up to $500K medical evacuation — important if you live outside San José and might need transport for specialized care.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in Costa Rica</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals</li>
        <li>Those comfortable with reimbursement</li>
        <li>Expats who travel frequently</li>
        <li>Those wanting maximum limits</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting direct billing</li>
        <li>Expats with pre-existing conditions</li>
        <li>Those needing mental health coverage</li>
        <li>People preferring established brands</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Do I still need CAJA with IMG?</h3>
  <p>
    Yes. CAJA is mandatory for all legal residents. IMG is a supplement.
  </p>

  <h3>How does the 50% deductible waiver work?</h3>
  <p>
    Treatment outside the US automatically gets 50% off your deductible. A $5,000 deductible becomes $2,500 in Costa Rica. No request needed — it's automatic.
  </p>

  <h3>Does IMG cover pre-existing conditions?</h3>
  <p>
    IMG typically excludes or applies waiting periods. If you have significant conditions, consider BUPA Global.
  </p>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for Costa Rica."
    buttonText="Get Your Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. CAJA requirements change. Verify all information with IMG Global and Costa Rican authorities.
    </p>
  </div>
</PageShell>
