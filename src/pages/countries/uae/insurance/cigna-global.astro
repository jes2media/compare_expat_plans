---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'uae-network', text: 'Network Coverage in UAE', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Local UAE Insurers', level: 2 },
  { id: 'claims-in-uae', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Cigna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs Allianz', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
  { key: 'dhaCompliant', header: 'DHA Compliant' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Inpatient + Day-patient', uaePrice: '$150-200/mo', dhaCompliant: true },
  { plan: 'Gold', coverage: 'Silver + Outpatient', uaePrice: '$200-280/mo', dhaCompliant: true },
  { plan: 'Platinum', coverage: 'Gold + Enhanced', uaePrice: '$280-380/mo', dhaCompliant: true },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Dubai', hospitals: 'American Hospital, Mediclinic City Hospital, Emirates Hospital, Saudi German', directBilling: true },
  { city: 'Abu Dhabi', hospitals: 'Cleveland Clinic Abu Dhabi, Mediclinic, NMC Royal', directBilling: true },
  { city: 'Sharjah', hospitals: 'Zulekha Hospital, University Hospital Sharjah', directBilling: true },
];
---

<PageShell
  title="Cigna Global Health Insurance in UAE"
  description="Complete guide to using Cigna Global in UAE. DHA compliance, Dubai and Abu Dhabi networks, pricing, and comparison to local insurers."
  headline="Cigna Global Health Insurance in UAE"
  subheadline="Is Cigna Global the right choice for expats in the UAE? Coverage, compliance, and how it compares to local options."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna UAE Quote"
  ctaButtonHref="/providers/cigna-global"
>
  <h2 id="overview">Cigna Global in UAE</h2>
  <p>
    Cigna Global is one of the most popular international health insurers among UAE expats. With DHA and HAAD compliance, strong local networks, and worldwide portability, it's a premium choice for professionals who want comprehensive coverage beyond basic employer plans.
  </p>
  <p>
    The trade-off is price. Cigna Global costs more than local UAE insurers, but offers higher coverage limits, better international coverage, and portability if you relocate.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$1-3M</p>
      <p class="text-sm text-neutral-600">Annual coverage limits</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">DHA</p>
      <p class="text-sm text-neutral-600">Dubai compliant</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">24/7</p>
      <p class="text-sm text-neutral-600">Multilingual support</p>
    </div>
  </div>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what Cigna Global costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    Cigna Global plans are approved for both Dubai (DHA) and Abu Dhabi (DOH/HAAD) visa requirements.
  </p>

  <h3>Dubai Requirements</h3>
  <p>
    DHA mandates AED 150,000 (~$41,000) minimum coverage. Cigna Global plans far exceed this with $1-3M annual limits. Gold and Platinum plans meet all DHA requirements including:
  </p>
  <ul>
    <li>Inpatient and outpatient coverage</li>
    <li>Emergency care</li>
    <li>Maternity benefits</li>
    <li>Basic diagnostics and tests</li>
  </ul>

  <h3>Abu Dhabi Requirements</h3>
  <p>
    Cigna Global is also compliant with Abu Dhabi Department of Health requirements. Plans meet enhanced coverage standards for professional employees.
  </p>

  <h3>Employer Plans vs Personal Coverage</h3>
  <p>
    Many employers provide basic DHA-compliant coverage. Cigna Global can serve as:
  </p>
  <ul>
    <li>Primary coverage if you're self-employed or freelance</li>
    <li>Supplemental coverage for better benefits and higher limits</li>
    <li>Family coverage when employer plans only cover employees</li>
  </ul>

  <h2 id="uae-network">Network Coverage in UAE</h2>
  <p>
    Cigna Global has an extensive network in the UAE, with direct billing at major hospitals in Dubai, Abu Dhabi, and other emirates.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Key Network Points</h3>
  <ul>
    <li><strong>Dubai:</strong> Full coverage at top hospitals including American Hospital and Mediclinic</li>
    <li><strong>Abu Dhabi:</strong> Cleveland Clinic Abu Dhabi and other world-class facilities</li>
    <li><strong>Dubai Healthcare City:</strong> Access to specialized medical facilities</li>
    <li><strong>Direct billing:</strong> Available at most major private hospitals</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    Cigna Global offers three tiers for UAE-based expats:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Age 40 shown as typical for UAE professional expats.</em>
  </p>

  <h3>Which Plan for UAE?</h3>
  <ul>
    <li><strong>Silver:</strong> Inpatient only. DHA-compliant. Good if you pay routine care out of pocket.</li>
    <li><strong>Gold:</strong> The practical choice. Full inpatient + outpatient, good benefits.</li>
    <li><strong>Platinum:</strong> Maximum coverage including enhanced mental health and wellness.</li>
  </ul>

  <h2 id="vs-local-options">vs Local UAE Insurers</h2>
  <p>
    How does Cigna Global compare to local insurers like Daman, Oman Insurance, or AXA Gulf?
  </p>

  <h3>Choose Cigna Global If:</h3>
  <ul>
    <li>You want worldwide coverage beyond UAE</li>
    <li>You travel frequently</li>
    <li>Portability matters (may relocate)</li>
    <li>You want higher coverage limits ($1-3M)</li>
    <li>Mental health coverage is important</li>
  </ul>

  <h3>Choose Local UAE Insurers If:</h3>
  <ul>
    <li>Budget is the primary concern</li>
    <li>You're staying in UAE long-term</li>
    <li>Basic compliance is sufficient</li>
    <li>You don't travel outside UAE</li>
  </ul>

  <h2 id="claims-in-uae">Using Your Insurance in UAE</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, present your Cigna membership card for cashless treatment. UAE hospitals are experienced with international insurers.
  </p>

  <h3>Reimbursement</h3>
  <p>
    For non-network providers, pay upfront and submit claims via Cigna's app or portal. Typical processing: 5-7 business days.
  </p>

  <h2 id="who-its-for">Who Should Choose Cigna in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Expats who travel frequently</li>
        <li>Those wanting highest coverage limits</li>
        <li>People who may relocate from UAE</li>
        <li>Freelancers and Golden Visa holders</li>
        <li>Families wanting comprehensive coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Those with good employer coverage</li>
        <li>Expats staying in UAE permanently</li>
        <li>Those who rarely travel</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in UAE?"
    description="Get a personalized Cigna Global quote for your situation."
    buttonText="Get Your Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Verify DHA/HAAD compliance directly with Cigna before purchasing.
    </p>
  </div>
</PageShell>
