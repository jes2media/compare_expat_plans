---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Cigna', href: '/compare/axa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
];

const planRows = [
  { plan: 'Comfort', coverage: 'Essential coverage', uaePrice: '$100-140/mo' },
  { plan: 'Standard', coverage: 'Standard + Outpatient', uaePrice: '$140-190/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', uaePrice: '$200-270/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in UAE"
  description="Guide to using AXA Global in UAE. EU-regulated international coverage with competitive pricing for Dubai and Abu Dhabi expats."
  headline="AXA Global Health Insurance in UAE"
  subheadline="EU-regulated international coverage with strong value and European heritage."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA UAE Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in UAE</h2>
  <p>
    AXA Global offers EU-regulated international health insurance with competitive pricing. For UAE expats, AXA provides solid coverage at a lower price point than many competitors, with the security of EU regulatory protections.
  </p>
  <p>
    AXA Gulf, their regional arm, has strong local presence and DHA approval, making them a practical choice for UAE residents.
  </p>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what AXA Global costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    AXA has strong presence in UAE through AXA Gulf and their international division. Plans meet DHA and HAAD requirements with coverage up to €1M or unlimited.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    AXA typically costs 20-30% less than premium competitors like BUPA while offering comparable core coverage. For value-conscious expats who want international coverage, AXA is worth considering.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Those who travel to Europe</li>
        <li>Expats wanting EU regulatory protection</li>
        <li>Families seeking affordable international coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing US network access</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those wanting premium service</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized AXA Global quote for UAE."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify DHA/HAAD compliance directly with AXA before purchasing.
    </p>
  </div>
</PageShell>
