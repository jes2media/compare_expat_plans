---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'uae-network', text: 'Network Coverage in UAE', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', uaePrice: '$100-140/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', uaePrice: '$150-200/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', uaePrice: '$220-300/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in UAE"
  description="Guide to using Allianz Care in UAE. DHA compliance, Dubai and Abu Dhabi coverage, pricing, and modular plan options."
  headline="Allianz Care Health Insurance in UAE"
  subheadline="Flexible, modular international coverage for UAE expats with competitive pricing."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz UAE Quote"
  ctaButtonHref="/providers/allianz-care"
>
  <h2 id="overview">Allianz Care in UAE</h2>
  <p>
    Allianz Care offers modular international health insurance that's popular among UAE expats who want flexibility and competitive pricing. Their plans are DHA-compliant and provide strong coverage both within UAE and worldwide.
  </p>
  <p>
    The key advantage is customization—you can build a plan that matches your needs and budget by selecting coverage modules.
  </p>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what Allianz Care costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    Allianz Care plans meet Dubai DHA and Abu Dhabi DOH requirements. Plans exceed the AED 150,000 minimum with coverage up to €1M or unlimited.
  </p>
  <p>
    Classic and Premium plans include required benefits like outpatient care, emergency treatment, and maternity.
  </p>

  <h2 id="uae-network">Network Coverage in UAE</h2>
  <p>
    Allianz Care has a strong network in the UAE with direct billing at major hospitals in Dubai and Abu Dhabi. Network includes American Hospital, Mediclinic facilities, and Cleveland Clinic Abu Dhabi.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Options</h3>
  <p>
    Allianz offers deductibles up to €10,000, which can reduce premiums by 30-50%. This works well in UAE where routine care is expensive but catastrophic coverage is the priority.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats wanting international coverage</li>
        <li>Those who want customizable plans</li>
        <li>Expats who travel within Europe frequently</li>
        <li>People comfortable with high deductibles</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting US network access</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those preferring all-inclusive plans</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage?"
    description="Get a personalized Allianz Care quote for UAE."
    buttonText="Get Your Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify DHA/HAAD compliance directly with Allianz before purchasing.
    </p>
  </div>
</PageShell>
