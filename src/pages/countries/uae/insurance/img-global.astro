---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
];

const planRows = [
  { plan: 'Global Select', coverage: 'Core international', uaePrice: '$90-130/mo' },
  { plan: 'Global Premier', coverage: 'Enhanced benefits', uaePrice: '$130-180/mo' },
  { plan: 'Global Elite', coverage: 'Comprehensive', uaePrice: '$180-250/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in UAE"
  description="Guide to using IMG Global in UAE. Budget-friendly international coverage with high-deductible options for cost-conscious expats."
  headline="IMG Global Health Insurance in UAE"
  subheadline="Budget-friendly international coverage with flexible deductible options."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG UAE Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in UAE</h2>
  <p>
    IMG Global offers budget-friendly international health insurance for UAE expats. Their high-deductible options can significantly reduce premiums while still providing catastrophic coverage.
  </p>
  <p>
    IMG's "50% deductible waiver" for care outside the US is less relevant in UAE, but their overall value proposition appeals to cost-conscious expats.
  </p>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what IMG Global costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    IMG Global plans can meet UAE visa requirements, but verification is essential. Coverage limits up to $8M exceed DHA minimums.
  </p>
  <p>
    Check with IMG and local authorities to confirm compliance before relying on IMG for visa purposes.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    IMG offers deductibles up to $25,000, which can reduce premiums dramatically. For expats who want catastrophic coverage and will pay routine care out of pocket, this can save thousands annually.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals</li>
        <li>Those comfortable with high deductibles</li>
        <li>Expats wanting international coverage at lower cost</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing mental health coverage</li>
        <li>Expats with pre-existing conditions</li>
        <li>Those wanting premium service</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for UAE."
    buttonText="Get Your Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify DHA/HAAD compliance directly with IMG before purchasing.
    </p>
  </div>
</PageShell>
