---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs Cigna', href: '/compare/cigna-global-vs-aetna-international' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
];

const planRows = [
  { plan: 'Pioneer', coverage: 'Core coverage', uaePrice: '$160-220/mo' },
  { plan: 'Navigator', coverage: 'Enhanced', uaePrice: '$220-300/mo' },
  { plan: 'Voyager', coverage: 'Comprehensive', uaePrice: '$300-400/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in UAE"
  description="Guide to using Aetna International in UAE. Premium coverage with US network integration for American expats in Dubai and Abu Dhabi."
  headline="Aetna International Health Insurance in UAE"
  subheadline="Premium international coverage with seamless US network access for American expats."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna UAE Quote"
  ctaButtonHref="/providers/aetna-international"
>
  <h2 id="overview">Aetna International in UAE</h2>
  <p>
    Aetna International is a strong choice for American expats in the UAE who want seamless coverage both locally and when returning to the US. With access to Aetna's massive US network (1.7M+ providers), it's ideal for those who maintain ties to American healthcare.
  </p>
  <p>
    For non-US expats, Aetna still offers comprehensive coverage, though the US network advantage is less relevant.
  </p>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what Aetna International costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    Aetna International plans are DHA and HAAD compliant. Coverage limits of $1-5M far exceed UAE minimums. Navigator and Voyager plans include all required benefits.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>US Network Integration</h3>
  <p>
    Aetna's key differentiator is US network access. If you're American and visit the US regularly, having access to 1.7M+ US providers with direct billing is valuable.
  </p>

  <h2 id="who-its-for">Who Should Choose Aetna in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>American expats</li>
        <li>Those who return to US regularly</li>
        <li>Expats who want US network access</li>
        <li>Families with US healthcare ties</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US expats (overpaying for US access)</li>
        <li>Budget-conscious expats</li>
        <li>Those who never visit the US</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for US-Integrated Coverage?"
    description="Get a personalized Aetna International quote for UAE."
    buttonText="Get Your Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify DHA/HAAD compliance directly with Aetna before purchasing.
    </p>
  </div>
</PageShell>
