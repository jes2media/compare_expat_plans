---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/geoblue-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Core coverage', uaePrice: '$140-190/mo' },
  { plan: 'Xplorer Select', coverage: 'Enhanced', uaePrice: '$190-260/mo' },
  { plan: 'Xplorer Premier', coverage: 'Comprehensive', uaePrice: '$260-350/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in UAE"
  description="Guide to using GeoBlue in UAE. BCBS network access for American expats in Dubai and Abu Dhabi."
  headline="GeoBlue Health Insurance in UAE"
  subheadline="Blue Cross Blue Shield network access for American expats in the UAE."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue UAE Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in UAE</h2>
  <p>
    GeoBlue is powered by Blue Cross Blue Shield, offering American expats in UAE access to 90%+ of US hospitals when they return home. In UAE, GeoBlue provides solid international coverage with a strong provider network.
  </p>
  <p>
    The main advantage is BCBS network access—if you're American and value seamless US coverage, GeoBlue delivers.
  </p>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what GeoBlue costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    GeoBlue plans can meet UAE visa requirements. Coverage limits of $1-5M exceed DHA minimums. Verify compliance directly with GeoBlue before purchasing.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>BCBS Network</h3>
  <p>
    GeoBlue's connection to BCBS means 90%+ of US hospitals accept your coverage directly. For Americans who visit home regularly, this is a significant advantage.
  </p>

  <h2 id="who-its-for">Who Should Choose GeoBlue in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>American expats</li>
        <li>Those who value BCBS network</li>
        <li>Expats returning to US frequently</li>
        <li>Families with US-based doctors</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-American expats</li>
        <li>Those who rarely visit the US</li>
        <li>Budget-conscious expats</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for BCBS Coverage?"
    description="Get a personalized GeoBlue quote for UAE."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify DHA/HAAD compliance directly with GeoBlue before purchasing.
    </p>
  </div>
</PageShell>
