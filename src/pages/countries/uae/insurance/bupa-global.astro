---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in UAE', level: 2 },
  { id: 'compliance', text: 'DHA/HAAD Compliance', level: 2 },
  { id: 'uae-network', text: 'Network Coverage in UAE', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in UAE', href: '/countries/uae/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'uaePrice', header: 'UAE (Age 40)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Core inpatient', uaePrice: '$180-240/mo' },
  { plan: 'Select', coverage: 'Inpatient + Outpatient', uaePrice: '$250-340/mo' },
  { plan: 'Elite', coverage: 'Comprehensive', uaePrice: '$350-480/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in UAE"
  description="Guide to using BUPA Global in UAE. Premium coverage, DHA compliance, and excellent mental health benefits for Dubai and Abu Dhabi expats."
  headline="BUPA Global Health Insurance in UAE"
  subheadline="Premium international coverage with industry-leading mental health benefits."
  heroBackgroundImage="/images/countries/uae-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA UAE Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">BUPA Global in UAE</h2>
  <p>
    BUPA Global is the premium choice for UAE expats who want the best coverage available. They're known for excellent mental health benefits, comprehensive coverage, and outstanding customer service.
  </p>
  <p>
    The trade-off is price—BUPA is typically the most expensive international insurer. For those who want maximum protection and can afford it, BUPA delivers.
  </p>

  <CTABox
    title="Get a UAE-Specific Quote"
    description="See what BUPA Global costs for expats living in the UAE."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="compliance">DHA/HAAD Compliance</h2>
  <p>
    BUPA Global plans are fully compliant with Dubai DHA and Abu Dhabi DOH requirements. All plans exceed minimum coverage requirements with limits up to $8M or unlimited.
  </p>

  <h2 id="uae-network">Network Coverage in UAE</h2>
  <p>
    BUPA has extensive direct-billing relationships with premium UAE hospitals including Cleveland Clinic Abu Dhabi, American Hospital Dubai, and the Mediclinic network.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    BUPA Global offers industry-leading mental health coverage with parity to physical health. This is a significant differentiator in UAE where mental health services are expensive.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in UAE</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those prioritizing mental health coverage</li>
        <li>Expats wanting premium service</li>
        <li>Families with complex health needs</li>
        <li>Those with pre-existing conditions</li>
        <li>Budget is not the primary concern</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals with basic needs</li>
        <li>Those satisfied with employer coverage</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for UAE."
    buttonText="Get Your Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify DHA/HAAD compliance directly with BUPA before purchasing.
    </p>
  </div>
</PageShell>
