---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Spain', level: 2 },
  { id: 'visa-compliance', text: 'Spanish Visa Compliance', level: 2 },
  { id: 'spain-network', text: 'Network Coverage in Spain', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'blue-cross-advantage', text: 'Blue Cross Advantage', level: 2 },
  { id: 'claims-in-spain', text: 'Using Your Insurance in Spain', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue in Spain', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Spain', href: '/countries/spain/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Aetna', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'spainPrice', header: 'Spain (Age 35)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Voyager Essential', coverage: 'Inpatient + Emergency', spainPrice: '$180-240/mo', visaCompliant: 'Check requirements' },
  { plan: 'Voyager Choice', coverage: 'Essential + Outpatient', spainPrice: '$250-320/mo', visaCompliant: true },
  { plan: 'Voyager Excel', coverage: 'Comprehensive + Maternity', spainPrice: '$320-420/mo', visaCompliant: true },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'spanish', header: 'Spanish Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 35)', geoblue: '$250-320', spanish: '€60-120' },
  { factor: 'US Network', geoblue: 'Blue Cross (largest US)', spanish: 'Not available' },
  { factor: 'Coverage Outside Spain', geoblue: 'Worldwide', spanish: 'Limited/None' },
  { factor: 'Network in Spain', geoblue: 'Good (major cities)', spanish: 'Extensive' },
  { factor: 'Mobile App', geoblue: 'Excellent', spanish: 'Varies' },
  { factor: 'Portability if You Move', geoblue: 'Fully portable', spanish: 'Must cancel' },
  { factor: 'Best For', geoblue: 'US expats wanting BCBS', spanish: 'Long-term residents' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Spain"
  description="Guide to using GeoBlue in Spain. Blue Cross network for US expats. Visa compliance, Spanish network coverage, and pricing details."
  headline="GeoBlue Health Insurance in Spain"
  subheadline="Blue Cross Blue Shield's international arm. The familiar US network you know, now covering you in Spain and beyond."
  heroBackgroundImage="/images/countries/spain-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Spain Quote"
  ctaButtonHref="/providers/geoblue"
>
  <h2 id="overview">GeoBlue in Spain</h2>
  <p>
    GeoBlue is Blue Cross Blue Shield's international health insurance brand. For Americans moving to Spain, GeoBlue offers a unique advantage: continuity with the Blue Cross network that over 100 million Americans already use.
  </p>
  <p>
    When you visit the US—for family, business, or emergencies—your GeoBlue card works at the same Blue Cross hospitals and doctors you've used your whole life. No new network to learn, no surprise coverage gaps.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">96%</p>
      <p class="text-sm text-neutral-600">US hospitals in network</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">International providers</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">190+</p>
      <p class="text-sm text-neutral-600">Countries covered</p>
    </div>
  </div>

  <CTABox
    title="Get a Spain-Specific Quote"
    description="See what GeoBlue costs for Americans living in Spain."
    buttonText="Get Quote"
    buttonHref="/providers/geoblue"
    variant="highlight"
  />

  <h2 id="visa-compliance">Spanish Visa Compliance</h2>
  <p>
    GeoBlue plans are generally accepted for Spanish visa applications. As a US-based insurer, some consulates may request additional documentation compared to EU-regulated insurers.
  </p>

  <h3>Visa Types Covered</h3>
  <ul>
    <li><strong>Non-Lucrative Visa</strong> — Retirement visa for US citizens</li>
    <li><strong>Digital Nomad Visa</strong> — Remote workers</li>
    <li><strong>Student Visa</strong> — US students in Spain</li>
    <li><strong>Golden Visa</strong> — Investment-based residency</li>
  </ul>

  <h3>Documentation Provided</h3>
  <p>
    GeoBlue provides:
  </p>
  <ul>
    <li>Certificate of coverage</li>
    <li>Coverage confirmation letter</li>
    <li>Policy details showing benefits</li>
    <li>Translation assistance if needed</li>
  </ul>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">Visa Application Tip</h3>
    <p class="text-amber-800">
      GeoBlue Voyager Choice or Excel plans are best for visa applications—they include outpatient coverage and meet typical no-copay requirements. Request documentation early; GeoBlue can provide visa-specific letters.
    </p>
  </div>

  <h2 id="spain-network">Network Coverage in Spain</h2>
  <p>
    GeoBlue contracts with 1.7 million+ providers in 190 countries. In Spain, network coverage focuses on major cities and expat areas.
  </p>

  <h3>Coverage by Region</h3>
  <ul>
    <li><strong>Madrid:</strong> Strong hospital and specialist network</li>
    <li><strong>Barcelona:</strong> Multiple direct-billing facilities</li>
    <li><strong>Valencia:</strong> Major hospital coverage</li>
    <li><strong>Costa del Sol:</strong> Málaga and Marbella coverage</li>
    <li><strong>Balearic Islands:</strong> Palma de Mallorca options</li>
  </ul>

  <h3>Finding Providers</h3>
  <p>
    GeoBlue's mobile app excels at provider search:
  </p>
  <ul>
    <li>GPS-based nearby provider finder</li>
    <li>Filter by specialty and language</li>
    <li>Real-time availability information</li>
    <li>Direct contact and directions</li>
  </ul>

  <h3>Out-of-Network Care</h3>
  <p>
    Any licensed provider in Spain can be used. For non-network care, pay upfront and submit for reimbursement. Spanish medical costs are reasonable, so out-of-pocket isn't as painful as in the US.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    GeoBlue Voyager plans are designed for long-term expats. US coverage is included—not an add-on.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices include worldwide coverage with full US Blue Cross access.</em>
  </p>

  <h3>Plan Recommendations for Spain</h3>
  <ul>
    <li><strong>Voyager Essential:</strong> Hospital-focused coverage. Pay for routine Spanish care out of pocket (it's affordable).</li>
    <li><strong>Voyager Choice:</strong> Most popular. Includes outpatient, meets visa requirements, good balance.</li>
    <li><strong>Voyager Excel:</strong> Comprehensive including maternity. Best for families planning to have children.</li>
  </ul>

  <h3>Deductible Strategy</h3>
  <p>
    Spanish private healthcare is affordable (doctor visits €50-100). Consider:
  </p>
  <ul>
    <li>Higher deductible ($2,500+) to lower premiums</li>
    <li>Pay routine care out of pocket in Spain</li>
    <li>Use insurance for hospitals, specialists, US care</li>
  </ul>

  <h2 id="blue-cross-advantage">Blue Cross Advantage</h2>
  <p>
    The core reason to choose GeoBlue is Blue Cross network access in the US:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-blue-900 mb-3">US Network Benefits</h3>
      <ul class="space-y-2 text-blue-800">
        <li>96% of US hospitals in network</li>
        <li>Familiar BCBS network</li>
        <li>Direct billing—no claims</li>
        <li>Negotiated BCBS rates</li>
        <li>Same doctors you used before moving</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Why It Matters in Spain</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Family visits covered automatically</li>
        <li>Keep your US specialists</li>
        <li>Emergencies during US trips</li>
        <li>Repatriation coverage seamless</li>
        <li>US prescriptions accessible</li>
      </ul>
    </div>
  </div>

  <h3>GeoBlue Mobile App</h3>
  <p>
    GeoBlue's app is one of the best in international insurance:
  </p>
  <ul>
    <li>Find providers anywhere with GPS</li>
    <li>Digital insurance card</li>
    <li>Submit claims with photo</li>
    <li>Track claim status</li>
    <li>One-touch emergency calling</li>
  </ul>

  <h2 id="claims-in-spain">Using Your Insurance in Spain</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals in Spain, show your GeoBlue card. The hospital bills GeoBlue directly. You pay only your deductible or copay.
  </p>

  <h3>Reimbursement Process</h3>
  <ol class="list-decimal list-inside space-y-2">
    <li>Pay the Spanish provider</li>
    <li>Get itemized receipt (factura)</li>
    <li>Submit via GeoBlue app (photo upload)</li>
    <li>Receive reimbursement in 7-14 days</li>
  </ol>

  <h3>Using Coverage in the US</h3>
  <p>
    Your GeoBlue card works at any Blue Cross network provider in the US. Show your card, receive care, done. Direct billing just like a domestic BCBS member.
  </p>

  <h3>Emergency Care</h3>
  <p>
    In emergencies, go to the nearest hospital—network or not. Emergency care is covered worldwide. Contact GeoBlue within 48 hours to coordinate.
  </p>

  <CTABox
    title="Questions About Coverage?"
    description="GeoBlue's 24/7 support can help with any coverage questions."
    buttonText="Learn More"
    buttonHref="/providers/geoblue"
  />

  <h2 id="who-its-for">Who Should Choose GeoBlue in Spain</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens in Spain</li>
        <li>Those familiar with Blue Cross</li>
        <li>Expats who visit the US regularly</li>
        <li>People who want the largest US network</li>
        <li>Those who value mobile app quality</li>
        <li>Families with US healthcare ties</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens (GeoBlue requires US ties)</li>
        <li>Those who never visit the US</li>
        <li>Budget-conscious without US needs</li>
        <li>Those wanting EU-regulated insurer</li>
        <li>Long-term Spain-only residents</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Do I need to be a US citizen for GeoBlue?</h3>
  <p>
    GeoBlue requires you to be a US citizen or permanent resident with US ties. It's designed specifically for Americans abroad.
  </p>

  <h3>How does GeoBlue compare to Aetna International?</h3>
  <p>
    Both are excellent for US expats in Spain. GeoBlue offers the Blue Cross network; Aetna offers more customizable Navigator plans. Pricing is similar. <a href="/compare/aetna-international-vs-geoblue">See our detailed comparison</a>.
  </p>

  <h3>Can I use my US prescriptions in Spain?</h3>
  <p>
    Spanish pharmacies may fill some US prescriptions, but regulations differ. For ongoing US medications, coordinate with GeoBlue about international options or fill during US visits.
  </p>

  <h3>What if I move from Spain to another country?</h3>
  <p>
    GeoBlue Voyager plans are portable worldwide. Update your residence country and coverage continues without new underwriting.
  </p>

  <h3>Does GeoBlue cover Spanish public hospitals?</h3>
  <p>
    GeoBlue is private insurance covering private providers. Emergency care at public hospitals may be covered and reimbursed.
  </p>

  <CTABox
    title="Ready for Blue Cross Coverage in Spain?"
    description="Get a personalized GeoBlue quote for your situation."
    buttonText="Get Your Quote"
    buttonHref="/providers/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Network availability, pricing, and visa requirements change. Verify all information with GeoBlue and Spanish authorities before making decisions.
    </p>
  </div>
</PageShell>
