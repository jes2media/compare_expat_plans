---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Spain', level: 2 },
  { id: 'visa-compliance', text: 'Spanish Visa Compliance', level: 2 },
  { id: 'spain-network', text: 'Network Coverage in Spain', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Spanish Insurers', level: 2 },
  { id: 'claims-in-spain', text: 'Using Your Insurance in Spain', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA in Spain', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Spain', href: '/countries/spain/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'spainPrice', header: 'Spain (Age 35)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Inpatient + Day-patient', spainPrice: '$140-180/mo', visaCompliant: 'Check requirements' },
  { plan: 'Complete', coverage: 'Essentials + Outpatient', spainPrice: '$200-260/mo', visaCompliant: true },
  { plan: 'Premier', coverage: 'Complete + Dental/Vision', spainPrice: '$280-360/mo', visaCompliant: true },
  { plan: 'Elite', coverage: 'Maximum coverage', spainPrice: '$350-450/mo', visaCompliant: true },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'spanish', header: 'Spanish Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 35)', bupa: '$200-260', spanish: '$60-120' },
  { factor: 'Coverage Outside Spain', bupa: 'Worldwide', spanish: 'Limited/None' },
  { factor: 'Network in Spain', bupa: 'Extensive', spanish: 'Very extensive' },
  { factor: 'Mental Health Parity', bupa: 'Full parity', spanish: 'Often limited' },
  { factor: 'Pre-existing Conditions', bupa: 'Often covered', spanish: 'Usually excluded' },
  { factor: 'Portability if You Move', bupa: 'Fully portable', spanish: 'Must cancel' },
  { factor: 'No-Claims Discount', bupa: 'Yes', spanish: 'Rarely' },
  { factor: 'Dental Included', bupa: 'Premier+ plans', spanish: 'Usually add-on' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Madrid', hospitals: 'Hospital Universitario HM Sanchinarro, MD Anderson Cancer Center, Hospital La Luz', directBilling: true },
  { city: 'Barcelona', hospitals: 'Hospital Universitari Quirón Dexeus, Centro Médico Teknon, Hospital de Barcelona', directBilling: true },
  { city: 'Valencia', hospitals: 'Hospital Quirónsalud Valencia, IVO (Instituto Valenciano de Oncología)', directBilling: true },
  { city: 'Málaga', hospitals: 'Hospital Quirónsalud Marbella, HC Marbella International Hospital', directBilling: true },
  { city: 'Seville', hospitals: 'Hospital Quirónsalud Sagrado Corazón, Hospital HM Sevilla', directBilling: true },
];
---

<PageShell
  title="BUPA Global Health Insurance in Spain"
  description="Complete guide to using BUPA Global in Spain. Premium coverage with mental health parity, pre-existing condition handling, and extensive benefits."
  headline="BUPA Global Health Insurance in Spain"
  subheadline="Premium international coverage for expats in Spain. Is BUPA Global's comprehensive approach worth the higher cost?"
  heroBackgroundImage="/images/countries/spain-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Spain Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Spain</h2>
  <p>
    BUPA Global is the premium choice for expats in Spain who want comprehensive coverage without gaps. As a healthcare-focused company (not a general insurer), BUPA takes a different approach: more inclusive benefits, better mental health coverage, and more favorable handling of pre-existing conditions.
  </p>
  <p>
    The trade-off is price. BUPA Global typically costs 40-60% more than mid-range competitors. For expats with health concerns, mental health needs, or who simply want peace of mind, that premium can be worthwhile.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">4.4/5</p>
      <p class="text-sm text-neutral-600">Trustpilot rating</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">75+</p>
      <p class="text-sm text-neutral-600">Years in healthcare</p>
    </div>
  </div>

  <CTABox
    title="Get a Spain-Specific Quote"
    description="See what BUPA Global costs for expats living in Spain."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="visa-compliance">Spanish Visa Compliance</h2>
  <p>
    BUPA Global plans are accepted for Spanish visa applications. Their comprehensive coverage typically exceeds minimum requirements.
  </p>
  <ul>
    <li><strong>Non-Lucrative Visa</strong> — Complete, Premier, and Elite plans meet requirements</li>
    <li><strong>Digital Nomad Visa</strong> — All comprehensive plans accepted</li>
    <li><strong>Golden Visa</strong> — BUPA's premium positioning aligns well</li>
    <li><strong>Student Visa</strong> — Complete plan or higher recommended</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">Pre-Existing Conditions Advantage</h3>
    <p class="text-green-800">
      Unlike most insurers, BUPA Global often covers pre-existing conditions from day one (with full disclosure). If you have health conditions that other insurers exclude, BUPA may accept you with full or partial coverage. This can be crucial for visa applications requiring proof of comprehensive coverage.
    </p>
  </div>

  <h2 id="spain-network">Network Coverage in Spain</h2>
  <p>
    BUPA Global has a strong network across Spain, with direct billing available at major hospitals in all principal cities.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Notable Network Features</h3>
  <ul>
    <li><strong>Cancer centers:</strong> Access to MD Anderson Madrid and other specialized oncology facilities</li>
    <li><strong>International hospitals:</strong> HC Marbella and other facilities catering to international patients</li>
    <li><strong>Private maternity:</strong> Top private maternity hospitals in Madrid and Barcelona</li>
    <li><strong>Mental health:</strong> Access to psychiatric facilities and therapy networks</li>
  </ul>

  <p>
    BUPA's network in Spain is slightly smaller than local insurers like Sanitas, but covers all major facilities where expats typically seek care.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    BUPA Global offers four tiers, each building on the previous:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Add 50-70% for US coverage.</em>
  </p>

  <h3>What Makes BUPA Different</h3>
  <ul>
    <li><strong>Mental health parity:</strong> Mental health covered at the same level as physical health — same limits, same access. This is rare in international insurance.</li>
    <li><strong>No-claims discount:</strong> Claim-free years reduce your premium over time.</li>
    <li><strong>Dental/vision included:</strong> Premier and Elite plans include dental and vision without add-ons.</li>
    <li><strong>Second medical opinion:</strong> Access to expert reviews for complex diagnoses.</li>
  </ul>

  <h3>Which Plan for Spain?</h3>
  <ul>
    <li><strong>Essentials:</strong> Hospital only. Only makes sense if you want BUPA's pre-existing condition handling but need to minimize cost.</li>
    <li><strong>Complete:</strong> The practical choice for most expats. Full medical coverage, visa-compliant.</li>
    <li><strong>Premier:</strong> Adds dental and vision. Good for families or those who want all-inclusive coverage.</li>
    <li><strong>Elite:</strong> Maximum benefits including enhanced wellness. For those who want the best available.</li>
  </ul>

  <CTABox
    title="Worth the Premium?"
    description="Get a personalized quote to see the actual cost difference."
    buttonText="Get a Quote"
    buttonHref="/providers/bupa-global"
  />

  <h2 id="vs-local-options">vs Spanish Insurers</h2>
  <p>
    BUPA Global costs significantly more than Spanish insurers. Here's what you get for the difference:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose BUPA Global If:</h3>
  <ul>
    <li>Mental health coverage is essential</li>
    <li>You have pre-existing conditions other insurers won't cover</li>
    <li>You want dental/vision included (Premier+)</li>
    <li>You may relocate from Spain</li>
    <li>Premium comprehensive coverage gives you peace of mind</li>
    <li>You value no-claims discounts long-term</li>
  </ul>

  <h3>Choose a Spanish Insurer If:</h3>
  <ul>
    <li>Budget is the primary concern</li>
    <li>You're healthy without pre-existing conditions</li>
    <li>Mental health coverage isn't a priority</li>
    <li>You're staying in Spain permanently</li>
    <li>You want the most extensive local network</li>
  </ul>

  <p>
    <a href="/countries/spain/insurance">See all Spain insurance options →</a>
  </p>

  <h2 id="claims-in-spain">Using Your Insurance in Spain</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, present your BUPA membership card for cashless treatment. BUPA's Member Services can also arrange direct billing with non-network hospitals in some cases.
  </p>

  <h3>MembersWorld Portal</h3>
  <p>
    BUPA's MembersWorld app and portal let you:
  </p>
  <ul>
    <li>Find network providers in Spain</li>
    <li>Submit claims digitally</li>
    <li>Track claim status in real-time</li>
    <li>Access your digital membership card</li>
    <li>Chat with support</li>
  </ul>

  <h3>Claims Process</h3>
  <p>
    BUPA has a strong claims reputation (4.4/5 Trustpilot). Claims typically process within 5-7 business days. For large claims, BUPA may request medical records but generally approves legitimate claims without difficulty.
  </p>

  <h3>24/7 Support</h3>
  <p>
    BUPA offers round-the-clock multilingual support. For medical emergencies in Spain, their assistance team can coordinate hospital admission, contact providers, and arrange treatment.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in Spain</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>Expats with pre-existing conditions</li>
        <li>Those needing mental health coverage</li>
        <li>Families wanting all-inclusive plans</li>
        <li>Retirees with complex health needs</li>
        <li>Those who value premium service</li>
        <li>Expats who may relocate</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Young, healthy individuals</li>
        <li>Those who rarely use healthcare</li>
        <li>Expats staying in Spain permanently</li>
        <li>Those comfortable with local insurers</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is BUPA Global related to Sanitas in Spain?</h3>
  <p>
    Yes. BUPA actually owns Sanitas, the largest private health insurer in Spain. However, BUPA Global and Sanitas are separate products. BUPA Global is international coverage; Sanitas is Spanish domestic coverage. You cannot simply convert between them.
  </p>

  <h3>Will BUPA cover my pre-existing condition?</h3>
  <p>
    Possibly. BUPA is more willing than most international insurers to cover pre-existing conditions, often from day one. Full disclosure is required. Depending on the condition, you may get full coverage, coverage with limits, or coverage after a waiting period. Severe conditions may still be excluded.
  </p>

  <h3>How does mental health parity work?</h3>
  <p>
    BUPA covers mental health treatment at the same limits as physical health. If your plan has a €2M annual limit, that applies equally to psychiatric care, therapy, and mental health hospitalization. Most insurers have separate, lower sub-limits for mental health.
  </p>

  <h3>Is the no-claims discount worth it?</h3>
  <p>
    Over time, yes. If you don't claim for consecutive years, your premium decreases. This can offset BUPA's higher base premium for healthy individuals. The discount typically maxes out at 20-30% after several claim-free years.
  </p>

  <h3>Can I access Sanitas facilities with BUPA Global?</h3>
  <p>
    BUPA Global has its own network that includes some Sanitas facilities, but they're separate networks. You may be able to use some Sanitas providers through BUPA Global, but don't assume complete overlap. Always verify network status before treatment.
  </p>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for your situation in Spain."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Network availability, pricing, and coverage terms change. We are not insurance brokers or immigration consultants. Verify all information with BUPA Global and Spanish authorities before making decisions.
    </p>
  </div>
</PageShell>
