---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Argentina', level: 2 },
  { id: 'why-bupa', text: 'Why BUPA for Argentina', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Argentina', href: '/countries/argentina/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 35)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Core inpatient', price: '$110-140/mo' },
  { plan: 'Comprehensive', coverage: 'Inpatient + outpatient', price: '$140-185/mo' },
  { plan: 'Elite', coverage: 'Full coverage', price: '$185-230/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Argentina"
  description="Guide to BUPA Global international health insurance for expats in Argentina. Premium service and comprehensive coverage."
  headline="BUPA Global in Argentina"
  subheadline="Trusted international insurer with excellent customer service. Comprehensive coverage for Argentina's expat community."
  heroBackgroundImage="/images/countries/argentina-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Argentina</h2>
  <p>
    BUPA Global is known for excellent customer service and comprehensive coverage. For Argentina expats who value responsive support and a well-established insurer, BUPA delivers a premium experience.
  </p>
  <p>
    With decades of experience serving expats worldwide, BUPA brings reliability and extensive hospital relationships to Argentina's growing expat market.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$140-230</p>
      <p class="text-sm text-neutral-600">Monthly (Age 35)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Great Service</p>
      <p class="text-sm text-neutral-600">Excellent support</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Direct Billing</p>
      <p class="text-sm text-neutral-600">Major hospitals</p>
    </div>
  </div>

  <CTABox
    title="Get Your BUPA Argentina Quote"
    description="Premium coverage with excellent service."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="why-bupa">Why BUPA for Argentina</h2>

  <h3>Customer Service Excellence</h3>
  <ul>
    <li>24/7 multilingual support</li>
    <li>Dedicated care coordinators</li>
    <li>Fast claims processing</li>
    <li>Proactive health management</li>
  </ul>

  <h3>Hospital Network</h3>
  <ul>
    <li><strong>Hospital Italiano:</strong> Direct billing available</li>
    <li><strong>Hospital Alemán:</strong> In-network</li>
    <li><strong>Hospital Británico:</strong> Network facility</li>
    <li><strong>Fundación Favaloro:</strong> Cardiac specialists</li>
  </ul>

  <h3>Comprehensive Benefits</h3>
  <ul>
    <li>Lifetime renewability guarantee</li>
    <li>Mental health coverage</li>
    <li>Wellness programs</li>
    <li>Global coverage</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 35-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Comprehensive+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation included</li>
    <li><strong>Mental health:</strong> Comprehensive coverage</li>
    <li><strong>Wellness:</strong> Annual health checks</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Underwriting or moratorium</li>
    <li>Maternity: 12-month waiting period</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Service-Oriented Expats</h3>
  <p>
    If responsive customer service matters—quick answers, smooth claims, care coordination—BUPA excels.
  </p>

  <h3>Long-term Expats</h3>
  <p>
    BUPA's lifetime renewability means you won't be dropped if health issues develop. Good for those planning to stay in Argentina long-term.
  </p>

  <h3>Families</h3>
  <p>
    BUPA's family plans and maternity coverage make it solid for expat families in Argentina.
  </p>

  <CTABox
    title="Compare BUPA Plans for Argentina"
    description="Find the right coverage level."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
