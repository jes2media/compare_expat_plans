---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Argentina', level: 2 },
  { id: 'why-img', text: 'Why IMG for Argentina', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Argentina', href: '/countries/argentina/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs SafetyWing', href: '/compare/img-global-vs-safetywing' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 35)' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Inpatient + outpatient', price: '$90-130/mo' },
  { plan: 'Global Medical Insurance Plus', coverage: 'Comprehensive', price: '$130-160/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Argentina"
  description="Guide to IMG Global international health insurance for expats in Argentina. Flexible, affordable coverage for digital nomads and expats."
  headline="IMG Global in Argentina"
  subheadline="Flexible international coverage at competitive prices. Popular choice for Argentina's digital nomad and expat community."
  heroBackgroundImage="/images/countries/argentina-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Argentina</h2>
  <p>
    IMG Global offers a strong middle ground between budget travel insurance and premium international plans. For Argentina expats who want comprehensive coverage without top-tier prices, IMG delivers excellent value.
  </p>
  <p>
    With flexible options and competitive pricing, IMG has become popular among digital nomads and expats throughout Latin America.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$90-160</p>
      <p class="text-sm text-neutral-600">Monthly (Age 35)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Flexible</p>
      <p class="text-sm text-neutral-600">Customizable plans</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Good Value</p>
      <p class="text-sm text-neutral-600">Competitive pricing</p>
    </div>
  </div>

  <CTABox
    title="Get Your IMG Argentina Quote"
    description="Flexible coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="why-img">Why IMG for Argentina</h2>

  <h3>Price-Performance Balance</h3>
  <p>
    IMG sits between budget options like SafetyWing and premium insurers like Cigna. Comprehensive coverage at prices that make sense.
  </p>

  <h3>Plan Flexibility</h3>
  <ul>
    <li>Multiple deductible options ($0 to $25,000)</li>
    <li>Regional or worldwide coverage</li>
    <li>Annual or semi-annual payments</li>
    <li>Add or exclude specific benefits</li>
  </ul>

  <h3>Hospital Access</h3>
  <ul>
    <li>Coverage at major Buenos Aires hospitals</li>
    <li>Access to Hospital Italiano, Alemán, Británico</li>
    <li>Network facilities in Córdoba, Mendoza</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-3">High-Deductible Strategy</h3>
    <p class="text-blue-800">
      In Argentina, where routine care costs $30-60, a high-deductible IMG plan makes sense. Pay out-of-pocket for minor issues, let insurance handle expensive hospitalizations.
    </p>
  </div>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 35-year-old. Higher deductibles can reduce premiums significantly.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists, diagnostics</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation included</li>
    <li><strong>Prescriptions:</strong> Outpatient medications</li>
    <li><strong>Mental health:</strong> Coverage with limits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: 12-month exclusion</li>
    <li>Maternity: Optional, requires waiting period</li>
    <li>Dental: Limited benefits</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Digital Nomads</h3>
  <p>
    IMG's flexibility and pricing make it ideal for nomads who want more than SafetyWing but don't need premium coverage.
  </p>

  <h3>Cost-Conscious Expats</h3>
  <p>
    Those wanting comprehensive coverage without paying top dollar find IMG hits the sweet spot.
  </p>

  <h3>Medium-term Stays</h3>
  <p>
    For 1-5 year stays in Argentina, IMG provides appropriate coverage without long-term premium commitments.
  </p>

  <CTABox
    title="Compare IMG Plans for Argentina"
    description="Find flexible coverage at the right price."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
