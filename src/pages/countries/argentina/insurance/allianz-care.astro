---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Argentina', level: 2 },
  { id: 'why-allianz', text: 'Why Allianz for Argentina', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Argentina', href: '/countries/argentina/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient only', price: '$90-120/mo' },
  { plan: 'Classic', coverage: 'Inpatient + basic outpatient', price: '$120-160/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', price: '$160-200/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Argentina"
  description="Guide to Allianz Care international health insurance for expats in Argentina. Strong value coverage for Buenos Aires and beyond."
  headline="Allianz Care in Argentina"
  subheadline="Excellent value from a trusted global insurer. Comprehensive coverage at competitive prices for Argentina expats."
  heroBackgroundImage="/images/countries/argentina-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Argentina</h2>
  <p>
    Allianz Care offers strong value for Argentina expats—comprehensive international coverage at prices that make sense given Argentina's affordable healthcare costs. As one of the world's largest insurers, Allianz brings financial stability and global reach.
  </p>
  <p>
    For expats seeking quality coverage without premium pricing, Allianz hits the sweet spot between cost and benefits.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$120-200</p>
      <p class="text-sm text-neutral-600">Monthly (Age 35)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Good Value</p>
      <p class="text-sm text-neutral-600">Competitive pricing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global Network</p>
      <p class="text-sm text-neutral-600">Worldwide coverage</p>
    </div>
  </div>

  <CTABox
    title="Get Your Allianz Argentina Quote"
    description="Quality coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="why-allianz">Why Allianz for Argentina</h2>

  <h3>Price-to-Coverage Ratio</h3>
  <p>
    Allianz typically offers 10-20% lower premiums than Cigna or BUPA for comparable coverage. In Argentina, where healthcare is already affordable, this makes Allianz an attractive choice.
  </p>

  <h3>Hospital Access</h3>
  <ul>
    <li><strong>Hospital Italiano:</strong> In-network, direct billing</li>
    <li><strong>Hospital Alemán:</strong> Network facility</li>
    <li><strong>Major Buenos Aires hospitals:</strong> Comprehensive access</li>
  </ul>

  <h3>Flexible Plans</h3>
  <ul>
    <li>Multiple coverage tiers to match your budget</li>
    <li>Adjustable deductibles for cost control</li>
    <li>Optional add-ons for dental, vision</li>
    <li>Regional or worldwide coverage choices</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 35-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU, cancer treatment</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Classic+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation and repatriation</li>
    <li><strong>Mental health:</strong> Coverage included with limits</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Moratorium or underwriting</li>
    <li>Maternity: Waiting period, optional on some plans</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Value-Conscious Expats</h3>
  <p>
    Those who want comprehensive international coverage but don't want to pay premium prices. The savings compared to Cigna or BUPA add up over time.
  </p>

  <h3>Long-term Residents</h3>
  <p>
    Allianz's competitive pricing makes it sustainable for long-term stays in Argentina without sacrificing quality.
  </p>

  <h3>Digital Nomads Wanting More</h3>
  <p>
    If SafetyWing feels too basic but Cigna seems expensive, Allianz offers middle-ground coverage at reasonable prices.
  </p>

  <CTABox
    title="Compare Allianz Plans for Argentina"
    description="Find the right coverage at the right price."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
