---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Argentina', level: 2 },
  { id: 'why-axa', text: 'Why AXA for Argentina', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Argentina', href: '/countries/argentina/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Core inpatient', price: '$100-135/mo' },
  { plan: 'Comfort', coverage: 'Inpatient + outpatient', price: '$135-180/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', price: '$180-240/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Argentina"
  description="Guide to AXA Global international health insurance for expats in Argentina. European insurance giant with comprehensive coverage."
  headline="AXA Global in Argentina"
  subheadline="European insurance powerhouse with strong global network. Reliable coverage for Argentina expats."
  heroBackgroundImage="/images/countries/argentina-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Quote"
  ctaButtonHref="/go/axa-global"
>
  <h2 id="overview">AXA Global in Argentina</h2>
  <p>
    AXA is one of the world's largest insurance companies, and their international health division brings scale and stability to expats in Argentina. For those who value major insurer backing, AXA provides reliable, comprehensive coverage.
  </p>
  <p>
    With strong presence in Latin America and established hospital relationships, AXA is well-positioned for Argentina's expat market.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$135-240</p>
      <p class="text-sm text-neutral-600">Monthly (Age 35)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global Giant</p>
      <p class="text-sm text-neutral-600">Major insurer backing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">LATAM Presence</p>
      <p class="text-sm text-neutral-600">Regional expertise</p>
    </div>
  </div>

  <CTABox
    title="Get Your AXA Argentina Quote"
    description="Comprehensive coverage from a global leader."
    buttonText="Get Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <h2 id="why-axa">Why AXA for Argentina</h2>

  <h3>Financial Stability</h3>
  <p>
    As one of the world's largest insurers, AXA's financial strength provides confidence that claims will be paid. Important for long-term coverage planning.
  </p>

  <h3>Latin America Expertise</h3>
  <ul>
    <li>Understanding of regional healthcare</li>
    <li>Established hospital relationships</li>
    <li>Spanish-language support</li>
    <li>Experience with Latin American expats</li>
  </ul>

  <h3>Hospital Network</h3>
  <ul>
    <li><strong>Hospital Italiano:</strong> Network access</li>
    <li><strong>Hospital Alemán:</strong> Direct billing</li>
    <li><strong>Buenos Aires hospitals:</strong> Comprehensive coverage</li>
    <li><strong>Regional cities:</strong> Córdoba, Mendoza access</li>
  </ul>

  <h3>Flexible Plans</h3>
  <ul>
    <li>Multiple coverage tiers</li>
    <li>Deductible options</li>
    <li>Optional dental, vision add-ons</li>
    <li>Regional or worldwide coverage</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 35-year-old. Actual premiums depend on age, health, and coverage choices.
  </p>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, cancer</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists (Comfort+)</li>
    <li><strong>Emergency:</strong> Worldwide coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation and repatriation</li>
    <li><strong>Mental health:</strong> Coverage with limits</li>
    <li><strong>Chronic conditions:</strong> Covered after waiting period</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: Moratorium or underwriting</li>
    <li>Maternity: Waiting period, optional</li>
    <li>Dental/vision: Optional add-ons</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>European Expats</h3>
  <p>
    Those familiar with AXA from Europe appreciate the continuity and similar experience.
  </p>

  <h3>Long-term Residents</h3>
  <p>
    AXA's financial stability and lifetime renewability suit expats planning extended stays in Argentina.
  </p>

  <h3>Corporate Expats</h3>
  <p>
    Companies often choose AXA for employee plans. If offered through work, it's a solid choice.
  </p>

  <h3>Those Valuing Stability</h3>
  <p>
    If major insurer backing matters—financial strength, scale, long history—AXA delivers.
  </p>

  <CTABox
    title="Compare AXA Plans for Argentina"
    description="Find comprehensive coverage from a global leader."
    buttonText="Get Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
