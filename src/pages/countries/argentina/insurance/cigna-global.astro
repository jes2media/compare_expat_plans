---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in Argentina', level: 2 },
  { id: 'why-cigna', text: 'Why Cigna for Argentina', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Argentina', href: '/countries/argentina/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs Allianz', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'price', header: 'Price (Age 35)' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Core inpatient', price: '$130-160/mo' },
  { plan: 'Gold', coverage: 'Inpatient + outpatient', price: '$160-200/mo' },
  { plan: 'Platinum', coverage: 'Comprehensive', price: '$200-250/mo' },
];
---

<PageShell
  title="Cigna Global Health Insurance in Argentina"
  description="Guide to Cigna Global international health insurance for expats in Argentina. Premium coverage for Buenos Aires and beyond."
  headline="Cigna Global in Argentina"
  subheadline="Premium international coverage with strong hospital relationships in Buenos Aires. Comprehensive protection for Argentina expats."
  heroBackgroundImage="/images/countries/argentina-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Quote"
  ctaButtonHref="/providers/cigna-global"
>
  <h2 id="overview">Cigna Global in Argentina</h2>
  <p>
    Cigna Global provides comprehensive international coverage that works well for Argentina's expat community. With relationships at Buenos Aires's top hospitals and worldwide coverage for travel, Cigna offers premium protection at reasonable rates given Argentina's low healthcare costs.
  </p>
  <p>
    For expats who want the security of a major international insurer with genuine global reach, Cigna delivers reliability and comprehensive benefits.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$160-250</p>
      <p class="text-sm text-neutral-600">Monthly (Age 35)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Direct Billing</p>
      <p class="text-sm text-neutral-600">Buenos Aires hospitals</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Worldwide</p>
      <p class="text-sm text-neutral-600">Coverage included</p>
    </div>
  </div>

  <CTABox
    title="Get Your Cigna Argentina Quote"
    description="Comprehensive coverage for Argentina expats."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <h2 id="why-cigna">Why Cigna for Argentina</h2>

  <h3>Hospital Network</h3>
  <p>
    Cigna has relationships with Argentina's leading hospitals:
  </p>
  <ul>
    <li><strong>Hospital Italiano:</strong> JCI-accredited, direct billing available</li>
    <li><strong>Hospital Alemán:</strong> German standards, expat-friendly</li>
    <li><strong>Hospital Británico:</strong> English-speaking staff</li>
    <li><strong>Fundación Favaloro:</strong> World-class cardiac care</li>
  </ul>

  <h3>Global Flexibility</h3>
  <ul>
    <li>Coverage continues when traveling outside Argentina</li>
    <li>US coverage available as an option</li>
    <li>Medical evacuation to appropriate facilities</li>
    <li>Portable if you relocate from Argentina</li>
  </ul>

  <h3>Comprehensive Benefits</h3>
  <ul>
    <li>Full inpatient and outpatient coverage</li>
    <li>Cancer treatment at network facilities</li>
    <li>Mental health benefits included</li>
    <li>Wellness and preventive care</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    Prices shown for healthy 35-year-old. Argentina's low healthcare costs help keep premiums competitive.
  </p>

  <h3>Cost Factors</h3>
  <ul>
    <li><strong>Age:</strong> Premiums increase with age, significantly after 50</li>
    <li><strong>US coverage:</strong> Adding US coverage increases premiums 30-50%</li>
    <li><strong>Deductible:</strong> Higher deductibles reduce premiums 20-30%</li>
    <li><strong>Coverage area:</strong> Americas-only is cheaper than worldwide</li>
  </ul>

  <h2 id="coverage-details">Coverage Details</h2>

  <h3>What's Covered</h3>
  <ul>
    <li><strong>Inpatient:</strong> Hospital stays, surgery, ICU</li>
    <li><strong>Outpatient:</strong> Doctor visits, specialists, diagnostics (Gold+)</li>
    <li><strong>Emergency:</strong> Worldwide emergency coverage</li>
    <li><strong>Evacuation:</strong> Medical evacuation if needed</li>
    <li><strong>Cancer:</strong> Full treatment coverage</li>
    <li><strong>Chronic conditions:</strong> Covered after waiting period</li>
  </ul>

  <h3>Limitations</h3>
  <ul>
    <li>Pre-existing conditions: 2-year moratorium or underwriting</li>
    <li>Mental health: Limited coverage, varies by plan</li>
    <li>Dental/vision: Optional add-on</li>
  </ul>

  <h2 id="best-for">Who It's Best For</h2>

  <h3>Long-term Expats</h3>
  <p>
    Those settling in Argentina for years benefit from Cigna's lifetime renewability and comprehensive coverage.
  </p>

  <h3>Frequent Travelers</h3>
  <p>
    Expats who travel frequently appreciate Cigna's worldwide coverage—no need for separate travel insurance.
  </p>

  <h3>Those Wanting Premium Coverage</h3>
  <p>
    If you want the best available protection without worrying about gaps, Cigna delivers peace of mind.
  </p>

  <CTABox
    title="Compare Cigna Plans for Argentina"
    description="Find the right coverage level for your needs."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates. Get a personalized quote for accurate pricing.
    </p>
  </div>
</PageShell>
