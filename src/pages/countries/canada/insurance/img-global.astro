---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Options', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Global Medical', coverage: 'Essential inpatient', canPrice: '$140-190/mo' },
  { plan: 'Global Medical Plus', coverage: 'Inpatient + Outpatient', canPrice: '$200-280/mo' },
  { plan: 'Global Medical Platinum', coverage: 'Comprehensive', canPrice: '$280-380/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Canada"
  description="Guide to using IMG Global in Canada. Flexible international coverage with competitive pricing for expats."
  headline="IMG Global Health Insurance in Canada"
  subheadline="Flexible international coverage with customizable options. Good mid-range choice for Canada expats."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Canada Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Canada</h2>
  <p>
    IMG (International Medical Group) offers flexible international health insurance at competitive prices. For Canada expats, IMG provides a solid mid-tier option with customizable deductibles and coverage limits.
  </p>
  <p>
    IMG's flexibility makes it attractive for those who want to balance coverage with budget. High-deductible options can significantly reduce premiums.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$8M</p>
      <p class="text-sm text-neutral-600">Maximum available</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Flexible</p>
      <p class="text-sm text-neutral-600">Deductible options</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Customizable</p>
      <p class="text-sm text-neutral-600">Coverage options</p>
    </div>
  </div>

  <CTABox
    title="Get an IMG Quote for Canada"
    description="Flexible coverage with customizable options."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Options</h2>
  <p>
    IMG Global Medical Insurance includes:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital, surgery, intensive care</li>
    <li><strong>Outpatient care:</strong> Doctor visits, specialists (Plus/Platinum)</li>
    <li><strong>Prescription drugs:</strong> Covered per plan terms</li>
    <li><strong>Mental health:</strong> Available on higher tiers</li>
    <li><strong>Maternity:</strong> Optional rider with waiting period</li>
    <li><strong>Dental:</strong> Optional add-on</li>
  </ul>

  <h3>Customization Options</h3>
  <p>
    IMG allows significant customization:
  </p>
  <ul>
    <li>Deductibles from $250 to $25,000</li>
    <li>Coverage limits from $1M to $8M</li>
    <li>Optional riders for dental, vision, maternity</li>
    <li>Area of coverage selection (with/without US)</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Saving with Higher Deductibles</h3>
  <p>
    IMG's flexible deductibles can significantly reduce premiums:
  </p>
  <ul>
    <li><strong>$250 deductible:</strong> Prices shown above</li>
    <li><strong>$2,500 deductible:</strong> 20-30% savings</li>
    <li><strong>$5,000 deductible:</strong> 30-40% savings</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose IMG in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious seeking real coverage</li>
        <li>Healthy individuals (high deductible)</li>
        <li>Those wanting flexible options</li>
        <li>Mid-term stays (1-3 years)</li>
        <li>Self-employed expats</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium service (Cigna)</li>
        <li>Corporate packages (BUPA, Cigna)</li>
        <li>Very short stays (SafetyWing)</li>
        <li>Those needing extensive direct billing</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Flexible Coverage?"
    description="Get a personalized IMG Global quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old with moderate deductible. Actual costs depend on specific selections.
    </p>
  </div>
</PageShell>
