---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Comfort', coverage: 'Essential coverage', canPrice: '$150-200/mo' },
  { plan: 'Standard', coverage: 'Standard + Outpatient', canPrice: '$210-280/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', canPrice: '$280-370/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Canada"
  description="Guide to using AXA Global in Canada. EU-regulated international coverage with competitive pricing."
  headline="AXA Global Health Insurance in Canada"
  subheadline="EU-regulated international coverage with strong value. Budget-friendly option for Canada expats."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Canada Quote"
  ctaButtonHref="/go/axa-global"
>
  <h2 id="overview">AXA Global in Canada</h2>
  <p>
    AXA Global offers EU-regulated international health insurance with competitive pricing. For budget-conscious expats in Canada who still want comprehensive international coverage, AXA provides solid value.
  </p>
  <p>
    AXA typically prices 20-30% below premium competitors while offering comparable core coverage—an attractive option for those watching costs in expensive Canada.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU Regulated</p>
      <p class="text-sm text-neutral-600">Consumer protections</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">20-30%</p>
      <p class="text-sm text-neutral-600">Below premium tier</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Coverage area</p>
    </div>
  </div>

  <CTABox
    title="Get an AXA Quote for Canada"
    description="Quality international coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    AXA Global plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital stays, surgery, cancer treatment</li>
    <li><strong>Outpatient care:</strong> GP and specialist visits (Standard+)</li>
    <li><strong>Mental health:</strong> Covered on higher tiers</li>
    <li><strong>Maternity:</strong> Available with 12-month waiting period</li>
    <li><strong>Prescriptions:</strong> Covered per plan terms</li>
    <li><strong>Dental and vision:</strong> Optional add-ons</li>
  </ul>

  <h3>How It Works in Canada</h3>
  <p>
    AXA operates primarily on a reimbursement basis in Canada. Pay for care and submit claims through the online portal or mobile app. Processing is generally efficient.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    AXA's pricing advantage is significant in expensive Canada. You might save $50-100/month compared to Cigna or BUPA while getting comparable core coverage. The trade-off: less extensive direct billing network.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Self-sufficient individuals</li>
        <li>Those comfortable with reimbursement</li>
        <li>EU expats (familiar brand)</li>
        <li>Long-term residents seeking value</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium service</li>
        <li>US expats needing US network (GeoBlue)</li>
        <li>Corporate packages (Cigna, BUPA)</li>
        <li>Short-term visitors (SafetyWing)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized AXA Global quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Verify coverage details directly with AXA before purchasing.
    </p>
  </div>
</PageShell>
