---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Inpatient only', canPrice: '$180-240/mo' },
  { plan: 'Comprehensive', coverage: 'Inpatient + Outpatient', canPrice: '$300-400/mo' },
  { plan: 'Elite', coverage: 'Full coverage + extras', canPrice: '$380-500/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Canada"
  description="Guide to using BUPA Global in Canada. UK-based international coverage popular with British expats in Toronto, Vancouver, and Montreal."
  headline="BUPA Global Health Insurance in Canada"
  subheadline="UK-based international coverage with strong mental health benefits. Popular with British expats and families."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Canada Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">BUPA Global in Canada</h2>
  <p>
    BUPA Global is a strong choice for expats in Canada, particularly those from the UK familiar with the BUPA brand. BUPA offers premium international coverage with particularly strong mental health benefits—an area where Canadian provincial healthcare often falls short.
  </p>
  <p>
    For families and long-term expats, BUPA's comprehensive coverage fills the significant gaps in provincial healthcare while providing worldwide coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Premium</p>
      <p class="text-sm text-neutral-600">Service level</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Strong</p>
      <p class="text-sm text-neutral-600">Mental health coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">UK Expat</p>
      <p class="text-sm text-neutral-600">Popular choice</p>
    </div>
  </div>

  <CTABox
    title="Get a BUPA Global Quote"
    description="Premium international coverage with strong mental health benefits."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    BUPA Global plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Private rooms, surgery, specialist treatment</li>
    <li><strong>Outpatient care:</strong> GPs, specialists, diagnostics</li>
    <li><strong>Mental health:</strong> Strong inpatient and outpatient coverage</li>
    <li><strong>Maternity:</strong> Covered after 12-month waiting period</li>
    <li><strong>Dental:</strong> Available on higher plans</li>
    <li><strong>Cancer care:</strong> Comprehensive treatment coverage</li>
    <li><strong>Wellness:</strong> Health checks and screenings</li>
  </ul>

  <h3>Mental Health Advantage</h3>
  <p>
    BUPA's mental health coverage is particularly valuable in Canada, where provincial plans often have limited mental health resources and long wait times for specialists. BUPA covers:
  </p>
  <ul>
    <li>Psychiatrist consultations</li>
    <li>Psychologist sessions</li>
    <li>Inpatient psychiatric care</li>
    <li>Outpatient therapy</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Pricing Position</h3>
  <p>
    BUPA Global sits in the premium tier alongside Cigna. Expect comprehensive coverage at premium pricing. The value is in the service quality and mental health benefits.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>UK expats (brand familiarity)</li>
        <li>Those prioritizing mental health coverage</li>
        <li>Families with children</li>
        <li>Corporate assignees</li>
        <li>Long-term Canada residents</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious (Allianz, AXA)</li>
        <li>US expats (GeoBlue familiarity)</li>
        <li>Short-term visitors (SafetyWing)</li>
        <li>Waiting period only</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for BUPA Global?"
    description="Get a personalized quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates. Verify coverage details directly with BUPA.
    </p>
  </div>
</PageShell>
