---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/geoblue-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Xplorer Essential', coverage: 'Inpatient + limited outpatient', canPrice: '$200-280/mo' },
  { plan: 'Xplorer Select', coverage: 'Comprehensive', canPrice: '$320-420/mo' },
  { plan: 'Xplorer Premier', coverage: 'Premium + US coverage', canPrice: '$450-600/mo' },
];
---

<PageShell
  title="GeoBlue Health Insurance in Canada"
  description="Guide to using GeoBlue in Canada. Blue Cross Blue Shield international coverage for US expats."
  headline="GeoBlue Health Insurance in Canada"
  subheadline="Blue Cross Blue Shield's international arm. Excellent choice for US expats in Canada."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Canada Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in Canada</h2>
  <p>
    GeoBlue is the international insurance arm of Blue Cross Blue Shield, one of America's most recognized health insurance brands. For US expats moving to Canada, GeoBlue offers familiar coverage style with seamless cross-border benefits.
  </p>
  <p>
    The unique value: GeoBlue can include meaningful US coverage through the BCBS network—essential for Americans who return home regularly or maintain US healthcare relationships.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">BCBS</p>
      <p class="text-sm text-neutral-600">Brand backing</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">US Network</p>
      <p class="text-sm text-neutral-600">BCBS access</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Cross-Border</p>
      <p class="text-sm text-neutral-600">US-Canada coverage</p>
    </div>
  </div>

  <CTABox
    title="Get a GeoBlue Quote for Canada"
    description="Blue Cross Blue Shield international coverage."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    GeoBlue Xplorer plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital, surgery, specialist treatment</li>
    <li><strong>Outpatient care:</strong> Physician visits, labs, imaging</li>
    <li><strong>Prescription drugs:</strong> Covered with formulary</li>
    <li><strong>Mental health:</strong> Coverage varies by plan</li>
    <li><strong>Maternity:</strong> Available with waiting period</li>
    <li><strong>US coverage:</strong> Through BCBS network (Premier)</li>
  </ul>

  <h3>US Coverage Advantage</h3>
  <p>
    GeoBlue's key differentiator for Canada expats:
  </p>
  <ul>
    <li>Access to BCBS provider network when in US</li>
    <li>Seamless cross-border coverage</li>
    <li>No gap when traveling between countries</li>
    <li>Valuable for expats with US ties</li>
  </ul>

  <h3>Digital Experience</h3>
  <p>
    GeoBlue's mobile app and digital tools are well-regarded:
  </p>
  <ul>
    <li>Provider finder in Canada and US</li>
    <li>Digital ID cards</li>
    <li>Mobile claims submission</li>
    <li>Telehealth options</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>US Coverage Impact on Pricing</h3>
  <p>
    Plans with full US coverage cost significantly more due to US healthcare costs. If you don't need regular US coverage, non-US plans from other insurers may offer better value.
  </p>

  <h2 id="who-its-for">Who Should Choose GeoBlue in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US expats needing US coverage</li>
        <li>Those familiar with BCBS</li>
        <li>Frequent US travelers</li>
        <li>Families with US ties</li>
        <li>Border-area residents</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US expats (better value elsewhere)</li>
        <li>Budget-focused (Allianz, AXA)</li>
        <li>UK expats (BUPA familiarity)</li>
        <li>Those not traveling to US</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for BCBS International Coverage?"
    description="Get a personalized GeoBlue quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates. US coverage significantly affects pricing. Get a personalized quote for accurate costs.
    </p>
  </div>
</PageShell>
