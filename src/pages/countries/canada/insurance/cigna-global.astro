---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Cigna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs BUPA Global', href: '/compare/cigna-global-vs-bupa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Inpatient only', canPrice: '$200-260/mo' },
  { plan: 'Gold', coverage: 'Inpatient + Outpatient', canPrice: '$320-420/mo' },
  { plan: 'Platinum', coverage: 'Comprehensive', canPrice: '$400-520/mo' },
];
---

<PageShell
  title="Cigna Global Health Insurance in Canada"
  description="Guide to using Cigna Global in Canada. Premium international coverage for expats in Toronto, Vancouver, Montreal, and Calgary."
  headline="Cigna Global Health Insurance in Canada"
  subheadline="Premium international coverage with comprehensive benefits. Ideal for executives and families in Canada."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Canada Quote"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Cigna Global in Canada</h2>
  <p>
    Cigna Global is a top choice for expats in Canada seeking comprehensive international health coverage. With strong presence in North America and relationships with major Canadian healthcare providers, Cigna offers premium service that goes beyond what provincial plans provide.
  </p>
  <p>
    For corporate expats and families, Cigna's coverage fills the significant gaps in provincial healthcare—dental, vision, prescriptions, and private rooms—while providing international coverage for travel.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$2M+</p>
      <p class="text-sm text-neutral-600">Maximum coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Dental/Vision</p>
      <p class="text-sm text-neutral-600">Included options</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Including US coverage</p>
    </div>
  </div>

  <CTABox
    title="Get a Cigna Canada Quote"
    description="Premium coverage that fills provincial healthcare gaps."
    buttonText="Get Quote"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    Cigna Global plans include benefits that provincial healthcare doesn't cover:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Private rooms, surgery, cancer treatment</li>
    <li><strong>Outpatient care:</strong> GP visits, specialists, diagnostics</li>
    <li><strong>Dental:</strong> Preventive, basic, and major dental work</li>
    <li><strong>Vision:</strong> Exams, glasses, contacts</li>
    <li><strong>Prescriptions:</strong> Comprehensive drug coverage</li>
    <li><strong>Mental health:</strong> Inpatient and outpatient coverage</li>
    <li><strong>Maternity:</strong> Covered after waiting period</li>
  </ul>

  <h3>Key Advantage: US Coverage</h3>
  <p>
    Cigna Global includes US coverage—important for Canadians who travel to the US frequently. Provincial plans provide minimal US coverage, and US healthcare costs can be devastating without insurance.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Canada Pricing Note</h3>
  <p>
    Canada premiums are higher than many other countries due to:
  </p>
  <ul>
    <li>Proximity to expensive US healthcare</li>
    <li>High local healthcare costs</li>
    <li>Comprehensive North American coverage expectations</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Cigna in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Corporate expats and executives</li>
        <li>Families wanting comprehensive coverage</li>
        <li>Those who travel to the US frequently</li>
        <li>People wanting dental/vision/Rx coverage</li>
        <li>Expats who may relocate internationally</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious (Allianz, AXA)</li>
        <li>Waiting period only (SafetyWing)</li>
        <li>Those satisfied with provincial coverage</li>
        <li>Short-term visitors</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized Cigna Global quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Actual premiums depend on age, health history, and coverage selections.
    </p>
  </div>
</PageShell>
