---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs Cigna', href: '/compare/aetna-international-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Core', coverage: 'Inpatient essential', canPrice: '$190-250/mo' },
  { plan: 'Navigator', coverage: 'Inpatient + Outpatient', canPrice: '$300-400/mo' },
  { plan: 'Pioneer', coverage: 'Comprehensive', canPrice: '$400-520/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Canada"
  description="Guide to using Aetna International in Canada. US-based insurer with strong North American presence."
  headline="Aetna International Health Insurance in Canada"
  subheadline="US-based global coverage backed by CVS Health. Strong North American presence for Canada expats."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Canada Quote"
  ctaButtonHref="/go/aetna-international"
>
  <h2 id="overview">Aetna International in Canada</h2>
  <p>
    Aetna International, backed by CVS Health, offers comprehensive global health insurance with particularly strong North American coverage. For expats in Canada who also travel to the US, Aetna's cross-border expertise is valuable.
  </p>
  <p>
    Aetna emphasizes wellness and preventive care, offering programs that complement Canada's provincial healthcare gaps.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">CVS Backed</p>
      <p class="text-sm text-neutral-600">Financial strength</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">North America</p>
      <p class="text-sm text-neutral-600">Strong presence</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Wellness</p>
      <p class="text-sm text-neutral-600">Preventive focus</p>
    </div>
  </div>

  <CTABox
    title="Get an Aetna Quote for Canada"
    description="North American expertise from a US healthcare leader."
    buttonText="Get Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    Aetna International plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital stays, surgery, specialist treatment</li>
    <li><strong>Outpatient care:</strong> Physician visits, diagnostics</li>
    <li><strong>Mental health:</strong> Good coverage across plans</li>
    <li><strong>Maternity:</strong> Covered after waiting period</li>
    <li><strong>Wellness programs:</strong> Preventive care, health coaching</li>
    <li><strong>Chronic condition management:</strong> Ongoing support</li>
  </ul>

  <h3>North American Advantage</h3>
  <p>
    Aetna's US roots mean strong cross-border coverage:
  </p>
  <ul>
    <li>Seamless coverage in US and Canada</li>
    <li>US network access for border-area expats</li>
    <li>Understanding of North American healthcare systems</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Pricing Position</h3>
  <p>
    Aetna International sits in the premium tier, typically priced between Cigna and BUPA. Strong value for those wanting US coverage alongside Canadian residence.
  </p>

  <h2 id="who-its-for">Who Should Choose Aetna in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US expats in Canada</li>
        <li>Those traveling to US frequently</li>
        <li>Border-area residents</li>
        <li>Those valuing wellness programs</li>
        <li>Corporate assignees</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious (Allianz, IMG)</li>
        <li>UK expats (BUPA familiarity)</li>
        <li>Short-term visitors (SafetyWing)</li>
        <li>Those not traveling to US</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for North American Coverage?"
    description="Get a personalized Aetna International quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Actual premiums depend on age, health history, and coverage selections.
    </p>
  </div>
</PageShell>
