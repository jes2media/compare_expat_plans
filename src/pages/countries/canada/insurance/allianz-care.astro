---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Canada', level: 2 },
  { id: 'coverage', text: 'Coverage Details', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Canada', href: '/countries/canada/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/allianz-care-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'canPrice', header: 'Canada (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', canPrice: '$160-210/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', canPrice: '$240-320/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', canPrice: '$320-420/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Canada"
  description="Guide to using Allianz Care in Canada. German-backed international coverage with strong value for expats."
  headline="Allianz Care Health Insurance in Canada"
  subheadline="German reliability with competitive pricing. Strong value for expats seeking comprehensive international coverage."
  heroBackgroundImage="/images/countries/canada-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Canada Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Canada</h2>
  <p>
    Allianz Care offers German-backed international health insurance with competitive pricing compared to premium competitors. For expats in Canada seeking comprehensive coverage without paying top dollar, Allianz provides solid value.
  </p>
  <p>
    Allianz fills the gaps in provincial healthcare—dental, vision, prescriptions—while typically costing 15-25% less than Cigna or BUPA for similar coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">€2M+</p>
      <p class="text-sm text-neutral-600">Maximum coverage</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">15-25%</p>
      <p class="text-sm text-neutral-600">Below premium tier</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Coverage area</p>
    </div>
  </div>

  <CTABox
    title="Get an Allianz Quote for Canada"
    description="Comprehensive coverage at competitive prices."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="coverage">Coverage Details</h2>
  <p>
    Allianz Care plans include:
  </p>
  <ul>
    <li><strong>Inpatient care:</strong> Hospital stays, surgery, cancer treatment</li>
    <li><strong>Outpatient care:</strong> GP and specialist visits (Classic/Premium)</li>
    <li><strong>Dental:</strong> Available on Premium plans</li>
    <li><strong>Vision:</strong> Available on Premium plans</li>
    <li><strong>Prescriptions:</strong> Covered per plan terms</li>
    <li><strong>Mental health:</strong> Covered on higher tiers</li>
  </ul>

  <h3>How It Works in Canada</h3>
  <p>
    Allianz operates primarily on a reimbursement basis in Canada. You pay for care and submit claims for reimbursement. Processing is typically efficient through the online portal.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Comparison</h3>
  <p>
    Allianz typically costs 15-25% less than premium competitors for similar coverage levels. For a healthy 35-year-old in Canada, you might save $50-100/month compared to Cigna.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Canada</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Long-term Canada residents</li>
        <li>Those comfortable with reimbursement</li>
        <li>EU expats (familiar brand)</li>
        <li>Expats who travel internationally</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium direct billing</li>
        <li>Corporate packages (Cigna, BUPA)</li>
        <li>Waiting period only (SafetyWing)</li>
        <li>Short-term visitors</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized Allianz Care quote for Canada."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices are estimates for a healthy 35-year-old. Actual premiums depend on age, health history, and coverage selections.
    </p>
  </div>
</PageShell>
