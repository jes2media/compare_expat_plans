---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Portugal', level: 2 },
  { id: 'visa-compliance', text: 'D7 & D8 Visa Compliance', level: 2 },
  { id: 'portugal-network', text: 'Network Coverage in Portugal', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Portuguese Insurers', level: 2 },
  { id: 'claims-in-portugal', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Portugal', href: '/countries/portugal/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'portugalPrice', header: 'Portugal (Age 35)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Emergency', portugalPrice: '€70-100/mo', visaCompliant: 'Check requirements' },
  { plan: 'Classic', coverage: 'Essential + Outpatient', portugalPrice: '€110-150/mo', visaCompliant: true },
  { plan: 'Premium', coverage: 'Comprehensive', portugalPrice: '€150-200/mo', visaCompliant: true },
  { plan: 'Platinum', coverage: 'Premium + Enhanced', portugalPrice: '€190-260/mo', visaCompliant: true },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'portuguese', header: 'Portuguese Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 35)', allianz: '€110-150', portuguese: '€26-100' },
  { factor: 'With High Deductible', allianz: '€45-75', portuguese: 'Limited options' },
  { factor: 'Coverage Outside Portugal', allianz: 'Worldwide', portuguese: 'Limited/None' },
  { factor: 'Network in Portugal', allianz: 'Extensive', portuguese: 'Extensive' },
  { factor: 'EU Travel Coverage', allianz: 'Full', portuguese: 'Limited' },
  { factor: 'Portability if You Move', allianz: 'Fully portable', portuguese: 'Must cancel' },
  { factor: 'Deductible Savings', allianz: 'Up to 60%', portuguese: 'Limited options' },
  { factor: 'AIMA Accepted', allianz: 'Yes', portuguese: 'Yes' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Lisbon', hospitals: 'Hospital da Luz, CUF Descobertas, Hospital Lusíadas, Clínica CUF Almada', directBilling: true },
  { city: 'Porto', hospitals: 'Hospital da Luz Arrábida, CUF Porto, Hospital Lusíadas Porto', directBilling: true },
  { city: 'Algarve', hospitals: 'Hospital Particular do Algarve, HPA Gambelas, Hospital de Loulé', directBilling: true },
  { city: 'Braga', hospitals: 'Hospital Lusíadas Braga, Hospital de Braga', directBilling: true },
  { city: 'Funchal (Madeira)', hospitals: 'Hospital Particular da Madeira', directBilling: true },
];
---

<PageShell
  title="Allianz Care Health Insurance in Portugal"
  description="Complete guide to using Allianz Care in Portugal. D7 and D8 visa compliance, deductible savings, and how it compares to Portuguese insurers."
  headline="Allianz Care Health Insurance in Portugal"
  subheadline="Is Allianz Care the right choice for expats in Portugal? High-deductible savings, EU coverage, and visa compliance explained."
  heroBackgroundImage="/images/countries/portugal-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Portugal Quote"
  ctaButtonHref="/providers/allianz-care"
>
  <h2 id="overview">Allianz Care in Portugal</h2>
  <p>
    Allianz Care is a strong choice for expats in Portugal, especially those who want European-based insurance with significant cost-saving options. As a German company with deep EU roots, Allianz has extensive networks across Portugal and Europe.
  </p>
  <p>
    The standout feature: Allianz offers high-deductible plans that can cut premiums by up to 60%. Given that routine healthcare in Portugal is affordable (GP visits €30-50, specialists €60-100), this strategy lets you save significantly while maintaining strong coverage for major expenses.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">2M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">60%</p>
      <p class="text-sm text-neutral-600">Max deductible savings</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU</p>
      <p class="text-sm text-neutral-600">Based and regulated</p>
    </div>
  </div>

  <CTABox
    title="Get a Portugal-Specific Quote"
    description="See what Allianz Care costs with different deductible options."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <h2 id="visa-compliance">D7 & D8 Visa Compliance</h2>
  <p>
    Allianz Care plans are accepted for Portuguese visa applications and AIMA residency appointments.
  </p>

  <h3>Stage 1: Consulate Application</h3>
  <p>
    For D7 (passive income/retirement) or D8 (digital nomad) visa applications:
  </p>
  <ul>
    <li>Minimum €30,000 coverage (Schengen requirement)</li>
    <li>Valid in Portugal/Schengen Area</li>
    <li>At least 1 year duration (some consulates require this)</li>
  </ul>
  <p>
    Allianz Care Classic, Premium, and Platinum all exceed these requirements.
  </p>

  <h3>Stage 2: AIMA Residency Appointment</h3>
  <p>
    For AIMA appointments, travel insurance is rejected. You need:
  </p>
  <ul>
    <li>Long-term private health insurance</li>
    <li>At least 12 months coverage</li>
    <li>Renewable policy</li>
    <li>Inpatient and outpatient coverage</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">EU Insurer Advantage</h3>
    <p class="text-green-800">
      As an EU-based insurer, Allianz Care is familiar with Portuguese visa requirements and routinely provides compliant documentation. Their European headquarters can be an advantage when dealing with AIMA or Portuguese authorities who may prefer EU-regulated insurers.
    </p>
  </div>

  <h3>Visa Type Summary</h3>
  <ul>
    <li><strong>D7 Visa (Passive Income)</strong> — Classic or higher recommended</li>
    <li><strong>D8 Visa (Digital Nomad)</strong> — Classic is the popular choice</li>
    <li><strong>Golden Visa</strong> — Premium aligns well with investor profile</li>
    <li><strong>Student Visa</strong> — Essential or Classic depending on requirements</li>
  </ul>

  <h2 id="portugal-network">Network Coverage in Portugal</h2>
  <p>
    Allianz Care has one of the most extensive networks in Portugal among international insurers, covering all major cities and expat areas including Lisbon, Porto, the Algarve, and Madeira.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Network Strengths</h3>
  <ul>
    <li><strong>Lisbon area:</strong> Excellent coverage including Hospital da Luz, CUF network, and Lusíadas group</li>
    <li><strong>Porto:</strong> Strong network in Portugal's second city</li>
    <li><strong>Algarve:</strong> Good coverage for the large expat community in the south</li>
    <li><strong>Madeira:</strong> Coverage on the island, important for retirees</li>
    <li><strong>EU-wide:</strong> Seamless coverage across Europe — no separate travel insurance needed</li>
  </ul>

  <p>
    Allianz's European focus means particularly strong coverage if you travel between Portugal and other EU countries. Many Portugal expats visit Spain, France, or their home countries regularly.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    Allianz Care offers four plan tiers with significant price variation based on deductible choice:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA, €500 deductible. Prices drop significantly with higher deductibles.</em>
  </p>

  <h3>The High-Deductible Strategy</h3>
  <p>
    Allianz's deductible options go up to €5,000, which can cut premiums by 50-60%. In Portugal, this makes sense because routine care is affordable:
  </p>
  <ul>
    <li>GP visit: €30-50</li>
    <li>Specialist consultation: €60-100</li>
    <li>Basic blood tests: €30-60</li>
    <li>Urgent care visit: €80-150</li>
  </ul>
  <p>
    With affordable local care, paying routine expenses out of pocket while maintaining strong coverage for major expenses (hospitalization, surgery, cancer treatment) can save €100+/month.
  </p>

  <h3>Which Plan for Portugal?</h3>
  <ul>
    <li><strong>Essential:</strong> Hospital and emergency only. Pair with high deductible for lowest cost while maintaining visa compliance.</li>
    <li><strong>Classic:</strong> Adds outpatient. The balanced choice for most expats. Visa-compliant for D7/D8.</li>
    <li><strong>Premium:</strong> Enhanced benefits including better mental health coverage.</li>
    <li><strong>Platinum:</strong> Maximum coverage. Best for families or complex health needs.</li>
  </ul>

  <CTABox
    title="Calculate Your Savings"
    description="See how different deductible options affect your premium."
    buttonText="Get a Quote"
    buttonHref="/providers/allianz-care"
  />

  <h2 id="vs-local-options">vs Portuguese Insurers</h2>
  <p>
    How does Allianz Care compare to Portuguese companies like Multicare or Allianz Portugal (the local subsidiary)?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose Allianz Care If:</h3>
  <ul>
    <li>You travel frequently within Europe</li>
    <li>You want high-deductible premium savings</li>
    <li>You might relocate to another country</li>
    <li>You prefer an EU-regulated insurer</li>
    <li>Mental health coverage is important</li>
    <li>You want flexibility for the future</li>
  </ul>

  <h3>Choose a Portuguese Insurer If:</h3>
  <ul>
    <li>You're committed to staying in Portugal long-term</li>
    <li>Lowest possible premium is the priority</li>
    <li>You don't travel outside Portugal</li>
    <li>You want the most extensive local network</li>
    <li>You plan to transition to SNS</li>
  </ul>

  <p>
    <a href="/countries/portugal/insurance">See all Portugal insurance options →</a>
  </p>

  <h2 id="claims-in-portugal">Using Your Insurance in Portugal</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals and clinics, show your Allianz card for cashless treatment. Allianz's strong Portuguese network means direct billing is widely available in Lisbon, Porto, and major cities.
  </p>

  <h3>Reimbursement</h3>
  <p>
    For non-network providers:
  </p>
  <ol class="list-decimal list-inside space-y-2">
    <li>Pay the provider (keep the factura/receipt)</li>
    <li>Submit via MyHealth app or online portal</li>
    <li>Typical processing: 5 business days</li>
    <li>Reimbursement to your bank account (IBAN)</li>
  </ol>
  <p>
    Portuguese receipts (facturas) are accepted without translation.
  </p>

  <h3>MyHealth App</h3>
  <p>
    Allianz's MyHealth app lets you:
  </p>
  <ul>
    <li>Find nearby network providers in Portugal</li>
    <li>Submit claims with photo upload</li>
    <li>Access digital insurance card</li>
    <li>Track claim status</li>
    <li>Contact support directly</li>
  </ul>

  <h3>Language Support</h3>
  <p>
    Allianz offers multilingual support including English and Portuguese. Claims documentation in Portuguese is accepted without translation.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Portugal</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Expats who travel within Europe</li>
        <li>Budget-conscious (high-deductible strategy)</li>
        <li>Those who prefer EU-based insurers</li>
        <li>D7/D8 visa applicants</li>
        <li>Digital nomads based in Portugal</li>
        <li>Those who value flexibility</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting lowest absolute premium</li>
        <li>Expats who never leave Portugal</li>
        <li>Those needing extensive US coverage</li>
        <li>People transitioning to SNS soon</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is Allianz Care the same as Allianz Portugal?</h3>
  <p>
    No. Allianz Care is the international health insurance division, separate from Allianz Portugal (the Portuguese domestic insurer). Allianz Care provides global coverage that moves with you; Allianz Portugal provides local Portuguese coverage only.
  </p>

  <h3>Can I use my Allianz Care policy if I travel to Spain?</h3>
  <p>
    Yes. Your coverage works seamlessly across all countries in your plan. Many Portugal expats travel to Spain regularly — no separate travel insurance needed.
  </p>

  <h3>How does the high-deductible option work?</h3>
  <p>
    You choose a deductible (€500-5,000) when purchasing. You pay healthcare costs up to that amount each year. After reaching your deductible, Allianz covers the rest. Higher deductible = lower premium.
  </p>

  <h3>Is Allianz Care accepted at AIMA?</h3>
  <p>
    Yes. Allianz Care Classic, Premium, and Platinum plans are accepted at AIMA appointments because they're long-term health insurance with 12-month renewable terms and comprehensive coverage.
  </p>

  <h3>Does Allianz cover dental in Portugal?</h3>
  <p>
    Dental is an optional add-on, not included in base plans. Given that dental care is affordable in Portugal (cleaning €40-60, filling €50-80), many expats skip dental coverage and pay out of pocket.
  </p>

  <h3>What if I move from Portugal to another EU country?</h3>
  <p>
    Your coverage continues unchanged. Simply update your residence with Allianz. No new policy or underwriting required.
  </p>

  <CTABox
    title="Ready to Get Covered in Portugal?"
    description="Get a personalized Allianz Care quote with deductible options."
    buttonText="Get Your Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements and healthcare policies change. We are not immigration consultants or insurance brokers. Verify all information with Allianz Care, AIMA, and Portuguese authorities before making decisions.
    </p>
  </div>
</PageShell>
