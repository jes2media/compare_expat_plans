---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Portugal', level: 2 },
  { id: 'visa-compliance', text: 'D7/D8 Visa Compliance', level: 2 },
  { id: 'portugal-network', text: 'Network Coverage in Portugal', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'eu-advantage', text: 'EU Insurer Advantage', level: 2 },
  { id: 'sns-transition', text: 'Transitioning to SNS', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Portugal', href: '/countries/portugal/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'portugalPrice', header: 'Portugal (Age 35)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Emergency', portugalPrice: '€90-130/mo', visaCompliant: 'Check requirements' },
  { plan: 'Comfort', coverage: 'Essential + Outpatient', portugalPrice: '€140-190/mo', visaCompliant: true },
  { plan: 'Excellence', coverage: 'Comprehensive', portugalPrice: '€200-270/mo', visaCompliant: true },
  { plan: 'Exclusive', coverage: 'Unlimited', portugalPrice: '€320-420/mo', visaCompliant: true },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'portuguese', header: 'Portuguese Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 35)', axa: '€140-190', portuguese: '€26-80' },
  { factor: 'Regulation', axa: 'EU (French ACPR)', portuguese: 'Portuguese ASF' },
  { factor: 'Visa Acceptance', axa: 'Excellent', portuguese: 'Excellent' },
  { factor: 'Coverage Outside Portugal', axa: 'Worldwide', portuguese: 'Limited' },
  { factor: 'Network in Portugal', axa: 'Good', portuguese: 'Extensive' },
  { factor: 'Portability', axa: 'Fully portable', portuguese: 'Must cancel' },
  { factor: 'Best For', axa: 'EU expats, visa applicants', portuguese: 'Long-term residents' },
];
---

<PageShell
  title="AXA Global Health Insurance in Portugal"
  description="Guide to using AXA Global Healthcare in Portugal. EU-regulated insurer ideal for D7/D8 visa compliance. Network, pricing, and coverage details."
  headline="AXA Global Health Insurance in Portugal"
  subheadline="French insurance giant with EU regulation. Smooth visa applications and European credibility for expats in Portugal."
  heroBackgroundImage="/images/countries/portugal-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Portugal Quote"
  ctaButtonHref="/go/axa-global"
>
  <h2 id="overview">AXA Global in Portugal</h2>
  <p>
    AXA Global Healthcare brings European insurance credibility to expats moving to Portugal. As a French company regulated under EU Solvency II rules, AXA offers something valuable for visa applications: immediate recognition by Portuguese authorities.
  </p>
  <p>
    Portugal has become a top destination for EU citizens, retirees, and digital nomads. AXA's EU regulation, euro-denominated premiums, and strong European network make it a natural fit—especially for non-American expats who don't need US coverage.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.6M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU</p>
      <p class="text-sm text-neutral-600">Regulated (Solvency II)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">€</p>
      <p class="text-sm text-neutral-600">Euro pricing</p>
    </div>
  </div>

  <CTABox
    title="Get a Portugal-Specific Quote"
    description="See what AXA Global costs for expats in Portugal."
    buttonText="Get Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <h2 id="visa-compliance">D7/D8 Visa Compliance</h2>
  <p>
    AXA Global is one of the most visa-friendly insurers for Portugal. As an EU-regulated company, Portuguese consulates and SEF (immigration authority) readily accept AXA documentation.
  </p>

  <h3>Visa Types Covered</h3>
  <ul>
    <li><strong>D7 (Passive Income Visa)</strong> — Retirees and those with passive income</li>
    <li><strong>D8 (Digital Nomad Visa)</strong> — Remote workers</li>
    <li><strong>Golden Visa</strong> — Investment-based residency</li>
    <li><strong>Student Visa</strong> — International students</li>
    <li><strong>Work Visa</strong> — Employed expats</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">Visa Advantage</h3>
    <p class="text-green-800">
      AXA's EU regulation means Portuguese consulates recognize the coverage immediately—no questions about whether a "foreign" insurer qualifies. Choose <strong>Comfort or higher</strong> to ensure outpatient coverage meets typical requirements. AXA provides documentation in Portuguese upon request.
    </p>
  </div>

  <h3>Documentation Provided</h3>
  <ul>
    <li>Certificate of coverage (available in Portuguese)</li>
    <li>Confirmation of no waiting periods for core benefits</li>
    <li>Coverage details meeting visa requirements</li>
    <li>Direct correspondence with authorities if needed</li>
  </ul>

  <h2 id="portugal-network">Network Coverage in Portugal</h2>
  <p>
    AXA maintains a solid network in Portugal, with coverage in all major cities and expat areas. As a European insurer, their Portuguese network is well-developed.
  </p>

  <h3>Coverage by Region</h3>
  <ul>
    <li><strong>Lisbon:</strong> Multiple hospital options including Hospital da Luz, CUF, Lusíadas</li>
    <li><strong>Porto:</strong> Good coverage at major private hospitals</li>
    <li><strong>Algarve:</strong> Network in Faro, Lagos, Portimão</li>
    <li><strong>Cascais/Sintra:</strong> Coverage in popular expat suburbs</li>
    <li><strong>Madeira/Azores:</strong> Island coverage available</li>
  </ul>

  <h3>Finding Providers</h3>
  <p>
    Use AXA's MyHealth portal or app to find:
  </p>
  <ul>
    <li>Direct-billing hospitals</li>
    <li>English or French-speaking doctors</li>
    <li>Specialists in your area</li>
    <li>24-hour urgent care facilities</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    AXA offers four tiers with euro pricing—convenient for Portugal-based expats.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Add approximately 40-50% for US coverage.</em>
  </p>

  <h3>Plan Recommendations for Portugal</h3>
  <ul>
    <li><strong>Essential:</strong> Hospital-only. Works once you have SNS access for routine care.</li>
    <li><strong>Comfort:</strong> Most popular for Portugal. Includes outpatient, meets visa requirements.</li>
    <li><strong>Excellence:</strong> Comprehensive with mental health parity. Good for families.</li>
    <li><strong>Exclusive:</strong> Unlimited coverage for maximum protection.</li>
  </ul>

  <h3>Deductible Strategy</h3>
  <p>
    Portuguese private healthcare is affordable. Consider:
  </p>
  <ul>
    <li>€1,000-2,500 deductible to reduce premiums</li>
    <li>Pay routine care out of pocket (doctor visits €30-60)</li>
    <li>Use insurance for hospitals, specialists, and travel</li>
    <li>Higher deductible especially makes sense once you have SNS access</li>
  </ul>

  <h2 id="eu-advantage">EU Insurer Advantage</h2>
  <p>
    Choosing an EU-regulated insurer like AXA offers several benefits in Portugal:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-blue-900 mb-3">Regulatory Benefits</h3>
      <ul class="space-y-2 text-blue-800">
        <li>EU Solvency II consumer protections</li>
        <li>Recognized by Portuguese authorities</li>
        <li>Smooth visa documentation</li>
        <li>GDPR data protection</li>
        <li>EU dispute resolution access</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Practical Benefits</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Euro-denominated premiums</li>
        <li>Strong European network</li>
        <li>French/Portuguese support</li>
        <li>European business hours</li>
        <li>Familiar to Portuguese providers</li>
      </ul>
    </div>
  </div>

  <h3>AXA vs US-Based Insurers</h3>
  <p>
    For visa applications, AXA's EU status simplifies the process. If you don't need US coverage, AXA is often a better fit than Aetna or GeoBlue—and typically 15-25% cheaper since there's no US network cost built in.
  </p>

  <h2 id="sns-transition">Transitioning to SNS</h2>
  <p>
    After getting your Portuguese residence permit, you can register for SNS (Serviço Nacional de Saúde). Portugal abolished most user fees in 2022, making public healthcare nearly free.
  </p>

  <h3>Why Keep AXA After SNS?</h3>
  <ul>
    <li><strong>Faster access:</strong> Private care vs public waitlists</li>
    <li><strong>Travel coverage:</strong> SNS only covers Portugal/EU</li>
    <li><strong>English-speaking doctors:</strong> Easier to find privately</li>
    <li><strong>Portability:</strong> If you move to another EU country</li>
    <li><strong>Choice of hospital:</strong> Private room, specific specialists</li>
  </ul>

  <h3>Cost-Saving Strategy Post-SNS</h3>
  <ul>
    <li>Switch to Essential (inpatient-only) plan</li>
    <li>Use SNS for routine care (it's free)</li>
    <li>Use AXA for private specialists and travel</li>
    <li>Higher deductible reduces premiums further</li>
  </ul>

  <CTABox
    title="EU-Regulated Coverage"
    description="Smooth visa process with AXA's European credentials."
    buttonText="Get Your Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <h2 id="who-its-for">Who Should Choose AXA</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>EU citizens moving to Portugal</li>
        <li>Those wanting EU-regulated insurer</li>
        <li>Visa applicants (smooth process)</li>
        <li>French speakers</li>
        <li>Expats who travel within Europe</li>
        <li>Those who don't need US coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>US expats needing US coverage (Aetna, GeoBlue)</li>
        <li>Budget-conscious (Multicare/Allianz Portugal cheaper)</li>
        <li>Those wanting fastest claims processing</li>
        <li>Long-term Portugal-only residents</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is AXA accepted for Portuguese D7 visa?</h3>
  <p>
    Yes. AXA is an EU-regulated insurer, and Portuguese consulates readily accept their documentation. Comfort or higher plans meet typical requirements.
  </p>

  <h3>How does AXA compare to Allianz Care for Portugal?</h3>
  <p>
    Both are excellent EU-regulated options. Allianz is typically 15-25% cheaper and offers higher deductible options. AXA has the Exclusive tier with unlimited coverage. <a href="/compare/axa-global-vs-allianz-care">See our comparison</a>.
  </p>

  <h3>Can I use AXA while waiting for SNS registration?</h3>
  <p>
    Yes. AXA covers you immediately. Use it for all healthcare until your SNS registration completes—which can take weeks or months.
  </p>

  <h3>Does AXA cover Portuguese public hospitals?</h3>
  <p>
    AXA is private insurance for private healthcare. Emergency care at public hospitals may be reimbursed. Routine SNS care is separate from your AXA coverage.
  </p>

  <h3>Should I get AXA or local Portuguese insurance?</h3>
  <p>
    Local insurers (Multicare, Allianz Portugal) are cheaper but don't cover you outside Portugal well. Choose AXA if you travel frequently, might relocate, or want the security of an international insurer.
  </p>

  <CTABox
    title="Ready for Portugal?"
    description="Get a personalized AXA Global quote for your situation."
    buttonText="Get Your Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements and network availability change. Verify all information with AXA Global and Portuguese authorities before making decisions.
    </p>
  </div>
</PageShell>
