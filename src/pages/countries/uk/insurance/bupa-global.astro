---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in the UK', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'uk-benefits', text: 'UK-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Day-patient', ukPrice: '£170-220/mo' },
  { plan: 'Gold', coverage: 'Comprehensive', ukPrice: '£220-300/mo' },
  { plan: 'Platinum', coverage: 'Premium + Wellness', ukPrice: '£320-450/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in the UK"
  description="Guide to using BUPA Global in the UK. Premium service, mental health coverage, and the BUPA UK hospital network advantage."
  headline="BUPA Global Health Insurance in the UK"
  subheadline="BUPA Global for expats in the UK—premium service from Britain's leading private healthcare provider."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in the UK</h2>
  <p>
    BUPA is a British institution—the UK's largest private health insurer with its own hospitals and clinics. BUPA Global is their international arm, offering worldwide coverage with unmatched UK network access.
  </p>
  <p>
    For expats in the UK who want premium private healthcare with the best UK network integration, BUPA Global offers a unique advantage: seamless access to BUPA's own UK facilities plus international coverage.
  </p>

  <CTABox
    title="Get a UK Quote"
    description="See BUPA Global pricing for expats in the UK."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>BUPA UK Network Advantage</h3>
  <p>
    BUPA owns hospitals, clinics, and dental practices across the UK. BUPA Global members get seamless access to these facilities with direct billing—no claims to file.
  </p>

  <h2 id="uk-benefits">UK-Specific Benefits</h2>
  <ul>
    <li><strong>BUPA UK network:</strong> Direct access to BUPA's own hospitals and clinics</li>
    <li><strong>British heritage:</strong> Deep understanding of UK healthcare</li>
    <li><strong>Mental health:</strong> Comprehensive coverage with UK specialists</li>
    <li><strong>Pre-existing conditions:</strong> More flexible underwriting than competitors</li>
    <li><strong>Cromwell Hospital:</strong> Access to BUPA's flagship London hospital</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose BUPA Global in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those wanting premium UK private care</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those with pre-existing conditions</li>
        <li>Families wanting comprehensive coverage</li>
        <li>Those who value British healthcare institutions</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Those comfortable with NHS only</li>
        <li>Short-term visitors</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium UK Coverage?"
    description="Get a personalized BUPA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />
</PageShell>
