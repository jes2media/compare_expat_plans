---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in the UK', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'uk-benefits', text: 'UK-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient only', ukPrice: '£100-130/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', ukPrice: '£150-200/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', ukPrice: '£220-300/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in the UK"
  description="Guide to using Allianz Care in the UK. EU expertise, high-deductible options, and flexible coverage."
  headline="Allianz Care Health Insurance in the UK"
  subheadline="Allianz Care for expats in the UK—European insurer expertise with flexible plan options."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in the UK</h2>
  <p>
    Allianz Care offers international health insurance with strong European roots. For expats in the UK—particularly those from EU countries or with EU ties—Allianz provides familiar service and plans designed for European healthcare expectations.
  </p>
  <p>
    Allianz's high-deductible options make it attractive for expats who want catastrophic coverage while relying on NHS for routine care.
  </p>

  <CTABox
    title="Get a UK Quote"
    description="See Allianz Care pricing for expats in the UK."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    With NHS providing free routine care, many UK expats choose Allianz's high-deductible plans. You use NHS day-to-day and Allianz for major medical events or when you want private care.
  </p>

  <h2 id="uk-benefits">UK-Specific Benefits</h2>
  <ul>
    <li><strong>EU expertise:</strong> Good for EU citizens post-Brexit</li>
    <li><strong>High-deductible savings:</strong> Use NHS + Allianz for major events</li>
    <li><strong>European network:</strong> Strong if you travel to EU frequently</li>
    <li><strong>Multilingual support:</strong> Multiple European languages</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Allianz in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>EU citizens in the UK</li>
        <li>Those wanting high-deductible savings</li>
        <li>Expats who travel to Europe frequently</li>
        <li>Those using NHS + international backup</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>US expats (Aetna or GeoBlue better)</li>
        <li>Those wanting UK-specific coverage</li>
        <li>Budget digital nomads</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in the UK?"
    description="Get a personalized Allianz Care quote."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />
</PageShell>
