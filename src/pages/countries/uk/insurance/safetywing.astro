---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'SafetyWing in the UK', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'uk-considerations', text: 'UK Considerations', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose SafetyWing', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'SafetyWing vs Cigna', href: '/compare/safetywing-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK Price' },
];

const planRows = [
  { plan: 'Nomad Insurance', coverage: 'Travel medical', ukPrice: '£40/mo' },
  { plan: 'Remote Health', coverage: 'Comprehensive health', ukPrice: '£160-220/mo' },
];
---

<PageShell
  title="SafetyWing Insurance in the UK"
  description="Guide to using SafetyWing in the UK. Affordable nomad insurance with important limitations to understand."
  headline="SafetyWing Insurance in the UK"
  subheadline="SafetyWing for digital nomads in the UK—affordable coverage with important considerations."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get SafetyWing"
  ctaButtonHref="/go/safetywing"
>
  <h2 id="overview">SafetyWing in the UK</h2>
  <p>
    SafetyWing offers affordable insurance popular with digital nomads. In the UK, most visa holders get NHS access via the IHS, making SafetyWing most relevant for visitors, short-term stays, or as supplementary travel coverage.
  </p>
  <p>
    Unlike Germany, the UK doesn't require private insurance for most visas—you pay IHS instead. This makes SafetyWing less necessary for UK-based expats.
  </p>

  <CTABox
    title="Get SafetyWing"
    description="See SafetyWing pricing for nomads."
    buttonText="Get Quote"
    buttonHref="/go/safetywing"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Nomad Insurance vs Remote Health</h3>
  <ul>
    <li><strong>Nomad Insurance (~£40/mo):</strong> Travel medical—good for visitors, short stays</li>
    <li><strong>Remote Health (~£160-220/mo):</strong> Comprehensive health insurance</li>
  </ul>

  <h2 id="uk-considerations">UK Considerations</h2>

  <h3>When SafetyWing Works in the UK</h3>
  <ul>
    <li><strong>Standard Visitor Visa:</strong> No NHS access, need travel insurance</li>
    <li><strong>Short stays (under 6 months):</strong> Supplementary coverage</li>
    <li><strong>Travel outside UK:</strong> Coverage when leaving the country</li>
    <li><strong>Pre-visa period:</strong> Before IHS kicks in</li>
  </ul>

  <h3>When SafetyWing Isn't Needed</h3>
  <ul>
    <li><strong>Work/Family visa holders:</strong> IHS provides NHS access</li>
    <li><strong>Settled status:</strong> Full NHS access</li>
    <li><strong>Students:</strong> IHS provides NHS access</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-2">UK Is Different from Germany</h3>
    <p class="text-blue-800">
      Unlike Germany where private insurance is complex, most UK visa holders simply pay IHS and get full NHS access. SafetyWing is mainly useful for visitors or as travel coverage—not as your primary UK health insurance.
    </p>
  </div>

  <h2 id="who-its-for">Who Should Choose SafetyWing in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Visitors without NHS access</li>
        <li>Short-term stays (under 6 months)</li>
        <li>Travel insurance when leaving UK</li>
        <li>Budget-conscious nomads passing through</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Not Needed If</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>You've paid IHS (have NHS access)</li>
        <li>You have settled/pre-settled status</li>
        <li>You're on a work or family visa</li>
        <li>You want private UK hospital access</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Need Travel Coverage?"
    description="SafetyWing works well for visitors and travel outside the UK."
    buttonText="Get SafetyWing"
    buttonHref="/go/safetywing"
    variant="highlight"
  />
</PageShell>
