---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in the UK', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'uk-benefits', text: 'UK-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs GeoBlue', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK (Age 40)' },
];

const planRows = [
  { plan: 'Pioneer', coverage: 'Inpatient focused', ukPrice: '£150-200/mo' },
  { plan: 'Navigator', coverage: 'Comprehensive', ukPrice: '£220-290/mo' },
  { plan: 'Vantage', coverage: 'Premium + USA', ukPrice: '£300-400/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in the UK"
  description="Guide to using Aetna International in the UK. US expat focus, integrated US coverage."
  headline="Aetna International Health Insurance in the UK"
  subheadline="Aetna International for US expats in the UK—seamless coverage when returning to the US."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Quote"
  ctaButtonHref="/providers/aetna-international"
>
  <h2 id="overview">Aetna International in the UK</h2>
  <p>
    Aetna International is ideal for US citizens living in the UK who need coverage when returning to the US. As part of CVS Health, Aetna offers US healthcare integration that British insurers can't match.
  </p>
  <p>
    London has a large American expat community, and many US companies have UK offices. Aetna serves this market with familiar American service and US network access.
  </p>

  <CTABox
    title="Get a UK Quote"
    description="See Aetna International pricing for US expats in the UK."
    buttonText="Get Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="uk-benefits">UK-Specific Benefits</h2>
  <ul>
    <li><strong>US return coverage:</strong> Seamless care when visiting the US</li>
    <li><strong>CVS integration:</strong> Pharmacy benefits in the US</li>
    <li><strong>American service style:</strong> Familiar US customer experience</li>
    <li><strong>Corporate plans:</strong> Popular with US companies in London</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Aetna in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens in the UK</li>
        <li>Those who return to the US regularly</li>
        <li>US company employees in London</li>
        <li>Those wanting US insurer familiarity</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens (BUPA or Allianz better value)</li>
        <li>Those who won't visit the US</li>
        <li>Budget-conscious expats</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in the UK?"
    description="Get a personalized Aetna International quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/aetna-international"
    variant="highlight"
  />
</PageShell>
