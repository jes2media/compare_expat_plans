---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in the UK', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'uk-benefits', text: 'UK-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK (Age 40)' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Comprehensive', ukPrice: '£90-130/mo' },
  { plan: 'Global Medical + Outpatient', coverage: 'Full coverage', ukPrice: '£130-180/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in the UK"
  description="Guide to using IMG Global in the UK. Budget-friendly international coverage for expats."
  headline="IMG Global Health Insurance in the UK"
  subheadline="IMG Global for expats in the UK—budget-friendly international coverage alongside NHS access."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Quote"
  ctaButtonHref="/go/img-global"
>
  <h2 id="overview">IMG Global in the UK</h2>
  <p>
    IMG Global offers budget-friendly international health insurance. For expats in the UK who have NHS access but want additional private coverage or international protection, IMG provides good value.
  </p>
  <p>
    IMG costs 20-40% less than premium competitors while providing solid worldwide coverage.
  </p>

  <CTABox
    title="Get a UK Quote"
    description="See IMG Global pricing for expats in the UK."
    buttonText="Get Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="uk-benefits">UK-Specific Benefits</h2>
  <ul>
    <li><strong>Budget-friendly:</strong> Lower premiums than premium competitors</li>
    <li><strong>NHS supplement:</strong> Private coverage to complement NHS</li>
    <li><strong>Worldwide coverage:</strong> Good for expats who travel</li>
    <li><strong>Flexible deductibles:</strong> Customize to your budget</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose IMG in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Those with NHS access wanting backup</li>
        <li>Expats who travel internationally</li>
        <li>Those comfortable with reimbursement model</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting premium UK network access</li>
        <li>Expats with pre-existing conditions</li>
        <li>Those prioritizing mental health coverage</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in the UK?"
    description="Get a personalized IMG Global quote."
    buttonText="Get Your Quote"
    buttonHref="/go/img-global"
    variant="highlight"
  />
</PageShell>
