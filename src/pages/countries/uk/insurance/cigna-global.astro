---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Cigna Global in the UK', level: 2 },
  { id: 'vs-nhs', text: 'vs NHS Coverage', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Cigna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Cigna vs BUPA', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK (Age 40)' },
];

const planRows = [
  { plan: 'Silver', coverage: 'Inpatient + Day-patient', ukPrice: '£140-180/mo' },
  { plan: 'Gold', coverage: 'Silver + Outpatient', ukPrice: '£180-240/mo' },
  { plan: 'Platinum', coverage: 'Gold + Enhanced', ukPrice: '£260-350/mo' },
];
---

<PageShell
  title="Cigna Global Health Insurance in the UK"
  description="Guide to using Cigna Global in the UK. How it complements NHS, worldwide coverage, and when it makes sense."
  headline="Cigna Global Health Insurance in the UK"
  subheadline="Is Cigna Global the right choice for expats in the UK? Understand how it works alongside NHS access."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Quote"
  ctaButtonHref="/providers/cigna-global"
>
  <h2 id="overview">Cigna Global in the UK</h2>
  <p>
    Cigna Global provides international health insurance that works alongside or instead of NHS coverage. For expats in the UK, it's particularly valuable if you travel frequently, might relocate, or want guaranteed private healthcare access worldwide.
  </p>
  <p>
    Unlike UK-only private insurance, Cigna Global provides coverage anywhere in the world, making it ideal for globally mobile professionals.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.5M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">24/7</p>
      <p class="text-sm text-neutral-600">English support</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">Global</p>
      <p class="text-sm text-neutral-600">Portable coverage</p>
    </div>
  </div>

  <CTABox
    title="Get a UK Quote"
    description="See Cigna Global pricing for expats in the UK."
    buttonText="Get Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />

  <h2 id="vs-nhs">vs NHS Coverage</h2>

  <h3>Why Add Cigna to NHS</h3>
  <ul>
    <li><strong>Skip wait times:</strong> See specialists within days</li>
    <li><strong>Worldwide coverage:</strong> Protected when traveling or relocating</li>
    <li><strong>Private hospitals:</strong> Access to Harley Street specialists, private rooms</li>
    <li><strong>Mental health:</strong> Faster access than NHS mental health services</li>
  </ul>

  <h3>When NHS Is Sufficient</h3>
  <ul>
    <li>You rarely leave the UK</li>
    <li>Wait times don't concern you</li>
    <li>Budget is a primary concern</li>
    <li>You're comfortable with NHS processes</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="who-its-for">Who Should Choose Cigna in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Globally mobile professionals</li>
        <li>Those who travel frequently</li>
        <li>Expats who may relocate from UK</li>
        <li>Those wanting guaranteed private access</li>
        <li>Mental health coverage priority</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>UK-only residents (UK private insurers cheaper)</li>
        <li>Those comfortable with NHS wait times</li>
        <li>Budget-conscious expats</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in the UK?"
    description="Get a personalized Cigna Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/cigna-global"
    variant="highlight"
  />
</PageShell>
