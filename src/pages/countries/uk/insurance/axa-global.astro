---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in the UK', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'uk-benefits', text: 'UK-Specific Benefits', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in the UK', href: '/countries/uk/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'ukPrice', header: 'UK (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient focused', ukPrice: '£110-150/mo' },
  { plan: 'Standard', coverage: 'Inpatient + Outpatient', ukPrice: '£170-230/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', ukPrice: '£240-320/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in the UK"
  description="Guide to using AXA Global in the UK. EU-regulated French insurer with strong UK presence."
  headline="AXA Global Health Insurance in the UK"
  subheadline="AXA Global for expats in the UK—European insurer with strong UK and EU coverage."
  heroBackgroundImage="/images/countries/uk-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in the UK</h2>
  <p>
    AXA Global, headquartered in France, offers international health insurance with strong European expertise. For expats in the UK—particularly those who travel frequently between the UK and EU—AXA provides seamless cross-border coverage.
  </p>
  <p>
    AXA also operates AXA Health in the UK (formerly AXA PPP), giving them deep UK market knowledge.
  </p>

  <CTABox
    title="Get a UK Quote"
    description="See AXA Global pricing for expats in the UK."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h2 id="uk-benefits">UK-Specific Benefits</h2>
  <ul>
    <li><strong>AXA UK presence:</strong> Local knowledge through AXA Health UK</li>
    <li><strong>EU coverage:</strong> Strong if you travel to EU post-Brexit</li>
    <li><strong>European expertise:</strong> Understands cross-border healthcare</li>
    <li><strong>Multilingual support:</strong> French, English, and more</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose AXA in the UK</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>EU citizens in the UK</li>
        <li>Those who travel UK-EU frequently</li>
        <li>French expats in London</li>
        <li>Those familiar with AXA brand</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>US expats (Aetna or GeoBlue better)</li>
        <li>Those wanting UK-only coverage</li>
        <li>Budget digital nomads</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Coverage in the UK?"
    description="Get a personalized AXA Global quote."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />
</PageShell>
