  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'healthcare-system', text: 'Mexico\'s Healthcare System', level: 2 },
  { id: 'imss', text: 'IMSS Public Insurance', level: 2 },
  { id: 'visa-requirements', text: 'Visa & Insurance Requirements', level: 2 },
  { id: 'recommended-plans', text: 'Recommended Plans', level: 2 },
  { id: 'costs', text: 'Expected Costs', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global in Mexico', href: '/countries/mexico/insurance/cigna-global' },
  { title: 'Allianz Care in Mexico', href: '/countries/mexico/insurance/allianz-care' },
  { title: 'BUPA Global in Mexico', href: '/countries/mexico/insurance/bupa-global' },
  { title: 'IMG Global in Mexico', href: '/countries/mexico/insurance/img-global' },
];

const planColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'type', header: 'Type' },
  { key: 'bestFor', header: 'Best For' },
  { key: 'startingPrice', header: 'From' },
];

const planRows = [
  { provider: 'IMSS (Public)', type: 'Public', bestFor: 'Budget-conscious', startingPrice: '$500/yr' },
  { provider: 'GNP Seguros', type: 'Local Private', bestFor: 'Long-term residents', startingPrice: '$120/mo' },
  { provider: 'Bupa Mexico', type: 'Local Private', bestFor: 'English speakers', startingPrice: '$150/mo' },
  { provider: 'IMG Global', type: 'International', bestFor: 'Budget international', startingPrice: '$75/mo' },
  { provider: 'Allianz Care', type: 'International', bestFor: 'High-deductible savings', startingPrice: '$120/mo' },
  { provider: 'Cigna Global', type: 'International', bestFor: 'US border / travelers', startingPrice: '$160/mo' },
  { provider: 'BUPA Global', type: 'International', bestFor: 'Mental health / pre-existing', startingPrice: '$200/mo' },
