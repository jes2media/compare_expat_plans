---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Mexico', level: 2 },
  { id: 'deductible-waiver', text: 'The 50% Deductible Waiver', level: 2 },
  { id: 'mexico-network', text: 'Network Coverage in Mexico', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Mexican Insurers', level: 2 },
  { id: 'claims-in-mexico', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Mexico', href: '/countries/mexico/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'mexicoPrice', header: 'Mexico (Age 35)' },
  { key: 'usIncluded', header: 'US Coverage' },
];

const planRows = [
  { plan: 'Global Medical (Excl. USA)', coverage: 'Inpatient + Outpatient', mexicoPrice: '$75-110/mo', usIncluded: 'Emergency only' },
  { plan: 'With $2,500 Deductible', coverage: 'Inpatient + Outpatient', mexicoPrice: '$55-80/mo', usIncluded: 'Emergency only' },
  { plan: 'Global Medical (Incl. USA)', coverage: 'Inpatient + Outpatient', mexicoPrice: '$180-240/mo', usIncluded: 'Full coverage' },
  { plan: 'With $5,000 Deductible', coverage: 'Inpatient + Outpatient', mexicoPrice: '$45-65/mo', usIncluded: 'Emergency only' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'img', header: 'IMG Global' },
  { key: 'mexican', header: 'Mexican Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 35)', img: '$75-110', mexican: '$120-180' },
  { factor: 'With High Deductible', img: '$45-65', mexican: 'Limited options' },
  { factor: 'Network in Mexico', img: 'Smaller (reimbursement)', mexican: 'Extensive' },
  { factor: 'Annual Maximum', img: 'Up to $8M', mexican: 'Varies' },
  { factor: 'Deductible Waiver', img: '50% outside US', mexican: 'No' },
  { factor: 'Deductible Type', img: 'Annual', mexican: 'Per-illness (lifetime)' },
  { factor: 'Medical Evacuation', img: 'Up to $500K', mexican: 'Usually not' },
  { factor: 'Portability', img: 'Worldwide', mexican: 'Mexico only' },
];

const savingsColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'img', header: 'IMG Global' },
  { key: 'premium', header: 'Premium Insurers' },
  { key: 'savings', header: 'Annual Savings' },
];

const savingsRows = [
  { coverage: 'Standard deductible', img: '$900-1,320/yr', premium: '$1,920-2,520/yr', savings: '$1,000-1,200' },
  { coverage: '$2,500 deductible', img: '$660-960/yr', premium: '$1,440-2,040/yr', savings: '$780-1,080' },
  { coverage: '$5,000 deductible', img: '$540-780/yr', premium: 'Limited options', savings: '$700+' },
];
---

<PageShell
  title="IMG Global Health Insurance in Mexico"
  description="Complete guide to using IMG Global in Mexico. Budget-friendly international coverage with the 50% deductible waiver advantage."
  headline="IMG Global Health Insurance in Mexico"
  subheadline="Budget-friendly international coverage for expats in Mexico. How IMG's 50% deductible waiver makes high-deductible plans practical."
  heroBackgroundImage="/images/countries/mexico-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Mexico Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Mexico</h2>
  <p>
    IMG Global offers a budget-friendly path to international health insurance for expats in Mexico. While not as well-known as Cigna or BUPA, IMG provides solid coverage at lower price points, making it attractive for cost-conscious expats.
  </p>
  <p>
    The key advantage: IMG's 50% deductible waiver for treatment outside the US makes high-deductible plans especially practical in Mexico, where healthcare is already affordable.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$8M</p>
      <p class="text-sm text-neutral-600">Max annual limit</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">50%</p>
      <p class="text-sm text-neutral-600">Deductible waiver outside US</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$500K</p>
      <p class="text-sm text-neutral-600">Medical evacuation</p>
    </div>
  </div>

  <CTABox
    title="Get a Mexico-Specific Quote"
    description="See what IMG Global costs for expats living in Mexico."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="deductible-waiver">The 50% Deductible Waiver</h2>
  <p>
    IMG's standout feature for Mexico expats: if you receive treatment outside the US, your deductible is automatically reduced by 50%.
  </p>

  <h3>How It Works</h3>
  <ul>
    <li><strong>$5,000 deductible → $2,500 effective deductible</strong> in Mexico</li>
    <li><strong>$2,500 deductible → $1,250 effective deductible</strong> in Mexico</li>
    <li><strong>$10,000 deductible → $5,000 effective deductible</strong> in Mexico</li>
  </ul>

  <h3>Why This Matters in Mexico</h3>
  <p>
    Mexican healthcare is already affordable:
  </p>
  <ul>
    <li>Doctor visit: $30-60</li>
    <li>Specialist: $50-100</li>
    <li>Lab work: $20-50</li>
    <li>Urgent care: $50-100</li>
  </ul>
  <p>
    With a $5,000 deductible (effective $2,500 in Mexico), you get the cheapest possible premium while still having major expenses covered. Most expats would have to incur significant medical costs before hitting even the reduced deductible.
  </p>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-2">Real-World Example</h3>
    <p class="text-green-800">
      With IMG's $5,000 deductible plan (~$45-65/month), your effective deductible in Mexico is $2,500. That means routine care is out of pocket (affordable in Mexico anyway), but hospitalization, surgery, or cancer treatment is covered after $2,500 — at premiums under $800/year.
    </p>
  </div>

  <h2 id="mexico-network">Network Coverage in Mexico</h2>
  <p>
    IMG has a smaller network in Mexico compared to local insurers or Cigna. Most expats use the reimbursement model: pay providers directly, then submit claims.
  </p>

  <h3>How It Works in Practice</h3>
  <ul>
    <li><strong>Any licensed provider:</strong> See any doctor or hospital in Mexico</li>
    <li><strong>Pay at time of service:</strong> Pay with card or cash</li>
    <li><strong>Submit for reimbursement:</strong> Upload factura via IMG app</li>
    <li><strong>Fast processing:</strong> Typical reimbursement in 5-10 business days</li>
  </ul>

  <p>
    This works well in Mexico because:
  </p>
  <ul>
    <li>Healthcare costs are affordable even without insurance</li>
    <li>Mexican providers issue detailed receipts (facturas)</li>
    <li>Complete freedom of provider choice</li>
    <li>No network restrictions</li>
  </ul>

  <h3>Emergency Care</h3>
  <p>
    For emergencies, go to the nearest hospital. IMG covers emergency care at any facility. Contact IMG's 24/7 assistance line for help with hospital coordination or if you need medical evacuation (covered up to $500K).
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    IMG Global offers Global Medical Insurance with flexible deductible options:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for "excluding USA" plans. Adding US coverage significantly increases premiums.</em>
  </p>

  <h3>Savings Comparison</h3>
  <p>
    How does IMG compare to premium international insurers?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={savingsColumns} rows={savingsRows} />
  </div>

  <h3>Coverage Highlights</h3>
  <ul>
    <li><strong>Annual maximum:</strong> Up to $8M</li>
    <li><strong>Inpatient:</strong> Hospital, surgery, ICU fully covered</li>
    <li><strong>Outpatient:</strong> Doctor visits, labs, imaging</li>
    <li><strong>Emergency evacuation:</strong> Up to $500K</li>
    <li><strong>Maternity:</strong> Available after waiting period</li>
    <li><strong>Mental health:</strong> Included (check limits)</li>
  </ul>

  <CTABox
    title="Calculate Your Savings"
    description="See how much you can save with IMG's high-deductible options."
    buttonText="Get a Quote"
    buttonHref="/providers/img-global"
  />

  <h2 id="vs-local-options">vs Mexican Insurers</h2>
  <p>
    How does IMG Global compare to Mexican insurance companies?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose IMG Global If:</h3>
  <ul>
    <li>Budget is a major consideration</li>
    <li>High-deductible strategy appeals to you</li>
    <li>You're comfortable with reimbursement model</li>
    <li>You travel outside Mexico and want worldwide coverage</li>
    <li>Medical evacuation is important</li>
    <li>You might relocate from Mexico</li>
    <li>Maximum coverage limits matter (up to $8M)</li>
  </ul>

  <h3>Choose a Mexican Insurer If:</h3>
  <ul>
    <li>You want direct billing at local hospitals</li>
    <li>Extensive local network is important</li>
    <li>You're staying in Mexico permanently</li>
    <li>Per-illness deductibles work for you</li>
    <li>You prefer peso billing</li>
  </ul>

  <h3>Consider Premium International Insurers If:</h3>
  <ul>
    <li>You need US coverage</li>
    <li>You have significant pre-existing conditions</li>
    <li>Mental health parity is essential</li>
    <li>Brand recognition matters</li>
  </ul>

  <p>
    <a href="/countries/mexico/insurance">See all Mexico insurance options →</a>
  </p>

  <h2 id="claims-in-mexico">Using Your Insurance in Mexico</h2>

  <h3>Reimbursement Process</h3>
  <ol class="list-decimal list-inside space-y-2">
    <li>See any licensed provider in Mexico</li>
    <li>Pay at time of service (get factura with RFC)</li>
    <li>Submit claim via IMG app or online portal</li>
    <li>Processing typically 5-10 business days</li>
    <li>Reimbursement to your bank account</li>
  </ol>

  <h3>Documentation Tips</h3>
  <ul>
    <li>Mexican facturas are accepted without translation</li>
    <li>Keep itemized receipts (not just credit card receipts)</li>
    <li>Include diagnosis codes when available</li>
    <li>Submit promptly (within 90 days)</li>
  </ul>

  <h3>IMG MyIMG App</h3>
  <p>
    The IMG app lets you:
  </p>
  <ul>
    <li>Submit claims with photo upload</li>
    <li>Track claim status</li>
    <li>Access digital ID card</li>
    <li>Contact 24/7 assistance</li>
  </ul>

  <h3>Medical Evacuation</h3>
  <p>
    IMG includes up to $500K in medical evacuation coverage — critical if you live outside major cities and might need transport to Mexico City, Guadalajara, or the US for specialized care.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in Mexico</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals comfortable with high deductibles</li>
        <li>Those who prefer provider freedom</li>
        <li>Expats who travel frequently</li>
        <li>Those wanting maximum coverage limits</li>
        <li>People comfortable with reimbursement</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those wanting direct billing networks</li>
        <li>Expats with significant pre-existing conditions</li>
        <li>Those needing US coverage (Cigna)</li>
        <li>People who prefer established brands</li>
        <li>Those needing extensive mental health coverage</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>How does the 50% deductible waiver work?</h3>
  <p>
    When you receive treatment outside the US, your deductible is automatically reduced by 50%. If you chose a $5,000 deductible, you only need to meet $2,500 in Mexico before coverage kicks in. This happens automatically — no need to request it.
  </p>

  <h3>Can I use IMG Global and IMSS together?</h3>
  <p>
    Yes. Many expats enroll in IMSS (~$500/year) for basic routine care, then keep IMG for private care, emergencies, international coverage, and major medical situations. This combination provides comprehensive coverage at minimal cost.
  </p>

  <h3>What if I need hospitalization?</h3>
  <p>
    Go to any hospital. Contact IMG's assistance line — they can help coordinate with the hospital, arrange direct payment for large expenses, and provide support throughout your stay. Medical evacuation is covered up to $500K if you need transport to a major city or the US.
  </p>

  <h3>Does IMG cover pre-existing conditions?</h3>
  <p>
    IMG typically excludes pre-existing conditions or applies waiting periods. If you have significant health conditions, consider BUPA Global which may offer more favorable handling.
  </p>

  <h3>How does IMG compare to IMSS?</h3>
  <p>
    IMSS costs ~$500/year with access to public facilities. IMG Global costs $540-1,320/year depending on deductible, with access to any private facility worldwide, medical evacuation, and up to $8M coverage. Many expats use both: IMSS for routine care, IMG for everything else.
  </p>

  <h3>Is IMG a good choice for retirees?</h3>
  <p>
    It can be. IMG's high-deductible options work well for healthy retirees who want catastrophic coverage at low cost. However, if you have pre-existing conditions or expect to use healthcare frequently, a premium insurer like BUPA may be more appropriate.
  </p>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for your situation in Mexico."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Pricing and coverage terms change. We are not insurance brokers. Verify all information with IMG Global before making decisions.
    </p>
  </div>
</PageShell>
