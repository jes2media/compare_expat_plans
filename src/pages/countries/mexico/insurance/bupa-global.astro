---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Mexico', level: 2 },
  { id: 'bupa-mexico-connection', text: 'BUPA Global vs BUPA Mexico', level: 2 },
  { id: 'mexico-network', text: 'Network Coverage in Mexico', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Mexican Insurers', level: 2 },
  { id: 'claims-in-mexico', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA Global', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Mexico', href: '/countries/mexico/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'mexicoPrice', header: 'Mexico (Age 35)' },
  { key: 'usIncluded', header: 'US Coverage' },
];

const planRows = [
  { plan: 'Essentials (Excl. USA)', coverage: 'Inpatient + Day-patient', mexicoPrice: '$140-180/mo', usIncluded: 'Emergency only' },
  { plan: 'Complete (Excl. USA)', coverage: 'Essentials + Outpatient', mexicoPrice: '$200-260/mo', usIncluded: 'Emergency only' },
  { plan: 'Complete (Incl. USA)', coverage: 'Essentials + Outpatient', mexicoPrice: '$340-440/mo', usIncluded: 'Full coverage' },
  { plan: 'Premier (Incl. USA)', coverage: 'Complete + Dental/Vision', mexicoPrice: '$420-540/mo', usIncluded: 'Full coverage' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'mexican', header: 'Mexican Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 35)', bupa: '$200-260', mexican: '$120-180' },
  { factor: 'Mental Health Parity', bupa: 'Full parity', mexican: 'Often limited' },
  { factor: 'Pre-existing Conditions', bupa: 'Often covered', mexican: 'Usually excluded' },
  { factor: 'Network in Mexico', bupa: 'Good', mexican: 'Extensive' },
  { factor: 'No-Claims Discount', bupa: 'Up to 30%', mexican: 'Rarely offered' },
  { factor: 'Deductible Type', bupa: 'Annual', mexican: 'Per-illness (lifetime)' },
  { factor: 'Medical Evacuation', bupa: 'Included', mexican: 'Usually not' },
  { factor: 'Dental/Vision Included', bupa: 'Premier+ plans', mexican: 'Usually add-on' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Mexico City', hospitals: 'Hospital ABC, Médica Sur, Hospital Ángeles Lomas', directBilling: true },
  { city: 'Guadalajara', hospitals: 'Hospital San Javier, Hospital Puerta de Hierro Sur', directBilling: true },
  { city: 'Monterrey', hospitals: 'Christus Muguerza, Hospital San José Tec de Monterrey', directBilling: true },
  { city: 'Cancun', hospitals: 'Hospiten Cancún, Hospital Amerimed', directBilling: true },
  { city: 'Los Cabos', hospitals: 'Hospiten Los Cabos, Hospital Amerimed Los Cabos', directBilling: true },
];
---

<PageShell
  title="BUPA Global Health Insurance in Mexico"
  description="Complete guide to using BUPA Global in Mexico. Premium coverage with mental health parity, pre-existing condition handling, and comparison to BUPA Mexico."
  headline="BUPA Global Health Insurance in Mexico"
  subheadline="Premium international coverage for expats in Mexico. Mental health parity, pre-existing conditions, and why BUPA Global differs from BUPA Mexico."
  heroBackgroundImage="/images/countries/mexico-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Mexico Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Mexico</h2>
  <p>
    BUPA Global is the premium choice for expats in Mexico who want comprehensive coverage without gaps. As a healthcare-focused company, BUPA offers more inclusive benefits, better mental health coverage, and more favorable handling of pre-existing conditions than most competitors.
  </p>
  <p>
    The trade-off is price. BUPA Global typically costs 40-60% more than mid-range options. For expats with health concerns, mental health needs, or who want peace of mind, that premium is often worth it.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">4.4/5</p>
      <p class="text-sm text-neutral-600">Trustpilot rating</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">75+</p>
      <p class="text-sm text-neutral-600">Years in healthcare</p>
    </div>
  </div>

  <CTABox
    title="Get a Mexico-Specific Quote"
    description="See what BUPA Global costs for expats living in Mexico."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="bupa-mexico-connection">BUPA Global vs BUPA Mexico</h2>
  <p>
    Mexico has a local BUPA presence (BUPA Mexico / Bupa Nacional Plus), which creates some confusion. Here's the difference:
  </p>

  <h3>BUPA Mexico (Bupa Nacional Plus)</h3>
  <ul>
    <li>Domestic Mexican insurance</li>
    <li>Coverage in Mexico only</li>
    <li>Priced in pesos</li>
    <li>Per-illness deductibles (Mexican standard)</li>
    <li>Popular with English-speaking expats</li>
    <li>Starting around $150/month</li>
  </ul>

  <h3>BUPA Global</h3>
  <ul>
    <li>International health insurance</li>
    <li>Worldwide coverage</li>
    <li>Priced in USD</li>
    <li>Annual deductibles</li>
    <li>Mental health parity</li>
    <li>Pre-existing condition options</li>
    <li>Starting around $200/month (excluding USA)</li>
  </ul>

  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-yellow-900 mb-2">Which BUPA for Mexico?</h3>
    <p class="text-yellow-800">
      <strong>BUPA Mexico</strong> is typically better if you're staying in Mexico permanently and want a local product. <strong>BUPA Global</strong> is better if you need mental health coverage, have pre-existing conditions, travel frequently, or might relocate.
    </p>
  </div>

  <h2 id="mexico-network">Network Coverage in Mexico</h2>
  <p>
    BUPA Global has a solid network in Mexico, with direct billing available at major private hospitals. Network coverage is similar to BUPA Mexico in major cities.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Notable Network Features</h3>
  <ul>
    <li><strong>Major cities:</strong> Strong coverage at top hospitals (ABC, Médica Sur, Hospital Ángeles)</li>
    <li><strong>Tourist areas:</strong> Good coverage in Cancun, Los Cabos, Puerto Vallarta</li>
    <li><strong>Christus Muguerza network:</strong> Access to this major hospital group</li>
    <li><strong>Mental health:</strong> Access to psychiatric facilities and therapy networks</li>
  </ul>

  <p>
    For providers outside the network, you can see any licensed doctor or hospital and submit for reimbursement.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    BUPA Global offers four tiers with or without US coverage:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Adding US coverage increases premiums by approximately 70%.</em>
  </p>

  <h3>What Makes BUPA Global Different</h3>
  <ul>
    <li><strong>Mental health parity:</strong> Mental health covered at the same level as physical health — same limits, same access. Rare in international insurance.</li>
    <li><strong>No-claims discount:</strong> Claim-free years reduce your premium over time (up to 30% savings).</li>
    <li><strong>Dental/vision included:</strong> Premier and Elite plans include dental and vision.</li>
    <li><strong>Pre-existing conditions:</strong> BUPA often covers pre-existing conditions from day one (with disclosure).</li>
  </ul>

  <h3>Which Plan for Mexico?</h3>
  <ul>
    <li><strong>Essentials:</strong> Hospital only. Consider if you want BUPA's benefits but need to minimize cost.</li>
    <li><strong>Complete:</strong> The practical choice for most expats. Full medical coverage with mental health parity.</li>
    <li><strong>Complete (Incl. USA):</strong> Adds US coverage. Good for border residents or those wanting US hospital access.</li>
    <li><strong>Premier:</strong> Adds dental and vision. Good for families or those wanting all-inclusive coverage.</li>
  </ul>

  <CTABox
    title="Worth the Premium?"
    description="Get a personalized quote to see the actual cost difference."
    buttonText="Get a Quote"
    buttonHref="/providers/bupa-global"
  />

  <h2 id="vs-local-options">vs Mexican Insurers</h2>
  <p>
    BUPA Global costs significantly more than Mexican insurers. Here's what you get for the difference:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose BUPA Global If:</h3>
  <ul>
    <li>Mental health coverage is essential</li>
    <li>You have pre-existing conditions other insurers won't cover</li>
    <li>You want dental/vision included (Premier+)</li>
    <li>You value no-claims discounts long-term</li>
    <li>You may relocate from Mexico</li>
    <li>Premium comprehensive coverage gives you peace of mind</li>
  </ul>

  <h3>Choose a Mexican Insurer (or BUPA Mexico) If:</h3>
  <ul>
    <li>Budget is the primary concern</li>
    <li>You're healthy without pre-existing conditions</li>
    <li>Mental health coverage isn't a priority</li>
    <li>You're staying in Mexico permanently</li>
    <li>You want the most extensive local network</li>
  </ul>

  <p>
    <a href="/countries/mexico/insurance">See all Mexico insurance options →</a>
  </p>

  <h2 id="claims-in-mexico">Using Your Insurance in Mexico</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, present your BUPA membership card for cashless treatment. Major hospitals in Mexico City, Guadalajara, and Monterrey accept direct billing.
  </p>

  <h3>MembersWorld Portal</h3>
  <p>
    BUPA's MembersWorld app and portal let you:
  </p>
  <ul>
    <li>Find network providers in Mexico</li>
    <li>Submit claims digitally</li>
    <li>Track claim status in real-time</li>
    <li>Access your digital membership card</li>
    <li>Chat with support</li>
  </ul>

  <h3>Claims Process</h3>
  <p>
    BUPA has a strong claims reputation (4.4/5 Trustpilot). For out-of-network care, pay the provider, keep the factura, and submit via the app. Claims typically process within 5-7 business days.
  </p>

  <h3>Medical Evacuation</h3>
  <p>
    BUPA includes medical evacuation — important if you live outside major cities and might need transport to Mexico City, Guadalajara, or the US for specialized care.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA Global in Mexico</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>Expats with pre-existing conditions</li>
        <li>Those needing mental health coverage</li>
        <li>Families wanting all-inclusive plans</li>
        <li>Retirees with complex health needs</li>
        <li>Those who value premium service</li>
        <li>Expats who may relocate</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Young, healthy individuals</li>
        <li>Those who rarely use healthcare</li>
        <li>Permanent Mexico residents (BUPA Mexico)</li>
        <li>Those comfortable with IMSS</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is BUPA Global the same as BUPA Mexico?</h3>
  <p>
    No. BUPA Mexico (Bupa Nacional Plus) is domestic Mexican insurance that only covers you in Mexico. BUPA Global is international health insurance with worldwide coverage, annual deductibles, and additional benefits like mental health parity. They're separate products.
  </p>

  <h3>Will BUPA Global cover my pre-existing condition?</h3>
  <p>
    Possibly. BUPA is more willing than most insurers to cover pre-existing conditions, often from day one with full disclosure. Depending on the condition, you may get full coverage, coverage with limits, or coverage after a waiting period. Severe conditions may still be excluded.
  </p>

  <h3>How does mental health parity work?</h3>
  <p>
    BUPA covers mental health treatment at the same limits as physical health. If your plan has a $2M annual limit, that applies equally to psychiatric care, therapy, and mental health hospitalization. Most insurers have separate, lower sub-limits for mental health.
  </p>

  <h3>Can I use BUPA Global and IMSS together?</h3>
  <p>
    Yes. Many expats enroll in IMSS (~$500/year) for basic routine care, then keep BUPA Global for private hospitals, mental health, and major medical situations. This combination provides comprehensive coverage with cost savings on routine care.
  </p>

  <h3>Is the no-claims discount worth it?</h3>
  <p>
    Over time, yes. If you don't claim for consecutive years, your premium decreases up to 30%. For healthy individuals, this can offset BUPA's higher base premium. The discount builds over several claim-free years.
  </p>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for your situation in Mexico."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Network availability, pricing, and coverage terms change. We are not insurance brokers. Verify all information with BUPA Global before making decisions.
    </p>
  </div>
</PageShell>
