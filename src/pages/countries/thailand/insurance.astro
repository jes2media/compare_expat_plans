  { provider: 'Luma Health', type: 'Local', visaApproved: true, startingPrice: '$60/mo' },
  { provider: 'IMG Global', type: 'International', visaApproved: 'Verify', startingPrice: '$85/mo' },
  { provider: 'Allianz Care', type: 'International', visaApproved: 'Verify', startingPrice: '$130/mo' },
  { provider: 'Cigna Global', type: 'International', visaApproved: 'Verify', startingPrice: '$180/mo' },
  { provider: 'BUPA Global', type: 'International', visaApproved: 'Verify', startingPrice: '$215/mo' },
