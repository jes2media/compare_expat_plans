---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Thailand', level: 2 },
  { id: 'visa-compliance', text: 'Thai Visa Compliance', level: 2 },
  { id: 'thailand-network', text: 'Network Coverage in Thailand', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'eu-regulation', text: 'EU Insurer Benefits', level: 2 },
  { id: 'vs-local-options', text: 'vs Thai Insurers', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Thailand', href: '/countries/thailand/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Allianz', href: '/compare/axa-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'thailandPrice', header: 'Thailand (Age 50)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Emergency', thailandPrice: '$110-150/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Comfort', coverage: 'Essential + Outpatient', thailandPrice: '$160-220/mo', visaCompliant: 'Verify' },
  { plan: 'Excellence', coverage: 'Comprehensive', thailandPrice: '$230-310/mo', visaCompliant: true },
  { plan: 'Exclusive', coverage: 'Unlimited', thailandPrice: '$370-480/mo', visaCompliant: true },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'thai', header: 'Thai Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', axa: '$160-220', thai: '$60-150' },
  { factor: 'Regulation', axa: 'EU (Solvency II)', thai: 'Thai OIC' },
  { factor: 'Network in Thailand', axa: 'Good', thai: 'Excellent' },
  { factor: 'TGIA Approved', axa: 'Verify', thai: 'Yes (most)' },
  { factor: 'Coverage Outside Thailand', axa: 'Worldwide', thai: 'Limited/None' },
  { factor: 'Currency', axa: 'EUR or USD', thai: 'THB' },
  { factor: 'Portability', axa: 'Fully portable', thai: 'Thailand only' },
  { factor: 'Best For', axa: 'EU expats, travelers', thai: 'Long-term residents' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Bangkok', hospitals: 'Bumrungrad International, Bangkok Hospital, BNH Hospital', directBilling: true },
  { city: 'Chiang Mai', hospitals: 'Bangkok Hospital Chiang Mai, Chiang Mai Ram Hospital', directBilling: true },
  { city: 'Phuket', hospitals: 'Bangkok Hospital Phuket, Phuket International Hospital', directBilling: true },
  { city: 'Pattaya', hospitals: 'Bangkok Hospital Pattaya, Pattaya International Hospital', directBilling: true },
  { city: 'Hua Hin', hospitals: 'Bangkok Hospital Hua Hin', directBilling: true },
];
---

<PageShell
  title="AXA Global Health Insurance in Thailand"
  description="Guide to using AXA Global in Thailand. EU-regulated insurer for European expats. Visa compliance, Thai network, and pricing details."
  headline="AXA Global Health Insurance in Thailand"
  subheadline="French insurance giant with EU regulation. Good choice for European expats who want worldwide portability without US coverage costs."
  heroBackgroundImage="/images/countries/thailand-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Thailand Quote"
  ctaButtonHref="/providers/axa-global"
>
  <h2 id="overview">AXA Global in Thailand</h2>
  <p>
    AXA Global Healthcare is one of the world's largest international health insurers. For expats in Thailand who don't need US coverage, AXA offers competitive pricing—15-25% less than US-focused insurers that bundle expensive US networks into the price.
  </p>
  <p>
    Thailand attracts expats from around the world, not just Americans. For Europeans, Australians, and other non-US expats, AXA provides EU-regulated protection with worldwide portability—useful if Thailand is part of a longer international journey.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.6M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">EU</p>
      <p class="text-sm text-neutral-600">Regulated (Solvency II)</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">€/$</p>
      <p class="text-sm text-neutral-600">Currency flexibility</p>
    </div>
  </div>

  <CTABox
    title="Get a Thailand-Specific Quote"
    description="See what AXA Global costs for expats in Thailand."
    buttonText="Get Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <h2 id="visa-compliance">Thai Visa Compliance</h2>
  <p>
    Thailand has strict insurance requirements for O-A, O-X, and LTR visas. AXA Global may meet these requirements, but TGIA approval is essential.
  </p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">Important: Verify TGIA Approval</h3>
    <p class="text-amber-800">
      AXA Global is EU-regulated, but Thai visa requirements specifically require TGIA-approved insurers. <strong>Always verify at longstay.tgia.org</strong> before visa applications. If AXA isn't approved, use a Thai insurer (Pacific Cross, AXA Thailand—the local subsidiary) for your visa.
    </p>
  </div>

  <h3>O-A Visa (1-Year Retirement)</h3>
  <ul>
    <li>400,000 THB (~$11,500) inpatient + 40,000 THB (~$1,150) outpatient, OR</li>
    <li>$100,000 USD / 3,000,000 THB total medical coverage</li>
    <li>Must be from a TGIA-approved insurer</li>
  </ul>
  <p>
    AXA Comfort and higher plans exceed these coverage minimums if approved.
  </p>

  <h3>O-X Visa (10-Year Retirement)</h3>
  <p>
    Same requirements as O-A. Verify TGIA approval before applying.
  </p>

  <h3>LTR Visa (Long-Term Resident)</h3>
  <p>
    Requires $50,000 USD minimum coverage. AXA plans exceed this with €1-3M limits. LTR visa may be more flexible with international insurers.
  </p>

  <h3>Non-O Visa (No Requirement)</h3>
  <p>
    If you're extending a Non-O visa based on retirement or Thai spouse, health insurance isn't mandatory. AXA is an excellent choice without TGIA constraints.
  </p>

  <h3>AXA Global vs AXA Thailand</h3>
  <p>
    Note: <strong>AXA Thailand</strong> is the local Thai subsidiary—separate from AXA Global Healthcare. AXA Thailand is TGIA-approved and may be better for visa purposes. AXA Global offers worldwide portability but may not have TGIA approval.
  </p>

  <h2 id="thailand-network">Network Coverage in Thailand</h2>
  <p>
    AXA has a good network in Thailand, covering major private hospitals.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Coverage by Region</h3>
  <ul>
    <li><strong>Bangkok:</strong> Good coverage at top hospitals including Bumrungrad International</li>
    <li><strong>Chiang Mai:</strong> Network hospitals serving the expat community</li>
    <li><strong>Beach destinations:</strong> Coverage in Phuket, Pattaya, Hua Hin</li>
    <li><strong>Smaller cities:</strong> May need to travel or use reimbursement</li>
  </ul>

  <h3>Thailand's Healthcare Quality</h3>
  <p>
    Thailand has 62+ JCI-accredited hospitals—more than any other Southeast Asian country. Bumrungrad International in Bangkok is world-renowned. You're getting excellent care regardless of insurer.
  </p>

  <h3>Finding Providers</h3>
  <p>
    Use AXA's MyHealth portal or app to find:
  </p>
  <ul>
    <li>Direct-billing hospitals</li>
    <li>English-speaking doctors</li>
    <li>Specialists in your area</li>
    <li>24-hour urgent care facilities</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    AXA offers four tiers. Excluding-USA plans are 15-25% cheaper than US-inclusive options.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Age 50 shown. Add 40-50% for US coverage.</em>
  </p>

  <h3>Plan Recommendations for Thailand</h3>
  <ul>
    <li><strong>Essential:</strong> Hospital-only. Budget option for healthy expats paying routine care out of pocket.</li>
    <li><strong>Comfort:</strong> Most practical. Includes outpatient, dental basics. Good balance.</li>
    <li><strong>Excellence:</strong> Comprehensive with mental health parity. Good for families.</li>
    <li><strong>Exclusive:</strong> Unlimited coverage. Maximum protection available.</li>
  </ul>

  <h3>Deductible Strategy</h3>
  <p>
    Thai healthcare is affordable:
  </p>
  <ul>
    <li>Doctor visit: $30-80</li>
    <li>Specialist: $50-150</li>
    <li>Lab work: $20-60</li>
  </ul>
  <p>
    A €1,000-2,500 deductible significantly reduces premiums. Pay routine care out of pocket and use AXA for hospitals.
  </p>

  <h2 id="eu-regulation">EU Insurer Benefits</h2>
  <p>
    AXA is headquartered in Paris, regulated under EU Solvency II rules. What does this mean for Thailand expats?
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-blue-900 mb-3">EU Regulatory Benefits</h3>
      <ul class="space-y-2 text-blue-800">
        <li>EU Solvency II consumer protections</li>
        <li>GDPR data protection</li>
        <li>Strong financial backing</li>
        <li>EU dispute resolution access</li>
        <li>Portable to EU countries</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Practical Benefits</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Euro or USD billing options</li>
        <li>French/English support</li>
        <li>European business hours</li>
        <li>No US coverage cost built in</li>
        <li>Portability if you relocate</li>
      </ul>
    </div>
  </div>

  <h3>For Non-US Expats</h3>
  <p>
    If you're European, Australian, Canadian, or from another country, AXA offers competitive pricing without paying for US networks you'll never use. US expats might prefer Aetna or GeoBlue for integrated US coverage.
  </p>

  <CTABox
    title="Lower Premiums Without US Coverage"
    description="If you don't need US coverage, AXA offers competitive pricing."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
  />

  <h2 id="vs-local-options">vs Thai Insurers</h2>
  <p>
    How does AXA Global compare to Thai insurers like Pacific Cross or AXA Thailand?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Key Differences</h3>
  <p>
    <strong>TGIA approval:</strong> Thai insurers are reliably TGIA-approved. AXA Global's status may vary—verify before visa applications.
  </p>
  <p>
    <strong>Worldwide coverage:</strong> AXA Global covers you worldwide. Thai insurers typically only cover Thailand.
  </p>
  <p>
    <strong>Portability:</strong> If you leave Thailand, AXA Global continues. Thai insurance must be cancelled.
  </p>
  <p>
    <strong>Price:</strong> Thai insurers cost 30-40% less for Thailand-only coverage.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>European expats in Thailand</li>
        <li>Non-Americans who don't need US coverage</li>
        <li>Those who travel outside Thailand</li>
        <li>Expats who might relocate</li>
        <li>French speakers</li>
        <li>Non-O visa holders (no TGIA needed)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>O-A/O-X applicants (TGIA uncertain)</li>
        <li>US expats wanting US coverage</li>
        <li>Budget-focused (Thai insurers cheaper)</li>
        <li>Those staying in Thailand permanently</li>
        <li>Age 75+ (limited acceptance)</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is AXA Global TGIA-approved for Thai visas?</h3>
  <p>
    TGIA approval varies. <strong>Always verify at longstay.tgia.org</strong>. Note that AXA Thailand (the local subsidiary) is typically TGIA-approved, while AXA Global Healthcare (international product) may not be.
  </p>

  <h3>What's the difference between AXA Global and AXA Thailand?</h3>
  <p>
    AXA Global Healthcare is the international product for expats—EU-regulated, worldwide coverage, portable. AXA Thailand is the local Thai insurer—TGIA-approved, Thailand-only coverage, lower premiums. Choose based on your needs.
  </p>

  <h3>Can I get AXA Global at age 70+?</h3>
  <p>
    AXA Global accepts new applicants up to age 74. If you're older, consider Pacific Cross which accepts up to age 80.
  </p>

  <h3>Should I use AXA Global or a Thai insurer?</h3>
  <p>
    For O-A/O-X visas, a Thai insurer guarantees TGIA approval. For Non-O visa holders, worldwide travelers, or those who might relocate, AXA Global offers better portability.
  </p>

  <h3>Does AXA offer US coverage for Thailand expats?</h3>
  <p>
    Yes, but it adds 40-50% to premiums. If you need US coverage, Aetna or GeoBlue are often better value—US coverage is integrated in their base price.
  </p>

  <CTABox
    title="Ready for International Coverage?"
    description="Get a personalized AXA Global quote for Thailand."
    buttonText="Get Your Quote"
    buttonHref="/providers/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. TGIA approval status and visa requirements change. Always verify at longstay.tgia.org before visa applications. We are not insurance brokers or immigration consultants.
    </p>
  </div>
</PageShell>
