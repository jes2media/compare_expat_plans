---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Thailand', level: 2 },
  { id: 'visa-compliance', text: 'Thai Visa Compliance', level: 2 },
  { id: 'thailand-network', text: 'Network Coverage in Thailand', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Thai Insurers', level: 2 },
  { id: 'claims-in-thailand', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Thailand', href: '/countries/thailand/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'thailandPrice', header: 'Thailand (Age 50)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Global Medical Insurance', coverage: 'Inpatient + Outpatient', thailandPrice: '$85-120/mo', visaCompliant: 'Verify TGIA' },
  { plan: 'With $2,500 Deductible', coverage: 'Inpatient + Outpatient', thailandPrice: '$60-85/mo', visaCompliant: 'Verify TGIA' },
  { plan: 'With $5,000 Deductible', coverage: 'Inpatient + Outpatient', thailandPrice: '$50-70/mo', visaCompliant: 'Verify TGIA' },
  { plan: 'With $10,000 Deductible', coverage: 'Inpatient + Outpatient', thailandPrice: '$40-55/mo', visaCompliant: 'Verify TGIA' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'img', header: 'IMG Global' },
  { key: 'thai', header: 'Thai Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', img: '$85-120', thai: '$60-150' },
  { factor: 'With High Deductible', img: '$40-70', thai: 'Limited options' },
  { factor: 'Network in Thailand', img: 'Smaller (reimbursement)', thai: 'Excellent' },
  { factor: 'Annual Maximum', img: 'Up to $8M', thai: 'Varies (often lower)' },
  { factor: 'Deductible Waiver', img: '50% outside US', thai: 'No' },
  { factor: 'Portability', img: 'Worldwide', thai: 'Thailand only' },
  { factor: 'Medical Evacuation', img: 'Up to $500K', thai: 'Usually not' },
  { factor: 'TGIA Approved', img: 'Verify', thai: 'Yes' },
];

const savingsColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'img', header: 'IMG Global' },
  { key: 'premium', header: 'Premium Insurers' },
  { key: 'savings', header: 'Annual Savings' },
];

const savingsRows = [
  { coverage: 'Standard deductible', img: '$1,020-1,440/yr', premium: '$2,160-2,880/yr', savings: '$1,140-1,440' },
  { coverage: '$2,500 deductible', img: '$720-1,020/yr', premium: '$1,560-2,160/yr', savings: '$840-1,140' },
  { coverage: '$5,000 deductible', img: '$600-840/yr', premium: 'Limited options', savings: '$700+' },
];
---

<PageShell
  title="IMG Global Health Insurance in Thailand"
  description="Complete guide to using IMG Global in Thailand. Budget-friendly international coverage with the 50% deductible waiver advantage."
  headline="IMG Global Health Insurance in Thailand"
  subheadline="Budget-friendly international coverage for expats in Thailand. How IMG's 50% deductible waiver works in practice."
  heroBackgroundImage="/images/countries/thailand-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Thailand Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Thailand</h2>
  <p>
    IMG Global offers a budget-friendly path to international health insurance for expats in Thailand. Their high-deductible options and 50% deductible waiver make them one of the most affordable international options available.
  </p>
  <p>
    Given Thailand's affordable healthcare, IMG's high-deductible strategy works especially well here. Pay routine care out of pocket (doctor visits $30-80), and let insurance cover what matters: hospitalization, surgery, major illness.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$8M</p>
      <p class="text-sm text-neutral-600">Max annual limit</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">50%</p>
      <p class="text-sm text-neutral-600">Deductible waiver outside US</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$500K</p>
      <p class="text-sm text-neutral-600">Medical evacuation</p>
    </div>
  </div>

  <CTABox
    title="Get a Thailand-Specific Quote"
    description="See what IMG Global costs for expats living in Thailand."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="visa-compliance">Thai Visa Compliance</h2>
  <p>
    Thailand requires TGIA-approved insurance for O-A, O-X, and LTR visas. IMG Global is less commonly used for Thai visas than local insurers.
  </p>

  <h3>Visa Requirements</h3>
  <ul>
    <li><strong>O-A/O-X:</strong> 400,000 THB inpatient + 40,000 THB outpatient, or $100,000 total</li>
    <li><strong>LTR:</strong> $50,000 USD minimum</li>
    <li>Must be TGIA-approved</li>
  </ul>

  <p>
    IMG Global's coverage limits exceed these minimums, but TGIA approval status must be verified.
  </p>

  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-yellow-900 mb-2">TGIA Approval Warning</h3>
    <p class="text-yellow-800">
      IMG Global is less commonly used for Thai visas. If you need guaranteed TGIA approval, consider Pacific Cross or AXA Thailand for your visa application. You can use IMG Global alongside or after obtaining your visa for additional worldwide coverage.
    </p>
  </div>

  <h3>Non-O Visa (No Requirement)</h3>
  <p>
    If you're extending a Non-Immigrant O visa, insurance is not mandatory. IMG Global works well as affordable international coverage in this case.
  </p>

  <h2 id="thailand-network">Network Coverage in Thailand</h2>
  <p>
    IMG has a smaller direct network in Thailand compared to local insurers. Most expats use the reimbursement model: pay providers directly, then submit claims.
  </p>

  <h3>How It Works in Practice</h3>
  <ul>
    <li><strong>Any licensed provider:</strong> See any doctor or hospital in Thailand</li>
    <li><strong>Pay at time of service:</strong> Pay with card or cash</li>
    <li><strong>Submit for reimbursement:</strong> Upload receipt via IMG app</li>
    <li><strong>Fast processing:</strong> Typical reimbursement in 5-10 business days</li>
  </ul>

  <p>
    This works well in Thailand because:
  </p>
  <ul>
    <li>Healthcare costs are affordable ($30-150 for most visits)</li>
    <li>Thai hospitals provide detailed receipts</li>
    <li>Complete freedom of provider choice</li>
    <li>No network restrictions at Bumrungrad, Bangkok Hospital, etc.</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    IMG Global offers Global Medical Insurance with flexible deductible options:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Age 50 shown as most Thailand expats are retirees.</em>
  </p>

  <h3>The 50% Deductible Waiver</h3>
  <p>
    IMG's standout feature: treatment outside the US gets 50% off your deductible. In Thailand:
  </p>
  <ul>
    <li><strong>$5,000 deductible → $2,500 effective</strong> in Thailand</li>
    <li><strong>$2,500 deductible → $1,250 effective</strong> in Thailand</li>
    <li><strong>$10,000 deductible → $5,000 effective</strong> in Thailand</li>
  </ul>

  <h3>Savings Comparison</h3>
  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={savingsColumns} rows={savingsRows} />
  </div>

  <h3>Coverage Highlights</h3>
  <ul>
    <li><strong>Annual maximum:</strong> Up to $8M</li>
    <li><strong>Inpatient:</strong> Hospital, surgery, ICU fully covered</li>
    <li><strong>Outpatient:</strong> Doctor visits, labs, imaging</li>
    <li><strong>Emergency evacuation:</strong> Up to $500K</li>
    <li><strong>Mental health:</strong> Included (check limits)</li>
  </ul>

  <CTABox
    title="Calculate Your Savings"
    description="See how much you can save with IMG's high-deductible options."
    buttonText="Get a Quote"
    buttonHref="/providers/img-global"
  />

  <h2 id="vs-local-options">vs Thai Insurers</h2>
  <p>
    How does IMG Global compare to Thai insurers like Pacific Cross or AXA Thailand?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose IMG Global If:</h3>
  <ul>
    <li>Budget is a major consideration</li>
    <li>High-deductible strategy appeals to you</li>
    <li>You don't need TGIA approval (Non-O visa or after initial visa)</li>
    <li>You travel outside Thailand frequently</li>
    <li>Medical evacuation is important</li>
    <li>Maximum coverage limits matter ($8M)</li>
  </ul>

  <h3>Choose a Thai Insurer If:</h3>
  <ul>
    <li>TGIA approval is essential (O-A/O-X visa)</li>
    <li>You want direct billing at local hospitals</li>
    <li>You're staying in Thailand permanently</li>
    <li>You're over 70 (Pacific Cross accepts to age 80)</li>
  </ul>

  <p>
    <a href="/countries/thailand/insurance">See all Thailand insurance options →</a>
  </p>

  <h2 id="claims-in-thailand">Using Your Insurance in Thailand</h2>

  <h3>Reimbursement Process</h3>
  <ol class="list-decimal list-inside space-y-2">
    <li>See any licensed provider in Thailand</li>
    <li>Pay at time of service (get itemized receipt)</li>
    <li>Submit claim via IMG app or portal</li>
    <li>Processing typically 5-10 business days</li>
    <li>Reimbursement to your bank account</li>
  </ol>

  <h3>Documentation Tips</h3>
  <ul>
    <li>Thai hospital receipts are accepted</li>
    <li>Keep itemized bills showing procedures and costs</li>
    <li>Submit promptly (within 90 days)</li>
  </ul>

  <h3>Medical Evacuation</h3>
  <p>
    IMG includes up to $500K medical evacuation — critical if you live outside Bangkok and might need transport to a major hospital or evacuation to another country.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in Thailand</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals with high-deductible tolerance</li>
        <li>Those on Non-O visas (no TGIA needed)</li>
        <li>Expats who travel frequently</li>
        <li>Those wanting maximum coverage limits</li>
        <li>People comfortable with reimbursement</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing TGIA approval</li>
        <li>Expats wanting direct billing</li>
        <li>Those with pre-existing conditions</li>
        <li>People preferring established Thai insurers</li>
        <li>Those needing extensive mental health</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is IMG Global TGIA-approved?</h3>
  <p>
    IMG Global is less commonly used for Thai visas. Verify at <strong>longstay.tgia.org</strong>. If not approved, consider Pacific Cross or AXA Thailand for visa applications, and IMG for additional worldwide coverage.
  </p>

  <h3>How does the 50% deductible waiver work?</h3>
  <p>
    Treatment outside the US automatically gets 50% off your deductible. A $5,000 deductible becomes $2,500 in Thailand. No request needed — it's automatic.
  </p>

  <h3>What if I need hospitalization in Thailand?</h3>
  <p>
    Go to any hospital. Contact IMG's assistance line for help coordinating with the hospital and arranging direct payment for large expenses.
  </p>

  <h3>Does IMG cover pre-existing conditions?</h3>
  <p>
    IMG typically excludes pre-existing conditions or applies waiting periods. If you have significant health conditions, consider BUPA Global or Pacific Cross.
  </p>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for your situation in Thailand."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements and TGIA approval status change. Verify at longstay.tgia.org before applying.
    </p>
  </div>
</PageShell>
