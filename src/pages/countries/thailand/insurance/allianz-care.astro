---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Thailand', level: 2 },
  { id: 'visa-compliance', text: 'Thai Visa Compliance', level: 2 },
  { id: 'thailand-network', text: 'Network Coverage in Thailand', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Thai Insurers', level: 2 },
  { id: 'claims-in-thailand', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Thailand', href: '/countries/thailand/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'thailandPrice', header: 'Thailand (Age 50)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Emergency', thailandPrice: '$80-110/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Classic', coverage: 'Essential + Outpatient', thailandPrice: '$130-170/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Premium', coverage: 'Comprehensive', thailandPrice: '$170-220/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Platinum', coverage: 'Premium + Enhanced', thailandPrice: '$210-280/mo', visaCompliant: 'Check TGIA' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'thai', header: 'Thai Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', allianz: '$130-170', thai: '$60-150' },
  { factor: 'With High Deductible', allianz: '$55-90', thai: 'Limited options' },
  { factor: 'Coverage Outside Thailand', allianz: 'Worldwide', thai: 'Limited/None' },
  { factor: 'Network in Thailand', allianz: 'Good', thai: 'Excellent' },
  { factor: 'Deductible Savings', allianz: 'Up to 60%', thai: 'Limited' },
  { factor: 'Portability', allianz: 'Worldwide', thai: 'Thailand only' },
  { factor: 'TGIA Approved', allianz: 'Verify', thai: 'Yes' },
  { factor: 'Mental Health', allianz: 'Good coverage', thai: 'Often limited' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Bangkok', hospitals: 'Bumrungrad International, Bangkok Hospital, BNH Hospital', directBilling: true },
  { city: 'Chiang Mai', hospitals: 'Bangkok Hospital Chiang Mai, Lanna Hospital', directBilling: true },
  { city: 'Phuket', hospitals: 'Bangkok Hospital Phuket, Mission Hospital Phuket', directBilling: true },
  { city: 'Pattaya', hospitals: 'Bangkok Hospital Pattaya, Pattaya Memorial Hospital', directBilling: true },
  { city: 'Koh Samui', hospitals: 'Bangkok Hospital Samui', directBilling: true },
];
---

<PageShell
  title="Allianz Care Health Insurance in Thailand"
  description="Complete guide to using Allianz Care in Thailand. High-deductible savings, visa compliance, and comparison to Thai insurers."
  headline="Allianz Care Health Insurance in Thailand"
  subheadline="Is Allianz Care the right choice for expats in Thailand? High-deductible savings, worldwide coverage, and Thai network access."
  heroBackgroundImage="/images/countries/thailand-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Thailand Quote"
  ctaButtonHref="/providers/allianz-care"
>
  <h2 id="overview">Allianz Care in Thailand</h2>
  <p>
    Allianz Care offers international coverage for expats in Thailand with a standout feature: high-deductible options that can cut premiums by up to 60%. Given Thailand's affordable healthcare, this strategy works especially well here.
  </p>
  <p>
    As a German company with global reach, Allianz provides solid worldwide coverage that's fully portable if you relocate from Thailand.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">2M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">60%</p>
      <p class="text-sm text-neutral-600">Max deductible savings</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">$5M</p>
      <p class="text-sm text-neutral-600">Annual limit available</p>
    </div>
  </div>

  <CTABox
    title="Get a Thailand-Specific Quote"
    description="See what Allianz Care costs with different deductible options."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <h2 id="visa-compliance">Thai Visa Compliance</h2>
  <p>
    Thailand requires TGIA-approved insurance for O-A, O-X, and LTR visas. Allianz Care may meet these requirements, but verification is essential.
  </p>

  <h3>O-A and O-X Visa Requirements</h3>
  <ul>
    <li>400,000 THB (~$11,500) inpatient + 40,000 THB (~$1,150) outpatient, OR</li>
    <li>$100,000 USD / 3,000,000 THB total medical coverage</li>
    <li>Must be from a TGIA-approved insurer</li>
  </ul>

  <h3>LTR Visa Requirements</h3>
  <p>
    The LTR visa requires $50,000 USD minimum coverage. Allianz Care plans easily exceed this.
  </p>

  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-yellow-900 mb-2">Verify TGIA Approval</h3>
    <p class="text-yellow-800">
      Always verify insurer status at <strong>longstay.tgia.org</strong> before applying. International insurers' approval can change. If Allianz Care isn't currently TGIA-approved, consider Pacific Cross or AXA Thailand for visa applications, then switch to Allianz Care after.
    </p>
  </div>

  <h2 id="thailand-network">Network Coverage in Thailand</h2>
  <p>
    Allianz Care has a good network in Thailand, with direct billing at major private hospitals.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Network Strengths</h3>
  <ul>
    <li><strong>Bangkok:</strong> Coverage at top hospitals including Bumrungrad</li>
    <li><strong>Major expat destinations:</strong> Network in Chiang Mai, Phuket, Pattaya</li>
    <li><strong>Islands:</strong> Coverage on Koh Samui through Bangkok Hospital Samui</li>
    <li><strong>Flexibility:</strong> Use any licensed provider and submit for reimbursement</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    Allianz Care offers four plan tiers with significant price variation based on deductible:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Higher deductibles reduce premiums by 40-60%.</em>
  </p>

  <h3>The High-Deductible Strategy in Thailand</h3>
  <p>
    Allianz's deductible options go up to $5,000, which can cut premiums by 50-60%. In Thailand, this makes excellent sense:
  </p>
  <ul>
    <li>Doctor visit: $30-80</li>
    <li>Specialist: $50-150</li>
    <li>Lab work: $20-60</li>
    <li>Dental cleaning: $30-50</li>
  </ul>
  <p>
    Many Thailand expats choose inpatient-only plans or high deductibles, paying routine care out of pocket.
  </p>

  <h3>Which Plan for Thailand?</h3>
  <ul>
    <li><strong>Essential:</strong> Hospital and emergency only. Pair with high deductible for minimum cost.</li>
    <li><strong>Classic:</strong> Adds outpatient. Balanced choice for most expats.</li>
    <li><strong>Premium:</strong> Enhanced benefits including better mental health.</li>
    <li><strong>Platinum:</strong> Maximum coverage for those wanting the best.</li>
  </ul>

  <CTABox
    title="Calculate Your Savings"
    description="See how different deductible options affect your premium."
    buttonText="Get a Quote"
    buttonHref="/providers/allianz-care"
  />

  <h2 id="vs-local-options">vs Thai Insurers</h2>
  <p>
    How does Allianz Care compare to Thai insurers like Pacific Cross or AXA Thailand?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose Allianz Care If:</h3>
  <ul>
    <li>You want high-deductible premium savings</li>
    <li>You travel outside Thailand frequently</li>
    <li>Worldwide portability matters</li>
    <li>Mental health coverage is important</li>
    <li>You may relocate from Thailand</li>
  </ul>

  <h3>Choose a Thai Insurer If:</h3>
  <ul>
    <li>TGIA approval is essential (O-A/O-X visa)</li>
    <li>Budget is the primary concern</li>
    <li>You're staying in Thailand permanently</li>
    <li>You're over 70 (higher age limits)</li>
  </ul>

  <p>
    <a href="/countries/thailand/insurance">See all Thailand insurance options →</a>
  </p>

  <h2 id="claims-in-thailand">Using Your Insurance in Thailand</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, show your Allianz card for cashless treatment. Major Bangkok hospitals are experienced with international insurers.
  </p>

  <h3>Reimbursement</h3>
  <p>
    For non-network providers:
  </p>
  <ol class="list-decimal list-inside space-y-2">
    <li>Pay the provider (get itemized receipt)</li>
    <li>Submit via MyHealth app or portal</li>
    <li>Typical processing: 5 business days</li>
    <li>Reimbursement to your bank account</li>
  </ol>

  <h3>MyHealth App</h3>
  <p>
    Allianz's app lets you find providers, submit claims, track status, and access your digital card.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Thailand</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious (high-deductible strategy)</li>
        <li>Expats who travel frequently</li>
        <li>Those who value flexibility</li>
        <li>People who might relocate</li>
        <li>EU expats (EU-regulated insurer)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing guaranteed TGIA approval</li>
        <li>Expats over 70</li>
        <li>Those staying in Thailand permanently</li>
        <li>People preferring Thai-based insurers</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is Allianz Care different from Allianz Ayudhya?</h3>
  <p>
    Yes. Allianz Ayudhya is the Thai domestic insurer (formerly Bupa/Aetna Thailand). Allianz Care is the international division. They're separate products with different coverage, networks, and pricing.
  </p>

  <h3>How does the high-deductible option work?</h3>
  <p>
    Choose a deductible ($500-$5,000) when purchasing. You pay costs up to that amount each year. After reaching your deductible, Allianz covers the rest. Higher deductible = lower premium.
  </p>

  <h3>What if I move from Thailand?</h3>
  <p>
    Your Allianz Care coverage continues unchanged. Simply update your residence. No new underwriting required.
  </p>

  <CTABox
    title="Ready for Coverage in Thailand?"
    description="Get a personalized Allianz Care quote with deductible options."
    buttonText="Get Your Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements and TGIA approval status change. Verify at longstay.tgia.org before applying.
    </p>
  </div>
</PageShell>
