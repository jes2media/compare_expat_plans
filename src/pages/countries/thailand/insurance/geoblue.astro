---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'GeoBlue in Thailand', level: 2 },
  { id: 'visa-compliance', text: 'Thai Visa Compliance', level: 2 },
  { id: 'thailand-network', text: 'Network Coverage in Thailand', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'blue-cross-advantage', text: 'Blue Cross Advantage', level: 2 },
  { id: 'vs-local-options', text: 'vs Thai Insurers', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose GeoBlue', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Thailand', href: '/countries/thailand/insurance' },
  { title: 'GeoBlue Review', href: '/providers/geoblue' },
  { title: 'GeoBlue vs Aetna', href: '/compare/aetna-international-vs-geoblue' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'thailandPrice', header: 'Thailand (Age 50)' },
  { key: 'usIncluded', header: 'US Coverage' },
];

const planRows = [
  { plan: 'Voyager Essential', coverage: 'Inpatient + Emergency', thailandPrice: '$180-240/mo', usIncluded: 'Full BCBS' },
  { plan: 'Voyager Choice', coverage: 'Essential + Outpatient', thailandPrice: '$240-320/mo', usIncluded: 'Full BCBS' },
  { plan: 'Voyager Excel', coverage: 'Comprehensive + Maternity', thailandPrice: '$320-420/mo', usIncluded: 'Full BCBS' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'thai', header: 'Thai Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', geoblue: '$240-320', thai: '$60-150' },
  { factor: 'US Coverage', geoblue: '96% of US hospitals (BCBS)', thai: 'Not available' },
  { factor: 'Network in Thailand', geoblue: 'Good', thai: 'Excellent' },
  { factor: 'TGIA Approved', geoblue: 'Verify', thai: 'Yes (most)' },
  { factor: 'Mobile App', geoblue: 'Excellent', thai: 'Varies' },
  { factor: 'Portability', geoblue: 'Worldwide', thai: 'Thailand only' },
  { factor: 'Best For', geoblue: 'US expats wanting BCBS', thai: 'Long-term Thailand residents' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Bangkok', hospitals: 'Bumrungrad International, Bangkok Hospital, Samitivej', directBilling: true },
  { city: 'Chiang Mai', hospitals: 'Bangkok Hospital Chiang Mai, Rajavej Hospital', directBilling: true },
  { city: 'Phuket', hospitals: 'Bangkok Hospital Phuket, Phuket International Hospital', directBilling: true },
  { city: 'Pattaya', hospitals: 'Bangkok Hospital Pattaya, Pattaya International Hospital', directBilling: true },
  { city: 'Hua Hin', hospitals: 'Bangkok Hospital Hua Hin', directBilling: true },
];
---

<PageShell
  title="GeoBlue Health Insurance in Thailand"
  description="Guide to using GeoBlue in Thailand. Blue Cross Blue Shield network for US expats. Visa compliance, Thai network, and pricing details."
  headline="GeoBlue Health Insurance in Thailand"
  subheadline="Blue Cross Blue Shield's international arm. Keep your familiar US network while enjoying Thai healthcare."
  heroBackgroundImage="/images/countries/thailand-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Thailand Quote"
  ctaButtonHref="/go/geoblue"
>
  <h2 id="overview">GeoBlue in Thailand</h2>
  <p>
    GeoBlue is Blue Cross Blue Shield's international brand, designed specifically for Americans abroad. For US expats in Thailand—whether retirees in Chiang Mai or digital nomads in Bangkok—GeoBlue offers continuity with the US healthcare system they know.
  </p>
  <p>
    Thailand has excellent local healthcare and insurance options. Most expats don't need US coverage. But for Americans who visit the States regularly or want the security of Blue Cross access, GeoBlue provides something Thai insurers can't match.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">96%</p>
      <p class="text-sm text-neutral-600">US hospitals in network</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">International providers</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">190+</p>
      <p class="text-sm text-neutral-600">Countries covered</p>
    </div>
  </div>

  <CTABox
    title="Get a Thailand-Specific Quote"
    description="See what GeoBlue costs for Americans in Thailand."
    buttonText="Get Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <h2 id="visa-compliance">Thai Visa Compliance</h2>
  <p>
    Thailand requires approved insurance for O-A, O-X, and LTR visas. GeoBlue may meet coverage requirements, but TGIA approval status is uncertain for US-based insurers.
  </p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">Important: Verify TGIA Approval</h3>
    <p class="text-amber-800">
      GeoBlue is US-based and may not be on the TGIA approved list. <strong>Always verify at longstay.tgia.org</strong> before relying on any insurer for visa applications. If GeoBlue isn't approved, use a Thai insurer (Pacific Cross, AXA Thailand) for your visa, then add GeoBlue for US coverage if needed.
    </p>
  </div>

  <h3>O-A and O-X Visa Requirements</h3>
  <ul>
    <li>400,000 THB (~$11,500) inpatient + 40,000 THB (~$1,150) outpatient, OR</li>
    <li>$100,000 USD / 3,000,000 THB total medical coverage</li>
    <li>Must be from a TGIA-approved insurer</li>
  </ul>
  <p>
    GeoBlue Voyager Choice and Excel exceed these coverage levels if approved.
  </p>

  <h3>LTR Visa (Long-Term Resident)</h3>
  <p>
    Requires $50,000 USD minimum. GeoBlue plans easily exceed this. LTR visa acceptance of international insurers may be more flexible.
  </p>

  <h3>Non-O Visa (No Requirement)</h3>
  <p>
    If you're extending a Non-O visa, health insurance isn't mandatory. GeoBlue is an excellent choice for comprehensive coverage without TGIA constraints.
  </p>

  <h2 id="thailand-network">Network Coverage in Thailand</h2>
  <p>
    GeoBlue contracts with providers in 190+ countries. Their Thai network covers major private hospitals.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Coverage by Region</h3>
  <ul>
    <li><strong>Bangkok:</strong> Strong coverage including Bumrungrad International, Samitivej, Bangkok Hospital</li>
    <li><strong>Chiang Mai:</strong> Network hospitals serving the large American expat community</li>
    <li><strong>Beach destinations:</strong> Coverage in Phuket, Pattaya, Hua Hin</li>
    <li><strong>Smaller cities:</strong> Use any provider and claim reimbursement</li>
  </ul>

  <h3>GeoBlue Mobile App</h3>
  <p>
    GeoBlue's app is excellent for finding care in Thailand:
  </p>
  <ul>
    <li>GPS-based provider search</li>
    <li>Filter by specialty and language</li>
    <li>English-speaking doctor finder</li>
    <li>Digital insurance card</li>
    <li>Claims submission from your phone</li>
  </ul>

  <h3>Thailand's Healthcare Quality</h3>
  <p>
    Thailand has 62+ JCI-accredited hospitals—more than any other Southeast Asian country. Bumrungrad International serves patients from around the world. You're getting excellent care regardless of which insurer you choose.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    GeoBlue Voyager plans include US coverage—not an expensive add-on.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices include worldwide coverage with full Blue Cross US access. Age 50 shown.</em>
  </p>

  <h3>Plan Recommendations for Thailand</h3>
  <ul>
    <li><strong>Voyager Essential:</strong> Hospital-focused. Good for healthy expats paying routine care out of pocket (affordable in Thailand).</li>
    <li><strong>Voyager Choice:</strong> Most popular. Full inpatient + outpatient, meets typical visa requirements if approved.</li>
    <li><strong>Voyager Excel:</strong> Comprehensive including maternity. Best for families or those wanting maximum coverage.</li>
  </ul>

  <h3>Deductible Strategy</h3>
  <p>
    Thai healthcare is affordable:
  </p>
  <ul>
    <li>Doctor visit: $30-80</li>
    <li>Specialist: $50-150</li>
    <li>Lab work: $20-60</li>
  </ul>
  <p>
    A higher deductible ($2,000-5,000) significantly reduces premiums. Pay routine care out of pocket in Thailand, save insurance for hospitals and US care.
  </p>

  <h2 id="blue-cross-advantage">Blue Cross Advantage</h2>
  <p>
    The core reason to choose GeoBlue for Thailand:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-blue-900 mb-3">US Network Benefits</h3>
      <ul class="space-y-2 text-blue-800">
        <li>96% of US hospitals in network</li>
        <li>Blue Cross negotiated rates</li>
        <li>Direct billing—no claims</li>
        <li>Familiar BCBS network</li>
        <li>Keep relationships with US doctors</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Why It Matters in Thailand</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Medicare doesn't work abroad</li>
        <li>Visit family in the US? Covered.</li>
        <li>US specialists accessible</li>
        <li>Second opinions from US doctors</li>
        <li>Coverage if you repatriate</li>
      </ul>
    </div>
  </div>

  <h3>Medicare Replacement</h3>
  <p>
    US Medicare doesn't cover you in Thailand. For American retirees, GeoBlue replaces Medicare abroad while keeping Blue Cross access for US visits.
  </p>

  <CTABox
    title="Blue Cross Coverage in Thailand"
    description="Keep your familiar US network while living abroad."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
  />

  <h2 id="vs-local-options">vs Thai Insurers</h2>
  <p>
    How does GeoBlue compare to Thai insurers like Pacific Cross or AXA Thailand?
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Key Differences</h3>
  <p>
    <strong>US coverage:</strong> Thai insurers don't cover the US at all. If you visit America, you'd need separate travel insurance. GeoBlue provides seamless coverage in both countries.
  </p>
  <p>
    <strong>TGIA approval:</strong> Thai insurers are reliably TGIA-approved for visas. GeoBlue's status may vary—verify before visa applications.
  </p>
  <p>
    <strong>Price:</strong> Thai insurers cost 40-60% less. If you don't need US coverage, local options offer much better value.
  </p>

  <h2 id="who-its-for">Who Should Choose GeoBlue</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>US citizens in Thailand</li>
        <li>Those familiar with Blue Cross</li>
        <li>Expats who visit the US regularly</li>
        <li>People who want largest US network</li>
        <li>Those who might repatriate</li>
        <li>Non-O visa holders (no TGIA needed)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US citizens (can't purchase)</li>
        <li>O-A/O-X applicants (TGIA uncertain)</li>
        <li>Budget-focused (Thai insurers cheaper)</li>
        <li>Those who never visit the US</li>
        <li>Permanent Thailand residents</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Do I need to be a US citizen for GeoBlue?</h3>
  <p>
    Yes. GeoBlue requires US citizenship or permanent residency with US ties. It's designed specifically for Americans abroad.
  </p>

  <h3>Is GeoBlue TGIA-approved for Thai visas?</h3>
  <p>
    TGIA approval varies for international insurers. <strong>Always verify at longstay.tgia.org</strong> before your visa application. If uncertain, use a Thai insurer for the visa.
  </p>

  <h3>Does GeoBlue replace Medicare in Thailand?</h3>
  <p>
    GeoBlue provides coverage abroad that Medicare doesn't offer. It effectively serves as Medicare replacement for Thai care while providing Blue Cross access for US visits.
  </p>

  <h3>Should I use GeoBlue or a Thai insurer?</h3>
  <p>
    If you need US coverage and visit America regularly, choose GeoBlue. If you're staying in Thailand full-time, Thai insurers offer better value and guaranteed TGIA approval.
  </p>

  <h3>Can I have both Thai insurance and GeoBlue?</h3>
  <p>
    Yes. Some expats use TGIA-approved Thai insurance for visa compliance and GeoBlue for US trips and portability. This provides visa security plus Blue Cross access, though at higher total cost.
  </p>

  <CTABox
    title="Ready for Coverage in Thailand?"
    description="Get a personalized GeoBlue quote for your situation."
    buttonText="Get Your Quote"
    buttonHref="/go/geoblue"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. TGIA approval status and visa requirements change. Always verify at longstay.tgia.org before visa applications. We are not insurance brokers or immigration consultants.
    </p>
  </div>
</PageShell>
