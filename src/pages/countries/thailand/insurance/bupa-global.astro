---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Thailand', level: 2 },
  { id: 'visa-compliance', text: 'Thai Visa Compliance', level: 2 },
  { id: 'thailand-network', text: 'Network Coverage in Thailand', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'vs-local-options', text: 'vs Thai Insurers', level: 2 },
  { id: 'claims-in-thailand', text: 'Using Your Insurance', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Thailand', href: '/countries/thailand/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'thailandPrice', header: 'Thailand (Age 50)' },
  { key: 'visaCompliant', header: 'Visa Compliant' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Inpatient + Day-patient', thailandPrice: '$150-195/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Complete', coverage: 'Essentials + Outpatient', thailandPrice: '$215-280/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Premier', coverage: 'Complete + Dental/Vision', thailandPrice: '$295-385/mo', visaCompliant: 'Check TGIA' },
  { plan: 'Elite', coverage: 'Maximum coverage', thailandPrice: '$370-480/mo', visaCompliant: 'Check TGIA' },
];

const comparisonColumns = [
  { key: 'factor', header: 'Factor' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'thai', header: 'Thai Insurers' },
];

const comparisonRows = [
  { factor: 'Monthly Cost (Age 50)', bupa: '$215-280', thai: '$60-150' },
  { factor: 'Mental Health Parity', bupa: 'Full parity', thai: 'Often limited' },
  { factor: 'Pre-existing Conditions', bupa: 'Often covered', thai: 'Usually excluded' },
  { factor: 'Network in Thailand', bupa: 'Excellent', thai: 'Excellent' },
  { factor: 'No-Claims Discount', bupa: 'Up to 30%', thai: 'Rarely' },
  { factor: 'Portability', bupa: 'Worldwide', thai: 'Thailand only' },
  { factor: 'Dental Included', bupa: 'Premier+ plans', thai: 'Usually add-on' },
  { factor: 'TGIA Approved', bupa: 'Verify', thai: 'Yes' },
];

const hospitalColumns = [
  { key: 'city', header: 'City' },
  { key: 'hospitals', header: 'Major Network Hospitals' },
  { key: 'directBilling', header: 'Direct Billing' },
];

const hospitalRows = [
  { city: 'Bangkok', hospitals: 'Bumrungrad International, Bangkok Hospital, Samitivej Sukhumvit', directBilling: true },
  { city: 'Chiang Mai', hospitals: 'Bangkok Hospital Chiang Mai, Chiang Mai Ram Hospital', directBilling: true },
  { city: 'Phuket', hospitals: 'Bangkok Hospital Phuket, Siriroj Hospital', directBilling: true },
  { city: 'Pattaya', hospitals: 'Bangkok Hospital Pattaya, Pattaya International Hospital', directBilling: true },
  { city: 'Hua Hin', hospitals: 'Bangkok Hospital Hua Hin', directBilling: true },
];
---

<PageShell
  title="BUPA Global Health Insurance in Thailand"
  description="Complete guide to using BUPA Global in Thailand. Premium coverage with mental health parity, pre-existing condition handling, and Thai network access."
  headline="BUPA Global Health Insurance in Thailand"
  subheadline="Premium international coverage for expats in Thailand. Mental health parity, pre-existing conditions, and comprehensive benefits."
  heroBackgroundImage="/images/countries/thailand-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Thailand Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Thailand</h2>
  <p>
    BUPA Global is the premium choice for expats in Thailand who want comprehensive coverage without gaps. As a healthcare-focused company, BUPA offers better mental health coverage, more favorable handling of pre-existing conditions, and no-claims discounts that reward healthy living.
  </p>
  <p>
    The trade-off is price. BUPA Global typically costs 50-100% more than Thai insurers. For expats with health concerns, mental health needs, or who want peace of mind, that premium is often worth it.
  </p>

  <div class="grid md:grid-cols-3 gap-4 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">4.4/5</p>
      <p class="text-sm text-neutral-600">Trustpilot rating</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">1.7M+</p>
      <p class="text-sm text-neutral-600">Providers worldwide</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 text-center">
      <p class="text-2xl font-bold text-primary-600">75+</p>
      <p class="text-sm text-neutral-600">Years in healthcare</p>
    </div>
  </div>

  <CTABox
    title="Get a Thailand-Specific Quote"
    description="See what BUPA Global costs for expats living in Thailand."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="visa-compliance">Thai Visa Compliance</h2>
  <p>
    Thailand requires TGIA-approved insurance for O-A, O-X, and LTR visas. BUPA Global may meet these requirements, but verification is essential.
  </p>

  <h3>Visa Requirements</h3>
  <ul>
    <li><strong>O-A/O-X:</strong> 400,000 THB inpatient + 40,000 THB outpatient, or $100,000 total</li>
    <li><strong>LTR:</strong> $50,000 USD minimum</li>
    <li>Must be TGIA-approved</li>
  </ul>

  <p>
    BUPA Global Complete, Premier, and Elite plans exceed these coverage minimums.
  </p>

  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-yellow-900 mb-2">Verify TGIA Approval</h3>
    <p class="text-yellow-800">
      Always verify insurer status at <strong>longstay.tgia.org</strong> before applying. If BUPA Global isn't currently TGIA-approved, consider Pacific Cross or AXA Thailand for visa applications, then add BUPA Global for comprehensive coverage.
    </p>
  </div>

  <h2 id="thailand-network">Network Coverage in Thailand</h2>
  <p>
    BUPA Global has an excellent network in Thailand, with direct billing at all major private hospitals.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={hospitalColumns} rows={hospitalRows} />
  </div>

  <h3>Notable Network Features</h3>
  <ul>
    <li><strong>Bangkok:</strong> Full coverage at Bumrungrad, Bangkok Hospital, Samitivej</li>
    <li><strong>All major cities:</strong> Network in Chiang Mai, Phuket, Pattaya, Hua Hin</li>
    <li><strong>Mental health facilities:</strong> Access to psychiatric care and therapy</li>
    <li><strong>JCI hospitals:</strong> Coverage at Thailand's 62+ JCI-accredited facilities</li>
  </ul>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>
  <p>
    BUPA Global offers four tiers for Thailand-based expats:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <p>
    <em>Prices for worldwide coverage excluding USA. Age 50 shown as most Thailand expats are retirees.</em>
  </p>

  <h3>What Makes BUPA Different</h3>
  <ul>
    <li><strong>Mental health parity:</strong> Same limits as physical health — rare in international insurance</li>
    <li><strong>Pre-existing conditions:</strong> Often covered from day one with full disclosure</li>
    <li><strong>No-claims discount:</strong> Up to 30% savings for healthy years</li>
    <li><strong>Dental/vision included:</strong> Premier and Elite plans include these</li>
  </ul>

  <h3>Which Plan for Thailand?</h3>
  <ul>
    <li><strong>Essentials:</strong> Inpatient only. For those wanting BUPA benefits at lower cost.</li>
    <li><strong>Complete:</strong> The practical choice. Full coverage with mental health parity.</li>
    <li><strong>Premier:</strong> Adds dental and vision. Great for families.</li>
    <li><strong>Elite:</strong> Maximum coverage for those wanting the best.</li>
  </ul>

  <CTABox
    title="Worth the Premium?"
    description="Get a personalized quote to see the actual cost difference."
    buttonText="Get a Quote"
    buttonHref="/providers/bupa-global"
  />

  <h2 id="vs-local-options">vs Thai Insurers</h2>
  <p>
    BUPA Global costs significantly more than Thai insurers. Here's what you get for the difference:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h3>Choose BUPA Global If:</h3>
  <ul>
    <li>Mental health coverage is essential</li>
    <li>You have pre-existing conditions others won't cover</li>
    <li>You want dental/vision included</li>
    <li>No-claims discounts appeal to you</li>
    <li>You may relocate from Thailand</li>
    <li>Premium comprehensive coverage matters</li>
  </ul>

  <h3>Choose a Thai Insurer If:</h3>
  <ul>
    <li>Budget is the primary concern</li>
    <li>You're healthy without pre-existing conditions</li>
    <li>Mental health coverage isn't a priority</li>
    <li>You're staying in Thailand permanently</li>
    <li>TGIA approval is essential (verify first)</li>
  </ul>

  <p>
    <a href="/countries/thailand/insurance">See all Thailand insurance options →</a>
  </p>

  <h2 id="claims-in-thailand">Using Your Insurance in Thailand</h2>

  <h3>Direct Billing</h3>
  <p>
    At network hospitals, present your BUPA card for cashless treatment. Thailand's major hospitals are experienced with BUPA.
  </p>

  <h3>MembersWorld Portal</h3>
  <p>
    BUPA's app and portal let you find providers, submit claims, track status, and access your digital card.
  </p>

  <h3>Claims Process</h3>
  <p>
    BUPA has a strong claims reputation (4.4/5 Trustpilot). Claims typically process within 5-7 business days.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in Thailand</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Ideal For</h3>
      <ul class="space-y-2 text-green-800">
        <li>Expats with pre-existing conditions</li>
        <li>Those needing mental health coverage</li>
        <li>Families wanting all-inclusive plans</li>
        <li>Retirees with complex health needs</li>
        <li>Those who value premium service</li>
        <li>Expats who may relocate</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Young, healthy individuals</li>
        <li>Those needing guaranteed TGIA approval</li>
        <li>Permanent Thailand residents</li>
        <li>Those comfortable with local insurers</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <h3>Is BUPA Global related to Bupa Thailand (now Allianz Ayudhya)?</h3>
  <p>
    Bupa Thailand was acquired by Aetna in 2017, then by Allianz Ayudhya in 2022. BUPA Global is a separate international product. They're not the same company or coverage.
  </p>

  <h3>Will BUPA cover my pre-existing condition?</h3>
  <p>
    Possibly. BUPA often covers pre-existing conditions from day one with full disclosure. You may get full coverage, coverage with limits, or a waiting period depending on the condition.
  </p>

  <h3>How does mental health parity work?</h3>
  <p>
    BUPA covers mental health at the same limits as physical health. If your plan has a $2M limit, that applies equally to psychiatric care and therapy.
  </p>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for your situation in Thailand."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements and TGIA approval status change. Verify at longstay.tgia.org before applying.
    </p>
  </div>
</PageShell>
