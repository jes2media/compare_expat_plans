---

<Layout title="Country Insurance Guides" description="Health insurance guides for expats by country. Learn about local requirements, healthcare systems, and plan options.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Country Insurance Guides
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          Find health insurance info for your destination. Learn about local requirements, healthcare systems, and recommended plans.
        </p>
        <CTAButton href="/countries/spain/insurance" size="lg">
          See Spain Guide
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={countries} title="Browse Countries" />
    </div>
  </section>
</Layout>
