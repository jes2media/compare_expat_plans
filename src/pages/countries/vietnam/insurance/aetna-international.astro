---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Aetna International in Vietnam', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Aetna', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Vietnam', href: '/countries/vietnam/insurance' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Aetna vs Cigna', href: '/compare/cigna-global-vs-aetna-international' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'vnPrice', header: 'Vietnam (Age 35)' },
];

const planRows = [
  { plan: 'Pioneer', coverage: 'Core coverage', vnPrice: '$130-175/mo' },
  { plan: 'Navigator', coverage: 'Enhanced', vnPrice: '$175-240/mo' },
  { plan: 'Voyager', coverage: 'Comprehensive', vnPrice: '$240-320/mo' },
];
---

<PageShell
  title="Aetna International Health Insurance in Vietnam"
  description="Guide to using Aetna International in Vietnam. Premium coverage with US network integration for American expats."
  headline="Aetna International Health Insurance in Vietnam"
  subheadline="Premium international coverage with seamless US network access for American expats."
  heroBackgroundImage="/images/countries/vietnam-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Aetna Vietnam Quote"
  ctaButtonHref="/go/aetna-international"
>
  <h2 id="overview">Aetna International in Vietnam</h2>
  <p>
    Aetna International is a strong choice for American expats in Vietnam who want seamless coverage both locally and when returning to the US. With access to Aetna's 1.7M+ US providers, it's ideal for maintaining ties to American healthcare.
  </p>
  <p>
    Vietnam has a growing American expat community, particularly in Ho Chi Minh City and Hanoi.
  </p>

  <CTABox
    title="Get a Vietnam-Specific Quote"
    description="See what Aetna International costs for expats in Vietnam."
    buttonText="Get Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>US Network Integration</h3>
  <p>
    If you're American and visit the US regularly, access to 1.7M+ US providers with direct billing is valuable.
  </p>

  <h2 id="who-its-for">Who Should Choose Aetna in Vietnam</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>American expats</li>
        <li>Those who return to US regularly</li>
        <li>Expats who want US network access</li>
        <li>Families with US healthcare ties</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Non-US expats</li>
        <li>Budget-conscious expats</li>
        <li>Digital nomads (SafetyWing)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for US-Integrated Coverage?"
    description="Get a personalized Aetna International quote for Vietnam."
    buttonText="Get Your Quote"
    buttonHref="/go/aetna-international"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with Aetna before purchasing.
    </p>
  </div>
</PageShell>
