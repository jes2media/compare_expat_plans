---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Vietnam', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Vietnam', href: '/countries/vietnam/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'vnPrice', header: 'Vietnam (Age 35)' },
];

const planRows = [
  { plan: 'Global Select', coverage: 'Core international', vnPrice: '$60-85/mo' },
  { plan: 'Global Premier', coverage: 'Enhanced benefits', vnPrice: '$85-120/mo' },
  { plan: 'Global Elite', coverage: 'Comprehensive', vnPrice: '$120-165/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Vietnam"
  description="Guide to using IMG Global in Vietnam. Budget-friendly international coverage with high-deductible options."
  headline="IMG Global Health Insurance in Vietnam"
  subheadline="Budget-friendly international coverage with flexible deductible options."
  heroBackgroundImage="/images/countries/vietnam-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Vietnam Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Vietnam</h2>
  <p>
    IMG Global offers budget-friendly international health insurance for Vietnam expats. Their high-deductible plans work particularly well in Vietnam where routine care is very affordable.
  </p>
  <p>
    For cost-conscious expats who want more coverage than SafetyWing but don't need premium options, IMG bridges the gap nicely.
  </p>

  <CTABox
    title="Get a Vietnam-Specific Quote"
    description="See what IMG Global costs for expats in Vietnam."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    IMG offers deductibles up to $25,000. In Vietnam, this makes sense:
  </p>
  <ul>
    <li>Pay routine care out of pocket (very cheap in Vietnam)</li>
    <li>Save significantly on premiums</li>
    <li>Keep catastrophic and evacuation coverage</li>
  </ul>

  <h3>50% Deductible Waiver</h3>
  <p>
    IMG waives 50% of your deductible for care outside the US. In Vietnam, this effectively cuts your out-of-pocket maximum in half.
  </p>

  <h2 id="who-its-for">Who Should Choose IMG in Vietnam</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals</li>
        <li>Those comfortable with high deductibles</li>
        <li>Step up from travel medical insurance</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing mental health coverage</li>
        <li>Expats with pre-existing conditions</li>
        <li>Short-term nomads (SafetyWing cheaper)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for Vietnam."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with IMG before purchasing.
    </p>
  </div>
</PageShell>
