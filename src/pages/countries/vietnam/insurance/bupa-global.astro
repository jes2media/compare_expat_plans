---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Vietnam', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Vietnam', href: '/countries/vietnam/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'vnPrice', header: 'Vietnam (Age 35)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Core inpatient', vnPrice: '$140-190/mo' },
  { plan: 'Select', coverage: 'Inpatient + Outpatient', vnPrice: '$190-260/mo' },
  { plan: 'Elite', coverage: 'Comprehensive', vnPrice: '$260-350/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Vietnam"
  description="Guide to using BUPA Global in Vietnam. Premium coverage with excellent mental health benefits."
  headline="BUPA Global Health Insurance in Vietnam"
  subheadline="Premium international coverage with industry-leading mental health benefits."
  heroBackgroundImage="/images/countries/vietnam-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Vietnam Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Vietnam</h2>
  <p>
    BUPA Global is the premium choice for Vietnam expats who want the best coverage available. They're known for excellent mental health benefits—increasingly important for expats dealing with isolation or adjustment challenges.
  </p>
  <p>
    BUPA's high limits and comprehensive coverage provide maximum protection, though premiums are higher than competitors.
  </p>

  <CTABox
    title="Get a Vietnam-Specific Quote"
    description="See what BUPA Global costs for expats in Vietnam."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    BUPA offers industry-leading mental health coverage with parity to physical health. This differentiator is valuable for expats in Vietnam.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in Vietnam</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those prioritizing mental health coverage</li>
        <li>Expats wanting premium service</li>
        <li>Families with complex health needs</li>
        <li>Those with pre-existing conditions</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Healthy digital nomads</li>
        <li>Those wanting lower premiums</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for Vietnam."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with BUPA before purchasing.
    </p>
  </div>
</PageShell>
