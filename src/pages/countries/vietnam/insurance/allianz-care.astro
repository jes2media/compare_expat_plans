---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Vietnam', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Vietnam', href: '/countries/vietnam/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'vnPrice', header: 'Vietnam (Age 35)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', vnPrice: '$80-110/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', vnPrice: '$110-150/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', vnPrice: '$160-220/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Vietnam"
  description="Guide to using Allianz Care in Vietnam. Modular international coverage with flexible options."
  headline="Allianz Care Health Insurance in Vietnam"
  subheadline="Flexible, modular international coverage for Vietnam expats at competitive prices."
  heroBackgroundImage="/images/countries/vietnam-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Vietnam Quote"
  ctaButtonHref="/go/allianz-care"
>
  <h2 id="overview">Allianz Care in Vietnam</h2>
  <p>
    Allianz Care offers modular international health insurance popular with Vietnam expats who want flexibility and value. You can customize coverage by selecting modules that match your needs.
  </p>
  <p>
    In Vietnam, where routine care is very affordable, Allianz's high-deductible options work well—save on premiums while keeping catastrophic coverage.
  </p>

  <CTABox
    title="Get a Vietnam-Specific Quote"
    description="See what Allianz Care costs for expats in Vietnam."
    buttonText="Get Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    Allianz offers deductibles up to €10,000. In Vietnam, where a GP visit costs $15-30, this can reduce premiums by 30-50% while keeping major expenses covered.
  </p>

  <h2 id="who-its-for">Who Should Choose Allianz in Vietnam</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Those who want customizable plans</li>
        <li>Expats comfortable with high deductibles</li>
        <li>Long-term residents wanting international coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>US expats needing US network access</li>
        <li>Short-term digital nomads (SafetyWing)</li>
        <li>Those preferring all-inclusive plans</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Flexible Coverage?"
    description="Get a personalized Allianz Care quote for Vietnam."
    buttonText="Get Your Quote"
    buttonHref="/go/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with Allianz before purchasing.
    </p>
  </div>
</PageShell>
