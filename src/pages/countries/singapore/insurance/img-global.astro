---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'IMG Global in Singapore', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose IMG', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Singapore', href: '/countries/singapore/insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'IMG vs Cigna', href: '/compare/img-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'sgPrice', header: 'Singapore (Age 40)' },
];

const planRows = [
  { plan: 'Global Select', coverage: 'Core international', sgPrice: '$100-140/mo' },
  { plan: 'Global Premier', coverage: 'Enhanced benefits', sgPrice: '$140-190/mo' },
  { plan: 'Global Elite', coverage: 'Comprehensive', sgPrice: '$190-260/mo' },
];
---

<PageShell
  title="IMG Global Health Insurance in Singapore"
  description="Guide to using IMG Global in Singapore. Budget-friendly international coverage with high-deductible options."
  headline="IMG Global Health Insurance in Singapore"
  subheadline="Budget-friendly international coverage with flexible deductible options."
  heroBackgroundImage="/images/countries/singapore-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an IMG Singapore Quote"
  ctaButtonHref="/providers/img-global"
>
  <h2 id="overview">IMG Global in Singapore</h2>
  <p>
    IMG Global offers budget-friendly international health insurance for Singapore expats. Their high-deductible options can significantly reduce premiums while still providing catastrophic coverage for Singapore's expensive healthcare.
  </p>
  <p>
    For cost-conscious expats who are healthy and want international coverage at a lower price point, IMG is worth considering.
  </p>

  <CTABox
    title="Get a Singapore-Specific Quote"
    description="See what IMG Global costs for expats living in Singapore."
    buttonText="Get Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Strategy</h3>
  <p>
    IMG offers deductibles up to $25,000. In Singapore, where even routine care is expensive, this approach works for those who:
  </p>
  <ul>
    <li>Are healthy and rarely use healthcare</li>
    <li>Want catastrophic coverage only</li>
    <li>Can afford to pay routine care out of pocket</li>
    <li>Prioritize low premiums</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose IMG in Singapore</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals</li>
        <li>Those comfortable with high deductibles</li>
        <li>Expats wanting basic international coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing mental health coverage</li>
        <li>Expats with pre-existing conditions</li>
        <li>Families with complex health needs</li>
        <li>Those wanting premium service</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Budget-Friendly Coverage?"
    description="Get a personalized IMG Global quote for Singapore."
    buttonText="Get Your Quote"
    buttonHref="/providers/img-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with IMG before purchasing.
    </p>
  </div>
</PageShell>
