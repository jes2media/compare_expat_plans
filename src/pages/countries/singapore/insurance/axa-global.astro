---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'AXA Global in Singapore', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose AXA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Singapore', href: '/countries/singapore/insurance' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'AXA vs Cigna', href: '/compare/axa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'sgPrice', header: 'Singapore (Age 40)' },
];

const planRows = [
  { plan: 'Comfort', coverage: 'Essential coverage', sgPrice: '$110-150/mo' },
  { plan: 'Standard', coverage: 'Standard + Outpatient', sgPrice: '$150-200/mo' },
  { plan: 'Comprehensive', coverage: 'Full coverage', sgPrice: '$210-280/mo' },
];
---

<PageShell
  title="AXA Global Health Insurance in Singapore"
  description="Guide to using AXA Global in Singapore. EU-regulated international coverage with competitive pricing."
  headline="AXA Global Health Insurance in Singapore"
  subheadline="EU-regulated international coverage with strong value and European heritage."
  heroBackgroundImage="/images/countries/singapore-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Singapore Quote"
  ctaButtonHref="/go/axa-global"
>
  <h2 id="overview">AXA Global in Singapore</h2>
  <p>
    AXA Global offers EU-regulated international health insurance with competitive pricing. For Singapore expats, AXA provides solid coverage at a lower price point than many competitors, with the security of EU regulatory protections.
  </p>
  <p>
    AXA has local presence in Singapore through AXA Insurance, making claims and support straightforward.
  </p>

  <CTABox
    title="Get a Singapore-Specific Quote"
    description="See what AXA Global costs for expats living in Singapore."
    buttonText="Get Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Value Proposition</h3>
  <p>
    AXA typically costs 20-30% less than premium competitors like BUPA while offering comparable core coverage. For value-conscious expats who want international coverage, AXA delivers.
  </p>

  <h2 id="who-its-for">Who Should Choose AXA in Singapore</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Those who travel to Europe/Asia</li>
        <li>Expats wanting EU regulatory protection</li>
        <li>Families seeking affordable international coverage</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing US network access</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those wanting premium service</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Value-Driven Coverage?"
    description="Get a personalized AXA Global quote for Singapore."
    buttonText="Get Your Quote"
    buttonHref="/go/axa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with AXA before purchasing.
    </p>
  </div>
</PageShell>
