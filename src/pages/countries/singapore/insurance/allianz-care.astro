---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Allianz Care in Singapore', level: 2 },
  { id: 'singapore-network', text: 'Network Coverage', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose Allianz', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Singapore', href: '/countries/singapore/insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Allianz vs Cigna', href: '/compare/cigna-global-vs-allianz-care' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'sgPrice', header: 'Singapore (Age 40)' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient core', sgPrice: '$110-150/mo' },
  { plan: 'Classic', coverage: 'Inpatient + Outpatient', sgPrice: '$160-220/mo' },
  { plan: 'Premium', coverage: 'Comprehensive', sgPrice: '$240-320/mo' },
];
---

<PageShell
  title="Allianz Care Health Insurance in Singapore"
  description="Guide to using Allianz Care in Singapore. Modular international coverage with competitive pricing."
  headline="Allianz Care Health Insurance in Singapore"
  subheadline="Flexible, modular international coverage for Singapore expats at competitive prices."
  heroBackgroundImage="/images/countries/singapore-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an Allianz Singapore Quote"
  ctaButtonHref="/providers/allianz-care"
>
  <h2 id="overview">Allianz Care in Singapore</h2>
  <p>
    Allianz Care offers modular international health insurance popular with Singapore expats who want flexibility and value. Their plans allow customization—you choose coverage modules that match your needs.
  </p>
  <p>
    In Singapore's expensive healthcare market, Allianz provides solid coverage at competitive prices compared to premium competitors.
  </p>

  <CTABox
    title="Get a Singapore-Specific Quote"
    description="See what Allianz Care costs for expats living in Singapore."
    buttonText="Get Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <h2 id="singapore-network">Network Coverage in Singapore</h2>
  <p>
    Allianz Care has a strong network in Singapore with direct billing at major private and restructured hospitals including Mount Elizabeth, Raffles Hospital, and Singapore General Hospital.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>High-Deductible Options</h3>
  <p>
    Allianz offers deductibles up to €10,000, which can reduce premiums significantly. Given Singapore's high costs, this works well for those wanting catastrophic coverage while paying smaller expenses out of pocket.
  </p>

  <h3>Modular Design</h3>
  <p>
    Build your plan by selecting:
  </p>
  <ul>
    <li>Core inpatient coverage</li>
    <li>Optional outpatient module</li>
    <li>Optional dental and vision</li>
    <li>Maternity add-on</li>
    <li>Coverage area (worldwide vs regional)</li>
  </ul>

  <h2 id="who-its-for">Who Should Choose Allianz in Singapore</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Value-conscious expats</li>
        <li>Those who want customizable plans</li>
        <li>Expats comfortable with high deductibles</li>
        <li>Those traveling within Europe and Asia</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Those needing US network access</li>
        <li>Expats prioritizing mental health coverage</li>
        <li>Those preferring all-inclusive plans</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Flexible Coverage?"
    description="Get a personalized Allianz Care quote for Singapore."
    buttonText="Get Your Quote"
    buttonHref="/providers/allianz-care"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with Allianz before purchasing.
    </p>
  </div>
</PageShell>
