---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'BUPA Global in Singapore', level: 2 },
  { id: 'singapore-network', text: 'Network Coverage', level: 2 },
  { id: 'plans-and-pricing', text: 'Plans and Pricing', level: 2 },
  { id: 'who-its-for', text: 'Who Should Choose BUPA', level: 2 },
];

const relatedLinks = [
  { title: 'Health Insurance in Singapore', href: '/countries/singapore/insurance' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'sgPrice', header: 'Singapore (Age 40)' },
];

const planRows = [
  { plan: 'Essentials', coverage: 'Core inpatient', sgPrice: '$200-270/mo' },
  { plan: 'Select', coverage: 'Inpatient + Outpatient', sgPrice: '$280-380/mo' },
  { plan: 'Elite', coverage: 'Comprehensive', sgPrice: '$380-520/mo' },
];
---

<PageShell
  title="BUPA Global Health Insurance in Singapore"
  description="Guide to using BUPA Global in Singapore. Premium coverage with excellent mental health benefits."
  headline="BUPA Global Health Insurance in Singapore"
  subheadline="Premium international coverage with industry-leading mental health benefits."
  heroBackgroundImage="/images/countries/singapore-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Singapore Quote"
  ctaButtonHref="/providers/bupa-global"
>
  <h2 id="overview">BUPA Global in Singapore</h2>
  <p>
    BUPA Global is the premium choice for Singapore expats who want the best coverage available. They're known for excellent mental health benefits, comprehensive coverage, and outstanding customer service.
  </p>
  <p>
    In Singapore's high-cost healthcare environment, BUPA's coverage limits of $2M to unlimited provide substantial protection.
  </p>

  <CTABox
    title="Get a Singapore-Specific Quote"
    description="See what BUPA Global costs for expats living in Singapore."
    buttonText="Get Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <h2 id="singapore-network">Network Coverage in Singapore</h2>
  <p>
    BUPA has extensive direct-billing relationships with Singapore's top hospitals including Mount Elizabeth, Raffles Hospital, Gleneagles, and major restructured hospitals.
  </p>

  <h2 id="plans-and-pricing">Plans and Pricing</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    BUPA Global offers industry-leading mental health coverage with parity to physical health. In Singapore, where mental health services are expensive and stigma is decreasing, this is increasingly valuable.
  </p>

  <h3>Pre-existing Conditions</h3>
  <p>
    BUPA offers full medical underwriting, which can mean better coverage for pre-existing conditions if you qualify.
  </p>

  <h2 id="who-its-for">Who Should Choose BUPA in Singapore</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Good Fit</h3>
      <ul class="space-y-2 text-green-800">
        <li>Those prioritizing mental health coverage</li>
        <li>Expats wanting premium service</li>
        <li>Families with complex health needs</li>
        <li>Those with pre-existing conditions</li>
        <li>Budget is not the primary concern</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives</h3>
      <ul class="space-y-2 text-neutral-600">
        <li>Budget-conscious expats</li>
        <li>Healthy individuals with basic needs</li>
        <li>Those satisfied with employer coverage</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Ready for Premium Coverage?"
    description="Get a personalized BUPA Global quote for Singapore."
    buttonText="Get Your Quote"
    buttonHref="/providers/bupa-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Verify coverage details directly with BUPA before purchasing.
    </p>
  </div>
</PageShell>
