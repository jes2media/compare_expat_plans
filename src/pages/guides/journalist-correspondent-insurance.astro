  { key: 'challenge', header: 'Freelance Challenge' },
  { key: 'impact', header: 'Impact' },
  { key: 'solutions', header: 'Solutions' },
];

const freelanceRows = [
  { challenge: 'No employer coverage', impact: 'Must arrange all coverage personally', solutions: 'Individual policies, journalist associations' },
  { challenge: 'Irregular income', impact: 'Premiums difficult during slow periods', solutions: 'Annual policies, budget during assignments' },
