---
/**
 * Problem/Solution Guide: Journalist and Correspondent Insurance
 *
 * Health insurance for journalists, war correspondents, and media professionals working internationally.
 */

import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const title = "Insurance for Journalists and Correspondents Abroad: Coverage for Media Professionals";
const description = "Journalists and correspondents working internationally face unique risks—conflict zones, civil unrest, and hostile environments. Learn how media professionals can secure appropriate health and security coverage while reporting abroad.";

const tocItems = [
