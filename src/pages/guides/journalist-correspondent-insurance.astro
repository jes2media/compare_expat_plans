  { id: "risk-levels", label: "Risk Level Coverage" },
  { id: "employer-coverage", label: "Employer Coverage" },
  { id: "freelance", label: "Freelance Journalists" },
  { id: "hostile-environment", label: "Hostile Environment" },
  { id: "kidnap-ransom", label: "K&R Coverage" },
  { id: "mental-health", label: "Trauma and Mental Health" },
  { id: "equipment", label: "Equipment Coverage" },
  { id: "faq", label: "FAQs" },
];

const riskColumns = [
  { key: 'assignment_type', header: 'Assignment Type' },
  { key: 'risk_level', header: 'Risk Level' },
  { key: 'coverage_needs', header: 'Coverage Needs' },
  { key: 'typical_exclusions', header: 'Watch For' },
];

const riskRows = [
  { assignment_type: 'Bureau-based correspondent', risk_level: 'Low-Moderate', coverage_needs: 'Standard international health', typical_exclusions: 'Usually straightforward' },
  { assignment_type: 'Travel/feature journalist', risk_level: 'Low-Moderate', coverage_needs: 'Travel + health coverage', typical_exclusions: 'Adventure activity exclusions' },
  { assignment_type: 'Investigative journalist', risk_level: 'Moderate-High', coverage_needs: 'Enhanced coverage, legal support', typical_exclusions: 'Hostile environment clauses' },
  { assignment_type: 'Protest/civil unrest coverage', risk_level: 'High', coverage_needs: 'Civil commotion coverage', typical_exclusions: 'War/terrorism exclusions may apply' },
  { assignment_type: 'Conflict zone correspondent', risk_level: 'Very High', coverage_needs: 'War zone coverage, evacuation, K&R', typical_exclusions: 'Standard policies exclude entirely' },
  { assignment_type: 'Embedded military journalist', risk_level: 'Very High', coverage_needs: 'Specialized hostile environment', typical_exclusions: 'Combat exclusions' },
];

const coverageColumns = [
  { key: 'coverage_type', header: 'Coverage Type' },
  { key: 'what_it_covers', header: 'What It Covers' },
  { key: 'who_provides', header: 'Who Provides It' },
  { key: 'cost_range', header: 'Typical Cost' },
];

const coverageRows = [
  { coverage_type: 'Standard international health', what_it_covers: 'Medical treatment, hospitalization', who_provides: 'International insurers', cost_range: '$2,000-8,000/year' },
  { coverage_type: 'Hostile environment add-on', what_it_covers: 'Coverage in conflict/high-risk areas', who_provides: 'Specialist insurers', cost_range: '$500-2,000+ per trip' },
  { coverage_type: 'War risk coverage', what_it_covers: 'Injuries in active conflict zones', who_provides: 'Lloyd\'s syndicates, specialists', cost_range: '$1,000-5,000+ per assignment' },
  { coverage_type: 'Kidnap & ransom (K&R)', what_it_covers: 'Ransom, crisis response, rehabilitation', who_provides: 'Specialist security insurers', cost_range: '$500-3,000/year' },
  { coverage_type: 'Medical evacuation (enhanced)', what_it_covers: 'Evacuation from hostile areas', who_provides: 'Security/evacuation companies', cost_range: 'Often bundled with other coverage' },
  { coverage_type: 'Accidental death & dismemberment', what_it_covers: 'Lump sum for death/serious injury', who_provides: 'Most insurers', cost_range: '$200-1,000/year' },
