const airlineRows = [
  { equipment: 'CPAP machine', carry_on: 'Yes, doesn\'t count toward limit', advance_notice: 'Recommended, not required', documentation: 'Medical necessity letter helpful' },
  { equipment: 'Insulin pump (worn)', carry_on: 'Yes, can remain on body', advance_notice: 'No', documentation: 'Medical ID recommended' },
  { equipment: 'Portable oxygen concentrator', carry_on: 'Yes, FAA-approved units only', advance_notice: 'Required (48-72 hours)', documentation: 'Physician statement, device approval letter' },
  { equipment: 'Syringes/needles', carry_on: 'Yes, with medication', advance_notice: 'No', documentation: 'Prescription label, medical letter' },
