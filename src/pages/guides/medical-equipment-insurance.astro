  { equipment: 'Home dialysis equipment', travel_complexity: 'High - supplies bulky, advance planning', supply_needs: 'Dialysate, supplies', coverage_considerations: 'Clinic vs. home dialysis abroad' },
  { equipment: 'Feeding tubes/pumps', travel_complexity: 'Moderate - supplies needed', supply_needs: 'Formula, tubes, extension sets', coverage_considerations: 'Enteral nutrition coverage varies' },
  { equipment: 'Mobility devices', travel_complexity: 'Varies by device', supply_needs: 'Batteries, maintenance parts', coverage_considerations: 'Repair coverage abroad' },
