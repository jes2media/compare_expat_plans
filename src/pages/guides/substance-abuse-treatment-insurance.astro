const title = "Insurance for Substance Abuse Treatment Abroad: Addiction Recovery Coverage for Expats";
const description = "Substance abuse treatment is essential healthcare, but coverage varies dramatically. Learn how expats can access addiction treatment, navigate insurance coverage for rehabilitation, and find support for recovery while living internationally.";

const tocItems = [
  { id: "overview", label: "The Coverage Challenge" },
  { id: "treatment-types", label: "Types of Treatment" },
  { id: "insurance-coverage", label: "Insurance Coverage" },
  { id: "finding-treatment", label: "Finding Treatment Abroad" },
  { id: "confidentiality", label: "Confidentiality Concerns" },
  { id: "returning-home", label: "Treatment at Home" },
  { id: "ongoing-recovery", label: "Ongoing Recovery" },
