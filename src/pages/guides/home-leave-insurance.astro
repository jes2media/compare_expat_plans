/**
 * Problem/Solution Guide: Home Leave and Insurance
 *
 * What happens to your international health insurance when you return to your home country temporarily.
 */

import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const title = "Home Leave and Insurance: Coverage When You Return Temporarily";
const description = "How international health insurance works during home leave. Coverage in your home country, duration limits, using your policy vs local options, and planning visits back home.";

const tocItems = [
  { id: "overview", label: "Home Leave Basics" },
  { id: "coverage-types", label: "How Policies Handle Home Leave" },
  { id: "duration-limits", label: "Duration Limits" },
  { id: "using-coverage", label: "Using Your Coverage" },
  { id: "us-expats", label: "US Expats" },
  { id: "planning", label: "Planning Home Visits" },
  { id: "extended-stays", label: "Extended Stays" },
  { id: "returning-permanently", label: "Returning Permanently" },
  { id: "faq", label: "FAQs" },
];

const coverageColumns = [
  { key: 'policy_type', header: 'Policy Type' },
  { key: 'home_country_coverage', header: 'Home Country Coverage' },
  { key: 'typical_limits', header: 'Typical Limits' },
];

const coverageRows = [
  { policy_type: 'Travel medical insurance', home_country_coverage: 'None - excluded', typical_limits: 'No home country coverage' },
  { policy_type: 'Basic international health', home_country_coverage: 'Emergency only', typical_limits: '30-90 days per year' },
  { policy_type: 'Comprehensive international', home_country_coverage: 'Full coverage', typical_limits: '90-180 days per year' },
  { policy_type: 'Premium global plans', home_country_coverage: 'Full worldwide', typical_limits: 'Often unlimited' },
  { policy_type: 'US-included plans', home_country_coverage: 'Full US coverage', typical_limits: 'Higher premiums but unlimited' },
