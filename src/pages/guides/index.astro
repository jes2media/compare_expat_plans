---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ContentCards from '../../components/ContentCards.astro';

const guides = [
  {
    title: 'International vs Travel Insurance',
    description: 'Understand the key differences and when you need each type.',
    href: '/guides/international-health-insurance-vs-travel',
    image: '/images/guides/international-vs-travel.png',
  },
  {
    title: 'Maternity Coverage Abroad',
    description: 'Waiting periods, what\'s covered, and how to plan for pregnancy.',
    href: '/guides/maternity-coverage-abroad',
    image: '/images/guides/maternity-coverage.png',
  },
  {
    title: 'Mental Health Coverage',
    description: 'What\'s covered, limitations, and finding care abroad.',
    href: '/guides/mental-health-coverage',
    image: '/images/guides/mental-health-coverage.png',
  },
  {
    title: 'Choosing Your Deductible',
    description: 'How to pick the right deductible for your budget and needs.',
    href: '/guides/choosing-deductibles',
    image: '/images/guides/choosing-deductibles.png',
  },
  {
    title: 'Pre-Existing Conditions',
    description: 'What you need to know about coverage for existing health issues.',
    href: '/guides/pre-existing-conditions',
    image: '/images/guides/pre-existing-conditions.png',
  },
  {
    title: 'Understanding Coverage Limits',
    description: 'Annual maximums, lifetime limits, and what they mean.',
    href: '/guides/coverage-limits',
    image: '/images/guides/coverage-limits.png',
  },
  {
    title: 'Filing Claims Abroad',
    description: 'How to submit claims and get reimbursed from anywhere.',
    href: '/guides/filing-claims',
    image: '/images/guides/filing-claims.png',
  },
  {
    title: 'Medical Evacuation',
    description: 'When and why you might need evacuation coverage.',
    href: '/guides/medical-evacuation',
    image: '/images/guides/medical-evacuation.png',
  },
];
---

<Layout title="Insurance Guides" description="How-to guides for understanding and choosing international health insurance. Learn about deductibles, claims, coverage, and more.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Insurance Guides
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          Learn everything you need to know about international health insurance. Plain-language guides to help you make better decisions.
        </p>
        <CTAButton href="/guides/international-health-insurance-vs-travel" size="lg">
          Start with the Basics
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={guides} title="All Guides" />
    </div>
  </section>
</Layout>
