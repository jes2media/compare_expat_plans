---
/**
 * Problem/Solution Guide: Coordination of Benefits
 *
 * How multiple insurance plans work together when you have more than one.
 */

import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const title = "Coordination of Benefits: How Multiple Insurance Plans Work Together";
const description = "Understanding coordination of benefits when you have multiple health insurance plans. Primary vs secondary coverage, claiming from both plans, and avoiding coverage conflicts.";

const tocItems = [
  { id: "overview", label: "What Is Coordination of Benefits" },
  { id: "primary-secondary", label: "Primary vs Secondary" },
  { id: "rules", label: "How COB Rules Work" },
  { id: "common-situations", label: "Common Situations" },
  { id: "claims-process", label: "Claiming from Both" },
  { id: "international", label: "International Complications" },
  { id: "avoiding-issues", label: "Avoiding Problems" },
  { id: "strategies", label: "Strategic Considerations" },
  { id: "faq", label: "FAQs" },
];

const cobColumns = [
  { key: 'situation', header: 'Situation' },
  { key: 'primary', header: 'Primary Coverage' },
  { key: 'secondary', header: 'Secondary Coverage' },
  { key: 'notes', header: 'Notes' },
];

const cobRows = [
  { situation: 'Own employer + spouse employer', primary: 'Your own employer', secondary: 'Spouse\'s plan', notes: '"Birthday rule" for children' },
  { situation: 'Employer + personal international', primary: 'Usually employer', secondary: 'Personal international', notes: 'Check policy terms' },
  { situation: 'Medicare + supplemental', primary: 'Medicare', secondary: 'Medigap/supplemental', notes: 'Standard in US' },
  { situation: 'Local + international', primary: 'Varies by policy', secondary: 'The other plan', notes: 'Read both policies' },
