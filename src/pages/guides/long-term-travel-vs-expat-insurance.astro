/**
 * Problem/Solution Guide: Long-Term Travel vs Permanent Expat Insurance
 *
 * Understanding the difference between travel medical insurance and true health insurance abroad.
 */

import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const title = "Long-Term Travel vs Expat Insurance: Which Do You Need?";
const description = "Understand the difference between travel medical insurance and international health insurance. Learn which coverage type fits your lifestyle—temporary traveler or permanent expat.";

const tocItems = [
  { id: "overview", label: "The Core Difference" },
  { id: "travel-insurance", label: "Travel Medical Insurance" },
  { id: "expat-insurance", label: "Expat Health Insurance" },
  { id: "comparison", label: "Side-by-Side Comparison" },
  { id: "transition", label: "When to Transition" },
  { id: "hybrid", label: "Hybrid Options" },
  { id: "mistakes", label: "Common Mistakes" },
  { id: "scenarios", label: "Which Is Right For You?" },
  { id: "faq", label: "FAQs" },
];

const comparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'travel', header: 'Travel Medical' },
  { key: 'expat', header: 'Expat Health Insurance' },
];

const comparisonRows = [
  { feature: 'Coverage focus', travel: 'Emergencies and urgent care', expat: 'Comprehensive health needs' },
  { feature: 'Routine care', travel: 'Not covered', expat: 'Included' },
  { feature: 'Pre-existing conditions', travel: 'Excluded', expat: 'Covered after waiting period' },
  { feature: 'Typical cost', travel: '$50-150/month', expat: '$200-600/month' },
  { feature: 'Policy duration', travel: '6-12 months max', expat: 'Renewable indefinitely' },
  { feature: 'Home country coverage', travel: 'Often excluded', expat: 'Usually included or optional' },
