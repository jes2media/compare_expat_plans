---
/**
 * Problem/Solution Guide: Gender-Affirming Care Insurance
 *
 * Health insurance for transgender and gender-diverse expats seeking gender-affirming healthcare abroad.
 */

import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const title = "Insurance for Gender-Affirming Care Abroad: Coverage for Transgender Expats";
const description = "Transgender expats face unique insurance challenges—coverage for hormone therapy, surgeries, and ongoing care varies dramatically by insurer and country. Learn how to find and maintain coverage for gender-affirming healthcare while living internationally.";

const tocItems = [
  { id: "overview", label: "Coverage Challenges" },
  { id: "types-of-care", label: "Types of Care" },
  { id: "finding-coverage", label: "Finding Coverage" },
  { id: "destinations", label: "Country Considerations" },
  { id: "hormones", label: "Hormone Therapy" },
  { id: "surgery", label: "Surgical Coverage" },
  { id: "mental-health", label: "Mental Health Support" },
  { id: "documentation", label: "Documentation Issues" },
  { id: "faq", label: "FAQs" },
];

const careColumns = [
  { key: 'care_type', header: 'Type of Care' },
  { key: 'coverage_likelihood', header: 'Insurance Coverage' },
  { key: 'cost_range', header: 'Typical Cost Without Insurance' },
  { key: 'notes', header: 'Notes' },
];

const careRows = [
  { care_type: 'Hormone therapy (HRT)', coverage_likelihood: 'Often covered as prescription', cost_range: '$30-200/month', notes: 'May require prior authorization' },
  { care_type: 'Mental health support', coverage_likelihood: 'Usually covered', cost_range: '$100-250/session', notes: 'Check for trans-competent providers' },
  { care_type: 'Top surgery (chest)', coverage_likelihood: 'Varies widely', cost_range: '$5,000-15,000', notes: 'Some insurers cover, many exclude' },
  { care_type: 'Bottom surgery (GRS/GCS)', coverage_likelihood: 'Rarely covered internationally', cost_range: '$15,000-50,000+', notes: 'Often explicitly excluded' },
  { care_type: 'Facial feminization surgery', coverage_likelihood: 'Usually excluded', cost_range: '$20,000-50,000', notes: 'Considered cosmetic by most insurers' },
  { care_type: 'Voice therapy/surgery', coverage_likelihood: 'Sometimes covered', cost_range: '$500-10,000', notes: 'Therapy more likely covered than surgery' },
  { care_type: 'Hair removal (laser/electrolysis)', coverage_likelihood: 'Rarely covered', cost_range: '$2,000-10,000 total', notes: 'Usually considered cosmetic' },
];

const countryColumns = [
  { key: 'country', header: 'Country' },
  { key: 'care_access', header: 'Care Accessibility' },
  { key: 'public_coverage', header: 'Public System Coverage' },
  { key: 'considerations', header: 'Key Considerations' },
];

const countryRows = [
  { country: 'Thailand', care_access: 'Excellent, established', care_access: 'Major hub for GCS', public_coverage: 'Private only for expats', considerations: 'Experienced surgeons, lower costs, medical tourism' },
  { country: 'Spain', care_access: 'Good', public_coverage: 'Some regions cover', considerations: 'Progressive laws, regional variation, wait times' },
  { country: 'Germany', care_access: 'Good, bureaucratic', public_coverage: 'Covered with approval', considerations: 'Lengthy approval process, comprehensive coverage' },
  { country: 'UK', care_access: 'Limited capacity', public_coverage: 'NHS covers but long waits', considerations: 'GIC wait times 3-5+ years, private faster' },
  { country: 'Netherlands', care_access: 'Good', public_coverage: 'Covered under insurance', considerations: 'Experienced clinics, some waiting lists' },
  { country: 'Argentina', care_access: 'Good', public_coverage: 'Legal right to coverage', considerations: 'Progressive laws, Spanish required' },
  { country: 'USA', care_access: 'Varies by state', public_coverage: 'No universal public', considerations: 'Insurance varies wildly, some states hostile' },
];

const insurerColumns = [
  { key: 'insurer_type', header: 'Insurer Type' },
  { key: 'hrt_coverage', header: 'HRT Coverage' },
  { key: 'surgery_coverage', header: 'Surgery Coverage' },
  { key: 'notes', header: 'Notes' },
];

const insurerRows = [
  { insurer_type: 'Major international insurers', hrt_coverage: 'Often covered', surgery_coverage: 'Usually excluded', notes: 'Read exclusions carefully' },
  { insurer_type: 'US-based expat plans', hrt_coverage: 'Varies', surgery_coverage: 'Varies by plan', notes: 'ACA-compliant plans may cover more' },
  { insurer_type: 'European insurers', hrt_coverage: 'Usually covered', surgery_coverage: 'Sometimes covered', notes: 'EU non-discrimination may help' },
  { insurer_type: 'Travel medical insurance', hrt_coverage: 'No (routine care)', surgery_coverage: 'No', notes: 'Not designed for ongoing care' },
