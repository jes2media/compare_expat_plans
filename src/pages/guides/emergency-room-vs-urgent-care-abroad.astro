const title = "Emergency Room vs Urgent Care Abroad: Where to Go When You're Sick";
const description = "How to choose between emergency rooms and urgent care clinics abroad. Understanding foreign healthcare systems, cost differences, insurance implications, and getting the right care at the right place.";

const tocItems = [
  { id: "overview", label: "Choosing the Right Care" },
  { id: "systems-vary", label: "How Systems Vary" },
  { id: "when-emergency", label: "When It's an Emergency" },
  { id: "when-urgent", label: "When It's Urgent Care" },
  { id: "cost-differences", label: "Cost Differences" },
  { id: "insurance-implications", label: "Insurance Implications" },
  { id: "finding-care", label: "Finding Care Abroad" },
  { id: "after-hours", label: "After-Hours Options" },
  { id: "faq", label: "FAQs" },
];

const careColumns = [
  { key: 'situation', header: 'Situation' },
  { key: 'where_to_go', header: 'Where to Go' },
  { key: 'why', header: 'Why' },
];

const careRows = [
  { situation: 'Chest pain, difficulty breathing', where_to_go: 'Emergency room', why: 'Potentially life-threatening' },
  { situation: 'High fever with other symptoms', where_to_go: 'Urgent care or ER', why: 'Depends on severity' },
