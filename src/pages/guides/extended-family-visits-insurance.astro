  { id: "visitor-insurance", label: "Visitor Insurance Options" },
  { id: "age-factors", label: "Age Considerations" },
  { id: "pre-existing", label: "Pre-Existing Conditions" },
  { id: "duration", label: "Duration Strategies" },
  { id: "home-coverage", label: "Home Country Coverage" },
  { id: "emergency-planning", label: "Emergency Planning" },
  { id: "cost-guide", label: "Cost Guide" },
  { id: "faq", label: "FAQs" },
