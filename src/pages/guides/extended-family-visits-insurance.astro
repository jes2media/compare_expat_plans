const title = "Insurance for Extended Family Visits Abroad: Covering Parents and Relatives";
const description = "When parents, grandparents, or other family visit you abroad, they need health insurance. Learn about visitor insurance options, age considerations, pre-existing conditions, and ensuring your family is protected during extended stays.";

const tocItems = [
