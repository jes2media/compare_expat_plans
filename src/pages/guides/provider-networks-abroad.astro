const tocItems = [
  { id: "overview", label: "How Networks Work" },
  { id: "in-network", label: "In-Network Benefits" },
  { id: "out-of-network", label: "Out-of-Network Coverage" },
  { id: "finding-providers", label: "Finding Providers" },
  { id: "evaluating", label: "Evaluating Network Strength" },
