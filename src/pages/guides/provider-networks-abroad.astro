const networkRows = [
  { region: 'Western Europe', network_depth: 'Extensive', direct_billing: 'Common', notes: 'Major cities well covered' },
  { region: 'Southeast Asia', network_depth: 'Strong', direct_billing: 'Common', notes: 'Bangkok, Singapore excellent' },
  { region: 'Middle East', network_depth: 'Strong', direct_billing: 'Standard', notes: 'UAE, Qatar well developed' },
