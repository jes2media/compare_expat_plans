];

const injuryColumns = [
  { key: 'injury_type', header: 'Injury Type' },
  { key: 'typical_treatment', header: 'Typical Treatment' },
  { key: 'cost_range', header: 'Cost Range' },
  { key: 'coverage_notes', header: 'Coverage Considerations' },
];

const injuryRows = [
  { injury_type: 'ACL tear', typical_treatment: 'Surgery + 6-12 months rehab', cost_range: '$20,000-75,000', coverage_notes: 'Usually covered, rehab duration varies' },
  { injury_type: 'Shoulder reconstruction', typical_treatment: 'Surgery + 4-8 months rehab', cost_range: '$15,000-50,000', coverage_notes: 'Standard coverage, sports-specific rehab extra' },
  { injury_type: 'Spinal injury', typical_treatment: 'Surgery, extended rehab, ongoing care', cost_range: '$100,000-500,000+', coverage_notes: 'Test policy limits, lifetime care concerns' },
  { injury_type: 'Concussion/TBI', typical_treatment: 'Evaluation, rest, cognitive therapy', cost_range: '$5,000-100,000+', coverage_notes: 'Long-term effects may need ongoing coverage' },
  { injury_type: 'Overuse injuries', typical_treatment: 'Rest, therapy, possible surgery', cost_range: '$2,000-30,000', coverage_notes: 'May be excluded as pre-existing if chronic' },
];

const careerEndingColumns = [
  { key: 'coverage_type', header: 'Coverage Type' },
  { key: 'what_it_covers', header: 'What It Covers' },
  { key: 'typical_benefit', header: 'Typical Benefit' },
  { key: 'who_needs_it', header: 'Who Needs It' },
];

const careerEndingRows = [
  { coverage_type: 'Permanent Total Disability (PTD)', what_it_covers: 'Cannot work in any occupation', typical_benefit: 'Lump sum or income replacement', who_needs_it: 'All professional athletes' },
  { coverage_type: 'Loss of Career Earnings', what_it_covers: 'Cannot continue sports career', typical_benefit: 'Multiple of annual earnings', who_needs_it: 'High earners, those without savings' },
  { coverage_type: 'Temporary Total Disability', what_it_covers: 'Cannot play temporarily', typical_benefit: 'Income replacement during recovery', who_needs_it: 'Self-employed athletes' },
