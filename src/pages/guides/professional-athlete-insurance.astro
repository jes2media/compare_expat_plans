import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const title = "Insurance for Expat Professional Athletes: Coverage for Sports Careers Abroad";
const description = "Professional athletes face unique insurance challenges—career-ending injuries, constant international travel, and sports-specific exclusions. Learn how athletes competing abroad can secure appropriate health coverage.";

const tocItems = [
