  { sport_type: 'Individual sports (tennis, golf)', typical_coverage: 'Personal responsibility', key_concerns: 'Must arrange own coverage, tour injuries' },
  { sport_type: 'Combat sports (boxing, MMA)', typical_coverage: 'Event/promotion coverage + personal', key_concerns: 'High injury risk, difficult to insure' },
  { sport_type: 'Extreme sports (skiing, surfing)', typical_coverage: 'Sponsor coverage varies + personal', key_concerns: 'Exclusions common, hazardous activity' },
  { sport_type: 'Olympic/amateur athletes', typical_coverage: 'Federation + personal', key_concerns: 'Limited federation coverage, gaps between events' },
