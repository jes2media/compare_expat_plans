---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ContentCards from '../../components/ContentCards.astro';

const personas = [
  {
    title: 'Digital Nomads',
    description: 'Coverage that works when you move between countries.',
    href: '/insurance-for/digital-nomads',
    image: '/images/lifestyle/digital-nomads.png',
  },
  {
    title: 'Retirees',
    description: 'Health insurance for retirement abroad.',
    href: '/insurance-for/retirees',
    image: '/images/lifestyle/retirees.png',
  },
  {
    title: 'Families',
    description: 'Plans with maternity and family coverage.',
    href: '/insurance-for/families',
    image: '/images/lifestyle/families.png',
  },
  {
    title: 'Remote Workers',
    description: 'Insurance for employees working from abroad.',
    href: '/insurance-for/remote-workers',
    image: '/images/lifestyle/remote-workers.png',
  },
  {
    title: 'Students',
    description: 'Coverage for studying internationally.',
    href: '/insurance-for/students',
    image: '/images/lifestyle/students.png',
  },
  {
    title: 'Freelancers',
    description: 'Self-employed? Find the right coverage.',
    href: '/insurance-for/freelancers',
    image: '/images/lifestyle/freelancers.png',
  },
  {
    title: 'Entrepreneurs',
    description: 'Coverage for founders running businesses abroad.',
    href: '/insurance-for/entrepreneurs',
    image: '/images/lifestyle/entrepreneurs.png',
  },
  {
    title: 'Pre-existing Conditions',
    description: 'Finding coverage with chronic illness or prior conditions.',
    href: '/insurance-for/pre-existing-conditions',
    image: '/images/lifestyle/pre-existing-conditions.png',
  },
  {
    title: 'Seniors (70+)',
    description: 'Insurance options for older expats abroad.',
    href: '/insurance-for/seniors',
    image: '/images/lifestyle/seniors.png',
  },
  {
    title: 'Teachers Abroad',
    description: 'Coverage for TEFL instructors and international school teachers.',
    href: '/insurance-for/teachers-abroad',
    image: '/images/lifestyle/teachers-abroad.png',
  },
  {
    title: 'Long-term Travelers',
    description: 'Gap years, sabbaticals, and extended trips.',
    href: '/insurance-for/long-term-travelers',
    image: '/images/lifestyle/long-term-travelers.png',
  },
];
---

<Layout title="Insurance For Your Situation" description="Find health insurance recommendations based on your lifestyle. Coverage guides for digital nomads, retirees, families, and more.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Insurance for Your Lifestyle
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          Find coverage recommendations tailored to your situation. Different lifestyles need different solutions.
        </p>
        <CTAButton href="/insurance-for/digital-nomads" size="lg">
          See Nomad Guide
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={personas} title="Find Your Fit" />
    </div>
  </section>
</Layout>
