  { title: 'Australia for Retirees', href: '/insurance-for/retirees/in/australia' },
];

const providerColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'ageLimit', header: 'Max Entry Age' },
  { key: 'preExisting', header: 'Pre-Existing' },
  { key: 'saNetwork', header: 'SA Network' },
  { key: 'monthly', header: 'Monthly (Age 60)' },
];

const providerRows = [
  { provider: 'Cigna Global', ageLimit: '74', preExisting: 'Covered (24mo wait)', saNetwork: 'Excellent', monthly: '$320-480' },
  { provider: 'Bupa Global', ageLimit: '65 (new)', preExisting: 'Full underwriting', saNetwork: 'Excellent', monthly: '$350-520' },
  { provider: 'Allianz Care', ageLimit: '74', preExisting: 'Moratorium option', saNetwork: 'Good', monthly: '$300-450' },
