  { provider: 'IMG Global', ageLimit: '74', preExisting: 'Case-by-case', drNetwork: 'Good', monthly: '$260-400' },
  { provider: 'Allianz Care', ageLimit: '74', preExisting: 'Moratorium option', drNetwork: 'Adequate', monthly: '$300-450' },
];

const costColumns = [
  { key: 'item', header: 'Expense' },
  { key: 'monthly', header: 'Monthly' },
  { key: 'notes', header: 'Notes' },
];

const costRows = [
  { item: 'International Insurance (55-59)', monthly: '$260-380', notes: 'Comprehensive coverage' },
  { item: 'International Insurance (60-64)', monthly: '$320-480', notes: 'Comprehensive coverage' },
  { item: 'International Insurance (65-69)', monthly: '$420-620', notes: 'Comprehensive coverage' },
