  { title: 'Mexico for Retirees', href: '/insurance-for/retirees/in/mexico' },
];

const providerColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'ageLimit', header: 'Max Entry Age' },
  { key: 'preExisting', header: 'Pre-Existing' },
  { key: 'drNetwork', header: 'DR Network' },
  { key: 'monthly', header: 'Monthly (Age 60)' },
];

const providerRows = [
  { provider: 'Cigna Global', ageLimit: '74', preExisting: 'Covered (24mo wait)', drNetwork: 'Good (Santo Domingo)', monthly: '$320-480' },
