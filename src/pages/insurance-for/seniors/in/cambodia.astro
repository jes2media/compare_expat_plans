const costRows = [
  { category: 'International Insurance (65-69)', monthly: '$300-450', annual: '$3,600-5,400' },
  { category: 'International Insurance (70-74)', monthly: '$420-620', annual: '$5,040-7,440' },
  { category: 'International Insurance (75-79)', monthly: '$580-850', annual: '$6,960-10,200' },
  { category: 'Cambodian Local Insurance', monthly: '$60-200', annual: '$720-2,400' },
  { category: 'Out-of-pocket (typical)', monthly: 'Very low', annual: '$300-1,500' },
