const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'TND 870-1,350', annual: 'TND 10,440-16,200' },
  { category: 'International Insurance (70-74)', monthly: 'TND 1,200-1,800', annual: 'TND 14,400-21,600' },
  { category: 'International Insurance (75-79)', monthly: 'TND 1,600-2,400', annual: 'TND 19,200-28,800' },
  { category: 'Tunisian Private Clinic', monthly: 'Pay per visit', annual: 'TND 50-150/visit' },
  { category: 'Tunisian Public', monthly: 'Subsidized', annual: 'Limited quality' },
