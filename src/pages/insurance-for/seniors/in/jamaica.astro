  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: 'J$88,000-125,500/mo', jamaicaFit: 'Excellent' },
  { provider: 'Allianz Care', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'J$67,500-96,000/mo', jamaicaFit: 'Very Good' },
