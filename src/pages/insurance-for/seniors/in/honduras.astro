const costColumns = [
  { key: 'category', header: 'Expense' },
  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: '$280-445', annual: '$3,360-5,340' },
  { category: 'International Insurance (70-74)', monthly: '$385-590', annual: '$4,620-7,080' },
  { category: 'International Insurance (75-79)', monthly: '$520-780', annual: '$6,240-9,360' },
  { category: 'Honduras Private Hospital', monthly: 'Pay per visit', annual: '$25-60/visit' },
