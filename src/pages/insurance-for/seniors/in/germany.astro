  { key: 'entryAge', header: 'Max Entry Age' },
  { key: 'renewal', header: 'Renewal' },
  { key: 'monthlyFrom', header: 'From (65-69)' },
  { key: 'germanyFit', header: 'Germany Fit' },
];

const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '€420-600/mo', germanyFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: '€490-700/mo', germanyFit: 'Excellent' },
  { provider: 'Allianz Care', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '€375-535/mo', germanyFit: 'Excellent' },
  { provider: 'Now Health', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '€350-500/mo', germanyFit: 'Very Good' },
