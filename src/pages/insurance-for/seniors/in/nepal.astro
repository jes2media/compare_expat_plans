const costColumns = [
  { key: 'category', header: 'Expense' },
  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'NPR 34,000-55,000', annual: 'NPR 408,000-660,000' },
  { category: 'International Insurance (70-74)', monthly: 'NPR 47,000-73,000', annual: 'NPR 564,000-876,000' },
  { category: 'International Insurance (75-79)', monthly: 'NPR 63,000-98,000', annual: 'NPR 756,000-1.18M' },
  { category: 'Nepal Private Hospital', monthly: 'Pay per visit', annual: 'NPR 500-2,000/visit' },
  { category: 'Nepal Public', monthly: 'Free/nominal', annual: 'Basic quality' },
];
---

<PageShell
  title="Health Insurance for Seniors in Nepal 2026 | Retirement Guide"
  description="Guide to health insurance for seniors retiring in Nepal. Himalayan views, spiritual culture, extremely affordable living, and coverage for expats 65+."
  headline="Health Insurance for Seniors in Nepal"
  subheadline="Nepal offers Himalayan grandeur, Buddhist and Hindu spirituality, extremely affordable living, and welcoming culture—a unique retirement destination for mountain lovers and spiritual seekers."
  heroImage="/images/countries/nepal-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Senior Plans →"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Why Seniors Choose Nepal</h2>
  <p>
    Nepal offers extraordinary value—Himalayan views from your window, ancient temples and stupas, extremely low costs, and spiritual depth. For those seeking meaningful retirement beyond beaches and golf, Nepal delivers unique experience. The challenge is limited healthcare and infrastructure.
  </p>

  <p>
    Kathmandu Valley has best services, temples, and healthcare. Pokhara offers lakeside living with Annapurna views. Chitwan provides jungle and wildlife. Hill towns like Bandipur offer traditional Nepal. Choose based on altitude tolerance, healthcare access, and lifestyle preference.
  </p>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-primary-900 mb-3">Key Facts for Seniors</h3>
    <ul class="text-primary-800 space-y-2">
      <li><strong>Healthcare:</strong> Limited; Delhi/Bangkok for serious care</li>
      <li><strong>Language:</strong> Nepali; English in tourist areas</li>
      <li><strong>Cost of Living:</strong> NPR 80,000-200,000/month (~$600-1,500); very affordable</li>
      <li><strong>Climate:</strong> Varies by altitude; pleasant in valleys</li>
      <li><strong>Character:</strong> Spiritual; Himalayan; welcoming</li>
      <li><strong>Altitude:</strong> Consider elevation for health</li>
    </ul>
  </div>

  <h2 id="healthcare-system">Nepal Healthcare System</h2>
  <p>
    Nepal healthcare is limited—developing country with basic facilities. Kathmandu has adequate private hospitals (Norvic, Grande, Om Hospital) for routine care. Complex conditions require evacuation to Delhi (1-hour flight) or Bangkok. High-altitude areas have minimal facilities.
  </p>

  <p>
    International insurance with India/Bangkok evacuation is essential. Many expats use Delhi for serious healthcare—world-class hospitals at Nepal doorstep. Altitude-related health issues are specific Nepal consideration.
  </p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">Delhi Healthcare Hub</h3>
    <p class="text-amber-800 mb-0">
      Delhi is the healthcare hub for Nepal expats—1-hour flight to world-class hospitals (Apollo, Fortis, Max). International insurance must include India coverage. Plan for Delhi medical visits for serious or complex care needs.
    </p>
  </div>

  <h2 id="visa-requirements">Visa Options for Seniors</h2>
  <p>
    Nepal has flexible visa options:
  </p>

  <h3>Non-Resident Nepali Visa</h3>
  <p>
    For people of Nepali origin—10-year multiple-entry visa with unlimited stay. Ideal for diaspora retirees returning home.
  </p>

  <h3>Residence Visa</h3>
  <p>
    For retirees with pension income. Demonstrate ~$1,500+/month income. Applied through Immigration Department. Renewable annually.
  </p>

  <h3>Tourist Visa</h3>
  <p>
    Multiple-entry tourist visas up to 150 days per year. Some retirees combine with regional travel while exploring longer-term options.
  </p>

  <h2 id="insurance-requirements">Insurance Requirements</h2>
  <p>
    Insurance requirements for Nepal:
  </p>

  <ul>
    <li><strong>Visa requirement:</strong> None mandatory</li>
    <li><strong>Practical need:</strong> Essential given limited local healthcare</li>
    <li><strong>India evacuation:</strong> Critical for serious care</li>
    <li><strong>Altitude coverage:</strong> Important for mountain living</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-2">Insurance Strategy for Nepal</h3>
    <p class="text-blue-800 mb-0">
      International insurance with Asia coverage including India is essential. Local healthcare handles routine needs; Delhi handles serious conditions. Ensure coverage includes altitude-related conditions and evacuation from remote areas.
    </p>
  </div>

  <h2 id="recommended-providers">Recommended Insurance Providers</h2>
  <p>
    For seniors in Nepal, evacuation coverage is the priority:
  </p>

  <ComparisonTable columns={providerColumns} rows={providerRows} />

  <h3>Why These Providers Work for Nepal</h3>
  <ul>
    <li><strong>Cigna Global:</strong> Strong Asia network, Delhi/Bangkok access</li>
    <li><strong>BUPA Global:</strong> Highest entry age (79), comprehensive evacuation</li>
    <li><strong>Now Health:</strong> Asia expertise, regional knowledge</li>
    <li><strong>Allianz Care:</strong> Good evacuation protocols</li>
  </ul>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Get Personalized Senior Quotes</h3>
    <p class="text-neutral-600 mb-4">Compare coverage with evacuation essential for Nepal.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/cigna-global" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Cigna Quote</a>
      <a href="/go/bupa-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get BUPA Quote</a>
    </div>
  </div>

  <h2 id="costs">Expected Insurance Costs</h2>
  <p>
    Insurance costs for Nepal are moderate given evacuation requirements:
  </p>

  <ComparisonTable columns={costColumns} rows={costRows} />

  <h3>Cost-Saving Strategies</h3>
  <ul>
    <li><strong>Higher deductibles:</strong> Local care is very affordable</li>
    <li><strong>Pay cash routine:</strong> Consultations NPR 500-1,500; very cheap</li>
    <li><strong>Asia regional:</strong> Regional rather than worldwide</li>
    <li><strong>Kathmandu base:</strong> Best local healthcare access</li>
  </ul>

  <h2 id="scenarios">Real-World Scenarios</h2>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 1: American Buddhist, 67</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> $1,800/month pension. Kathmandu spiritual practice.</p>
      <p class="text-neutral-600 mb-2"><strong>Solution:</strong> Residence visa. Cigna Global with India/Bangkok evacuation.</p>
      <p class="text-neutral-600 mb-0"><strong>Cost:</strong> Cigna ~NPR 45,000/month (~$340). Stupas and temples; Delhi healthcare.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 2: British Trekker, 71</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> £1,600/month pension. Pokhara base, mountain views.</p>
      <p class="text-neutral-600 mb-2"><strong>Solution:</strong> BUPA Global with high-altitude coverage. Annapurna at doorstep.</p>
      <p class="text-neutral-600 mb-0"><strong>Cost:</strong> BUPA ~NPR 55,000/month (~£380). Lake and mountains; trekking lifestyle.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 3: Nepali-Australian Returning, 66</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> AUD 2,000/month pension. NRN status, returning to Kathmandu.</p>
      <p class="text-neutral-600 mb-2"><strong>Solution:</strong> NRN visa. Now Health with comprehensive Asia coverage.</p>
      <p class="text-neutral-600 mb-0"><strong>Cost:</strong> Now Health ~NPR 40,000/month (~AUD 320). Family return; familiar culture.</p>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <div class="space-y-6 my-8">
    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Is altitude a concern for seniors?</h3>
      <p class="text-neutral-600 mb-0">
        Yes—Kathmandu is 1,400m elevation. Higher areas require acclimatization. Some seniors find altitude affects breathing, sleep, energy. Those with heart/lung conditions should consult doctors. Lower areas (Chitwan, Terai) are at lower elevation. Important consideration.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">How affordable is Nepal?</h3>
      <p class="text-neutral-600 mb-0">
        Extremely affordable—among world lowest costs. Comfortable retirement possible on $800-1,200/month. Local food, domestic help very cheap. Western goods cost more. Rent $200-500 for nice apartment. Excellent value for mountain lifestyle.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Is Nepal stable?</h3>
      <p class="text-neutral-600 mb-0">
        Generally yes—federal republic since 2008. Political changes but peaceful. Tourism is major industry; foreigners welcome. Crime is low. Infrastructure is challenging (power, roads). Earthquakes are natural risk. Most expats feel safe.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What is the expat community like?</h3>
      <p class="text-neutral-600 mb-0">
        Small but dedicated—NGO workers, spiritual seekers, adventurers. Kathmandu and Pokhara have established communities. Not as large as Thailand or Mexico retiree communities. People who choose Nepal usually have specific reasons. Welcoming to newcomers.
      </p>
    </div>
  </div>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Ready to Compare Options?</h3>
    <p class="text-neutral-600 mb-4">Get quotes with evacuation coverage essential for Nepal.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/cigna-global" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Cigna Quote</a>
      <a href="/go/allianz-care" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get Allianz Quote</a>
    </div>
  </div>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600 mb-0">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Insurance requirements, visa regulations, and healthcare access rules change regularly. Always verify current requirements with Nepal authorities and consult with a licensed insurance professional.
    </p>
  </div>
</PageShell>
