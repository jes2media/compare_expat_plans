const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'NPR 38,000-55,000/mo', nepalFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: 'NPR 45,000-64,000/mo', nepalFit: 'Excellent' },
  { provider: 'Now Health', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'NPR 34,000-49,000/mo', nepalFit: 'Very Good' },
