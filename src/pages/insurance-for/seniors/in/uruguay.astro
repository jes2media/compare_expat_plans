];

const costColumns = [
  { key: 'category', header: 'Expense' },
  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: '$320-500', annual: '$3,840-6,000' },
  { category: 'International Insurance (70-74)', monthly: '$440-660', annual: '$5,280-7,920' },
  { category: 'International Insurance (75-79)', monthly: '$600-900', annual: '$7,200-10,800' },
