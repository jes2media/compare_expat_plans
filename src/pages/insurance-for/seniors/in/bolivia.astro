const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'BOB$2,140-3,395', annual: 'BOB$25,680-40,740' },
  { category: 'International Insurance (70-74)', monthly: 'BOB$2,935-4,530', annual: 'BOB$35,220-54,360' },
  { category: 'International Insurance (75-79)', monthly: 'BOB$3,955-6,095', annual: 'BOB$47,460-73,140' },
  { category: 'Private Hospital Visit', monthly: 'BOB$100-300/visit', annual: 'Very affordable' },
  { category: 'Private Hospital Stay', monthly: 'BOB$700-2,100/day', annual: 'Per incident' },
