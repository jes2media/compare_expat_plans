const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'KES$49,500-78,500', annual: 'KES$594K-942K' },
  { category: 'International Insurance (70-74)', monthly: 'KES$67,900-104,650', annual: 'KES$815K-1.26M' },
  { category: 'International Insurance (75-79)', monthly: 'KES$91,350-140,650', annual: 'KES$1.1M-1.69M' },
  { category: 'Private Hospital Visit', monthly: 'KES$3,000-10,000/visit', annual: 'Affordable' },
  { category: 'Private Hospital Stay', monthly: 'KES$20,000-60,000/day', annual: 'Per incident' },
