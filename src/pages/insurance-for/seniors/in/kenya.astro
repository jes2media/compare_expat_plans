const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'KES 37,000-58,000', annual: 'KES 444,000-696,000' },
  { category: 'International Insurance (70-74)', monthly: 'KES 52,000-78,000', annual: 'KES 624,000-936,000' },
  { category: 'International Insurance (75-79)', monthly: 'KES 70,000-105,000', annual: 'KES 840,000-1,260,000' },
  { category: 'Kenyan Premium Local', monthly: 'KES 15,000-30,000', annual: 'KES 180,000-360,000' },
  { category: 'Private Clinic Visit', monthly: 'Pay per visit', annual: 'KES 2,000-6,000/visit' },
