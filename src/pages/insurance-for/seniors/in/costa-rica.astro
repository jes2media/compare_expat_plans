const relatedLinks = [
  { title: 'Costa Rica Insurance Guide', href: '/countries/costa-rica/insurance' },
  { title: 'Insurance for Seniors', href: '/insurance-for/seniors' },
  { title: 'Costa Rica Retirement Visa', href: '/visas/retirement-visa/in/costa-rica' },
  { title: 'Insurance with Pre-existing Conditions', href: '/insurance-for/pre-existing-conditions' },
  { title: 'Panama for Seniors', href: '/insurance-for/seniors/in/panama' },
