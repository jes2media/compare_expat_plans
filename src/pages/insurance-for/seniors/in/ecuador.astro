const relatedLinks = [
  { title: 'Ecuador Insurance Guide', href: '/countries/ecuador/insurance' },
  { title: 'Insurance for Seniors', href: '/insurance-for/seniors' },
  { title: 'Ecuador Retirement Visa', href: '/visas/retirement-visa/in/ecuador' },
  { title: 'Insurance with Pre-existing Conditions', href: '/insurance-for/pre-existing-conditions' },
  { title: 'Colombia for Seniors', href: '/insurance-for/seniors/in/colombia' },
