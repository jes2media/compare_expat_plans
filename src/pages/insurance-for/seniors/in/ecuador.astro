const providerColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'entryAge', header: 'Max Entry Age' },
  { key: 'renewal', header: 'Renewal' },
  { key: 'monthlyFrom', header: 'From (65-69)' },
  { key: 'ecuadorFit', header: 'Ecuador Fit' },
];

const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '$340-480/mo', ecuadorFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: '$420-600/mo', ecuadorFit: 'Excellent' },
  { provider: 'GeoBlue (Americans)', entryAge: '84', renewal: 'Lifetime', monthlyFrom: '$380-520/mo', ecuadorFit: 'Excellent' },
  { provider: 'IMG Global', entryAge: '74', renewal: '80', monthlyFrom: '$280-400/mo', ecuadorFit: 'Very Good' },
  { provider: 'IESS (Public)', entryAge: 'No limit', renewal: 'Lifetime', monthlyFrom: '~$80/mo', ecuadorFit: 'Good (Basic)' },
];

const costColumns = [
  { key: 'category', header: 'Expense' },
  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: '$320-480', annual: '$3,840-5,760' },
  { category: 'International Insurance (70-74)', monthly: '$450-650', annual: '$5,400-7,800' },
  { category: 'International Insurance (75-79)', monthly: '$600-900', annual: '$7,200-10,800' },
  { category: 'IESS Public Insurance', monthly: '~$80 (17.6% min wage)', annual: '~$960' },
  { category: 'Ecuadorian Private Insurance', monthly: '$100-250', annual: '$1,200-3,000' },
];
---

<PageShell
  title="Health Insurance for Seniors in Ecuador | Retirement Guide"
  description="Guide to health insurance for seniors retiring in Ecuador. IESS system, Cuenca expat community, ultra-affordable costs, and coverage for expats 70+."
  headline="Health Insurance for Seniors in Ecuador"
  subheadline="Ecuador offers the lowest cost of living in the Americas plus access to public healthcare—making it ideal for budget-conscious seniors."
  heroImage="/images/countries/ecuador-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Senior Plans →"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Why Seniors Choose Ecuador</h2>
  <p>
    Ecuador has become the go-to destination for retirees seeking the lowest cost of living in the Americas. Using the US dollar as currency and offering access to its public healthcare system, Ecuador allows seniors to stretch their retirement income further than almost anywhere else.
  </p>

  <p>
    Cuenca, a UNESCO World Heritage city in the Andean highlands, hosts the largest American expat community in Ecuador. Its eternal spring climate (60-75°F year-round), colonial architecture, and affordable lifestyle have made it a retirement haven. The coast around Salinas and the capital Quito offer alternatives for those preferring beach or big-city living.
  </p>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-primary-900 mb-3">Key Facts for Seniors</h3>
    <ul class="text-primary-800 space-y-2">
      <li><strong>Currency:</strong> US Dollar (no exchange risk)</li>
      <li><strong>Healthcare:</strong> IESS public system available to residents</li>
      <li><strong>Cost of living:</strong> $1,200-2,000/month for comfortable retirement</li>
      <li><strong>Climate:</strong> Varies by region; Cuenca 60-75°F year-round</li>
      <li><strong>Senior benefits:</strong> 50% discounts on utilities, transport, entertainment</li>
    </ul>
  </div>

  <h2 id="healthcare-system">Ecuador's Healthcare System</h2>
  <p>
    Ecuador's healthcare system includes both the public IESS system and private hospitals. For seniors, the ability to enroll in IESS regardless of age or pre-existing conditions makes Ecuador uniquely attractive.
  </p>

  <h3>IESS Public Healthcare</h3>
  <p>
    The Instituto Ecuatoriano de Seguridad Social (IESS) provides universal coverage to all legal residents who pay into the system. Enrollment costs approximately 17.6% of Ecuador's minimum wage (about $80/month). Coverage includes:
  </p>
  <ul>
    <li>Hospital care and surgery</li>
    <li>Doctor and specialist consultations</li>
    <li>Prescription medications</li>
    <li>Emergency care</li>
    <li>Chronic disease management</li>
    <li>Pre-existing conditions (no exclusions)</li>
  </ul>
  <p>
    Wait times can be lengthy (weeks to months for specialists), and navigating the system requires Spanish or a helper. However, the coverage is comprehensive and remarkably affordable.
  </p>

  <h3>Private Healthcare</h3>
  <p>
    Ecuador has good private hospitals, particularly in Quito and Guayaquil. Facilities like Hospital Metropolitano, Hospital de los Valles, and Clínica Kennedy offer modern care. Cuenca has Hospital Santa Inés and Clínica Santa Ana. Private costs are very low:
  </p>
  <ul>
    <li><strong>Doctor visit:</strong> $20-40</li>
    <li><strong>Specialist consultation:</strong> $35-70</li>
    <li><strong>Hospital day:</strong> $100-200</li>
    <li><strong>MRI:</strong> $150-300</li>
    <li><strong>Hip replacement:</strong> $6,000-10,000</li>
  </ul>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-3">IESS Pre-existing Coverage</h3>
    <p class="text-amber-800">
      Unlike private insurance, IESS has no pre-existing condition exclusions or waiting periods for most conditions. A 75-year-old with diabetes, heart disease, and cancer history can enroll and receive full coverage. This makes Ecuador exceptionally attractive for seniors with health conditions.
    </p>
  </div>

  <h2 id="visa-requirements">Visa Options for Senior Retirees</h2>
  <p>
    Ecuador offers accessible retirement visa options with low income requirements.
  </p>

  <h3>Jubilado Visa (Retiree)</h3>
  <ul>
    <li><strong>Income requirement:</strong> $800/month pension or Social Security</li>
    <li><strong>Health insurance:</strong> Required for application (IESS or private)</li>
    <li><strong>Duration:</strong> 2 years initially, then indefinite renewal</li>
    <li><strong>Age:</strong> Must receive retirement income (typically 65+)</li>
  </ul>

  <h3>Rentista Visa (Private Income)</h3>
  <ul>
    <li><strong>Income requirement:</strong> $800/month from investments or stable source</li>
    <li><strong>Health insurance:</strong> Required</li>
    <li><strong>Duration:</strong> 2 years, renewable</li>
    <li><strong>Notes:</strong> Good for those not yet receiving pension</li>
  </ul>

  <h3>Senior Citizen Benefits</h3>
  <p>
    Residents 65+ (Ecuadorians and legal residents) receive substantial benefits:
  </p>
  <ul>
    <li>50% off domestic airfare</li>
    <li>50% off utilities (electricity, water, phone)</li>
    <li>50% off public transportation</li>
    <li>50% off entertainment and cultural events</li>
    <li>Priority service at banks and government offices</li>
  </ul>

  <CTABox
    title="Planning Your Ecuador Move?"
    description="Get coverage that complements Ecuador's IESS system."
    buttonText="Compare Plans →"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="insurance-requirements">Insurance Requirements for Seniors</h2>
  <p>
    Ecuador requires health insurance for visa applications. IESS enrollment or private insurance satisfies this requirement.
  </p>

  <h3>Visa Application Requirements</h3>
  <ul>
    <li>Valid health insurance covering Ecuador</li>
    <li>IESS enrollment letter OR private/international insurance</li>
    <li>Coverage for duration of stay</li>
  </ul>

  <h3>After Obtaining Residency</h3>
  <p>
    Once you have residency (cédula), IESS enrollment is straightforward. Most seniors choose one of these approaches:
  </p>
  <ul>
    <li><strong>IESS only:</strong> ~$80/month for comprehensive coverage</li>
    <li><strong>IESS + private pay:</strong> Use IESS for major expenses, pay out-of-pocket for faster private care</li>
    <li><strong>IESS + international:</strong> Keep international insurance for travel and evacuation</li>
  </ul>

  <h3>Recommended Approach</h3>
  <p>
    Given Ecuador's extremely affordable healthcare, many seniors find IESS plus out-of-pocket private care the most economical approach. International insurance makes sense if you travel frequently, want evacuation coverage, or prefer the security of higher limits. Many seniors use IESS for the first year to evaluate the system.
  </p>

  <h2 id="recommended-providers">Recommended Providers for Ecuador</h2>
  <p>
    These options work well for seniors retiring in Ecuador:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={providerColumns} rows={providerRows} />
  </div>

  <h3>IESS (Public Insurance)</h3>
  <p>
    The foundation of healthcare for most expat seniors in Ecuador. ~$80/month covers everything including pre-existing conditions. No age limits. Enroll after obtaining your cédula. Use for medications (heavily subsidized), hospitalizations, and ongoing care. Supplement with private visits when you need faster access.
  </p>

  <h3>GeoBlue (For Americans)</h3>
  <p>
    Accepts applicants up to 84. BCBS network access when visiting the US. Ideal for Americans who travel home frequently or want evacuation coverage. Works well as supplement to IESS.
  </p>

  <h3>Cigna Global</h3>
  <p>
    Excellent international option with Latin America regional coverage options. Entry up to 74 with lifetime renewal. Direct billing at major Ecuadorian hospitals. Good choice for comprehensive worldwide coverage.
  </p>

  <h3>Ecuadorian Private Insurance</h3>
  <p>
    Companies like BMI, Seguros del Pichincha, and Equivida offer local private plans. Age limits typically 60-65 for new policies. Low cost but Ecuador-only coverage. Can work as supplement to IESS for faster private access.
  </p>

  <CTABox
    title="Compare Senior-Friendly Plans"
    description="Find coverage that works with Ecuador's ultra-affordable healthcare."
    buttonText="See Options →"
    buttonHref="/go/cigna-global"
  />

  <h2 id="costs">Expected Insurance Costs</h2>
  <p>
    Healthcare costs in Ecuador are among the lowest in the Americas:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={costColumns} rows={costRows} />
  </div>

  <h3>Why Many Skip International Insurance</h3>
  <p>
    Ecuador's healthcare is so affordable that many retirees operate with IESS plus a cash reserve:
  </p>
  <ul>
    <li>IESS: ~$80/month = $960/year</li>
    <li>Annual healthcare budget: $2,000-3,000 (covers most out-of-pocket private care)</li>
    <li>Total: $3,000-4,000/year vs. $6,000-10,000 for international insurance</li>
    <li>Even major surgery ($6,000-15,000) is manageable compared to US prices</li>
  </ul>

  <h3>When International Insurance Makes Sense</h3>
  <ul>
    <li><strong>Frequent travelers:</strong> If you leave Ecuador regularly</li>
    <li><strong>Complex conditions:</strong> If you might need treatment abroad</li>
    <li><strong>Peace of mind:</strong> If you prefer comprehensive coverage</li>
    <li><strong>Evacuation:</strong> Remote areas may require air transport</li>
    <li><strong>Higher limits:</strong> Cancer treatment can exceed $100,000 anywhere</li>
  </ul>

  <h2 id="scenarios">Real-World Scenarios</h2>

  <div class="grid gap-6 my-8">
    <div class="bg-white border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 1: Routine Care in Cuenca</h3>
      <p class="text-neutral-600 mb-3">Janet, 72, needs blood pressure medication and checkup.</p>
      <p class="text-green-700"><strong>Outcome:</strong> Visits IESS clinic in Cuenca. Appointment within 1 week. Medications: $5 for 3-month supply. No additional cost beyond $80/month IESS contribution.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 2: Private Specialist Visit</h3>
      <p class="text-neutral-600 mb-3">Tom, 69, wants to see cardiologist faster than IESS wait.</p>
      <p class="text-green-700"><strong>Outcome:</strong> Visits private cardiologist at Hospital Santa Inés. Consultation: $50. EKG + bloodwork: $80. Total: $130 out-of-pocket. Seen within 2 days vs. 4-6 weeks at IESS.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 3: Major Surgery</h3>
      <p class="text-neutral-600 mb-3">Robert, 74, needs hip replacement.</p>
      <p class="text-green-700"><strong>Outcome:</strong> IESS covers surgery at public hospital (8-week wait). Alternatively, pays $8,500 at private hospital (1-week wait). Cigna Global covers private surgery after $2,500 deductible.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 4: Pre-existing Diabetes and Heart Disease</h3>
      <p class="text-neutral-600 mb-3">Linda, 73, has multiple chronic conditions.</p>
      <p class="text-green-700"><strong>Outcome:</strong> IESS covers everything—no pre-existing exclusions. Regular cardiology appointments, diabetes management, and medications all included in $80/month contribution. Private insurance would have excluded or charged significantly more.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 5: Medical Evacuation</h3>
      <p class="text-neutral-600 mb-3">George, 76, has stroke in small coastal town.</p>
      <p class="text-amber-700"><strong>Outcome:</strong> Stabilized at local clinic. Air ambulance to Hospital Metropolitano in Quito arranged by BUPA Global—$22,000 covered. Treatment in Quito; recovery in Ecuador. This scenario shows value of evacuation coverage for those outside major cities.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 6: Budget-Conscious Senior</h3>
      <p class="text-neutral-600 mb-3">Carol, 70, on $1,400/month Social Security.</p>
      <p class="text-green-700"><strong>Outcome:</strong> Uses IESS exclusively ($80/month). Saves $500/month vs. international insurance. Budget for occasional private visits when needed. Total annual healthcare cost: ~$1,200. Comfortable retirement on limited income.</p>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <div class="grid gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Is IESS really available to foreign retirees?</h3>
      <p class="text-neutral-700">Yes, all legal residents with a cédula can enroll in IESS. Contribution is ~17.6% of Ecuador's minimum wage (about $80/month regardless of your actual income). Coverage is comprehensive including pre-existing conditions.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">What are the IESS wait times really like?</h3>
      <p class="text-neutral-700">Emergency care is immediate. GP appointments: 1-2 weeks. Specialists: 2-8 weeks depending on specialty and location. Non-urgent surgery: can be months. Many expats use IESS for ongoing care and pay out-of-pocket ($30-70) for private when they want faster access.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">I'm 80—what are my options?</h3>
      <p class="text-neutral-700">IESS has no age limit—you can enroll at any age. GeoBlue accepts Americans up to 84. BUPA Global accepts up to 79. Ecuadorian private insurers typically cap at 60-65. For seniors 80+, IESS plus GeoBlue (if American) is the typical combination.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Do doctors speak English?</h3>
      <p class="text-neutral-700">Some doctors in Cuenca and Quito speak English, particularly in private hospitals. However, Spanish is generally required for IESS and most healthcare interactions. The large expat community in Cuenca means translators and English-speaking doctors are findable, but learning medical Spanish helps significantly.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Can I really retire on $1,200/month in Ecuador?</h3>
      <p class="text-neutral-700">Yes, many expats live comfortably on $1,200-1,500/month in Cuenca. This covers rent ($400-600 for a nice apartment), food, utilities (with 50% senior discount), healthcare (IESS $80), and entertainment. Those with $2,000+ live very well. The dollar currency means no exchange rate concerns.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">What about healthcare quality in Cuenca specifically?</h3>
      <p class="text-neutral-700">Cuenca has good hospitals (Santa Inés, Santa Ana) and many private clinics. For complex procedures, some people travel to Quito or Guayaquil. The IESS regional hospital in Cuenca handles most needs. The expat community has extensive knowledge of English-speaking doctors and best facilities.</p>
    </div>
  </div>

  <CTABox
    title="Ready for Ecuador?"
    description="Find the right insurance balance for your budget."
    buttonText="Compare Plans →"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This guide is for informational purposes. Ecuadorian visa requirements, IESS rules, and healthcare costs change. Verify current requirements with Ecuadorian authorities. Consider consulting an immigration lawyer and connecting with the expat community in your target city for current local information.
    </p>
  </div>
</PageShell>
