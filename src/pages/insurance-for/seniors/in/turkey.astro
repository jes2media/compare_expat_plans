const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'TRY 12,000-17,000/mo', turkeyFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: 'TRY 14,000-20,000/mo', turkeyFit: 'Excellent' },
  { provider: 'Allianz Care', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'TRY 11,000-16,000/mo', turkeyFit: 'Very Good' },
