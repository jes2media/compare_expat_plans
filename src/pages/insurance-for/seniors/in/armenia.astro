const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'AMD$145,000-207,000/mo', armeniaFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: 'AMD$170,000-243,000/mo', armeniaFit: 'Excellent' },
  { provider: 'Allianz Care', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'AMD$130,000-186,000/mo', armeniaFit: 'Very Good' },
