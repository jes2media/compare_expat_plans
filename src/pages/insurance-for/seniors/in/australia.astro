const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'A$620-890/mo', auFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: 'A$730-1,040/mo', auFit: 'Excellent' },
  { provider: 'Allianz Care', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'A$560-800/mo', auFit: 'Very Good' },
