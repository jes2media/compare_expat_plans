const costColumns = [
  { key: 'category', header: 'Expense' },
  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'A$560-890', annual: 'A$6,720-10,680' },
  { category: 'International Insurance (70-74)', monthly: 'A$770-1,180', annual: 'A$9,240-14,160' },
  { category: 'International Insurance (75-79)', monthly: 'A$1,040-1,590', annual: 'A$12,480-19,080' },
  { category: 'Medicare (Citizens/PR)', monthly: 'Tax-funded', annual: 'Public system free' },
  { category: 'Australian Private Health', monthly: 'A$250-600/mo', annual: 'A$3,000-7,200' },
];
---

<PageShell
  title="Health Insurance for Seniors in Australia 2026 | Retirement Guide"
  description="Guide to health insurance for seniors retiring in Australia. World-class healthcare, outdoor lifestyle, English-speaking, and coverage for expats 65+."
  headline="Health Insurance for Seniors in Australia"
  subheadline="Australia offers world-class healthcare, outdoor lifestyle, English-speaking environment, and high quality of life—popular among those seeking first-world retirement in the Asia-Pacific."
  heroImage="/images/countries/australia-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Senior Plans →"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Why Seniors Choose Australia</h2>
  <p>
    Australia offers first-world quality of life—world-class healthcare, outdoor lifestyle, English-speaking environment, and diverse landscapes. For those from UK, US, or other English-speaking countries, Australia offers familiar culture with better weather. The challenge is visa access for non-citizens.
  </p>

  <p>
    Sydney offers cosmopolitan living with beaches. Melbourne has culture and European feel. Brisbane provides subtropical climate. Perth has beautiful isolation. Adelaide offers affordable city living. Regional areas provide affordable alternatives with good healthcare access.
  </p>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-primary-900 mb-3">Key Facts for Seniors</h3>
    <ul class="text-primary-800 space-y-2">
      <li><strong>Healthcare:</strong> Excellent; Medicare + private system</li>
      <li><strong>Language:</strong> English</li>
      <li><strong>Cost of Living:</strong> A$3,500-7,000/month (~$2,300-4,700); high</li>
      <li><strong>Climate:</strong> Varies; temperate to tropical</li>
      <li><strong>Lifestyle:</strong> Outdoor; beach; active</li>
      <li><strong>Safety:</strong> Very safe and stable</li>
    </ul>
  </div>

  <h2 id="healthcare-system">Australia Healthcare System</h2>
  <p>
    Australia has excellent dual healthcare system—Medicare (public) provides universal coverage for citizens/PR, and robust private sector offers faster access. Royal Melbourne, Royal Prince Alfred, St Vincent are excellent public hospitals. Private hospitals provide choice and convenience.
  </p>

  <p>
    Medicare covers most medical needs for citizens/PR. Private health insurance provides faster access, choice of doctor, private room. For non-citizens, international insurance is essential. Healthcare quality rivals any developed nation.
  </p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">Medicare + Private System</h3>
    <p class="text-amber-800 mb-0">
      Citizens/PR access Medicare (public) plus optional private health insurance. Private provides faster elective surgery, choice of specialist, private rooms. For seniors, private insurance avoids wait times for hip replacements, cataracts, etc. Combination provides comprehensive coverage.
    </p>
  </div>

  <h2 id="visa-requirements">Visa Options for Seniors</h2>
  <p>
    Australia visa access is limited for retirees:
  </p>

  <h3>Investor Retirement Visa (Subclass 405)</h3>
  <p>
    Closed to new applicants—was for retirees 55+ with A$500,000+ investment. Current holders can renew but new applications not accepted.
  </p>

  <h3>Parent Visa</h3>
  <p>
    For parents of Australian citizen/PR children. Various categories including Contributory Parent Visa. Long processing times. Leads to Medicare eligibility.
  </p>

  <h3>Partner Visa</h3>
  <p>
    For partners of Australian citizens/PR. Leads to permanent residence and Medicare.
  </p>

  <h3>Visitor Visa</h3>
  <p>
    Up to 12-month tourist visa possible for some nationalities. Not suitable for permanent retirement.
  </p>

  <h2 id="insurance-requirements">Insurance Requirements</h2>
  <p>
    Insurance requirements for Australia:
  </p>

  <ul>
    <li><strong>Visitors:</strong> Travel insurance required for visa</li>
    <li><strong>PR/Citizens:</strong> Medicare provides base; private recommended</li>
    <li><strong>Non-Medicare eligible:</strong> International insurance essential</li>
    <li><strong>Visa holders:</strong> OVHC (Overseas Visitor Health Cover) may be required</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-2">Insurance Strategy for Australia</h3>
    <p class="text-blue-800 mb-0">
      For PR/citizens: Medicare provides base coverage; private health insurance recommended for faster access and choice. For non-residents: international insurance essential. Australia healthcare is excellent but expensive without coverage.
    </p>
  </div>

  <h2 id="recommended-providers">Recommended Insurance Providers</h2>
  <p>
    For seniors in Australia, coverage depends on visa/Medicare status:
  </p>

  <ComparisonTable columns={providerColumns} rows={providerRows} />

  <h3>Why These Providers Work for Australia</h3>
  <ul>
    <li><strong>Cigna Global:</strong> Strong Australia network, international coverage</li>
    <li><strong>BUPA Global:</strong> Highest entry age (79), BUPA also has Australian arm</li>
    <li><strong>Australian Private:</strong> BUPA, Medibank, HCF for residents</li>
    <li><strong>Medicare:</strong> Base coverage for citizens/PR (not insurance but essential)</li>
  </ul>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Get Personalized Senior Quotes</h3>
    <p class="text-neutral-600 mb-4">Compare coverage options for Australia healthcare.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/cigna-global" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Cigna Quote</a>
      <a href="/go/bupa-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get BUPA Quote</a>
    </div>
  </div>

  <h2 id="costs">Expected Insurance Costs</h2>
  <p>
    Insurance costs for Australia vary by coverage type:
  </p>

  <ComparisonTable columns={costColumns} rows={costRows} />

  <h3>Cost-Saving Strategies</h3>
  <ul>
    <li><strong>Medicare base:</strong> If eligible, provides excellent free coverage</li>
    <li><strong>Higher excess:</strong> Private policies with higher excess reduce premiums</li>
    <li><strong>Regional areas:</strong> Lower living costs, Medicare covers healthcare</li>
    <li><strong>Lifetime Health Cover:</strong> Start private early to avoid loadings</li>
  </ul>

  <h2 id="scenarios">Real-World Scenarios</h2>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 1: British Parent Visa, 68</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> Parent visa holder, A$3,500/month pension. Melbourne near children.</p>
      <p class="text-neutral-600 mb-2"><strong>Solution:</strong> Medicare + Medibank private for extras. Family proximity.</p>
      <p class="text-neutral-600 mb-0"><strong>Cost:</strong> Private ~A$350/month. Medicare covers majority; private for choice.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 2: American Long-term Visitor, 71</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> $4,000/month pension. Visitor visa, Sydney area.</p>
      <p class="text-neutral-600 mb-2"><strong>Solution:</strong> Cigna Global comprehensive. No Medicare access.</p>
      <p class="text-neutral-600 mb-0"><strong>Cost:</strong> Cigna ~A$780/month (~$520). Full coverage required; excellent quality.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 3: Returning Aussie, 66</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> A$4,500/month pension. Returning after overseas career. Brisbane.</p>
      <p class="text-neutral-600 mb-2"><strong>Solution:</strong> Reactivate Medicare + BUPA Australia private.</p>
      <p class="text-neutral-600 mb-0"><strong>Cost:</strong> BUPA ~A$400/month. Full Australian system; homecoming.</p>
    </div>
  </div>

  <h2 id="faqs">Common Questions</h2>

  <div class="space-y-6 my-8">
    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Can non-citizens retire in Australia?</h3>
      <p class="text-neutral-600 mb-0">
        Difficult—no specific retirement visa since 405 closed. Need family sponsor (Parent/Partner visa) or other qualifying pathway. Long-term visitor status possible for some nationalities. Australia is restrictive on immigration. Research visa options carefully.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">How good is Medicare?</h3>
      <p class="text-neutral-600 mb-0">
        Excellent—comprehensive public coverage for citizens/PR. Covers GP visits, public hospital, pharmaceuticals (PBS). Wait times for elective surgery in public. Private insurance provides faster access and choice. Medicare is solid foundation.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Is private health insurance worth it?</h3>
      <p class="text-neutral-600 mb-0">
        For seniors, often yes—faster access to elective procedures (hip, knee, cataracts), choice of specialist, private rooms. Lifetime Health Cover means starting early reduces loadings. Medicare Levy Surcharge applies to higher earners without private. Consider individual needs.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Is Australia affordable?</h3>
      <p class="text-neutral-600 mb-0">
        Moderate-high—major cities expensive but regional areas more affordable. Healthcare excellent value with Medicare. Budget A$4,000-7,000/month for comfortable living. Property expensive in Sydney/Melbourne. Not a budget destination but good value for quality of life.
      </p>
    </div>
  </div>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Ready to Compare Options?</h3>
    <p class="text-neutral-600 mb-4">Get quotes from providers with Australia coverage.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/cigna-global" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Cigna Quote</a>
      <a href="/go/allianz-care" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get Allianz Quote</a>
    </div>
  </div>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600 mb-0">
      <strong>Disclaimer:</strong> This guide is for informational purposes only. Insurance requirements, visa regulations, and healthcare access rules change regularly. Always verify current requirements with Australian authorities and consult with a licensed insurance professional.
    </p>
  </div>
</PageShell>
