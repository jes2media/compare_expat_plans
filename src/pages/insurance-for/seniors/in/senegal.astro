const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'XOF$261K-415K', annual: 'XOF$3.1M-5.0M' },
  { category: 'International Insurance (70-74)', monthly: 'XOF$358K-554K', annual: 'XOF$4.3M-6.6M' },
  { category: 'International Insurance (75-79)', monthly: 'XOF$482K-743K', annual: 'XOF$5.8M-8.9M' },
  { category: 'Private Hospital Visit', monthly: 'XOF$20K-50K/visit', annual: 'Affordable' },
  { category: 'Private Hospital Stay', monthly: 'XOF$75K-200K/day', annual: 'Per incident' },
