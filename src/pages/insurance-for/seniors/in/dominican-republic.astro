  { category: 'Private Clinic Visit', lowEstimate: '$40-60', midEstimate: '$60-100', highEstimate: '$100-200' },
  { category: 'Specialist Consultation', lowEstimate: '$60-100', midEstimate: '$100-150', highEstimate: '$150-250' },
  { category: 'Hospital Day (Private)', lowEstimate: '$300-500', midEstimate: '$500-800', highEstimate: '$800-1,500' },
  { category: 'Prescription Medications', lowEstimate: '30-50% US prices', midEstimate: '30-50% US prices', highEstimate: '30-50% US prices' },
