const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'CI$360-570', annual: 'CI$4,320-6,840' },
  { category: 'International Insurance (70-74)', monthly: 'CI$495-760', annual: 'CI$5,940-9,120' },
  { category: 'International Insurance (75-79)', monthly: 'CI$665-1,025', annual: 'CI$7,980-12,300' },
  { category: 'Local Insurance', monthly: 'CI$300-500/mo', annual: 'CI$3,600-6,000' },
  { category: 'Private Hospital Stay', monthly: 'CI$1,000-2,500/day', annual: 'Per incident' },
