  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: '$400-600', annual: '$4,800-7,200' },
  { category: 'International Insurance (70-74)', monthly: '$550-800', annual: '$6,600-9,600' },
  { category: 'International Insurance (75-79)', monthly: '$750-1,100', annual: '$9,000-13,200' },
  { category: 'Mexican Private Insurance', monthly: '$150-350', annual: '$1,800-4,200' },
  { category: 'IMSS (Public) Buy-in', monthly: '~$600/year', annual: '~$600 (annual fee)' },
