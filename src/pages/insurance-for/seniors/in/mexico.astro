const hospitalRows = [
  { hospital: 'Hospital Ángeles', location: 'Multiple cities', specialty: 'Full-service, English-speaking' },
  { hospital: 'Médica Sur', location: 'Mexico City', specialty: 'Complex procedures' },
  { hospital: 'Christus Muguerza', location: 'Northern Mexico', specialty: 'US-affiliated network' },
  { hospital: 'Star Médica', location: 'Multiple cities', specialty: 'Modern facilities' },
  { hospital: 'San Javier', location: 'Guadalajara/Chapala', specialty: 'Expat community access' },
