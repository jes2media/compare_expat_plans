  { key: 'renewal', header: 'Renewal' },
  { key: 'monthlyFrom', header: 'From (65-69)' },
  { key: 'estoniaFit', header: 'Estonia Fit' },
];

const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '€280-400/mo', estoniaFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: '€330-470/mo', estoniaFit: 'Excellent' },
  { provider: 'Allianz Care', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '€260-370/mo', estoniaFit: 'Very Good' },
  { provider: 'AXA Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: '€240-350/mo', estoniaFit: 'Very Good' },
