  { key: 'monthly', header: 'Monthly' },
  { key: 'annual', header: 'Annual' },
];

const costRows = [
  { category: 'International Insurance (65-69)', monthly: 'ALL 27,000-45,000', annual: 'ALL 324,000-540,000' },
  { category: 'International Insurance (70-74)', monthly: 'ALL 38,000-57,000', annual: 'ALL 456,000-684,000' },
  { category: 'International Insurance (75-79)', monthly: 'ALL 50,000-78,000', annual: 'ALL 600,000-936,000' },
  { category: 'Albanian Public', monthly: 'Tax-funded', annual: 'Limited access' },
  { category: 'Private Clinic Visit', monthly: 'Pay per visit', annual: 'ALL 2,000-6,000/visit' },
