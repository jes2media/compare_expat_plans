  { provider: 'Bupa Global', maxAge: '74', coverage: 'Premium', brazilNetwork: 'Major private networks', usAccess: 'Add-on available', annualCost: '$6,500-10,500' },
  { provider: 'Allianz Care', maxAge: '74', coverage: 'Comprehensive', brazilNetwork: 'Good urban coverage', usAccess: 'Available', annualCost: '$5,200-8,200' },
