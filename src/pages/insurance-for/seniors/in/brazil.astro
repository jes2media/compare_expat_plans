const costRows = [
  { category: 'International Health Insurance', lowEstimate: '$4,200/year', midEstimate: '$6,500/year', highEstimate: '$10,000+/year' },
  { category: 'Private Clinic Visit', lowEstimate: '$40-60', midEstimate: '$60-100', highEstimate: '$100-200' },
  { category: 'Specialist Consultation', lowEstimate: '$60-100', midEstimate: '$100-150', highEstimate: '$150-300' },
  { category: 'Hospital Day (Private)', lowEstimate: '$400-600', midEstimate: '$600-1,000', highEstimate: '$1,000-2,000' },
  { category: 'Prescription Medications', lowEstimate: '40-60% US prices', midEstimate: '40-60% US prices', highEstimate: '40-60% US prices' },
