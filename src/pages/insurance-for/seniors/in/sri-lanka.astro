const providerRows = [
  { provider: 'Cigna Global', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'LKR 95,000-135,000/mo', sriLankaFit: 'Excellent' },
  { provider: 'BUPA Global', entryAge: '79', renewal: 'Lifetime', monthlyFrom: 'LKR 110,000-158,000/mo', sriLankaFit: 'Excellent' },
  { provider: 'Now Health', entryAge: '74', renewal: 'Lifetime', monthlyFrom: 'LKR 85,000-122,000/mo', sriLankaFit: 'Very Good' },
