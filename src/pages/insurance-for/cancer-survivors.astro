const providerRows = [
  { provider: 'BUPA Global', cancerHandling: 'Case-by-case review', remissionReq: '5+ years preferred', notes: 'Best for complex histories' },
  { provider: 'Cigna Global', cancerHandling: 'Exclusion or decline', remissionReq: '5-10 years', notes: 'May review after exclusion period' },
  { provider: 'Allianz Care', cancerHandling: 'Full underwriting', remissionReq: '5+ years', notes: 'Clear documentation required' },
  { provider: 'AXA Global', cancerHandling: 'Case-by-case', remissionReq: '5+ years', notes: 'Premium loading common' },
  { provider: 'Aetna International', cancerHandling: 'Exclusion typical', remissionReq: '5-10 years', notes: 'Exclusion may lift over time' },
