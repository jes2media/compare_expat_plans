  { id: 'cancer-and-insurance', text: 'Cancer History and Insurance', level: 2 },
  { id: 'what-insurers-ask', text: 'What Insurers Will Ask', level: 2 },
  { id: 'coverage-options', text: 'Your Coverage Options', level: 2 },
  { id: 'provider-comparison', text: 'Provider Comparison', level: 2 },
  { id: 'improving-your-chances', text: 'Improving Your Chances', level: 2 },
  { id: 'country-considerations', text: 'Country Considerations', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Pre-existing Conditions', href: '/insurance-for/pre-existing-conditions' },
  { title: 'Insurance for Seniors', href: '/insurance-for/seniors' },
  { title: 'Insurance for Retirees', href: '/insurance-for/retirees' },
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
