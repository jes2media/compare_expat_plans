---
/**
 * Romania Freelancer/Digital Nomad Visa - Long-form CRO-optimized page
 * Digital Nomad Visa guide with insurance requirements for freelancers
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Romania", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Best Digital Nomad Insurance", href: "/best/digital-nomad-insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Portugal Freelancer Visa", href: "/visas/freelancer-visa/in/portugal" },
  { title: "Estonia Freelancer Visa", href: "/visas/freelancer-visa/in/estonia" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Minimum Income", details: "~€3,700-5,600/month", notes: "3x Romanian average salary" },
  { requirement: "Income History", details: "6 months documentation", notes: "Bank statements or payslips" },
  { requirement: "Work Arrangement", details: "Foreign employer or clients", notes: "Company outside Romania" },
  { requirement: "Health Insurance", details: "€30,000 minimum coverage", notes: "International or Romania-valid" },
  { requirement: "Accommodation", details: "Rental or property proof", notes: "Romanian address required" },
  { requirement: "Medical Certificate", details: "Health clearance", notes: "Recent medical exam" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "minimum", header: "Minimum Required" },
  { key: "recommended", header: "Recommended" },
];

const insuranceRows = [
  { feature: "Coverage Amount", minimum: "€30,000", recommended: "€100,000+" },
  { feature: "Coverage Area", minimum: "Romania", recommended: "Worldwide" },
  { feature: "Inpatient Care", minimum: "Required", recommended: "Unlimited" },
  { feature: "Emergency Care", minimum: "Required", recommended: "Included" },
  { feature: "Policy Duration", minimum: "Full visa period", recommended: "Annual renewable" },
  { feature: "Pre-existing Conditions", minimum: "Not specified", recommended: "Coverage available" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", type: "Nomad Insurance", price: "€45-85", strengths: "Budget-friendly, meets €30k minimum" },
  { provider: "Cigna Global", type: "International", price: "€200-400", strengths: "Comprehensive, large network" },
  { provider: "Allianz Care", type: "International", price: "€180-350", strengths: "Strong EU coverage" },
  { provider: "IMG Global", type: "International", price: "€150-300", strengths: "Flexible plans, good value" },
  { provider: "World Nomads", type: "Travel", price: "€80-150", strengths: "Adventure activities" },
  { provider: "Genki", type: "Nomad Insurance", price: "€60-120", strengths: "EU-based, simple" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$130 / ~€120", notes: "eVisa platform" },
  { item: "Health Insurance", amount: "€45-400/month", notes: "€30k minimum coverage" },
  { item: "Accommodation (Bucharest)", amount: "€400-800/month", notes: "City center apartment" },
  { item: "Accommodation (Cluj/Brasov)", amount: "€350-650/month", notes: "Popular nomad cities" },
  { item: "Living Expenses", amount: "€500-800/month", notes: "Food, transport, utilities" },
  { item: "Coworking Space", amount: "€80-200/month", notes: "Optional" },
  { item: "Tax (First 6 months)", amount: "€0", notes: "Tax exempt period" },
  { item: "Tax (Self-employed, after)", amount: "1-3%", notes: "Very favorable freelancer rate" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Register on eVisa platform", duration: "1 day", location: "evisa.mae.ro" },
  { step: "Submit online application", duration: "1 day", location: "eVisa platform" },
  { step: "Application processing", duration: "10-14 days", location: "Romanian authorities" },
  { step: "Receive visa approval", duration: "After processing", location: "Email/online" },
  { step: "Travel to Romania", duration: "After approval", location: "Romania" },
  { step: "Register residence", duration: "Within 30 days", location: "Local immigration office" },
];
---

<PageShell
  title="Romania Freelancer Visa 2026: Digital Nomad Requirements, Insurance & Guide"
  description="Complete guide to Romania's Digital Nomad Visa for freelancers. €3,700+/month income, €30,000 insurance minimum, 1% tax rate for freelancers, fast 10-14 day processing."
  headline="Romania Digital Nomad Visa for Freelancers: Requirements & Insurance Guide"
  subheadline="Everything you need to know about freelancing in Romania—income requirements, affordable €30,000 insurance minimum, incredibly low 1% freelancer tax rate, fast processing, and affordable Eastern European lifestyle."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Nomad Insurance"
  ctaButtonHref="/go/safetywing"
  heroBackgroundImage="/images/visas/digital-nomad-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Fast 10-14 Day Processing
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      1% Freelancer Tax Rate
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Romania's Digital Nomad Visa has emerged as one of Europe's most attractive options for freelancers, combining fast processing (10-14 days), affordable insurance requirements (€30,000 minimum), and an incredibly favorable 1% tax rate for self-employed professionals. Add in some of Europe's lowest living costs and fastest internet, and Romania deserves serious consideration.
    </p>

    <p class="mb-4">
      The income requirement—approximately 3x the Romanian average gross salary (~€3,700-5,600/month depending on current figures)—is higher than some alternatives. But the tax benefits more than compensate: first 6 months are tax-exempt, and after that, self-employed nomads can benefit from a flat 1-3% tax on earnings, one of the lowest rates in Europe.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Romania Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Digital Nomad Visa (Type D Long-Stay)</li>
        <li>• <strong>Income requirement:</strong> ~€3,700-5,600/month (3x average salary)</li>
        <li>• <strong>Health insurance:</strong> €30,000 minimum coverage</li>
        <li>• <strong>Duration:</strong> 1 year, renewable</li>
        <li>• <strong>Processing time:</strong> 10-14 days (one of the fastest)</li>
        <li>• <strong>Application fee:</strong> $130 (~€120)</li>
        <li>• <strong>Tax rate:</strong> 0% first 6 months; ~1% for self-employed after</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Romania for Freelancers?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Romania's Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Incredibly fast processing (10-14 days)</li>
          <li>✓ 1% tax rate for freelancers</li>
          <li>✓ First 6 months tax-exempt</li>
          <li>✓ Low €30,000 insurance requirement</li>
          <li>✓ Very affordable living costs</li>
          <li>✓ Excellent internet infrastructure</li>
          <li>✓ Growing tech/startup scene</li>
          <li>✓ eVisa online application</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Popular Nomad Destinations</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Bucharest:</strong> Capital, vibrant, affordable</li>
          <li>• <strong>Cluj-Napoca:</strong> Tech hub, university city</li>
          <li>• <strong>Brașov:</strong> Mountains, medieval charm</li>
          <li>• <strong>Timișoara:</strong> Cultural capital, West-facing</li>
          <li>• <strong>Sibiu:</strong> Historic, scenic, smaller</li>
          <li>• <strong>Constanța:</strong> Black Sea coast</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Internet advantage:</strong> Romania consistently ranks among Europe's top countries for internet speed. Bucharest and Cluj have some of the fastest and most affordable fiber connections globally—a major draw for remote workers who need reliable connectivity.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Romania is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €3,700+/month from foreign sources</li>
          <li>✓ Tax optimization is a priority (1% rate)</li>
          <li>✓ You want fast visa processing</li>
          <li>✓ You prefer very affordable living costs</li>
          <li>✓ Fast internet is essential for your work</li>
          <li>✓ You like mountains, nature, and culture</li>
          <li>✓ You're open to Eastern European adventure</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You earn less than €3,700/month</li>
          <li>• You prefer Western/Southern Europe</li>
          <li>• You need English-speaking environment</li>
          <li>• You want beach/Mediterranean lifestyle</li>
          <li>• You're uncomfortable with developing infrastructure</li>
          <li>• You prefer larger expat community</li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Tax highlight:</strong> Romania's 1% flat tax for micro-enterprises/freelancers (after the first 6 months exempt) is one of Europe's best deals. A freelancer earning €5,000/month pays roughly €50/month in Romanian tax—compare that to 30-50% in most Western European countries.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Romania's Digital Nomad Visa requires proof of income at roughly 3x the national average gross salary, plus standard documentation. The income threshold adjusts annually—verify the current requirement when applying.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Requirements</h3>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-amber-900 mb-3">Income Threshold Details:</h4>
      <ul class="space-y-2 text-amber-800">
        <li>• <strong>Requirement:</strong> 3x Romanian average gross monthly salary</li>
        <li>• <strong>2025-2026 estimate:</strong> ~€3,700-5,600/month (fluctuates)</li>
        <li>• <strong>Documentation:</strong> 6 months of bank statements or payslips</li>
        <li>• <strong>Source:</strong> Must be from employment/freelance with foreign entities</li>
        <li>• <strong>Platform income:</strong> Upwork, Fiverr, etc. qualifies</li>
        <li>• <strong>Multiple sources:</strong> Can combine foreign income streams</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Essential Documents</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Required Documents</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport</li>
          <li>• Completed application form</li>
          <li>• Employment contract or freelance agreements</li>
          <li>• 6 months income proof (bank statements)</li>
          <li>• Health insurance (€30,000 minimum)</li>
          <li>• Proof of accommodation</li>
          <li>• Medical certificate of health</li>
          <li>• Visa fee payment ($130)</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Document Notes</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Apply online via evisa.mae.ro</li>
          <li>• Documents may need translation</li>
          <li>• Contracts must show foreign employer</li>
          <li>• Accommodation: rental agreement works</li>
          <li>• Medical certificate: recent exam required</li>
          <li>• Processing: 10-14 days typically</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>eVisa convenience:</strong> Romania's online eVisa platform (evisa.mae.ro) makes application straightforward. You can complete the entire process online without visiting an embassy, though you may need to collect the visa from a Romanian consulate depending on your nationality.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">€30,000 Minimum Coverage</h3>
      <p class="text-green-800">
        Romania requires health insurance with at least €30,000 coverage—one of the lower thresholds among European digital nomad visas. This makes budget nomad insurance options like SafetyWing viable, though comprehensive international insurance provides better protection.
      </p>
    </div>

    <p class="mb-4">
      The €30,000 minimum is achievable with most nomad insurance products, making Romania more accessible than countries requiring €100,000+ coverage. However, the minimum may not provide adequate protection for serious medical situations.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Insurance Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Budget Options (Meet Minimum)</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ SafetyWing Nomad Insurance (~€45-85/month)</li>
          <li>✓ World Nomads (~€80-150/month)</li>
          <li>✓ Genki (~€60-120/month)</li>
          <li>✓ Most travel medical insurance</li>
          <li>Note: Verify €30k coverage explicitly</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Comprehensive Options (Recommended)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Cigna Global (~€200-400/month)</li>
          <li>✓ Allianz Care (~€180-350/month)</li>
          <li>✓ IMG Global (~€150-300/month)</li>
          <li>✓ Higher coverage limits</li>
          <li>Better for long-term residence</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Coverage consideration:</strong> While €30,000 meets visa requirements, serious medical events can easily exceed this. A week in ICU or emergency surgery could cost €50,000+. Consider whether budget insurance provides adequate protection for your risk tolerance.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for Romania's digital nomad visa?"
    description="Compare options meeting the €30,000 minimum—from budget nomad insurance to comprehensive coverage."
    buttonText="Compare Nomad Insurance"
    buttonHref="/go/safetywing"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Romania's €30,000 minimum opens the door to budget nomad insurance options. Choose based on your coverage needs, travel plans, and risk tolerance.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Budget: SafetyWing</h4>
        <p class="text-neutral-600">SafetyWing Nomad Insurance meets Romania's €30,000 requirement at €45-85/month. Popular among digital nomads for its flexibility and low cost. Good for younger, healthy individuals comfortable with basic coverage.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Value: IMG Global</h4>
        <p class="text-neutral-600">IMG Global offers flexible plans at competitive prices (€150-300/month). Good balance between cost and comprehensive coverage. Strong for those wanting more than minimum but not premium pricing.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Comprehensive: Cigna Global</h4>
        <p class="text-neutral-600">For those wanting premium coverage, Cigna Global provides unlimited coverage options and large network. Higher cost (€200-400/month) but peace of mind for longer stays or health concerns.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Romania offers some of Europe's lowest living costs while maintaining modern infrastructure and amenities. Combined with the 1% tax rate, your money goes significantly further than in Western Europe.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Budget Examples</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Lifestyle</p>
        <p class="text-3xl font-bold text-neutral-900">€1,000-1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Shared flat, basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500-2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Own apartment, coworking</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium</p>
        <p class="text-3xl font-bold text-neutral-900">€2,500-3,500</p>
        <p class="text-sm text-neutral-500 mt-2">Central location, all amenities</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Tax Benefits (The Big Advantage)</h3>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">Romania's Freelancer Tax Regime:</h4>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>First 6 months:</strong> Tax exempt on foreign salary income</li>
        <li>• <strong>After 183 days (tax resident):</strong> Subject to Romanian tax</li>
        <li>• <strong>Self-employed rate:</strong> ~1-3% flat tax on turnover</li>
        <li>• <strong>Micro-enterprise:</strong> 1% on revenue (if registered)</li>
        <li>• <strong>Social contributions:</strong> Optional for digital nomads</li>
        <li>• <strong>Comparison:</strong> Western Europe often 30-50%+ tax</li>
      </ul>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Tax math example:</strong> A freelancer earning €5,000/month in France might pay €1,500-2,000/month in taxes. The same freelancer in Romania, after the initial 6-month exemption, pays approximately €50-150/month. Annual savings: €15,000-22,000+.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Romania's eVisa system makes application straightforward. The 10-14 day processing time is one of Europe's fastest, and the online platform eliminates embassy visits for most applicants.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect 6 months of income proof (bank statements/payslips), employment contract or freelance agreements showing foreign employer/clients, passport, and medical certificate.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
