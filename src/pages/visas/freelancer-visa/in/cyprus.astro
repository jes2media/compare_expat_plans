  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-3 weeks", location: "Home country" },
  { step: "Apostille and translate", duration: "1-2 weeks", location: "Home country" },
  { step: "Apply for visa (consulate or in-country)", duration: "1 day", location: "Cyprus consulate or Civil Registry" },
  { step: "Visa processing", duration: "5-7 weeks", location: "Civil Registry processes" },
  { step: "Receive approval notification", duration: "After processing", location: "Email/mail" },
  { step: "Travel to Cyprus (if applied abroad)", duration: "Upon approval", location: "Cyprus" },
  { step: "Apply for Alien Registration Certificate", duration: "Within 7 days of arrival", location: "Civil Registry" },
  { step: "Receive ARC (residence card)", duration: "2-4 weeks", location: "Cyprus" },
];
---

<PageShell
  title="Cyprus Freelancer Visa 2026: Digital Nomad Visa Requirements, Insurance & Guide"
  description="Complete guide to Cyprus Digital Nomad Visa for freelancers. €3,500/month income, up to 3 years, English-speaking, Mediterranean lifestyle, and step-by-step application process."
  headline="Cyprus Freelancer Visa: Digital Nomad Visa Insurance & Requirements Guide"
  subheadline="Everything you need to know about freelancing in Cyprus—€3,500/month income requirement, up to 3 years stay, English as official language, non-dom tax benefits, and Mediterranean island living."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Freelancer Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/visas/digital-nomad-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      English Official Language
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Up to 3 Years Stay
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Cyprus offers one of the most appealing digital nomad visas in the EU—up to 3 years of stay, English as an official language, Mediterranean climate, and favorable tax treatment for non-domiciled residents. The island's strategic location between Europe, Middle East, and Africa makes it attractive for remote workers serving clients across multiple time zones.
    </p>

    <p class="mb-4">
      Launched in early 2022 and refreshed with new quotas in 2025, the Cyprus Digital Nomad Visa targets IT professionals, digital consultants, freelancers, and entrepreneurs who work remotely for companies or clients located abroad. The program has proven popular, prompting Cyprus to increase the annual cap to 1,000 permits.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Cyprus Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Digital Nomad Residence Permit</li>
        <li>• <strong>Income requirement:</strong> €3,500/month net (+20% spouse, +15% child)</li>
        <li>• <strong>Health insurance:</strong> MANDATORY—comprehensive coverage for entire stay</li>
        <li>• <strong>Duration:</strong> 1 year, renewable up to 3 years total</li>
        <li>• <strong>Language:</strong> English is official (along with Greek)</li>
        <li>• <strong>Quota:</strong> 1,000 permits total (500 original + 500 added March 2025)</li>
        <li>• <strong>Tax status:</strong> Non-dom benefits available (no SDC on passive income)</li>
        <li>• <strong>Work restriction:</strong> Cannot work for Cypriot companies/clients</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Digital Nomad Visa vs. Standard Work Permit</h3>

    <p class="mb-4">
      Cyprus offers different pathways depending on whether you work remotely for foreign entities or seek local employment. The DNV is specifically designed for location-independent workers.
    </p>

    <ComparisonTable columns={visaTypesColumns} rows={visaTypesRows} />

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Critical restriction:</strong> Digital nomad visa holders cannot work for Cypriot employers or provide services to residents of Cyprus. Your clients and income must come entirely from abroad. Violating this rule can result in visa revocation and potential deportation.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Cyprus is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want an English-speaking EU country</li>
          <li>✓ You earn €3,500+/month from foreign clients</li>
          <li>✓ You want up to 3 years of stay</li>
          <li>✓ You prefer Mediterranean climate</li>
          <li>✓ You value British-style legal/business systems</li>
          <li>✓ You want non-dom tax benefits</li>
          <li>✓ You work across EU, Middle East, or US time zones</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Your income is below €3,500/month</li>
          <li>• You need Schengen Zone access (Cyprus is not Schengen)</li>
          <li>• You want lower living costs (try Bulgaria, Romania)</li>
          <li>• You prefer larger cities with nightlife</li>
          <li>• You need to work with local clients</li>
          <li>• You want guaranteed approval (quota system applies)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Schengen note:</strong> Cyprus is an EU member but not part of the Schengen Area. Your Cyprus DNV doesn't grant automatic travel access to Schengen countries—you'll need separate visas or rely on your passport's Schengen allowance (typically 90 days per 180 days for many nationalities).
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Cyprus's DNV has straightforward requirements centered on income, remote work proof, and comprehensive health insurance. The €3,500/month threshold is higher than some EU alternatives but reasonable for established professionals.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Family Income Requirements</h3>

    <p class="mb-4">
      Unlike some DNV programs, Cyprus allows family members to join you. Income requirements increase for each dependent—plan your finances accordingly.
    </p>

    <ComparisonTable columns={familyColumns} rows={familyRows} />

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mt-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">Important Family Rules:</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Spouse/Partner:</strong> Can accompany but cannot work in Cyprus</li>
        <li>• <strong>Children:</strong> Underage children included, cannot work</li>
        <li>• <strong>Income proof:</strong> Must show €3,500 base plus increases for each member</li>
        <li>• <strong>Insurance:</strong> Each family member needs comprehensive coverage</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Essential Documents</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">For Application</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport (6+ months validity)</li>
          <li>• Completed application form</li>
          <li>• Passport photos (biometric)</li>
          <li>• Employment contract (1+ year) or freelance contracts</li>
          <li>• Proof of income (bank statements)</li>
          <li>• Health insurance certificate</li>
          <li>• Criminal record certificate (apostilled)</li>
          <li>• Proof of accommodation in Cyprus</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Document Specifications</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Documents apostilled or legalized</li>
          <li>• Translations into Greek or English</li>
          <li>• Employment contract from non-EU/EEA company</li>
          <li>• Criminal record from country of citizenship AND residence</li>
          <li>• Insurance covering Cyprus specifically</li>
          <li>• Rental contract or property deed</li>
          <li>• Recent bank statements (3-6 months)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Contract requirement:</strong> Your employment contract or freelance agreement must have a minimum duration of one year. If you're a freelancer with multiple shorter contracts, aggregate them to show ongoing work—include client recommendations to strengthen your application.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        Cyprus requires valid health insurance covering your entire duration of stay. The insurance must provide comprehensive coverage including hospitalization, outpatient care, and repatriation. International health insurance is the standard choice for DNV applicants.
      </p>
    </div>

    <p class="mb-4">
      Basic travel insurance typically won't satisfy Cyprus's requirements. You need annual, renewable coverage that demonstrates you won't become a burden on the Cypriot healthcare system.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Travel vs. International Health Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance for Families</h3>

    <p class="mb-4">
      Each family member on your application needs their own health insurance coverage. International family plans from providers like Cigna Global or Allianz Care can cover the entire family under one policy, often with better rates than individual plans.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Choose International Health Insurance If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ You're staying 1-3 years</li>
          <li>✓ You want routine care included</li>
          <li>✓ You have family members on the visa</li>
          <li>✓ You may have pre-existing conditions</li>
          <li>✓ You value English-language support</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Travel Insurance Limitations:</h4>
        <ul class="space-y-2 text-amber-800">
          <li>△ Unlikely to meet visa requirements</li>
          <li>△ Coverage gaps for long stays</li>
          <li>△ Emergency-only coverage</li>
          <li>△ No pre-existing condition coverage</li>
          <li>△ Renewal complications</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Recommendation:</strong> For Cyprus's 1-3 year DNV, proper international health insurance is essential. Budget €150-350/month for a single person, or explore family plans if bringing dependents. The investment ensures smooth visa processing and quality healthcare access.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Cyprus digital nomad visa?"
    description="Compare international health insurance plans accepted for Cyprus DNV applications."
    buttonText="Compare Freelancer Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Cyprus's DNV, you need comprehensive international health insurance that covers the full visa duration. These providers are well-established in Cyprus and understood by immigration authorities.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Solo Professional, Full-Time in Cyprus</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care provide comprehensive coverage with good Cyprus networks. Budget €180-340/month for solid protection including routine care, specialists, and hospitalization in private facilities.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Family Relocating Together</h4>
        <p class="text-neutral-600">Family plans from Cigna Global, Allianz Care, or Bupa Global cover everyone under one policy. This simplifies administration and often costs less than separate individual plans. Expect €400-700/month for a family of four.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US-Based Remote Worker</h4>
        <p class="text-neutral-600">Aetna International or Cigna Global are familiar to US applicants and provide strong global coverage. If you travel back to the US regularly, ensure your plan includes US coverage (may cost extra).</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Discuss your conditions during the quote process. Cigna Global and Allianz Care may cover pre-existing conditions after waiting periods. Full disclosure is essential—undisclosed conditions can void your policy.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Cyprus has moderate living costs compared to Western Europe, though it's more expensive than Eastern European alternatives like Bulgaria or Romania. The main cities for digital nomads—Limassol, Nicosia, and Paphos—have different price points.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Non-Domicile (Non-Dom) Tax Benefits</h3>

    <p class="mb-4">
      Cyprus offers significant tax advantages for non-domiciled residents. If you qualify as a non-dom (most new arrivals do for their first 17 years), you're exempt from the Special Defence Contribution (SDC) on passive income like dividends, interest, and rental income.
    </p>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">Non-Dom Tax Advantages:</h4>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>SDC exemption:</strong> No Special Defence Contribution on dividends, interest, rental income</li>
        <li>• <strong>Employment income:</strong> Progressive rates up to 35% (but first €19,500 tax-free)</li>
        <li>• <strong>Non-dom period:</strong> First 17 years in Cyprus</li>
        <li>• <strong>Tax residency:</strong> Triggered at 60 days under certain conditions (or standard 183 days)</li>
        <li>• <strong>No wealth tax:</strong> Cyprus doesn't tax net worth</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Realistic Monthly Budget by City</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Paphos (Budget-Friendly)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,600-2,200</p>
        <p class="text-sm text-neutral-500 mt-2">Coastal resort town</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Nicosia (Capital)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,800-2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Business center</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Limassol (Popular)</p>
        <p class="text-3xl font-bold text-neutral-900">€2,200-3,200</p>
        <p class="text-sm text-neutral-500 mt-2">Expat hub, beach access</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost Breakdown (Limassol)</h3>

