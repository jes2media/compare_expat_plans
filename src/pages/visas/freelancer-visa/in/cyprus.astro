const visaTypesColumns = [
  { key: "feature", header: "Feature" },
  { key: "dnv", header: "Digital Nomad Visa" },
  { key: "employment", header: "Standard Work Permit" },
];

const visaTypesRows = [
  { feature: "Income Requirement", dnv: "€3,500/month net", employment: "Varies by position" },
  { feature: "Employer Location", dnv: "Foreign only", employment: "Cypriot employer" },
  { feature: "Duration", dnv: "1 year, renewable to 3", employment: "Tied to contract" },
  { feature: "Work Restriction", dnv: "Cannot work for Cyprus companies", employment: "Must work for sponsoring employer" },
  { feature: "Family Inclusion", dnv: "Yes (+20% spouse, +15% per child)", employment: "Yes, on dependent visa" },
  { feature: "Quota System", dnv: "Yes (1,000 total permits)", employment: "No quota" },
  { feature: "Best For", dnv: "Remote workers, freelancers", employment: "Traditional employment" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Minimum Income", details: "€3,500/month net", notes: "+20% for spouse, +15% per child" },
  { requirement: "Work Type", details: "Remote work for foreign entities", requirements: "IT, consulting, freelance" },
  { requirement: "Contract Duration", details: "1+ year employment or freelance", notes: "Must show ongoing work" },
  { requirement: "Health Insurance", details: "Full coverage in Cyprus", notes: "Entire stay duration" },
  { requirement: "Accommodation", details: "Rental or property proof", notes: "Cypriot address required" },
  { requirement: "Criminal Record", details: "Clean background check", notes: "Apostilled, recent" },
  { requirement: "No Cyprus Work", details: "Cannot serve Cypriot market", notes: "Foreign clients only" },
];

const familyColumns = [
  { key: "member", header: "Family Member" },
  { key: "incomeIncrease", header: "Income Requirement" },
  { key: "notes", header: "Notes" },
];

const familyRows = [
  { member: "Main Applicant", incomeIncrease: "€3,500/month", notes: "Base requirement" },
  { member: "Spouse/Partner", incomeIncrease: "+€700/month (+20%)", notes: "Total: €4,200/month" },
  { member: "First Child", incomeIncrease: "+€525/month (+15%)", notes: "Total: €4,725/month" },
  { member: "Second Child", incomeIncrease: "+€525/month (+15%)", notes: "Total: €5,250/month" },
  { member: "Family of 4", incomeIncrease: "€5,250/month minimum", notes: "All included" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "travel", header: "Travel Insurance" },
  { key: "international", header: "International Health Insurance" },
];

const insuranceRows = [
  { feature: "Visa Acceptance", travel: "May not qualify", international: "Fully accepted" },
  { feature: "Coverage Duration", travel: "30-90 days", international: "Annual renewable" },
  { feature: "Inpatient Coverage", travel: "Limited", international: "Comprehensive" },
  { feature: "Outpatient Care", travel: "Emergency only", international: "Full coverage" },
  { feature: "Pre-existing Conditions", travel: "Never covered", international: "Varies by plan" },
  { feature: "Monthly Cost", travel: "€30-80", international: "€120-350" },
  { feature: "Recommendation", travel: "Not sufficient", international: "Required for DNV" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€180-380", strengths: "Comprehensive coverage, Cyprus network" },
  { provider: "Allianz Care", type: "International", price: "€160-340", strengths: "Strong EU coverage, flexible plans" },
  { provider: "Bupa Global", type: "International", price: "€200-420", strengths: "Premium service, global network" },
  { provider: "AXA Global", type: "International", price: "€150-320", strengths: "Good value, solid coverage" },
  { provider: "Aetna International", type: "International", price: "€170-350", strengths: "US-friendly, comprehensive" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€70", notes: "Initial application" },
  { item: "Alien Registration (ARC)", amount: "€70", notes: "Per person" },
  { item: "Health Insurance", amount: "€150-350/month", notes: "International required" },
  { item: "Rent (Limassol/Nicosia)", amount: "€800-1,500/month", notes: "1-2 bedroom apartment" },
  { item: "Utilities", amount: "€100-200/month", notes: "Electricity, water, internet" },
  { item: "Living Expenses", amount: "€600-1,000/month", notes: "Food, transport, leisure" },
  { item: "Total Monthly (Single)", amount: "€1,800-3,000", notes: "Comfortable lifestyle" },
];

