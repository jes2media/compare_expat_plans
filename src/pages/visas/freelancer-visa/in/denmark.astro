---
/**
 * Denmark Freelancer Visa - Long-form CRO-optimized page
 * Startup Denmark programme guide with insurance requirements
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Denmark", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Sweden Freelancer Visa", href: "/visas/freelancer-visa/in/sweden" },
  { title: "Germany Freelancer Visa", href: "/visas/freelancer-visa/in/germany" },
  { title: "Netherlands Freelancer Visa", href: "/visas/freelancer-visa/in/netherlands" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Business Approval", details: "Danish Business Authority", notes: "Must approve business idea first" },
  { requirement: "Business Type", details: "Innovative & scalable", notes: "Restaurants/retail typically rejected" },
  { requirement: "Annual Cap", details: "75 permits/year", notes: "Highly competitive" },
  { requirement: "Financial Proof", details: "DKK 140,000+ (~€18,800)", notes: "Varies by family size" },
  { requirement: "With Children", details: "DKK 203,664 (~€27,300)", notes: "If children accompany" },
  { requirement: "Health Insurance", details: "Required for visa", notes: "Until CPR registration" },
  { requirement: "Work Restriction", details: "Only your approved business", notes: "No side jobs without permit" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "private", header: "Private International" },
  { key: "danish", header: "Danish Public System" },
];

const insuranceRows = [
  { feature: "When Required", private: "Visa application + first months", danish: "After CPR registration" },
  { feature: "Coverage Scope", private: "Comprehensive", danish: "Universal, tax-funded" },
  { feature: "Pre-existing Conditions", private: "Varies by plan", danish: "Fully covered" },
  { feature: "Monthly Cost", private: "€120-300", danish: "Tax-funded (free at point of use)" },
  { feature: "GP Visit", private: "Covered after deductible", danish: "Free" },
  { feature: "Specialist", private: "Covered", danish: "Free with referral" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€140-300", strengths: "Transition coverage, global network" },
  { provider: "Allianz Care", type: "International", price: "€130-280", strengths: "Strong Nordic coverage" },
  { provider: "Tryg", type: "Danish Insurer", price: "€80-180", strengths: "Local Danish expertise" },
  { provider: "SafetyWing", type: "Nomad Insurance", price: "€65-120", strengths: "Budget-friendly initial coverage" },
  { provider: "Danish Public", type: "Sygesikring", price: "Tax-funded", strengths: "After CPR, comprehensive" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Application Fee", amount: "DKK 1,890 (~€253)", notes: "Startup Denmark fee" },
  { item: "Financial Requirement (Single)", amount: "DKK 140,000+ (~€18,800)", notes: "Self-support for permit period" },
  { item: "Financial Requirement (Family)", amount: "DKK 203,664 (~€27,300)", notes: "With children" },
  { item: "Health Insurance (Initial)", amount: "€120-300/month", notes: "Until CPR registration" },
  { item: "Rent (Copenhagen)", amount: "DKK 12,000-18,000/month", notes: "€1,600-2,400, 1BR" },
  { item: "Rent (Other Cities)", amount: "DKK 8,000-12,000/month", notes: "€1,100-1,600" },
  { item: "Living Expenses", amount: "DKK 6,000-10,000/month", notes: "€800-1,350, food/transport" },
  { item: "Total Monthly (Single)", amount: "€2,500-4,000", notes: "Copenhagen lifestyle" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Prepare business plan", duration: "2-4 weeks", location: "Home country" },
  { step: "Submit to Danish Business Authority", duration: "1 day", location: "Online" },
  { step: "Business Authority evaluation", duration: "2-4 weeks", location: "Denmark" },
  { step: "Apply for residence permit (SIRI)", duration: "After approval", location: "Online/Embassy" },
  { step: "SIRI processing", duration: "~1 month", location: "SIRI" },
  { step: "Receive permit & move", duration: "After approval", location: "Denmark" },
  { step: "Register for CPR number", duration: "After arrival", location: "Borgerservice" },
];
---

<PageShell
  title="Denmark Freelancer Visa 2026: Startup Denmark Requirements, Insurance & Guide"
  description="Complete guide to Denmark's Startup Denmark programme. 75 annual permits, innovative business required, 1-month processing, Danish Business Authority approval, and path to permanent residency."
  headline="Denmark Freelancer Visa: Startup Denmark Insurance & Requirements Guide"
  subheadline="Everything you need to know about freelancing in Denmark—Startup Denmark programme, 75 annual permit cap, innovative business requirement, world's happiest workforce, and Scandinavian quality of life."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Freelancer Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/visas/digital-nomad-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      75 Permits Per Year
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      1-Month Processing
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Denmark doesn't have a digital nomad visa—non-EU entrepreneurs use the Startup Denmark programme to establish innovative, scalable businesses. This is an exclusive route: only 75 permits are issued per year, and your business idea must be approved by the Danish Business Authority before you can even apply for the residence permit.
    </p>

    <p class="mb-4">
      Denmark consistently ranks among the world's happiest countries, with excellent work-life balance, strong social benefits, and a thriving startup ecosystem in Copenhagen. The trade-off is strict eligibility requirements, high costs, and limited spots.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Startup Denmark Programme</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Startup Denmark residence and work permit</li>
        <li>• <strong>Annual cap:</strong> 75 permits per year (highly competitive)</li>
        <li>• <strong>Business requirement:</strong> Innovative, scalable concept</li>
        <li>• <strong>First step:</strong> Danish Business Authority approval</li>
        <li>• <strong>Financial proof:</strong> DKK 140,000-203,664 (~€18,800-27,300)</li>
        <li>• <strong>Duration:</strong> 2 years initial, 3-year extensions</li>
        <li>• <strong>Processing:</strong> ~1 month (after business approval)</li>
        <li>• <strong>Work restriction:</strong> Only your approved business</li>
        <li>• <strong>Schengen access:</strong> Yes—travel freely in Schengen Zone</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">What Qualifies as "Innovative"?</h3>

    <p class="mb-4">
      The Danish Business Authority evaluates your business idea through an expert panel. They're looking for genuine innovation and growth potential—not traditional businesses.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Typically rejected:</strong> Restaurants, retail shops, cafés, small import/export businesses, consulting without innovation, traditional service businesses. The panel wants tech startups, innovative products, or scalable business models—not lifestyle businesses.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Denmark is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You have a genuinely innovative business idea</li>
          <li>✓ Your business is scalable (not lifestyle)</li>
          <li>✓ You can compete for 75 annual spots</li>
          <li>✓ You have DKK 140,000+ savings</li>
          <li>✓ You value work-life balance</li>
          <li>✓ You appreciate Scandinavian design/culture</li>
          <li>✓ You can handle high living costs</li>
          <li>✓ You want excellent social benefits</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Your business is traditional (restaurant, retail)</li>
          <li>• You're a pure freelancer/consultant</li>
          <li>• You want guaranteed approval</li>
          <li>• High costs are a concern</li>
          <li>• You need to take side jobs</li>
          <li>• You prefer warmer climate</li>
          <li>• You can't handle dark winters</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>75 spot competition:</strong> With only 75 permits per year, Startup Denmark is highly selective. Your business idea competes against other applicants globally. Strong, innovative concepts with clear Danish market potential have the best chances.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Startup Denmark has a two-stage process: first your business idea must be approved by the Danish Business Authority, then you apply for the residence permit through SIRI (Danish Agency for International Recruitment and Integration).
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Business Approval Criteria</h3>

    <p class="mb-4">
      An expert panel evaluates your business idea. They assess innovation, scalability, and your ability to execute. This isn't a rubber stamp—many applications are rejected.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">What the Panel Evaluates:</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Innovation:</strong> Is this genuinely new or significantly improved?</li>
        <li>• <strong>Scalability:</strong> Can this grow beyond a small business?</li>
        <li>• <strong>Market potential:</strong> Is there demand for this product/service?</li>
        <li>• <strong>Team capability:</strong> Can you execute this business plan?</li>
        <li>• <strong>Danish relevance:</strong> Why Denmark specifically?</li>
        <li>• <strong>Growth trajectory:</strong> What's the path to significant revenue?</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Financial Requirements</h3>

    <p class="mb-4">
      You must prove financial self-sufficiency for the permit period. The amount depends on family composition:
    </p>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Single Applicant</p>
        <p class="text-2xl font-bold text-neutral-900">DKK 140,000+</p>
        <p class="text-sm text-neutral-500 mt-2">~€18,800</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With Spouse</p>
        <p class="text-2xl font-bold text-neutral-900">Higher amount</p>
        <p class="text-sm text-neutral-500 mt-2">Check current rates</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With Children</p>
        <p class="text-2xl font-bold text-neutral-900">DKK 203,664</p>
        <p class="text-sm text-neutral-500 mt-2">~€27,300</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Required Documents</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Business Authority Application</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Detailed business plan</li>
          <li>• Innovation explanation</li>
          <li>• Market analysis</li>
          <li>• Financial projections</li>
          <li>• Team/founder background</li>
          <li>• Scalability roadmap</li>
          <li>• Why Denmark rationale</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">SIRI Residence Permit</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Business Authority approval letter</li>
          <li>• Valid passport</li>
          <li>• Bank statements (financial proof)</li>
          <li>• Health insurance certificate</li>
          <li>• Passport photos</li>
          <li>• Application fee (DKK 1,890)</li>
          <li>• Biometrics (at embassy if abroad)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Work restriction:</strong> Your permit only allows work in your approved business. You cannot take side jobs, freelance gigs, or employment without applying for a separate permit. This limits flexibility compared to some other countries.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Private Insurance → Danish Public System</h3>
      <p class="text-green-800">
        Health insurance is required for your visa application. After arriving and registering for a CPR number (Danish personal ID), you access Denmark's universal healthcare system for free. Plan for 1-3 months of private coverage during transition.
      </p>
    </div>

    <p class="mb-4">
      Denmark has universal, tax-funded healthcare. Once registered with a CPR number, you get a yellow health insurance card (sundhedskort) giving access to free GP visits, hospital care, and specialists with referral.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Private vs. Danish Public System</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Danish Healthcare System</h3>

    <p class="mb-4">
      Denmark's healthcare is excellent and entirely free at point of use for registered residents. The system is GP-led—you register with a local doctor who refers you to specialists.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">What's Covered (After CPR Registration):</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>GP visits:</strong> Free (unlimited)</li>
        <li>• <strong>Specialists:</strong> Free (with GP referral)</li>
        <li>• <strong>Hospital care:</strong> Free (including surgery)</li>
        <li>• <strong>Maternity:</strong> Fully covered</li>
        <li>• <strong>Mental health:</strong> Covered with referral</li>
        <li>• <strong>Prescriptions:</strong> Partially subsidized</li>
        <li>• <strong>Dental:</strong> Not covered for adults (pay privately)</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Dental not covered:</strong> Unlike medical care, adult dental is not covered by the Danish system. Budget for private dental insurance or out-of-pocket costs. Children's dental is partially covered.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Startup Denmark application?"
    description="Compare international health insurance plans for your visa application and transition period."
    buttonText="Compare Freelancer Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      You need comprehensive health insurance for the visa application. After getting your CPR number, you'll switch to the free Danish public system.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Visa Application Phase</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care provide comprehensive coverage accepted for visa applications. Budget €130-300/month for 1-3 months until CPR registration.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Danish Insurer Option</h4>
        <p class="text-neutral-600">Tryg (Denmark's largest insurer) offers expat-focused coverage with local expertise. Good coordination with Danish healthcare system during transition.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Option</h4>
        <p class="text-neutral-600">SafetyWing offers nomad coverage at €65-120/month. Verify it meets Danish visa requirements for minimum coverage levels.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">After CPR Registration</h4>
        <p class="text-neutral-600">Once you have your yellow card (sundhedskort), basic healthcare is free. Many expats add private "sundhedsforsikring" (€30-80/month) for faster private access or dental coverage.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Denmark is one of the world's most expensive countries. Copenhagen regularly ranks among the priciest cities globally. High costs come with high quality of life—excellent infrastructure, safety, and social benefits.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Tax Considerations</h3>

    <p class="mb-4">
      Danish taxes are high but fund comprehensive social benefits. As a startup founder, you'll pay corporate tax on company profits and personal income tax on salary/dividends.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">Danish Tax System:</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Corporate tax:</strong> 22% flat rate</li>
        <li>• <strong>Personal income tax:</strong> ~37-52% (progressive)</li>
        <li>• <strong>VAT:</strong> 25% (moms)</li>
        <li>• <strong>Researcher tax scheme:</strong> 27% flat rate (if eligible)</li>
        <li>• <strong>Benefits:</strong> Free healthcare, education, generous parental leave</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Budget</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget (Outside Copenhagen)</p>
        <p class="text-2xl font-bold text-neutral-900">€1,800-2,400</p>
        <p class="text-sm text-neutral-500 mt-2">Aarhus, Odense</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable (Copenhagen)</p>
        <p class="text-2xl font-bold text-neutral-900">€2,800-3,800</p>
        <p class="text-sm text-neutral-500 mt-2">Own apartment</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Living</p>
        <p class="text-3xl font-bold text-neutral-900">€4,000+</p>
        <p class="text-sm text-neutral-500 mt-2">Central Copenhagen</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Copenhagen housing crisis:</strong> Finding rental apartments in Copenhagen is extremely difficult. Waiting lists can be years long. Most newcomers use short-term rentals, subletting, or buy property. Budget significant time and money for housing search.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Startup Denmark is a two-stage process: first get business approval, then apply for residence permit. Total timeline is typically 2-3 months.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Develop Your Business Concept</h4>
          <p class="text-neutral-600">Create a compelling business plan demonstrating innovation, scalability, and Danish market potential. The expert panel will evaluate this—make it strong. Include market research, financial projections, and team background.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit to Danish Business Authority</h4>
          <p class="text-neutral-600">Apply through the Startup Denmark programme website. Your business idea goes to an expert panel for evaluation. This typically takes 2-4 weeks. The panel meets periodically to review applications.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Business Approval</h4>
          <p class="text-neutral-600">If approved, you receive confirmation allowing you to proceed with the residence permit application. If rejected, you can revise and reapply, but there's no guarantee of success.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Residence Permit (SIRI)</h4>
          <p class="text-neutral-600">Submit your residence permit application to SIRI with the business approval, financial proof, health insurance, and passport. Pay the DKK 1,890 fee. Processing takes approximately 1 month.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Biometrics & Permit Issuance</h4>
          <p class="text-neutral-600">If applying from abroad, provide biometrics at the Danish embassy. Once approved, you receive a residence permit valid for 2 years with work permission limited to your approved business.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Move & Register in Denmark</h4>
          <p class="text-neutral-600">Arrive in Denmark. Register at the local Borgerservice (citizen service center) for your CPR number. This personal ID unlocks healthcare, banking, phone contracts, and full participation in Danish society.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Build Your Business</h4>
          <p class="text-neutral-600">Register your company (ApS or IVS), open a business bank account, and start operations. Connect with the Copenhagen startup ecosystem—Founders House, Copenhagen Fintech, industry meetups.</p>
        </div>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Extension:</strong> After 2 years, you can extend for 3-year periods if your business remains active and viable. After sufficient time, you can apply for permanent residence.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
