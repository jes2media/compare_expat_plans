---
/**
 * Croatia Freelancer/Digital Nomad Visa - Long-form CRO-optimized page
 * Digital Nomad Visa guide with insurance requirements for freelancers
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Croatia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Best Digital Nomad Insurance", href: "/best/digital-nomad-insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Spain Freelancer Visa", href: "/visas/freelancer-visa/in/spain" },
  { title: "Portugal Freelancer Visa", href: "/visas/freelancer-visa/in/portugal" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Minimum Income", details: "€3,295/month (~€39,540/year)", notes: "2.5x Croatian average salary" },
  { requirement: "Bank Statements", details: "6 months required", notes: "Must show consistent income" },
  { requirement: "Remote Work Proof", details: "Employment or client contracts", notes: "Foreign companies/clients only" },
  { requirement: "Health Insurance", details: "Full duration coverage", notes: "Must be valid in Croatia" },
  { requirement: "Accommodation", details: "Rental or ownership proof", notes: "Croatian address required" },
  { requirement: "Criminal Record", details: "Clean background check", notes: "Apostilled from home country" },
  { requirement: "Family Members", details: "+10% income per dependent", notes: "Each needs own insurance" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "travel", header: "Travel Insurance" },
  { key: "international", header: "International Health" },
];

const insuranceRows = [
  { feature: "Visa Acceptance", travel: "May be accepted", international: "Fully accepted" },
  { feature: "Coverage Duration", travel: "Usually 90-180 days", international: "Annual policies" },
  { feature: "Monthly Cost", travel: "€50-100", international: "€150-350" },
  { feature: "Pre-existing Conditions", travel: "Usually excluded", international: "Varies by plan" },
  { feature: "Outpatient Care", travel: "Limited", international: "Comprehensive" },
  { feature: "Renewal Friendly", travel: "Need new policy", international: "Continuous coverage" },
  { feature: "Direct Billing", travel: "Rare", international: "Available" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", type: "Nomad Insurance", price: "€45-85", strengths: "Budget-friendly, nomad-focused" },
  { provider: "Cigna Global", type: "International", price: "€200-400", strengths: "Comprehensive, large network" },
  { provider: "Allianz Care", type: "International", price: "€180-350", strengths: "Strong EU coverage" },
  { provider: "World Nomads", type: "Travel", price: "€80-150", strengths: "Adventure activities included" },
  { provider: "IMG Global", type: "International", price: "€150-300", strengths: "Flexible plans" },
  { provider: "Genki", type: "Nomad Insurance", price: "€60-120", strengths: "EU-based, good for Europe" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€100-200", notes: "Varies by application method" },
  { item: "Health Insurance", amount: "€50-350/month", notes: "Depending on coverage level" },
  { item: "Accommodation (Zagreb)", amount: "€600-1,000/month", notes: "City center apartment" },
  { item: "Accommodation (Split/Coast)", amount: "€700-1,200/month", notes: "Higher in summer" },
  { item: "Living Expenses", amount: "€800-1,200/month", notes: "Food, transport, utilities" },
  { item: "Coworking Space", amount: "€100-250/month", notes: "Optional" },
  { item: "Croatian Income Tax", amount: "€0", notes: "Foreign income exempt" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Apostille criminal record", duration: "1-2 weeks", location: "Home country" },
  { step: "Secure accommodation", duration: "1-2 weeks", location: "Online/Croatia" },
  { step: "Obtain health insurance", duration: "1-3 days", location: "Online" },
  { step: "Submit online application", duration: "1 day", location: "Croatian government portal" },
  { step: "Application processing", duration: "30-60 days", location: "Croatian authorities" },
  { step: "Receive decision", duration: "After processing", location: "Email notification" },
  { step: "Collect residence permit", duration: "1-2 weeks", location: "Croatia (police station)" },
];
---

<PageShell
  title="Croatia Freelancer Visa 2026: Digital Nomad Requirements, Insurance & Guide"
  description="Complete guide to Croatia's Digital Nomad Visa for freelancers. €3,295/month income requirement, no Croatian income tax, 18-month stay, and health insurance requirements."
  headline="Croatia Digital Nomad Visa for Freelancers: Requirements & Insurance Guide"
  subheadline="Everything you need to know about freelancing in Croatia—income requirements, tax-free foreign earnings, 18-month residence permit, health insurance options, and life on the Adriatic coast."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Nomad Insurance"
  ctaButtonHref="/go/safetywing"
  heroBackgroundImage="/images/visas/digital-nomad-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      No Croatian Income Tax
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Up to 18 Months Stay
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Croatia's Digital Nomad Visa has become one of Europe's most attractive options for freelancers seeking Mediterranean lifestyle without European income taxes. Since launching in 2021, the program has drawn remote workers to destinations like Zagreb, Split, and Dubrovnik with its combination of beautiful coastline, affordable living, and tax-free status for foreign income.
    </p>

    <p class="mb-4">
      The 2025 amendments extended the maximum stay from 12 to 18 months, though they also increased the income requirement to approximately €3,295/month to reflect Croatia's rising wages. The visa remains popular despite a challenging 41.5% approval rate—proper preparation is essential.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Croatia Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Digital Nomad Residence Permit</li>
        <li>• <strong>Income requirement:</strong> €3,295/month (~€39,540/year)</li>
        <li>• <strong>Health insurance:</strong> MANDATORY—valid for entire stay in Croatia</li>
        <li>• <strong>Duration:</strong> Up to 18 months (extended in 2025)</li>
        <li>• <strong>Renewal:</strong> Cannot renew consecutively—must leave 6 months first</li>
        <li>• <strong>Croatian income tax:</strong> NONE on foreign-sourced income</li>
        <li>• <strong>Approval rate:</strong> ~41.5% (2024 data)—prepare thoroughly</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Who Qualifies as a Freelancer?</h3>

    <p class="mb-4">
      Croatia's Digital Nomad Visa covers remote employees, freelancers, and self-employed professionals—anyone earning income from sources outside Croatia. Freelancers must provide contracts with foreign clients to prove their work arrangements.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Eligible Activities</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Freelance consulting and services</li>
          <li>✓ Remote employment for foreign company</li>
          <li>✓ Own business registered abroad</li>
          <li>✓ Platform work (Upwork, Fiverr, etc.)</li>
          <li>✓ Multiple foreign income streams</li>
          <li>✓ Content creation, design, development</li>
        </ul>
      </div>

      <div class="border border-red-200 bg-red-50 rounded-lg p-6">
        <h4 class="font-semibold text-red-900 mb-3">Not Eligible</h4>
        <ul class="space-y-2 text-red-800">
          <li>✗ Working for Croatian companies</li>
          <li>✗ Providing services to Croatian clients</li>
          <li>✗ Business registered in Croatia</li>
          <li>✗ Employment by Croatian employer</li>
          <li>✗ Physical services in Croatia</li>
          <li>✗ Passive income only (dividends, rental)</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Tax advantage:</strong> Croatia does not tax foreign-sourced income for digital nomad visa holders. Your income is taxed only in your country of tax residence (if any). This makes Croatia one of the most tax-efficient digital nomad destinations in Europe—but verify your home country tax obligations.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Croatia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €3,295+/month from foreign sources</li>
          <li>✓ You want tax-free income in Europe</li>
          <li>✓ You love Mediterranean climate and coast</li>
          <li>✓ You want EU Schengen access</li>
          <li>✓ You're comfortable with moderate cost of living</li>
          <li>✓ 18 months is sufficient for your plans</li>
          <li>✓ You can provide strong documentation</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You earn less than €3,295/month (try Portugal)</li>
          <li>• You need permanent residency path (try Spain)</li>
          <li>• You want to work with local clients (try Germany)</li>
          <li>• You need guaranteed approval (41.5% rate is risky)</li>
          <li>• You want consecutive renewals (not allowed)</li>
          <li>• You prefer year-round warm weather</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Best destinations in Croatia:</strong> Zagreb offers urban lifestyle with coworking spaces and tech community. Split combines beach life with historic old town. Dubrovnik is stunning but expensive and touristy. Zadar and Rijeka offer lower costs with coastal access. Consider seasonal patterns—coastal towns are crowded in summer, quiet in winter.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The 2025 amendments to Croatia's Law on Foreigners updated several requirements. Most notably, the income threshold increased to €3,295/month and bank statement requirements extended from 3 to 6 months. Meeting these requirements doesn't guarantee approval—documentation must be thorough and clear.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Documentation</h3>

    <p class="mb-4">
      Croatia requires proof of consistent income from foreign sources. The €3,295/month threshold reflects approximately 2.5 times the Croatian average salary. For an 18-month stay, you'll need to show access to approximately €59,310.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-amber-900 mb-3">Income Proof Requirements:</h4>
      <ul class="space-y-2 text-amber-800">
        <li>• <strong>Bank statements:</strong> 6 months showing €3,295+ average monthly income</li>
        <li>• <strong>Total balance:</strong> €39,540 for 12 months, €59,310 for 18 months</li>
        <li>• <strong>Contracts:</strong> Employment contract, freelance agreements, or client contracts</li>
        <li>• <strong>Platform income:</strong> Upwork, Fiverr, and similar platforms are accepted</li>
        <li>• <strong>Multiple streams:</strong> Can combine income sources if all are foreign</li>
        <li>• <strong>Family:</strong> Add 10% of base income per dependent</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Essential Documents</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Required Documents</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport (6+ months validity)</li>
          <li>• Passport-size photos</li>
          <li>• Proof of remote work (contracts)</li>
          <li>• 6 months bank statements</li>
          <li>• Health insurance for full stay</li>
          <li>• Proof of accommodation</li>
          <li>• Criminal record certificate (apostilled)</li>
          <li>• Application form</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Document Notes</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• All documents must be recent (within 6 months)</li>
          <li>• Non-English documents need certified translation</li>
          <li>• Criminal record must be apostilled</li>
          <li>• Contracts must show foreign company/client</li>
          <li>• Insurance must specify Croatia coverage</li>
          <li>• Accommodation can be rental or hotel booking</li>
        </ul>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Approval rate warning:</strong> Only 41.5% of applications were approved in 2024 (342 of 824). Common rejection reasons include: insufficient income documentation, unclear work arrangements, missing or expired documents, and failure to prove foreign-source income. Prepare meticulously.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        Croatia requires valid health insurance covering your entire stay. Unlike some countries that require comprehensive local insurance, Croatia accepts both international health insurance and travel medical insurance—though comprehensive coverage is recommended for the 18-month duration.
      </p>
    </div>

    <p class="mb-4">
      For an 18-month stay, annual international health insurance typically makes more sense than travel insurance designed for shorter trips. Consider coverage quality, renewal ease, and whether you'll travel outside Croatia during your stay.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Travel vs. International Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Which Insurance Should You Choose?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Choose Travel/Nomad Insurance If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Budget is primary concern</li>
          <li>✓ You're young and healthy</li>
          <li>✓ You travel frequently outside Croatia</li>
          <li>✓ You don't have pre-existing conditions</li>
          <li>✓ You're comfortable with basic coverage</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Choose International Health Insurance If:</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ You want comprehensive coverage</li>
          <li>✓ You have pre-existing conditions</li>
          <li>✓ You want outpatient care included</li>
          <li>✓ You prefer direct billing options</li>
          <li>✓ You want easier renewal process</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Popular nomad choice:</strong> SafetyWing's Nomad Insurance is widely used by digital nomads in Croatia due to its low cost (~€45-85/month) and acceptance by Croatian authorities. For longer stays or those wanting comprehensive coverage, Cigna Global or Allianz Care provide full international health insurance.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Croatia digital nomad visa?"
    description="Compare travel and international health insurance options for freelancers."
    buttonText="Compare Nomad Insurance"
    buttonHref="/go/safetywing"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Croatia accepts various insurance types for the digital nomad visa. Your choice depends on budget, health needs, and travel plans. Nomad-specific insurance is popular for its flexibility and lower cost.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Digital Nomad</h4>
        <p class="text-neutral-600">SafetyWing Nomad Insurance offers the best value at €45-85/month. It's designed for location-independent workers and is widely accepted for Croatia's visa. Coverage includes emergency care and limited outpatient visits.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Coverage Needed</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care provide full international health insurance with outpatient care, specialist access, and direct billing. Expect €200-400/month but get peace of mind and no coverage gaps.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Adventure Activities Included</h4>
        <p class="text-neutral-600">World Nomads covers hiking, water sports, and adventure activities that other policies exclude. Important if you plan to explore Croatia's national parks or coastline actively.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Based Provider Preferred</h4>
        <p class="text-neutral-600">Genki (German-based) offers nomad insurance with EU compliance. Some nomads prefer EU insurers for regulatory familiarity when living in EU countries.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Croatia offers moderate living costs compared to Western Europe, making it attractive for freelancers meeting the €3,295/month income requirement. The biggest financial advantage is zero Croatian income tax on foreign earnings.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Budget Examples</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Zagreb (Budget)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500-2,000</p>
        <p class="text-sm text-neutral-500 mt-2">Shared flat, simple lifestyle</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Split (Comfortable)</p>
        <p class="text-3xl font-bold text-neutral-900">€2,000-2,800</p>
        <p class="text-sm text-neutral-500 mt-2">Own apartment, coastal life</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Dubrovnik (Premium)</p>
        <p class="text-3xl font-bold text-neutral-900">€2,500-3,500</p>
        <p class="text-sm text-neutral-500 mt-2">High season, touristy</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Tax Implications</h3>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">No Croatian Income Tax:</h4>
      <p class="text-green-800 mb-4">
        Digital nomad visa holders do not pay Croatian income tax on foreign-sourced earnings. This includes remote employment salary, freelance income, and business income from foreign clients.
      </p>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>Croatian tax:</strong> €0 on foreign income</li>
        <li>• <strong>Home country tax:</strong> Check your tax residency status</li>
        <li>• <strong>Social security:</strong> Not required in Croatia</li>
        <li>• <strong>VAT:</strong> Not applicable to foreign services</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Tax residency warning:</strong> While Croatia won't tax you, your home country might. US citizens are taxed on worldwide income. Others may remain tax resident if they don't establish residency elsewhere. Consult a tax advisor about your specific situation before assuming you're tax-free.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      You can apply for Croatia's Digital Nomad Visa online through the official government portal, at a Croatian embassy/consulate, or in person at a police station in Croatia if you're already there on a tourist visa. Online application is generally most convenient.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather and Prepare Documents</h4>
          <p class="text-neutral-600">Collect 6 months of bank statements showing consistent income. Get your criminal record certificate and have it apostilled. Prepare employment contracts or client agreements proving foreign-source work.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Secure Accommodation</h4>
          <p class="text-neutral-600">Book accommodation in Croatia—a rental agreement, hotel reservation, or Airbnb booking for your initial period. You'll need a Croatian address for the application.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get health insurance valid in Croatia for the full duration of your intended stay. SafetyWing, Cigna Global, or similar providers work. Ensure the policy explicitly covers Croatia.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Online Application</h4>
          <p class="text-neutral-600">Apply through the Croatian Ministry of Interior's online portal (cro-egov.hr). Upload all documents, pay the application fee (€100-200), and submit. Keep confirmation for your records.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing typically takes 30-60 days. You may be contacted for additional documents or clarification. Check your email regularly and respond promptly to any requests.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Decision and Travel</h4>
          <p class="text-neutral-600">If approved, you'll receive notification and instructions for collecting your residence permit. Travel to Croatia and collect the permit at the designated police station.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Alternative application:</strong> If you're already in Croatia on a tourist visa (Schengen 90 days), you can apply in person at a police administration office. This allows you to experience Croatia before committing to the visa application.
      </p>
    </div>
  </section>

