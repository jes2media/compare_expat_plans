  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€99", notes: "At French consulate" },
  { item: "OFII Validation", amount: "€225", notes: "Within 3 months of arrival" },
  { item: "Health Insurance (Initial)", amount: "€150-400/month", notes: "Private for visa period" },
  { item: "CFE Registration", amount: "Free-€60", notes: "Depends on activity type" },
  { item: "URSSAF Contributions", amount: "~22% of revenue", notes: "Auto-entrepreneur rate" },
  { item: "Accountant (Expert-Comptable)", amount: "€80-200/month", notes: "Optional for auto-entrepreneur" },
  { item: "Professional Insurance (RC Pro)", amount: "€30-150/month", notes: "Required for many activities" },
  { item: "Financial Buffer", amount: "€5,000-15,000", notes: "Recommended savings" },
];

