const insuranceRows = [
  { feature: "Monthly Cost", private: "€150-400", puma: "Free-€300/year + mutuelle ~€50-150" },
  { feature: "When Available", private: "Immediately", puma: "After 3 months residency" },
  { feature: "Coverage Level", private: "Comprehensive", puma: "~70% reimbursement + mutuelle" },
  { feature: "GP Access", private: "Any doctor", puma: "Médecin traitant + referrals" },
  { feature: "Hospital Care", private: "Direct billing often", puma: "70% reimbursed, rest via mutuelle" },
  { feature: "Visa Acceptance", private: "Required for visa", puma: "N/A—for residents only" },
  { feature: "Pre-existing Conditions", private: "May have waiting periods", puma: "Full coverage, no exclusions" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "AXA Global", type: "International", price: "€200-450", strengths: "French-based, local network, expat support" },
  { provider: "Cigna Global", type: "International", price: "€220-500", strengths: "Large network, English support, flexible plans" },
  { provider: "Allianz Care", type: "International", price: "€180-400", strengths: "High-deductible options, EU coverage" },
  { provider: "April International", type: "International", price: "€150-350", strengths: "French company, tailored expat plans" },
  { provider: "BUPA Global", type: "International", price: "€260-550", strengths: "Mental health, pre-existing conditions" },
  { provider: "Mutuelle (post-CPAM)", type: "French Top-up", price: "€50-150", strengths: "Complements public coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
