const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "autoentrepreneur", header: "Auto-Entrepreneur" },
  { key: "professionliberale", header: "Profession Libérale" },
];

const requirementsRows = [
  { requirement: "Revenue Limits", autoentrepreneur: "€77,700/year services (2024)", professionliberale: "No limit" },
  { requirement: "Social Contributions", autoentrepreneur: "~22% of revenue", professionliberale: "~45% of net income" },
  { requirement: "Business Plan", autoentrepreneur: "Required—projet professionnel", professionliberale: "Required—detailed business case" },
  { requirement: "Qualifications", autoentrepreneur: "Varies by activity", professionliberale: "Professional diplomas required" },
  { requirement: "Registration", autoentrepreneur: "URSSAF + CFE", professionliberale: "URSSAF + Professional order" },
  { requirement: "Health Insurance", autoentrepreneur: "Private for visa, then CPAM", professionliberale: "Private for visa, then CPAM" },
