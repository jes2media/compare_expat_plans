  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Prepare documents and business plan", duration: "2-4 weeks", location: "Home country" },
  { step: "Get private health insurance", duration: "1-2 weeks", location: "Insurance provider" },
  { step: "Book visa appointment", duration: "2-6 weeks wait", location: "French consulate" },
  { step: "Attend visa appointment", duration: "1 day", location: "Consulate" },
  { step: "Visa processing", duration: "2-3 months", location: "Consulate review" },
  { step: "Arrive in France", duration: "After approval", location: "France" },
  { step: "Validate visa with OFII", duration: "Within 3 months", location: "Online + medical exam" },
  { step: "Register business with CFE/URSSAF", duration: "1-2 weeks", location: "Online" },
