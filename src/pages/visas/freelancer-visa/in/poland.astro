---
/**
 * Poland Freelancer Visa - Long-form CRO-optimized page
 * Self-Employment (Działalność Gospodarcza) visa guide with insurance requirements
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Poland", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Czech Republic Freelancer Visa", href: "/visas/freelancer-visa/in/czech-republic" },
  { title: "Germany Freelancer Visa", href: "/visas/freelancer-visa/in/germany" },
  { title: "Hungary Freelancer Visa", href: "/visas/freelancer-visa/in/hungary" },
];

const visaComparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "polandFreelance", header: "Poland Freelance Visa" },
  { key: "typicalDNV", header: "Typical EU DNV" },
];

const visaComparisonRows = [
  { feature: "Income Requirement", polandFreelance: "~€850/month (proof of means)", typicalDNV: "€2,500-3,500/month" },
  { feature: "Client Location", polandFreelance: "Any clients (Polish OK)", typicalDNV: "Foreign clients only" },
  { feature: "Business Registration", polandFreelance: "Required (JDG)", typicalDNV: "Not required" },
  { feature: "Tax Obligation", polandFreelance: "Polish taxes", typicalDNV: "Often exempt or reduced" },
  { feature: "Duration", polandFreelance: "2 years, renewable", typicalDNV: "1 year typically" },
  { feature: "Path to PR", polandFreelance: "Yes (after 5 years)", typicalDNV: "Usually no" },
  { feature: "Processing Speed", polandFreelance: "3-4 weeks", typicalDNV: "4-8 weeks" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Financial Means", details: "~€850/month or equivalent", notes: "No strict minimum, prove self-sufficiency" },
  { requirement: "Business Registration", details: "JDG (Jednoosobowa Działalność Gospodarcza)", notes: "Register as sole proprietor" },
  { requirement: "PESEL Number", details: "National ID number", notes: "Obtained during registration" },
  { requirement: "NIP Number", details: "Tax identification", notes: "For invoicing and taxes" },
  { requirement: "Health Insurance", details: "ZUS public or private", notes: "Required for registration" },
  { requirement: "Accommodation", details: "Proof of Polish address", notes: "Rental contract or letter" },
  { requirement: "Criminal Record", details: "Not required", notes: "Simplified documentation" },
];

const businessRegistrationColumns = [
  { key: "item", header: "Registration Item" },
  { key: "purpose", header: "Purpose" },
  { key: "where", header: "Where to Get" },
];

const businessRegistrationRows = [
  { item: "PESEL", purpose: "Personal identification number", where: "Local Urząd Gminy (municipal office)" },
  { item: "NIP", purpose: "Tax identification number", where: "Tax office (Urząd Skarbowy)" },
  { item: "REGON", purpose: "Statistical business number", where: "GUS (Statistics Office)" },
  { item: "CEIDG Registration", purpose: "Business activity record", where: "Online at biznes.gov.pl" },
  { item: "ZUS Registration", purpose: "Social security enrollment", where: "ZUS office (if choosing public)" },
  { item: "Bank Account", purpose: "Business transactions", where: "Polish bank" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "zus", header: "ZUS (Public)" },
  { key: "international", header: "International Private" },
];

const insuranceRows = [
  { feature: "Monthly Cost", zus: "€150-400 (varies)", international: "€100-280" },
  { feature: "Coverage Type", zus: "Polish public healthcare", international: "Global/EU private" },
  { feature: "Visa/Registration", zus: "Required for JDG", international: "Supplement or alternative" },
  { feature: "Wait Times", zus: "Can be long for specialists", international: "Short, direct access" },
  { feature: "English Support", zus: "Limited", international: "Full English support" },
  { feature: "Pre-existing", zus: "Covered", international: "Varies by plan" },
  { feature: "Travel Coverage", zus: "Poland/EU (EHIC)", international: "Worldwide" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€130-280", strengths: "Comprehensive coverage, global network" },
  { provider: "Allianz Care", type: "International", price: "€110-250", strengths: "Strong EU coverage, flexible plans" },
  { provider: "Medicover Poland", type: "Polish Private", price: "€40-100", strengths: "Local network, Polish system access" },
  { provider: "LuxMed", type: "Polish Private", price: "€35-90", strengths: "Large Polish network, affordable" },
  { provider: "SafetyWing", type: "Nomad Insurance", price: "€65-110", strengths: "Budget-friendly, nomad-focused" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€80", notes: "Type D visa" },
  { item: "Temporary Residence Permit", amount: "€100-150", notes: "After arrival" },
  { item: "ZUS Contributions", amount: "€150-400/month", notes: "Social security (variable)" },
  { item: "Private Health Insurance", amount: "€35-150/month", notes: "Optional supplement" },
  { item: "Accountant (Księgowy)", amount: "€50-150/month", notes: "Highly recommended" },
  { item: "Rent (Warsaw)", amount: "€500-900/month", notes: "1-bedroom apartment" },
  { item: "Living Expenses", amount: "€500-800/month", notes: "Food, transport, leisure" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Apply for Type D visa", duration: "1 day", location: "Polish embassy/consulate" },
  { step: "Visa processing", duration: "3-4 weeks", location: "Embassy processes" },
  { step: "Arrive in Poland", duration: "After visa issued", location: "Poland" },
  { step: "Get PESEL number", duration: "1-2 days", location: "Municipal office" },
  { step: "Register JDG business", duration: "1 day", location: "Online (CEIDG)" },
  { step: "Register with ZUS", duration: "7 days after JDG", location: "ZUS office or online" },
  { step: "Apply for Temporary Residence", duration: "Within 45 days", location: "Voivodeship office" },
  { step: "Residence permit processing", duration: "1-3 months", location: "Immigration processes" },
];
---

<PageShell
  title="Poland Freelancer Visa 2026: Self-Employment Visa Requirements, Insurance & Guide"
  description="Complete guide to Poland's Freelancer Visa (JDG self-employment). Low income threshold, work with any clients, 2-year duration, and step-by-step registration process."
  headline="Poland Freelancer Visa: Self-Employment Insurance & Requirements Guide"
  subheadline="Everything you need to know about freelancing in Poland—JDG business registration, no strict income minimum, work with Polish or foreign clients, ZUS contributions, and path to permanent residency."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Freelancer Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/visas/digital-nomad-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Work with Any Clients
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Path to PR
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Poland doesn't offer a dedicated "digital nomad visa" like Croatia or Portugal. Instead, freelancers use the self-employment route: registering a sole proprietorship (Jednoosobowa Działalność Gospodarcza or JDG) and obtaining a visa for business purposes. This approach has unique advantages—no strict income minimum, ability to work with Polish clients, and a clear path to permanent residency.
    </p>

    <p class="mb-4">
      While this means more paperwork than a typical DNV, the trade-offs are favorable for many freelancers. Poland's growing tech scene, affordable living costs, and central European location make it attractive for digital professionals willing to integrate into the Polish business system.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Poland Freelancer Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Type D Visa + Temporary Residence Permit for Business</li>
        <li>• <strong>Income requirement:</strong> ~€850/month (proof of means, no strict minimum)</li>
        <li>• <strong>Health insurance:</strong> ZUS (public) or private international</li>
        <li>• <strong>Duration:</strong> 2 years, renewable</li>
        <li>• <strong>Business registration:</strong> Required (JDG sole proprietorship)</li>
        <li>• <strong>Client location:</strong> Any clients—Polish or foreign</li>
        <li>• <strong>Path to PR:</strong> Yes—permanent residence after 5 years</li>
        <li>• <strong>Schengen access:</strong> Yes—travel freely in Schengen Zone</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Poland vs. Typical Digital Nomad Visas</h3>

    <p class="mb-4">
      Poland's approach differs significantly from countries with dedicated DNV programs. Understanding these differences helps you decide if Poland's system fits your situation.
    </p>

    <ComparisonTable columns={visaComparisonColumns} rows={visaComparisonRows} />

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Key advantage:</strong> Unlike most EU digital nomad visas that prohibit working with local clients, Poland's freelance visa allows you to work with Polish companies. This opens the door to the local market while maintaining international clients.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Poland is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want to work with Polish AND foreign clients</li>
          <li>✓ You want a path to permanent residency</li>
          <li>✓ You're comfortable with business registration</li>
          <li>✓ You value affordable Central European living</li>
          <li>✓ You want Schengen Zone access</li>
          <li>✓ You appreciate fast-growing tech hubs (Warsaw, Kraków)</li>
          <li>✓ You don't mind Polish bureaucracy</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want minimal paperwork (try Hungary)</li>
          <li>• You want to avoid local tax obligations</li>
          <li>• You prefer warm Mediterranean climate</li>
          <li>• You don't want to register a business</li>
          <li>• You want exemption from social contributions</li>
          <li>• You prefer English-speaking countries</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>ZUS relief for new freelancers:</strong> Poland offers "Ulga na start" (startup relief)—6 months exemption from ZUS social contributions for first-time freelancers, followed by up to 24 months of reduced "small ZUS" rates. This significantly reduces costs in your first 2.5 years.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Poland's freelance visa has surprisingly flexible requirements compared to dedicated DNV programs. The lack of a strict income minimum and the ability to work with local clients make it accessible for a wider range of freelancers.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Business Registration (JDG) Components</h3>

    <p class="mb-4">
      To work legally as a freelancer in Poland, you register a sole proprietorship (Jednoosobowa Działalność Gospodarcza). This involves several registration numbers and accounts.
    </p>

    <ComparisonTable columns={businessRegistrationColumns} rows={businessRegistrationRows} />

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mt-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">Good News About Registration:</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>CEIDG registration:</strong> Free and can be done online</li>
        <li>• <strong>NIP/REGON:</strong> Automatically issued with CEIDG registration</li>
        <li>• <strong>Speed:</strong> Business can be registered in 1 day</li>
        <li>• <strong>Language:</strong> Forms increasingly available in English</li>
        <li>• <strong>Help available:</strong> Many accountants assist foreigners</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Documentation Advantages</h3>

    <p class="mb-4">
      Poland's freelance visa is notably simpler than many alternatives in terms of upfront documentation:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">NOT Required:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ No criminal background check (FBI)</li>
          <li>✓ No medical certificate</li>
          <li>✓ No high income threshold</li>
          <li>✓ No pre-paid accommodation</li>
          <li>✓ No pre-paid health insurance</li>
          <li>✓ No apostilled documents</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Required:</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport</li>
          <li>• Proof of financial means (~€850/month)</li>
          <li>• Evidence of business activity or client interest</li>
          <li>• Polish address (rental contract)</li>
          <li>• Passport photos</li>
          <li>• Visa/permit application fees</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Client letters help:</strong> While not strictly required, letters of interest from prospective clients or existing contracts strengthen your application. Polish authorities want to see that your business has genuine prospects.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Required</h3>
      <p class="text-green-800">
        Poland requires health insurance for all legal residents. As a registered freelancer (JDG), you'll typically enroll in ZUS (the public social security system), which includes health coverage. You can also supplement with private insurance for faster access and English-speaking providers.
      </p>
    </div>

    <p class="mb-4">
      The ZUS system covers public healthcare but involves monthly contributions. Many freelancers combine ZUS (required) with private Polish or international insurance for better service.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">ZUS vs. Private Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">ZUS Contribution Relief</h3>

    <p class="mb-4">
      Poland offers significant ZUS relief for new freelancers, making the first few years much more affordable:
    </p>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">ZUS Relief Programs:</h4>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>Ulga na start:</strong> First 6 months—only health insurance (~€100/month), no pension contributions</li>
        <li>• <strong>Mały ZUS (Small ZUS):</strong> Next 24 months—reduced contributions (~€150-200/month)</li>
        <li>• <strong>After 30 months:</strong> Full ZUS contributions (~€300-400/month)</li>
        <li>• <strong>Total savings:</strong> Significant in first 2.5 years of business</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>2025-2026 changes:</strong> ZUS rates and eligibility may adjust with reforms. Consult a Polish accountant for current rates and to ensure you claim all available relief programs.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Poland freelancer visa?"
    description="Compare international health insurance plans to supplement ZUS coverage in Poland."
    buttonText="Compare Freelancer Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      While ZUS provides basic coverage, many freelancers add private insurance for faster access, English support, and better facilities. Here are options for Poland.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-Term Poland Resident</h4>
        <p class="text-neutral-600">ZUS (required) plus LuxMed or Medicover for private clinic access. This combination costs €200-300/month total but provides both public system access and fast private care with English-speaking doctors.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Frequent Traveler</h4>
        <p class="text-neutral-600">ZUS plus international insurance (Cigna Global, Allianz Care). International plans cover you throughout Europe and globally, while ZUS handles your Polish obligations. Budget €250-400/month total.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Freelancer</h4>
        <p class="text-neutral-600">During Ulga na start period (first 6 months), your health contribution is minimal. Add SafetyWing for emergencies if needed. After relief ends, ZUS alone provides adequate basic coverage.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">ZUS covers pre-existing conditions without exclusions—a major advantage of the public system. If you need specialized care, supplement with Polish private insurance (Medicover, LuxMed) for faster specialist access.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Poland offers excellent value—significantly more affordable than Western Europe with good quality of life. The main ongoing costs are ZUS contributions, accountant fees, and living expenses.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Polish Tax System for Freelancers</h3>

    <p class="mb-4">
      Poland offers multiple taxation options for freelancers. Your accountant can help you choose the most advantageous:
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">Tax Options:</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Flat tax (podatek liniowy):</strong> 19% flat rate on income</li>
        <li>• <strong>Progressive tax (skala podatkowa):</strong> 12% up to ~€30,000, then 32%</li>
        <li>• <strong>Lump sum (ryczałt):</strong> Lower rates (2-17%) based on activity type</li>
        <li>• <strong>IP Box:</strong> 5% rate for qualifying intellectual property income</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Realistic Monthly Budget</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget (Smaller Cities)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,000-1,400</p>
        <p class="text-sm text-neutral-500 mt-2">Kraków, Wrocław, Gdańsk</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable (Warsaw)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500-2,200</p>
        <p class="text-sm text-neutral-500 mt-2">Own apartment, city center</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Living</p>
        <p class="text-3xl font-bold text-neutral-900">€2,500-3,500</p>
        <p class="text-sm text-neutral-500 mt-2">Warsaw premium areas</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost Breakdown (Warsaw)</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Rent (1BR apartment):</strong> €500-800/month (city center)</li>
      <li><strong>ZUS contributions:</strong> €100-400/month (varies by relief status)</li>
      <li><strong>Private insurance (optional):</strong> €40-100/month</li>
      <li><strong>Accountant:</strong> €50-100/month</li>
      <li><strong>Utilities:</strong> €80-120/month</li>
      <li><strong>Groceries:</strong> €200-300/month</li>
      <li><strong>Transport:</strong> €30-50/month (public transport)</li>
      <li><strong>Coworking:</strong> €80-150/month (optional)</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Currency note:</strong> Poland uses the Polish Złoty (PLN), not the Euro. Exchange rates fluctuate, so consider a multi-currency account (Wise, Revolut). Most prices quoted here assume current EUR/PLN rates.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Poland's freelance visa process involves two main phases: obtaining the initial visa abroad, then registering your business and applying for a temporary residence permit after arrival.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documents</h4>
          <p class="text-neutral-600">Gather proof of financial means, evidence of freelance work or client interest, and passport. Unlike many visas, Poland doesn't require apostilled documents, criminal records, or pre-paid insurance at this stage.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Type D Visa</h4>
          <p class="text-neutral-600">Visit the Polish embassy or consulate in your country. Apply for a Type D visa for business purposes. Processing typically takes 3-4 weeks with help from a lawyer or immigration specialist.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive in Poland</h4>
          <p class="text-neutral-600">Enter Poland with your Type D visa. Secure accommodation with a rental contract—you'll need a Polish address for all subsequent registrations.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get PESEL Number</h4>
          <p class="text-neutral-600">Visit your local municipal office (Urząd Gminy) to obtain your PESEL—Poland's personal identification number. This is essential for all further registrations.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Register Your Business (JDG)</h4>
          <p class="text-neutral-600">Register your sole proprietorship through CEIDG (biznes.gov.pl). This is free and can be done online. You'll automatically receive your NIP and REGON numbers.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Register with ZUS</h4>
          <p class="text-neutral-600">Within 7 days of registering your JDG, register with ZUS for social security and health insurance. Claim Ulga na start if you're a first-time freelancer for 6 months of reduced contributions.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Find an Accountant</h4>
          <p class="text-neutral-600">Hire a Polish accountant (księgowy) to handle your books, tax filings, and ZUS declarations. Many work with English-speaking foreign freelancers. Budget €50-150/month.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">8</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Temporary Residence Permit</h4>
          <p class="text-neutral-600">Within 45 days of arrival, apply for a temporary residence permit at your local Voivodeship office. This converts your visa to a residence card valid for 2 years.</p>
        </div>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Speed advantage:</strong> Poland's freelance visa can be obtained in 3-4 weeks from embassy application—faster than many EU alternatives. Business registration takes just 1 day once you're in Poland.
      </p>
    </div>
  </section>

