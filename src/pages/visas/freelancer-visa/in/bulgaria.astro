---
/**
 * Bulgaria Freelancer Visa - Long-form CRO-optimized page
 * Digital Nomad Visa guide with insurance requirements
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Bulgaria", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Romania Freelancer Visa", href: "/visas/freelancer-visa/in/romania" },
  { title: "Greece Freelancer Visa", href: "/visas/freelancer-visa/in/greece" },
  { title: "Croatia Freelancer Visa", href: "/visas/freelancer-visa/in/croatia" },
];

const applicantTypesColumns = [
  { key: "feature", header: "Feature" },
  { key: "freelancer", header: "Freelancer" },
  { key: "remoteEmployee", header: "Remote Employee" },
  { key: "businessOwner", header: "Business Owner" },
];

const applicantTypesRows = [
  { feature: "Eligibility", freelancer: "1+ year digital services", remoteEmployee: "Non-EU/EEA employer", businessOwner: "25%+ foreign company" },
  { feature: "Income Proof", freelancer: "Contracts, invoices, platform earnings", remoteEmployee: "Employment contract", businessOwner: "Company registration + contract" },
  { feature: "Client Location", freelancer: "Non-Bulgarian clients only", remoteEmployee: "Foreign employer only", businessOwner: "Non-Bulgarian clients" },
  { feature: "Documentation", freelancer: "Client recommendations", remoteEmployee: "Company register extract", businessOwner: "Ownership proof + work contracts" },
  { feature: "Best For", freelancer: "Upwork, Fiverr, direct clients", remoteEmployee: "US/UK company employees", businessOwner: "Startup founders" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Minimum Income", details: "€2,300-2,600/month (~€31,000/year)", notes: "50x Bulgarian minimum wage" },
  { requirement: "Work History", details: "1+ year in digital services", notes: "Freelancers/contractors must show track record" },
  { requirement: "Health Insurance", details: "Valid coverage in Bulgaria", notes: "Comprehensive international insurance" },
  { requirement: "Accommodation", details: "Rental contract or property ownership", notes: "Bulgarian address required" },
  { requirement: "Criminal Record", details: "Clean background check", notes: "Apostilled from home country" },
  { requirement: "Client Location", details: "Non-Bulgarian clients only", notes: "Cannot serve Bulgarian market" },
  { requirement: "Passport Validity", details: "6+ months beyond stay", notes: "With blank pages for visa" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "travel", header: "Travel Insurance" },
  { key: "international", header: "International Health Insurance" },
];

const insuranceRows = [
  { feature: "Visa Acceptance", travel: "May not qualify", international: "Recommended for visa" },
  { feature: "Coverage Duration", travel: "30-90 days typically", international: "Annual renewable" },
  { feature: "Coverage Amount", travel: "€30,000-50,000", international: "€1M+ comprehensive" },
  { feature: "Pre-existing Conditions", travel: "Never covered", international: "Varies by plan" },
  { feature: "Routine Care", travel: "Not covered", international: "Usually included" },
  { feature: "Monthly Cost", travel: "€30-80", international: "€100-300" },
  { feature: "Recommendation", travel: "Not recommended", international: "Best choice for DNV" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€150-300", strengths: "Comprehensive coverage, global network" },
  { provider: "Allianz Care", type: "International", price: "€130-280", strengths: "Strong EU coverage, flexible plans" },
  { provider: "SafetyWing", type: "Nomad Insurance", price: "€70-120", strengths: "Budget-friendly, nomad-focused" },
  { provider: "World Nomads", type: "Travel/Nomad", price: "€80-150", strengths: "Adventure activities, flexible" },
  { provider: "Genki", type: "Nomad Insurance", price: "€60-100", strengths: "European-focused, good value" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Type D Visa Fee", amount: "€100", notes: "Long-stay visa application" },
  { item: "Residence Permit Fee", amount: "€100-150", notes: "After arrival in Bulgaria" },
  { item: "Health Insurance", amount: "€100-300/month", notes: "International recommended" },
  { item: "Translation/Legalization", amount: "€100-300", notes: "Document apostilles and translations" },
  { item: "Rent (Sofia)", amount: "€400-800/month", notes: "City center apartment" },
  { item: "Living Expenses", amount: "€600-900/month", notes: "Food, transport, utilities" },
  { item: "Coworking Space", amount: "€80-200/month", notes: "Optional, many cafes work well" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Apostille and translate documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Apply for Type D visa at embassy", duration: "1 day", location: "Bulgarian embassy/consulate" },
  { step: "Visa processing", duration: "1-2 months", location: "Embassy processes" },
  { step: "Receive Type D visa", duration: "After approval", location: "Embassy pickup" },
  { step: "Enter Bulgaria", duration: "Within visa validity", location: "Bulgaria" },
  { step: "Apply for residence permit", duration: "Within 14 days of arrival", location: "Migration Directorate" },
  { step: "Residence permit processing", duration: "2-4 weeks", location: "Local migration office" },
  { step: "Receive residence card", duration: "After approval", location: "Migration office pickup" },
];
---

<PageShell
  title="Bulgaria Freelancer Visa 2026: Digital Nomad Visa Requirements, Insurance & Guide"
  description="Complete guide to Bulgaria's new Digital Nomad Visa for freelancers. €2,300/month income, 10% flat tax, Schengen access, Euro currency, and step-by-step application process."
  headline="Bulgaria Freelancer Visa: Digital Nomad Visa Insurance & Requirements Guide"
  subheadline="Everything you need to know about freelancing in Bulgaria—new DNV launched December 2025, 10% flat tax rate, Schengen Zone access, Euro currency, and affordable European living."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Freelancer Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/visas/digital-nomad-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      New DNV Launched Dec 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      10% Flat Tax Rate
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Bulgaria launched its Digital Nomad Visa on December 20, 2025, becoming one of the newest EU countries to offer a dedicated pathway for remote workers. The timing is significant—Bulgaria joined the Schengen Zone and adopted the Euro in 2025, making it a strategic base for freelancers who want EU access with Eastern European affordability.
    </p>

    <p class="mb-4">
      The Bulgarian DNV allows freelancers, remote employees, and business owners to live and work in Bulgaria for up to two years, with income thresholds that are reasonable by EU standards (roughly €2,300-2,600/month). Combined with Bulgaria's 10% flat income tax—the lowest in the EU—this visa offers an attractive financial package for independent professionals.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Bulgaria Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Digital Nomad Residence Permit</li>
        <li>• <strong>Income requirement:</strong> ~€31,000/year (50x minimum wage)</li>
        <li>• <strong>Health insurance:</strong> MANDATORY—comprehensive international coverage</li>
        <li>• <strong>Duration:</strong> 1 year, renewable for a second year (2 years total)</li>
        <li>• <strong>Tax rate:</strong> 10% flat tax (if tax resident 183+ days)</li>
        <li>• <strong>Schengen access:</strong> Yes—travel freely in Schengen Zone</li>
        <li>• <strong>Currency:</strong> Euro (adopted 2025)</li>
        <li>• <strong>Work restriction:</strong> Cannot work for Bulgarian clients/employers</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Who Can Apply?</h3>

    <p class="mb-4">
      Bulgaria's DNV targets three categories of remote workers. All must demonstrate at least one year of relevant work history and earn income exclusively from outside Bulgaria.
    </p>

    <ComparisonTable columns={applicantTypesColumns} rows={applicantTypesRows} />

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Important restriction:</strong> Digital nomad visa holders cannot work for Bulgarian employers or serve Bulgarian clients. Your income must come entirely from outside Bulgaria. Violating this rule can result in visa revocation.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Bulgaria is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want EU's lowest flat tax rate (10%)</li>
          <li>✓ You value affordable European living</li>
          <li>✓ You want Schengen Zone travel access</li>
          <li>✓ You earn €2,300+/month from foreign clients</li>
          <li>✓ You prefer emerging tech/startup scenes</li>
          <li>✓ You want Euro stability with low costs</li>
          <li>✓ You have 1+ year of remote work history</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need to work with local clients</li>
          <li>• You're new to freelancing (1-year requirement)</li>
          <li>• You want Mediterranean weather (try Greece/Croatia)</li>
          <li>• You prefer Western European infrastructure</li>
          <li>• You don't speak any Slavic languages</li>
          <li>• You want immediate permanent residency path</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>New program advantage:</strong> As a newly launched visa (December 2025), Bulgaria's DNV application process is less congested than established programs in Portugal or Spain. Early applicants report smoother processing and helpful embassy staff eager to make the program succeed.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Bulgaria's Digital Nomad Visa requirements focus on proving stable remote income, a clean background, and comprehensive health coverage. The income threshold is based on Bulgaria's minimum wage, making it accessible for most established freelancers.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Requirement Explained</h3>

    <p class="mb-4">
      The minimum income is set at 50 times Bulgaria's monthly minimum wage. As of 2025-2026, this translates to approximately €31,000 annually or €2,300-2,600 monthly. You must demonstrate stable, recurring income—not just savings.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-primary-900 mb-3">Acceptable Income Proof:</h4>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Freelancers:</strong> Contracts with clients, invoices, bank statements, platform earnings (Upwork, Fiverr)</li>
        <li>• <strong>Remote employees:</strong> Employment contract (company must be outside EU/EEA/Switzerland)</li>
        <li>• <strong>Business owners:</strong> Company registration (25%+ ownership), recent company extract, work contracts</li>
        <li>• <strong>All applicants:</strong> Bank statements showing income over past 6-12 months</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Essential Documents</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">For Type D Visa Application</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport (6+ months validity)</li>
          <li>• Completed visa application form</li>
          <li>• Passport-sized photos (biometric)</li>
          <li>• Proof of income (contracts, bank statements)</li>
          <li>• Health insurance documentation</li>
          <li>• Criminal record certificate (apostilled)</li>
          <li>• Proof of accommodation in Bulgaria</li>
          <li>• Employment contract or client recommendations</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Document Preparation</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• All documents apostilled</li>
          <li>• Translations into Bulgarian required</li>
          <li>• Company extracts no older than 6 months</li>
          <li>• Criminal record recent (usually 3-6 months)</li>
          <li>• Certified translations by sworn translator</li>
          <li>• Insurance certificate showing Bulgaria coverage</li>
          <li>• Rental contract or property deed</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Translation requirement:</strong> All foreign documents must be legalized with an apostille and translated into Bulgarian by a certified translator. Plan for €100-300 in translation and legalization costs depending on your document count.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        Bulgaria requires valid health insurance covering your entire stay. Unlike some countries that accept basic travel insurance, Bulgaria's DNV expects comprehensive coverage. International health insurance is strongly recommended over short-term travel policies.
      </p>
    </div>

    <p class="mb-4">
      The insurance must cover medical emergencies, hospitalization, and repatriation. While specific coverage minimums aren't rigidly defined, comprehensive international health insurance provides the best protection and smoothest visa approval.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Travel vs. International Health Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Recommended Insurance Approach</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Choose International Health Insurance If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ You're staying the full 1-2 years</li>
          <li>✓ You want routine care coverage</li>
          <li>✓ You have pre-existing conditions</li>
          <li>✓ You travel frequently within Schengen</li>
          <li>✓ You want hassle-free visa renewal</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Travel Insurance Limitations:</h4>
        <ul class="space-y-2 text-amber-800">
          <li>△ May not meet visa requirements</li>
          <li>△ Coverage gaps for long stays</li>
          <li>△ No routine care or checkups</li>
          <li>△ Pre-existing conditions excluded</li>
          <li>△ May need to renew frequently</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Recommendation:</strong> For a 1-2 year digital nomad visa, invest in proper international health insurance rather than patching together travel insurance policies. The peace of mind and visa compliance are worth the higher monthly cost.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Bulgarian digital nomad visa?"
    description="Compare international health insurance plans accepted for Bulgaria's DNV application."
    buttonText="Compare Freelancer Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Bulgaria's DNV, you need insurance that provides comprehensive coverage for the full visa duration. Here are the top options for freelancers and remote workers.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Full-Time Bulgaria Resident</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care provide comprehensive coverage with global networks. Budget €150-280/month for solid protection including routine care, specialists, and hospitalization.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Nomad</h4>
        <p class="text-neutral-600">SafetyWing or Genki offer nomad-focused coverage at €60-120/month. Good for healthy freelancers who primarily need emergency coverage. Check if policies meet Bulgaria's specific requirements.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Frequent Schengen Traveler</h4>
        <p class="text-neutral-600">Choose international insurance with strong EU-wide coverage. Your Bulgaria DNV grants Schengen access—make sure your insurance covers you throughout the zone.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care may cover pre-existing conditions after waiting periods or with specific plans. Discuss your situation during the quote process—disclosure is essential.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Bulgaria offers some of the lowest living costs in the EU while providing Schengen access and Euro stability. Combined with the 10% flat tax, it's financially attractive for freelancers earning in stronger currencies.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Bulgaria's 10% Flat Tax</h3>

    <p class="mb-4">
      Bulgaria has the lowest flat income tax rate in the EU—just 10% on personal income. If you become a tax resident (183+ days in Bulgaria), you'll pay this rate on worldwide income. For freelancers earning in USD, EUR, or GBP, this represents significant savings compared to Western European or North American rates.
    </p>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">Tax Advantages:</h4>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>Income tax:</strong> 10% flat rate (EU's lowest)</li>
        <li>• <strong>Tax residency:</strong> 183+ days in Bulgaria</li>
        <li>• <strong>Social security:</strong> Freelancers may be exempt or pay reduced rates</li>
        <li>• <strong>Dividend tax:</strong> 5% on dividends from Bulgarian companies</li>
        <li>• <strong>No wealth tax:</strong> Bulgaria doesn't tax net worth</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Realistic Monthly Budget</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget (Shared/Studio)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,000-1,400</p>
        <p class="text-sm text-neutral-500 mt-2">Sofia or smaller cities</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable (Own Apartment)</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500-2,000</p>
        <p class="text-sm text-neutral-500 mt-2">Sofia city center</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Living</p>
        <p class="text-3xl font-bold text-neutral-900">€2,000-2,800</p>
        <p class="text-sm text-neutral-500 mt-2">Luxury apartments, frequent dining out</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost Breakdown (Sofia)</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Rent (1BR apartment):</strong> €400-700/month (city center)</li>
      <li><strong>Health insurance:</strong> €100-250/month</li>
      <li><strong>Utilities:</strong> €80-120/month (electricity, heating, internet)</li>
      <li><strong>Food & groceries:</strong> €200-350/month</li>
      <li><strong>Transport:</strong> €30-50/month (public transport) or €0 (walking)</li>
      <li><strong>Coworking:</strong> €80-150/month (optional, many cafes are work-friendly)</li>
      <li><strong>Entertainment:</strong> €100-200/month</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Currency advantage:</strong> Bulgaria adopted the Euro in 2025, eliminating currency exchange concerns within the Eurozone. If you earn in USD or GBP, the current exchange rates make Bulgarian prices exceptionally affordable.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Bulgaria's DNV application follows a two-step process: first apply for a Type D long-stay visa at a Bulgarian embassy abroad, then apply for the residence permit after arriving in Bulgaria.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather and Prepare Documents</h4>
          <p class="text-neutral-600">Collect all required documents: employment contract or freelance contracts, proof of income, criminal record certificate, and accommodation proof. Get apostilles from relevant authorities and certified translations into Bulgarian.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Secure Health Insurance</h4>
          <p class="text-neutral-600">Purchase comprehensive international health insurance covering your planned stay in Bulgaria. Get an official certificate or letter confirming coverage dates and scope—you'll need this for the visa application.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Type D Visa</h4>
          <p class="text-neutral-600">Schedule an appointment at the Bulgarian embassy or consulate in your country of residence. Submit your application with all supporting documents. Pay the visa fee (approximately €100).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Visa Approval</h4>
          <p class="text-neutral-600">Processing typically takes 1-2 months. The embassy may request additional documents or schedule an interview. Track your application status through the embassy's system.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Travel to Bulgaria</h4>
          <p class="text-neutral-600">Once your Type D visa is approved, travel to Bulgaria within the visa validity period. Your Type D visa allows entry and short-term stay while you apply for the residence permit.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Residence Permit</h4>
          <p class="text-neutral-600">Within 14 days of arrival, apply for your residence permit at the local Migration Directorate. Bring your Type D visa, all original documents, and proof of Bulgarian address.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Residence Card</h4>
          <p class="text-neutral-600">After 2-4 weeks of processing, return to collect your residence card. This card is valid for 1 year and can be renewed for a second year, allowing up to 2 years total on the DNV.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">8</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Set Up Local Life</h4>
          <p class="text-neutral-600">Open a Bulgarian bank account, register your address locally, and familiarize yourself with Sofia's coworking spaces and nomad community. Many expats connect through Sofia Nomads and similar groups.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>New program tip:</strong> As Bulgaria's DNV launched in late 2025, embassy staff are still adapting to the new requirements. Be patient, bring printed copies of the official regulations, and maintain clear communication with the embassy.
      </p>
    </div>
  </section>

