const providerRows = [
  { provider: "PVZP (Pojišťovna VZP)", type: "Czech - Required", price: "€500-700", accepted: "YES - Required" },
  { provider: "Maxima pojišťovna", type: "Czech - Required", price: "€500-800", accepted: "YES - Required" },
  { provider: "SafetyWing", type: "International", price: "€500-1,000", accepted: "NO - REJECTED" },
  { provider: "Cigna Global", type: "International", price: "€1,000-2,000", accepted: "NO - REJECTED" },
  { provider: "Allianz Care", type: "International", price: "€800-1,500", accepted: "NO - REJECTED" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Trade License (Živnostenský list)", amount: "~€30 (CZK 1,000)", notes: "One-time fee at Trade Office" },
  { item: "Long-term Visa Application", amount: "~€100 (CZK 2,500)", notes: "Embassy application fee" },
  { item: "Health Insurance (Annual)", amount: "€500-800", notes: "PVZP or Maxima only" },
  { item: "Residence Permit Card", amount: "~€50 (CZK 1,000)", notes: "Biometric card fee" },
  { item: "Document Translations", amount: "€100-300", notes: "Sworn translations required" },
  { item: "Criminal Record Apostille", amount: "€50-150", notes: "Varies by country" },
  { item: "Registered Agent (optional)", amount: "€100-300", notes: "For initial Czech address" },
];

