const timelineRows = [
  { step: "Obtain Trade License (Živnostenský list)", duration: "1-5 days", location: "Czech Trade Office (can use representative)" },
  { step: "Purchase PVZP or Maxima insurance", duration: "1-3 days", location: "Online (pvzp.cz or maxi.cz)" },
  { step: "Gather and apostille documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Obtain sworn translations", duration: "1-2 weeks", location: "Home country or Czech Republic" },
  { step: "Submit visa application IN PERSON", duration: "1 day", location: "Czech embassy/consulate" },
  { step: "Visa processing", duration: "60-90 days", location: "Ministry of Interior" },
  { step: "Collect visa", duration: "1 day", location: "Embassy pickup" },
