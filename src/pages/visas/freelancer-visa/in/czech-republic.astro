const insuranceRows = [
  { feature: "Annual Cost", pvzp: "€500-700/year", maxima: "€500-800/year" },
  { feature: "Accepted for Visa?", pvzp: "YES - required provider", maxima: "YES - required provider" },
  { feature: "Coverage Level", pvzp: "Comprehensive (hospital + outpatient)", maxima: "Comprehensive (hospital + outpatient)" },
  { feature: "Coverage Limit", pvzp: "CZK 2,000,000+", maxima: "CZK 2,000,000+" },
  { feature: "Emergency Repatriation", pvzp: "Included", maxima: "Included" },
  { feature: "Website", pvzp: "pvzp.cz", maxima: "maxi.cz" },
  { feature: "English Support", pvzp: "Yes", maxima: "Yes" },
];

const internationalInsuranceColumns = [
  { key: "provider", header: "International Provider" },
  { key: "accepted", header: "Accepted for Czech Visa?" },
  { key: "notes", header: "Notes" },
];

const internationalInsuranceRows = [
  { provider: "SafetyWing", accepted: "NO - NOT ACCEPTED", notes: "Will be rejected at embassy" },
  { provider: "Cigna Global", accepted: "NO - NOT ACCEPTED", notes: "Does not meet Czech requirements" },
  { provider: "Allianz Care", accepted: "NO - NOT ACCEPTED", notes: "Not on approved list" },
  { provider: "BUPA Global", accepted: "NO - NOT ACCEPTED", notes: "Not recognized by Czech authorities" },
  { provider: "World Nomads", accepted: "NO - NOT ACCEPTED", notes: "Travel insurance, not compliant" },
  { provider: "IMG Global", accepted: "NO - NOT ACCEPTED", notes: "Not on approved list" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
