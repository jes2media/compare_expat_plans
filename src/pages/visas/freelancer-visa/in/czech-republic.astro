  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Trade License (Živnostenský list)", details: "Required for all freelance activities", evidence: "Application at Trade Licensing Office" },
  { requirement: "Financial Proof", details: "~€5,000-6,000 in savings", evidence: "Bank statements (3 months)" },
  { requirement: "Health Insurance", details: "PVZP or Maxima ONLY", evidence: "Insurance certificate from approved provider" },
  { requirement: "Accommodation", details: "Proof of housing in Czech Republic", evidence: "Rental contract or registered agent confirmation" },
  { requirement: "Clean Criminal Record", details: "No criminal history", evidence: "Police clearance certificate (apostilled)" },
  { requirement: "Valid Passport", details: "Valid for duration of stay + 3 months", evidence: "Passport with 2+ blank pages" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "pvzp", header: "PVZP" },
  { key: "maxima", header: "Maxima" },
