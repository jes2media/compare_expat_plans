  { item: "Standard Visa Fee", amount: "€350+", notes: "Non-DAFT applicants" },
  { item: "Business Investment (DAFT)", amount: "€4,500", notes: "Minimum in bank/business" },
  { item: "KvK Registration", amount: "€75", notes: "Chamber of Commerce (one-time)" },
  { item: "Health Insurance", amount: "€120-150/month", notes: "Mandatory basic insurance" },
