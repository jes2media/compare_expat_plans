    <p class="mb-4">
      Setting up as a freelancer in the Netherlands involves visa fees, business registration, and ongoing health insurance costs. DAFT applicants have lower upfront costs than those going through the points system.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Total Upfront Costs</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">DAFT Path (US/Japan)</p>
        <p class="text-3xl font-bold text-neutral-900">~€4,900</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + investment + fees</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Path</p>
        <p class="text-3xl font-bold text-neutral-900">~€5,500+</p>
        <p class="text-sm text-neutral-500 mt-2">Higher fees + assessments</p>
      </div>
