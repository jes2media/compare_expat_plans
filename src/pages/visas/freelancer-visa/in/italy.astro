---
/**
 * Italy Freelancer Visa - Long-form CRO-optimized page
 * Lavoro Autonomo (Self-Employment) Visa guide with insurance requirements
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Italy", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Italy Health Insurance Guide", href: "/countries/italy/insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Italy Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/italy" },
  { title: "Spain Freelancer Visa", href: "/visas/freelancer-visa/in/spain" },
];

const visaTypesColumns = [
  { key: "feature", header: "Feature" },
  { key: "lavoroAutonomo", header: "Lavoro Autonomo" },
  { key: "digitalNomad", header: "Digital Nomad Visa" },
];

const visaTypesRows = [
  { feature: "Income Requirement", lavoroAutonomo: "€8,500/year minimum", digitalNomad: "€28,000/year minimum" },
  { feature: "Client Location", lavoroAutonomo: "Can work with Italian clients", digitalNomad: "Foreign clients only" },
  { feature: "Quota System", lavoroAutonomo: "Yes (limited slots)", digitalNomad: "No quota limits" },
  { feature: "Initial Duration", lavoroAutonomo: "2 years", digitalNomad: "1 year" },
  { feature: "Renewable", lavoroAutonomo: "Yes, indefinitely", digitalNomad: "Yes, up to 2 more years" },
  { feature: "Path to Residency", lavoroAutonomo: "Yes (after 5 years)", digitalNomad: "Limited pathway" },
  { feature: "Italian Tax Resident", lavoroAutonomo: "Yes", digitalNomad: "Possible (after 183 days)" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Minimum Income", details: "€8,500/year gross", notes: "Must prove financial sustainability" },
  { requirement: "Nulla Osta", details: "Authorization from Sportello Unico", notes: "Required before visa application" },
  { requirement: "Accommodation", details: "Rental contract or property ownership", notes: "Or hospitality declaration" },
  { requirement: "Health Insurance", details: "Valid coverage in Italy", notes: "Required for entire stay" },
  { requirement: "Professional Requirements", details: "Varies by profession", notes: "Some require Italian qualifications" },
  { requirement: "Criminal Record", details: "Clean background check", notes: "Apostilled from home country" },
  { requirement: "Quota Availability", details: "Must apply during Decreto Flussi", notes: "Usually early in year" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "italian", header: "Italian Private (Unisalute, etc.)" },
  { key: "international", header: "International (Cigna, Allianz)" },
];

const insuranceRows = [
  { feature: "Monthly Cost", italian: "€80-200", international: "€150-400" },
  { feature: "Visa Acceptance", italian: "Always accepted", international: "Accepted with proper documentation" },
  { feature: "Coverage Area", italian: "Italy only", international: "Worldwide" },
  { feature: "Pre-existing Conditions", italian: "Often excluded", international: "Varies by plan" },
  { feature: "English Support", italian: "Limited", international: "Full English support" },
  { feature: "Direct Billing", italian: "Yes, in network", international: "Yes, global network" },
  { feature: "SSN Access Later", italian: "Can supplement SSN", international: "Separate from SSN" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€200-400", strengths: "Comprehensive global coverage, large network" },
  { provider: "Allianz Care", type: "International", price: "€180-350", strengths: "Strong EU coverage, flexible plans" },
  { provider: "Bupa Global", type: "International", price: "€220-450", strengths: "Premium coverage, excellent service" },
  { provider: "AXA Global", type: "International", price: "€170-320", strengths: "Good value, solid coverage" },
  { provider: "Unisalute", type: "Italian", price: "€80-150", strengths: "Local network, lower cost, Italian support" },
  { provider: "Generali", type: "Italian", price: "€100-180", strengths: "Major Italian insurer, good network" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€116", notes: "National visa fee" },
  { item: "Nulla Osta Fee", amount: "€50-100", notes: "Work authorization" },
  { item: "Residence Permit (Permesso)", amount: "€70-100", notes: "Applied for after arrival" },
  { item: "Health Insurance", amount: "€80-400/month", notes: "Italian or international" },
  { item: "Codice Fiscale", amount: "Free", notes: "Tax identification number" },
  { item: "Commercialista (Accountant)", amount: "€100-250/month", notes: "Highly recommended" },
  { item: "INPS Social Security", amount: "~26% of income", notes: "Gestione Separata fund" },
  { item: "Income Tax", amount: "5-15% flat rate", notes: "Regime forfettario option" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Wait for Decreto Flussi opening", duration: "Usually January-March", location: "Monitor announcements" },
  { step: "Submit Nulla Osta application", duration: "Within application window", location: "Sportello Unico online" },
  { step: "Wait for Nulla Osta approval", duration: "30-120 days", location: "Italian authorities" },
  { step: "Apply for visa at consulate", duration: "1-2 weeks after Nulla Osta", location: "Italian embassy/consulate" },
  { step: "Visa processing", duration: "30-90 days", location: "Consulate" },
  { step: "Arrive in Italy", duration: "After visa issued", location: "Italy" },
  { step: "Apply for Permesso di Soggiorno", duration: "Within 8 days of arrival", location: "Post office (Poste Italiane)" },
  { step: "Receive Permesso", duration: "30-90 days", location: "Questura (police HQ)" },
  { step: "Register for Codice Fiscale", duration: "1 day", location: "Agenzia delle Entrate" },
  { step: "Open Partita IVA", duration: "1-2 weeks", location: "Agenzia delle Entrate" },
];
---

<PageShell
  title="Italy Freelancer Visa 2026: Lavoro Autonomo Requirements, Insurance & Guide"
  description="Complete guide to Italy's Freelancer Visa (Lavoro Autonomo). €8,500 minimum income, quota system, mandatory health insurance, and step-by-step application process for self-employed professionals."
  headline="Italy Freelancer Visa: Lavoro Autonomo Insurance & Requirements Guide"
  subheadline="Everything you need to know about freelancing in Italy—Lavoro Autonomo vs Digital Nomad visa, quota system timing, health insurance options, flat-rate tax regime, and the path to Italian residency."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Freelancer Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated April 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Italian Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Low €8,500 Income Threshold
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Italy offers one of Europe's most accessible freelancer visas in terms of income requirements—just €8,500 per year minimum. The Lavoro Autonomo (self-employment) visa allows non-EU nationals to work as freelancers, consultants, or independent professionals in Italy, with the ability to take on Italian clients and build a long-term career in the country.
    </p>

    <p class="mb-4">
      However, the Lavoro Autonomo visa operates under Italy's annual quota system (Decreto Flussi), which limits the number of work permits issued each year. This creates a competitive application process with specific timing windows—usually opening in January or February. Missing the window means waiting another year.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Italy Freelancer Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Lavoro Autonomo (Self-Employment Work Visa)</li>
        <li>• <strong>Income requirement:</strong> €8,500/year gross minimum</li>
        <li>• <strong>Health insurance:</strong> MANDATORY—Italian private or qualifying international insurance</li>
        <li>• <strong>Duration:</strong> Initial 2 years, renewable</li>
        <li>• <strong>Quota system:</strong> Yes—must apply during Decreto Flussi window</li>
        <li>• <strong>Path to PR:</strong> Permanent residence after 5 years of legal residency</li>
        <li>• <strong>Tax regime:</strong> Regime forfettario offers 5-15% flat tax rate</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Lavoro Autonomo vs. Digital Nomad Visa: Which to Choose?</h3>

    <p class="mb-4">
      Italy now offers two main paths for freelancers: the traditional Lavoro Autonomo visa and the newer Digital Nomad Visa (introduced 2024). Understanding the differences is crucial for choosing the right path.
    </p>

    <ComparisonTable columns={visaTypesColumns} rows={visaTypesRows} />

    <div class="grid md:grid-cols-2 gap-6 mt-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Choose Lavoro Autonomo If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>• You want to work with Italian clients</li>
          <li>• You plan to stay long-term (5+ years)</li>
          <li>• You want permanent residency pathway</li>
          <li>• You earn under €28,000/year</li>
          <li>• You want to build an Italian business</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Choose Digital Nomad Visa If:</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• You only work with foreign clients</li>
          <li>• You earn €28,000+/year</li>
          <li>• You want to avoid quota system</li>
          <li>• You prefer flexible, shorter stays</li>
          <li>• You work for a foreign employer</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important distinction:</strong> The Digital Nomad Visa does not allow you to work with Italian clients. If your business model includes serving the Italian market, the Lavoro Autonomo visa is your only option. The Digital Nomad Visa is strictly for those whose income comes entirely from outside Italy.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Italy is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want a low income threshold (€8,500/year)</li>
          <li>✓ You dream of living in Rome, Milan, or Florence</li>
          <li>✓ You can plan around quota system timing</li>
          <li>✓ You want favorable tax treatment (5-15% flat rate)</li>
          <li>✓ You value quality of life over bureaucratic simplicity</li>
          <li>✓ You're comfortable with Italian administrative pace</li>
          <li>✓ You want access to EU's third-largest economy</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need visa approval quickly (quota system takes months)</li>
          <li>• You can't wait for Decreto Flussi window</li>
          <li>• You want minimal bureaucracy (try Estonia)</li>
          <li>• You need to start working in Italy immediately</li>
          <li>• You don't speak any Italian (daily life is harder)</li>
          <li>• Your profession requires Italian-only licensing</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Timing matters:</strong> The Decreto Flussi typically opens in January or February each year. If you're reading this in March and the window has closed, you'll need to wait until next year—or consider the Digital Nomad Visa as an alternative if you qualify (€28,000+ income, foreign clients only).
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The Lavoro Autonomo visa requires proving that your freelance activity is economically viable and that you can support yourself in Italy. Unlike Germany or Portugal, Italy uses a quota system that limits how many self-employment visas are issued each year.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">The Decreto Flussi (Quota System) Explained</h3>

    <p class="mb-4">
      Italy's annual quota decree (Decreto Flussi) sets limits on how many non-EU workers can enter Italy for various purposes, including self-employment. The self-employment quota is typically much smaller than employment quotas—often just a few thousand slots for the entire country.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-amber-900 mb-3">Decreto Flussi Key Points:</h4>
      <ul class="space-y-2 text-amber-800">
        <li>• <strong>Timing:</strong> Usually opens January-March (dates announced late December)</li>
        <li>• <strong>Application method:</strong> Online through Sportello Unico per l'Immigrazione</li>
        <li>• <strong>Speed matters:</strong> Quotas often fill within days or hours of opening</li>
        <li>• <strong>Limited slots:</strong> Self-employment quotas are small compared to total work permits</li>
        <li>• <strong>Competition:</strong> High demand means preparation before opening is essential</li>
        <li>• <strong>Annual cycle:</strong> If you miss the window, wait until next year (or use DNV if eligible)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Essential Documents</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">For Nulla Osta Application</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport (6+ months validity)</li>
          <li>• Proof of income/financial resources</li>
          <li>• Business plan or activity description</li>
          <li>• Proof of accommodation in Italy</li>
          <li>• Professional qualifications (if applicable)</li>
          <li>• Health insurance documentation</li>
          <li>• Criminal record certificate (apostilled)</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">For Visa Application at Consulate</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Approved Nulla Osta</li>
          <li>• Completed visa application form</li>
          <li>• Passport photos (biometric)</li>
          <li>• Flight itinerary or booking</li>
          <li>• Health insurance confirmation</li>
          <li>• Proof of sufficient funds</li>
          <li>• Visa fee payment (€116)</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">The Nulla Osta (Work Authorization)</h3>

    <p class="mb-4">
      Before you can apply for the visa at an Italian consulate, you need a Nulla Osta—a work authorization issued by the local Sportello Unico per l'Immigrazione in the Italian province where you plan to live. This is the critical step that depends on the quota system.
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Who applies:</strong> You apply directly online through the Ministry of Interior portal</li>
      <li><strong>When:</strong> Only during the Decreto Flussi application window</li>
      <li><strong>Processing:</strong> 30-120 days depending on the province</li>
      <li><strong>Validity:</strong> Once approved, you have 6 months to apply for the visa</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Province matters:</strong> Processing times vary significantly by province. Milan and Rome have longer wait times due to volume. Smaller cities like Bologna, Florence, or Palermo may process faster. Choose your intended residence strategically if timing is critical.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        Italy requires all visa applicants to have valid health insurance covering the duration of their stay. Unlike some EU countries, Italy accepts both Italian private insurance and qualifying international health insurance for the initial visa application. However, once you become a tax resident and start paying into INPS, you may gain access to the public healthcare system (SSN).
      </p>
    </div>

    <p class="mb-4">
      For freelancers, you have two main options: Italian private insurance (like Unisalute or Generali) which is cheaper but Italy-only, or international insurance (like Cigna or Allianz) which is more expensive but provides worldwide coverage and is useful if you travel frequently.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Italian vs. International Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Which Insurance Should You Choose?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Choose Italian Private Insurance If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ You plan to stay primarily in Italy</li>
          <li>✓ Budget is a primary concern</li>
          <li>✓ You speak some Italian</li>
          <li>✓ You don't travel frequently</li>
          <li>✓ You'll gain SSN access eventually</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Choose International Insurance If:</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ You travel outside Italy frequently</li>
          <li>✓ You want English-language support</li>
          <li>✓ You have pre-existing conditions to cover</li>
          <li>✓ You want global emergency coverage</li>
          <li>✓ You may relocate from Italy later</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Access to SSN (Public Healthcare)</h3>

    <p class="mb-4">
      Italy's public healthcare system (Servizio Sanitario Nazionale or SSN) is available to legal residents who pay into the social security system (INPS). As a freelancer paying INPS contributions, you should eventually qualify for SSN enrollment—though the process can take several months.
    </p>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-blue-900 mb-3">SSN Enrollment for Freelancers:</h4>
      <ul class="space-y-2 text-blue-800">
        <li>• <strong>Eligibility:</strong> Legal residents paying INPS contributions</li>
        <li>• <strong>Cost:</strong> Free once enrolled (funded through taxes/INPS)</li>
        <li>• <strong>Coverage:</strong> GP visits, hospital care, prescriptions (small copays)</li>
        <li>• <strong>Enrollment:</strong> Apply at local ASL (Azienda Sanitaria Locale)</li>
        <li>• <strong>Timing:</strong> May take 3-6 months after starting INPS payments</li>
        <li>• <strong>Keep private insurance:</strong> Until SSN enrollment confirmed</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Don't drop private insurance too early:</strong> SSN enrollment can be slow, and there may be gaps in coverage. Keep your private or international insurance active until you have your SSN health card (tessera sanitaria) and have verified your enrollment with your local ASL.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Italian freelancer visa?"
    description="Compare international and Italian private options for self-employed professionals."
    buttonText="Compare Freelancer Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For the visa application, Italian authorities accept both Italian private insurance and comprehensive international insurance. Your choice depends on budget, travel needs, and whether you want Italian-language or English-language support.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Freelancer, Staying in Italy</h4>
        <p class="text-neutral-600">Start with Italian private insurance (Unisalute, Generali) at €80-150/month. Once you're paying INPS and gain SSN access, you can reduce private coverage to a supplement. This is the most cost-effective path for long-term residents.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Frequent Traveler or Digital Professional</h4>
        <p class="text-neutral-600">International insurance (Cigna Global, Allianz Care) provides worldwide coverage. If your work takes you across Europe or globally, international coverage means you're protected everywhere. Budget €200-400/month.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Family Relocating to Italy</h4>
        <p class="text-neutral-600">For families, Italian insurance is often more cost-effective since you're adding multiple people. Alternatively, international family plans from Cigna or Bupa cover the whole family under one policy with global coverage.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Italian insurers often exclude pre-existing conditions. International insurers like Cigna Global or Allianz Care may cover them after waiting periods or with specific plans. Check coverage carefully before committing.</p>
      </div>
    </div>
  </section>

