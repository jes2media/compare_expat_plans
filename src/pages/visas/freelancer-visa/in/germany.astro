const relatedLinks = [
  { title: "Germany Health Insurance Guide", href: "/countries/germany/insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Germany Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/germany" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "freiberufler", header: "Freiberufler (Liberal)" },
  { key: "gewerbe", header: "Gewerbetreibende (Trade)" },
];

const requirementsRows = [
  { requirement: "Minimum Income", freiberufler: "None specified (must prove sustainability)", gewerbe: "None specified (must prove sustainability)" },
  { requirement: "Business Plan", freiberufler: "Required—detailed description of services", gewerbe: "Required—detailed business plan" },
  { requirement: "Client Contracts", freiberufler: "Helpful—letters of intent, existing contracts", gewerbe: "Important—existing customers/orders" },
  { requirement: "Qualifications", freiberufler: "Diplomas, certifications, portfolio", gewerbe: "Trade certificates, experience proof" },
  { requirement: "Registration", freiberufler: "Finanzamt only", gewerbe: "Gewerbeamt + Finanzamt" },
  { requirement: "Health Insurance", freiberufler: "Mandatory—public or private", gewerbe: "Mandatory—public or private" },
