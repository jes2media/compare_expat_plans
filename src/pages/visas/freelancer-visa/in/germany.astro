const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "public", header: "Public (Gesetzliche)" },
  { key: "private", header: "Private Insurance" },
];

const insuranceRows = [
  { feature: "Monthly Cost", public: "~€200-400 (income-based)", private: "€200-500 (age/health-based)" },
  { feature: "Eligibility", public: "All self-employed can opt in", private: "Anyone, easier if healthy" },
  { feature: "KSK Option", public: "Artists/writers pay ~€200/month", private: "Not applicable" },
  { feature: "GP Access", public: "Any doctor, no referral", private: "Any doctor, often faster" },
  { feature: "Hospital Care", public: "Full coverage", private: "Full coverage, private rooms" },
  { feature: "Deductible", public: "None", private: "€500-2,500 common" },
  { feature: "Visa Acceptance", public: "Accepted", private: "Must meet minimum standards" },
];

