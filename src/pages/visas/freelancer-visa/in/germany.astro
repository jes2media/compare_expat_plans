  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "TK (Techniker Krankenkasse)", type: "Public", price: "€200-400+", strengths: "English support, app-based, most popular" },
  { provider: "Barmer", type: "Public", price: "€200-400+", strengths: "Good digital tools, nationwide" },
  { provider: "Allianz Care", type: "Private", price: "€250-500", strengths: "Comprehensive, global coverage option" },
  { provider: "Cigna Global", type: "Private", price: "€300-600", strengths: "Large network, flexible plans" },
  { provider: "Ottonova", type: "Private", price: "€300-450", strengths: "Digital-first, English-friendly" },
  { provider: "KSK (via public)", type: "Public (subsidized)", price: "~€200", strengths: "Artists, writers, journalists only" },
