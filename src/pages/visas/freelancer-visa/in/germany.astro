const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€100-150", notes: "Varies by embassy" },
  { item: "Residence Permit Fee", amount: "€100-150", notes: "Issued after arrival" },
  { item: "Health Insurance", amount: "€200-500/month", notes: "Public or private required" },
  { item: "Steuerberater (Tax Advisor)", amount: "€100-300/month", notes: "Highly recommended for compliance" },
  { item: "Certified Translations", amount: "€50-200", notes: "For non-German documents" },
  { item: "Trade Registration (Gewerbe)", amount: "€20-65", notes: "Only for trade activities" },
  { item: "Liability Insurance", amount: "€50-150/month", notes: "Often required by clients" },
  { item: "Financial Buffer", amount: "€5,000-15,000", notes: "Recommended savings" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents and business plan", duration: "2-4 weeks", location: "Home country" },
  { step: "Get health insurance confirmation", duration: "1-2 weeks", location: "Insurance provider" },
  { step: "Book visa appointment", duration: "1-8 weeks wait", location: "German embassy/consulate" },
  { step: "Attend visa appointment", duration: "1 day", location: "Embassy/consulate" },
  { step: "Visa processing", duration: "4-12 weeks", location: "Embassy review" },
  { step: "Arrive in Germany", duration: "After approval", location: "Germany" },
  { step: "Register residence (Anmeldung)", duration: "Within 2 weeks", location: "Bürgeramt" },
  { step: "Register with Finanzamt", duration: "Within 4 weeks", location: "Local tax office" },
  { step: "Register trade (if Gewerbe)", duration: "Within 4 weeks", location: "Gewerbeamt" },
  { step: "Get residence permit", duration: "1-4 weeks", location: "Ausländerbehörde" },
