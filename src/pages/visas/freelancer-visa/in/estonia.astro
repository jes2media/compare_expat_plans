---
/**
 * Estonia Freelancer/Self-Employed Visa - Long-form CRO-optimized page
 * Covers e-Residency, Digital Nomad Visa, and Self-Employment TRP
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Estonia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Estonia Health Insurance Guide", href: "/countries/estonia/insurance" },
  { title: "Estonia Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/estonia" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const pathwayColumns = [
  { key: "feature", header: "Feature" },
  { key: "eresidency", header: "e-Residency" },
  { key: "dnvisa", header: "Digital Nomad Visa" },
  { key: "selfemployed", header: "Self-Employed TRP" },
];

const pathwayRows = [
  { feature: "Physical Residence", eresidency: "No (digital identity only)", dnvisa: "Yes (up to 1 year)", selfemployed: "Yes (up to 5 years)" },
  { feature: "Income Requirement", eresidency: "None", dnvisa: "€3,504/month", selfemployed: "Sufficient funds (no fixed amount)" },
  { feature: "Business Requirement", eresidency: "Can form Estonian OÜ", dnvisa: "Must work remotely for foreign employer", selfemployed: "Business plan required" },
  { feature: "Processing Time", eresidency: "4-8 weeks", dnvisa: "2-4 weeks", selfemployed: "2-3 months" },
  { feature: "Fees", eresidency: "€100-120", dnvisa: "€80-100", selfemployed: "~€160" },
  { feature: "Renewable", eresidency: "Yes (every 5 years)", dnvisa: "No (non-renewable)", selfemployed: "Yes (renewable)" },
  { feature: "Path to PR", eresidency: "No", dnvisa: "No", selfemployed: "Yes (after 5 years)" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "requirement", header: "Requirement" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { feature: "Medical Coverage", requirement: "€30,000+ (Schengen)", notes: "EU minimum standard" },
  { feature: "Repatriation", requirement: "Required", notes: "Return transport if needed" },
  { feature: "Coverage Duration", requirement: "Full stay period", notes: "No gaps allowed" },
  { feature: "EU/Schengen Area", requirement: "Must be covered", notes: "For travel within EU" },
  { feature: "Haigekassa Access", requirement: "Not included", notes: "Only for employed/tax-paying residents" },
  { feature: "Private Insurance", requirement: "Required for freelancers", notes: "€100-200/month typical" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€40-75", strengths: "Budget-conscious nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive global coverage" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-300", strengths: "EU-focused, strong network" },
  { provider: "Feather", coverage: "Varies", price: "€80-180", strengths: "EU expat specialist" },
  { provider: "BUPA Global", coverage: "€2,000,000+", price: "€280-450", strengths: "Premium coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "e-Residency Application", amount: "€100-120", notes: "One-time, digital ID only" },
  { item: "Estonian OÜ Formation", amount: "€190-500", notes: "Company registration + share capital" },
  { item: "Digital Nomad Visa", amount: "€80-100", notes: "1 year, non-renewable" },
  { item: "Self-Employed TRP", amount: "~€160", notes: "Up to 5 years, renewable" },
  { item: "Health Insurance", amount: "€100-200/month", notes: "Private insurance required" },
  { item: "Virtual Office", amount: "€30-100/month", notes: "For company legal address" },
  { item: "Accounting Services", amount: "€50-150/month", notes: "Required for OÜ compliance" },
  { item: "Bank Account", amount: "€0-10/month", notes: "LHV, Wise, or fintech options" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const eresidencyTimelineRows = [
  { step: "Apply online for e-Residency", duration: "30 minutes", location: "Online" },
  { step: "Background check and processing", duration: "4-8 weeks", location: "Police and Border Guard" },
  { step: "Pick up e-Residency kit", duration: "1 day", location: "Embassy or Estonia" },
  { step: "Form Estonian OÜ company", duration: "1-3 days", location: "Online (e-Business Register)" },
  { step: "Open business bank account", duration: "1-2 weeks", location: "Online or in-person" },
  { step: "Apply for DN Visa or TRP (if residing)", duration: "2-12 weeks", location: "Embassy or in Estonia" },
];

const dnvisaTimelineRows = [
  { step: "Gather documents and income proof", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit visa application", duration: "1 day", location: "Estonian embassy" },
  { step: "Processing", duration: "15-30 days", location: "Police and Border Guard" },
  { step: "Receive decision", duration: "Via email", location: "Digital notification" },
  { step: "Collect visa", duration: "1-5 days", location: "Embassy or in Estonia" },
  { step: "Register address in Estonia", duration: "Within 30 days", location: "Local municipality" },
];
---

<PageShell
  title="Estonia Freelancer Visa 2026: e-Residency, DN Visa & Self-Employed Guide"
  description="Complete guide to freelancing in Estonia. Understand e-Residency vs Digital Nomad Visa vs Self-Employed TRP. Insurance requirements, company formation, and the world's most digital country."
  headline="Estonia Freelancer Visa: e-Residency, Insurance & Requirements Guide"
  subheadline="Everything you need to know about freelancing in the world's most digital country—e-Residency, Digital Nomad Visa, Self-Employed TRP, mandatory private insurance, and Estonian company formation."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Freelancer Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/visas/freelancer-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Estonian Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU/Schengen Member
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Estonia has positioned itself as the world's most digitally advanced country and a magnet for location-independent entrepreneurs. Known for pioneering e-Residency—a digital identity for global business owners—Estonia offers freelancers several pathways to work from this Baltic tech hub.
    </p>

    <p class="mb-4">
      Tallinn, the capital, is home to a thriving startup ecosystem that produced unicorns like Skype, Wise (TransferWise), and Bolt. The country's "e-Estonia" infrastructure means 99% of government services are online, taxes can be filed in minutes, and business formation happens in hours rather than weeks.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Freelancing in Estonia</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>e-Residency:</strong> Digital identity (€100-120)—NOT a visa, but enables Estonian company</li>
        <li>• <strong>Digital Nomad Visa:</strong> 1 year, €3,504/month income, non-renewable</li>
        <li>• <strong>Self-Employed TRP:</strong> Up to 5 years, renewable, path to permanent residence</li>
        <li>• <strong>Health insurance:</strong> Private insurance REQUIRED—Haigekassa not available to freelancers</li>
        <li>• <strong>Popular structure:</strong> e-Residency + OÜ company (location-independent)</li>
        <li>• <strong>English proficiency:</strong> Excellent, especially in Tallinn</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Three Pathways for Freelancers</h3>

    <p class="mb-4">
      Estonia offers distinct options depending on whether you want to live in Estonia, run a business remotely, or both. Understanding these differences is crucial before applying.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">e-Residency</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Digital identity card</li>
          <li>• Form Estonian OÜ company</li>
          <li>• Access EU banking and payments</li>
          <li>• Manage business 100% online</li>
          <li>• <strong>NOT a residence permit</strong></li>
          <li>• Live anywhere in the world</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Digital Nomad Visa</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Physical residence in Estonia</li>
          <li>• €3,504/month income required</li>
          <li>• Work remotely for foreign employer</li>
          <li>• Valid up to 1 year</li>
          <li>• <strong>Non-renewable</strong></li>
          <li>• Full Schengen travel access</li>
        </ul>
      </div>

      <div class="border border-purple-200 bg-purple-50 rounded-lg p-6">
        <h4 class="font-semibold text-purple-900 mb-3">Self-Employed TRP</h4>
        <ul class="space-y-2 text-purple-800">
          <li>• Long-term residence permit</li>
          <li>• Requires business plan</li>
          <li>• Valid up to 5 years</li>
          <li>• <strong>Renewable</strong></li>
          <li>• Path to permanent residence</li>
          <li>• Run Estonian business locally</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Common combination:</strong> Many location-independent freelancers get e-Residency, form an Estonian OÜ company, then continue living elsewhere. If you actually want to live in Estonia, you'll need either the Digital Nomad Visa (short-term) or Self-Employed TRP (long-term) in addition to e-Residency.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Estonia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You value digital infrastructure and e-government</li>
          <li>✓ You want an EU company structure (OÜ)</li>
          <li>✓ You work in tech, startups, or digital services</li>
          <li>✓ You earn €3,500+/month (for DN Visa)</li>
          <li>✓ You appreciate efficient bureaucracy</li>
          <li>✓ You enjoy Baltic/Nordic culture and four seasons</li>
          <li>✓ You want access to Helsinki (2-hour ferry)</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You expect e-Residency to give you residence rights</li>
          <li>• You want warm weather year-round</li>
          <li>• You need a path to citizenship (Estonia is strict)</li>
          <li>• You prefer larger expat communities</li>
          <li>• You work Americas time zones primarily</li>
          <li>• You can't afford €100-200/month for private insurance</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Helsinki backup:</strong> Tallinn is just a 2-hour ferry from Helsinki, Finland. Many freelancers in Estonia use Helsinki for specialized medical care or larger-city amenities. Your Schengen visa or residence permit allows easy travel between the two.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Estonia offers multiple pathways for freelancers. Here's a side-by-side comparison to help you choose the right one for your situation.
    </p>

    <ComparisonTable columns={pathwayColumns} rows={pathwayRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">e-Residency Requirements</h3>

    <p class="mb-4">
      e-Residency is Estonia's digital identity program for global entrepreneurs. It's the easiest pathway—you don't need to visit Estonia, meet income requirements, or prove business viability. However, it gives you zero residence rights.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Requirements</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Valid passport</li>
          <li>• Passport-style photo</li>
          <li>• Brief statement of purpose</li>
          <li>• €100-120 application fee</li>
          <li>• Clean criminal record (checked)</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">What You Get</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Digital identity card + reader</li>
          <li>• Ability to form Estonian OÜ</li>
          <li>• Access to Estonian digital services</li>
          <li>• EU business banking options</li>
          <li>• Digital signatures valid in EU</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Digital Nomad Visa Requirements</h3>

    <p class="mb-4">
      The Digital Nomad Visa is for remote workers who want to live in Estonia while working for a foreign employer. It's Estonia's answer to the global remote work trend, launched in 2020.
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Income:</strong> €3,504/month averaged over the past 6 months</li>
      <li><strong>Employment:</strong> Work remotely for employer outside Estonia, OR run your own business serving non-Estonian clients</li>
      <li><strong>Insurance:</strong> Schengen-compliant health insurance (€30,000+ coverage)</li>
      <li><strong>Passport:</strong> Valid 3+ months beyond planned stay</li>
      <li><strong>Clean record:</strong> No criminal history</li>
    </ul>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Self-Employed TRP Requirements</h3>

    <p class="mb-4">
      The Self-Employed Temporary Residence Permit is for freelancers who want to build a long-term business in Estonia. It's more involved than the DN Visa but offers a renewable permit and path to permanent residence.
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Business plan:</strong> Detailed description of your business activities</li>
      <li><strong>Sufficient funds:</strong> Proof you can support yourself (bank statements, contracts)</li>
      <li><strong>Estonian business:</strong> Typically involves forming an OÜ company</li>
      <li><strong>Insurance:</strong> Private health insurance required</li>
      <li><strong>Clean record:</strong> Background check</li>
      <li><strong>Address:</strong> Accommodation in Estonia</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Note on income:</strong> While the Self-Employed TRP doesn't have a fixed income requirement like the DN Visa, immigration authorities want to see you can sustain yourself. In practice, demonstrating €2,000-3,000/month in savings or contracts helps your application.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Private Insurance is Mandatory</h3>
      <p class="text-red-800">
        Estonia's public health system (Haigekassa) is NOT available to freelancers unless you're employed and paying social tax. e-Residents, Digital Nomad Visa holders, and most self-employed professionals must arrange private health insurance. Budget €100-200/month.
      </p>
    </div>

    <p class="mb-4">
      This is one of the most important (and often misunderstood) aspects of freelancing in Estonia. Unlike some countries where self-employed individuals can access public healthcare, Estonia requires you to be employed and paying social tax to access Haigekassa.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Insurance Requirements by Pathway</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Who Gets Haigekassa Access?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Haigekassa Eligible</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Employees with Estonian employment contract</li>
          <li>✓ Self-employed paying social tax (33%)</li>
          <li>✓ Pensioners receiving Estonian pension</li>
          <li>✓ Students at Estonian institutions</li>
          <li>✓ Parents on parental leave</li>
          <li>✓ Registered unemployed</li>
        </ul>
      </div>

      <div class="border border-red-200 bg-red-50 rounded-lg p-6">
        <h4 class="font-semibold text-red-900 mb-3">NOT Haigekassa Eligible</h4>
        <ul class="space-y-2 text-red-800">
          <li>✗ e-Residents (digital identity only)</li>
          <li>✗ Digital Nomad Visa holders</li>
          <li>✗ OÜ owners not paying themselves salary</li>
          <li>✗ Freelancers with foreign clients only</li>
          <li>✗ Remote workers for foreign companies</li>
          <li>✗ Tourists and short-term visitors</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">The OÜ + Salary Workaround</h3>

    <p class="mb-4">
      Some freelancers form an Estonian OÜ company and pay themselves a minimum salary (around €725/month in 2026) to access Haigekassa. This triggers social tax obligations but provides public healthcare. However, this adds complexity, costs, and tax implications—consult an Estonian accountant before choosing this route.
    </p>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <p class="text-blue-800">
        <strong>Calculation example:</strong> If you pay yourself €725/month salary, your company pays ~€240/month in social tax (33%). That's about the same cost as good private insurance, but you get Haigekassa access. The trade-off: more paperwork, tax filing, and you're now an "employer."
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Private Insurance Requirements</h3>

    <p class="mb-4">
      For visa and residence permit purposes, your private insurance must meet Schengen standards:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li>Minimum €30,000 medical coverage</li>
      <li>Repatriation coverage included</li>
      <li>Valid throughout the Schengen area</li>
      <li>Coverage for entire stay duration</li>
      <li>No exclusions for COVID-19 or pandemics</li>
    </ul>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Estonia move?"
    description="Compare private health insurance plans that meet Estonian visa requirements."
    buttonText="Compare Qualifying Plans"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer Schengen-compliant coverage suitable for freelancers in Estonia. All meet the minimum requirements for visa applications and residence permits.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Freelancer</h4>
        <p class="text-neutral-600">SafetyWing at €40-75/month is the most affordable option that meets Schengen requirements. Good for healthy digital nomads who need basic coverage.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Location-Independent Entrepreneur</h4>
        <p class="text-neutral-600">Cigna Global provides comprehensive worldwide coverage. Ideal if you travel frequently between Estonia and other countries.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Professional</h4>
        <p class="text-neutral-600">Allianz Care or Feather offer strong European networks. Feather specifically caters to EU expats and integrates well with Estonian digital infrastructure.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage Seeker</h4>
        <p class="text-neutral-600">BUPA Global provides top-tier coverage with excellent customer service. Worth it if you want premium hospital rooms and global evacuation coverage.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-Term Resident (Haigekassa Route)</h4>
        <p class="text-neutral-600">If you form an OÜ and pay yourself a salary, you'll access Haigekassa. Consider supplemental private insurance for faster specialist access or services not fully covered.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
