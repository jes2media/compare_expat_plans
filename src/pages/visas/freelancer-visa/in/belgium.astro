---
/**
 * Belgium Freelancer Visa - Long-form CRO-optimized page
 * Professional Card guide with insurance requirements
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Belgium", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Netherlands Freelancer Visa", href: "/visas/freelancer-visa/in/netherlands" },
  { title: "France Freelancer Visa", href: "/visas/freelancer-visa/in/france" },
  { title: "Germany Freelancer Visa", href: "/visas/freelancer-visa/in/germany" },
];

const regionColumns = [
  { key: "feature", header: "Feature" },
  { key: "flanders", header: "Flanders" },
  { key: "wallonia", header: "Wallonia" },
  { key: "brussels", header: "Brussels-Capital" },
];

const regionRows = [
  { feature: "Authority", flanders: "VLAIO", wallonia: "SPW Économie", brussels: "Brussels Economy" },
  { feature: "Language", flanders: "Dutch", wallonia: "French", brussels: "Dutch/French" },
  { feature: "Processing Time", flanders: "60-90 days", wallonia: "90-120 days", brussels: "90-120 days" },
  { feature: "Economic Focus", flanders: "Business viability", wallonia: "Economic benefit", brussels: "Value to region" },
  { feature: "Fee", flanders: "€140", wallonia: "€140", brussels: "€140" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
