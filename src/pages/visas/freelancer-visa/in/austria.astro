  { requirement: "Business Plan", rwrCard: "Must demonstrate economic benefit", settlement: "Proof of sustainable activity" },
  { requirement: "Income Proof", rwrCard: "~€1,100-1,400/month minimum", settlement: "~€1,100-1,400/month minimum" },
  { requirement: "Gewerbeschein", rwrCard: "Trade license required", settlement: "Trade license or profession registration" },
  { requirement: "Health Insurance", rwrCard: "Mandatory—SVS or private", settlement: "Mandatory—SVS or private" },
  { requirement: "Duration", rwrCard: "2 years initially", settlement: "1 year initially" },
  { requirement: "German Language", rwrCard: "Points for German (A1=5pts, A2=10pts)", settlement: "A1 often required" },
