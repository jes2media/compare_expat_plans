  { key: "private", header: "Private Insurance" },
];

const insuranceRows = [
  { feature: "Monthly Cost", svs: "~27% of income (capped)", private: "€250-600 (age/health-based)" },
  { feature: "Eligibility", svs: "Mandatory for all self-employed", private: "Optional supplement or initial coverage" },
  { feature: "Healthcare", svs: "Full ÖGK public healthcare access", private: "Private doctors and hospitals" },
  { feature: "Pension", svs: "Included in contribution", private: "Not included" },
  { feature: "Deductible", svs: "Small copays only", private: "€300-2,500 common" },
  { feature: "Visa Acceptance", svs: "Accepted", private: "Must meet minimum standards" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SVS + ÖGK", type: "Mandatory Social", price: "~27% of income", strengths: "Comprehensive public healthcare + pension" },
  { provider: "Allianz Care", type: "Private International", price: "€300-500", strengths: "Initial coverage before SVS, global coverage" },
  { provider: "Cigna Global", type: "Private International", price: "€350-600", strengths: "Large network, flexible plans" },
  { provider: "UNIQA", type: "Private Austrian", price: "€200-400", strengths: "Local expertise, supplementary coverage" },
  { provider: "Wiener Städtische", type: "Private Austrian", price: "€180-350", strengths: "Austrian market leader" },
  { provider: "Generali Austria", type: "Private Austrian", price: "€220-450", strengths: "Good supplementary options" },
