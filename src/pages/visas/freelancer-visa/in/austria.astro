const pointsRows = [
  { category: "Qualifications", criteria: "University degree", points: "20-25" },
  { category: "Qualifications", criteria: "Vocational training", points: "15-20" },
  { category: "Experience", criteria: "3+ years professional experience", points: "10-20" },
  { category: "Language", criteria: "German A1 / A2 / B1", points: "5 / 10 / 15" },
