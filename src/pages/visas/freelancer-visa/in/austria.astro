  { item: "RWR Card Application", amount: "€120-160", notes: "Varies by permit type" },
  { item: "SVS Contributions", amount: "~27% of income", notes: "Mandatory (health, pension, accident)" },
  { item: "Minimum SVS (Year 1)", amount: "~€150-200/month", notes: "Reduced rate for new businesses" },
  { item: "Gewerbeschein (Trade License)", amount: "€50-300", notes: "Depends on trade type" },
  { item: "Wirtschaftskammer (Chamber)", amount: "€100-500/year", notes: "Mandatory membership" },
  { item: "Steuerberater (Tax Advisor)", amount: "€100-300/month", notes: "Highly recommended" },
  { item: "Translations & Apostilles", amount: "€100-300", notes: "For foreign documents" },
