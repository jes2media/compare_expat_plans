  { step: "Gather documents, translations, apostilles", duration: "2-4 weeks", location: "Home country" },
  { step: "Apply for initial visa (D visa)", duration: "4-12 weeks processing", location: "Austrian embassy" },
  { step: "Arrive in Austria", duration: "After D visa", location: "Austria" },
  { step: "Register residence (Meldezettel)", duration: "Within 3 days", location: "Meldeamt" },
