---
/**
 * Ireland Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Ireland", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Ireland Health Insurance Guide", href: "/countries/ireland/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "University Acceptance", details: "Letter from Irish institution", evidence: "Official acceptance letter" },
  { requirement: "Financial Proof", details: "€10,000 immediately available", evidence: "Bank statement showing €10,000" },
  { requirement: "Tuition Evidence", details: "Paid or ability to pay", evidence: "Payment receipt or bank statement" },
  { requirement: "Health Insurance", details: "Private medical insurance", evidence: "Insurance certificate" },
  { requirement: "English Proficiency", details: "IELTS 5.5-6.5 typically", evidence: "Test certificate" },
  { requirement: "Clean Record", details: "No criminal convictions", evidence: "Police clearance certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "requirement", header: "Ireland Requirement" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { feature: "Type", requirement: "Private medical insurance", notes: "Public HSE not available to students initially" },
  { feature: "Coverage", requirement: "Comprehensive medical", notes: "Hospital, doctor visits, emergencies" },
  { feature: "Duration", requirement: "Full length of stay", notes: "Must cover entire study period" },
  { feature: "Provider", requirement: "Any reputable insurer", notes: "Irish or international accepted" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Irish Life Health", type: "Irish Local", price: "€80-150", strengths: "Local network, Irish support" },
  { provider: "VHI Healthcare", type: "Irish Local", price: "€90-160", strengths: "Largest Irish insurer" },
  { provider: "Laya Healthcare", type: "Irish Local", price: "€85-140", strengths: "Good student plans" },
  { provider: "Cigna Global", type: "International", price: "€100-180", strengths: "Global coverage, expat-focused" },
  { provider: "Allianz Care", type: "International", price: "€90-160", strengths: "Good EU coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Fee", amount: "€60-100", notes: "Single or multi-entry" },
  { item: "Tuition (EU)", amount: "€0-3,000/year", notes: "Free Grant + student contribution" },
  { item: "Tuition (Non-EU)", amount: "€10,000-25,000/year", notes: "Varies by program" },
  { item: "Health Insurance", amount: "€80-180/month", notes: "Private insurance required" },
  { item: "IRP Registration", amount: "€300", notes: "Immigration registration fee" },
  { item: "IELTS Test", amount: "€200-230", notes: "If required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Receive university acceptance", duration: "Varies", location: "University" },
  { step: "Pay tuition deposit", duration: "1-2 weeks", location: "University" },
  { step: "Apply for study visa (AVATS)", duration: "1 day", location: "Online" },
  { step: "Attend biometrics appointment", duration: "1 day", location: "Visa office" },
  { step: "Visa processing", duration: "4-8 weeks", location: "Irish authorities" },
  { step: "Travel to Ireland", duration: "-", location: "-" },
  { step: "Register with GNIB/IRP", duration: "Within 90 days", location: "Immigration office" },
  { step: "Receive Stamp 2 permission", duration: "Same day", location: "Immigration office" },
];
---

<PageShell
  title="Ireland Student Visa 2026: Requirements, Insurance & Stamp 1G Guide"
  description="Complete guide to studying in Ireland. €10,000 financial proof, private insurance requirements, Stamp 1G 2-year post-study work visa, and application process."
  headline="Ireland Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in Ireland—English-speaking environment, €10,000 financial requirement, private insurance, and the excellent 2-year Stamp 1G post-study work visa."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official INIS Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      2-Year Stamp 1G Work Visa
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Ireland is an increasingly popular destination for international students, especially those seeking an <strong>English-speaking environment</strong> with strong ties to the tech and pharmaceutical industries. Major companies like Google, Facebook, Apple, and Pfizer have European headquarters in Ireland, creating excellent employment prospects.
    </p>

    <p class="mb-4">
      The key advantage of studying in Ireland is the <strong>Stamp 1G post-study work visa</strong>—2 years to find work after graduating from a degree program. Combined with one of Europe's highest minimum wages (€12.70/hour), Ireland offers strong earning potential during and after studies.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Ireland Student Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Language:</strong> English-speaking—no language barrier</li>
        <li>• <strong>Financial proof:</strong> €10,000 immediately available (strict)</li>
        <li>• <strong>Insurance:</strong> Private medical insurance required (no public access initially)</li>
        <li>• <strong>Work rights:</strong> 20 hrs/week term, 40 hrs/week holidays</li>
        <li>• <strong>Stamp 1G:</strong> 2-year post-study work visa for degree holders</li>
        <li>• <strong>Minimum wage:</strong> €12.70/hour (among Europe's highest)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Study in Ireland?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>English-speaking:</strong> No language barrier for studies or daily life</li>
      <li><strong>Tech hub:</strong> Google, Facebook, Apple, LinkedIn all have European HQs</li>
      <li><strong>Pharma industry:</strong> Major pharmaceutical companies (Pfizer, Johnson & Johnson)</li>
      <li><strong>Stamp 1G:</strong> 2-year post-study work visa—one of Europe's best</li>
      <li><strong>High wages:</strong> €12.70/hour minimum wage, good earning potential</li>
      <li><strong>Quality education:</strong> Trinity College Dublin, UCD in global top 200</li>
      <li><strong>Friendly culture:</strong> Known for welcoming international students</li>
      <li><strong>EU access:</strong> Gateway to EU market and travel</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Ireland is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want to study entirely in English</li>
          <li>✓ You want to work in tech or pharma</li>
          <li>✓ You want strong post-study work options (Stamp 1G)</li>
          <li>✓ You can demonstrate €10,000 upfront</li>
          <li>✓ You want high earning potential while studying</li>
          <li>✓ You prefer a friendly, welcoming culture</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Budget is very tight (Ireland is expensive)</li>
          <li>• You want free/cheap tuition (Germany, Italy better)</li>
          <li>• You want public healthcare access (Italy's SSN is €150/year)</li>
          <li>• You prefer warmer climate</li>
          <li>• €10,000 upfront is difficult to demonstrate</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Stamp 1G advantage:</strong> After completing a degree (Level 8+), you can apply for Stamp 1G—a 2-year permission to work in Ireland while seeking employment. You can work any job during this time. It's one of Europe's most generous post-study work visas.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Ireland requires acceptance from an Irish institution, proof of €10,000 immediately available funds, private health insurance, and English language proficiency.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">The €10,000 Requirement</h3>

    <p class="mb-4">
      Ireland's financial requirement is specific: you must show <strong>€10,000 immediately available</strong> in your bank account. This is different from other countries that accept annual income proof or blocked accounts.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Timing matters:</strong> Your bank statement should show €10,000 available at the time of your visa application. If funds are recently deposited, immigration may question the source. Ideally, show consistent funds over several months.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">If Parents Are Sponsoring</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Parent's bank statement:</strong> Showing €10,000+ available</li>
      <li><strong>Sponsorship letter:</strong> Signed declaration of financial support</li>
      <li><strong>Relationship proof:</strong> Birth certificate or family documentation</li>
      <li><strong>Parent's employment:</strong> Letter confirming income/employment</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-amber-900 mb-2">Private Insurance Required—No Public Healthcare Initially</h3>
      <p class="text-amber-800">
        Unlike Italy (€150/year SSN) or UK (NHS via IHS), Ireland requires <strong>private health insurance</strong> for students. You cannot access the public HSE system until you establish "habitual residence"—typically after 1+ year. Budget €80-180/month for private coverage.
      </p>
    </div>

    <p class="mb-4">
      Ireland doesn't have specific policy requirements like Spain's "no copays" rule. Any reputable private health insurance that covers medical treatment in Ireland is acceptable. Irish local insurers (VHI, Irish Life Health, Laya) and international insurers (Cigna, Allianz) all work.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">What Your Insurance Should Cover</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Irish vs. International Insurers</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Irish Local Insurers</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ VHI, Irish Life Health, Laya Healthcare</li>
          <li>✓ Strong local hospital and doctor networks</li>
          <li>✓ Irish customer service</li>
          <li>✓ Often have student-specific plans</li>
          <li>✓ Coverage primarily in Ireland</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurers</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Cigna Global, Allianz Care, BUPA</li>
          <li>✓ Coverage when traveling outside Ireland</li>
          <li>✓ Familiar if you've used them before</li>
          <li>✓ May cover home country visits</li>
          <li>✓ Often more expensive</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>After 1+ year—potential HSE access:</strong> After establishing "habitual residence" (typically 1+ year of legal residence), you may qualify for a medical card (income-dependent) giving access to free public healthcare. Until then, maintain private insurance.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need health insurance for Ireland?"
    description="Compare VHI, Laya, and international options for students."
    buttonText="Compare Ireland Insurance Options"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Irish local insurers offer strong local networks, while international insurers provide coverage for travel. Both types are accepted for visa applications.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Recommendations by Need</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Staying in Ireland Only</h4>
        <p class="text-neutral-600">Irish insurers (VHI, Irish Life Health, Laya) offer the best local networks and often have student-specific plans. VHI is the largest, Laya is popular for value, Irish Life Health has good comprehensive options.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Traveling Often</h4>
        <p class="text-neutral-600">International insurers (Cigna Global, Allianz Care) provide coverage across Europe and beyond. Good if you'll travel frequently during breaks or visit home. More expensive but more flexible.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious</h4>
        <p class="text-neutral-600">Look for basic plans from Laya or Irish Life Health. Some universities partner with insurers for student rates. Basic coverage (~€80-100/month) is sufficient for most healthy students.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Irish insurers must offer "community rating"—they can't charge more for pre-existing conditions after a waiting period. Cigna Global also handles pre-existing conditions well. Discuss your situation before purchasing.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Ireland is expensive compared to continental Europe. Non-EU tuition is significant (€10,000-25,000/year), and private insurance adds to costs. However, high wages (€12.70/hour minimum) help offset expenses.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">EU vs. Non-EU Tuition</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">EU/EEA Students</h4>
        <p class="text-green-800 text-sm mb-2">May qualify for free fees if meeting residency requirements</p>
        <ul class="space-y-2 text-green-700 text-sm">
          <li>• Free Fees Initiative: €0 tuition</li>
          <li>• Student contribution: ~€3,000/year</li>
          <li>• Total: ~€3,000/year</li>
          <li>• Some grants available (SUSI)</li>
        </ul>
      </div>

      <div class="bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Non-EU Students</h4>
        <p class="text-amber-800 text-sm mb-2">Pay full international fees</p>
        <ul class="space-y-2 text-amber-700 text-sm">
          <li>• Undergraduate: €10,000-15,000/year</li>
          <li>• Postgraduate: €12,000-25,000/year</li>
          <li>• Medicine: €45,000-55,000/year</li>
          <li>• Scholarships available but competitive</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Living Costs</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Dublin</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €700-1,200/month (room or studio)</li>
          <li>• Food: €250-350/month</li>
          <li>• Transport: €100-120/month (Leap card)</li>
          <li>• Insurance: €80-180/month</li>
          <li>• Other: €150-250/month</li>
          <li>• <strong>Total: €1,300-2,000/month</strong></li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Cork, Galway, Limerick</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €500-800/month</li>
          <li>• Food: €200-300/month</li>
          <li>• Transport: €50-80/month</li>
          <li>• Insurance: €80-180/month</li>
          <li>• Other: €100-200/month</li>
          <li>• <strong>Total: €1,000-1,500/month</strong></li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>High earning potential:</strong> Irish minimum wage is €12.70/hour—among Europe's highest. Working 20 hours/week = €1,000+/month, potentially covering most living costs. During holiday periods (40 hours/week), you can earn €2,000+/month.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Ireland's visa process is done online through the AVATS system. After arrival, you register with immigration (GNIB/IRP) to receive your Stamp 2 permission.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get University Acceptance</h4>
          <p class="text-neutral-600">Apply to Irish universities directly. Once accepted, you'll receive an official acceptance letter. This letter is required for your visa application.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Tuition Deposit</h4>
          <p class="text-neutral-600">Most universities require a deposit (often €6,000-10,000) to confirm your place. This is applied toward your tuition. Keep the payment receipt—it's evidence of your ability to pay fees.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online via AVATS</h4>
          <p class="text-neutral-600">Complete the online application through the AVATS (Automated Visa Application Tracking System). Upload required documents: acceptance letter, financial proof, insurance, passport copy, photo.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Attend Biometrics Appointment</h4>
          <p class="text-neutral-600">Schedule and attend a biometrics appointment at your local visa application center. Provide fingerprints and have your photo taken. Pay the visa fee (€60-100).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Decision</h4>
          <p class="text-neutral-600">Processing typically takes 4-8 weeks. You can track your application through AVATS. Once approved, your passport will be returned with a visa sticker.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Travel and Register with GNIB/IRP</h4>
          <p class="text-neutral-600">Arrive in Ireland and register with immigration (GNIB/IRP) within 90 days. Book an appointment online (Dublin) or walk in (other cities). Bring passport, visa, acceptance letter, proof of address, and €300 registration fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Stamp 2 Permission</h4>
          <p class="text-neutral-600">At your registration appointment, you'll receive Stamp 2 in your passport—your permission to study in Ireland. This allows you to work 20 hours/week during term and 40 hours/week during holidays.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Dublin registration tip:</strong> GNIB/IRP appointments in Dublin can be difficult to get—slots fill quickly. Check the booking website frequently (early morning is best) or use a notification service. Outside Dublin, many offices accept walk-ins.
      </p>
    </div>
  </section>

