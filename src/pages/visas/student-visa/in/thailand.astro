---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', label: 'Overview' },
  { id: 'quick-decision', label: 'Quick Decision Guide' },
  { id: 'requirements', label: 'Official Requirements' },
  { id: 'insurance-requirements', label: 'Insurance Requirements' },
  { id: 'recommended-providers', label: 'Recommended Providers' },
  { id: 'costs', label: 'Costs Breakdown' },
  { id: 'application-timeline', label: 'Application Timeline' },
  { id: 'scenarios', label: 'Real-World Scenarios' },
  { id: 'common-mistakes', label: 'Common Mistakes' },
  { id: 'healthcare-access', label: 'Healthcare Access' },
  { id: 'faqs', label: 'FAQs' },
  { id: 'verdict', label: 'Final Verdict' },
];

const relatedLinks = [
  { href: '/visas/student-visa/in/malaysia', label: 'Malaysia Student Visa' },
  { href: '/visas/student-visa/in/taiwan', label: 'Taiwan Student Visa' },
  { href: '/visas/digital-nomad-visa/in/thailand', label: 'Thailand Digital Nomad Visa' },
  { href: '/best/expat-health-insurance', label: 'Compare Expat Insurance' },
  { href: '/insurance-for/students-abroad', label: 'Student Insurance Guide' },
];

const requirementsColumns = [
  { key: 'requirement', header: 'Requirement' },
  { key: 'details', header: 'Details' },
];

const requirementsRows = [
  { requirement: 'Institution Acceptance', details: 'Acceptance from Thai educational institution (degree or language school)' },
  { requirement: 'Financial Proof', details: 'THB 500,000 (~$14,000 USD) or proof of sponsorship' },
  { requirement: 'Passport Validity', details: '6+ months beyond intended stay' },
  { requirement: 'Criminal Record', details: 'Police clearance (some embassies require)' },
  { requirement: 'Visa Fee', details: '~$80 single entry, ~$200 multiple entry' },
  { requirement: 'Institution Letter', details: 'Letter confirming enrollment from Thai school' },
];

const insuranceColumns = [
  { key: 'aspect', header: 'Insurance Aspect' },
  { key: 'requirement', header: 'Requirement' },
];

const insuranceRows = [
  { aspect: 'Mandatory', requirement: 'Recommended but not always strictly required (varies by embassy)' },
  { aspect: 'Typical Coverage', requirement: 'Comprehensive medical and accident coverage' },
  { aspect: 'Public Healthcare', requirement: 'Not available to international students' },
  { aspect: 'Private Healthcare', requirement: 'Excellent quality, very affordable' },
  { aspect: 'Cost Range', requirement: 'THB 10,000-25,000/year (~$280-700 USD)' },
  { aspect: 'School Insurance', requirement: 'Many language schools include basic coverage' },
];

const providersColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'monthly', header: 'Monthly Cost' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'bestFor', header: 'Best For' },
];

const providersRows = [
  { provider: 'Pacific Cross Thailand', monthly: 'THB 1,000-2,500', coverage: 'Comprehensive', bestFor: 'Local provider, good network' },
  { provider: 'AXA Thailand', monthly: 'THB 800-2,000', coverage: 'Comprehensive', bestFor: 'Established insurer, reliable' },
  { provider: 'SafetyWing', monthly: '~$56', coverage: '$250,000', bestFor: 'International coverage, travel included' },
  { provider: 'Cigna Global', monthly: '~$120-180', coverage: 'Comprehensive', bestFor: 'Premium coverage, chronic conditions' },
];

const costsColumns = [
  { key: 'item', header: 'Cost Item' },
  { key: 'amount', header: 'Amount' },
  { key: 'notes', header: 'Notes' },
];

const costsRows = [
  { item: 'Visa Fee', amount: '$80-200', notes: 'Single entry $80, multiple entry $200' },
  { item: 'Visa Extensions', amount: 'THB 1,900 (~$55)', notes: 'Every 90 days at immigration' },
  { item: 'Health Insurance', amount: 'THB 10,000-25,000/year', notes: '~$280-700 USD' },
  { item: 'Language School', amount: 'THB 30,000-80,000/year', notes: '~$840-2,240 USD' },
  { item: 'University Tuition', amount: 'THB 50,000-200,000/year', notes: '~$1,400-5,600 USD' },
  { item: 'Living Costs', amount: 'THB 20,000-40,000/month', notes: '~$560-1,120 USD' },
  { item: 'Accommodation', amount: 'THB 5,000-15,000/month', notes: '~$140-420 USD (varies by city)' },
];

const timelineColumns = [
  { key: 'step', header: 'Step' },
  { key: 'duration', header: 'Duration' },
  { key: 'details', header: 'Details' },
];

const timelineRows = [
  { step: '1. Choose School', duration: '2-4 weeks', details: 'Select accredited institution (university or language school)' },
  { step: '2. Get Acceptance', duration: '1-2 weeks', details: 'Receive acceptance letter and supporting documents' },
  { step: '3. Visa Application', duration: '3-5 business days', details: 'Apply at Thai embassy/consulate' },
  { step: '4. Arrive in Thailand', duration: 'Within visa validity', details: 'Enter Thailand with ED visa' },
  { step: '5. Start Classes', duration: 'As scheduled', details: 'Begin your study program' },
  { step: '6. 90-Day Reporting', duration: 'Every 90 days', details: 'Report address to immigration (mandatory)' },
];
---

<PageShell
  title="Thailand ED Visa Insurance Requirements 2026 | Study in Thailand Guide"
  description="Complete guide to Thailand Non-Immigrant ED (Education) visa and health insurance. Learn about Thai language study, university programs, and world-class healthcare at budget prices."
  headline="Thailand ED Visa & Insurance Guide"
  subheadline="Study Thai, earn a degree, or learn Muay Thai with world-class healthcare"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/visas/student-visa-hero-bg.png"
>
  <!-- Overview Section -->
  <section id="overview" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Overview</h2>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h3 class="text-lg font-semibold text-primary-900 mb-4">Quick Facts: Thailand ED Visa</h3>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div><strong>Visa Type:</strong> Non-Immigrant ED (Education)</div>
        <div><strong>Duration:</strong> 90 days single, 1 year multiple (extendable)</div>
        <div><strong>Processing Time:</strong> 3-5 business days</div>
        <div><strong>Visa Fee:</strong> $80 single entry, $200 multiple entry</div>
        <div><strong>Work Allowed:</strong> NO - strictly prohibited</div>
        <div><strong>Insurance:</strong> Highly recommended, sometimes required</div>
        <div><strong>90-Day Reporting:</strong> Mandatory</div>
        <div><strong>Living Cost:</strong> $560-1,120/month (very affordable)</div>
      </div>
    </div>

    <p class="text-lg text-neutral-700 mb-4">
      Thailand's ED visa is popular for several paths: Thai language study, university degrees, Muay Thai training, and even cooking courses. It's one of the most flexible ways to stay long-term in Thailand while pursuing genuine educational goals.
    </p>

    <p class="text-neutral-600 mb-4">
      Thailand offers an exceptional combination of very affordable living, amazing food, beautiful nature, and world-class private healthcare. Bangkok's private hospitals like Bumrungrad are internationally accredited and serve medical tourists from around the world—at a fraction of Western prices.
    </p>

    <p class="text-neutral-600">
      <strong>Important:</strong> Working on an ED visa is strictly prohibited. Thailand enforces this seriously—violations can result in fines, deportation, and bans. If you need to work, you need a different visa type (Non-Immigrant B with work permit).
    </p>
  </section>

  <!-- Quick Decision Guide -->
  <section id="quick-decision" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-green-900 mb-4">Thailand ED Visa is Great If You...</h3>
        <ul class="space-y-2 text-green-800">
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Want to learn Thai language (excellent schools available)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Value very affordable living ($560-1,120/month)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Want access to world-class private healthcare at low cost</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Enjoy tropical climate, beaches, and amazing food</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Can support yourself without needing to work</span>
          </li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-amber-900 mb-4">Consider Alternatives If You...</h3>
        <ul class="space-y-2 text-amber-800">
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Need to work (NO work allowed on ED visa)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Don't want to deal with 90-day reporting</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Want a clear path to residency/citizenship</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Prefer cooler climates (Thailand is hot and humid)</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Official Requirements -->
  <section id="requirements" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Official Requirements</h2>

    <p class="text-neutral-600 mb-6">
      The ED visa requires acceptance from a Thai educational institution. Requirements vary by embassy, so check with your local Thai embassy for specific documentation.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Pro Tip:</strong> Requirements vary significantly by embassy. Some are stricter about financial proof and criminal records. Contact your local Thai embassy directly to confirm current requirements before applying.
      </p>
    </div>
  </section>

  <!-- Insurance Requirements -->
  <section id="insurance-requirements" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Insurance Requirements</h2>

    <p class="text-neutral-600 mb-6">
      Health insurance is highly recommended for Thailand ED visa holders, though requirements vary by embassy. Regardless of requirements, insurance is strongly advised—Thai private healthcare is excellent but costs add up without coverage.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <h4 class="font-semibold text-green-900 mb-2">Why Insurance Still Matters</h4>
      <p class="text-green-800">
        Even though Thai healthcare is affordable, a serious accident or illness can cost thousands. Insurance (THB 10,000-25,000/year, ~$280-700) provides peace of mind. Many language schools include basic coverage in their fees—verify what's covered.
      </p>
    </div>

    <div class="mt-4 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>No Public Healthcare:</strong> International students don't have access to Thailand's subsidized public healthcare. You use private hospitals or pay full price at public facilities. Private is often preferred anyway for quality and English-speaking staff.
      </p>
    </div>
  </section>

  <!-- Recommended Providers -->
  <section id="recommended-providers" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Recommended Insurance Providers</h2>

    <p class="text-neutral-600 mb-6">
      For Thailand, you can use local Thai insurers (often cheaper) or international providers (better for travel outside Thailand).
    </p>

    <ComparisonTable columns={providersColumns} rows={providersRows} />

    <div class="mt-6 grid md:grid-cols-2 gap-4">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">For Thailand-Only Coverage</h4>
        <p class="text-neutral-600 text-sm">
          Thai insurers (Pacific Cross, AXA Thailand) offer good value for Thailand-only coverage. They work directly with Thai hospitals, making claims simpler. Lower premiums but no international coverage.
        </p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">For Regional Travel</h4>
        <p class="text-neutral-600 text-sm">
          If you plan to travel around Southeast Asia, international providers (SafetyWing, Cigna) cover you in multiple countries. Slightly higher cost but more flexible.
        </p>
      </div>
    </div>
  </section>

  <CTABox
    title="Compare Insurance for Thailand ED Visa"
    description="Find coverage for world-class Thai healthcare. Routine care is affordable; insurance protects against major expenses."
    buttonText="Compare Plans"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <!-- Costs Breakdown -->
  <section id="costs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Costs Breakdown</h2>

    <p class="text-neutral-600 mb-6">
      Thailand is one of the world's most affordable places to live. Here's a realistic breakdown.
    </p>

    <ComparisonTable columns={costsColumns} rows={costsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">City Cost Comparison</h4>
      <ul class="text-blue-800 text-sm space-y-1">
        <li><strong>Bangkok:</strong> THB 25,000-50,000/month (~$700-1,400)</li>
        <li><strong>Chiang Mai:</strong> THB 15,000-30,000/month (~$420-840) - popular for students</li>
        <li><strong>Phuket/Islands:</strong> THB 20,000-40,000/month (~$560-1,120)</li>
        <li><strong>Other cities:</strong> THB 12,000-25,000/month (~$335-700)</li>
      </ul>
    </div>

    <div class="mt-4 bg-green-50 border border-green-200 rounded-lg p-4">
      <h4 class="font-semibold text-green-900 mb-2">Why Thailand is So Affordable</h4>
      <p class="text-green-800 text-sm">
        Street food meals: $1-3. Excellent restaurant meal: $5-10. Studio apartment: $140-350/month. Motorbike rental: $50-80/month. Massage: $5-10. SIM with data: $10/month. You can live very comfortably on $800-1,200/month.
      </p>
    </div>
  </section>

  <!-- Application Timeline -->
  <section id="application-timeline" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Application Timeline</h2>

    <p class="text-neutral-600 mb-6">
      The ED visa process is relatively straightforward once you have acceptance from a Thai institution.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <div class="mt-6 bg-red-50 border border-red-200 rounded-lg p-4">
      <h4 class="font-semibold text-red-900 mb-2">Critical: 90-Day Reporting</h4>
      <p class="text-red-800">
        Every 90 days, you MUST report your address to Thai immigration. This is non-negotiable. Can be done in person, by mail, or online. Missing it results in a THB 2,000 fine (~$55) and potential complications. Set calendar reminders!
      </p>
    </div>
  </section>

  <!-- Real-World Scenarios -->
  <section id="scenarios" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Real-World Scenarios</h2>

    <p class="text-neutral-600 mb-6">
      Here's how healthcare works in common situations in Thailand.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Private Hospital GP Visit</h4>
        <p class="text-neutral-600 text-sm mb-2">You have a cold and want to see a doctor.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Walk into any private hospital clinic. Cost: THB 500-1,500 (~$14-43) including medication. No appointment needed. English-speaking doctors available.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Private Hospital Emergency</h4>
        <p class="text-neutral-600 text-sm mb-2">You're in a motorbike accident and need emergency care.</p>
        <p class="text-amber-700 text-sm"><strong>Outcome:</strong> Go to Bumrungrad, Bangkok Hospital, or similar. Excellent care. Costs vary: simple treatment THB 5,000-15,000 (~$140-420), serious injury significantly more. Insurance essential for major accidents.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Dental Cleaning</h4>
        <p class="text-neutral-600 text-sm mb-2">You want a routine dental checkup and cleaning.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Dental cleaning: THB 700-1,500 (~$20-42). Thailand is popular for dental tourism—high quality at low prices. Whitening, veneers, implants all affordable.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Prescription Medication</h4>
        <p class="text-neutral-600 text-sm mb-2">You need regular medication for allergies.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Pharmacies everywhere, many medications available over-the-counter. Common drugs: THB 50-300 (~$1.50-8.50). Antibiotics, birth control, allergy meds often no prescription needed.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Medical Tourism Quality Care</h4>
        <p class="text-neutral-600 text-sm mb-2">You need minor surgery (wisdom tooth removal).</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Bangkok's top hospitals are JCI-accredited (same as US hospitals). Wisdom tooth removal: THB 3,000-8,000 (~$85-225). World-class care at budget prices.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Mental Health Support</h4>
        <p class="text-neutral-600 text-sm mb-2">You want to see a therapist or psychiatrist.</p>
        <p class="text-amber-700 text-sm"><strong>Outcome:</strong> Private psychiatrist: THB 1,500-3,000 (~$42-85). Therapy: THB 1,500-3,000/session. English-speaking providers available in Bangkok/Chiang Mai. More limited in smaller cities.</p>
      </div>
    </div>
  </section>

  <!-- Common Mistakes -->
  <section id="common-mistakes" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Common Mistakes to Avoid</h2>

    <div class="space-y-4">
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Working on ED Visa</h4>
        <p class="text-red-800">Working on an ED visa is ILLEGAL. Thailand enforces this seriously. Consequences: fines, deportation, potential ban from Thailand. If you need to work, get a Non-Immigrant B visa with work permit. No exceptions.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Missing 90-Day Reporting</h4>
        <p class="text-red-800">Every 90 days, you must report your address to immigration. Missing it = THB 2,000 fine and potential complications. Can be done online, by mail, or in person. Set calendar reminders—no excuses accepted.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Overstaying Your Visa</h4>
        <p class="text-red-800">Thailand has strict overstay penalties. Fine: THB 500/day (max THB 20,000). Over 90 days overstay = 1-10 year ban depending on duration. NEVER overstay—extend your visa before it expires.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Choosing a Low-Quality School</h4>
        <p class="text-red-800">Some language schools exist mainly to provide visa paperwork without real education. Immigration is cracking down on these. Choose accredited schools with genuine programs. Fake study = visa problems.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Not Having Insurance</h4>
        <p class="text-red-800">While not always strictly required, insurance is essential. A motorbike accident or serious illness can cost thousands. Thai healthcare is excellent but not free. Budget THB 10,000-25,000/year (~$280-700) for peace of mind.</p>
      </div>
    </div>
  </section>

  <!-- Healthcare Access -->
  <section id="healthcare-access" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Healthcare System Access</h2>

    <p class="text-neutral-600 mb-6">
      Thailand is a major medical tourism destination. Private hospitals, especially in Bangkok, are world-class and JCI-accredited. International students use private healthcare or pay full price at public facilities.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>Quality:</strong> World-class, JCI-accredited hospitals</li>
          <li>• <strong>GP visit:</strong> THB 500-1,500 (~$14-43)</li>
          <li>• <strong>Top hospitals:</strong> Bumrungrad, Bangkok Hospital, BNH</li>
          <li>• <strong>English:</strong> Widely spoken in private hospitals</li>
          <li>• <strong>Wait times:</strong> Minimal, often same-day</li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>Access:</strong> Available but no subsidy for internationals</li>
          <li>• <strong>Cost:</strong> Full price (still cheaper than private)</li>
          <li>• <strong>English:</strong> Limited, especially outside Bangkok</li>
          <li>• <strong>Wait times:</strong> Can be long</li>
          <li>• <strong>When to use:</strong> Complex cases, budget constraints</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">Healthcare Strategy</h4>
      <p class="text-blue-800 text-sm">
        Get comprehensive insurance (Thai or international provider). Use private hospitals for routine care—it's affordable and convenient. Thai pharmacies sell many medications over-the-counter. For serious issues, Bangkok's top hospitals rival any in the world.
      </p>
    </div>
  </section>

  <CTABox
    title="Need Insurance for Thailand ED Visa?"
    description="Compare local Thai insurers and international options. Protect yourself in one of the world's best healthcare destinations."
    buttonText="View Insurance Comparison"
    buttonHref="/go/cigna-global"
  />

  <!-- FAQs -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Frequently Asked Questions</h2>

    <div class="space-y-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Can I work on an ED visa?</h4>
        <p class="text-neutral-600">Absolutely not. Working on an ED visa is illegal and Thailand enforces this. Getting caught means fines, deportation, and potential ban. If you need to work, you need a Non-Immigrant B visa with work permit. Remote work for foreign companies is a gray area—technically prohibited.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">What is 90-day reporting?</h4>
        <p class="text-neutral-600">Every 90 days in Thailand, you must report your address to immigration. Can be done in person, by mail, or online (TM47 form). Missing it = THB 2,000 fine. It's administrative but strictly enforced. Set reminders—no exceptions.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Can I study Thai language on an ED visa?</h4>
        <p class="text-neutral-600">Yes, this is one of the most common uses of the ED visa. Choose an accredited Thai language school with genuine instruction. Immigration cracks down on schools that don't provide real education. Minimum class hours required to maintain visa status.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Is Thai healthcare really that good?</h4>
        <p class="text-neutral-600">Bangkok's top hospitals (Bumrungrad, Bangkok Hospital) are JCI-accredited—the same certification as top US hospitals. Doctors often trained in US, UK, or Australia. Thailand is a major medical tourism destination. Quality is excellent; prices are a fraction of Western costs.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">What happens if I overstay?</h4>
        <p class="text-neutral-600">Serious consequences. Fine: THB 500/day (max THB 20,000). If overstay exceeds 90 days and you're caught, you'll be banned: 90+ days = 1 year ban, 1+ year = 3 year ban, longer = up to 10 years. Never overstay—always extend before expiry.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">How affordable is Thailand really?</h4>
        <p class="text-neutral-600">Very affordable. Street food: $1-3/meal. Nice restaurant: $5-10. Studio apartment: $140-350/month. You can live comfortably on $800-1,200/month. Chiang Mai is particularly popular with students for lower costs. Bangkok is more expensive but still affordable by global standards.</p>
      </div>
    </div>
  </section>

  <!-- Final Verdict -->
  <section id="verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Final Verdict</h2>

    <div class="bg-gradient-to-r from-primary-50 to-primary-100 border border-primary-200 rounded-lg p-6">
      <p class="text-lg text-primary-900 mb-4">
        Thailand's ED visa offers an excellent way to stay long-term while pursuing genuine educational goals—Thai language, university degrees, martial arts, or cooking. Combined with very affordable living, amazing food, and world-class private healthcare, Thailand is hard to beat for lifestyle value.
      </p>

      <p class="text-primary-800 mb-4">
        The critical limitation is no work rights. If you can support yourself through savings, remote income (gray area), or sponsorship, the ED visa provides a legitimate, affordable path to living in Thailand. The 90-day reporting is annoying but manageable.
      </p>

      <p class="text-primary-800 mb-4">
        <strong>Our recommendation:</strong> Get comprehensive health insurance (local Thai or international—THB 10,000-25,000/year). Use Bangkok's private hospitals for anything serious—they're world-class. For routine care, local clinics are affordable even out-of-pocket. Don't skip insurance; motorbike accidents are common.
      </p>

      <div class="mt-4 pt-4 border-t border-primary-200">
        <p class="text-sm text-primary-700">
          <strong>Bottom Line:</strong> Thailand ED visa is ideal for students who want affordable living, world-class healthcare, and an amazing lifestyle—without needing to work. Choose a legitimate school, follow the rules (90-day reporting, no working), and enjoy one of the world's most livable countries at budget prices.
        </p>
      </div>
    </div>
  </section>

