---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', label: 'Overview' },
  { id: 'quick-decision', label: 'Quick Decision Guide' },
  { id: 'requirements', label: 'Official Requirements' },
  { id: 'insurance-requirements', label: 'Insurance Requirements' },
  { id: 'recommended-providers', label: 'Recommended Providers' },
  { id: 'costs', label: 'Costs Breakdown' },
  { id: 'application-timeline', label: 'Application Timeline' },
  { id: 'scenarios', label: 'Real-World Scenarios' },
  { id: 'common-mistakes', label: 'Common Mistakes' },
  { id: 'healthcare-access', label: 'Healthcare Access' },
  { id: 'faqs', label: 'FAQs' },
  { id: 'verdict', label: 'Final Verdict' },
];

const relatedLinks = [
  { href: '/visas/student-visa/in/poland', label: 'Poland Student Visa' },
  { href: '/visas/student-visa/in/czech-republic', label: 'Czech Republic Student Visa' },
  { href: '/visas/student-visa/in/austria', label: 'Austria Student Visa' },
  { href: '/best/expat-health-insurance', label: 'Compare Expat Insurance' },
  { href: '/insurance-for/students-abroad', label: 'Student Insurance Guide' },
];

const requirementsColumns = [
  { key: 'requirement', header: 'Requirement' },
  { key: 'details', header: 'Details' },
];

const requirementsRows = [
  { requirement: 'University Acceptance', details: 'Admission to accredited Hungarian higher education institution' },
  { requirement: 'Financial Proof', details: 'HUF 96,000/month (~€250) - one of lowest in EU' },
  { requirement: 'Health Insurance', details: 'Comprehensive coverage required' },
  { requirement: 'Accommodation Proof', details: 'Dormitory confirmation or rental contract' },
  { requirement: 'Criminal Record', details: 'Clean background check certificate' },
  { requirement: 'Application Fee', details: '~€60 visa processing fee' },
];

const insuranceColumns = [
  { key: 'aspect', header: 'Insurance Aspect' },
  { key: 'requirement', header: 'Requirement' },
];

const insuranceRows = [
  { aspect: 'Mandatory', requirement: 'Yes - required for residence permit' },
  { aspect: 'EU Students', requirement: 'EHIC provides public healthcare access' },
  { aspect: 'Non-EU Students', requirement: 'Private insurance required initially' },
  { aspect: 'TAJ Card', requirement: 'After registration, access to Hungarian public system' },
  { aspect: 'Typical Cost', requirement: '€200-500/year for private coverage' },
  { aspect: 'Schengen Coverage', requirement: 'Must meet €30,000 Schengen minimum' },
];

const providersColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'monthly', header: 'Monthly Cost' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'bestFor', header: 'Best For' },
];

const providersRows = [
  { provider: 'Hungarian Public (TAJ)', monthly: 'Free/subsidized', coverage: 'Public system', bestFor: 'After TAJ registration (long-term)' },
  { provider: 'Generali Hungary', monthly: '€20-40', coverage: 'Comprehensive', bestFor: 'Local provider, good network' },
  { provider: 'SafetyWing', monthly: '~$56', coverage: '$250,000', bestFor: 'Initial visa, travel coverage' },
  { provider: 'Cigna Global', monthly: '~$120-180', coverage: 'Comprehensive', bestFor: 'Premium coverage, chronic conditions' },
];

const costsColumns = [
  { key: 'item', header: 'Cost Item' },
  { key: 'amount', header: 'Amount' },
  { key: 'notes', header: 'Notes' },
];

const costsRows = [
  { item: 'Visa Application Fee', amount: '~€60', notes: 'Residence permit processing' },
  { item: 'Health Insurance', amount: '€200-500/year', notes: 'Private coverage; public after TAJ' },
  { item: 'Tuition (Non-Scholarship)', amount: '€1,500-6,000/year', notes: 'Much lower than Western Europe' },
  { item: 'Stipendium Hungaricum', amount: '€0 + stipend', notes: 'Full scholarship for eligible nationalities' },
  { item: 'Living Costs', amount: '€400-700/month', notes: 'One of cheapest in EU' },
  { item: 'Accommodation', amount: '€150-400/month', notes: 'Dorm €100-200, private €250-400' },
  { item: 'Food', amount: '€100-200/month', notes: 'Very affordable, great cuisine' },
];

const timelineColumns = [
  { key: 'step', header: 'Step' },
  { key: 'duration', header: 'Duration' },
  { key: 'details', header: 'Details' },
];

const timelineRows = [
  { step: '1. Apply for Stipendium (if eligible)', duration: 'Jan-Feb typically', details: 'Government scholarship application' },
  { step: '2. University Application', duration: '3-4 months before', details: 'Direct or through Stipendium' },
  { step: '3. Gather Documents', duration: '2-4 weeks', details: 'Apostille certificates, insurance' },
  { step: '4. Visa Application', duration: '15-30 days processing', details: 'At Hungarian embassy/consulate' },
  { step: '5. Arrive in Hungary', duration: 'Before semester', details: 'Collect residence permit' },
  { step: '6. Register for TAJ', duration: 'After arrival', details: 'At local immigration office' },
];
---

<PageShell
  title="Hungary Student Visa Insurance Requirements 2026 | Study in Hungary Guide"
  description="Complete guide to Hungary student visa and health insurance. Learn about Stipendium Hungaricum scholarship, TAJ card registration, and studying in one of Europe's most affordable countries."
  headline="Hungary Student Visa & Insurance Guide"
  subheadline="Quality European education at Eastern European prices with generous scholarships"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/visas/student-visa-hero-bg.png"
>
  <!-- Overview Section -->
  <section id="overview" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Overview</h2>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h3 class="text-lg font-semibold text-primary-900 mb-4">Quick Facts: Hungary Student Residence Permit</h3>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div><strong>Permit Type:</strong> Residence Permit for Studies</div>
        <div><strong>Duration:</strong> 1 year (renewable)</div>
        <div><strong>Processing Time:</strong> 15-30 days</div>
        <div><strong>Application Fee:</strong> ~€60</div>
        <div><strong>Work Allowed:</strong> 24 hrs/week (term), full-time (holidays)</div>
        <div><strong>Insurance:</strong> Required; TAJ card after registration</div>
        <div><strong>Schengen Access:</strong> Yes, travel within Schengen zone</div>
        <div><strong>Living Cost:</strong> €400-700/month (very affordable)</div>
      </div>
    </div>

    <p class="text-lg text-neutral-700 mb-4">
      Hungary offers one of Europe's best value propositions for international students: quality education at affordable prices, with generous government scholarships available. The Stipendium Hungaricum program provides full funding—tuition, accommodation, and stipend—for students from over 80 partner countries.
    </p>

    <p class="text-neutral-600 mb-4">
      As an EU and Schengen member, Hungary provides students with the freedom to travel throughout Europe while studying. Budapest, in particular, offers an incredible student experience—vibrant nightlife, rich history, famous thermal baths, and a thriving international community.
    </p>

    <p class="text-neutral-600">
      Healthcare is straightforward: EU students use EHIC for public access, while non-EU students need private insurance initially. After registering for a TAJ card (Hungarian social security number), all students can access the public healthcare system.
    </p>
  </section>

  <!-- Quick Decision Guide -->
  <section id="quick-decision" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-green-900 mb-4">Hungary is a Great Fit If You...</h3>
        <ul class="space-y-2 text-green-800">
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Want affordable European education (€400-700/month living costs)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Are eligible for Stipendium Hungaricum (free + stipend)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Want Schengen access for European travel</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Enjoy vibrant student life (Budapest is legendary)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Value growing English-taught program options</span>
          </li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-amber-900 mb-4">Consider Alternatives If You...</h3>
        <ul class="space-y-2 text-amber-800">
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Need programs only in English (many still in Hungarian)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Require top global university rankings</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Prefer warmer Mediterranean climate</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Want very clear post-graduation work pathways</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Official Requirements -->
  <section id="requirements" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Official Requirements</h2>

    <p class="text-neutral-600 mb-6">
      Hungary has straightforward requirements with one of the lowest financial thresholds in the EU. The Stipendium Hungaricum scholarship eliminates financial requirements entirely for eligible students.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <h4 class="font-semibold text-green-900 mb-2">Stipendium Hungaricum Scholarship</h4>
      <p class="text-green-800">
        If your country has an agreement with Hungary, you may be eligible for full funding: tuition waiver, accommodation, monthly stipend (~€140), and health insurance. Check eligibility at stipendiumhungaricum.hu—it's one of the most generous government scholarship programs globally.
      </p>
    </div>
  </section>

  <!-- Insurance Requirements -->
  <section id="insurance-requirements" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Insurance Requirements</h2>

    <p class="text-neutral-600 mb-6">
      Health insurance is required for the residence permit. EU students can use EHIC, while non-EU students need private insurance. After arrival and TAJ card registration, all students can access Hungarian public healthcare.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">TAJ Card: Your Key to Public Healthcare</h4>
      <p class="text-blue-800">
        TAJ (Társadalombiztosítási Azonosító Jel) is Hungary's social security number. After registering with the local immigration office, you can get a TAJ card allowing access to Hungarian public healthcare. This is especially valuable for long-term students.
      </p>
    </div>

    <div class="mt-4 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Stipendium Hungaricum Students:</strong> Your scholarship includes health insurance coverage. Verify the details with your university, but you typically don't need to purchase separate insurance.
      </p>
    </div>
  </section>

  <!-- Recommended Providers -->
  <section id="recommended-providers" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Recommended Insurance Providers</h2>

    <p class="text-neutral-600 mb-6">
      For non-EU students without Stipendium Hungaricum, you'll need private insurance for the visa application. After TAJ registration, you can rely on public healthcare.
    </p>

    <ComparisonTable columns={providersColumns} rows={providersRows} />

    <div class="mt-6 grid md:grid-cols-2 gap-4">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">For Visa Application</h4>
        <p class="text-neutral-600 text-sm">
          Use SafetyWing (~$56/month) or a Hungarian provider for your residence permit application. Must meet Schengen €30,000 minimum requirement.
        </p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Long-Term Strategy</h4>
        <p class="text-neutral-600 text-sm">
          After arrival, register for TAJ card. Once active, you can access Hungarian public healthcare. Keep travel insurance for trips outside Hungary.
        </p>
      </div>
    </div>
  </section>

  <CTABox
    title="Compare Insurance for Hungary Student Visa"
    description="Find coverage that meets residence permit requirements. TAJ card provides public healthcare access after registration."
    buttonText="Compare Plans"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <!-- Costs Breakdown -->
  <section id="costs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Costs Breakdown</h2>

    <p class="text-neutral-600 mb-6">
      Hungary is one of the most affordable EU countries for students. Here's a realistic breakdown.
    </p>

    <ComparisonTable columns={costsColumns} rows={costsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">Cost Comparison with Western Europe</h4>
      <p class="text-blue-800 text-sm">
        Hungary costs roughly 50-70% less than Western European countries. Budapest monthly budget: €500-700. Compare to Amsterdam €1,200-1,500, Paris €1,300-1,800, or London €1,500-2,000. The savings are substantial.
      </p>
    </div>

    <div class="mt-4 bg-green-50 border border-green-200 rounded-lg p-4">
      <h4 class="font-semibold text-green-900 mb-2">Stipendium Hungaricum Value</h4>
      <p class="text-green-800 text-sm">
        Full scholarship covers: tuition (€1,500-6,000 value), accommodation, monthly stipend (~€140), and health insurance. Total value can exceed €10,000/year. Check eligibility—it's worth the application effort.
      </p>
    </div>
  </section>

  <!-- Application Timeline -->
  <section id="application-timeline" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Application Timeline</h2>

    <p class="text-neutral-600 mb-6">
      If applying for Stipendium Hungaricum, start early—deadlines are typically January-February for the following academic year.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> Document apostille requirements vary by country. Some documents need apostille or authentication before submission. Start this process early—it can take weeks in some countries.
      </p>
    </div>
  </section>

  <!-- Real-World Scenarios -->
  <section id="scenarios" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Real-World Scenarios</h2>

    <p class="text-neutral-600 mb-6">
      Here's how healthcare works in common situations for students in Hungary.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">GP Visit (With TAJ Card)</h4>
        <p class="text-neutral-600 text-sm mb-2">You have a fever and need to see a doctor.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Visit assigned GP (háziorvos). Free with TAJ card. May need to wait but basic care covered. English may be limited—bring translation app or friend.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">GP Visit (Private Clinic)</h4>
        <p class="text-neutral-600 text-sm mb-2">Same situation but you want English-speaking doctor.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Private clinic in Budapest: HUF 10,000-20,000 (~€25-50). Many English-speaking doctors. Quick service, modern facilities. Insurance may cover.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Hospital Emergency</h4>
        <p class="text-neutral-600 text-sm mb-2">You break your arm playing sports.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Go to hospital emergency. With TAJ/EHIC: mostly covered (small fees possible). Without: still affordable but bring insurance. Budapest hospitals are decent quality.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Dental Care</h4>
        <p class="text-neutral-600 text-sm mb-2">You need a dental checkup and cleaning.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Hungary is famous for dental tourism. Private cleaning: HUF 8,000-15,000 (~€20-38). High quality at low prices. Many clinics cater to internationals.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Weekend Trip to Vienna</h4>
        <p class="text-neutral-600 text-sm mb-2">You visit Vienna (2 hours away) and get sick.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> EHIC (EU students) or Schengen-compliant insurance covers you. Vienna is close and convenient—many students visit regularly.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Prescription Medication</h4>
        <p class="text-neutral-600 text-sm mb-2">You need regular medication for allergies.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Hungarian pharmacies (gyógyszertár) well-stocked. Many medications very affordable. TAJ card provides subsidies on many prescriptions. OTC medications even cheaper.</p>
      </div>
    </div>
  </section>

  <!-- Common Mistakes -->
  <section id="common-mistakes" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Common Mistakes to Avoid</h2>

    <div class="space-y-4">
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Not Applying for Stipendium Hungaricum</h4>
        <p class="text-red-800">If your country has an agreement with Hungary, you may qualify for full funding: tuition, accommodation, stipend, insurance. Check eligibility before paying tuition—many students miss this opportunity.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Forgetting Document Apostille</h4>
        <p class="text-red-800">Many countries require apostille or authentication on educational documents. This process can take weeks. Start early and verify requirements with the Hungarian embassy.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Not Registering for TAJ Card</h4>
        <p class="text-red-800">TAJ card gives you access to Hungarian public healthcare. Register at the local immigration office after arrival. Without it, you're relying solely on private insurance or paying out-of-pocket.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Assuming All Programs Are in English</h4>
        <p class="text-red-800">While English programs are growing, many courses are still in Hungarian. Verify the language of instruction before applying. Hungarian is notoriously difficult to learn.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Not Registering at Immigration Office</h4>
        <p class="text-red-800">After arriving, you need to register at the local immigration office (Office of Immigration and Nationality). This is separate from university registration and required for your residence permit.</p>
      </div>
    </div>
  </section>

  <!-- Healthcare Access -->
  <section id="healthcare-access" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Healthcare System Access</h2>

    <p class="text-neutral-600 mb-6">
      Hungary has a public healthcare system accessible to registered residents. Private healthcare is affordable and offers better English-language services.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (TAJ)</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>Cost:</strong> Free/minimal copays with TAJ card</li>
          <li>• <strong>Access:</strong> Register with assigned GP</li>
          <li>• <strong>Quality:</strong> Acceptable, can be crowded</li>
          <li>• <strong>English:</strong> Limited, especially outside Budapest</li>
          <li>• <strong>Best for:</strong> Routine care, emergencies</li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>Cost:</strong> GP ~€25-50, specialist ~€40-80</li>
          <li>• <strong>Access:</strong> Direct booking, short waits</li>
          <li>• <strong>Quality:</strong> Good, modern facilities</li>
          <li>• <strong>English:</strong> Common in Budapest private clinics</li>
          <li>• <strong>Best for:</strong> Quick service, English speakers</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">Healthcare Strategy</h4>
      <p class="text-blue-800 text-sm">
        1) Get private insurance for visa application. 2) Register for TAJ card after arrival. 3) Use public system for routine care. 4) Private clinics for English-speaking doctors or faster service. 5) Hungary is excellent for dental care—consider getting dental work done affordably.
      </p>
    </div>
  </section>

  <CTABox
    title="Need Insurance for Hungary Student Visa?"
    description="Compare options for your residence permit application. TAJ card provides public healthcare access after registration."
    buttonText="View Insurance Comparison"
    buttonHref="/go/cigna-global"
  />

  <!-- FAQs -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Frequently Asked Questions</h2>

    <div class="space-y-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">What is Stipendium Hungaricum?</h4>
        <p class="text-neutral-600">A Hungarian government scholarship covering tuition, accommodation, monthly stipend (~€140), and health insurance. Available to students from 80+ partner countries. Highly competitive but very generous. Check if your country is eligible at stipendiumhungaricum.hu.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">How affordable is Hungary compared to Western Europe?</h4>
        <p class="text-neutral-600">Hungary costs 50-70% less. Monthly budget: €400-700 in Budapest. Compare to €1,200-1,800 in Amsterdam, Paris, or Munich. Tuition also lower: €1,500-6,000/year vs €10,000-20,000 in Western Europe. Substantial savings.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">What is the TAJ card?</h4>
        <p class="text-neutral-600">TAJ (Társadalombiztosítási Azonosító Jel) is Hungary's social security number. Register at the immigration office after arrival to get one. It gives you access to Hungarian public healthcare—essential for long-term students.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Can I work while studying in Hungary?</h4>
        <p class="text-neutral-600">Yes. EU students can work freely. Non-EU students can work up to 24 hours/week during term, full-time during holidays. No separate work permit needed with student residence permit. Wages are lower than Western Europe but so are costs.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Is Hungarian difficult to learn?</h4>
