---
/**
 * Italy Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Italy", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Italy Health Insurance Guide", href: "/countries/italy/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "University Enrollment", details: "Pre-enrollment via Universitaly portal", evidence: "Pre-enrollment confirmation" },
  { requirement: "Financial Proof", details: "€467/month (~€5,600/year)", evidence: "Bank statements or sponsor declaration" },
  { requirement: "Accommodation", details: "Proof of housing in Italy", evidence: "Rental contract or declaration of hospitality" },
  { requirement: "Health Insurance", details: "Valid coverage in Italy", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "3+ months beyond intended stay", evidence: "Passport" },
  { requirement: "Return Means", details: "Return ticket or funds for return", evidence: "Ticket or bank statement" },
];

const insuranceColumns = [
  { key: "option", header: "Option" },
  { key: "cost", header: "Annual Cost" },
  { key: "coverage", header: "Coverage" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { option: "SSN (Public Healthcare)", cost: "~€150/year", coverage: "Full public healthcare", notes: "Best value—same as Italian citizens" },
  { option: "Private Insurance", cost: "€600-1,500/year", coverage: "Varies by plan", notes: "For visa, can switch to SSN after arrival" },
  { option: "EHIC (EU students)", cost: "Free", coverage: "Emergency/necessary care", notes: "EU citizens only" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Italian SSN", type: "Public", price: "~€150/year", strengths: "Best value, full coverage, recommended" },
  { provider: "Cigna Global", type: "International", price: "€100-180/mo", strengths: "Visa application, global coverage" },
  { provider: "Allianz Care", type: "International", price: "€80-150/mo", strengths: "Good networks, EU coverage" },
  { provider: "IMG Global", type: "International", price: "€50-100/mo", strengths: "Budget option for visa" },
  { provider: "UnipolSai", type: "Italian Local", price: "€40-80/mo", strengths: "Local coverage, Italian support" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Fee", amount: "€50", notes: "Student visa application" },
  { item: "Tuition (Public)", amount: "€200-3,000/year", notes: "Based on family income (ISEE)" },
  { item: "SSN Enrollment", amount: "~€150/year", notes: "Public healthcare—highly recommended" },
  { item: "Permesso di Soggiorno", amount: "€40-100", notes: "Residence permit fees" },
  { item: "Private Insurance (if used)", amount: "€50-150/month", notes: "Only until SSN enrollment" },
  { item: "Regional Tax", amount: "€120-200/year", notes: "Varies by region" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Pre-enroll via Universitaly", duration: "Varies by deadline", location: "Online (universitaly.it)" },
  { step: "Receive pre-enrollment confirmation", duration: "2-4 weeks", location: "University" },
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Apply for visa at Italian consulate", duration: "1 day", location: "Italian consulate" },
  { step: "Visa processing", duration: "2-6 weeks", location: "Italian authorities" },
  { step: "Travel to Italy", duration: "-", location: "-" },
  { step: "Apply for Permesso di Soggiorno", duration: "Within 8 days", location: "Post office (kit)" },
  { step: "Enroll in SSN", duration: "After Permesso", location: "Local ASL office" },
];
---

<PageShell
  title="Italy Student Visa 2026: Requirements, SSN Healthcare & Application Guide"
  description="Complete guide to the Italian Student Visa. €150/year SSN public healthcare, ultra-low tuition, Universitaly pre-enrollment, and step-by-step application process."
  headline="Italy Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in Italy—€150/year public healthcare (SSN), income-based tuition as low as €200/year, Universitaly pre-enrollment, and the complete visa process."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Universitaly Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      €150/year SSN Healthcare
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Italy offers one of Europe's best deals for international students: <strong>€150/year public healthcare</strong> through the SSN (national health service) and <strong>income-based tuition</strong> that can be as low as €200/year at public universities. Combined with world-class education in art, design, architecture, and business, Italy is hard to beat on value.
    </p>

    <p class="mb-4">
      Unlike many countries where healthcare is complicated, Italy makes it simple: after arriving, students can enroll in the SSN for about €150/year and get the same healthcare coverage as Italian citizens. This is exceptional value compared to paying €100+/month for private insurance elsewhere.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Italy Student Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Healthcare:</strong> SSN enrollment ~€150/year—full public coverage</li>
        <li>• <strong>Tuition:</strong> €200-3,000/year based on family income (ISEE)</li>
        <li>• <strong>Financial proof:</strong> €467/month (~€5,600/year)</li>
        <li>• <strong>Pre-enrollment:</strong> Via Universitaly portal (required)</li>
        <li>• <strong>Permesso di Soggiorno:</strong> Apply within 8 days of arrival</li>
        <li>• <strong>Work rights:</strong> 20 hours/week during term, full-time in breaks</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Study in Italy?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>€150/year healthcare:</strong> SSN gives you full public coverage—unbeatable value</li>
      <li><strong>Ultra-low tuition:</strong> Income-based fees mean many pay under €500/year</li>
      <li><strong>World-class programs:</strong> Art, design, architecture, fashion, music, culinary</li>
      <li><strong>Rich culture:</strong> History, art, food—Italy is a living museum</li>
      <li><strong>Affordable living:</strong> €700-1,000/month in most cities</li>
      <li><strong>Central location:</strong> Easy access to rest of Europe</li>
      <li><strong>Language opportunity:</strong> Learn Italian—beautiful and useful</li>
      <li><strong>Post-study options:</strong> Can convert to work permit after graduation</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Italy is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want the cheapest healthcare option (€150/year SSN)</li>
          <li>✓ You want low tuition based on income</li>
          <li>✓ You're studying art, design, architecture, or fashion</li>
          <li>✓ You want to immerse in Italian culture</li>
          <li>✓ You appreciate history, food, and lifestyle</li>
          <li>✓ You're willing to learn Italian</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want all English instruction (limited in Italy)</li>
          <li>• You want faster post-study work path (Germany's 18 months)</li>
          <li>• You prefer efficient bureaucracy (Italy is slow)</li>
          <li>• You want strong tech industry (Netherlands, Germany better)</li>
          <li>• You need everything in English from day one</li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>SSN is the best healthcare deal in Europe:</strong> For ~€150/year, you get the same healthcare as Italian citizens—doctor visits, hospital care, prescriptions (with small copays). No other country offers this value. Don't skip SSN enrollment.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The Italian Student Visa requires pre-enrollment through the Universitaly portal, proof of financial means, and health insurance (which you can later convert to SSN after arrival).
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Universitaly Pre-Enrollment</h3>

    <p class="mb-4">
      Most international students must pre-enroll through the <strong>Universitaly portal</strong> (universitaly.it) before applying for a visa. This is Italy's centralized system for international student applications.
    </p>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <p class="text-blue-800">
        <strong>Deadline alert:</strong> Universitaly has specific deadlines for each intake (usually spring for fall enrollment). Check deadlines early—missing them can delay your studies by a full year. Some programs fill quickly.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Financial Requirements</h3>

    <p class="mb-4">
      Italy requires proof of <strong>€467/month</strong> (approximately €5,600/year) to support yourself. This is lower than many European countries, making Italy accessible to more students.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Bank statements:</strong> Showing sufficient savings</li>
      <li><strong>Scholarship letter:</strong> If receiving funding</li>
      <li><strong>Sponsor declaration:</strong> Parents or guarantor (notarized)</li>
      <li><strong>Combination:</strong> Partial personal funds plus sponsor</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">SSN Enrollment: The Smart Choice (~€150/year)</h3>
      <p class="text-green-800">
        After arriving in Italy, students can enroll in the SSN (Servizio Sanitario Nazionale) for approximately €150/year. This gives you the same healthcare coverage as Italian citizens—doctor visits, hospital care, specialists, prescriptions. It's by far the best value in Europe.
      </p>
    </div>

    <p class="mb-4">
      For your <strong>visa application</strong>, you need health insurance. You can use private insurance initially, then switch to SSN after arrival. EU students can use EHIC for the visa and then decide on SSN or EHIC for ongoing coverage.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Insurance Options Compared</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Strategy: Private for Visa, SSN After Arrival</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">For Visa Application</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Get private insurance (Cigna, Allianz, IMG)</li>
          <li>• Or Italian insurer if available</li>
          <li>• Coverage for at least initial months</li>
          <li>• Can be basic—just needs to satisfy visa requirement</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">After Arrival</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Enroll in SSN at local ASL office</li>
          <li>• Pay ~€150 for the year</li>
          <li>• Get tessera sanitaria (health card)</li>
          <li>• Cancel or keep private insurance as backup</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Don't skip SSN:</strong> Some students keep paying for private insurance without realizing SSN is available. For €150/year, SSN provides comprehensive coverage. It's one of Italy's best features for students—take advantage of it.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Italy visa application?"
    description="Get coverage for your visa, then switch to SSN after arrival."
    buttonText="Compare Initial Coverage Options"
    buttonHref="/countries/italy/insurance"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For your visa, any reputable health insurance works. After arrival, SSN enrollment is strongly recommended for the best value.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Recommendations by Stage</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">After Arrival: Enroll in SSN</h4>
        <p class="text-neutral-600">Once you have your Permesso di Soggiorno, go to your local ASL (health authority) office and enroll in SSN. Pay ~€150 for the year. You'll receive a tessera sanitaria (health card) and can register with a family doctor (medico di base).</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">For Visa Application: Budget Options</h4>
        <p class="text-neutral-600">IMG Global and similar providers offer affordable coverage (~€50-100/month) sufficient for visa purposes. You only need this until you can enroll in SSN—usually a few weeks after arrival.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Traveling Often: Keep Private Insurance</h4>
        <p class="text-neutral-600">SSN primarily covers you in Italy. If you'll travel frequently outside Italy, consider keeping basic international coverage (Cigna, Allianz) alongside SSN for travel protection.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU Students: EHIC Option</h4>
        <p class="text-neutral-600">EU citizens can use EHIC (European Health Insurance Card) for visa and ongoing coverage. However, EHIC only covers "necessary" care, not routine care. Consider SSN enrollment anyway for comprehensive coverage at minimal cost.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Italy offers exceptional value. Public university tuition is income-based (many pay under €500/year), and SSN healthcare costs just ~€150/year. This makes Italy one of Europe's most affordable destinations.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Tuition: The ISEE System</h3>

    <p class="mb-4">
      Italian public universities use the <strong>ISEE</strong> system to calculate tuition based on family income. Students from lower-income families can pay as little as €200/year, while the maximum is around €3,000/year.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Low Income (ISEE)</p>
        <p class="text-3xl font-bold text-green-600">€200-500</p>
        <p class="text-sm text-neutral-500 mt-2">Per year</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Medium Income</p>
        <p class="text-3xl font-bold text-neutral-900">€800-1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Per year</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Higher Income</p>
        <p class="text-3xl font-bold text-neutral-900">€2,000-3,000</p>
        <p class="text-sm text-neutral-500 mt-2">Per year</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Living Costs</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Milan/Rome (More Expensive)</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €500-800/month (room or small flat)</li>
          <li>• Food: €200-300/month</li>
          <li>• Transport: €22-35/month (student pass)</li>
          <li>• SSN: ~€12/month (€150/year)</li>
          <li>• Other: €100-200/month</li>
          <li>• <strong>Total: €850-1,300/month</strong></li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Bologna, Florence, Turin</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €350-550/month</li>
          <li>• Food: €150-250/month</li>
          <li>• Transport: €20-30/month</li>
          <li>• SSN: ~€12/month (€150/year)</li>
          <li>• Other: €80-150/month</li>
          <li>• <strong>Total: €650-950/month</strong></li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Scholarships and fee waivers:</strong> Many Italian universities offer scholarships and fee reductions for international students. The DSU (regional right to study) provides grants, housing subsidies, and meal vouchers for qualifying students. Apply early—these are competitive.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Italian student visa process involves pre-enrolling through Universitaly, applying for your visa, and then completing enrollment and residence permit after arrival.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pre-Enroll via Universitaly</h4>
          <p class="text-neutral-600">Create an account at universitaly.it and complete the pre-enrollment process. Upload required documents (transcripts, passport, language certificates). Pay attention to deadlines—they're strict.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Pre-Enrollment Confirmation</h4>
          <p class="text-neutral-600">Once your application is processed, you'll receive a pre-enrollment confirmation. This document is required for your visa application. Some universities may require additional steps or entrance exams.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents and Get Insurance</h4>
          <p class="text-neutral-600">Collect all required documents: passport, financial proof, accommodation proof, insurance certificate. Get health insurance for your visa—you can switch to SSN after arrival.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Visa</h4>
          <p class="text-neutral-600">Apply at the Italian consulate in your country. Bring all documents and pay the €50 visa fee. Processing typically takes 2-6 weeks. Some consulates are faster than others.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive and Apply for Permesso di Soggiorno</h4>
          <p class="text-neutral-600">Within 8 working days of arrival, go to the post office (Poste Italiane) to get the "kit" for your residence permit application. Fill it out, submit it, and attend the Questura appointment when scheduled.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete University Enrollment</h4>
          <p class="text-neutral-600">Finalize your enrollment at the university (immatricolazione). Pay tuition fees, submit any remaining documents, and get your student card. This confirms your student status.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enroll in SSN</h4>
          <p class="text-neutral-600">Once you have your Permesso di Soggiorno (or receipt), visit your local ASL (health authority) to enroll in SSN. Pay ~€150 for the year. You'll receive a tessera sanitaria and can choose a family doctor.</p>
        </div>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mt-6">
      <p class="text-red-800">
        <strong>8-day deadline is strict:</strong> You must apply for your Permesso di Soggiorno within 8 working days of arrival. Missing this deadline can cause serious problems with your legal status. Go to the post office immediately after arriving.
      </p>
    </div>
  </section>

