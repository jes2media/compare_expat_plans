---
/**
 * Denmark Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Denmark", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Denmark Health Insurance Guide", href: "/countries/denmark/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "University Admission", details: "Full-time higher education in Denmark", evidence: "Letter of admission" },
  { requirement: "Financial Proof", details: "DKK 6,397/month (~€860)", evidence: "Bank statements, scholarship" },
  { requirement: "Health Insurance", details: "Coverage until CPR registration", evidence: "Insurance certificate" },
  { requirement: "Tuition Payment", details: "Non-EU students must pay/confirm", evidence: "Payment confirmation" },
  { requirement: "Valid Passport", details: "Valid for study duration", evidence: "Passport" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "danish", header: "Danish Public (after CPR)" },
  { key: "private", header: "Private (before CPR)" },
];

const insuranceRows = [
  { feature: "Cost", danish: "FREE", private: "€50-100/month" },
  { feature: "Coverage", danish: "GP, hospital, most care free", private: "Varies by plan" },
  { feature: "Required?", danish: "Automatic after CPR registration", private: "Until you get CPR" },
  { feature: "Dental", danish: "Not covered (except emergencies)", private: "Usually extra" },
  { feature: "Wait Time", danish: "GP immediate, specialists vary", private: "Depends on plan" },
  { feature: "Access", danish: "All public healthcare facilities", private: "Varies" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Danish Public Healthcare", type: "Public", price: "Free", strengths: "After CPR—comprehensive, free" },
  { provider: "Cigna Global", type: "International", price: "$100-200/month", strengths: "Before CPR, global coverage" },
  { provider: "Allianz Care", type: "International", price: "$100-180/month", strengths: "Comprehensive private coverage" },
  { provider: "SafetyWing", type: "International", price: "$45-85/month", strengths: "Budget option before CPR" },
  { provider: "BUPA Global", type: "International", price: "$120-200/month", strengths: "Premium coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Application Fee", amount: "DKK 2,000-2,500 (~€270-335)", notes: "Residence permit" },
  { item: "Tuition (EU)", amount: "FREE", notes: "No tuition for EU/EEA students" },
  { item: "Tuition (Non-EU)", amount: "DKK 45,000-120,000/year", notes: "~€6,000-16,000" },
  { item: "Healthcare", amount: "Free (after CPR)", notes: "Dental and some services not covered" },
  { item: "Living Costs", amount: "DKK 6,397/month", notes: "~€860/month minimum required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Receive university admission", duration: "3-6 months before", location: "Danish university" },
  { step: "Pay tuition (non-EU)", duration: "Before application", location: "University" },
  { step: "Apply online for residence permit", duration: "1-2 months processing", location: "newtodenmark.dk" },
  { step: "Submit biometrics", duration: "After application", location: "Embassy/application center" },
  { step: "Receive residence permit", duration: "-", location: "Embassy" },
  { step: "Arrive in Denmark", duration: "-", location: "Airport" },
  { step: "Register for CPR", duration: "ASAP after arrival", location: "Citizen Service Centre" },
  { step: "Receive sundhedskort", duration: "1-3 weeks", location: "By mail" },
];
---

<PageShell
  title="Denmark Student Visa 2026: Requirements, Free Healthcare & Application Guide"
  description="Complete guide to Denmark's Student Residence Permit. Free healthcare after CPR registration, free tuition for EU students, hygge lifestyle, and post-graduation establishment card."
  headline="Denmark Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in Denmark—free public healthcare once registered, free tuition for EU students, the essential CPR number, and the famous Danish quality of life."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official SIRI Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Free Healthcare (after CPR)
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Denmark consistently ranks among the world's happiest countries, and its education system is a big part of that. With free tuition for EU students, free healthcare after CPR registration, and a culture that values work-life balance (hygge), Denmark offers an exceptional student experience—if you can afford the living costs.
    </p>

    <p class="mb-4">
      The key to Danish life is the <strong>CPR number</strong>—your civil registration number. Once you have it, you receive a sundhedskort (health card) that gives you access to free public healthcare. Getting your CPR should be your first priority after arrival.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-2">Quick Facts: Denmark Student Visa</h3>
      <ul class="space-y-1 text-primary-800">
        <li>• <strong>Permit Type:</strong> Residence Permit for Studies</li>
        <li>• <strong>Duration:</strong> Length of study program</li>
        <li>• <strong>Health Insurance:</strong> Free after CPR registration</li>
        <li>• <strong>Work Rights:</strong> 20 hrs/week term, full-time summer</li>
        <li>• <strong>Tuition:</strong> Free (EU) or DKK 45,000-120,000/year (non-EU)</li>
        <li>• <strong>Processing:</strong> 1-2 months</li>
        <li>• <strong>Post-Study:</strong> 6-month establishment card (extendable)</li>
      </ul>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">✓ Denmark Is a Great Fit If You:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• Want free, high-quality healthcare</li>
          <li>• Are EU and want free tuition</li>
          <li>• Value work-life balance and hygge culture</li>
          <li>• Want high-quality, practical education</li>
          <li>• Like cycling (it's the main transport)</li>
          <li>• Appreciate design, sustainability, and innovation</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">⚠ Consider Alternatives If You:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Can't handle very high living costs</li>
          <li>• Struggle with cold, dark winters</li>
          <li>• Want more than 20 hrs/week work during term</li>
          <li>• Prefer warmer climate</li>
          <li>• Don't want to cycle (really, you need to cycle)</li>
          <li>• Expect easy social integration (Danes can be reserved)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-6">
      Apply online through newtodenmark.dk. Processing is relatively fast (1-2 months). Non-EU students must have tuition arranged before applying.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Financial Requirement:</strong> DKK 6,397/month (~€860) is the minimum required. Copenhagen costs significantly more—budget DKK 8,000-12,000/month realistically for the capital.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-green-800">
        <strong>✓ Free Healthcare After CPR Registration:</strong> Once you have a CPR number and receive your sundhedskort (health card), Danish public healthcare is free. GP visits, hospital care, most treatments—all free. This happens within 1-3 weeks of registering.
      </p>
    </div>

    <p class="mb-6">
      Until you receive your CPR and sundhedskort, you need private insurance. EU students can use EHIC; non-EU students should have comprehensive coverage. The gap is usually only 1-3 weeks, but don't risk being uninsured.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Dental Not Covered:</strong> Danish public healthcare does NOT cover dental care (except emergencies). Budget separately for dental or consider supplementary dental insurance.
      </p>
    </div>
  </section>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-6">
      Danish public healthcare is excellent and free. You only need private insurance for the initial weeks before CPR registration and for services not covered (dental, travel abroad).
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <CTABox
      title="Need Coverage Before CPR Registration?"
      description="Have comprehensive insurance for your first weeks in Denmark until your sundhedskort arrives."
      buttonText="Compare Insurance Plans"
      buttonHref="/best/expat-health-insurance"
    />
  </section>

  <!-- Section: Costs -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-6">
      Denmark is expensive—Copenhagen especially so. The upside: healthcare is free, and EU students pay no tuition. The challenge is finding affordable housing.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <div class="mt-6 grid md:grid-cols-2 gap-4">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Monthly Budget (Copenhagen)</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>Rent: DKK 5,000-8,000 (~€670-1,070)</li>
          <li>Food: DKK 2,500-3,500 (~€335-470)</li>
          <li>Transport: DKK 300-500 (bike + occasional)</li>
          <li>Healthcare: DKK 0 (free)</li>
          <li>Phone/Misc: DKK 500-1,000</li>
          <li><strong>Total: DKK 8,500-13,500/month</strong></li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Monthly Budget (Aarhus/Odense)</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>Rent: DKK 3,500-5,500 (~€470-740)</li>
          <li>Food: DKK 2,000-3,000 (~€270-400)</li>
          <li>Transport: DKK 200-400</li>
          <li>Healthcare: DKK 0 (free)</li>
          <li>Phone/Misc: DKK 400-800</li>
          <li><strong>Total: DKK 6,500-10,000/month</strong></li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Student Housing (Kollegium):</strong> If you can get a spot in a kollegium (student residence), rent drops to DKK 2,500-4,500/month. Apply early—waiting lists are long!
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-6">
      Apply online at newtodenmark.dk. Danish processing is efficient—usually 1-2 months. The CPR registration after arrival is straightforward.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <div class="mt-6 bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Priority: Get Your CPR Number!</strong> Register at your local Citizen Service Centre (Borgerservice) as soon as you have housing. CPR unlocks everything: healthcare, banking, phone contracts, even library cards. Process takes 1-3 weeks.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="space-y-4">
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 1: GP Visit</h4>
        <p class="text-neutral-600 mb-2">You have cold symptoms and visit your assigned GP.</p>
        <p class="text-green-700"><strong>Outcome:</strong> With sundhedskort, the visit is completely FREE. You're assigned a GP in your area when you register. Prescriptions may have small copay.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 2: Specialist Referral</h4>
        <p class="text-neutral-600 mb-2">Your GP refers you to a specialist for further examination.</p>
        <p class="text-green-700"><strong>Outcome:</strong> Specialist visit is FREE with referral from GP. Wait times vary—for non-urgent issues, you might wait a few weeks. Quality is excellent.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 3: Emergency Room</h4>
        <p class="text-neutral-600 mb-2">You have a bicycle accident and need emergency treatment.</p>
        <p class="text-green-700"><strong>Outcome:</strong> ER (skadestue) treatment is FREE. All necessary care, X-rays, and treatment included. Danish emergency care is efficient and high-quality.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 4: Dental Checkup</h4>
        <p class="text-neutral-600 mb-2">You want a routine dental cleaning and checkup.</p>
        <p class="text-red-700"><strong>Outcome:</strong> Dental is NOT covered by public healthcare. Expect to pay DKK 500-1,500 (~€70-200) for a checkup and cleaning. Budget separately for dental or get supplementary insurance.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 5: Before CPR Registration</h4>
        <p class="text-neutral-600 mb-2">You get sick in your first week before receiving sundhedskort.</p>
        <p class="text-amber-700"><strong>Outcome:</strong> Use your private insurance or EHIC (EU students). You can still see doctors but may need to pay upfront and claim reimbursement. This is why you need insurance initially.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 6: Trip to Sweden, Get Sick</h4>
        <p class="text-neutral-600 mb-2">You visit Sweden for a weekend and need medical care.</p>
        <p class="text-green-700"><strong>Outcome:</strong> Your sundhedskort includes EU health card functionality. Emergency care in EU/EEA countries is covered at local rates.</p>
      </div>
    </div>
  </section>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-4">
      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">1</div>
        <div>
          <h4 class="font-semibold text-red-900">No Insurance Before CPR Registration</h4>
          <p class="text-red-700">You need insurance until your sundhedskort arrives (1-3 weeks). EU students: bring EHIC. Non-EU: have comprehensive private insurance. Don't assume immediate healthcare access.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">2</div>
        <div>
          <h4 class="font-semibold text-red-900">Underestimating Copenhagen Costs</h4>
          <p class="text-red-700">DKK 6,397/month is the official minimum—Copenhagen actually costs DKK 8,000-12,000/month. Housing is the biggest challenge. Apply for kollegium early!</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">3</div>
        <div>
          <h4 class="font-semibold text-red-900">Delaying CPR Registration</h4>
          <p class="text-red-700">Register at Borgerservice (Citizen Service) as soon as you have housing. CPR is essential for healthcare, banking, phone contracts, employment, and more.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">4</div>
        <div>
          <h4 class="font-semibold text-red-900">Not Getting a Bike</h4>
          <p class="text-red-700">Seriously—cycling is THE way to get around in Danish cities. Public transport exists but is expensive. Buy or rent a bike immediately. It will change your life in Denmark.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">5</div>
        <div>
          <h4 class="font-semibold text-red-900">Forgetting Dental Isn't Covered</h4>
          <p class="text-red-700">Danish public healthcare doesn't cover dental (except emergencies). Budget DKK 500-1,500 for a checkup, more for any work needed. Consider supplementary dental insurance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Healthcare in Denmark -->
  <section id="healthcare" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Healthcare in Denmark</h2>

    <p class="mb-4">
      Danish healthcare is excellent and, with your sundhedskort, completely free for most services. You're assigned a GP in your area and access specialists through referral. The system is efficient and high-quality.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">What's Free</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>✓ GP visits (læge)</li>
          <li>✓ Specialist visits (with referral)</li>
          <li>✓ Hospital stays and treatment</li>
          <li>✓ Emergency care (skadestue)</li>
          <li>✓ Mental health services</li>
          <li>✓ Maternity care</li>
          <li>✓ Most prescriptions (subsidized)</li>
          <li>✓ Physiotherapy (with referral)</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">What's NOT Covered</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>✗ Dental care (except emergencies)</li>
          <li>✗ Glasses and contacts</li>
          <li>✗ Some cosmetic procedures</li>
          <li>✗ Private healthcare</li>
          <li>✗ Some alternative medicine</li>
          <li>✗ Non-emergency care abroad</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Sundhed.dk:</strong> Denmark has an excellent digital health portal (sundhed.dk) where you can see your health records, book appointments, view prescriptions, and more. Very convenient once you're in the system.
      </p>
    </div>
  </section>

  <!-- Section: FAQ -->
  <section id="faq" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Frequently Asked Questions</h2>

    <div class="space-y-4">
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Is healthcare free for students in Denmark?</h4>
        <p class="text-neutral-600">Yes, once you have a CPR number and Danish health card (sundhedskort). Registration takes a few weeks after arrival. Until then, EU students use EHIC; non-EU students need private insurance. After registration, GP visits and hospital care are free.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">How much is tuition in Denmark?</h4>
        <p class="text-neutral-600">EU/EEA students: FREE. Non-EU students: DKK 45,000-120,000/year (~€6,000-16,000). Some programs (business, technical) cost more. Scholarships available but competitive.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Can I work while studying in Denmark?</h4>
        <p class="text-neutral-600">Yes. During semester: 20 hours/week. June-August and December: full-time allowed. No separate work permit needed. Many students work to offset Denmark's high living costs. Minimum wage is high (~DKK 120/hour).</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">What is the CPR number?</h4>
        <p class="text-neutral-600">Civil Personal Registration number—your Danish ID. Essential for healthcare, banking, employment, phone contracts. Register at your local Citizen Service Centre after arrival. Processing: 1-3 weeks typically.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Can I stay after graduation?</h4>
        <p class="text-neutral-600">Yes. Denmark offers a 6-month "establishment card" for job seeking after graduation. Can be extended to 3 years if you find qualifying work. Pay Limit scheme allows staying if earning above DKK 465,000/year.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">How expensive is Copenhagen?</h4>
        <p class="text-neutral-600">Very expensive. Budget DKK 8,000-12,000/month minimum (€1,100-1,600). Rent alone: DKK 5,000-8,000 for a room. Smaller cities (Aarhus, Odense) are cheaper. Student housing (kollegium) is much more affordable if you can get it.</p>
      </div>
    </div>
  </section>

  <!-- Section: Final Verdict -->
  <section id="verdict" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Final Verdict</h2>

    <p class="mb-4">
      Denmark offers exceptional quality of life for students: free healthcare, free tuition for EU students, a culture that values balance and well-being, and a practical, high-quality education system. The challenge is purely financial—Danish living costs are among Europe's highest.
    </p>

    <p class="mb-4">
      The healthcare system is genuinely excellent once you have your CPR and sundhedskort. Get those registered as soon as possible after arrival. For the initial weeks, ensure you have insurance coverage. And remember: dental care is NOT covered—budget accordingly.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-2">The Bottom Line</h3>
      <p class="text-primary-800">
        Denmark is ideal for students who value quality of life, excellent free healthcare, and a sustainable lifestyle—and who can afford the high living costs. Get your CPR number immediately after arrival. Buy a bike. And embrace hygge—you're in one of the happiest countries in the world.
      </p>
