---
/**
 * Netherlands Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in the Netherlands", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Netherlands Health Insurance Guide", href: "/countries/netherlands/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "University Admission", details: "Unconditional acceptance from Dutch institution", evidence: "Admission letter from university" },
  { requirement: "Financial Proof", details: "€11,400/year (or €950/month)", evidence: "Bank statements or sponsor declaration" },
  { requirement: "Health Insurance", details: "Valid insurance meeting Dutch standards", evidence: "Insurance certificate" },
  { requirement: "Accommodation", details: "Housing in the Netherlands (initial address)", evidence: "Rental contract or university housing" },
  { requirement: "English Proficiency", details: "IELTS 6.0-6.5 or TOEFL 80-90 typically", evidence: "Test certificate" },
  { requirement: "TB Certificate", details: "Required from certain countries", evidence: "Medical certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "student", header: "Student Insurance" },
  { key: "basic", header: "Dutch Basic (Basisverzekering)" },
];

const insuranceRows = [
  { feature: "Monthly Cost", student: "€50-80/month", basic: "€130+/month" },
  { feature: "When Required", student: "If not working or under 32 hrs/month", basic: "If working 32+ hours/month" },
  { feature: "Deductible", student: "Usually none or low", basic: "€385/year (eigen risico)" },
  { feature: "Dental", student: "Often included (basic)", basic: "NOT covered for adults" },
  { feature: "Providers", student: "AON, OOM, Zorgverzekering", basic: "Zilveren Kruis, VGZ, CZ" },
  { feature: "GP Access", student: "Yes, register with huisarts", basic: "Yes, register with huisarts" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "AON Student Insurance", type: "Student", price: "€50-70", strengths: "Most popular, comprehensive" },
  { provider: "OOM Verzekeringen", type: "Student", price: "€45-65", strengths: "Good value, flexible" },
  { provider: "IND Erkend", type: "Student", price: "€55-80", strengths: "IND-recognized options" },
  { provider: "Zilveren Kruis", type: "Dutch Basic", price: "€130+", strengths: "Required if working 32+ hrs" },
  { provider: "Cigna Global", type: "International", price: "€100-180", strengths: "Frequent travelers" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "MVV/Residence Permit", amount: "€210", notes: "Often paid via university" },
  { item: "Tuition (EU/EEA)", amount: "€2,530/year", notes: "Statutory rate 2024/25" },
  { item: "Tuition (non-EU)", amount: "€8,000-20,000/year", notes: "Institutional rate, varies" },
  { item: "Health Insurance", amount: "€50-80/month", notes: "Student insurance" },
  { item: "Housing Deposit", amount: "€500-1,500", notes: "Refundable, varies" },
  { item: "Municipality Registration", amount: "€0-50", notes: "Varies by gemeente" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Receive unconditional admission", duration: "Varies", location: "University" },
  { step: "University initiates MVV application", duration: "1-2 weeks", location: "University international office" },
  { step: "IND processes MVV", duration: "2-4 weeks", location: "Netherlands (IND)" },
  { step: "Receive MVV approval", duration: "Via embassy", location: "Dutch embassy in your country" },
  { step: "Travel to Netherlands", duration: "Within 90 days of MVV", location: "-" },
  { step: "Register at municipality", duration: "Within 5 days of arrival", location: "Local gemeente" },
  { step: "Collect residence permit", duration: "1-2 weeks", location: "IND desk" },
  { step: "Arrange health insurance", duration: "Immediately", location: "Online" },
];
---

<PageShell
  title="Netherlands Student Visa 2026: Requirements, Insurance & Zoekjaar Guide"
  description="Complete guide to the Dutch Student Visa. MVV requirements, health insurance options, the zoekjaar job search year, tuition fees, and the straightforward visa process handled by your university."
  headline="Netherlands Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in the Netherlands—university-managed visa process, health insurance options, the zoekjaar post-study work year, and navigating Dutch healthcare."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official IND Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Zoekjaar Work Year Available
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The Netherlands is one of the most popular destinations for international students, with over 115,000 studying at Dutch universities. The appeal is clear: <strong>most programs taught in English</strong>, a streamlined visa process where the university handles most paperwork, excellent quality of education, and a 1-year job search visa (zoekjaar) after graduation.
    </p>

    <p class="mb-4">
      Health insurance in the Netherlands works differently depending on whether you work. If you don't work (or work less than 32 hours/month), you need student insurance meeting Dutch requirements. If you work 32+ hours/month, you're required to join Dutch basic insurance (basisverzekering)—which is more expensive but covers you like any Dutch resident.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Netherlands Student Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Programs:</strong> 2,100+ English-taught programs—most in continental Europe</li>
        <li>• <strong>Visa process:</strong> University handles MVV application on your behalf</li>
        <li>• <strong>Insurance:</strong> Student insurance (~€60/month) or Dutch basic (€130+/month if working)</li>
        <li>• <strong>Work rights:</strong> 16 hours/week during term (permit required), full-time in summer</li>
        <li>• <strong>Zoekjaar:</strong> 1-year job search visa after graduation</li>
        <li>• <strong>Dental warning:</strong> Dutch basic insurance does NOT cover dental for adults</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Study in the Netherlands?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>English everywhere:</strong> 2,100+ programs in English, 95% of Dutch speak English</li>
      <li><strong>University handles visa:</strong> Less paperwork—they apply for your MVV</li>
      <li><strong>Quality education:</strong> 13 Dutch universities in world top 200</li>
      <li><strong>Zoekjaar:</strong> 1-year post-study job search visa</li>
      <li><strong>Central location:</strong> Easy access to rest of Europe, major airport hub</li>
      <li><strong>International environment:</strong> 13% of population is non-Dutch</li>
      <li><strong>Innovation hub:</strong> Strong in tech, business, engineering, creative industries</li>
      <li><strong>Bike culture:</strong> Easy, affordable transport</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Netherlands is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want to study entirely in English</li>
          <li>✓ You want a straightforward visa process</li>
          <li>✓ You want to work in Europe after graduation</li>
          <li>✓ You value international, diverse environments</li>
          <li>✓ You're interested in business, tech, or creative fields</li>
          <li>✓ You want central European location</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want free tuition (Germany is €0 at public unis)</li>
          <li>• Budget is very tight (Netherlands is expensive)</li>
          <li>• You need dental coverage (not included in basic insurance)</li>
          <li>• You want longer post-study work (Germany offers 18 months)</li>
          <li>• Housing is a dealbreaker (Dutch housing crisis is real)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Zoekjaar advantage:</strong> After graduating from a Dutch university, you can apply for the zoekjaar (orientation year)—a 1-year residence permit to find work. You can work any job during this time, and once employed, switch to a work permit. Great for building a career in Europe.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The Dutch student visa process is uniquely straightforward: your university handles the MVV (entry visa) and residence permit application on your behalf. This means less bureaucracy for you.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">The MVV + Residence Permit Process</h3>

    <p class="mb-4">
      Unlike most countries where you apply for a visa at an embassy, Dutch universities act as "sponsors" and apply to IND (Immigration and Naturalization Service) on your behalf. You just need to:
    </p>

    <ol class="list-decimal pl-6 space-y-2 mb-6">
      <li>Get <strong>unconditional admission</strong> from a Dutch university</li>
      <li>Provide required documents to university (passport, financial proof, insurance)</li>
      <li>University submits MVV application to IND</li>
      <li>Collect MVV sticker from Dutch embassy in your country</li>
      <li>Travel to Netherlands and collect residence permit</li>
    </ol>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-green-800">
        <strong>Much simpler than other countries:</strong> No embassy interviews, no complex paperwork. Your university's international office guides you through the process. Just provide documents and follow their instructions.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Financial Requirements</h3>

    <p class="mb-4">
      You must prove you have <strong>€11,400/year</strong> (approximately €950/month) to support yourself. This can be shown through:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Bank statements:</strong> Showing sufficient savings</li>
      <li><strong>Sponsor declaration:</strong> Parents or guarantor (notarized declaration)</li>
      <li><strong>Scholarship letter:</strong> If receiving funding</li>
      <li><strong>Combination:</strong> Partial savings plus sponsor</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Housing warning:</strong> The Netherlands, especially Amsterdam, has a severe housing shortage. Finding accommodation is often the hardest part of moving. Start searching early, use university housing if available, and consider smaller cities (Groningen, Eindhoven, Maastricht) where housing is easier.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-amber-900 mb-2">Insurance Depends on Whether You Work</h3>
      <p class="text-amber-800">
        The Netherlands has a unique rule: if you work 32 hours/month or more, you MUST join Dutch basic insurance (basisverzekering). If you don't work (or work less), you can use student insurance. This matters for costs—Dutch basic is €130+/month vs. ~€60/month for student insurance.
      </p>
    </div>

    <p class="mb-4">
      Either way, you need valid health insurance from day 1 in the Netherlands. Student insurance from providers like AON or OOM meets IND requirements. If you start working significantly, you'll need to switch to Dutch basic insurance.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Student Insurance vs. Dutch Basic</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Which Do You Need?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Student Insurance (~€60/month) If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ You don't work in the Netherlands</li>
          <li>✓ You work less than 32 hours/month</li>
          <li>✓ You want lower costs</li>
          <li>✓ You want included basic dental</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Dutch Basic (€130+/month) If:</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ You work 32+ hours/month (mandatory)</li>
          <li>✓ You want the same coverage as Dutch residents</li>
          <li>✓ You plan to stay after graduation (smoother transition)</li>
        </ul>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Dental NOT covered:</strong> Dutch basic insurance does NOT cover dental care for adults (only children under 18). This is true for all Dutch residents. Budget €200-400/year for dental, or get additional dental insurance (aanvullende verzekering), or do dental work before moving.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need help choosing Dutch health insurance?"
    description="Compare AON, OOM, and Dutch basic insurance options for students."
    buttonText="Compare Dutch Insurance Options"
    buttonHref="/countries/netherlands/insurance"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For most students (not working or working fewer than 32 hours/month), student insurance is the best choice. AON Student Insurance is the most popular among international students in the Netherlands.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Standard Student (Not Working)</h4>
        <p class="text-neutral-600">AON Student Insurance is the most popular choice—widely recognized, comprehensive coverage, includes basic dental, and priced around €50-70/month. OOM is a good alternative at similar pricing.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Working Part-Time (32+ hours/month)</h4>
        <p class="text-neutral-600">You must join Dutch basic insurance (basisverzekering). Zilveren Kruis, VGZ, and CZ are major providers. Compare on zorgwijzer.nl or independer.nl. Add dental coverage separately—it's not included.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Traveling Frequently</h4>
        <p class="text-neutral-600">Dutch student insurance typically covers you in the Netherlands and has limited EU coverage. If you travel often outside Europe, consider adding international coverage from Cigna Global or similar alongside your student insurance.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Dental Concerns</h4>
        <p class="text-neutral-600">Student insurance often includes basic dental. Dutch basic insurance does NOT. If you're on Dutch basic and need dental care, add aanvullende verzekering (supplementary insurance) with dental coverage—costs €5-20/month extra.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The Netherlands is not a budget destination, but it offers good value for the quality of education and international experience. EU students benefit from much lower tuition fees.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Total First-Year Costs</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">EU Student</p>
        <p class="text-3xl font-bold text-neutral-900">€3,500-4,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + tuition + insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Non-EU Student</p>
        <p class="text-3xl font-bold text-neutral-900">€9,000-21,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + tuition + insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Annual Insurance</p>
        <p class="text-3xl font-bold text-neutral-900">€600-900</p>
        <p class="text-sm text-neutral-500 mt-2">Student insurance</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Living Costs</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Amsterdam (Most Expensive)</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €700-1,200/month (room or small studio)</li>
          <li>• Food: €200-300/month</li>
          <li>• Transport: €0-100/month (bike!)</li>
          <li>• Insurance: €60-130/month</li>
          <li>• Other: €100-200/month</li>
          <li>• <strong>Total: €1,100-1,800/month</strong></li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Other Cities (Groningen, Eindhoven, etc.)</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €400-700/month</li>
          <li>• Food: €150-250/month</li>
          <li>• Transport: €0-50/month (bike!)</li>
          <li>• Insurance: €60-130/month</li>
          <li>• Other: €80-150/month</li>
          <li>• <strong>Total: €750-1,200/month</strong></li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Bike culture saves money:</strong> The Netherlands is bike-friendly—most students cycle everywhere. A good used bike costs €100-200, and you'll save on transport all year. Budget €0-50/month for transport if you bike (vs. €100+ for public transport in other countries).
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Dutch student visa process is refreshingly simple because your university handles most of it. Your main job is to get admitted and provide documents—they do the rest.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get University Admission</h4>
          <p class="text-neutral-600">Apply to Dutch universities through Studielink (Dutch system) or directly. You need unconditional admission—conditional offers don't work for visa applications. Confirm your place and pay any deposits.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Provide Documents to University</h4>
          <p class="text-neutral-600">Your university's international office will request: passport copy, passport photo, financial proof (€11,400), proof of health insurance, and sometimes TB certificate. Follow their specific instructions.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">University Submits MVV Application</h4>
          <p class="text-neutral-600">The university submits your MVV (entry visa) and residence permit applications to IND. You don't need to do anything except wait. Processing typically takes 2-4 weeks.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect MVV from Embassy</h4>
          <p class="text-neutral-600">Once approved, you'll be notified to collect your MVV (visa sticker) from the Dutch embassy or consulate in your country. Bring your passport. The MVV is valid for 90 days—travel within this window.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive and Register</h4>
          <p class="text-neutral-600">Upon arrival, register at the municipality (gemeente) within 5 days. You need a Dutch address—this is why housing is important to arrange beforehand. You'll receive a BSN (citizen service number).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect Residence Permit</h4>
          <p class="text-neutral-600">Visit an IND desk (often at university or nearby) to provide biometrics and collect your residence permit. This takes 1-2 weeks after your appointment. The permit is your official status in the Netherlands.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Finalize Health Insurance</h4>
          <p class="text-neutral-600">If not already done, arrange health insurance immediately. AON and OOM can be arranged online. You need coverage from day 1—don't delay. Register with a huisarts (GP) in your area.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>5-day registration deadline:</strong> You must register at the municipality (gemeente) within 5 days of arrival. This requires having a Dutch address—another reason to arrange housing before you arrive. Missing this deadline complicates everything.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out for international students in the Netherlands:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Master's Student from India, Amsterdam</h3>
        <p class="text-neutral-600 mb-4">Data Science at University of Amsterdam, not working.</p>
        <p class="text-green-700 font-medium">✓ AON student insurance (€65/month). University handled entire visa process—just submitted documents. Housing was hard—ended up 30 minutes outside Amsterdam but manageable by train. Very happy with English environment.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Bachelor's Student from Germany (EU), Groningen</h3>
        <p class="text-neutral-600 mb-4">Psychology at University of Groningen, works part-time.</p>
        <p class="text-amber-700 font-medium">△ EU citizen—no visa needed. Works 40 hours/month at a restaurant, so had to get Dutch basic insurance (€130/month) instead of cheaper student insurance. Added dental coverage separately. Housing much easier in Groningen than Amsterdam.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">MBA Student from Nigeria, Rotterdam</h3>
        <p class="text-neutral-600 mb-4">MBA at Rotterdam School of Management.</p>
        <p class="text-green-700 font-medium">✓ University handled everything—even airport pickup. OOM insurance (€60/month) covers basics. Intensive program means no time for work anyway. Rotterdam more affordable than Amsterdam. Planning to use zoekjaar after graduation.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">PhD Candidate from China, Eindhoven</h3>
        <p class="text-neutral-600 mb-4">Funded PhD at TU Eindhoven (employed researcher).</p>
        <p class="text-green-700 font-medium">✓ As employee, automatically enrolled in Dutch basic insurance (employer contribution). Full Dutch benefits. Tech hub environment perfect for research. Eindhoven more affordable than Amsterdam. Housing still challenging but better than Randstad.</p>
