---
/**
 * Spain Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Spain", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Spain Health Insurance Guide", href: "/countries/spain/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "University Admission", details: "Acceptance from Spanish institution", evidence: "Official admission letter" },
  { requirement: "Financial Proof", details: "€600/month (100% IPREM)", evidence: "Bank statements or sponsor letter" },
  { requirement: "Health Insurance", details: "No copays, €30,000+ coverage", evidence: "Policy certificate in Spanish" },
  { requirement: "Accommodation", details: "Proof of housing in Spain", evidence: "Rental contract or residence letter" },
  { requirement: "Criminal Record", details: "Clean background from home country", evidence: "Certificate (apostilled)" },
  { requirement: "Medical Certificate", details: "No serious communicable diseases", evidence: "Doctor's certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "requirement", header: "Spain Requirement" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { feature: "Copays", requirement: "NOT ALLOWED (sin copagos)", notes: "Policies with any copay are rejected" },
  { feature: "Minimum Coverage", requirement: "€30,000+", notes: "For medical treatment and repatriation" },
  { feature: "Insurer Location", requirement: "Must operate in Spain", notes: "Spanish or international with Spanish presence" },
  { feature: "Coverage Area", requirement: "All of Spain", notes: "Full Schengen coverage recommended" },
  { feature: "Duration", requirement: "Full length of stay", notes: "Must cover entire visa period" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Sanitas", type: "Spanish Local", price: "€40-80", strengths: "Excellent network, accepted everywhere" },
  { provider: "ASSSA", type: "Spanish Local", price: "€50-90", strengths: "Expat-focused, English service" },
  { provider: "Adeslas", type: "Spanish Local", price: "€50-100", strengths: "Largest network in Spain" },
  { provider: "Cigna Global", type: "International", price: "€100-180", strengths: "Global coverage, premium service" },
  { provider: "Allianz Care", type: "International", price: "€90-150", strengths: "Good balance, Spanish presence" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Fee", amount: "€80-180", notes: "Varies by visa type and consulate" },
  { item: "Tuition (Public, EU)", amount: "€700-1,500/year", notes: "Varies by region and program" },
  { item: "Tuition (Public, non-EU)", amount: "€1,500-3,500/year", notes: "Higher in Madrid/Catalonia" },
  { item: "Health Insurance", amount: "€40-150/month", notes: "Must be sin copagos" },
  { item: "TIE Card", amount: "€15-20", notes: "Foreigner ID card fee" },
  { item: "Document Apostille", amount: "€50-150", notes: "For criminal record, diplomas" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Receive university admission", duration: "Varies", location: "University" },
  { step: "Gather documents (apostilles, translations)", duration: "2-4 weeks", location: "Home country" },
  { step: "Purchase Spanish health insurance", duration: "1-2 days", location: "Online or local" },
  { step: "Schedule visa appointment", duration: "2-8 weeks wait", location: "Spanish consulate" },
  { step: "Attend visa interview", duration: "1 day", location: "Spanish consulate" },
  { step: "Visa processing", duration: "1-3 months", location: "Spanish authorities" },
  { step: "Travel to Spain", duration: "-", location: "-" },
  { step: "Apply for TIE card", duration: "Within 30 days", location: "Extranjería (police station)" },
];
---

<PageShell
  title="Spain Student Visa 2026: Requirements, Insurance & Application Guide"
  description="Complete guide to the Spanish Student Visa. Insurance requirements (sin copagos), affordable tuition, 30 hours/week work rights, and step-by-step application process."
  headline="Spain Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in Spain—strict insurance requirements (no copays), affordable public university tuition, generous work rights, and the complete application process."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Consulate Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Sin Copagos Requirement
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Spain is one of Europe's most popular destinations for international students, attracting over 125,000 students annually. The combination of <strong>affordable tuition</strong>, excellent quality of life, rich culture, and the chance to learn Spanish makes it highly appealing.
    </p>

    <p class="mb-4">
      However, Spain has one of the <strong>strictest insurance requirements</strong> in Europe: your policy must have absolutely no copays (sin copagos). This catches many students off-guard—policies with even small copays like €10 per visit are routinely rejected by Spanish consulates.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Spain Student Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Insurance:</strong> Must have NO copays (sin copagos)—strictly enforced</li>
        <li>• <strong>Tuition:</strong> €700-3,500/year at public universities (very affordable)</li>
        <li>• <strong>Work rights:</strong> 30 hours/week (more generous than most countries)</li>
        <li>• <strong>Financial proof:</strong> €600/month (100% IPREM)</li>
        <li>• <strong>TIE card:</strong> Required within 30 days of arrival</li>
        <li>• <strong>Processing time:</strong> 1-3 months (can be slow)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Study in Spain?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Affordable tuition:</strong> Public universities charge €700-3,500/year</li>
      <li><strong>Spanish language:</strong> Learn the world's 4th most spoken language</li>
      <li><strong>Quality of life:</strong> Mediterranean climate, vibrant culture, great food</li>
      <li><strong>Work rights:</strong> 30 hours/week—more than most European countries</li>
      <li><strong>Central location:</strong> Easy access to rest of Europe</li>
      <li><strong>Strong programs:</strong> Business, architecture, engineering, arts</li>
      <li><strong>Affordable living:</strong> €800-1,200/month in most cities (less than UK/Germany)</li>
      <li><strong>Post-study options:</strong> Can convert to work permit after graduation</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Spain is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want to learn Spanish</li>
          <li>✓ You value quality of life and work-life balance</li>
          <li>✓ You want affordable tuition</li>
          <li>✓ You want generous work rights (30 hrs/week)</li>
          <li>✓ You prefer Mediterranean climate</li>
          <li>✓ You're studying business, architecture, or arts</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want free tuition (Germany has €0 tuition)</li>
          <li>• You want English-only environment (Netherlands, Ireland)</li>
          <li>• You need fast visa processing (Spain can take 3 months)</li>
          <li>• You want simpler insurance rules (Italy's SSN is easier)</li>
          <li>• You want stronger post-study work visa (Germany's 18 months)</li>
        </ul>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Critical: "Sin Copagos" insurance required.</strong> Spain strictly enforces the no-copay rule. Many students have their visas rejected because their insurance has small copays. Always verify your policy is explicitly "sin copagos" before your visa appointment.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The Spanish Student Visa requires university admission, proof of financial means, no-copay health insurance, and several documents that must be apostilled and potentially translated.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Financial Requirements</h3>

    <p class="mb-4">
      Spain requires proof of <strong>€600/month</strong> (100% of the IPREM indicator). For a full academic year, that's approximately €7,200. You can demonstrate this through:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Personal bank statements:</strong> Showing sufficient funds</li>
      <li><strong>Scholarship letter:</strong> If receiving funding</li>
      <li><strong>Sponsor declaration:</strong> Parents or guarantor with notarized letter</li>
      <li><strong>Combination:</strong> Partial personal funds plus sponsor support</li>
    </ul>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Requirements</h3>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Apostille requirement:</strong> Your criminal record certificate (and sometimes other documents) must be apostilled in your home country. This process can take 2-4 weeks, so start early. Some consulates also require Spanish translations by certified translators.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">STRICT: No Copays Allowed (Sin Copagos)</h3>
      <p class="text-red-800">
        Spain has one of Europe's strictest insurance requirements. Your policy must have <strong>absolutely no copays</strong>—not €5, not €10, not any amount. Consulates routinely reject applications with policies that have any cost-sharing at the point of care. This is the #1 reason for student visa rejections.
      </p>
    </div>

    <p class="mb-4">
      Beyond the no-copay rule, your insurance must provide at least €30,000 in coverage, be from an insurer operating in Spain, and cover your entire stay.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Insurance Requirements Summary</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Which Insurance Works?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Accepted Insurance Types:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Spanish insurers (Sanitas, ASSSA, Adeslas)</li>
          <li>✓ Cigna Global (has Spanish presence)</li>
          <li>✓ Allianz Care (has Spanish presence)</li>
          <li>✓ BUPA Global (with Spain coverage)</li>
          <li>✓ Any insurer operating in Spain with sin copagos policy</li>
        </ul>
      </div>

      <div class="border border-red-200 bg-red-50 rounded-lg p-6">
        <h4 class="font-semibold text-red-900 mb-3">NOT Accepted:</h4>
        <ul class="space-y-2 text-red-800">
          <li>✗ SafetyWing (travel insurance, has copays)</li>
          <li>✗ World Nomads (travel insurance)</li>
          <li>✗ Any policy with copays/deductibles at point of care</li>
          <li>✗ Insurers not operating in Spain</li>
          <li>✗ Travel insurance policies</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Spanish insurers are often cheaper:</strong> Local insurers like Sanitas (€40-80/month) and ASSSA (€50-90/month) are typically cheaper than international insurers and are always accepted. They have excellent networks throughout Spain.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need sin copagos insurance for Spain?"
    description="Compare Sanitas, ASSSA, and international options that meet Spanish requirements."
    buttonText="Compare Spain-Compliant Insurance"
    buttonHref="/countries/spain/insurance"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Spanish local insurers are often the best choice for students—they're accepted at all consulates, have extensive local networks, and are typically cheaper than international options.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Value: Spanish Local Insurers</h4>
        <p class="text-neutral-600">Sanitas, ASSSA, and Adeslas offer excellent coverage at €40-100/month. They're always accepted by consulates, have the best networks in Spain, and often provide English-speaking support. ASSSA is particularly popular with expats.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Need International Coverage</h4>
        <p class="text-neutral-600">If you'll travel frequently or want coverage outside Spain, Cigna Global and Allianz Care work well. They cost more (€90-180/month) but provide global coverage. Ensure you get a sin copagos policy—their standard plans may have copays.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Studying in Multiple Countries</h4>
        <p class="text-neutral-600">For exchange students or those studying in multiple EU countries, international insurers provide seamless coverage. Allianz Care and Cigna Global handle multi-country situations well.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">English Service Priority</h4>
        <p class="text-neutral-600">ASSSA specifically targets expats and offers excellent English service. Cigna Global and Allianz Care also provide strong English support. Sanitas and Adeslas have English options but are primarily Spanish-language.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Spain offers excellent value for students. Public university tuition is among the lowest in Europe, and living costs are moderate compared to Northern Europe.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Total First-Year Costs</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">EU Student</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500-2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + tuition + insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Non-EU Student</p>
        <p class="text-3xl font-bold text-neutral-900">€2,500-5,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + tuition + insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Annual Insurance</p>
        <p class="text-3xl font-bold text-neutral-900">€500-1,800</p>
        <p class="text-sm text-neutral-500 mt-2">€40-150/month sin copagos</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Living Costs</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Madrid/Barcelona</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €500-900/month (room or small flat)</li>
          <li>• Food: €200-300/month</li>
          <li>• Transport: €20-40/month (student pass)</li>
          <li>• Insurance: €40-150/month</li>
          <li>• Other: €100-200/month</li>
          <li>• <strong>Total: €900-1,500/month</strong></li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Valencia, Seville, Granada</h4>
        <ul class="space-y-2 text-neutral-700 text-sm">
          <li>• Rent: €350-600/month</li>
          <li>• Food: €150-250/month</li>
          <li>• Transport: €20-35/month</li>
          <li>• Insurance: €40-150/month</li>
          <li>• Other: €80-150/month</li>
          <li>• <strong>Total: €700-1,100/month</strong></li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Work rights help:</strong> Spain allows students to work up to 30 hours/week—more than most European countries (typically 20 hours). At Spanish minimum wage (~€8/hour), that's potentially €900+/month, enough to cover most living costs.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Spanish student visa process involves gathering apostilled documents, obtaining compliant insurance, and applying at the Spanish consulate. Processing times vary but can be slow—plan for 1-3 months.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get University Admission</h4>
          <p class="text-neutral-600">Apply to Spanish universities directly or through the UNED system (for credential validation). Once accepted, you'll receive an official admission letter (carta de admisión) needed for the visa.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather and Apostille Documents</h4>
          <p class="text-neutral-600">Get your criminal record certificate apostilled (can take 2-4 weeks). Some consulates require Spanish translations of documents. Start this process early—it's often the bottleneck.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Sin Copagos Insurance</h4>
          <p class="text-neutral-600">Get health insurance from a Spanish insurer (Sanitas, ASSSA, Adeslas) or an international insurer operating in Spain. Verify the policy is explicitly "sin copagos" before your visa appointment.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Schedule Visa Appointment</h4>
          <p class="text-neutral-600">Book an appointment at the Spanish consulate in your country. Wait times vary significantly—some consulates have 2-week waits, others 2+ months. Book as early as possible.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Attend Visa Interview</h4>
          <p class="text-neutral-600">Bring all documents: admission letter, passport, financial proof, insurance certificate, criminal record (apostilled), medical certificate, accommodation proof, photos. Pay the visa fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Spanish visa processing can take 1-3 months—longer than many countries. Don't book non-refundable flights until you have your visa. Some consulates are faster than others.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive and Get TIE Card</h4>
          <p class="text-neutral-600">Within 30 days of arrival, apply for your TIE (Tarjeta de Identidad de Extranjero) at the local Extranjería (foreigners office). This is your Spanish ID card for the duration of your stay.</p>
        </div>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Start early:</strong> Spanish visa processing is notoriously slow. Begin gathering documents 4-6 months before your intended start date. The apostille process alone can take weeks, and consulate appointments may have long wait times.
      </p>
    </div>
  </section>

