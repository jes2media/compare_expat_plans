---
/**
 * Austria Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Austria", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Austria Health Insurance Guide", href: "/countries/austria/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "University Admission", details: "Acceptance from recognized Austrian institution", evidence: "Letter of admission" },
  { requirement: "Financial Proof", details: "€10,452/year (under 24) or €12,500 (24+)", evidence: "Bank statements, scholarship, sponsor" },
  { requirement: "Accommodation", details: "Proof of housing in Austria", evidence: "Rental contract or housing confirmation" },
  { requirement: "Health Insurance", details: "Valid coverage for Austria", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "Valid for duration of stay", evidence: "Passport" },
  { requirement: "Criminal Record", details: "Clean record certificate", evidence: "Police clearance (apostilled)" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "oegk", header: "ÖGK Student Insurance" },
  { key: "private", header: "Private Insurance" },
];

const insuranceRows = [
  { feature: "Monthly Cost", oegk: "~€70/month", private: "€50-150/month" },
  { feature: "Coverage", oegk: "Full public healthcare access", private: "Varies by plan" },
  { feature: "Network", oegk: "All public hospitals and doctors", private: "May have restrictions" },
  { feature: "Dental", oegk: "Basic coverage included", private: "Often better dental" },
  { feature: "Best For", oegk: "Best value—recommended for most", private: "Those wanting private rooms/faster access" },
  { feature: "Sign-up", oegk: "ÖGK office or online", private: "Direct with insurer" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "ÖGK (Student Self-Insurance)", type: "Public", price: "~€70", strengths: "Best value—full public healthcare access" },
  { provider: "UNIQA", type: "Private", price: "€60-120", strengths: "Good supplementary coverage" },
  { provider: "Wiener Städtische", type: "Private", price: "€50-100", strengths: "Austrian market leader" },
  { provider: "Generali", type: "Private", price: "€70-130", strengths: "International network" },
  { provider: "Allianz Austria", type: "Private", price: "€80-150", strengths: "Premium coverage options" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Residence Permit Fee", amount: "€160", notes: "Application fee" },
  { item: "Health Insurance (ÖGK)", amount: "~€70/month", notes: "Student self-insurance rate" },
  { item: "Tuition (EU)", amount: "~€20/semester", notes: "Student union fee only" },
  { item: "Tuition (Non-EU)", amount: "€726.72/semester", notes: "Public universities" },
  { item: "Living Costs (Vienna)", amount: "€1,000-1,400/month", notes: "Including rent" },
  { item: "Living Costs (Other)", amount: "€800-1,100/month", notes: "Graz, Salzburg, etc." },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Receive university admission", duration: "3-6 months before", location: "Austrian university" },
  { step: "Apply for student visa", duration: "2-3 months processing", location: "Austrian embassy" },
  { step: "Receive visa", duration: "Included above", location: "Austrian embassy" },
  { step: "Arrive in Austria", duration: "-", location: "Airport" },
  { step: "Register residence (Meldezettel)", duration: "Within 3 days", location: "Meldeamt" },
  { step: "Apply for residence permit", duration: "1-2 months processing", location: "MA 35 (Vienna) or BH" },
  { step: "Enroll in ÖGK insurance", duration: "After arrival", location: "ÖGK office" },
];
---

<PageShell
  title="Austria Student Visa 2026: Requirements, ÖGK Insurance & Application Guide"
  description="Complete guide to Austria's Student Residence Permit. Affordable ÖGK health insurance (~€70/month), low tuition, and studying in Vienna—Europe's most livable city."
  headline="Austria Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in Austria—affordable ÖGK student insurance at just €70/month, low tuition for non-EU students, and life in Vienna, consistently ranked the world's most livable city."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official MA 35 Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      ÖGK Student Insurance ~€70/month
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Austria offers a compelling combination: excellent universities, affordable tuition (€726/semester for non-EU), and Vienna—consistently ranked the world's most livable city. Over 80,000 international students study in Austria, drawn by the quality of life, central European location, and reasonable costs compared to neighboring Switzerland.
    </p>

    <p class="mb-4">
      One of Austria's best-kept secrets is the <strong>ÖGK student self-insurance</strong> program. For approximately €70/month, you get full access to Austria's excellent public healthcare system. This is one of the best value student insurance options in Europe—comprehensive coverage at a very reasonable price.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-2">Quick Facts: Austria Student Visa</h3>
      <ul class="space-y-1 text-primary-800">
        <li>• <strong>Permit Type:</strong> Aufenthaltsbewilligung Studierende</li>
        <li>• <strong>Duration:</strong> 1 year, renewable</li>
        <li>• <strong>Health Insurance:</strong> ÖGK recommended (~€70/month)</li>
        <li>• <strong>Work Rights:</strong> 20 hrs/week</li>
        <li>• <strong>Tuition:</strong> €726.72/semester (non-EU)</li>
        <li>• <strong>Processing:</strong> 2-3 months</li>
        <li>• <strong>Post-Study:</strong> Rot-Weiß-Rot Karte job search (12 months)</li>
      </ul>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">✓ Austria Is a Great Fit If You:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• Want excellent education at low tuition</li>
          <li>• Prefer affordable, high-quality healthcare</li>
          <li>• Want to live in a highly livable city (Vienna)</li>
          <li>• Are interested in German-speaking opportunities</li>
          <li>• Want central EU location for travel</li>
          <li>• Appreciate culture, music, and history</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">⚠ Consider Alternatives If You:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Don't want to learn German</li>
          <li>• Prefer English-only environment</li>
          <li>• Want warmer climate</li>
          <li>• Need flexible work hours beyond 20/week</li>
          <li>• Prefer larger country with more cities</li>
          <li>• Want coastal or beach access</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-6">
      Non-EU students need a student visa before arrival, then apply for a residence permit after arriving. EU citizens just need to register. The process is straightforward but plan 2-3 months for visa processing.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Financial Proof:</strong> Under 24: €10,452/year. 24 and over: €12,500/year. This can come from personal savings, scholarship, or sponsor (parents typically). Bank statements should show consistent funds.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-green-800">
        <strong>✓ ÖGK Student Self-Insurance is the Best Option:</strong> For approximately €70/month, you get full access to Austria's public healthcare system. This is one of the best deals for student health insurance in Europe. Highly recommended over private insurance for most students.
      </p>
    </div>

    <p class="mb-6">
      Health insurance is required for your residence permit. While private insurance is accepted, the ÖGK student self-insurance (Selbstversicherung für Studierende) offers far better value. EU students can use EHIC initially, then enroll in ÖGK.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>How to Enroll:</strong> Visit your local ÖGK (Österreichische Gesundheitskasse) office after arrival. Bring your passport, residence registration (Meldezettel), and university enrollment confirmation. The process is straightforward.
      </p>
    </div>
  </section>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-6">
      ÖGK student self-insurance is the clear winner for most students. Private insurance makes sense only if you want specific benefits like private hospital rooms.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <CTABox
      title="Best Option: ÖGK Student Insurance"
      description="At ~€70/month for full public healthcare access, ÖGK is hard to beat. Most students should choose this option."
      buttonText="Learn More About Options"
      buttonHref="/go/cigna-global"
    />
  </section>

  <!-- Section: Costs -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-6">
      Austria offers excellent value compared to Switzerland, UK, or Netherlands. Vienna is more expensive than smaller cities, but still affordable by European standards.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <div class="mt-6 grid md:grid-cols-2 gap-4">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Monthly Budget (Vienna)</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>Rent: €400-600 (shared apartment)</li>
          <li>Food: €200-300</li>
          <li>Transport: €75 (semester ticket)</li>
          <li>Insurance: €70 (ÖGK)</li>
          <li>Phone/Misc: €50-100</li>
          <li><strong>Total: €1,000-1,400/month</strong></li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Monthly Budget (Graz/Salzburg)</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>Rent: €300-450 (shared apartment)</li>
          <li>Food: €180-250</li>
          <li>Transport: €50-70</li>
          <li>Insurance: €70 (ÖGK)</li>
          <li>Phone/Misc: €50-80</li>
          <li><strong>Total: €800-1,100/month</strong></li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Annual Cost Estimate:</strong> Non-EU students: €12,000-18,000/year total (tuition + living + insurance). This is very competitive compared to UK (~€25,000+) or Netherlands (~€15,000-20,000).
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-6">
      Non-EU students: apply for visa before arriving, then residence permit after. EU students: just register after arrival. The Meldezettel (residence registration) must be done within 3 days!
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <div class="mt-6 bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Critical: 3-Day Meldezettel Deadline!</strong> You must register your residence (Meldezettel) within 3 days of moving into accommodation. Go to the Meldeamt (registration office) with your passport and rental contract. This is strictly enforced.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="space-y-4">
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 1: GP Visit for Illness</h4>
        <p class="text-neutral-600 mb-2">You have flu symptoms and visit a general practitioner.</p>
        <p class="text-green-700"><strong>Outcome:</strong> With ÖGK, you show your e-card and pay nothing. GP visit is fully covered. Prescriptions have small copay (€6-7 per medication typically).</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 2: Specialist Referral</h4>
        <p class="text-neutral-600 mb-2">You need to see a dermatologist for a skin condition.</p>
        <p class="text-green-700"><strong>Outcome:</strong> Get referral from GP. Specialist visit covered by ÖGK. May have short wait for appointment, but no cost. Private specialists charge more but no wait.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 3: Emergency Room Visit</h4>
        <p class="text-neutral-600 mb-2">You injure yourself and need emergency treatment.</p>
        <p class="text-green-700"><strong>Outcome:</strong> Go to any public hospital. Show e-card. Treatment is covered—no direct payment needed. Austrian ER care is efficient and high-quality.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 4: Dental Cleaning</h4>
        <p class="text-neutral-600 mb-2">You want a routine dental checkup and cleaning.</p>
        <p class="text-green-700"><strong>Outcome:</strong> Basic dental (checkups, fillings) is covered by ÖGK with small copays. Annual cleaning covered. Cosmetic dental and orthodontics not covered.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 5: Hospital Stay</h4>
        <p class="text-neutral-600 mb-2">You need surgery and a week in hospital.</p>
        <p class="text-green-700"><strong>Outcome:</strong> ÖGK covers hospitalization fully. You'll be in a general ward (4-6 bed room typically). Small daily copay (~€10/day). Private rooms require supplementary insurance.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Scenario 6: Trip to Germany, Get Sick</h4>
        <p class="text-neutral-600 mb-2">You travel to Germany and need medical care.</p>
        <p class="text-green-700"><strong>Outcome:</strong> ÖGK provides EU coverage via EHIC. Emergency care in Germany covered. Keep receipts for reimbursement. Works throughout EU/EEA.</p>
      </div>
    </div>
  </section>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-4">
      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">1</div>
        <div>
          <h4 class="font-semibold text-red-900">Missing the 3-Day Meldezettel Deadline</h4>
          <p class="text-red-700">You MUST register your residence within 3 days of moving in. This is strictly enforced in Austria. Go to Meldeamt with passport and rental contract immediately after arrival.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">2</div>
        <div>
          <h4 class="font-semibold text-red-900">Choosing Expensive Private Insurance</h4>
          <p class="text-red-700">ÖGK student self-insurance (~€70/month) offers better coverage than most private plans at lower cost. Unless you specifically need private hospital rooms, ÖGK is the smart choice.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">3</div>
        <div>
          <h4 class="font-semibold text-red-900">Underestimating German Language Needs</h4>
          <p class="text-red-700">Most bachelor's programs require German B2-C1. Even English master's programs benefit from German for daily life. Start learning before arrival—it greatly improves your experience.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">4</div>
        <div>
          <h4 class="font-semibold text-red-900">Delaying Residence Permit Application</h4>
          <p class="text-red-700">Apply for your residence permit soon after arrival. Processing takes 1-2 months. Don't wait until your visa is about to expire. MA 35 in Vienna can be busy.</p>
        </div>
      </div>

      <div class="flex gap-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div class="text-red-600 font-bold">5</div>
        <div>
          <h4 class="font-semibold text-red-900">Working More Than 20 Hours/Week</h4>
          <p class="text-red-700">Students can work max 20 hours/week (10 for language course students). Exceeding this can jeopardize your residence permit. Keep track of your hours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Healthcare in Austria -->
  <section id="healthcare" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Healthcare in Austria</h2>

    <p class="mb-4">
      Austria has excellent healthcare with universal coverage. The ÖGK system provides comprehensive care through a network of public hospitals and contracted doctors. Quality is high, and with ÖGK student insurance, your costs are minimal.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">What ÖGK Covers</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>✓ GP and specialist visits</li>
          <li>✓ Hospital stays (general ward)</li>
          <li>✓ Surgery and procedures</li>
          <li>✓ Prescriptions (small copay)</li>
          <li>✓ Basic dental care</li>
          <li>✓ Mental health services</li>
          <li>✓ Maternity care</li>
          <li>✓ EU coverage via EHIC</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">What ÖGK Doesn't Cover</h4>
        <ul class="text-sm space-y-1 text-neutral-700">
          <li>✗ Private hospital rooms</li>
          <li>✗ Chief physician treatment</li>
          <li>✗ Cosmetic procedures</li>
          <li>✗ Some alternative medicine</li>
          <li>✗ Orthodontics (mostly)</li>
          <li>✗ Non-EU travel coverage</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>e-card System:</strong> After enrolling in ÖGK, you receive an e-card (electronic health card). Present this at any doctor or hospital for cashless treatment. It's simple and efficient.
      </p>
    </div>
  </section>

  <!-- Section: FAQ -->
  <section id="faq" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Frequently Asked Questions</h2>

    <div class="space-y-4">
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Is health insurance mandatory in Austria?</h4>
        <p class="text-neutral-600">Yes, you need health insurance to get a residence permit. The best option is ÖGK student self-insurance (~€70/month) which gives full public healthcare access. EU students can use EHIC initially, then switch to ÖGK. Private insurance is also accepted.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">How much does ÖGK student insurance cost?</h4>
        <p class="text-neutral-600">Approximately €70/month for the student self-insurance scheme (Selbstversicherung für Studierende). This covers comprehensive healthcare including GP, specialists, hospital, prescriptions, and basic dental. One of the best value student insurance options in Europe.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Can I work while studying in Austria?</h4>
        <p class="text-neutral-600">Yes. Non-EU students can work up to 20 hours/week (10 hrs/week for language course students). No separate work permit needed—it's included in your residence permit. Summer jobs and internships have different rules.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Is tuition free in Austria?</h4>
        <p class="text-neutral-600">For EU/EEA students: essentially yes (only ~€20 student union fee). For non-EU students: €726.72/semester at public universities. Much more affordable than UK or US. Some programs charge higher fees.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Can I stay after graduation?</h4>
        <p class="text-neutral-600">Yes. Graduates can apply for "Rot-Weiß-Rot Karte" (job seeker permit) for 12 months. If you find qualifying employment, you can stay long-term. Austria actively recruits skilled graduates in shortage occupations.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold mb-2">Do I need to speak German?</h4>
        <p class="text-neutral-600">For most bachelor's programs: yes, German B2-C1 required. Master's programs increasingly offer English tracks. Daily life in Vienna is manageable with English, but German greatly improves your experience and job prospects.</p>
      </div>
    </div>
  </section>

  <!-- Section: Final Verdict -->
