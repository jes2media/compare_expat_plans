---
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', label: 'Overview' },
  { id: 'quick-decision', label: 'Quick Decision Guide' },
  { id: 'requirements', label: 'Official Requirements' },
  { id: 'insurance-requirements', label: 'Insurance Requirements' },
  { id: 'recommended-providers', label: 'Recommended Providers' },
  { id: 'costs', label: 'Costs Breakdown' },
  { id: 'application-timeline', label: 'Application Timeline' },
  { id: 'scenarios', label: 'Real-World Scenarios' },
  { id: 'common-mistakes', label: 'Common Mistakes' },
  { id: 'healthcare-access', label: 'Healthcare Access' },
  { id: 'faqs', label: 'FAQs' },
  { id: 'verdict', label: 'Final Verdict' },
];

const relatedLinks = [
  { href: '/visas/student-visa/in/singapore', label: 'Singapore Student Visa' },
  { href: '/visas/student-visa/in/thailand', label: 'Thailand Student Visa' },
  { href: '/visas/student-visa/in/taiwan', label: 'Taiwan Student Visa' },
  { href: '/best/expat-health-insurance', label: 'Compare Expat Insurance' },
  { href: '/insurance-for/students-abroad', label: 'Student Insurance Guide' },
];

const requirementsColumns = [
  { key: 'requirement', header: 'Requirement' },
  { key: 'details', header: 'Details' },
];

const requirementsRows = [
  { requirement: 'University Acceptance', details: 'Offer from EMGS-approved Malaysian institution' },
  { requirement: 'Financial Proof', details: 'RM15,000-20,000 (~$3,200-4,300 USD) proof of funds' },
  { requirement: 'Medical Examination', details: 'Health screening required for Student Pass' },
  { requirement: 'Passport Validity', details: '18+ months validity recommended' },
  { requirement: 'Age Requirement', details: '18-45 years (varies by institution type)' },
  { requirement: 'EMGS Fee', details: '~RM1,860 (~$400 USD) processing fee' },
];

const insuranceColumns = [
  { key: 'aspect', header: 'Insurance Aspect' },
  { key: 'requirement', header: 'Requirement' },
];

const insuranceRows = [
  { aspect: 'Mandatory', requirement: 'Yes - required for Student Pass approval' },
  { aspect: 'Provider Options', requirement: 'Institution-arranged or approved private insurers' },
  { aspect: 'Typical Cost', requirement: 'RM500-1,500/year (~$110-325 USD)' },
  { aspect: 'Public Healthcare', requirement: 'Not subsidized for international students' },
  { aspect: 'Private Healthcare', requirement: 'Very affordable even without insurance' },
  { aspect: 'Coverage Needed', requirement: 'Comprehensive medical coverage for visa' },
];

const providersColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'monthly', header: 'Monthly Cost' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'bestFor', header: 'Best For' },
];

const providersRows = [
  { provider: 'Institution Plan', monthly: 'RM40-125', coverage: 'Basic to comprehensive', bestFor: 'Convenience, meets visa requirements' },
  { provider: 'Allianz Malaysia', monthly: 'RM60-150', coverage: 'Comprehensive', bestFor: 'Reliable local provider' },
  { provider: 'AXA Malaysia', monthly: 'RM50-120', coverage: 'Comprehensive', bestFor: 'Good network, reasonable prices' },
  { provider: 'SafetyWing', monthly: '~$56', coverage: '$250,000', bestFor: 'International coverage, travel included' },
];

const costsColumns = [
  { key: 'item', header: 'Cost Item' },
  { key: 'amount', header: 'Amount' },
  { key: 'notes', header: 'Notes' },
];

const costsRows = [
  { item: 'EMGS Processing Fee', amount: '~RM1,860 (~$400)', notes: 'One-time Student Pass fee' },
  { item: 'Health Insurance', amount: 'RM500-1,500/year', notes: '~$110-325 USD annually' },
  { item: 'Tuition (Public)', amount: 'RM8,000-15,000/year', notes: '~$1,700-3,200 USD' },
  { item: 'Tuition (Private)', amount: 'RM15,000-40,000/year', notes: '~$3,200-8,600 USD' },
  { item: 'Living Costs', amount: 'RM1,500-2,500/month', notes: '~$320-540 USD' },
  { item: 'Accommodation', amount: 'RM400-1,500/month', notes: 'Dorm RM400-700, private RM800-1,500' },
  { item: 'Food', amount: 'RM400-800/month', notes: '~$85-170 USD (street food very cheap)' },
];

const timelineColumns = [
  { key: 'step', header: 'Step' },
  { key: 'duration', header: 'Duration' },
  { key: 'details', header: 'Details' },
];

const timelineRows = [
  { step: '1. University Application', duration: '2-4 months before', details: 'Apply to EMGS-approved institution' },
  { step: '2. Receive Offer', duration: '2-4 weeks', details: 'Conditional or unconditional offer' },
  { step: '3. EMGS Submission', duration: 'Institution handles', details: 'University submits your application' },
  { step: '4. Medical Exam', duration: '1-2 weeks', details: 'Complete health screening' },
  { step: '5. VAL Issued', duration: '2-4 weeks', details: 'Visa Approval Letter from EMGS' },
  { step: '6. SEV Collection', duration: '1-2 weeks', details: 'Get Single Entry Visa at Malaysian embassy' },
  { step: '7. Arrival + Screening', duration: 'On arrival', details: 'Immigration screening, Student Pass issued' },
];
---

<PageShell
  title="Malaysia Student Pass Insurance Requirements 2025 | Study in Malaysia Guide"
  description="Complete guide to Malaysia Student Pass (student visa) and health insurance requirements. Very affordable education and living costs with English-taught programs."
  headline="Malaysia Student Pass & Insurance Guide"
  subheadline="World-class education at Asian prices with English-taught programs"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/visas/student-visa-hero-bg.png"
>
  <!-- Overview Section -->
  <section id="overview" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Overview</h2>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h3 class="text-lg font-semibold text-primary-900 mb-4">Quick Facts: Malaysia Student Pass</h3>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div><strong>Visa Type:</strong> Student Pass (via EMGS)</div>
        <div><strong>Duration:</strong> 1 year (renewable annually)</div>
        <div><strong>Processing Time:</strong> 2-4 weeks via EMGS</div>
        <div><strong>EMGS Fee:</strong> ~RM1,860 (~$400 USD)</div>
        <div><strong>Work Allowed:</strong> During semester breaks only (20 hrs/week)</div>
        <div><strong>Insurance:</strong> Required for Student Pass</div>
        <div><strong>Language:</strong> Many programs in English</div>
        <div><strong>Living Cost:</strong> $320-540/month (very affordable)</div>
      </div>
    </div>

    <p class="text-lg text-neutral-700 mb-4">
      Malaysia has emerged as a major education hub, hosting branch campuses of renowned universities like Monash, Nottingham, and Heriot-Watt. With competitive tuition, very affordable living costs, and programs taught in English, Malaysia offers Western-quality education at a fraction of the price.
    </p>

    <p class="text-neutral-600 mb-4">
      The multicultural environment—Malay, Chinese, Indian, and international communities—creates a unique experience. English is widely spoken, making daily life easy for international students. Malaysia's strategic location also makes it a gateway to explore Southeast Asia.
    </p>

    <p class="text-neutral-600">
      Healthcare in Malaysia is excellent and very affordable by global standards. Private hospitals are modern and staffed by doctors trained in UK, Australia, and other top countries. While international students don't get subsidized public healthcare, private care is reasonably priced even without insurance.
    </p>
  </section>

  <!-- Quick Decision Guide -->
  <section id="quick-decision" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-green-900 mb-4">Malaysia is a Great Fit If You...</h3>
        <ul class="space-y-2 text-green-800">
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Want affordable English-taught programs</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Value low living costs ($320-540/month)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Enjoy multicultural environments and amazing food</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Want a gateway to explore Southeast Asia</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-1">✓</span>
            <span>Prefer tropical climate year-round</span>
          </li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-amber-900 mb-4">Consider Alternatives If You...</h3>
        <ul class="space-y-2 text-amber-800">
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Need to work during the semester (only breaks allowed)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Prefer a more liberal social environment</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Want clear post-graduation work pathways</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-600 mt-1">→</span>
            <span>Can't handle hot, humid tropical weather</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Official Requirements -->
  <section id="requirements" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Official Requirements</h2>

    <p class="text-neutral-600 mb-6">
      Malaysia's Student Pass is managed through EMGS (Education Malaysia Global Services). You cannot apply directly—your institution handles the application process.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Important:</strong> All Student Pass applications go through EMGS via your institution. You cannot apply directly. Choose an EMGS-approved university and they'll guide you through the process.
      </p>
    </div>
  </section>

  <!-- Insurance Requirements -->
  <section id="insurance-requirements" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Insurance Requirements</h2>

    <p class="text-neutral-600 mb-6">
      Health insurance is required for Student Pass approval. Many institutions include basic insurance in their fees, or you can arrange your own coverage through approved providers.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
      <h4 class="font-semibold text-green-900 mb-2">Malaysia Healthcare Costs (Without Insurance)</h4>
      <p class="text-green-800">
        Even without insurance, Malaysian private healthcare is very affordable: GP visit RM50-100 (~$11-22), specialist RM100-300 (~$22-65). Insurance is required for the visa and protects against major expenses, but routine care won't break the bank.
      </p>
    </div>

    <div class="mt-4 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>No Public Healthcare Subsidy:</strong> International students don't qualify for Malaysia's subsidized public healthcare. You'll pay full price at public facilities or use private hospitals. Insurance is essential for major medical events.
      </p>
    </div>
  </section>

  <!-- Recommended Providers -->
  <section id="recommended-providers" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Recommended Insurance Providers</h2>

    <p class="text-neutral-600 mb-6">
      Most students use institution-arranged insurance for convenience. International providers are also accepted if they meet visa requirements.
    </p>

    <ComparisonTable columns={providersColumns} rows={providersRows} />

    <div class="mt-6 grid md:grid-cols-2 gap-4">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Easiest Option</h4>
        <p class="text-neutral-600 text-sm">
          Use your institution's insurance plan. It's included in fees at many universities, guaranteed to meet visa requirements, and handles claims locally. Simple and hassle-free.
        </p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">For Travel Coverage</h4>
        <p class="text-neutral-600 text-sm">
          If you plan to travel frequently around Southeast Asia, SafetyWing or Cigna Global provides coverage beyond Malaysia. Verify it meets EMGS requirements before relying on it.
        </p>
      </div>
    </div>
  </section>

  <CTABox
    title="Compare Student Insurance for Malaysia"
    description="Find coverage that meets Student Pass requirements. Malaysian healthcare is affordable, but insurance is required for your visa."
    buttonText="Compare Plans"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <!-- Costs Breakdown -->
  <section id="costs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Costs Breakdown</h2>

    <p class="text-neutral-600 mb-6">
      Malaysia offers exceptional value—Western-quality education at Asian prices. Here's what you can expect.
    </p>

    <ComparisonTable columns={costsColumns} rows={costsRows} />

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">City Cost Comparison</h4>
      <ul class="text-blue-800 text-sm space-y-1">
        <li><strong>Kuala Lumpur:</strong> Most expensive (RM2,000-3,000/month, ~$430-650)</li>
        <li><strong>Penang:</strong> Mid-range (RM1,500-2,500/month, ~$320-540)</li>
        <li><strong>Johor Bahru:</strong> Affordable (RM1,200-2,000/month, ~$260-430)</li>
        <li><strong>Other cities:</strong> Budget-friendly (RM1,000-1,800/month)</li>
      </ul>
    </div>

    <div class="mt-4 bg-green-50 border border-green-200 rounded-lg p-4">
      <h4 class="font-semibold text-green-900 mb-2">Why Malaysia is Exceptional Value</h4>
      <p class="text-green-800 text-sm">
        International branch campuses (Monash, Nottingham) cost RM30,000-60,000/year (~$6,500-13,000)—a fraction of their home country fees. Local private universities: RM15,000-40,000/year. Combined with $320-540/month living costs, total annual expenses can be under $10,000 for quality education.
      </p>
    </div>
  </section>

  <!-- Application Timeline -->
  <section id="application-timeline" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Application Timeline</h2>

    <p class="text-neutral-600 mb-6">
      The Student Pass process is centralized through EMGS. Your institution handles the application—you provide documents and complete the medical exam.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>EMGS Process:</strong> You cannot apply for a Student Pass directly. Your institution submits the application through EMGS. Choose an EMGS-approved university and follow their guidance. Track your application at emgs.com.my.
      </p>
    </div>
  </section>

  <!-- Real-World Scenarios -->
  <section id="scenarios" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Real-World Scenarios</h2>

    <p class="text-neutral-600 mb-6">
      Here's how healthcare works in common situations for students in Malaysia.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">GP Visit (Private Clinic)</h4>
        <p class="text-neutral-600 text-sm mb-2">You have a fever and need to see a doctor.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Walk into any private clinic. Cost: RM50-100 (~$11-22) including medication. No appointment needed. Quick and efficient.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Private Hospital Emergency</h4>
        <p class="text-neutral-600 text-sm mb-2">You break your arm playing sports.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Go to private hospital ER. X-ray + treatment: RM500-1,500 (~$110-325). Insurance covers most or all. Excellent care, English-speaking staff.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Specialist Consultation</h4>
        <p class="text-neutral-600 text-sm mb-2">You need to see a dermatologist.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Private specialist: RM100-300 (~$22-65). Can usually get appointment within a week. Many doctors UK/Australia trained.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Dental Cleaning</h4>
        <p class="text-neutral-600 text-sm mb-2">You want a routine dental checkup.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Dental cleaning: RM80-150 (~$17-32). Check if your insurance includes dental. Even without, very affordable compared to Western countries.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Weekend Trip to Thailand</h4>
        <p class="text-neutral-600 text-sm mb-2">You visit Bangkok for the weekend and get food poisoning.</p>
        <p class="text-amber-700 text-sm"><strong>Outcome:</strong> Check if your insurance covers travel. Institution plans often don't. International insurers (SafetyWing) cover you. Without coverage, pay Thai prices (still affordable).</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Prescription Medication</h4>
        <p class="text-neutral-600 text-sm mb-2">You need regular medication for allergies.</p>
        <p class="text-green-700 text-sm"><strong>Outcome:</strong> Medications very affordable in Malaysia. Common drugs: RM10-50 (~$2-11). Pharmacies everywhere. No prescription needed for many basic medications.</p>
      </div>
    </div>
  </section>

  <!-- Common Mistakes -->
  <section id="common-mistakes" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Common Mistakes to Avoid</h2>

    <div class="space-y-4">
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Trying to Apply for Student Pass Directly</h4>
        <p class="text-red-800">You cannot apply to EMGS yourself. All Student Pass applications must go through your institution. Choose an EMGS-approved university and they'll handle the process.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Passport Validity Too Short</h4>
        <p class="text-red-800">Malaysia recommends 18+ months passport validity for Student Pass. If your passport expires mid-studies, you'll face complications. Renew before applying if needed.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Working During the Semester</h4>
        <p class="text-red-800">Student Pass only allows work during semester breaks (not during term), limited to 20 hours/week in approved sectors. Working outside these rules violates your visa conditions.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Delaying Medical Examination</h4>
        <p class="text-red-800">The medical exam is required before your Student Pass is approved. Schedule it promptly after starting the EMGS process. Delays here delay your entire application.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h4 class="font-semibold text-red-900 mb-2">❌ Assuming Public Healthcare is Free</h4>
        <p class="text-red-800">International students don't get subsidized public healthcare in Malaysia. You pay full price at public facilities or use private hospitals. Insurance is important for major medical events.</p>
      </div>
    </div>
  </section>

  <!-- Healthcare Access -->
  <section id="healthcare-access" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Healthcare System Access</h2>

    <p class="text-neutral-600 mb-6">
      Malaysia has excellent healthcare, especially in the private sector. Many doctors trained in UK, Australia, or the US. Private hospitals are modern, efficient, and affordable by global standards.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>GP visit:</strong> RM50-100 (~$11-22)</li>
          <li>• <strong>Specialist:</strong> RM100-300 (~$22-65)</li>
          <li>• <strong>Major hospitals:</strong> Gleneagles, Pantai, Prince Court</li>
          <li>• <strong>Quality:</strong> Excellent, English-speaking staff</li>
          <li>• <strong>Wait times:</strong> Short, appointments easy</li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>Access:</strong> Available but no subsidy for internationals</li>
          <li>• <strong>Cost:</strong> Full price (still cheaper than private)</li>
          <li>• <strong>Wait times:</strong> Can be longer</li>
          <li>• <strong>Quality:</strong> Good but less comfortable</li>
          <li>• <strong>Use for:</strong> Complex cases, budget option</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h4 class="font-semibold text-blue-900 mb-2">Healthcare Strategy</h4>
      <p class="text-blue-800 text-sm">
        Use institution insurance for visa compliance and major medical events. For routine care (minor illness, checkups), private clinics are affordable even out-of-pocket. Malaysia is a medical tourism destination—quality is high and prices are low.
      </p>
    </div>
  </section>

  <CTABox
    title="Need Insurance for Malaysia Student Pass?"
    description="Compare options that meet EMGS requirements. Malaysian healthcare is affordable, but insurance protects against major expenses."
    buttonText="View Insurance Comparison"
    buttonHref="/go/cigna-global"
  />

  <!-- FAQs -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Frequently Asked Questions</h2>

    <div class="space-y-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">What is EMGS and how does it work?</h4>
        <p class="text-neutral-600">EMGS (Education Malaysia Global Services) is the government agency handling all international student visas. You cannot apply directly—your institution submits your application through EMGS. Processing typically takes 2-4 weeks. Track status at emgs.com.my.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Can I work while studying in Malaysia?</h4>
        <p class="text-neutral-600">Limited. You can only work during semester breaks (not during term), maximum 20 hours/week, in approved sectors (restaurants, hotels, retail, gas stations). Many students focus on studies and rely on savings or sponsorship.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Are courses taught in English?</h4>
        <p class="text-neutral-600">Many are, especially at private universities and international branch campuses (Monash, Nottingham, Heriot-Watt). Public universities may use Malay for some programs. English proficiency (IELTS/TOEFL) required for English programs.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">How affordable is Malaysia really?</h4>
        <p class="text-neutral-600">Very affordable. Monthly budget: $320-540 covers rent, food, transport comfortably. Street food meal: $1-3. Rent: $85-200 for a room. International branch campus degrees cost $6,500-13,000/year—a fraction of UK/Australia prices for the same qualification.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Is Malaysian healthcare good?</h4>
        <p class="text-neutral-600">Yes, especially private healthcare. Malaysia is a medical tourism destination—people fly in for treatment. Many doctors trained in UK/Australia. Private hospitals are modern, English-speaking, and affordable. GP visit: $11-22. Specialist: $22-65.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-2">Can I stay after graduation?</h4>
        <p class="text-neutral-600">Options are more limited than some countries. You can apply for Employment Pass if you find work, but it's employer-driven. Some transition to MM2H (Malaysia My Second Home) if eligible. Malaysia is improving post-study pathways but they're not as clear as UK/Canada.</p>
      </div>
    </div>
  </section>

  <!-- Final Verdict -->
  <section id="verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 mb-6">Final Verdict</h2>

    <div class="bg-gradient-to-r from-primary-50 to-primary-100 border border-primary-200 rounded-lg p-6">
      <p class="text-lg text-primary-900 mb-4">
        Malaysia offers exceptional value: Western-quality education (including branch campuses of top universities) at Asian prices, English-taught programs, and very affordable living costs. Healthcare is excellent and reasonably priced even without insurance.
      </p>

      <p class="text-primary-800 mb-4">
        The main limitations are restricted work rights during studies and less clear post-graduation pathways compared to UK, Canada, or Australia. However, for pure value—quality education at low cost—Malaysia is hard to beat.
      </p>

      <p class="text-primary-800 mb-4">
        <strong>Our recommendation:</strong> Use your institution's insurance plan for simplicity—it meets visa requirements and handles claims locally. For routine care, Malaysian clinics are affordable even out-of-pocket. If you travel frequently around Southeast Asia, consider an international policy as supplement.
      </p>

      <div class="mt-4 pt-4 border-t border-primary-200">
        <p class="text-sm text-primary-700">
          <strong>Bottom Line:</strong> Malaysia is ideal for students prioritizing value: quality English-taught education, low living costs, excellent healthcare, and a multicultural environment. The $10,000-15,000/year total cost (including tuition) for a internationally-recognized degree is remarkable.
        </p>
      </div>
    </div>
  </section>

