---
/**
 * UK Student Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in the UK", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "UK Health Insurance Guide", href: "/countries/uk/insurance" },
  { title: "Insurance for Students Abroad", href: "/insurance-for/students" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "CAS Number", details: "Confirmation of Acceptance for Studies", evidence: "CAS reference number from licensed sponsor" },
  { requirement: "English Language", details: "IELTS 5.5-7.0+ depending on course level", evidence: "Test certificate (IELTS, TOEFL, PTE)" },
  { requirement: "Financial Proof", details: "£1,334/month (London) or £1,023/month (outside)", evidence: "Bank statements for 28+ consecutive days" },
  { requirement: "Tuition Funds", details: "Course fees for first year (or full amount)", evidence: "Bank statements or sponsor letter" },
  { requirement: "Valid Passport", details: "Valid for duration of studies", evidence: "Passport copy" },
  { requirement: "TB Test", details: "Required from certain countries", evidence: "TB test certificate (if applicable)" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "ihs", header: "IHS (NHS Access)" },
  { key: "private", header: "Private Insurance" },
];

const insuranceRows = [
  { feature: "Cost", ihs: "£776/year (discounted student rate)", private: "£50-150/month" },
  { feature: "GP Access", ihs: "Free (registration required)", private: "Private GP, no wait" },
  { feature: "Hospital Care", ihs: "Free (may have waits)", private: "Private hospitals" },
  { feature: "Mental Health", ihs: "NHS services (long waits)", private: "Faster access to therapy" },
  { feature: "Dental", ihs: "Subsidized (not free)", private: "Usually included" },
  { feature: "Prescriptions", ihs: "£9.90/item (free in Scotland/Wales)", private: "Usually covered" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (Students)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "£1,000,000+", price: "£80-150", strengths: "Comprehensive, mental health" },
  { provider: "BUPA Global", coverage: "£500,000+", price: "£90-160", strengths: "UK network, no wait times" },
  { provider: "Allianz Care", coverage: "£500,000+", price: "£70-130", strengths: "Good value, EU coverage" },
  { provider: "IMG Global", coverage: "£500,000+", price: "£50-100", strengths: "Budget-friendly students" },
  { provider: "SafetyWing", coverage: "$250,000", price: "£45-85", strengths: "Affordable, remote students" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (GBP)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "£490", notes: "Standard fee (outside UK)" },
  { item: "Immigration Health Surcharge", amount: "£776/year", notes: "Discounted student rate" },
  { item: "Priority Processing", amount: "£500", notes: "Optional, 5 working days" },
  { item: "Super Priority", amount: "£1,000", notes: "Optional, next working day" },
  { item: "TB Test (if required)", amount: "£50-150", notes: "From approved clinic" },
  { item: "English Test (IELTS)", amount: "£170-210", notes: "Pre-application" },
  { item: "Biometric Appointment", amount: "£0-80", notes: "Varies by location" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Receive university offer", duration: "Varies", location: "University/UCAS" },
  { step: "Meet conditions, get CAS", duration: "1-4 weeks", location: "University" },
  { step: "Gather financial documents", duration: "1-2 weeks", location: "Your bank" },
  { step: "Complete online application", duration: "1-2 hours", location: "gov.uk" },
  { step: "Pay fees (visa + IHS)", duration: "Same day", location: "Online" },
  { step: "Biometric appointment", duration: "1 day", location: "Visa center" },
  { step: "Processing", duration: "3-8 weeks", location: "UKVI review" },
  { step: "Receive decision", duration: "Email", location: "Online" },
  { step: "Collect BRP card", duration: "Within 10 days of arrival", location: "Post office or uni" },
];
---

<PageShell
  title="UK Student Visa 2026: Requirements, Insurance & Application Guide"
  description="Complete guide to the UK Student Visa. Requirements, Immigration Health Surcharge, NHS access, financial proof, and step-by-step application process for international students."
  headline="UK Student Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about studying in the UK—visa requirements, NHS healthcare access via the Immigration Health Surcharge, financial proof, and the complete application process."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Student Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/visas/student-visa-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official UKVI Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      NHS Access Included
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The UK remains one of the world's top destinations for international students, with over 680,000 studying at British universities. The UK Student Visa (formerly Tier 4) provides access to world-renowned institutions like Oxford, Cambridge, Imperial, and UCL, along with full NHS healthcare access through the Immigration Health Surcharge.
    </p>

    <p class="mb-4">
      Unlike many countries where student health insurance is separate and complicated, the UK system is straightforward: pay the Immigration Health Surcharge (IHS) with your visa application, and you get the same NHS access as British residents. This makes healthcare planning simpler, though some students still opt for private insurance to avoid NHS wait times.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: UK Student Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Student Visa (replaced Tier 4 in 2020)</li>
        <li>• <strong>Healthcare access:</strong> Full NHS via Immigration Health Surcharge (£776/year)</li>
        <li>• <strong>Work rights:</strong> 20 hours/week during term, full-time during holidays</li>
        <li>• <strong>Duration:</strong> Length of course + wind-down period</li>
        <li>• <strong>Post-study work:</strong> Graduate Route (2-3 years) available after completion</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Study in the UK?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>World-class universities:</strong> 4 of the global top 10, 17 in the top 100</li>
      <li><strong>Shorter degrees:</strong> 3-year undergraduate, 1-year master's (vs. 4/2 in US)</li>
      <li><strong>NHS healthcare:</strong> Full access with IHS payment—no separate insurance needed</li>
      <li><strong>Work rights:</strong> 20 hours/week during term helps offset costs</li>
      <li><strong>Graduate Route:</strong> Stay 2-3 years after graduation to work</li>
      <li><strong>English language:</strong> No translation barriers</li>
      <li><strong>Cultural hub:</strong> London, Edinburgh, Manchester—diverse, vibrant cities</li>
      <li><strong>Global recognition:</strong> UK degrees respected worldwide</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">UK is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want a globally recognized degree</li>
          <li>✓ You prefer shorter degree programs</li>
          <li>✓ You want straightforward healthcare (NHS)</li>
          <li>✓ You want to work after graduation (Graduate Route)</li>
          <li>✓ You value English-language instruction</li>
          <li>✓ You want part-time work rights during studies</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Budget is your primary concern (Germany/France are cheaper)</li>
          <li>• You want to stay long-term (Canada/Australia have easier PR)</li>
          <li>• You prefer warmer climate</li>
          <li>• You want free/low tuition (consider Germany, Norway)</li>
          <li>• You need immediate family to join you easily</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Graduate Route advantage:</strong> After completing your degree, you can apply for the Graduate Route visa—2 years for bachelor's/master's, 3 years for PhD. This lets you work any job at any skill level while you gain UK experience and potentially transition to a Skilled Worker visa.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The UK Student Visa requires a CAS (Confirmation of Acceptance for Studies) from a licensed sponsor institution, proof of English language ability, and evidence you can support yourself financially.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Financial Requirements</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Studying in London</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Living costs:</strong> £1,334/month</li>
          <li>• <strong>9-month course:</strong> £12,006</li>
          <li>• <strong>Plus:</strong> First year tuition fees</li>
          <li>• <strong>Total example (1-year MA):</strong> £27,000+</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Outside London</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Living costs:</strong> £1,023/month</li>
          <li>• <strong>9-month course:</strong> £9,207</li>
          <li>• <strong>Plus:</strong> First year tuition fees</li>
          <li>• <strong>Total example (1-year MA):</strong> £22,000+</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>28-day rule:</strong> Your bank statements must show the required funds held for at least 28 consecutive days ending no more than 31 days before your application. This is strictly enforced—gaps or dips below the threshold can result in rejection.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">English Language Requirements</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Foundation/pre-sessional:</strong> IELTS 4.0-5.5 (varies by program)</li>
      <li><strong>Undergraduate:</strong> IELTS 6.0-6.5 (most courses)</li>
      <li><strong>Master's/PhD:</strong> IELTS 6.5-7.0+ (competitive programs higher)</li>
      <li><strong>Accepted tests:</strong> IELTS Academic, TOEFL iBT, PTE Academic, Cambridge</li>
      <li><strong>Exemptions:</strong> Nationals of majority English-speaking countries; degrees taught in English</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">NHS Access Through Immigration Health Surcharge</h3>
      <p class="text-green-800">
        Unlike most countries, the UK doesn't require separate health insurance for students. The Immigration Health Surcharge (IHS) of £776/year gives you full NHS access—the same healthcare available to British residents. This is mandatory and paid with your visa application.
      </p>
    </div>

    <p class="mb-4">
      The IHS covers GP visits, hospital care, and most treatments. However, dental care is only partially covered (subsidized, not free), prescriptions cost £9.90/item in England (free in Scotland, Wales, and Northern Ireland), and NHS mental health services often have long wait times.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">NHS vs. Private Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">When to Consider Private Insurance</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">NHS Only is Usually Fine If:</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ You're generally healthy</li>
          <li>✓ You can wait for non-urgent care</li>
          <li>✓ Budget is a priority</li>
          <li>✓ You're in Scotland/Wales (free prescriptions)</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Add Private Insurance If:</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ You need mental health support (NHS waits are long)</li>
          <li>✓ You have ongoing health conditions</li>
          <li>✓ You want dental coverage</li>
          <li>✓ You prefer faster specialist access</li>
          <li>✓ You travel frequently (UK + home country)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>University health services:</strong> Most UK universities have on-campus health centers that provide free services to students. These can handle routine care and mental health support, often with shorter waits than external NHS services.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need private insurance to supplement NHS coverage?"
    description="Compare plans from top providers for students studying in the UK."
    buttonText="Compare Student Insurance Plans"
    buttonHref="/get-quotes"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Since you'll have NHS access through IHS, private insurance is optional but valuable for faster care, mental health support, and dental coverage. These providers offer plans suitable for students.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Need</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Mental Health Priority</h4>
        <p class="text-neutral-600">BUPA and Cigna offer the best mental health coverage for students. NHS counseling waits can exceed 6 months—private insurance provides faster access to therapy and psychiatry.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Students</h4>
        <p class="text-neutral-600">SafetyWing and IMG Global offer affordable coverage for healthy students who want a safety net. Good for travel coverage and private GP access without breaking the bank.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Travel During Studies</h4>
        <p class="text-neutral-600">If you'll travel frequently to Europe or home, Allianz Care and Cigna Global provide seamless international coverage. NHS only covers you in the UK.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Cigna Global handles pre-existing conditions better than most. For chronic conditions requiring regular specialist care, private insurance reduces NHS wait times significantly.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The UK Student Visa involves several mandatory fees. The Immigration Health Surcharge is paid upfront for your entire visa duration—for a 3-year undergraduate degree, that's £2,328 in healthcare costs alone.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Total Upfront Visa Costs</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">1-Year Master's</p>
        <p class="text-3xl font-bold text-neutral-900">£1,400</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + 1 year IHS</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">3-Year Undergraduate</p>
        <p class="text-3xl font-bold text-neutral-900">£2,900</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + 3 years IHS</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">4-Year PhD</p>
        <p class="text-3xl font-bold text-neutral-900">£3,600</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + 4 years IHS</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Annual Student Costs</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Tuition (international):</strong> £12,000-38,000/year (varies by course and university)</li>
      <li><strong>London living:</strong> £15,000-20,000/year (room, food, transport, social)</li>
      <li><strong>Other cities:</strong> £10,000-15,000/year (Manchester, Edinburgh, Bristol, etc.)</li>
      <li><strong>Optional private insurance:</strong> £600-1,500/year</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Work rights help:</strong> You can work up to 20 hours/week during term and full-time during holidays. At minimum wage (£11.44/hour for 21+), that's roughly £4,500/year—enough to cover most living cost increases.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The UK Student Visa application is done online through gov.uk. You'll need your CAS from the university, financial evidence, and identity documents. Most applications are decided within 3 weeks, but priority options are available for faster decisions.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Accept University Offer & Receive CAS</h4>
          <p class="text-neutral-600">Once you've met all conditions (grades, English test), your university issues a CAS number. This 14-character code is essential—you can't apply without it. Check CAS details carefully for errors.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Financial Documents</h4>
          <p class="text-neutral-600">Bank statements showing required funds (tuition + living costs) held for 28+ consecutive days. Statement date must be within 31 days of application. If parents are funding you, include relationship evidence.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete Online Application</h4>
          <p class="text-neutral-600">Apply at gov.uk/student-visa. Enter your CAS number, personal details, travel history, and immigration history. Be completely honest—discrepancies can lead to rejection or future visa issues.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Visa Fee and IHS</h4>
          <p class="text-neutral-600">Pay the £490 visa fee and Immigration Health Surcharge (£776/year × course length) online. Keep payment receipts. You can add priority processing (£500) or super priority (£1,000) for faster decisions.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Attend Biometric Appointment</h4>
          <p class="text-neutral-600">Book an appointment at a visa application center to provide fingerprints and photo. Bring your passport and appointment confirmation. Some countries offer "scan and send" for documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Decision</h4>
          <p class="text-neutral-600">Standard processing is 3 weeks from biometrics. Priority is 5 working days, super priority is next working day. You'll receive an email when decided. If approved, your passport gets a vignette (entry sticker).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect BRP Card in UK</h4>
          <p class="text-neutral-600">The passport vignette is valid for 90 days. Once in the UK, collect your Biometric Residence Permit (BRP) within 10 days—usually from your university or a designated post office. This is your ID for the duration of studies.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Earliest application:</strong> You can apply up to 6 months before your course starts. Apply early to avoid stress—visa centers get very busy in July-September.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out for international students in the UK:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
