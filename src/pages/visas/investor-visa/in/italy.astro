---
/**
 * Italy Investor Visa (Visto per Investitori) - Long-form CRO-optimized page
 * Startup, company, bonds, or philanthropic route
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-requirements", text: "Investment Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Italy", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Italy Health Insurance Guide", href: "/countries/italy/insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Italy Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/italy" },
];

const investmentColumns = [
  { key: "option", header: "Investment Route" },
  { key: "minimum", header: "Minimum Amount" },
  { key: "notes", header: "Key Details" },
];

const investmentRows = [
  { option: "Innovative Startup", minimum: "€250,000", notes: "Must be registered in Italian startup registry" },
  { option: "Innovative SME", minimum: "€500,000", notes: "Small/medium enterprise with innovation status" },
  { option: "Italian Company", minimum: "€1,000,000", notes: "Established Italian company (any sector)" },
  { option: "Government Bonds", minimum: "€2,000,000", notes: "Italian sovereign bonds (BTPs), 2-year hold" },
  { option: "Philanthropic Donation", minimum: "€1,000,000", notes: "Cultural, educational, or public interest projects" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "requirement", header: "Visa Requirement" },
  { key: "recommendation", header: "Our Recommendation" },
];

const insuranceRows = [
  { feature: "Coverage Type", requirement: "Health insurance covering Italy", recommendation: "Comprehensive international plan" },
  { feature: "Coverage Area", requirement: "Must cover Italy", recommendation: "Europe-wide or global coverage" },
  { feature: "Coverage Limits", requirement: "€30,000+ medical treatment", recommendation: "€1M+ or unlimited" },
  { feature: "Duration", requirement: "Valid for visa period", recommendation: "Annual renewable policy" },
  { feature: "Hospitalization", requirement: "Required", recommendation: "Full inpatient coverage" },
  { feature: "Repatriation", requirement: "Required for visa", recommendation: "Essential" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€180-450", strengths: "Comprehensive global coverage, large network" },
  { provider: "Allianz Care", type: "International", price: "€150-380", strengths: "Strong EU coverage, competitive pricing" },
  { provider: "BUPA Global", type: "International", price: "€200-500", strengths: "Premium service, mental health parity" },
  { provider: "AXA Global", type: "International", price: "€160-400", strengths: "EU-regulated, strong Italy network" },
  { provider: "Generali Italia", type: "Local Italian", price: "€100-250", strengths: "Extensive local network, Italian-regulated" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€116", notes: "Investor visa type" },
  { item: "Residence Permit (Permesso)", amount: "€100-200", notes: "Upon arrival in Italy" },
  { item: "Legal/Advisory Fees", amount: "€5,000-15,000", notes: "Immigration and investment structuring" },
  { item: "Investment Verification", amount: "€2,000-5,000", notes: "Due diligence and documentation" },
  { item: "Notary Fees (if applicable)", amount: "€1,000-3,000", notes: "For company investments" },
  { item: "Health Insurance", amount: "€150-450/month", notes: "International coverage required" },
  { item: "Codice Fiscale (Tax Code)", amount: "Free", notes: "Required for all transactions" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Pre-approval application to Invest in Italy Committee", duration: "1-2 weeks to prepare", location: "Online/Remote" },
  { step: "Committee evaluation (nulla osta)", duration: "30 days maximum", location: "Italian government" },
  { step: "Receive nulla osta (clearance certificate)", duration: "After approval", location: "Via email" },
  { step: "Apply for investor visa at Italian consulate", duration: "1-2 weeks to prepare", location: "Home country consulate" },
  { step: "Visa processing", duration: "15-30 days", location: "Consulate" },
  { step: "Enter Italy and complete investment", duration: "Within 3 months", location: "Italy" },
  { step: "Apply for residence permit (Permesso di Soggiorno)", duration: "8 days after arrival", location: "Local Questura" },
  { step: "Receive residence permit", duration: "2-4 weeks", location: "Italy" },
];
---

<PageShell
  title="Italy Investor Visa 2026: Investment Options, Insurance & Application Guide"
  description="Complete guide to Italy's Investor Visa (Visto per Investitori). Startup investment from €250,000, company investment €1M, or €2M bonds. Path to Italian and EU citizenship."
  headline="Italy Investor Visa: Investment & Insurance Guide"
  subheadline="The dolce vita through investment—startup from €250,000, company from €1M, or bonds at €2M. Full guide to Italy's investor visa, requirements, and mandatory health insurance."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Investor Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/countries/italy-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Startup Route from €250K
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Path to Italian Citizenship
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Italy's Investor Visa (Visto per Investitori) offers residency through investment in Italian startups, companies, government bonds, or philanthropy. Launched in 2017, it's designed to attract entrepreneurs, investors, and high-net-worth individuals to Italy's economy.
    </p>

    <p class="mb-4">
      Unlike property-based Golden Visas (Greece, Spain), Italy's program focuses on business investment—with the lowest entry point being €250,000 into Italian startups. This makes it attractive for entrepreneurially-minded investors who want to actively participate in Italy's economy rather than just own property.
    </p>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-3">Key Advantage: Startup Route at €250,000</h3>
      <p class="text-green-800">
        Italy offers the lowest entry point among major EU investor programs through its innovative startup route. By investing €250,000 in a registered Italian startup, you gain residence in one of Europe's largest economies—with full work rights, Schengen access, and a path to citizenship. No other major EU country offers investor residence at this level.
      </p>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Italy Investor Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Official name:</strong> Visto per Investitori (Investor Visa)</li>
        <li>• <strong>Minimum investment:</strong> €250,000 (startup) to €2,000,000 (bonds)</li>
        <li>• <strong>Initial visa:</strong> 2 years</li>
        <li>• <strong>Renewal:</strong> 3 years (if investment maintained)</li>
        <li>• <strong>Family included:</strong> Spouse and dependent children</li>
        <li>• <strong>Work rights:</strong> Yes—can work in Italy</li>
        <li>• <strong>Permanent residence:</strong> After 5 years of legal residence</li>
        <li>• <strong>Citizenship:</strong> After 10 years (4 years if EU citizen)</li>
        <li>• <strong>Schengen access:</strong> Free travel in 27 Schengen countries</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Italy's Investor Visa Stands Out</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Key Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Lowest startup entry (€250,000) in major EU</li>
          <li>• Full work rights included</li>
          <li>• Access to Italy's startup ecosystem</li>
          <li>• Path to Italian (EU) citizenship</li>
          <li>• Business investment, not just property</li>
          <li>• Fast pre-approval (30 days max)</li>
          <li>• World-class lifestyle and culture</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Startup investment carries risk</li>
          <li>• No property investment option</li>
          <li>• 10 years to citizenship (longer than Portugal)</li>
          <li>• Italian bureaucracy can be challenging</li>
          <li>• Language helpful for integration</li>
          <li>• Higher thresholds for lower-risk options</li>
          <li>• Must maintain investment 2+ years</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Health insurance requirement:</strong> Private health insurance covering Italy is mandatory for the Investor Visa. You must provide proof of valid coverage at application and maintain it throughout your stay. Italy has an excellent public healthcare system (SSN), but you need private coverage initially and may choose to enroll in SSN once resident.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">The Investor Visa is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>You want to invest in Italian businesses, not just property</li>
          <li>You have €250,000-2,000,000 for business investment</li>
          <li>You're comfortable with startup/business risk</li>
          <li>You want full work rights in Italy</li>
          <li>You're interested in Italian entrepreneurship</li>
          <li>You appreciate Italian lifestyle and culture</li>
          <li>You can commit to 10-year citizenship path</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You prefer property investment (try Greece)</li>
          <li>• You want guaranteed return (bonds require €2M)</li>
          <li>• You want fast citizenship (Portugal = 5 years)</li>
          <li>• You prefer English-speaking country (Malta)</li>
          <li>• You want zero stay requirement (Greece)</li>
          <li>• You're uncomfortable with business risk</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Italy vs. Other EU Investor Programs</h3>

    <div class="grid md:grid-cols-3 gap-4 mb-6">
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Greece Golden Visa</h4>
        <p class="text-neutral-600 text-sm">€250,000 property minimum. Zero stay. Property-based. Lower risk than startup. 7 years to citizenship. No work rights.</p>
      </div>
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Portugal Golden Visa</h4>
        <p class="text-neutral-600 text-sm">€500,000 funds. 7 days/year stay. Fund investment. 5 years to citizenship. No property route. Work rights included.</p>
      </div>
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Spain Golden Visa</h4>
        <p class="text-neutral-600 text-sm">€500,000 property. No stay first 2 years. 10 years to citizenship. Property route still active. Work rights included.</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Italy's unique position:</strong> The €250,000 startup investment is the lowest entry to a major EU economy. For entrepreneurially-minded investors interested in Italy's startup scene (Milan, Rome, Turin), it offers unmatched access. But it requires tolerance for startup risk—this isn't a passive property investment.
      </p>
    </div>
  </section>

  <!-- Section: Investment Requirements -->
  <section id="investment-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Requirements</h2>

    <p class="mb-4">
      Italy's Investor Visa offers five investment routes with different thresholds and risk profiles. Unlike property-based Golden Visas, all options involve business or financial investment in Italy's economy.
    </p>

    <ComparisonTable columns={investmentColumns} rows={investmentRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Innovative Startup Route (€250,000)</h3>

    <p class="mb-4">
      The most accessible route—invest €250,000 in an Italian startup registered in the special registry of innovative startups (Registro delle startup innovative). These companies must meet specific innovation criteria.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Startup Route Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>Lowest entry threshold in major EU (€250,000)</li>
          <li>Access to growing Italian tech ecosystem</li>
          <li>Potential for significant returns</li>
          <li>Active involvement possible</li>
          <li>Milan/Rome startup scenes growing</li>
          <li>Government support for innovation</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Startup Route Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>High risk—startups can fail</li>
          <li>Capital may be illiquid for years</li>
          <li>Must find qualifying startup</li>
          <li>Due diligence essential</li>
          <li>No guaranteed return</li>
          <li>Business knowledge helpful</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Innovative SME Route (€500,000)</h3>

    <p class="mb-4">
      Invest €500,000 in an innovative small or medium enterprise. These are larger than startups but still registered for special innovation status. Lower risk than pure startups but still equity investment.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Italian Company Route (€1,000,000)</h3>

    <p class="mb-4">
      Invest €1,000,000 in any established Italian company. No innovation requirement—can be traditional businesses. More options but higher threshold. Can include family businesses or established SMEs.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Government Bonds Route (€2,000,000)</h3>

    <p class="mb-4">
      Purchase €2,000,000 of Italian government bonds (BTPs—Buoni del Tesoro Poliennali). Must hold for at least 2 years. Lowest risk option but requires four times the capital of startup route.
    </p>

    <div class="border border-neutral-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-neutral-900 mb-3">Government Bonds: Risk vs. Access</h4>
      <ul class="space-y-2 text-neutral-700">
        <li><strong>Pro:</strong> Lowest risk—Italian sovereign debt rated BBB/Baa3</li>
        <li><strong>Pro:</strong> Liquid after 2-year hold period</li>
        <li><strong>Pro:</strong> Interest income (currently 3-4% on 10-year BTPs)</li>
        <li><strong>Con:</strong> Requires €2,000,000 (vs €250,000 startup)</li>
        <li><strong>Con:</strong> Capital could earn more elsewhere</li>
        <li><strong>Con:</strong> Currency risk if you're not EUR-based</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Philanthropic Donation Route (€1,000,000)</h3>

    <p class="mb-4">
      Donate €1,000,000 to cultural, educational, scientific, or public interest projects. This is a donation, not investment—no return expected. Appeals to high-net-worth philanthropists who want Italian residence while supporting causes.
    </p>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Investment must be maintained:</strong> All investment options require maintaining the investment for at least the initial 2-year visa period. For renewals, continued investment (or evidence the startup/company remains active) is expected. Government bonds must be held for the full 2-year minimum.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        Private health insurance covering Italy is required for the Investor Visa application. You must show valid coverage at the consulate and maintain it initially. Once resident, you may be eligible to enroll in Italy's public SSN (Servizio Sanitario Nazionale), but private coverage is needed at minimum for the visa.
      </p>
    </div>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Italian Healthcare Options</h3>

    <p class="mb-4">
      Italy has an excellent public healthcare system (SSN) that residents can access. As an Investor Visa holder, you have options:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Public Healthcare (SSN)</h4>
        <ul class="space-y-2 text-green-800">
          <li>Free or low-cost for residents</li>
          <li>Excellent quality hospitals</li>
          <li>Need "tessera sanitaria" (health card)</li>
          <li>Requires residency registration</li>
          <li>May need to pay contribution if self-employed</li>
          <li>Long waits for non-urgent care</li>
        </ul>
        <p class="text-green-700 text-sm mt-3">Available after establishing residency in Italy</p>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Private Insurance (Required Initially)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>Required for visa application</li>
          <li>Immediate access to care</li>
          <li>Shorter wait times</li>
          <li>Choice of specialists</li>
          <li>English-speaking options</li>
          <li>Covers you during Schengen travel</li>
        </ul>
        <p class="text-blue-700 text-sm mt-3">Mandatory for visa, many keep for convenience</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">What Your Insurance Must Cover</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Mandatory for Visa</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>Medical treatment minimum €30,000</li>
          <li>Hospitalization coverage</li>
          <li>Valid in Italy for visa duration</li>
          <li>Repatriation coverage</li>
          <li>Emergency treatment</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Recommended Additional</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>Europe-wide coverage (Schengen travel)</li>
          <li>Higher limits (€1M+)</li>
          <li>Outpatient care</li>
          <li>Prescription medications</li>
          <li>Specialist consultations</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Long-term strategy:</strong> Many Investor Visa holders maintain private insurance even after SSN eligibility. Private insurance provides faster access, choice of specialists, and covers gaps in public system. If you travel frequently or live part-time outside Italy, international coverage is essential.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for Italy Investor Visa?"
    description="Compare international health insurance plans that meet Italian visa requirements and provide Europe-wide coverage."
    buttonText="Compare Investor Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Italy's Investor Visa, you need coverage that satisfies visa requirements while providing genuine protection. Both international and Italian providers can work, depending on your lifestyle.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Entrepreneur Spending Time Across Europe</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care with Europe zone. Full Schengen coverage for business travel. Direct billing at major European hospitals. Budget €180-400/month depending on age and coverage level.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Relocating Full-Time to Italy</h4>
        <p class="text-neutral-600">Consider Italian insurers like Generali or UniSalute for local focus (€100-250/month). Supplement with travel coverage for trips. Once SSN-eligible, many reduce private coverage to top-up only.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US Investor Wanting US + Italy Coverage</h4>
        <p class="text-neutral-600">Cigna Global or BUPA Global with worldwide zone including USA. Essential if you maintain US business ties or travel there frequently. Budget €350-550/month for comprehensive US-included coverage.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
