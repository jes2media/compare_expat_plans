---
/**
 * Grenada Citizenship by Investment - Long-form CRO-optimized page
 * CBI with US E-2 Treaty access, Spice Isle, unique value proposition
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "us-e2-treaty", text: "US E-2 Treaty Access", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Grenada", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "St. Kitts Investor Visa", href: "/visas/investor-visa/in/st-kitts-and-nevis" },
  { title: "Dominica Investor Visa", href: "/visas/investor-visa/in/dominica" },
  { title: "USA Investor Visa (EB-5)", href: "/visas/investor-visa/in/usa" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const visaRoutesColumns = [
  { key: "program", header: "Investment Route" },
  { key: "investment", header: "Minimum Investment" },
  { key: "timeline", header: "Processing Time" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "National Transformation Fund (NTF)", investment: "$150,000 (single)", timeline: "4-6 months", benefits: "Simplest route, non-refundable" },
  { program: "NTF Family", investment: "$200,000 (family of 4)", timeline: "4-6 months", benefits: "Includes spouse + 2 dependents" },
  { program: "Real Estate Investment", investment: "$220,000 (5-year hold)", timeline: "4-6 months", benefits: "Asset ownership, resellable" },
  { program: "Shares Investment", investment: "$220,000 (5-year hold)", timeline: "4-6 months", benefits: "Hotel shares, income potential" },
];

const insuranceColumns = [
  { key: "situation", header: "Situation" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "recommendation", header: "Recommended Coverage" },
];

const insuranceRows = [
  { situation: "CBI Application", requirement: "Not mandatory", recommendation: "International coverage recommended" },
  { situation: "Residing in Grenada", requirement: "No mandatory insurance", recommendation: "$100,000+ with evacuation" },
  { situation: "US E-2 Application", requirement: "Not required for visa", recommendation: "US coverage for E-2 stay" },
  { situation: "Global Travelers", requirement: "N/A", recommendation: "Worldwide coverage essential" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$300-600", strengths: "Global + US coverage" },
  { provider: "Allianz Care", type: "International", price: "$250-500", strengths: "Worldwide network" },
  { provider: "IMG Global", type: "International", price: "$200-450", strengths: "Flexible, US options" },
  { provider: "GeoBlue", type: "US-focused", price: "$250-400", strengths: "BCBS network for US stay" },
  { provider: "Sagicor", type: "Regional Caribbean", price: "$150-350", strengths: "Caribbean specialist" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "NTF Contribution (Single)", amount: "$150,000", notes: "Non-refundable donation" },
  { item: "NTF Contribution (Couple)", amount: "$200,000", notes: "Main applicant + spouse" },
  { item: "NTF Family (4)", amount: "$200,000", notes: "Couple + 2 children under 18" },
  { item: "NTF Additional Dependent", amount: "$25,000", notes: "Each additional dependent" },
  { item: "Real Estate Minimum", amount: "$220,000", notes: "5-year holding period" },
  { item: "Due Diligence (Main)", amount: "$5,000", notes: "Per main applicant" },
  { item: "Due Diligence (Spouse)", amount: "$5,000", notes: "Per spouse" },
  { item: "Due Diligence (Dependent 17+)", amount: "$5,000", notes: "Per dependent 17 and older" },
  { item: "Government Processing Fee", amount: "$1,500", notes: "Per application" },
  { item: "Legal/Agent Fees", amount: "$15,000-30,000", notes: "Authorized agent required" },
];

const timelineColumns = [
  { key: "stage", header: "Stage" },
  { key: "duration", header: "Duration" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { stage: "Document Preparation", duration: "2-4 weeks", notes: "Gather and apostille documents" },
  { stage: "Application Submission", duration: "1 week", notes: "Via authorized agent" },
  { stage: "Due Diligence", duration: "8-12 weeks", notes: "Thorough background verification" },
  { stage: "Approval in Principle", duration: "Week 10-14", notes: "Conditional approval" },
  { stage: "Investment Payment", duration: "1-2 weeks", notes: "Complete NTF or real estate" },
  { stage: "Citizenship Certificate", duration: "1-2 weeks", notes: "Certificate issued" },
  { stage: "Passport Application", duration: "2-4 weeks", notes: "Passport processing" },
  { stage: "Total", duration: "4-6 months", notes: "Standard timeline" },
