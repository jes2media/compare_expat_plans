const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$300-600", strengths: "Comprehensive coverage, worldwide network" },
  { provider: "Allianz Care", type: "International", price: "$250-500", strengths: "Flexible plans, strong Canada network" },
  { provider: "Manulife", type: "Canadian", price: "$150-350", strengths: "Local insurer, visitor coverage" },
  { provider: "Blue Cross", type: "Canadian", price: "$100-300", strengths: "Affordable, good for waiting period" },
  { provider: "GMS", type: "Canadian", price: "$80-250", strengths: "Budget option, basic coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (CAD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "PR Application Fee", amount: "$2,140", notes: "Principal applicant (2024 fees)" },
  { item: "Biometrics Fee", amount: "$85", notes: "Per person" },
  { item: "Right of PR Fee", amount: "$575", notes: "Paid upon approval" },
  { item: "Medical Exam", amount: "$200-400", notes: "Per person, panel physician" },
  { item: "Language Test (IELTS/TEF)", amount: "$300-400", notes: "Required for Start-Up Visa" },
  { item: "Health Insurance (3 months)", amount: "$600-1,800", notes: "During waiting period" },
  { item: "Legal Fees", amount: "$5,000-25,000", notes: "Immigration lawyer recommended" },
  { item: "Business Plan (Start-Up)", amount: "$2,000-10,000", notes: "Professional preparation" },
