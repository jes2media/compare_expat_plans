  { step: "Secure designated organization support", duration: "2-12 months", location: "Remote/Canada visits" },
  { step: "Receive Letter of Support", duration: "1-4 weeks", location: "From designated org" },
  { step: "Complete language test", duration: "1-3 months", location: "Testing center" },
  { step: "Medical examination", duration: "1-2 weeks", location: "Panel physician" },
  { step: "Submit PR application", duration: "1 day", location: "Online (IRCC)" },
  { step: "Application processing", duration: "12-36 months", location: "Government review" },
  { step: "Receive COPR", duration: "After approval", location: "Visa office" },
  { step: "Land in Canada as PR", duration: "Flexible", location: "Port of entry" },
