---
/**
 * Vanuatu Citizenship by Investment - Long-form CRO-optimized page
 * Fast CBI program, Pacific island paradise, tax haven
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Vanuatu", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "St. Kitts Investor Visa", href: "/visas/investor-visa/in/st-kitts-and-nevis" },
  { title: "Dominica Investor Visa", href: "/visas/investor-visa/in/dominica" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Contribution" },
  { key: "timeline", header: "Processing Time" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "DSP (Development Support Program)", investment: "$130,000 (single)", timeline: "30-60 days", benefits: "Fastest CBI globally" },
  { program: "DSP Family", investment: "$150,000 (family of 4)", timeline: "30-60 days", benefits: "Spouse + 2 children" },
  { program: "VCP (Vanuatu Contribution Program)", investment: "$130,000 (single)", timeline: "30-60 days", benefits: "Alternative program" },
  { program: "Additional Dependent", investment: "+$15,000-25,000 each", timeline: "Same", benefits: "Parents, siblings eligible" },
];

const insuranceColumns = [
  { key: "situation", header: "Situation" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "recommendation", header: "Recommended Coverage" },
];

const insuranceRows = [
  { situation: "CBI Application", requirement: "Not mandatory", recommendation: "International coverage recommended" },
  { situation: "Residing in Vanuatu", requirement: "No mandatory insurance", recommendation: "$100K+ with evacuation essential" },
  { situation: "Passport holders abroad", requirement: "N/A", recommendation: "Coverage based on residence country" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$300-600", strengths: "Global coverage, evacuation" },
  { provider: "Allianz Care", type: "International", price: "$250-500", strengths: "Worldwide network" },
  { provider: "IMG Global", type: "International", price: "$200-450", strengths: "Pacific coverage, evacuation" },
  { provider: "Pacific Blue Cross", type: "Regional", price: "$150-350", strengths: "Pacific specialist" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "DSP Contribution (Single)", amount: "$130,000", notes: "Non-refundable donation" },
  { item: "DSP Contribution (Couple)", amount: "$150,000", notes: "Main applicant + spouse" },
  { item: "DSP Family (4)", amount: "$150,000", notes: "Couple + 2 children under 18" },
  { item: "Additional Dependent", amount: "$15,000-25,000", notes: "Each additional family member" },
  { item: "Due Diligence Fee", amount: "$5,000", notes: "Per main applicant" },
  { item: "Government Processing", amount: "$3,000", notes: "Application fee" },
  { item: "Passport Fee", amount: "$200", notes: "Per passport" },
  { item: "Agent Fees", amount: "$10,000-20,000", notes: "Authorized agent required" },
];

const timelineColumns = [
  { key: "stage", header: "Stage" },
  { key: "duration", header: "Duration" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { stage: "Document Preparation", duration: "1-2 weeks", notes: "Minimal documents required" },
  { stage: "Application Submission", duration: "1-3 days", notes: "Via authorized agent" },
  { stage: "Due Diligence", duration: "2-3 weeks", notes: "Background verification" },
  { stage: "Approval", duration: "Week 3-4", notes: "Government approval" },
  { stage: "Payment", duration: "1 week", notes: "Complete contribution" },
  { stage: "Citizenship/Passport", duration: "1-2 weeks", notes: "Certificate and passport issued" },
  { stage: "Total", duration: "30-60 days", notes: "Fastest CBI worldwide" },
];
---

<PageShell
  title="Vanuatu Citizenship by Investment 2026: Fastest CBI Program Guide"
  description="Complete guide to Vanuatu CBI. $130K contribution, 30-60 day processing (fastest globally), 112 countries visa-free, zero taxes, Pacific island citizenship."
  headline="Vanuatu Citizenship by Investment: Complete Guide"
  subheadline="The world's fastest citizenship by investment—$130K contribution, 30-60 day processing, zero income/capital gains tax, and visa-free access to 112 countries including UK, EU Schengen, Singapore, and Hong Kong from this South Pacific paradise."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/vanuatu-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Vanuatu CBI
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Fastest Processing (30-60 days)
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Vanuatu offers the world's fastest citizenship by investment program—obtain a second passport in as little as 30-60 days for a $130,000 contribution. This South Pacific island nation provides visa-free access to 112 countries including the UK, EU Schengen zone, Singapore, and Hong Kong. With zero income tax, capital gains tax, and wealth tax, Vanuatu is attractive for tax planning.
    </p>

    <p class="mb-4">
      The Development Support Program (DSP) is Vanuatu's primary CBI route. While the passport offers fewer visa-free countries than Caribbean programs (112 vs 145-157), Vanuatu's speed and competitive pricing make it attractive for time-sensitive applicants. The program has processed thousands of applications since 2017, mostly from Chinese and Southeast Asian investors.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Vanuatu CBI Program</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>DSP Contribution:</strong> $130,000 single / $150,000 family of 4</li>
        <li>• <strong>Processing:</strong> 30-60 days (fastest globally)</li>
        <li>• <strong>Visa-free travel:</strong> 112 countries (UK, EU, Singapore, HK)</li>
        <li>• <strong>Dual citizenship:</strong> Fully permitted</li>
        <li>• <strong>Residency required:</strong> No physical presence requirement</li>
        <li>• <strong>Tax benefits:</strong> Zero income, capital gains, wealth tax</li>
        <li>• <strong>Passport validity:</strong> 5 years, renewable</li>
        <li>• <strong>Language:</strong> English, French, Bislama official</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Vanuatu?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Fastest CBI (30-60 days)</strong></li>
          <li>• Zero income/capital gains tax</li>
          <li>• Lower cost than St. Kitts</li>
          <li>• UK/EU/Singapore visa-free</li>
          <li>• No residency requirement</li>
          <li>• English is official language</li>
          <li>• Include family members</li>
          <li>• Beautiful Pacific location</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• Fewer visa-free countries (112)</li>
          <li>• No US/Canada visa-free</li>
          <li>• Very limited healthcare</li>
          <li>• Remote Pacific location</li>
          <li>• Cyclone/earthquake zone</li>
          <li>• Less established than Caribbean</li>
          <li>• Passport only 5 years validity</li>
          <li>• No US E-2 treaty</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Speed advantage:</strong> Vanuatu's 30-60 day processing is unmatched. St. Kitts takes 45-60 days (with accelerated fee), Dominica 3-4 months, Grenada 4-6 months. If time is critical—urgent travel needs, deal deadlines, or immediate diversification—Vanuatu delivers fastest.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Vanuatu CBI is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>You need fastest processing</strong></li>
          <li>• UK/EU travel is primary goal</li>
          <li>• Zero-tax jurisdiction appeals</li>
          <li>• Budget is $130K-$180K</li>
          <li>• You don't need US access</li>
          <li>• Time-sensitive situation</li>
          <li>• Pacific timezone suits you</li>
          <li>• You value English environment</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Maximum visa-free countries matter</li>
          <li>• You need US E-2 access (Grenada)</li>
          <li>• You want established program (St. Kitts)</li>
          <li>• Healthcare access matters</li>
          <li>• You plan to reside there</li>
          <li>• Budget allows St. Kitts premium</li>
          <li>• Chinese visa-free matters (Grenada)</li>
          <li>• Program reputation concerns you</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Vanuatu vs. Other CBI Programs</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Minimum</th>
            <th class="px-4 py-2 text-left">Processing</th>
            <th class="px-4 py-2 text-left">Visa-Free</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b bg-green-50">
            <td class="px-4 py-2 font-medium">Vanuatu</td>
            <td class="px-4 py-2">$130,000</td>
            <td class="px-4 py-2 font-semibold text-green-700">30-60 days</td>
            <td class="px-4 py-2">112</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Dominica</td>
            <td class="px-4 py-2">$100,000</td>
            <td class="px-4 py-2">3-4 months</td>
            <td class="px-4 py-2">145</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">St. Kitts</td>
            <td class="px-4 py-2">$250,000</td>
            <td class="px-4 py-2">45-60 days</td>
            <td class="px-4 py-2">157</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Grenada</td>
            <td class="px-4 py-2">$150,000</td>
            <td class="px-4 py-2">4-6 months</td>
            <td class="px-4 py-2">146 + E-2</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Value proposition:</strong> Vanuatu offers middle-ground pricing ($130K) with fastest processing. Trade-off is fewer visa-free countries (112 vs 145+). For time-critical applications needing UK/EU/Singapore access, Vanuatu beats alternatives. For maximum travel freedom, Caribbean programs win.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Vanuatu's citizenship is obtained through non-refundable contributions to government development programs. The Development Support Program (DSP) is the primary route.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Development Support Program (DSP)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The DSP is Vanuatu's primary CBI pathway—a non-refundable contribution to national development:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Single Applicant</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $130,000</li>
            <li>• Due diligence: $5,000</li>
            <li>• Processing: $3,000</li>
            <li>• Agent fees: ~$15,000</li>
            <li>• Total: ~$155,000</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Family of Four</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $150,000</li>
            <li>• Includes spouse + 2 children</li>
            <li>• Additional DD fees for adults</li>
            <li>• Agent fees: ~$20,000</li>
            <li>• Total: ~$185,000</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Eligible Family Members</h3>

    <div class="bg-neutral-50 rounded-lg p-6 mb-6">
      <ul class="space-y-2 text-neutral-700">
        <li>• <strong>Spouse:</strong> Legally married spouse</li>
        <li>• <strong>Children under 18:</strong> Included in base pricing</li>
        <li>• <strong>Children 18-25:</strong> If dependent, additional fee</li>
        <li>• <strong>Parents 50+:</strong> If dependent, additional fee ($25,000 each)</li>
        <li>• <strong>Unmarried siblings:</strong> May be eligible, case-by-case</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> All applications must go through government-authorized agents. Vanuatu has fewer agents than Caribbean programs—verify authorization carefully. The government publishes licensed agent lists.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">No Insurance Required for CBI</h3>
      <p class="text-green-800">
        Vanuatu does not require health insurance for citizenship application. However, if you visit or reside on the islands, comprehensive international coverage with medical evacuation is absolutely essential. Vanuatu has very limited healthcare—serious conditions require evacuation to Australia or New Zealand.
      </p>
    </div>

    <p class="mb-4">
      Most Vanuatu CBI citizens never reside there—they obtain citizenship for the passport and tax benefits while living elsewhere. Port Vila has basic hospital facilities but limited specialist care. For anything serious, evacuation to Brisbane, Sydney, or Auckland is necessary.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Critical: Medical Evacuation</h3>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-red-900 mb-2">Evacuation is NOT Optional</h4>
      <p class="text-red-800">
        If residing in or visiting Vanuatu, medical evacuation coverage is essential—not optional. Evacuation to Australia costs $50,000-100,000+ without insurance. Ensure your plan includes: minimum $250,000 evacuation coverage, 24/7 coordination, and Australia/New Zealand as evacuation destinations.
      </p>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Reality:</strong> 99%+ of Vanuatu CBI citizens don't live there. They hold the passport for travel and tax purposes while residing in Asia, Europe, or elsewhere with proper healthcare. Insurance needs depend on where you actually live.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need international health coverage?"
    description="Compare global plans with essential evacuation coverage for Pacific island citizenship."
    buttonText="Compare Premium Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Vanuatu passport holders traveling internationally or occasionally visiting the islands:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Global Travelers</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care for worldwide coverage. Your Vanuatu passport enables 112 countries visa-free—ensure coverage matches your travel patterns. Budget $300-500/month.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pacific Region Visitors</h4>
        <p class="text-neutral-600">IMG Global has strong Pacific coverage with Australia/NZ evacuation. Essential if visiting Vanuatu. Verify evacuation limits are adequate ($250K+ recommended).</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Based in Asia</h4>
        <p class="text-neutral-600">Many Vanuatu CBI holders live in Hong Kong, Singapore, or China. Maintain comprehensive coverage in your actual residence country. Vanuatu passport doesn't change your insurance needs.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Vanuatu offers middle-ground CBI pricing—cheaper than St. Kitts, slightly more than Dominica, but with fastest processing.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Total Cost Estimates</h3>

    <div class="bg-neutral-50 rounded-lg p-6 mb-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-semibold text-neutral-900 mb-3">Single Applicant</h4>
          <ul class="space-y-2 text-neutral-700">
            <li>DSP contribution: <strong>$130,000</strong></li>
            <li>Due diligence: <strong>$5,000</strong></li>
            <li>Processing fee: <strong>$3,000</strong></li>
            <li>Agent fees: <strong>$15,000</strong></li>
            <li>Passport: <strong>$200</strong></li>
            <li class="pt-2 border-t font-semibold">Total: <strong>~$153,000</strong></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-neutral-900 mb-3">Family of Four</h4>
          <ul class="space-y-2 text-neutral-700">
            <li>DSP contribution: <strong>$150,000</strong></li>
            <li>Due diligence (family): <strong>$15,000</strong></li>
            <li>Processing fee: <strong>$3,000</strong></li>
            <li>Agent fees: <strong>$18,000</strong></li>
            <li>Passports (4): <strong>$800</strong></li>
            <li class="pt-2 border-t font-semibold">Total: <strong>~$187,000</strong></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Value comparison:</strong> Vanuatu ($153K single) costs more than Dominica ($124K) but processes in 30-60 days vs 3-4 months. You pay ~$30K premium for speed. For time-sensitive needs, this premium is justified. For patient applicants, Dominica offers better value.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Vanuatu's streamlined process enables the world's fastest CBI—30-60 days from application to passport.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Process</h3>

    <div class="space-y-6 mb-8">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Select Authorized Agent</h4>
          <p class="text-neutral-600">Choose from government-authorized agents. Fewer agents than Caribbean programs—verify authorization on official Vanuatu government website. Compare fees and track record.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Document Preparation</h4>
