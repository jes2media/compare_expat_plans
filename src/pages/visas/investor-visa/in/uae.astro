---
/**
 * UAE Golden Visa (Investor Visa) - Long-form CRO-optimized page
 * Complete guide to UAE's 10-year Golden Visa for investors and entrepreneurs
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-requirements", text: "Investment Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in UAE", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "UAE Health Insurance Guide", href: "/countries/uae/insurance" },
  { title: "UAE Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/uae" },
  { title: "UAE Freelancer Visa", href: "/visas/freelancer-visa/in/uae" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const investmentColumns = [
  { key: "option", header: "Investment Route" },
  { key: "minimum", header: "Minimum Investment" },
  { key: "duration", header: "Visa Duration" },
  { key: "notes", header: "Notes" },
];

const investmentRows = [
  { option: "Real Estate", minimum: "AED 2M (~$545,000)", duration: "10 years", notes: "Property must be retained; can be mortgaged up to 50%" },
  { option: "Public Investment", minimum: "AED 2M (~$545,000)", duration: "10 years", notes: "Investment in approved funds or deposits" },
  { option: "Business Owner", minimum: "AED 2M capital (~$545,000)", duration: "10 years", notes: "Own company with minimum AED 2M capital" },
  { option: "Business Partner", minimum: "AED 2M share value", duration: "10 years", notes: "Share in existing UAE company worth AED 2M+" },
  { option: "Entrepreneur", minimum: "AED 500,000 (~$136,000)", duration: "5-10 years", notes: "Startup valued at AED 500K+ or incubator-approved" },
  { option: "Green Visa (Self-employed)", minimum: "AED 360,000/year income", duration: "5 years", notes: "For skilled freelancers and professionals" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "requirement", header: "UAE Requirement" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { feature: "Coverage Type", requirement: "Comprehensive health insurance", notes: "Mandatory in Dubai and Abu Dhabi for all residents" },
  { feature: "Provider Type", requirement: "DHA/DOH approved insurer", notes: "International insurers widely accepted if compliant" },
  { feature: "Minimum Coverage", requirement: "AED 150,000+ (~$40,000)", notes: "Higher coverage recommended for investors" },
  { feature: "Inpatient Coverage", requirement: "Required", notes: "Hospital stays, surgeries fully covered" },
  { feature: "Outpatient Coverage", requirement: "Required", notes: "Doctor visits, diagnostics, prescriptions" },
  { feature: "Emergency Coverage", requirement: "Required", notes: "24/7 emergency access mandatory" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$300-600", strengths: "Global coverage, high-net-worth individuals" },
  { provider: "Bupa Global", type: "International", price: "$350-700", strengths: "Premium service, extensive UAE network" },
  { provider: "Allianz Care", type: "International", price: "$280-550", strengths: "Flexible plans, strong Middle East presence" },
  { provider: "Aetna International", type: "International", price: "$320-620", strengths: "US ties, excellent customer service" },
  { provider: "Daman (National)", type: "UAE Local", price: "$150-350", strengths: "Government-linked, comprehensive local coverage" },
  { provider: "AXA Gulf", type: "Regional", price: "$200-450", strengths: "Good balance of cost and coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (AED/USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Golden Visa Fee", amount: "AED 1,150 (~$313)", notes: "10-year residence visa" },
  { item: "Emirates ID", amount: "AED 1,000 (~$272)", notes: "Biometric ID card (10-year)" },
  { item: "Medical Fitness Test", amount: "AED 300-500 (~$80-135)", notes: "Required health screening" },
  { item: "Investment (Property)", amount: "AED 2,000,000+ (~$545,000+)", notes: "Minimum for 10-year Golden Visa" },
  { item: "Property Registration", amount: "4% of property value", notes: "Dubai Land Department fee" },
  { item: "Health Insurance (Annual)", amount: "$2,000-8,000", notes: "Mandatory; family plans higher" },
  { item: "Company Setup (if applicable)", amount: "AED 15,000-50,000", notes: "For business route; varies by free zone" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Complete investment (property/business)", duration: "Varies (days-weeks)", location: "UAE" },
  { step: "Gather required documents", duration: "1-2 weeks", location: "Home country/UAE" },
  { step: "Submit Golden Visa application", duration: "1 day", location: "ICP/GDRFA portal or office" },
  { step: "Application processing", duration: "2-4 weeks", location: "Government review" },
  { step: "Medical fitness test", duration: "1-2 days", location: "Approved UAE centers" },
  { step: "Emirates ID biometrics", duration: "1 day", location: "Typing center" },
  { step: "Visa stamping", duration: "3-7 days", location: "GDRFA office" },
  { step: "Receive Emirates ID card", duration: "1-2 weeks", location: "Delivered or pickup" },
];

const comparisonColumns = [
  { key: "country", header: "Country" },
  { key: "investment", header: "Min. Investment" },
  { key: "duration", header: "Visa Duration" },
  { key: "tax", header: "Income Tax" },
  { key: "citizenship", header: "Citizenship Path" },
];

const comparisonRows = [
  { country: "UAE Golden Visa", investment: "$545,000", duration: "10 years", tax: "0%", citizenship: "Limited (by decree)" },
  { country: "Portugal Golden Visa", investment: "$500,000 (funds)", duration: "2 years", tax: "20-48%", citizenship: "5 years" },
  { country: "Spain Golden Visa", investment: "$545,000 (property)", duration: "2+5 years", tax: "19-47%", citizenship: "10 years" },
  { country: "UK Innovator Founder", investment: "$68,000+", duration: "3 years", tax: "20-45%", citizenship: "5 years" },
  { country: "US EB-5", investment: "$800,000+", duration: "2 years (conditional)", tax: "10-37%", citizenship: "5 years" },
];
---

<PageShell
  title="UAE Golden Visa 2026: Investment Options, Insurance & Complete Guide"
  description="Complete guide to UAE's Golden Visa for investors. AED 2 million investment threshold, 10-year residence, 0% income tax, mandatory insurance requirements, and fast processing."
  headline="UAE Golden Visa: Investment & Insurance Guide"
  subheadline="Everything you need to know about UAE's 10-year Golden Visa for investors and entrepreneurs—AED 2 million investment routes, mandatory health insurance, 0% income tax, and the path to long-term residence."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/uae-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official UAE Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      0% Personal Income Tax
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The UAE Golden Visa is one of the world's most attractive investor residence programs. Launched in 2019 and expanded significantly in 2022, it offers 10-year renewable residence to investors, entrepreneurs, and high-net-worth individuals. Unlike most investor visas, the UAE combines long-term residence with zero personal income tax—a powerful combination for wealth preservation.
    </p>

    <p class="mb-4">
      For investors seeking a stable, business-friendly jurisdiction with world-class infrastructure, the UAE delivers exceptional value. Dubai and Abu Dhabi serve as global business hubs connecting Europe, Asia, and Africa, with modern cities, English widely spoken, and a government actively courting international investment and talent.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: UAE Golden Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>* <strong>Official name:</strong> UAE Golden Visa / Long-Term Residence Visa</li>
        <li>* <strong>Minimum investment:</strong> AED 2 million (~$545,000) for 10-year visa</li>
        <li>* <strong>Entrepreneur route:</strong> AED 500,000 (~$136,000) startup value</li>
        <li>* <strong>Duration:</strong> 10 years, renewable indefinitely</li>
        <li>* <strong>Family included:</strong> Spouse, children, domestic staff</li>
        <li>* <strong>No sponsor required:</strong> Self-sponsored residence</li>
        <li>* <strong>100% business ownership:</strong> No local partner needed</li>
        <li>* <strong>Tax status:</strong> 0% personal income tax (9% corporate on profits over AED 375,000)</li>
        <li>* <strong>Processing time:</strong> 2-4 weeks (very fast)</li>
        <li>* <strong>Minimum stay:</strong> None required</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose UAE's Golden Visa?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>* 0% personal income tax (massive wealth preservation)</li>
          <li>* 10-year visa with auto-renewal</li>
          <li>* No sponsor needed (self-sponsored)</li>
          <li>* 100% business ownership (no local partner required)</li>
          <li>* No minimum stay requirement</li>
          <li>* Include spouse, children, and domestic staff</li>
          <li>* Fast processing (2-4 weeks)</li>
          <li>* World-class infrastructure and safety</li>
          <li>* Strategic location between Europe and Asia</li>
          <li>* English widely spoken</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>* High investment threshold (AED 2M minimum)</li>
          <li>* No path to citizenship (generally)</li>
          <li>* High cost of living (Dubai especially)</li>
          <li>* Health insurance mandatory and expensive</li>
          <li>* Hot climate (summer temperatures exceed 40C)</li>
          <li>* 9% corporate tax introduced in 2023</li>
          <li>* Cultural differences to navigate</li>
          <li>* Property market can be volatile</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Golden Visa vs Green Visa</h3>

    <p class="mb-4">
      The UAE offers two main long-term residence options for investors and professionals:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Golden Visa (10 Years)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>* AED 2 million investment minimum</li>
          <li>* 10-year renewable residence</li>
          <li>* No sponsor required</li>
          <li>* Include unlimited family members</li>
          <li>* Stay outside UAE up to 6 months</li>
          <li>* Best for: Investors, entrepreneurs, high-net-worth</li>
        </ul>
      </div>

      <div class="border border-purple-200 bg-purple-50 rounded-lg p-6">
        <h4 class="font-semibold text-purple-900 mb-3">Green Visa (5 Years)</h4>
        <ul class="space-y-2 text-purple-800">
          <li>* Lower threshold for skilled workers/freelancers</li>
          <li>* 5-year renewable residence</li>
          <li>* Self-sponsored (no employer needed)</li>
          <li>* Include first-degree relatives</li>
          <li>* Stay outside UAE up to 6 months</li>
          <li>* Best for: Freelancers, self-employed, professionals</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>2023-2024 developments:</strong> The UAE introduced 9% corporate tax on business profits exceeding AED 375,000 in 2023. Personal income remains tax-free. Free zone businesses may still qualify for 0% corporate tax if meeting substance requirements. The Golden Visa program has expanded eligibility, making it more accessible than when first launched.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">UAE Golden Visa is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>* You have AED 2M+ ($545,000+) to invest</li>
          <li>* You want to eliminate personal income tax</li>
          <li>* You value 100% business ownership</li>
          <li>* You want a stable, business-friendly jurisdiction</li>
          <li>* You work with Europe, Middle East, or Asia</li>
          <li>* You prefer modern, luxury infrastructure</li>
          <li>* You can afford premium cost of living</li>
          <li>* You don't need a path to citizenship</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>* You want a path to citizenship/passport</li>
          <li>* You prefer lower cost of living</li>
          <li>* You work primarily with US time zones</li>
          <li>* You want European Union access</li>
          <li>* You prefer moderate climates</li>
          <li>* You're looking for cultural immersion</li>
          <li>* You have less than $500,000 to invest</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Comparing Global Investor Visas</h3>

    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Why UAE stands out:</strong> The UAE's unique advantage is the combination of 10-year residence, 0% personal income tax, and 100% business ownership. No European program offers this tax treatment. For investors prioritizing wealth preservation over citizenship, the UAE is often the optimal choice.
      </p>
    </div>
  </section>

  <!-- Section: Investment Requirements -->
  <section id="investment-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Requirements</h2>

    <p class="mb-4">
      The UAE offers multiple qualifying routes for the Golden Visa. Real estate is the most straightforward, but business investment and entrepreneurship provide alternatives. The investment must be maintained throughout your residence—though property can be mortgaged up to 50%.
    </p>

    <ComparisonTable columns={investmentColumns} rows={investmentRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Real Estate Route (Most Popular)</h3>

    <p class="mb-4">
      The AED 2 million property investment is the most common route to the Golden Visa. Key details:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Property value:</strong> Minimum AED 2 million (approximately $545,000)</li>
      <li><strong>Mortgage allowed:</strong> Property can be mortgaged up to 50%—equity must be AED 2M+</li>
      <li><strong>Multiple properties:</strong> Can combine properties to reach AED 2M threshold</li>
      <li><strong>Property type:</strong> Residential properties (apartments, villas, townhouses)</li>
      <li><strong>Location:</strong> Dubai, Abu Dhabi, or other emirates (Dubai most popular)</li>
      <li><strong>Off-plan purchases:</strong> Accepted if developer is approved and significant payment made</li>
      <li><strong>Must retain property:</strong> Cannot sell and keep visa (unlike some programs)</li>
    </ul>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Popular Investment Areas (Dubai)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>* <strong>Palm Jumeirah:</strong> Iconic, premium, AED 3M+ typical</li>
          <li>* <strong>Downtown Dubai:</strong> Near Burj Khalifa, high demand</li>
          <li>* <strong>Dubai Marina:</strong> Waterfront, expat-popular</li>
          <li>* <strong>Business Bay:</strong> Central, good value</li>
          <li>* <strong>JBR/Bluewaters:</strong> Beach lifestyle, tourism rental potential</li>
          <li>* <strong>Dubai Hills:</strong> Family-friendly, growing area</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Property Considerations</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>* Work with RERA-registered agents only</li>
          <li>* Verify property is in freehold area</li>
          <li>* Check developer track record</li>
          <li>* Understand service charges (can be high)</li>
          <li>* Consider rental yield potential (4-7% typical)</li>
          <li>* Factor in 4% DLD registration fee</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Business & Entrepreneur Routes</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Business Owner (AED 2,000,000)</h4>
        <p class="text-neutral-600">Own a UAE company with capital or revenue of AED 2 million+. Can be mainland or free zone company. You must be the sole or majority owner. The company must be operational with legitimate business activity—shell companies don't qualify.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Entrepreneur / Startup (AED 500,000)</h4>
        <p class="text-neutral-600">For startup founders with a business valued at AED 500,000+ or approved by a UAE incubator/accelerator. This route is more flexible but requires demonstrating innovation, scalability, and job creation potential. Incubator approval (Hub71, DIFC, etc.) can substitute for valuation requirement.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Public Investment (AED 2,000,000)</h4>
        <p class="text-neutral-600">Deposit AED 2 million in an approved investment fund or establish a company with AED 2 million capital. This provides an alternative to real estate for investors preferring liquid assets. The investment must remain committed for the visa duration.</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Free Zone vs Mainland Companies</h3>

    <p class="mb-4">
      When establishing a business in the UAE, you'll choose between free zone and mainland setup:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Free Zone Company</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>* 100% foreign ownership guaranteed</li>
          <li>* Potential 0% corporate tax (if qualifying)</li>
          <li>* Cannot trade directly with UAE mainland</li>
          <li>* Faster setup (1-2 weeks)</li>
          <li>* Popular: DMCC, DIFC, ADGM, JAFZA</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Mainland Company</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>* 100% foreign ownership now allowed (most sectors)</li>
          <li>* Trade freely within UAE and internationally</li>
          <li>* 9% corporate tax on profits over AED 375,000</li>
          <li>* More complex setup (3-4 weeks)</li>
          <li>* Required for some activities (retail, contracting)</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> The investment must be made with legally obtained funds. Source of funds verification is standard practice. Bank transfers should be documented, and you may need to provide evidence of how you accumulated the investment capital. Anti-money-laundering checks are thorough but not onerous for legitimate investors.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Mandatory Requirement</h3>
      <p class="text-red-800">
        Health insurance is <strong>mandatory</strong> for all UAE residents, including Golden Visa holders. In Dubai (DHA) and Abu Dhabi (DOH), you cannot complete your visa process without valid health insurance. This requirement is strictly enforced—you will need to show proof of coverage.
      </p>
    </div>

    <p class="mb-4">
      Unlike some investor visa programs where insurance requirements are loosely enforced, the UAE takes health insurance seriously. Your policy must meet regulatory standards set by the Dubai Health Authority (DHA) or Department of Health Abu Dhabi (DOH), depending on your emirate of residence.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">What "Compliant Coverage" Means</h3>

    <p class="mb-4">
      UAE health insurance regulations require comprehensive coverage. Your policy must include:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Inpatient hospitalization:</strong> Full coverage for hospital stays, surgeries, ICU</li>
      <li><strong>Outpatient care:</strong> Doctor visits, specialists, diagnostics, prescriptions</li>
      <li><strong>Emergency care:</strong> 24/7 emergency treatment access</li>
      <li><strong>Maternity coverage:</strong> Often required for female residents of childbearing age</li>
      <li><strong>Minimum coverage limits:</strong> AED 150,000+ (DHA Essential Benefits Plan minimum)</li>
      <li><strong>Network access:</strong> Must include UAE hospitals and clinics</li>
    </ul>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">International vs. Local Insurance</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
