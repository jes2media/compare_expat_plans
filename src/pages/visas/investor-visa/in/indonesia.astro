---
/**
 * Indonesia Investor Visa - Long-form CRO-optimized page
 * Second Home Visa, Investor KITAS, and investment options
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Indonesia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Indonesia Insurance Guide", href: "/countries/indonesia/insurance" },
  { title: "Indonesia Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/indonesia" },
  { title: "Bali Insurance Guide", href: "/countries/indonesia/insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Investment/Requirement" },
  { key: "duration", header: "Duration" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "Second Home Visa", investment: "$130K savings + $1,400/mo income", duration: "5-10 years", benefits: "Long-term stay, Bali lifestyle" },
  { program: "Investor KITAS", investment: "IDR 10B (~$625K) in company", duration: "1 year renewable", benefits: "Work rights, business activities" },
  { program: "Retirement KITAS (Lansia)", investment: "$1,500/month pension", duration: "1 year renewable", benefits: "Age 55+, no work rights" },
  { program: "Golden Visa", investment: "$2.5M+ investment", duration: "5-10 years", benefits: "New 2024 program, premium" },
  { program: "PMA Company Setup", investment: "IDR 10B capital commitment", duration: "Tied to company", benefits: "Full business rights, employ staff" },
];

const insuranceColumns = [
  { key: "program", header: "Visa Program" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "minimum", header: "Minimum Coverage" },
];

const insuranceRows = [
  { program: "Second Home Visa", requirement: "Mandatory", minimum: "Covers stay in Indonesia" },
  { program: "Investor KITAS", requirement: "Mandatory", minimum: "Comprehensive coverage" },
  { program: "Retirement KITAS", requirement: "Mandatory", minimum: "Covers healthcare costs" },
  { program: "Golden Visa", requirement: "Mandatory", minimum: "Premium coverage expected" },
  { program: "BPJS (Public)", requirement: "Available to KITAS holders", minimum: "After 6 months residence" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$200-500", strengths: "Comprehensive, Singapore evac" },
  { provider: "Allianz Care", type: "International", price: "$180-450", strengths: "Good Asia network" },
  { provider: "Pacific Cross Indonesia", type: "Regional", price: "$100-300", strengths: "Indonesia specialist" },
  { provider: "William Russell", type: "International", price: "$150-400", strengths: "Expat-focused, flexible" },
  { provider: "Allianz Utama", type: "Indonesian", price: "$50-150", strengths: "Local coverage, affordable" },
  { provider: "AXA Mandiri", type: "Indonesian", price: "$60-180", strengths: "Good hospital network" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Second Home Visa (5 years)", amount: "$130,000 savings proof", notes: "Plus $1,400/month income proof" },
  { item: "Second Home Visa (10 years)", amount: "$130,000 savings proof", notes: "Extended option available" },
  { item: "Investor KITAS", amount: "~$625,000 (IDR 10B)", notes: "Company investment capital" },
  { item: "Golden Visa (5 years)", amount: "$2,500,000+", notes: "Premium investor category" },
  { item: "Retirement KITAS", amount: "$1,500/month pension", notes: "Age 55+, no work" },
  { item: "Visa Processing Fees", amount: "$200-500", notes: "Government fees" },
  { item: "Agent/Sponsor Fees", amount: "$500-2,000", notes: "Most visas require sponsor" },
  { item: "Health Insurance", amount: "$1,000-5,000/year", notes: "Mandatory for all long-term visas" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "Second Home Visa", processing: "2-4 weeks", notes: "Online application + document review" },
  { program: "Investor KITAS", processing: "1-3 months", notes: "Company setup first, then visa" },
  { program: "Retirement KITAS", processing: "2-4 weeks", notes: "Straightforward process" },
  { program: "Golden Visa", processing: "1-2 months", notes: "Premium processing" },
];
---

<PageShell
  title="Indonesia Investor Visa 2026: Second Home Visa, Golden Visa & KITAS Guide"
  description="Complete guide to Indonesia investor visas. Second Home Visa ($130K), Golden Visa ($2.5M), Investor KITAS, and paths to long-term residence in Bali and beyond."
  headline="Indonesia Investor Visa: Complete Guide"
  subheadline="Everything you need to know about Indonesia's investor visa options—Second Home Visa, Golden Visa, Investor KITAS, and paths to long-term residence in Bali, Jakarta, and across the Indonesian archipelago."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/indonesia-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Bali & Beyond
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Indonesia has dramatically expanded its long-term visa options for investors and high-net-worth individuals. The Second Home Visa (launched 2022) offers 5-10 years of residence for those with $130,000 in savings and $1,400/month income. The newer Golden Visa (2024) targets premium investors with $2.5M+ investments. For business investors, the traditional Investor KITAS remains available.
    </p>

    <p class="mb-4">
      Indonesia's appeal is obvious: Bali's legendary lifestyle, affordable cost of living, tropical climate, rich culture, and welcoming people. While bureaucracy can be challenging and healthcare varies by location, the new visa options make long-term residence more accessible than ever. No path to citizenship exists, but long-term residence is now genuinely achievable.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Indonesia Investor Options</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Second Home Visa:</strong> $130K savings + $1,400/mo income (5-10 years)</li>
        <li>• <strong>Golden Visa:</strong> $2.5M+ investment (5-10 years, premium)</li>
        <li>• <strong>Investor KITAS:</strong> IDR 10B (~$625K) company investment</li>
        <li>• <strong>Retirement KITAS:</strong> $1,500/month pension (age 55+)</li>
        <li>• <strong>No citizenship:</strong> Indonesia doesn't allow naturalization for most</li>
        <li>• <strong>Property:</strong> Foreigners can't own freehold land (leasehold options)</li>
        <li>• <strong>Insurance:</strong> Mandatory for all long-term visas</li>
        <li>• <strong>Healthcare:</strong> Varies by location—Singapore evacuation important</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Indonesia?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Bali lifestyle (world-famous)</li>
          <li>• Very affordable cost of living</li>
          <li>• Tropical climate, beaches, nature</li>
          <li>• Welcoming, friendly culture</li>
          <li>• Second Home Visa relatively accessible</li>
          <li>• Large expat community (especially Bali)</li>
          <li>• Excellent food and wellness scene</li>
          <li>• Improving digital infrastructure</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• No path to citizenship</li>
          <li>• Can't own land (leasehold only)</li>
          <li>• Healthcare varies significantly by location</li>
          <li>• Bureaucracy can be challenging</li>
          <li>• Language barrier (Bahasa Indonesia)</li>
          <li>• Infrastructure outside major cities</li>
          <li>• Traffic in developed areas</li>
          <li>• Visa rules can change</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Bali reality:</strong> Most investor visa applicants are Bali-focused. Bali offers the best combination of lifestyle, expat community, healthcare, and infrastructure. Other areas (Jakarta, Lombok, Yogyakarta) have their charms but less developed expat support. Plan your base carefully—Indonesia is huge and varied.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Indonesia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want Bali/tropical island lifestyle</li>
          <li>• You have $130K+ in savings</li>
          <li>• You value affordable cost of living</li>
          <li>• You appreciate wellness/yoga/surf culture</li>
          <li>• You're okay with leasehold property</li>
          <li>• You don't need citizenship</li>
          <li>• You're comfortable with Southeast Asia</li>
          <li>• You want long-term (5-10 year) visa</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want citizenship pathway</li>
          <li>• You need to own land freehold</li>
          <li>• You require world-class healthcare</li>
          <li>• You prefer Western infrastructure</li>
          <li>• You want stable regulatory environment</li>
          <li>• You don't like hot, humid climate</li>
          <li>• You prefer urban, modern lifestyle</li>
          <li>• You need work rights (complicated)</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Indonesia vs. SE Asia Alternatives</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investor Route</th>
            <th class="px-4 py-2 text-left">Investment</th>
            <th class="px-4 py-2 text-left">Duration</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Indonesia</td>
            <td class="px-4 py-2">Second Home Visa</td>
            <td class="px-4 py-2">$130K savings + income</td>
            <td class="px-4 py-2">5-10 years</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Thailand</td>
            <td class="px-4 py-2">Elite / LTR</td>
            <td class="px-4 py-2">฿600K-1M / Income</td>
            <td class="px-4 py-2">5-20 years</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Malaysia</td>
            <td class="px-4 py-2">MM2H / S-MM2H</td>
            <td class="px-4 py-2">RM1M / RM150K</td>
            <td class="px-4 py-2">5-10 years</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Philippines</td>
            <td class="px-4 py-2">SRRV</td>
            <td class="px-4 py-2">$10K-50K deposit</td>
            <td class="px-4 py-2">Permanent</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Second Home advantage:</strong> The Second Home Visa is one of the easiest long-term visas in SE Asia. $130K in savings (doesn't need to be invested, just proven) plus $1,400/month income gets you 5-10 years. No complex company setup or property purchase required. For Bali dreamers, this is the clearest path.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Indonesia offers several pathways depending on your financial situation and goals. The Second Home Visa is most popular; the Golden Visa is for high-net-worth individuals; Investor KITAS is for business investors.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Second Home Visa (Most Popular)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The flagship long-term visa for investors and retirees. Launched 2022, it's now the easiest path to long-term Indonesia residence:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Requirements</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Savings: <strong>$130,000</strong> (bank statement proof)</li>
            <li>• Monthly income: <strong>$1,400+</strong></li>
            <li>• Valid passport (18+ months validity)</li>
            <li>• Health insurance (mandatory)</li>
            <li>• No criminal record</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Benefits</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• 5 or 10-year visa options</li>
            <li>• Multiple entry</li>
            <li>• Live anywhere in Indonesia</li>
            <li>• No Indonesian sponsor required</li>
            <li>• Can include family members</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Restrictions</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• NO work rights (can't work in Indonesia)</li>
            <li>• Savings must remain (proof at renewal)</li>
            <li>• Remote work for overseas technically tolerated</li>
            <li>• Must exit/enter to validate visa</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Family Inclusion</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Spouse can be included</li>
            <li>• Children under 18 included</li>
            <li>• Each family member needs own visa</li>
            <li>• Same financial requirements</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Golden Visa (Premium, 2024)</h3>

    <div class="border-l-4 border-amber-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Indonesia's new premium visa for high-net-worth individuals. Launched 2024 with significant investment requirements:</p>

      <div class="space-y-4">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Investment Options</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Government bonds: <strong>$2,500,000+</strong> (5-year visa)</li>
            <li>• Company shares in Indonesian company: <strong>$2,500,000+</strong></li>
            <li>• 10-year option available with higher investment</li>
            <li>• Can combine with establishing new company</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Benefits</h4>
          <p class="text-neutral-700 text-sm">Premium processing, potential work authorization, multiple entry, family inclusion. Best for serious investors wanting deeper Indonesia involvement. New program—rules still evolving.</p>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Investor KITAS (Business Investment)</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Traditional investor visa through establishing Indonesian company (PMA):</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Establish PMA (foreign-owned company) with IDR 10B (~$625K) capital</li>
        <li>Capital can be invested over time (commitment, not immediate)</li>
        <li>Full work rights in your company</li>
        <li>Can hire Indonesian staff</li>
        <li>1-year KITAS, renewable</li>
        <li>Path to KITAP (permanent stay permit) after years</li>
      </ul>

      <p class="text-neutral-600">Best for serious business investors. Requires ongoing company activity and compliance. Not suitable for passive residence seekers.</p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Retirement KITAS (Age 55+)</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For retirees seeking affordable Indonesia living:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Age requirement: 55+</li>
        <li>Pension/income: $1,500/month minimum</li>
        <li>No work rights</li>
        <li>Must have Indonesian sponsor (agent/company)</li>
        <li>Health insurance mandatory</li>
        <li>1-year visa, renewable up to 5 times</li>
      </ul>

      <p class="text-neutral-600">Lower threshold than Second Home, but requires sponsor and has age requirement. Good for budget-conscious retirees.</p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> None of these visas lead to Indonesian citizenship. Indonesia generally doesn't allow naturalization except in very rare circumstances (marriage to Indonesian for many years). Plan for long-term residence, not citizenship.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        All long-term visas (Second Home, KITAS, Golden Visa) require valid health insurance as an application condition. This isn't just a formality—Indonesia's healthcare varies dramatically by location, and international insurance with Singapore evacuation is strongly recommended.
      </p>
    </div>

    <p class="mb-4">
      Indonesia has a two-tier healthcare system: BPJS (public) for residents and private hospitals. Bali has decent private hospitals (BIMC, Siloam), but complex cases typically require evacuation to Singapore (2.5 hours). Insurance with evacuation coverage is essential.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Indonesia</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance (Recommended)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Cigna, Allianz, William Russell</li>
          <li>• Premium: $150-500/month</li>
          <li>• Singapore evacuation included</li>
          <li>• Global coverage for travel</li>
          <li>• English-speaking support</li>
          <li>• Direct billing at major hospitals</li>
          <li>• Higher limits for complex care</li>
          <li>• Essential for serious health issues</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Indonesian Local Insurance</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Allianz Utama, AXA Mandiri</li>
          <li>• Premium: $50-180/month</li>
          <li>• Indonesia-focused coverage</li>
          <li>• Local hospital networks</li>
          <li>• Bahasa Indonesia services</li>
          <li>• More affordable</li>
          <li>• May meet visa requirements</li>
          <li>• Limited for complex cases</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Choosing the Right Insurance</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Bali-Based (Recommended Approach)</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care with Singapore evacuation. Bali's BIMC and Siloam handle routine care; serious issues go to Singapore. Budget $200-400/month. The evacuation coverage is worth every dollar—Singapore is world-class, Bali is not.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Jakarta-Based</h4>
        <p class="text-neutral-600">Jakarta has better hospitals (Pondok Indah, Siloam Semanggi) than Bali. Still recommend international insurance, but evacuation less critical. Pacific Cross Indonesia or Allianz Care. Budget $150-300/month.</p>
