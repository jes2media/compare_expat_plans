---
import Layout from '../../../../layouts/Layout.astro';
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const title = "Vietnam Investor Visa Insurance Guide 2025";
const description = "Complete guide to Vietnam's investor visa options. Learn about IRC requirements, insurance for foreign investors, and healthcare access in one of Southeast Asia's fastest-growing economies.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Compare Expat Plans"
  },
  "datePublished": "2025-01-15",
  "dateModified": "2025-01-15"
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <PageShell
    title={title}
    subtitle="Your complete guide to investor visa insurance in Vietnam"
    heroImage="/images/countries/vietnam-hero-bg.png"
  >
    <!-- Quick Facts Box -->
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-bold text-primary-900 mb-4">Vietnam Investor Visa: Quick Facts</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="font-semibold text-neutral-700">Investment Minimum:</span>
          <span class="text-neutral-900"> No fixed minimum (sector-dependent)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Typical Investment:</span>
          <span class="text-neutral-900"> $50,000-$500,000 USD</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Visa Duration:</span>
          <span class="text-neutral-900"> 1-5 years (renewable)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Processing Time:</span>
          <span class="text-neutral-900"> 2-4 months</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Path to Citizenship:</span>
          <span class="text-neutral-900"> No (dual citizenship prohibited)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Insurance Requirement:</span>
          <span class="text-neutral-900"> Not mandatory but highly recommended</span>
        </div>
      </div>
    </div>

    <!-- Overview Section -->
    <section id="overview" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>
      <p class="text-neutral-700 mb-4">
        Vietnam's investor visa (ĐT visa) offers foreign entrepreneurs access to one of Southeast Asia's most dynamic
        economies. With GDP growth consistently above 6% and a young, educated workforce of nearly 100 million people,
        Vietnam has become a magnet for foreign investment—particularly as businesses diversify supply chains away
        from China.
      </p>
      <p class="text-neutral-700 mb-4">
        Unlike citizenship-by-investment programs, Vietnam's investor visa is purely a residency pathway for active
        business participation. The country doesn't offer citizenship to foreign investors (and doesn't allow dual
        citizenship), but long-term investors can obtain permanent residence cards after extended periods of lawful stay.
        The focus is on actual business operation rather than passive investment.
      </p>
      <p class="text-neutral-700 mb-4">
        Healthcare in Vietnam ranges from basic public facilities to excellent international hospitals in major cities.
        International health insurance is essential for foreign investors, as the public system isn't designed for
        expat needs and private hospital costs can accumulate quickly. Most investors opt for comprehensive plans with
        Singapore or Bangkok evacuation coverage for complex procedures.
      </p>
    </section>

    <!-- Quick Decision Guide -->
    <section id="decision-guide" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-green-800 mb-3">Vietnam Investor Visa is Ideal If You:</h3>
          <ul class="space-y-2 text-green-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Want to actively run a business in a high-growth market</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Seek low operating costs with educated, affordable workforce</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Are interested in manufacturing, tech, or export-oriented businesses</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Value affordable cost of living with vibrant culture</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Are comfortable navigating bureaucratic processes with local partners</span>
            </li>
          </ul>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-amber-800 mb-3">Consider Alternatives If You:</h3>
          <ul class="space-y-2 text-amber-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Seek citizenship or second passport (not available)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Want passive investment without business involvement</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Need 100% foreign ownership in restricted sectors</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Prefer English as primary business language</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Want top-tier local healthcare (medical evacuation recommended)</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Official Requirements -->
    <section id="requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Official Requirements</h2>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Investment Structures</h3>

        <div class="space-y-6">
          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 1: 100% Foreign-Owned Company (LLC)</h4>
            <p class="text-neutral-700 mt-2">
              Establish a Limited Liability Company (Công ty TNHH) with 100% foreign capital. Requires an Investment
              Registration Certificate (IRC) and Enterprise Registration Certificate (ERC). Minimum charter capital
              depends on industry—no legal minimum for most sectors, but authorities expect capital sufficient for
              stated business activities (typically $10,000-$50,000+ for service companies, $100,000+ for manufacturing).
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 2: Joint Venture with Vietnamese Partner</h4>
            <p class="text-neutral-700 mt-2">
              Partner with a Vietnamese company or individual. Required for certain restricted sectors (education,
              logistics, advertising, some retail). Foreign ownership caps vary by industry—some allow 49%, others 51%
              or higher. JVs can provide local market access and regulatory navigation expertise.
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 3: Representative Office</h4>
            <p class="text-neutral-700 mt-2">
              Establish a Representative Office of an existing foreign company. Cannot generate revenue in Vietnam—
              limited to market research, liaison activities, and promoting parent company. Simpler setup but doesn't
              qualify for full investor visa benefits; Chief Representative gets a 1-year visa.
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 4: Capital Contribution to Existing Company</h4>
            <p class="text-neutral-700 mt-2">
              Purchase shares or contribute capital to an existing Vietnamese company. Minimum investment typically
              VND 3 billion (~$120,000 USD) for investor visa eligibility when not establishing a new company. Due
              diligence on the existing company is critical.
            </p>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Eligibility Criteria</h3>
        <ul class="space-y-3 text-neutral-700">
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Investment Registration Certificate (IRC):</strong> Issued by Department of Planning and Investment</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Enterprise Registration Certificate (ERC):</strong> Proof of company establishment</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Valid passport:</strong> At least 6 months validity beyond visa period</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Capital contribution proof:</strong> Bank statements, wire transfers, capital account records</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Business license:</strong> For regulated industries requiring additional permits</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Clean record:</strong> No criminal convictions or previous visa violations in Vietnam</span>
          </li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Required Documents</h3>
        <ul class="space-y-2 text-neutral-700">
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">1.</span>
            <span>Visa application form (NA1 or NA2)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">2.</span>
            <span>Original passport with at least 6 months validity</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">3.</span>
            <span>2 passport-sized photos (4x6cm, white background)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">4.</span>
            <span>Investment Registration Certificate (IRC)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">5.</span>
            <span>Enterprise Registration Certificate (ERC)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">6.</span>
            <span>Proof of capital contribution (bank statements, transfer records)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">7.</span>
            <span>Company appointment letter confirming position</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">8.</span>
            <span>Business license (for regulated industries)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">9.</span>
            <span>Temporary residence registration at local police station</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Insurance Requirements -->
    <section id="insurance-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-amber-800 mb-2">Not Mandatory, But Essential</h3>
        <p class="text-amber-900">
          Vietnam does not legally require health insurance for investor visa applicants. However, international
          health insurance is <strong>strongly recommended</strong> for any foreign investor. Public hospitals have
          limited English capability and varying quality; private and international hospitals are expensive without
          insurance. Medical evacuation to Singapore or Bangkok is common for serious conditions.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Recommended Coverage</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Inpatient coverage: $500,000+ annual maximum</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Outpatient benefits for routine care</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Medical evacuation (Singapore/Bangkok)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Direct billing at international hospitals</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Social Insurance (Optional)</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Foreigners with work permits can join BHXH</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Covers public hospital care (limited)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>~3% of salary contribution</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Most expats prefer private insurance</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-blue-800 mb-2">Why Medical Evacuation Coverage is Critical</h3>
        <p class="text-blue-900 mb-4">
          Vietnam's best hospitals are concentrated in Ho Chi Minh City and Hanoi. For complex procedures—cardiac
          surgery, cancer treatment, neurosurgery—many expats evacuate to Singapore (2-hour flight) or Bangkok
          (1.5-hour flight). Medical evacuation costs $15,000-$50,000+ without insurance.
        </p>
        <ul class="space-y-2 text-blue-900">
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>Singapore: Mount Elizabeth, Raffles Hospital (world-class tertiary care)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>Bangkok: Bumrungrad, Bangkok Hospital (excellent value, JCI-accredited)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>Ensure your plan includes air ambulance and medical repatriation</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Recommended Insurance Providers -->
    <section id="recommended-providers" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

      <p class="text-neutral-700 mb-6">
        These international health insurance providers have strong networks in Vietnam and Southeast Asia, offering
        plans suitable for foreign investors with regional evacuation coverage.
      </p>

      <ComparisonTable
        columns={["Provider", "Annual Cost", "Best For", "Key Features"]}
        rows={[
          ["Cigna Global", "$2,500-$7,000", "Comprehensive coverage", "Strong Vietnam network, direct billing, Singapore/Bangkok evacuation"],
          ["Allianz Care", "$2,000-$6,000", "Regional coverage", "Excellent SEA network, 24/7 support, flexible plans"],
          ["Bupa Global", "$2,500-$8,000", "Premium expats", "Worldwide coverage, VIP service, top-tier hospitals"],
          ["Pacific Cross", "$1,500-$4,000", "Asia specialists", "Regional expertise, competitive pricing, good value"],
          ["Now Health", "$1,800-$5,000", "Mid-market option", "Flexible modules, Asia-Pacific focus, direct billing"]
        ]}
      />

      <div class="mt-6 grid md:grid-cols-2 gap-4">
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
