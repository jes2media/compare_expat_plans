---
/**
 * Panama Investor Visa - Long-form CRO-optimized page
 * Qualified Investor Visa, Friendly Nations Visa, and investment options
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Panama", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Panama Insurance Guide", href: "/countries/panama/insurance" },
  { title: "Panama Retirement Visa", href: "/visas/retirement-visa/in/panama" },
  { title: "Panama Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/panama" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Investment Required" },
  { key: "duration", header: "Duration" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "Qualified Investor Visa", investment: "$300,000+ real estate or bank deposit", duration: "2 years → PR", benefits: "Fast-track to permanent residence" },
  { program: "Friendly Nations Visa", investment: "$5,000 bank deposit + economic tie", duration: "2 years → PR", benefits: "Easiest for 50+ countries" },
  { program: "Reforestation Investor Visa", investment: "$80,000+ in teak/reforestation", duration: "2 years → PR", benefits: "Lower threshold, eco-investment" },
  { program: "Self-Economic Solvency", investment: "$300,000+ real estate", duration: "2 years → PR", benefits: "Pure property investment" },
  { program: "Small Business Investor", investment: "$160,000+ business capital", duration: "2 years → PR", benefits: "For business owners" },
];

const insuranceColumns = [
  { key: "program", header: "Visa Program" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "minimum", header: "Minimum Coverage" },
];

const insuranceRows = [
  { program: "Qualified Investor", requirement: "Recommended (not mandatory)", minimum: "N/A (recommend $100K+)" },
  { program: "Friendly Nations", requirement: "Recommended (not mandatory)", minimum: "N/A (recommend $100K+)" },
  { program: "Pensionado", requirement: "Recommended (not mandatory)", minimum: "N/A (recommend $100K+)" },
  { program: "Caja de Seguro Social", requirement: "Contribution-based", minimum: "After employment/voluntary contribution" },
  { program: "Private Expat Plans", requirement: "Optional", minimum: "Typically $100K-1M coverage" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$250-600", strengths: "Comprehensive, US coverage option" },
  { provider: "Allianz Care", type: "International", price: "$200-500", strengths: "Good value, Latin America network" },
  { provider: "IMG Global", type: "International", price: "$150-400", strengths: "Budget-friendly, flexible plans" },
  { provider: "BUPA Global", type: "International", price: "$300-700", strengths: "Premium coverage, Panama network" },
  { provider: "Pacific Prime", type: "International", price: "$200-500", strengths: "Americas specialist" },
  { provider: "CSS (local)", type: "Panamanian", price: "% of income", strengths: "Public system, contribution-based" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Qualified Investor (Real Estate)", amount: "$300,000+", notes: "Property retains value, generates rental" },
  { item: "Qualified Investor (Bank Deposit)", amount: "$300,000", notes: "Fixed for 3 years, earns interest" },
  { item: "Friendly Nations Bank Deposit", amount: "$5,000+", notes: "Economic tie + deposit" },
  { item: "Reforestation Investment", amount: "$80,000+", notes: "Teak or approved forestry project" },
  { item: "Legal Fees", amount: "$3,000-8,000", notes: "Immigration lawyer essential" },
  { item: "Processing Fees", amount: "$500-1,500", notes: "Government fees vary by visa" },
  { item: "Health Insurance", amount: "$2,000-8,000/year", notes: "International coverage" },
  { item: "E-Cedula (digital ID)", amount: "$100", notes: "Required for residents" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "Qualified Investor Visa", processing: "3-6 months", notes: "Straightforward with proper documentation" },
  { program: "Friendly Nations Visa", processing: "4-8 months", notes: "Requires economic tie documentation" },
  { program: "Reforestation Investor", processing: "3-6 months", notes: "Investment verification required" },
  { program: "Permanent Residence", processing: "2 years after initial visa", notes: "Automatic for most investor visas" },
  { program: "Citizenship", processing: "5 years as PR", notes: "By naturalization, Spanish required" },
];
---

<PageShell
  title="Panama Investor Visa 2026: Qualified Investor, Friendly Nations & PR Guide"
  description="Complete guide to Panama investor visas. Qualified Investor ($300K), Friendly Nations ($5K), Reforestation ($80K). Fast-track to permanent residence and citizenship."
  headline="Panama Investor Visa: Complete Guide"
  subheadline="Everything you need to know about Panama's investor visa options—Qualified Investor Visa, Friendly Nations, Reforestation Investment, and paths to permanent residence and citizenship in the Hub of the Americas."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/panama-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      USD Economy
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Panama offers one of the most investor-friendly immigration systems in the Americas. The Qualified Investor Visa provides a direct path to permanent residence with a $300,000 real estate or bank deposit investment. For citizens of 50+ "friendly nations" (including US, UK, Canada, and most EU countries), an even simpler option exists with just a $5,000 bank deposit and economic tie.
    </p>

    <p class="mb-4">
      Panama's advantages are compelling: US dollar economy (no currency risk), strategic location (Hub of the Americas), territorial tax system (foreign income not taxed), modern infrastructure, and a clear path to citizenship after 5 years of permanent residence. For North Americans and Europeans seeking a Latin American base, Panama is hard to beat.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Panama Investor Visas</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Qualified Investor:</strong> $300,000 real estate or bank deposit → PR</li>
        <li>• <strong>Friendly Nations:</strong> $5,000 deposit + economic tie → PR</li>
        <li>• <strong>Reforestation:</strong> $80,000+ in forestry → PR</li>
        <li>• <strong>Processing:</strong> 3-8 months depending on program</li>
        <li>• <strong>Permanent Residence:</strong> After 2 years on temporary visa</li>
        <li>• <strong>Citizenship:</strong> After 5 years as PR (Spanish required)</li>
        <li>• <strong>Currency:</strong> US Dollar (no exchange risk)</li>
        <li>• <strong>Taxes:</strong> Territorial (foreign income not taxed)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Panama?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• US dollar economy (no currency risk)</li>
          <li>• Territorial taxation (foreign income not taxed)</li>
          <li>• Modern infrastructure (Hub of Americas)</li>
          <li>• Clear path to citizenship</li>
          <li>• Pensionado discounts (famous retiree benefits)</li>
          <li>• Strategic location (Americas + Caribbean)</li>
          <li>• English widely spoken (business)</li>
          <li>• Established expat community</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• Hot and humid (tropical climate)</li>
          <li>• Rainy season (May-November)</li>
          <li>• Spanish essential outside Panama City</li>
          <li>• Healthcare quality varies</li>
          <li>• Traffic in Panama City</li>
          <li>• Bureaucracy can be slow</li>
          <li>• Higher cost than Central America neighbors</li>
          <li>• Limited domestic tourism options</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Tax advantage:</strong> Panama uses territorial taxation—you're only taxed on Panama-sourced income. Foreign income (US pension, rental income abroad, dividends from non-Panama investments) is not taxed. Combined with no capital gains tax on foreign investments, Panama is a popular choice for tax-efficient structuring.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Panama is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want US dollar economy</li>
          <li>• You have foreign income (territorial tax benefit)</li>
          <li>• You want path to citizenship</li>
          <li>• You prefer urban, modern lifestyle</li>
          <li>• You value Americas hub connectivity</li>
          <li>• You're from "Friendly Nations" list</li>
          <li>• You want clear, structured process</li>
          <li>• You appreciate retiree discounts</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You prefer cooler climate</li>
          <li>• You want lower cost of living (try Ecuador)</li>
          <li>• You don't speak any Spanish</li>
          <li>• You want beach/rural lifestyle (try Costa Rica)</li>
          <li>• You prefer European culture</li>
          <li>• You need world-class healthcare</li>
          <li>• You dislike hot, humid weather</li>
          <li>• You want faster citizenship (try Paraguay)</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Panama vs. Latin America Alternatives</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investor Route</th>
            <th class="px-4 py-2 text-left">Investment</th>
            <th class="px-4 py-2 text-left">Citizenship Timeline</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Panama</td>
            <td class="px-4 py-2">Qualified Investor / Friendly Nations</td>
            <td class="px-4 py-2">$300K / $5K</td>
            <td class="px-4 py-2">~7 years (2 yr visa + 5 yr PR)</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Costa Rica</td>
            <td class="px-4 py-2">Investor Visa</td>
            <td class="px-4 py-2">$150K+</td>
            <td class="px-4 py-2">~10 years (7 yr residency)</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Mexico</td>
            <td class="px-4 py-2">Residente Permanente</td>
            <td class="px-4 py-2">Income/asset based</td>
            <td class="px-4 py-2">~9 years (5 yr residence)</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Paraguay</td>
            <td class="px-4 py-2">SUACE Business</td>
            <td class="px-4 py-2">$5K bank deposit</td>
            <td class="px-4 py-2">~3-5 years (fastest)</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Ecuador</td>
            <td class="px-4 py-2">Investor Visa</td>
            <td class="px-4 py-2">$42,500+</td>
            <td class="px-4 py-2">~5 years (3 yr residence)</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Friendly Nations advantage:</strong> If you're from the US, UK, Canada, Australia, or most EU countries, the Friendly Nations Visa offers an incredibly low barrier—just $5,000 bank deposit and proof of economic activity (employment, business, or pension). It's one of the easiest residency paths in the Americas.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Panama offers multiple pathways depending on your nationality, investment capacity, and goals. The Qualified Investor Visa is straightforward for anyone; Friendly Nations is easier but nationality-restricted.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Qualified Investor Visa (Visa de Inversionista Calificado)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The most straightforward investor visa for any nationality. Invest $300,000+ and receive residency:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Real Estate Investment</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Minimum: <strong>$300,000</strong> property purchase</li>
            <li>• Can be any real estate (residential, commercial)</li>
            <li>• Multiple properties allowed to reach $300K</li>
            <li>• Property retains value, can generate rental</li>
            <li>• Title must be free and clear</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Bank Deposit / CD</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Minimum: <strong>$300,000</strong> fixed deposit</li>
            <li>• Must be in Panamanian bank</li>
            <li>• Fixed for 3 years minimum</li>
            <li>• Earns interest (~3-5%/year)</li>
            <li>• Cannot be withdrawn during visa period</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Process & Timeline</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Apply with proof of investment</li>
            <li>• 2-year temporary residence first</li>
            <li>• Convert to permanent residence</li>
            <li>• Citizenship after 5 years as PR</li>
            <li>• Processing: 3-6 months</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Family Inclusion</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Spouse included</li>
            <li>• Children under 18 included</li>
            <li>• Additional dependents possible</li>
            <li>• All receive same visa status</li>
            <li>• Small additional fees</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Friendly Nations Visa (Visa de Países Amigos)</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For citizens of 50+ countries with economic ties to Panama. One of the easiest residency paths in the Americas:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Requirements</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Bank account with <strong>$5,000+</strong> deposit</li>
            <li>• Plus ONE economic tie:</li>
            <li>  → Employment by Panamanian company, OR</li>
            <li>  → Own a Panamanian business, OR</li>
            <li>  → Own Panama real estate (any value)</li>
            <li>• Passport from Friendly Nation</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Eligible Countries (Partial List)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• United States, Canada</li>
            <li>• United Kingdom, Ireland</li>
            <li>• Germany, France, Spain, Italy</li>
            <li>• Australia, New Zealand</li>
            <li>• Japan, South Korea, Singapore</li>
            <li>• Most EU/Schengen countries</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Common Economic Ties</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• <strong>Real estate:</strong> Buy any property (no minimum)</li>
            <li>• <strong>Corporation:</strong> Form Panama company (~$1,500)</li>
            <li>• <strong>Employment:</strong> Work for Panama company</li>
            <li>• Most choose property or corporation</li>
            <li>• Property can be very modest</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Process</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• 2-year temporary residence</li>
            <li>• Convert to permanent residence</li>
            <li>• Same citizenship path as Qualified Investor</li>
            <li>• Processing: 4-8 months</li>
            <li>• Lower cost than Qualified Investor</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Reforestation Investor Visa</h3>

    <div class="border-l-4 border-green-600 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Invest in government-approved forestry projects (typically teak) for a lower investment threshold:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Minimum investment: <strong>$80,000</strong> in approved reforestation project</li>
        <li>Typically teak plantations or similar forestry</li>
        <li>Long-term investment (15-25 years to maturity)</li>
        <li>Potential ROI from timber harvest</li>
        <li>Same residency path as Qualified Investor</li>
      </ul>

      <p class="text-neutral-600">Best for those wanting lower initial investment with long-term, eco-conscious approach. Risk: dependent on forestry project success.</p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Self-Economic Solvency Visa</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Pure property investment route without the "Qualified Investor" label:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Invest <strong>$300,000+</strong> in Panama real estate</li>
        <li>Similar to Qualified Investor but property-only</li>
        <li>Slightly different documentation requirements</li>
        <li>Same path to permanent residence and citizenship</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> Panama residency does not require you to live in Panama full-time. Many residents maintain property/investment and visit periodically. However, for citizenship, you must demonstrate genuine ties and physical presence (typically 180+ days/year for citizenship application).
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">No Mandatory Insurance for Investor Visas</h3>
      <p class="text-green-800">
        Panama does not require health insurance for investor visa applications. However, Panama's public healthcare (CSS) requires contributions, and private care requires payment or insurance. International health insurance is strongly recommended for quality care and peace of mind.
      </p>
    </div>

    <p class="mb-4">
      Panama has a two-tier healthcare system: the public Caja de Seguro Social (CSS) for contributors, and private hospitals for those with insurance or cash. Private hospitals in Panama City (Punta Pacífica, Hospital Nacional) offer excellent care but expect payment upfront.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Panama</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Cigna, Allianz, BUPA, IMG</li>
          <li>• Premium: $200-700/month</li>
          <li>• Global coverage (US option available)</li>
          <li>• Direct billing at private hospitals</li>
          <li>• English-speaking support</li>
          <li>• Medical evacuation to US included</li>
          <li>• No contribution requirements</li>
          <li>• Best for expats and travelers</li>
        </ul>
