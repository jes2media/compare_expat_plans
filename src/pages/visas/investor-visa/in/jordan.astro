---
import Layout from '../../../../layouts/Layout.astro';
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const title = "Jordan Investor Visa & Residency Guide 2025";
const description = "Complete guide to Jordan's investor residency program. Investment options from $100,000+, 5-year renewable residence, excellent healthcare in Amman, and strategic MENA location.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Compare Expat Plans"
  },
  "datePublished": "2025-01-15",
  "dateModified": "2025-01-15"
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <PageShell
    title={title}
    subtitle="Your complete guide to investor residency in Jordan"
    heroImage="/images/countries/jordan-hero-bg.png"
  >
    <!-- Quick Facts Box -->
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-bold text-primary-900 mb-4">Jordan Investor Residency: Quick Facts</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="font-semibold text-neutral-700">Minimum Investment:</span>
          <span class="text-neutral-900"> $100,000+ (varies by type)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Residency Duration:</span>
          <span class="text-neutral-900"> 5 years (renewable)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Processing Time:</span>
          <span class="text-neutral-900"> 2-4 months</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Path to Citizenship:</span>
          <span class="text-neutral-900"> Possible after 15+ years (discretionary)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Healthcare Quality:</span>
          <span class="text-neutral-900"> Excellent in Amman (medical tourism hub)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Insurance Requirement:</span>
          <span class="text-neutral-900"> Required for residency</span>
        </div>
      </div>
    </div>

    <!-- Overview Section -->
    <section id="overview" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>
      <p class="text-neutral-700 mb-4">
        Jordan offers investor residency for those seeking a foothold in the stable, strategically-located Hashemite
        Kingdom. Positioned at the crossroads of the Middle East, Jordan provides access to regional markets while
        maintaining political stability, Western-friendly relations, and a well-educated English-speaking workforce.
        The country has become a regional hub for business, technology, and medical tourism.
      </p>
      <p class="text-neutral-700 mb-4">
        Investment options range from company formation and real estate to bank deposits and government bonds.
        The 5-year renewable residency allows investors and their families to live, work, and access Jordan's
        excellent healthcare system. While citizenship is possible after extended residence (15+ years), it remains
        discretionary—Jordan doesn't offer citizenship by investment.
      </p>
      <p class="text-neutral-700 mb-4">
        Healthcare is a major draw: Amman hosts world-class hospitals that attract medical tourists from across
        the Middle East. King Hussein Cancer Center, Jordan Hospital, and specialty clinics offer care at
        significantly lower costs than Western countries. Health insurance is required for residency and widely
        available from international and local providers.
      </p>
    </section>

    <!-- Quick Decision Guide -->
    <section id="decision-guide" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-green-800 mb-3">Jordan Investor Residency is Ideal If You:</h3>
          <ul class="space-y-2 text-green-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Want a stable base in the Middle East</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Value excellent, affordable healthcare (medical tourism hub)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Seek business opportunities in MENA region</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Prefer lower cost of living than Gulf states</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Value English-speaking environment with rich culture</span>
            </li>
          </ul>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-amber-800 mb-3">Consider Alternatives If You:</h3>
          <ul class="space-y-2 text-amber-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Need guaranteed citizenship path (not available via investment)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Want tax-free income (Jordan taxes worldwide income)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Prefer Gulf-level infrastructure (choose UAE)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Need strong passport for visa-free travel</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Concerned about regional instability (neighbors include Syria, Iraq)</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Official Requirements -->
    <section id="requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Official Requirements</h2>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Investment Options</h3>

        <div class="space-y-6">
          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 1: Company Investment</h4>
            <p class="text-neutral-700 mt-2">
              Establish or invest in a Jordanian company. The most common route for active investors seeking
              business involvement in Jordan's economy.
            </p>
            <ul class="mt-3 space-y-1 text-neutral-600 text-sm">
              <li>• Minimum capital: JOD 50,000 (~$70,000) for standard sectors</li>
              <li>• Higher thresholds for specific industries</li>
              <li>• Must maintain active business operations</li>
              <li>• Creates employment for Jordanians (encouraged)</li>
            </ul>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 2: Bank Deposit</h4>
            <p class="text-neutral-700 mt-2">
              Time deposit in a Jordanian bank. Simpler option for passive investors who don't want
              business involvement.
            </p>
            <ul class="mt-3 space-y-1 text-neutral-600 text-sm">
              <li>• Minimum deposit: JOD 100,000 (~$140,000)</li>
              <li>• Must be maintained for residency duration</li>
              <li>• Interest earned is taxable</li>
              <li>• Deposit frozen during residency period</li>
            </ul>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 3: Real Estate Investment</h4>
            <p class="text-neutral-700 mt-2">
              Purchase of Jordanian real estate. Foreigners can own property in Jordan subject to
              Cabinet approval.
            </p>
            <ul class="mt-3 space-y-1 text-neutral-600 text-sm">
              <li>• Minimum investment: JOD 100,000+ (~$140,000+)</li>
              <li>• Cabinet approval required for foreigners</li>
              <li>• Property can generate rental income</li>
              <li>• Amman and Dead Sea areas most popular</li>
            </ul>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 4: Government Bonds/Treasury</h4>
            <p class="text-neutral-700 mt-2">
              Investment in Jordanian government securities. Provides fixed returns while qualifying
              for residency.
            </p>
            <ul class="mt-3 space-y-1 text-neutral-600 text-sm">
              <li>• Minimum investment: JOD 150,000+ (~$210,000+)</li>
              <li>• Government-backed security</li>
              <li>• Interest paid during holding period</li>
              <li>• Less common option</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Eligibility Criteria</h3>
        <ul class="space-y-3 text-neutral-700">
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Clean record:</strong> No criminal convictions, not on international sanctions lists</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Valid passport:</strong> At least 6 months validity</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Health insurance:</strong> Valid coverage in Jordan required</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Source of funds:</strong> Legitimate and documented</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Dependents:</strong> Spouse and children can be included</span>
          </li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Required Documents</h3>
        <ul class="space-y-2 text-neutral-700">
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">1.</span>
            <span>Valid passport (copy and original for verification)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">2.</span>
            <span>Passport photos (white background)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">3.</span>
            <span>Police clearance from country of origin</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">4.</span>
            <span>Medical certificate</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">5.</span>
            <span>Proof of investment (company registration, bank deposit certificate, property deed)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">6.</span>
            <span>Bank statements showing source of funds</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">7.</span>
            <span>Marriage/birth certificates for dependents (translated to Arabic)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">8.</span>
            <span>Health insurance certificate valid in Jordan</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">9.</span>
            <span>Proof of address in Jordan (rental contract or property ownership)</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Insurance Requirements -->
    <section id="insurance-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-amber-800 mb-2">Health Insurance Required</h3>
        <p class="text-amber-900">
          Jordan requires valid health insurance for residency applications. While specific coverage minimums
          aren't always mandated, comprehensive coverage is expected. Jordan's excellent healthcare means most
          care can be obtained locally, but international plans with regional coverage provide added flexibility.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Recommended Coverage</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Annual maximum: $500,000+ recommended</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Inpatient and outpatient coverage</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Direct billing at Jordan's private hospitals</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Regional coverage (including Israel for emergencies)</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Jordan's Healthcare Advantage</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Regional medical tourism hub</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>JCI-accredited hospitals</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>World-class oncology (King Hussein Cancer Center)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>50-70% lower costs than Western countries</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-blue-800 mb-2">Local Insurance Options</h3>
        <p class="text-blue-900 mb-4">
          Jordan has a developed insurance market with options for residents:
        </p>
        <ul class="space-y-2 text-blue-900">
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span><strong>Local insurers:</strong> Jordan Insurance, Middle East Insurance, Arab Orient</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span><strong>International:</strong> Cigna, Allianz, Bupa (all have Jordan networks)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span><strong>Cost:</strong> Local plans ~$1,000-$3,000/year; international $2,000-$6,000/year</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Recommended Insurance Providers -->
    <section id="recommended-providers" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

      <p class="text-neutral-700 mb-6">
        These providers offer plans suitable for Jordan investor residents, with strong local networks and
        regional coverage.
      </p>

      <ComparisonTable
        columns={["Provider", "Annual Cost", "Best For", "Key Features"]}
        rows={[
          ["Cigna Global", "$2,500-$6,000", "Comprehensive coverage", "Direct billing at Jordan hospitals, MENA coverage, evacuation"],
          ["Allianz Care", "$2,000-$5,500", "Regional focus", "Strong Middle East network, 24/7 Arabic support"],
          ["Bupa Global", "$2,500-$7,000", "Premium service", "No network restrictions, Jordan Hospital direct billing"],
          ["Now Health", "$1,500-$4,000", "Value option", "MENA specialists, competitive pricing, good coverage"],
          ["Local Plans", "$1,000-$3,000", "Budget option", "Jordan Insurance, Arab Orient - local facilities only"]
        ]}
      />

      <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
