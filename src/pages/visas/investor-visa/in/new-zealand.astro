  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
  { title: "Allianz Care Review", href: "/providers/allianz-care" },
];

const investorColumns = [
  { key: "option", header: "Investment Pathway" },
  { key: "minimum", header: "Minimum Investment" },
  { key: "duration", header: "Investment Period" },
  { key: "notes", header: "Key Notes" },
];

const investorRows = [
  { option: "Direct Investment (Growth)", minimum: "NZD 5 million", duration: "4 years", notes: "Growth-stage NZ businesses, equities, managed funds" },
  { option: "Listed Equities Pathway", minimum: "NZD 10 million", duration: "4 years", notes: "Includes NZX-listed company shares" },
  { option: "Residential Property Pathway", minimum: "NZD 15 million", duration: "4 years", notes: "Can include residential property investment" },
  { option: "Entrepreneur Work Visa", minimum: "NZD 100,000", duration: "3 years (renewable)", notes: "High-value business establishment" },
  { option: "Entrepreneur Resident Visa", minimum: "NZD 100,000 (from Work Visa)", duration: "After 2 years", notes: "Pathway from successful Entrepreneur Work Visa" },
