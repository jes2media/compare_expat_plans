  { step: "Invitation to apply (if EOI accepted)", duration: "Within 2-3 months", location: "Immigration NZ" },
  { step: "Prepare full application documents", duration: "4-8 weeks", location: "Home country/NZ" },
  { step: "Submit complete application", duration: "1 day", location: "Immigration NZ online" },
  { step: "Application processing", duration: "3-6 months", location: "Immigration NZ" },
  { step: "Approval and visa issued", duration: "After processing", location: "Immigration NZ" },
  { step: "Transfer funds to NZ", duration: "12 months from approval", location: "NZ banks/investments" },
  { step: "Maintain investment period", duration: "4 years", location: "New Zealand" },
  { step: "Apply for residence", duration: "After investment period", location: "Immigration NZ" },
