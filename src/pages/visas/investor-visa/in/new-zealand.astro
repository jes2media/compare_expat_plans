  { key: "requirement", header: "Investor Visa Status" },
  { key: "notes", header: "Practical Considerations" },
];

const insuranceRows = [
  { feature: "Health Insurance", requirement: "Strongly recommended (not mandatory)", notes: "No public healthcare for non-residents" },
  { feature: "ACC Coverage", requirement: "Automatic for everyone", notes: "Covers accidents and injuries only" },
  { feature: "Coverage Duration", requirement: "Full visa period recommended", notes: "Until eligible for residence" },
  { feature: "Minimum Coverage", requirement: "No official minimum", notes: "Comprehensive coverage advisable" },
  { feature: "Pre-existing Conditions", requirement: "Not covered initially", notes: "Waiting periods apply" },
  { feature: "Family Coverage", requirement: "Recommended for dependents", notes: "Each family member should have coverage" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "NZD 350-700", strengths: "High-net-worth investors, global coverage" },
  { provider: "Allianz Care", type: "International", price: "NZD 300-600", strengths: "Flexible plans, worldwide network" },
  { provider: "Bupa Global", type: "International", price: "NZD 400-750", strengths: "Premium service, family coverage" },
  { provider: "Southern Cross", type: "NZ Private", price: "NZD 150-350", strengths: "Established NZ insurer, local network" },
  { provider: "nib", type: "NZ Private", price: "NZD 140-320", strengths: "Good value, NZ-focused coverage" },
