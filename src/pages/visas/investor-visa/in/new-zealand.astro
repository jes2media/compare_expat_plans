const costRows = [
  { item: "Active Investor Plus Application", amount: "NZD 4,310", notes: "Non-refundable application fee" },
  { item: "Entrepreneur Work Visa Application", amount: "NZD 2,440", notes: "Initial application fee" },
  { item: "Entrepreneur Resident Visa", amount: "NZD 3,170", notes: "After successful business operation" },
  { item: "Immigration Levy", amount: "NZD 420", notes: "Added to application fees" },
  { item: "Investment Minimum", amount: "NZD 5-15 million", notes: "Depending on investment pathway" },
  { item: "Health Insurance", amount: "NZD 3,000-8,000/year", notes: "Recommended comprehensive coverage" },
  { item: "Legal/Advisory Fees", amount: "NZD 15,000-50,000", notes: "Immigration and investment advisors" },
  { item: "English Test (IELTS)", amount: "NZD 385", notes: "If required" },
