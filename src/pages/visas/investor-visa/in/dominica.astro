---
/**
 * Dominica Citizenship by Investment - Long-form CRO-optimized page
 * Most affordable Caribbean CBI, Nature Isle, eco-tourism focus
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Dominica", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "St. Kitts Investor Visa", href: "/visas/investor-visa/in/st-kitts-and-nevis" },
  { title: "Grenada Investor Visa", href: "/visas/investor-visa/in/grenada" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Investment Route" },
  { key: "investment", header: "Minimum Investment" },
  { key: "timeline", header: "Processing Time" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "Economic Diversification Fund (EDF)", investment: "$100,000 (single)", timeline: "3-4 months", benefits: "Lowest cost CBI globally" },
  { program: "EDF Family", investment: "$175,000 (family of 4)", timeline: "3-4 months", benefits: "Excellent family value" },
  { program: "Real Estate Investment", investment: "$200,000 (3-year hold)", timeline: "3-4 months", benefits: "Asset ownership, resellable" },
  { program: "Government Housing Project", investment: "$200,000+", timeline: "3-4 months", benefits: "Social housing contribution" },
];

const insuranceColumns = [
  { key: "situation", header: "Situation" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "recommendation", header: "Recommended Coverage" },
];

const insuranceRows = [
  { situation: "CBI Application", requirement: "Not mandatory", recommendation: "International coverage recommended" },
  { situation: "Residing in Dominica", requirement: "No mandatory insurance", recommendation: "$100,000+ with evacuation" },
  { situation: "Visiting/Tourism", requirement: "Travel insurance recommended", recommendation: "Regional Caribbean plan" },
  { situation: "Global Travelers", requirement: "N/A", recommendation: "Worldwide coverage" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$300-600", strengths: "Global coverage, evacuation" },
  { provider: "Allianz Care", type: "International", price: "$250-500", strengths: "Worldwide network" },
  { provider: "IMG Global", type: "International", price: "$200-450", strengths: "Flexible, evacuation included" },
  { provider: "Sagicor", type: "Regional Caribbean", price: "$150-350", strengths: "Caribbean specialist" },
  { provider: "CLICO", type: "Regional Caribbean", price: "$100-250", strengths: "Eastern Caribbean focus" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "EDF Contribution (Single)", amount: "$100,000", notes: "Non-refundable donation" },
  { item: "EDF Contribution (Couple)", amount: "$150,000", notes: "Main applicant + spouse" },
  { item: "EDF Family (4)", amount: "$175,000", notes: "Couple + 2 children under 18" },
  { item: "EDF Additional Dependent", amount: "$25,000-50,000", notes: "Varies by age" },
  { item: "Real Estate Minimum", amount: "$200,000", notes: "3-year holding period" },
  { item: "Due Diligence (Main)", amount: "$7,500", notes: "Per main applicant" },
  { item: "Due Diligence (Spouse)", amount: "$4,000", notes: "Per spouse" },
  { item: "Due Diligence (Dependent)", amount: "$4,000", notes: "Per dependent 16+" },
  { item: "Government Processing Fee", amount: "$1,000", notes: "Per application" },
  { item: "Legal/Agent Fees", amount: "$10,000-25,000", notes: "Authorized agent required" },
];

const timelineColumns = [
  { key: "stage", header: "Stage" },
  { key: "duration", header: "Duration" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { stage: "Document Preparation", duration: "2-4 weeks", notes: "Gather and apostille documents" },
  { stage: "Application Submission", duration: "1 week", notes: "Via authorized agent" },
  { stage: "Due Diligence", duration: "6-8 weeks", notes: "Background verification" },
  { stage: "Approval in Principle", duration: "Week 8-10", notes: "Conditional approval" },
  { stage: "Investment Payment", duration: "1-2 weeks", notes: "Complete EDF or real estate" },
  { stage: "Citizenship Certificate", duration: "1-2 weeks", notes: "Certificate issued" },
  { stage: "Passport Application", duration: "2-4 weeks", notes: "Passport processing" },
  { stage: "Total", duration: "3-4 months", notes: "Standard timeline" },
];
---

<PageShell
  title="Dominica Citizenship by Investment 2026: Most Affordable CBI Guide"
  description="Complete guide to Dominica CBI. $100K EDF donation (lowest cost CBI), 145 countries visa-free, 3-4 month processing, Nature Isle Caribbean citizenship."
  headline="Dominica Citizenship by Investment: Complete Guide"
  subheadline="Everything you need to know about the world's most affordable citizenship by investment—$100K donation for Dominica passport with visa-free access to 145 countries including UK, EU Schengen, and Singapore. The 'Nature Isle' offers excellent value CBI."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/dominica-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official CBI Unit Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Most Affordable CBI
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Dominica offers the world's most affordable legitimate citizenship by investment program at $100,000 for single applicants. Known as the "Nature Isle of the Caribbean," this small island nation has operated its CBI program since 1993, providing visa-free access to 145 countries including the UK, EU Schengen zone, and Singapore.
    </p>

    <p class="mb-4">
      Despite its low cost, Dominica maintains rigorous due diligence standards and a respected passport. The country uses CBI funds for hurricane recovery (Hurricane Maria 2017), housing development, and economic diversification. For budget-conscious applicants seeking legitimate second citizenship, Dominica offers unmatched value.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Dominica CBI Program</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>EDF Donation:</strong> $100,000 single / $175,000 family of 4</li>
        <li>• <strong>Real Estate:</strong> $200,000 minimum (3-year hold)</li>
        <li>• <strong>Processing:</strong> 3-4 months standard</li>
        <li>• <strong>Visa-free travel:</strong> 145 countries (UK, EU, Singapore)</li>
        <li>• <strong>Dual citizenship:</strong> Fully permitted</li>
        <li>• <strong>Residency required:</strong> No physical presence requirement</li>
        <li>• <strong>Passport validity:</strong> 10 years, renewable</li>
        <li>• <strong>Tax benefits:</strong> No income tax on worldwide income</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Dominica?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Lowest cost legitimate CBI globally</li>
          <li>• 145 countries visa-free (UK, EU)</li>
          <li>• No residency requirement</li>
          <li>• Established since 1993</li>
          <li>• Family-friendly pricing</li>
          <li>• Include parents and siblings</li>
          <li>• No income/capital gains tax</li>
          <li>• Commonwealth membership</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• No US visa-free travel</li>
          <li>• Fewer visa-free countries than St. Kitts</li>
          <li>• Very limited healthcare</li>
          <li>• Hurricane vulnerable zone</li>
          <li>• Small, undeveloped economy</li>
          <li>• Limited flight connections</li>
          <li>• Processing slower than St. Kitts</li>
          <li>• EDF donation non-refundable</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Best value CBI:</strong> Dominica consistently ranks as the best value Caribbean CBI program. At $100,000 vs. $250,000 (St. Kitts), you save $150,000 with only slightly fewer visa-free destinations (145 vs. 157). For budget-focused applicants, the cost difference often outweighs the marginal travel benefit difference.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Dominica CBI is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• Budget is primary consideration</li>
          <li>• You want UK/EU visa-free travel</li>
          <li>• You don't need US visa-free access</li>
          <li>• You have clean background</li>
          <li>• You want legitimate, established program</li>
          <li>• You're including family (best value)</li>
          <li>• You want no residency requirement</li>
          <li>• Commonwealth citizenship appeals</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need US E-2 treaty access (Grenada)</li>
          <li>• Maximum visa-free countries matter (St. Kitts)</li>
          <li>• You want fastest processing (St. Kitts 45 days)</li>
          <li>• You plan to actually live there</li>
          <li>• Real estate investment priority</li>
          <li>• You want premium "brand" passport</li>
          <li>• You need EU citizenship (Malta/Portugal)</li>
          <li>• Healthcare access matters</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Dominica vs. Other Caribbean CBI Programs</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Minimum Investment</th>
            <th class="px-4 py-2 text-left">Processing</th>
            <th class="px-4 py-2 text-left">Visa-Free Countries</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b bg-green-50">
            <td class="px-4 py-2 font-medium">Dominica</td>
            <td class="px-4 py-2 font-semibold text-green-700">$100,000</td>
            <td class="px-4 py-2">3-4 months</td>
            <td class="px-4 py-2">145</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Antigua & Barbuda</td>
            <td class="px-4 py-2">$100,000</td>
            <td class="px-4 py-2">3-4 months</td>
            <td class="px-4 py-2">151</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Grenada</td>
            <td class="px-4 py-2">$150,000</td>
            <td class="px-4 py-2">4-6 months</td>
            <td class="px-4 py-2">146 + US E-2</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">St. Kitts and Nevis</td>
            <td class="px-4 py-2">$250,000</td>
            <td class="px-4 py-2">45-60 days</td>
            <td class="px-4 py-2">157</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Why Dominica wins on value:</strong> At $100,000, Dominica matches Antigua's price but has stronger due diligence reputation. The 145 visa-free countries cover all major destinations (UK, EU, Singapore). The $150,000 savings vs. St. Kitts can fund years of travel or other investments.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Dominica offers two main pathways: a non-refundable contribution to the Economic Diversification Fund (EDF) or investment in government-approved real estate. The EDF route is simpler and cheaper; real estate provides asset ownership with 3-year holding requirement.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Option 1: Economic Diversification Fund (EDF)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Non-refundable contribution to the government fund used for national development:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Single Applicant</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $100,000</li>
            <li>• Due diligence: $7,500</li>
            <li>• Processing fee: $1,000</li>
            <li>• Lowest cost CBI globally</li>
            <li>• No ongoing obligations</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Couple</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $150,000</li>
            <li>• Due diligence: $11,500</li>
            <li>• Spouse included</li>
            <li>• Only $50,000 more than single</li>
            <li>• Excellent couple value</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Family of Four</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $175,000</li>
            <li>• Includes spouse + 2 children under 18</li>
            <li>• Due diligence varies by age</li>
            <li>• Best family value in Caribbean</li>
            <li>• Children under 16: no DD fee</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Additional Dependents</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Children under 18: $25,000 each</li>
            <li>• Dependents 18-30: $50,000 each</li>
            <li>• Parents 55+: $50,000 each</li>
            <li>• Siblings under 25: $50,000 each</li>
            <li>• Must be financially dependent</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Option 2: Real Estate Investment</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Purchase government-approved real estate for asset ownership:</p>

      <div class="space-y-4">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Standard Real Estate ($200,000)</h4>
          <p class="text-neutral-700 text-sm">Purchase in approved development. 3-year holding period (shorter than St. Kitts' 7 years). Can sell to another CBI applicant after 3 years. Government fees additional (~$25,000). Rental income possible during holding period.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Approved Projects</h4>
          <p class="text-neutral-700 text-sm">Eco-tourism resorts, Cabrits Resort Kempinski (flagship), hotel shares, approved developments. Limited inventory—Dominica is small. Must be government pre-approved property. Agent can advise on current availability.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Real Estate vs. EDF</h4>
          <p class="text-neutral-700 text-sm">Real estate costs $200,000 minimum vs. $100,000 EDF—a $100,000 difference. You get an asset, but Dominica real estate has limited liquidity and appreciation potential. Most applicants (80%+) choose EDF for simplicity and lower cost.</p>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Eligible Family Members</h3>

    <div class="bg-neutral-50 rounded-lg p-6 mb-6">
      <ul class="space-y-2 text-neutral-700">
        <li>• <strong>Spouse:</strong> Legally married spouse</li>
        <li>• <strong>Children under 18:</strong> Included automatically</li>
        <li>• <strong>Children 18-30:</strong> If financially dependent, full-time students</li>
        <li>• <strong>Parents/Grandparents 55+:</strong> If financially dependent on applicant</li>
        <li>• <strong>Unmarried siblings under 25:</strong> If financially dependent</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Agent requirement:</strong> Like all Caribbean CBI programs, Dominica requires applications through licensed agents. You cannot apply directly. Budget $10,000-25,000 for agent fees. Verify agents on the official Dominica CBI website.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">No Insurance Required for CBI</h3>
      <p class="text-green-800">
        Dominica does not require health insurance for citizenship application or maintenance. However, if you visit or reside on the island, comprehensive coverage with medical evacuation is essential. Dominica has very limited healthcare facilities—serious conditions require evacuation.
      </p>
    </div>

    <p class="mb-4">
      Most Dominica CBI citizens never actually visit the island—they obtain citizenship for passport and travel benefits while living elsewhere. Princess Margaret Hospital in Roseau provides basic services but lacks advanced care. Evacuation to Martinique, Barbados, or Miami is necessary for serious conditions.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Strategy</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Passport Holders (Non-Resident)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Keep insurance from your actual residence</li>
          <li>• Add travel insurance for Caribbean trips</li>
          <li>• No Dominica-specific coverage needed</li>
          <li>• Dominica citizenship doesn't affect insurance needs</li>
          <li>• Most CBI holders never visit the island</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Visitors or Residents</h4>
        <ul class="space-y-2 text-green-800">
          <li>• International insurance mandatory</li>
          <li>• Medical evacuation coverage essential</li>
          <li>• Martinique (40 min) for French healthcare</li>
          <li>• Barbados or Miami for complex care</li>
          <li>• Budget $300-500/month minimum</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Reality:</strong> Dominica's population is ~75,000 with one small hospital. If you actually plan to spend time there (eco-tourism, diving, hiking), ensure robust evacuation coverage. Most CBI citizens use the passport for travel freedom while living in countries with proper healthcare.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need international health coverage?"
    description="Compare global insurance options with evacuation benefits for Caribbean travel."
    buttonText="Compare Premium Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Dominica CBI citizens traveling internationally or visiting the Caribbean, these providers offer appropriate coverage:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">International Travelers</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care for worldwide coverage. Your Dominica passport enables visa-free travel to 145 countries—international coverage ensures you're protected everywhere. Budget $300-500/month for comprehensive coverage.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Caribbean Visitors</h4>
        <p class="text-neutral-600">IMG Global or regional Caribbean insurers work well if you're primarily in the Caribbean. Key requirement: medical evacuation to Martinique, Barbados, or Miami. Caribbean specialists (Sagicor, CLICO) understand regional networks.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Existing Coverage</h4>
