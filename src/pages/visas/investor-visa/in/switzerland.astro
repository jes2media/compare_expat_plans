---
/**
 * Switzerland Investor/Wealthy Resident Visa - Long-form CRO-optimized page
 * Lump-sum taxation (forfait fiscal) route for high-net-worth individuals
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-requirements", text: "Requirements & Pathways", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Switzerland", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Switzerland Health Insurance Guide", href: "/countries/switzerland/insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Insurance for Pre-existing Conditions", href: "/insurance-for/pre-existing-conditions" },
];

const pathwayColumns = [
  { key: "pathway", header: "Residence Pathway" },
  { key: "requirement", header: "Key Requirement" },
  { key: "taxation", header: "Tax Treatment" },
];

const pathwayRows = [
  { pathway: "Lump-Sum Taxation (Forfait Fiscal)", requirement: "CHF 400,000+ annual tax minimum", taxation: "Based on living expenses, not income/assets" },
  { pathway: "Wealthy Resident (Cantonal)", requirement: "CHF 1-10M+ assets (varies by canton)", taxation: "Regular Swiss taxation or lump-sum" },
  { pathway: "Company Formation", requirement: "Establish/invest in Swiss company", taxation: "Standard corporate + personal tax" },
  { pathway: "Entrepreneur Visa", requirement: "Create jobs, invest in Swiss economy", taxation: "Standard Swiss taxation" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "requirement", header: "Swiss Requirement" },
  { key: "recommendation", header: "Our Recommendation" },
];

const insuranceRows = [
  { feature: "Basic Health Insurance", requirement: "MANDATORY (LAMal)", recommendation: "Required within 3 months of arrival" },
  { feature: "Coverage Type", requirement: "Swiss-regulated basic insurance", recommendation: "Add supplementary (Zusatzversicherung)" },
  { feature: "Provider", requirement: "Swiss insurer (60+ options)", recommendation: "Compare cantons - premiums vary 50%+" },
  { feature: "Deductible (Franchise)", requirement: "CHF 300-2,500 annual", recommendation: "Higher franchise = lower premium" },
  { feature: "International Coverage", requirement: "Basic = Switzerland only", recommendation: "Add travel/international supplement" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost (CHF)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "CSS", type: "Swiss (LAMal)", price: "350-600", strengths: "Large network, good service" },
  { provider: "Helsana", type: "Swiss (LAMal)", price: "340-580", strengths: "Strong supplementary options" },
  { provider: "Swica", type: "Swiss (LAMal)", price: "360-620", strengths: "Premium service, alternative medicine" },
  { provider: "Cigna Global", type: "International (supplement)", price: "400-800", strengths: "Worldwide coverage for travel" },
  { provider: "BUPA Global", type: "International (supplement)", price: "450-900", strengths: "Global coverage, premium service" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (CHF)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Minimum Annual Tax (Lump-Sum)", amount: "400,000-600,000+", notes: "Varies by canton, negotiated" },
  { item: "Permit B Application", amount: "100-500", notes: "Cantonal fee" },
  { item: "Immigration Lawyer", amount: "10,000-50,000", notes: "Essential for lump-sum negotiation" },
  { item: "Tax Advisor", amount: "5,000-20,000/year", notes: "Ongoing tax planning" },
  { item: "Health Insurance (Basic)", amount: "350-600/month", notes: "Per person, canton dependent" },
  { item: "Health Insurance (Supplementary)", amount: "100-500/month", notes: "Optional but recommended" },
  { item: "Cost of Living", amount: "8,000-20,000/month", notes: "Switzerland is extremely expensive" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Initial consultation and canton selection", duration: "1-3 months", location: "Remote/Switzerland" },
  { step: "Lump-sum tax negotiation with canton", duration: "2-6 months", location: "Via tax advisor" },
  { step: "Secure accommodation in chosen canton", duration: "1-2 months", location: "Switzerland" },
  { step: "Submit residence permit application", duration: "1 day", location: "Cantonal migration office" },
  { step: "Permit processing", duration: "2-8 weeks", location: "Swiss authorities" },
  { step: "Receive Permit B", duration: "After approval", location: "Switzerland" },
  { step: "Register for health insurance", duration: "Within 3 months", location: "Swiss insurer" },
  { step: "Permit C (permanent) eligibility", duration: "After 10 years", location: "Switzerland" },
];
---

<PageShell
  title="Switzerland Investor Visa 2026: Wealthy Resident Permit & Lump-Sum Tax Guide"
  description="Complete guide to Swiss residence for wealthy individuals. Lump-sum taxation (forfait fiscal), permit requirements, mandatory health insurance, and the path to living in Switzerland."
  headline="Switzerland Wealthy Resident Permit: Investment & Insurance Guide"
  subheadline="How high-net-worth individuals obtain Swiss residence—lump-sum taxation, cantonal requirements, mandatory health insurance, and the realities of Europe's most exclusive destination."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Swiss Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/countries/switzerland-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Lump-Sum Taxation Available
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Mandatory Health Insurance
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Switzerland doesn't have a traditional "Golden Visa" or investor visa program. Instead, wealthy individuals can obtain residence through lump-sum taxation (forfait fiscal) or by demonstrating significant assets and economic contribution. This is a negotiated process with cantonal authorities, not a standardized investment threshold.
    </p>

    <p class="mb-4">
      The Swiss approach is highly selective. Cantons compete for wealthy residents who will pay substantial taxes, contribute to the local economy, and integrate into Swiss society. It's less about hitting a specific investment number and more about what you bring to Switzerland.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-amber-900 mb-3">Important: Switzerland is Different</h3>
      <p class="text-amber-800">
        Unlike EU Golden Visas with clear investment thresholds, Swiss residence for wealthy individuals is negotiated case-by-case. There's no "invest €500,000 and get residency" option. You'll need substantial wealth (typically CHF 5-10M+ assets), willingness to pay significant taxes (CHF 400,000+ annually), and professional advisors to navigate the process.
      </p>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Swiss Wealthy Resident Permit</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Program type:</strong> Lump-sum taxation (forfait fiscal) or wealthy resident permit</li>
        <li>• <strong>Minimum tax:</strong> CHF 400,000-600,000+ annually (varies by canton)</li>
        <li>• <strong>Assets typically required:</strong> CHF 5-10M+ (informal, varies)</li>
        <li>• <strong>Work rights:</strong> Cannot work in Switzerland under lump-sum taxation</li>
        <li>• <strong>Initial permit:</strong> Permit B (temporary residence, 1 year renewable)</li>
        <li>• <strong>Permanent residence:</strong> Permit C after 10 years (5 years for some nationalities)</li>
        <li>• <strong>Citizenship:</strong> After 10+ years, language and integration requirements</li>
        <li>• <strong>Health insurance:</strong> MANDATORY—must enroll within 3 months</li>
        <li>• <strong>Schengen access:</strong> Yes (90 days per 180 days in other Schengen countries)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Switzerland?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Key Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Political and economic stability</li>
          <li>• World-class banking and wealth management</li>
          <li>• Excellent healthcare and infrastructure</li>
          <li>• Safe, clean, high quality of life</li>
          <li>• Central European location</li>
          <li>• Strong privacy protections</li>
          <li>• Lump-sum taxation can save ultra-wealthy millions</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Extremely high cost of living</li>
          <li>• No formal investment visa—negotiated process</li>
          <li>• Cannot work under lump-sum taxation</li>
          <li>• 10 years to permanent residence</li>
          <li>• Citizenship requires language proficiency</li>
          <li>• Not EU member (different rules)</li>
          <li>• Limited non-EU quota for permits</li>
        </ul>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Mandatory health insurance:</strong> Switzerland requires ALL residents to have basic health insurance (LAMal) within 3 months of arrival. This is not optional—it's legally mandated. Unlike other countries where you can use international insurance for visa purposes, Switzerland specifically requires enrollment in a Swiss-regulated basic insurance plan.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Switzerland is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>You have CHF 10M+ in assets</li>
          <li>You can pay CHF 400,000+ annually in taxes</li>
          <li>You don't need to work (retirement/passive income)</li>
          <li>You value stability, privacy, and quality of life</li>
          <li>You appreciate Swiss culture and lifestyle</li>
          <li>You can handle very high cost of living</li>
          <li>You're comfortable with a 10-year permanence path</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Your assets are under CHF 5-10M</li>
          <li>• You can't commit to CHF 400K+ annual tax</li>
          <li>• You want to work or run active business</li>
          <li>• You want EU membership benefits</li>
          <li>• You prefer faster citizenship path</li>
          <li>• You want lower cost of living</li>
          <li>• You prefer a clear, standardized process</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Switzerland vs. Other Options</h3>

    <div class="grid md:grid-cols-3 gap-4 mb-6">
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Monaco</h4>
        <p class="text-neutral-600 text-sm">No income tax. Similar wealth requirement (€500K+ deposit). Smaller, French-speaking. More straightforward process. Good alternative if tax efficiency is priority.</p>
      </div>
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Portugal Golden Visa</h4>
        <p class="text-neutral-600 text-sm">€500K investment. Much lower threshold. EU citizenship in 5 years. NHR tax benefits (being phased out). Better for those with €500K-5M.</p>
      </div>
      <div class="border border-neutral-200 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">UK Innovator/Investor</h4>
        <p class="text-neutral-600 text-sm">Investor visa suspended. Innovator requires endorsement. Less straightforward than before. Switzerland offers more predictability for ultra-wealthy.</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Switzerland's niche:</strong> For ultra-high-net-worth individuals (CHF 20M+ assets), lump-sum taxation can mean paying a fraction of what they'd owe under normal taxation. A billionaire might pay CHF 1-2M annually instead of tens of millions. For this group, Switzerland offers unmatched tax efficiency combined with world-class lifestyle.
      </p>
    </div>
  </section>

  <!-- Section: Requirements & Pathways -->
  <section id="investment-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Requirements & Pathways</h2>

    <p class="mb-4">
      Switzerland offers several pathways for wealthy individuals, none of which are standardized "investor visas." The most common for non-working wealthy individuals is lump-sum taxation.
    </p>

    <ComparisonTable columns={pathwayColumns} rows={pathwayRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Lump-Sum Taxation (Forfait Fiscal)</h3>

    <p class="mb-4">
      The most common route for wealthy non-working residents. Instead of paying tax on worldwide income and assets, you pay a negotiated annual amount based on your living expenses in Switzerland.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">How It Works</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Tax calculated on 5-7x annual Swiss living expenses</li>
          <li>• Minimum tax: CHF 400,000-600,000+ (varies by canton)</li>
          <li>• Covers federal, cantonal, and municipal taxes</li>
          <li>• No disclosure of worldwide assets/income required</li>
          <li>• Negotiated with cantonal tax authority</li>
          <li>• Reviewed periodically (typically every 5 years)</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Eligibility Requirements</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Not a Swiss citizen</li>
          <li>• First time residing in Switzerland (or returning after 10+ years abroad)</li>
          <li>• Cannot work in Switzerland</li>
          <li>• Cannot have Swiss-source income</li>
          <li>• Must actually live in Switzerland</li>
          <li>• Some cantons have abolished it (Zurich, Basel-Stadt, others)</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cantons That Offer Lump-Sum Taxation</h3>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">Available Cantons</h4>
      <p class="text-green-800 mb-3">
        Not all cantons offer lump-sum taxation. Popular options include:
      </p>
      <ul class="grid md:grid-cols-2 gap-2 text-green-800">
        <li>• <strong>Vaud</strong> (Lausanne, Lake Geneva) - Most forfait residents</li>
        <li>• <strong>Geneva</strong> - International, French-speaking</li>
        <li>• <strong>Valais</strong> - Mountains, ski resorts (Verbier, Zermatt)</li>
        <li>• <strong>Ticino</strong> - Italian-speaking, Mediterranean feel</li>
        <li>• <strong>Graubünden</strong> (St. Moritz, Davos) - Luxury ski areas</li>
        <li>• <strong>Bern</strong> - Capital, German-speaking</li>
        <li>• <strong>Lucerne</strong> - Central, scenic, German-speaking</li>
        <li>• <strong>Zug</strong> - Low taxes, business-friendly</li>
      </ul>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-red-900 mb-3">Cantons That Have ABOLISHED Lump-Sum Taxation</h4>
      <ul class="text-red-800 space-y-1">
        <li>• <strong>Zurich</strong> - Switzerland's largest city (abolished 2009)</li>
        <li>• <strong>Basel-Stadt</strong> - Basel city (abolished 2014)</li>
        <li>• <strong>Basel-Landschaft</strong> - Basel region (abolished 2014)</li>
        <li>• <strong>Schaffhausen</strong> - (abolished 2012)</li>
        <li>• <strong>Appenzell Ausserrhoden</strong> - (abolished 2012)</li>
      </ul>
      <p class="text-red-800 mt-2">If you want lump-sum taxation, you cannot live in these cantons.</p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Minimum Tax by Canton (Approximate)</h3>

    <div class="grid md:grid-cols-3 gap-4 mb-6">
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-neutral-900">Geneva</p>
        <p class="text-2xl font-bold text-primary-700">CHF 400,000+</p>
        <p class="text-neutral-600 text-sm">Federal minimum</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-neutral-900">Vaud</p>
        <p class="text-2xl font-bold text-primary-700">CHF 400,000+</p>
        <p class="text-neutral-600 text-sm">Most popular canton</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-neutral-900">Valais/Ticino</p>
        <p class="text-2xl font-bold text-primary-700">CHF 250,000+</p>
        <p class="text-neutral-600 text-sm">Lower thresholds possible</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Negotiation matters:</strong> Unlike fixed EU Golden Visa thresholds, Swiss lump-sum taxation is negotiated. The final amount depends on your living expenses, property value, and the canton's appetite for new forfait residents. Work with experienced Swiss tax advisors who know the cantonal authorities.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Swiss Health Insurance is MANDATORY</h3>
      <p class="text-red-800">
        Switzerland has a unique healthcare system. Basic health insurance (LAMal/KVG) is legally required for ALL residents within 3 months of arrival. This is not optional, and international insurance does not satisfy the requirement. You must enroll with a Swiss-regulated insurer offering the mandatory basic package.
      </p>
    </div>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Understanding Swiss Health Insurance</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Basic Insurance (LAMal) - Mandatory</h4>
        <ul class="space-y-2 text-blue-800">
          <li>Required by law for all residents</li>
          <li>Standardized benefits across all insurers</li>
          <li>Cannot be denied for pre-existing conditions</li>
          <li>Same premium for all ages (per insurer/canton)</li>
          <li>Choose your deductible (CHF 300-2,500)</li>
          <li>Premiums vary significantly by canton</li>
          <li>~60 insurers offer LAMal coverage</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Supplementary Insurance (Zusatz) - Optional</h4>
        <ul class="space-y-2 text-green-800">
          <li>Private/semi-private hospital rooms</li>
          <li>Dental coverage (not in LAMal)</li>
          <li>Alternative medicine</li>
          <li>Worldwide emergency coverage</li>
          <li>Free choice of hospital across Switzerland</li>
          <li>Medical underwriting required</li>
          <li>Highly recommended for wealthy residents</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Premium Variation by Canton</h3>

    <p class="mb-4">
      Swiss health insurance premiums vary dramatically by canton—up to 50% difference for identical coverage. This matters when choosing where to live.
    </p>

    <div class="grid md:grid-cols-4 gap-4 mb-6">
      <div class="bg-green-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-green-900">Appenzell IR</p>
        <p class="text-xl font-bold text-green-700">~CHF 280</p>
        <p class="text-green-600 text-sm">Lowest</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-neutral-900">Valais</p>
        <p class="text-xl font-bold text-neutral-700">~CHF 350</p>
        <p class="text-neutral-600 text-sm">Below average</p>
      </div>
      <div class="bg-amber-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-amber-900">Vaud</p>
        <p class="text-xl font-bold text-amber-700">~CHF 450</p>
        <p class="text-amber-600 text-sm">Above average</p>
      </div>
      <div class="bg-red-50 rounded-lg p-4 text-center">
        <p class="font-semibold text-red-900">Geneva</p>
        <p class="text-xl font-bold text-red-700">~CHF 550</p>
        <p class="text-red-600 text-sm">Highest</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">International Insurance: What Role Does It Play?</h3>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-amber-900 mb-3">Important Clarification</h4>
      <p class="text-amber-800 mb-4">
        International health insurance (Cigna Global, BUPA, etc.) does NOT satisfy Switzerland's mandatory insurance requirement. You must have Swiss LAMal coverage regardless of any international policies.
      </p>
      <p class="text-amber-800">
        However, international insurance can supplement Swiss coverage for:
      </p>
      <ul class="text-amber-800 mt-2 space-y-1">
        <li>• Worldwide coverage when traveling</li>
