  { step: "Submit visa application", duration: "1 day", location: "Austrian embassy/consulate" },
  { step: "AMS labor market assessment", duration: "2-4 weeks", location: "Austria (internal process)" },
  { step: "Application review", duration: "4-8 weeks", location: "MA 35/immigration authority" },
  { step: "Visa decision and issuance", duration: "1-2 weeks", location: "Embassy notification" },
  { step: "Enter Austria", duration: "Within visa validity", location: "Austria" },
  { step: "Register residence (Meldezettel)", duration: "Within 3 days", location: "Meldeamt" },
  { step: "Collect biometric permit card", duration: "2-4 weeks", location: "MA 35" },
  { step: "Register business", duration: "1-2 weeks", location: "Gewerbebehörde" },
