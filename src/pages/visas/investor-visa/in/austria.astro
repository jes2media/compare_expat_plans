const insuranceRows = [
  { feature: "Coverage Type", requirement: "Comprehensive health insurance", notes: "Must cover illness, accident, hospitalization" },
  { feature: "Provider Type", requirement: "Austrian or EU-recognized insurer", notes: "International insurers accepted" },
  { feature: "Minimum Coverage", requirement: "€30,000+ medical coverage", notes: "Higher is recommended" },
  { feature: "Duration", requirement: "Full visa/permit duration", notes: "Continuous coverage required" },
  { feature: "Pre-existing Conditions", requirement: "No exclusions for acute care", notes: "Emergency coverage mandatory" },
  { feature: "Repatriation", requirement: "Recommended but not mandatory", notes: "Important for travel coverage" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Allianz Care", type: "International Private", price: "€180-400", strengths: "Global coverage, strong EU network" },
  { provider: "Cigna Global", type: "International Private", price: "€220-480", strengths: "Comprehensive plans, excellent service" },
  { provider: "ÖGK (Austrian public)", type: "Austrian Social Insurance", price: "~20% of income", strengths: "Full Austrian coverage once employed" },
  { provider: "UNIQA", type: "Austrian Private", price: "€150-350", strengths: "Local private option, good network" },
  { provider: "DR-WALTER", type: "Expat Insurance", price: "€80-200", strengths: "Visa-compliant, easy setup" },
  { provider: "Feather", type: "Expat Insurance", price: "€120-280", strengths: "Flexible plans, digital service" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€160", notes: "Red-White-Red Card application" },
  { item: "Residence Permit Fee", amount: "€120-160", notes: "Annual permit fee" },
  { item: "Business Registration", amount: "€25-50", notes: "Gewerbeschein (trade license)" },
  { item: "Company Formation (GmbH)", amount: "€2,000-5,000", notes: "Notary, registration, minimum capital" },
  { item: "Minimum Capital (GmbH)", amount: "€10,000", notes: "Privileged formation; €35,000 standard" },
  { item: "Legal/Consulting Fees", amount: "€1,500-8,000", notes: "Immigration lawyer + business setup" },
  { item: "Health Insurance", amount: "€100-400/month", notes: "Budget €1,200-5,000/year" },
  { item: "Chamber Membership", amount: "€200-1,000/year", notes: "WKO (Austrian Chamber) for businesses" },
];

