  { category: "Start-up Founder", requirement: "Innovative business, VC/incubator backing", benefit: "2-year visa, renewal possible" },
  { category: "Investor (Settlement Permit)", requirement: "Major investment, economic benefit", benefit: "Direct settlement permit" },
  { category: "Artist/Athlete", requirement: "Exceptional talent, cultural contribution", benefit: "Simplified approval process" },
