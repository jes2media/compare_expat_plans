  { key: "notes", header: "Notes" },
];

const timelineEntrePassRows = [
  { step: "Register ACRA company (or plan to)", duration: "1-2 weeks", notes: "Private limited company required" },
  { step: "Prepare business plan", duration: "2-4 weeks", notes: "Must demonstrate innovation and scalability" },
  { step: "Submit EntrePass application online", duration: "1 day", notes: "Via Ministry of Manpower portal" },
  { step: "Application processing", duration: "8 weeks", notes: "May request additional documents" },
  { step: "Receive In-Principle Approval", duration: "After processing", notes: "Valid 6 months to collect pass" },
