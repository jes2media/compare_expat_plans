  { key: "notes", header: "Notes" },
];

const timelineGIPRows = [
  { step: "Prepare business documentation", duration: "4-8 weeks", notes: "Audited financials, business plan, personal docs" },
  { step: "Submit GIP application to EDB", duration: "1 week", notes: "Economic Development Board reviews" },
  { step: "EDB assessment and interview", duration: "4-6 months", notes: "May include in-person interview" },
  { step: "Receive Approval In-Principle", duration: "After assessment", notes: "Conditional on investment execution" },
  { step: "Execute qualifying investment", duration: "6-12 months", notes: "Must meet specific criteria" },
  { step: "Submit investment proof to EDB", duration: "1-2 weeks", notes: "Documentation of completed investment" },
  { step: "Final GIP approval", duration: "2-4 weeks", notes: "Permanent residence status granted" },
