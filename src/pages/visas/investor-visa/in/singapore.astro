  { option: "Option B: GIP Fund", investment: "SGD 25 million", requirements: "Invest in approved GIP-selected fund investing in Singapore companies" },
  { option: "Option C: Single Family Office", investment: "SGD 50 million", requirements: "Establish family office in Singapore with AUM of at least SGD 200M" },
];

const visaComparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "gip", header: "Global Investor Programme" },
  { key: "entrepass", header: "EntrePass" },
  { key: "pep", header: "Personalised Employment Pass" },
];

const visaComparisonRows = [
  { feature: "Investment Minimum", gip: "SGD 10-50 million", entrepass: "No minimum (innovative business)", pep: "SGD 270,000/year income" },
  { feature: "Business Track Record", gip: "3 years audited financials, 200M+ revenue", entrepass: "None required (idea-stage OK)", pep: "Senior executive experience" },
  { feature: "Residency Status", gip: "Permanent Residence", entrepass: "Work Pass (1-2 years)", pep: "Work Pass (3 years max)" },
  { feature: "Processing Time", gip: "6-8 months", entrepass: "8 weeks", pep: "8 weeks" },
  { feature: "Family Inclusion", gip: "Spouse, children, parents", entrepass: "Dependent passes available", pep: "Dependent passes available" },
  { feature: "Best For", gip: "Established UHNW investors", entrepass: "Tech/startup founders", pep: "High-earning executives" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "requirement", header: "Visa Requirement" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { feature: "Mandatory?", requirement: "No—but highly recommended", notes: "Singapore healthcare is excellent but expensive" },
  { feature: "Public Healthcare Access", requirement: "Not subsidized for foreigners", notes: "Pay full foreigner rates at public hospitals" },
  { feature: "Recommended Coverage", requirement: "Comprehensive private insurance", notes: "Budget SGD 300-800/month" },
  { feature: "Coverage Type", requirement: "International or Singapore private", notes: "Both options viable" },
  { feature: "Hospitalization Costs", requirement: "SGD 1,000-5,000/day at private", notes: "Without insurance, bills can exceed SGD 100,000" },
  { feature: "Pre-existing Conditions", requirement: "No mandate", notes: "International insurers often better" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost (SGD)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "SGD 400-900", strengths: "Comprehensive global coverage, premium service" },
  { provider: "Bupa Global", type: "International", price: "SGD 500-1,100", strengths: "Extensive network, family plans, chronic conditions" },
  { provider: "Allianz Care", type: "International", price: "SGD 350-800", strengths: "Flexible plans, good value for coverage" },
  { provider: "AXA Singapore", type: "Local/Intl", price: "SGD 250-600", strengths: "Strong local presence, integrated products" },
  { provider: "Great Eastern", type: "Local", price: "SGD 200-500", strengths: "Largest local insurer, extensive network" },
  { provider: "Prudential Singapore", type: "Local", price: "SGD 180-450", strengths: "Comprehensive plans, good claims process" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (SGD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "GIP Application Fee", amount: "SGD 7,500", notes: "Non-refundable processing fee" },
  { item: "EntrePass Application", amount: "SGD 105", notes: "Per application" },
  { item: "EntrePass Issuance", amount: "SGD 225", notes: "Upon approval" },
  { item: "PEP Application", amount: "SGD 105", notes: "Per application" },
  { item: "GIP Investment (Option A)", amount: "SGD 10,000,000", notes: "New business or expansion" },
  { item: "Legal/Advisory Fees", amount: "SGD 20,000-100,000", notes: "Immigration and corporate setup" },
  { item: "Health Insurance", amount: "SGD 400-1,000/month", notes: "Comprehensive international coverage" },
  { item: "Living Costs (Family)", amount: "SGD 8,000-20,000/month", notes: "Depends on lifestyle and housing" },
];

