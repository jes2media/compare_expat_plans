const insuranceRows = [
  { feature: "National Health Insurance", requirement: "Mandatory after landing", notes: "NHI (Kokumin Kenkō Hoken) enrollment required" },
  { feature: "Coverage Type", requirement: "Universal 70% coverage", notes: "Patient pays 30% coinsurance" },
  { feature: "Premium Basis", requirement: "Income + municipality-based", notes: "Varies by city; ¥30,000-80,000/month typical" },
