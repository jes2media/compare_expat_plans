];

const providerRows = [
  { provider: "NHI (Kokumin Kenkō Hoken)", type: "Japanese Public", price: "¥30,000-80,000", strengths: "Mandatory, comprehensive Japan coverage" },
  { provider: "Allianz Care", type: "International Private", price: "¥25,000-60,000", strengths: "Global coverage, English service" },
  { provider: "Cigna Global", type: "International Private", price: "¥30,000-70,000", strengths: "Worldwide network, premium service" },
  { provider: "AFLAC Japan", type: "Japanese Supplement", price: "¥5,000-15,000", strengths: "Cancer/illness supplements" },
  { provider: "Sony Life", type: "Japanese Private", price: "¥10,000-30,000", strengths: "Local comprehensive options" },
  { provider: "Tokio Marine", type: "Japanese Private", price: "¥8,000-25,000", strengths: "Leading Japanese insurer" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (JPY)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Capital Investment", amount: "¥5,000,000+", notes: "Minimum required capital" },
  { item: "Company Registration", amount: "¥200,000-300,000", notes: "Registration tax + fees" },
  { item: "Office Lease (initial)", amount: "¥500,000-2,000,000", notes: "Deposit + advance rent (Tokyo)" },
  { item: "Visa Application Fee", amount: "¥4,000", notes: "At immigration" },
  { item: "Certificate of Eligibility", amount: "Free", notes: "Processing fee waived" },
  { item: "Legal/Administrative Fees", amount: "¥300,000-1,000,000", notes: "Lawyer + judicial scrivener" },
  { item: "National Health Insurance", amount: "¥360,000-960,000/year", notes: "Mandatory after enrollment" },
