  { step: "Secure office space", duration: "1-2 weeks", location: "Japan" },
  { step: "Apply for Certificate of Eligibility", duration: "1-3 months", location: "Immigration Bureau" },
  { step: "CoE approval", duration: "1-3 months processing", location: "Japan" },
  { step: "Apply for visa at embassy", duration: "1-2 weeks", location: "Home country embassy" },
  { step: "Enter Japan", duration: "Within 3 months", location: "Japan" },
  { step: "Register residence", duration: "Within 14 days", location: "City/ward office" },
  { step: "Enroll in NHI and pension", duration: "Within 14 days", location: "City/ward office" },
