---
/**
 * Philippines Investor Visa - Long-form CRO-optimized page
 * SRRV, SIRV, and investment options
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Philippines", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Philippines Insurance Guide", href: "/countries/philippines/insurance" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Thailand Investor Visa", href: "/visas/investor-visa/in/thailand" },
  { title: "Malaysia Investor Visa", href: "/visas/investor-visa/in/malaysia" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Deposit Required" },
  { key: "duration", header: "Duration" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "SRRV Smile (50+)", investment: "$20,000 deposit", duration: "Permanent", benefits: "Retirees 50+, refundable deposit" },
  { program: "SRRV Classic (35+)", investment: "$50,000 deposit", duration: "Permanent", benefits: "Age 35+, can invest in condo" },
  { program: "SRRV Human Touch", investment: "$10,000 deposit", duration: "Permanent", benefits: "Medical needs, requires treatment" },
  { program: "SIRV (Investment)", investment: "$75,000 investment", duration: "Permanent", benefits: "Active investment, business" },
  { program: "SRRV Courtesy (former citizens)", investment: "$1,500 deposit", duration: "Permanent", benefits: "Former Filipino citizens/diplomats" },
];

const insuranceColumns = [
  { key: "program", header: "Visa Program" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "minimum", header: "Minimum Coverage" },
];

const insuranceRows = [
  { program: "SRRV (all types)", requirement: "Recommended but not mandatory", minimum: "N/A (recommend $100K+)" },
  { program: "PhilHealth", requirement: "Available to residents", minimum: "After SRRV approval, optional" },
  { program: "Private Expat Insurance", requirement: "Strongly recommended", minimum: "Include Singapore evacuation" },
  { program: "Local HMOs", requirement: "Optional", minimum: "Maxicare, Medicard options" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$200-500", strengths: "Comprehensive, Singapore evac" },
  { provider: "Allianz Care", type: "International", price: "$180-450", strengths: "Good Asia network" },
  { provider: "Pacific Cross Philippines", type: "Regional", price: "$100-250", strengths: "Philippines specialist" },
  { provider: "Maxicare", type: "Philippine HMO", price: "$50-150", strengths: "Local network, affordable" },
  { provider: "Medicard", type: "Philippine HMO", price: "$40-120", strengths: "Wide network, budget option" },
  { provider: "PhilHealth", type: "Government", price: "~$20", strengths: "Basic coverage, subsidized" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "SRRV Smile Deposit (50+)", amount: "$20,000", notes: "Refundable on visa cancellation" },
  { item: "SRRV Classic Deposit (35-49)", amount: "$50,000", notes: "Can convert to condo investment" },
  { item: "SRRV Classic Deposit (50+)", amount: "$10,000-20,000", notes: "With pension proof" },
  { item: "SIRV Investment", amount: "$75,000", notes: "Active business/investment" },
  { item: "Processing Fee", amount: "$1,400", notes: "Non-refundable application fee" },
  { item: "Annual Fee", amount: "$360", notes: "Yearly renewal fee" },
  { item: "Health Insurance", amount: "$1,000-5,000/year", notes: "International recommended" },
  { item: "ID Card Fee", amount: "$10", notes: "SRRV ID issuance" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "SRRV (all types)", processing: "2-4 weeks", notes: "After document submission" },
  { program: "SIRV", processing: "4-8 weeks", notes: "Investment verification required" },
  { program: "Deposit Transfer", processing: "1-2 weeks", notes: "To PRA accredited bank" },
];
---

<PageShell
  title="Philippines Investor Visa 2026: SRRV, SIRV & Retirement Visa Guide"
  description="Complete guide to Philippines investor visas. SRRV retirement visa ($10K-50K deposit), SIRV investment visa ($75K), and permanent residence in the English-speaking Philippines."
  headline="Philippines Investor Visa: Complete Guide"
  subheadline="Everything you need to know about the Philippines investor visa options—SRRV retirement visa, SIRV investment visa, and paths to permanent residence in Southeast Asia's English-speaking tropical paradise."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/philippines-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official PRA Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      English-Speaking
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The Philippines offers one of the most accessible permanent residence programs in Asia through the SRRV (Special Resident Retiree's Visa). Despite the "retiree" name, SRRV is available from age 35 with varying deposit requirements. A $20,000 refundable deposit gets you permanent residence in an English-speaking, tropical archipelago with one of the lowest costs of living in the region.
    </p>

    <p class="mb-4">
      The Philippines' advantages are compelling: English is official language (no language barrier), extremely affordable cost of living, warm and welcoming culture, beautiful islands and beaches, and strong Western influence. Healthcare varies by location—Metro Manila has excellent private hospitals, but provinces are limited. Singapore evacuation coverage is important.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Philippines Investor Options</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>SRRV Smile (50+):</strong> $20,000 deposit (refundable)</li>
        <li>• <strong>SRRV Classic (35+):</strong> $50,000 deposit (can invest in condo)</li>
        <li>• <strong>SIRV:</strong> $75,000 active investment</li>
        <li>• <strong>Duration:</strong> Permanent residence (indefinite)</li>
        <li>• <strong>Processing:</strong> 2-4 weeks typically</li>
        <li>• <strong>English:</strong> Official language, widely spoken</li>
        <li>• <strong>Citizenship:</strong> Possible after 10 years continuous residence</li>
        <li>• <strong>Cost of living:</strong> One of lowest in SE Asia</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose the Philippines?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• English official language (no barrier)</li>
          <li>• Very low cost of living</li>
          <li>• Low deposit requirement ($20K)</li>
          <li>• Permanent residence (not time-limited)</li>
          <li>• Warm, welcoming Filipino culture</li>
          <li>• Beautiful islands and beaches</li>
          <li>• Strong Western cultural influence</li>
          <li>• Path to citizenship (10 years)</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• Healthcare varies (Manila good, provinces limited)</li>
          <li>• Infrastructure challenges</li>
          <li>• Traffic in Metro Manila</li>
          <li>• Typhoon season (June-November)</li>
          <li>• Security varies by region</li>
          <li>• Bureaucracy can be slow</li>
          <li>• Limited land ownership for foreigners</li>
          <li>• Internet/utilities can be unreliable</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>English advantage:</strong> The Philippines is one of the largest English-speaking countries in the world. English is official language, used in government, education, and business. For expats uncomfortable with language barriers, this is a significant benefit over Thailand, Indonesia, or Vietnam.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Philippines is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want English-speaking country</li>
          <li>• You have limited budget ($20-50K)</li>
          <li>• You want permanent residence</li>
          <li>• You prefer Western cultural influence</li>
          <li>• You want tropical island lifestyle</li>
          <li>• You're comfortable with developing country</li>
          <li>• You want potential citizenship path</li>
          <li>• You appreciate warm, friendly people</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need world-class healthcare</li>
          <li>• You want modern infrastructure</li>
          <li>• You're uncomfortable with developing country</li>
          <li>• You need reliable utilities/internet</li>
          <li>• You want urban, modern lifestyle</li>
          <li>• You're concerned about security</li>
          <li>• You prefer temperate climate</li>
          <li>• You want to own land freehold</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Philippines vs. SE Asia Alternatives</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investor Route</th>
            <th class="px-4 py-2 text-left">Investment</th>
            <th class="px-4 py-2 text-left">Duration</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Philippines SRRV</td>
            <td class="px-4 py-2">Retirement Deposit</td>
            <td class="px-4 py-2">$20,000-50,000</td>
            <td class="px-4 py-2">Permanent</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Thailand Elite</td>
            <td class="px-4 py-2">Membership</td>
            <td class="px-4 py-2">฿600K-1M (~$17K-28K)</td>
            <td class="px-4 py-2">5-20 years</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Malaysia MM2H</td>
            <td class="px-4 py-2">Fixed Deposit</td>
            <td class="px-4 py-2">RM1M (~$210K)</td>
            <td class="px-4 py-2">5 years renewable</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Indonesia Second Home</td>
            <td class="px-4 py-2">Savings Proof</td>
            <td class="px-4 py-2">$130K (not invested)</td>
            <td class="px-4 py-2">5-10 years</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>SRRV advantage:</strong> At $20,000 for permanent residence, SRRV offers the lowest entry point among major SE Asian programs. The deposit is refundable if you cancel the visa. English proficiency and low cost of living make it accessible for budget-conscious retirees.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      The Philippine Retirement Authority (PRA) manages SRRV programs. Several options exist depending on age, pension status, and investment preference.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">SRRV Smile (Most Popular, Age 50+)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The most popular option for retirees. Simple deposit-based permanent residence:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Requirements</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Age: <strong>50 years or older</strong></li>
            <li>• Deposit: <strong>$20,000</strong> in PRA bank</li>
            <li>• No pension requirement</li>
            <li>• Clean criminal record</li>
            <li>• Medical clearance</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Benefits</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Permanent residence</li>
            <li>• Multiple entry visa</li>
            <li>• Deposit is refundable (on visa cancellation)</li>
            <li>• Can include spouse and children</li>
            <li>• Import tax exemption (household goods)</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Deposit Details</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Held in PRA-accredited Philippine bank</li>
            <li>• Earns interest (~1-3%)</li>
            <li>• Cannot be withdrawn while visa active</li>
            <li>• Refunded if visa cancelled</li>
            <li>• USD or PHP deposit options</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Work Rights</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• SRRV alone doesn't allow employment</li>
            <li>• Need separate AEP for employment</li>
            <li>• Can own Philippine business</li>
            <li>• Remote work for overseas OK</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">SRRV Classic (Age 35+)</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For younger applicants or those wanting condo investment option:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Age 35-49 (No Pension)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Deposit: <strong>$50,000</strong></li>
            <li>• Can convert to condo investment</li>
            <li>• Higher threshold reflects younger age</li>
            <li>• Same permanent residence benefits</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Age 50+ (With Pension)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Deposit: <strong>$10,000</strong> (single) or <strong>$20,000</strong> (couple)</li>
            <li>• Requires $800/month pension proof (single)</li>
            <li>• $1,000/month for couple</li>
            <li>• Lower deposit with pension income</li>
          </ul>
        </div>
      </div>

      <div class="mt-4 bg-neutral-50 rounded-lg p-4">
        <h4 class="font-semibold text-neutral-900 mb-2">Condo Conversion Option</h4>
        <p class="text-neutral-700 text-sm">SRRV Classic allows conversion of deposit to Philippine condo investment. Buy a condo worth at least the deposit amount, and it replaces the cash deposit. Property ownership provides tangible asset while maintaining visa status.</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">SIRV (Special Investor's Resident Visa)</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For active business investors:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Investment: <strong>$75,000</strong> in qualifying Philippine investment</li>
        <li>Can be business equity, securities, or real estate development</li>
        <li>Must be maintained throughout visa validity</li>
        <li>Permanent residence like SRRV</li>
        <li>Best for those wanting active Philippine business involvement</li>
      </ul>

      <p class="text-neutral-600">More complex than SRRV—investment must be in approved categories and maintained. Better for genuine business investors than lifestyle retirees.</p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">SRRV Human Touch (Medical Needs)</h3>

    <div class="border-l-4 border-amber-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Lower deposit for those requiring ongoing medical treatment in the Philippines:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Deposit: <strong>$10,000</strong></li>
        <li>Must require medical treatment at Philippine facility</li>
        <li>Documentation from Philippine hospital required</li>
        <li>Popular for those seeking affordable medical care</li>
        <li>Not for general retirement—specific medical purpose</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> SRRV deposit is refundable if you cancel the visa. Unlike some countries where investment is "spent," your deposit remains in a Philippine bank earning interest. On visa cancellation or death, the deposit returns to you or your estate.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">No Mandatory Insurance for SRRV</h3>
      <p class="text-green-800">
        SRRV doesn't require health insurance for application. However, Philippine healthcare outside Metro Manila is limited, and international insurance with Singapore evacuation is strongly recommended. Don't rely on PhilHealth alone—it's basic coverage only.
      </p>
    </div>

    <p class="mb-4">
      The Philippines has two healthcare tiers: excellent private hospitals in Metro Manila (St. Luke's, Makati Medical Center, The Medical City), and limited facilities in provinces. For serious conditions, Singapore evacuation is the standard safety net.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Philippines</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance (Recommended)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Cigna, Allianz, Pacific Cross</li>
          <li>• Premium: $150-500/month</li>
          <li>• Singapore evacuation included</li>
          <li>• Global coverage for travel</li>
          <li>• English-speaking support</li>
          <li>• Direct billing at major hospitals</li>
          <li>• Higher limits, comprehensive</li>
          <li>• Essential for serious conditions</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Philippine HMOs & Local Options</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Maxicare, Medicard, Intellicare</li>
          <li>• Premium: $40-150/month</li>
          <li>• Wide Philippine network</li>
          <li>• Cash-less treatment at clinics</li>
          <li>• English services (widely spoken)</li>
          <li>• Very affordable</li>
          <li>• Limited for complex cases</li>
          <li>• Good for routine care</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Choosing the Right Insurance</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Metro Manila-Based</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care with Singapore evacuation. Manila has excellent hospitals (St. Luke's Global City, Makati Med), but complex oncology, cardiac, or neurosurgery may still need Singapore. Budget $200-400/month. International coverage recommended even in Manila.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Provincial/Island Living</h4>
        <p class="text-neutral-600">International insurance with evacuation is essential. Provincial hospitals are limited—serious issues require Manila or Singapore. Pacific Cross Philippines or Cigna Global. Budget $200-350/month. Don't skip this—evacuation can save your life.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget + Local Combo</h4>
        <p class="text-neutral-600">Maxicare or Medicard for routine Philippine care ($50-100/month), plus international catastrophic coverage for major issues. Good balance of affordability and protection. Total budget: $150-250/month combined.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
