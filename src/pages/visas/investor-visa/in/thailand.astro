---
/**
 * Thailand Investor/Elite Visa - Long-form CRO-optimized page
 * Thailand Elite, LTR Visa, and Investment Visa guide
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Thailand", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Thailand Insurance Guide", href: "/countries/thailand/insurance" },
  { title: "Thailand Retirement Visa", href: "/visas/retirement-visa/in/thailand" },
  { title: "Thailand Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/thailand" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Investment/Cost" },
  { key: "duration", header: "Duration" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "Thailand Elite (Privilege Entry)", investment: "฿600K-2.14M", duration: "5-20 years", benefits: "Multiple entry, airport services, no reporting" },
  { program: "LTR Visa (Wealthy Global)", investment: "$1M assets or $80K income", duration: "10 years", benefits: "Work permit, 17% tax cap, 90-day reporting" },
  { program: "LTR Visa (Pensioner)", investment: "$80K income or $250K pension", duration: "10 years", benefits: "For retirees 50+, healthcare required" },
  { program: "Investment Visa (BOI)", investment: "฿10M (~$280K)", duration: "1 year renewable", benefits: "Business activities permitted" },
  { program: "Business Visa (Non-B)", investment: "฿2M+ company capital", duration: "1 year renewable", benefits: "Work permit, Thai company required" },
];

const insuranceColumns = [
  { key: "program", header: "Visa Program" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "minimum", header: "Minimum Coverage" },
];

const insuranceRows = [
  { program: "Thailand Elite", requirement: "Recommended but not mandatory", minimum: "N/A (recommended $50K+)" },
  { program: "LTR Visa (Wealthy)", requirement: "Mandatory", minimum: "$50,000 coverage" },
  { program: "LTR Visa (Pensioner)", requirement: "Mandatory", minimum: "$50,000 coverage" },
  { program: "Retirement Visa (O-A)", requirement: "Mandatory", minimum: "฿40K OPD / ฿400K IPD" },
  { program: "Business Visa (Non-B)", requirement: "Recommended", minimum: "Social Security once employed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "฿8,000-20,000", strengths: "Comprehensive, global coverage" },
  { provider: "Allianz Care", type: "International", price: "฿6,000-15,000", strengths: "Good value, strong network" },
  { provider: "Pacific Cross", type: "Regional", price: "฿4,000-12,000", strengths: "Asia specialist, Thai expertise" },
  { provider: "Luma (formerly AIA)", type: "Thai Local", price: "฿3,000-10,000", strengths: "Local hospitals, affordable" },
  { provider: "Bupa Thailand", type: "Thai/International", price: "฿5,000-15,000", strengths: "Good hospital network" },
  { provider: "AXA Thailand", type: "Thai Local", price: "฿3,500-12,000", strengths: "Established, flexible plans" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (THB)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Elite Easy Access (5 years)", amount: "฿600,000", notes: "Entry level, single member" },
  { item: "Elite Superiority (20 years)", amount: "฿1,000,000", notes: "Best value per year" },
  { item: "Elite Family Excursion", amount: "฿800,000-1,000,000", notes: "Family packages available" },
  { item: "LTR Visa Application", amount: "฿50,000", notes: "10-year visa fee" },
  { item: "Investment Visa (BOI)", amount: "฿10,000,000+", notes: "Actual investment in Thailand" },
  { item: "Business Setup (Non-B route)", amount: "฿100,000-300,000", notes: "Company registration + visa" },
  { item: "Health Insurance", amount: "฿40,000-150,000/year", notes: "Mandatory for most visas" },
  { item: "Work Permit (if needed)", amount: "฿3,000-6,000", notes: "Annual renewal" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "Thailand Elite", processing: "2-4 weeks", notes: "Background check required" },
  { program: "LTR Visa", processing: "3-5 weeks (BOI review)", notes: "Documentation intensive" },
  { program: "Investment Visa (BOI)", processing: "1-3 months", notes: "Project approval needed" },
  { program: "Business Visa (Non-B)", processing: "2-4 weeks", notes: "Company must be registered first" },
];
---

<PageShell
  title="Thailand Investor Visa 2026: Elite, LTR & Investment Options Guide"
  description="Complete guide to Thailand investor visas. Thailand Elite (฿600K-2.14M), LTR Visa ($1M assets), BOI Investment Visa, and paths to long-term residence."
  headline="Thailand Investor Visa: Complete Guide"
  subheadline="Everything you need to know about Thailand's investor visa options—Thailand Elite membership, Long-Term Resident (LTR) Visa, BOI Investment Visa, and paths to long-term residence in Southeast Asia's most popular expat destination."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/thailand-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Thai Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Multiple Visa Pathways
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Thailand offers multiple pathways for investors and high-net-worth individuals to obtain long-term residence. The most popular is the Thailand Elite visa—a membership program providing 5-20 years of hassle-free stay for a one-time fee. For those with substantial assets or income, the newer LTR (Long-Term Resident) Visa offers 10-year residence with work permit and tax benefits.
    </p>

    <p class="mb-4">
      Thailand remains one of the most attractive destinations for expats: affordable cost of living, excellent healthcare infrastructure, tropical climate, and welcoming culture. While Thailand doesn't offer citizenship through investment, the long-term visa options provide stability and convenience that many investors find sufficient.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Thailand Investor Visas</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Thailand Elite:</strong> ฿600K-2.14M for 5-20 years (easiest option)</li>
        <li>• <strong>LTR Visa:</strong> $1M assets or $80K/year income (10-year visa)</li>
        <li>• <strong>BOI Investment:</strong> ฿10M+ in approved sectors</li>
        <li>• <strong>Processing:</strong> 2-5 weeks depending on program</li>
        <li>• <strong>Family included:</strong> Options vary by program</li>
        <li>• <strong>No citizenship path:</strong> Long-term residence only</li>
        <li>• <strong>Work rights:</strong> LTR includes work permit; Elite does not</li>
        <li>• <strong>Healthcare:</strong> Insurance mandatory for most programs</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Thailand?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Low cost of living (especially vs. West)</li>
          <li>• Excellent private healthcare</li>
          <li>• Tropical climate, beaches, nature</li>
          <li>• Large, established expat community</li>
          <li>• Affordable world-class dining</li>
          <li>• Convenient Asia travel hub</li>
          <li>• Thailand Elite simplicity</li>
          <li>• Welcoming, friendly culture</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• No path to citizenship</li>
          <li>• Property ownership restrictions (land)</li>
          <li>• Work restrictions on most visas</li>
          <li>• Language barrier outside tourist areas</li>
          <li>• Hot, humid climate</li>
          <li>• Traffic in Bangkok</li>
          <li>• Political stability varies</li>
          <li>• 90-day reporting (most visas)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Thailand Elite advantage:</strong> For most investors, Thailand Elite is the simplest path. Pay once, get 5-20 years of unlimited entries, VIP airport services, and no 90-day reporting (you do online notification instead). It doesn't include work permit, but for retirees, remote workers, or those with passive income, this is often ideal.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Thailand is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want long-term SE Asia base</li>
          <li>• You value low cost of living</li>
          <li>• You prefer warm, tropical climate</li>
          <li>• You have passive/remote income</li>
          <li>• You want easy visa (Thailand Elite)</li>
          <li>• You appreciate Thai culture and food</li>
          <li>• You want quality healthcare at low cost</li>
          <li>• You don't need citizenship pathway</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want citizenship pathway</li>
          <li>• You need to own land</li>
          <li>• You want to work for Thai company</li>
          <li>• You prefer four seasons</li>
          <li>• You want Western legal system</li>
          <li>• You need stable political environment</li>
          <li>• You prefer English-first environment</li>
          <li>• You want PR with clear timeline</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Thailand vs. Other SE Asia Options</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investor Route</th>
            <th class="px-4 py-2 text-left">Cost</th>
            <th class="px-4 py-2 text-left">Duration</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Thailand</td>
            <td class="px-4 py-2">Elite / LTR</td>
            <td class="px-4 py-2">฿600K-1M / Income-based</td>
            <td class="px-4 py-2">5-20 years / 10 years</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Malaysia</td>
            <td class="px-4 py-2">MM2H</td>
            <td class="px-4 py-2">RM500K fixed deposit</td>
            <td class="px-4 py-2">5 years renewable</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Philippines</td>
            <td class="px-4 py-2">SRRV</td>
            <td class="px-4 py-2">$10K-50K deposit</td>
            <td class="px-4 py-2">Permanent</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Indonesia</td>
            <td class="px-4 py-2">Second Home Visa</td>
            <td class="px-4 py-2">$130K assets + $1.4K/month</td>
            <td class="px-4 py-2">5-10 years</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Why Thailand stands out:</strong> Thailand Elite offers the simplest long-term visa in SE Asia—pay once, stay up to 20 years with minimal hassle. The LTR Visa adds work permit and tax benefits for those who qualify. Thailand's infrastructure (healthcare, internet, flights) is more developed than most regional alternatives.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Thailand offers several pathways for long-term residence. The best choice depends on your wealth, income sources, work needs, and how much hassle you want to avoid.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Thailand Elite (Privilege Card)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The most popular option for investors and retirees. A membership program (not technically a "visa" but provides visa privileges) with multiple tiers:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Elite Easy Access (5 years)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Cost: ฿600,000 (~$17,000)</li>
            <li>• Duration: 5 years</li>
            <li>• Single member only</li>
            <li>• Airport fast-track</li>
            <li>• Multiple entry</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Elite Superiority Extension (20 years)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Cost: ฿1,000,000 (~$28,000)</li>
            <li>• Duration: 20 years</li>
            <li>• Best value per year</li>
            <li>• All Elite benefits</li>
            <li>• Golf, spa discounts</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Elite Family Excursion</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Cost: ฿800,000-1,000,000</li>
            <li>• Duration: 5 years</li>
            <li>• Includes spouse and children</li>
            <li>• Family-friendly package</li>
            <li>• Up to 4 members</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Elite Benefits</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• No 90-day in-person reporting</li>
            <li>• Airport VIP service (meet & greet)</li>
            <li>• Immigration fast-track</li>
            <li>• Government services assistance</li>
            <li>• No work permit included</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">LTR Visa (Long-Term Resident)</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Launched in 2022, the LTR offers 10-year residence with work permit and tax benefits. Four categories:</p>

      <div class="space-y-4">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Wealthy Global Citizen</h4>
          <p class="text-neutral-700 text-sm">Requirements: $1M+ assets OR $80,000+/year income (past 2 years). Investment of $500,000+ in Thai government bonds, property, or FDI. Benefits: 10-year visa, work permit, 17% income tax cap, 90-day reporting (not in-person).</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Wealthy Pensioner</h4>
          <p class="text-neutral-700 text-sm">Requirements: Age 50+, $80,000+/year pension income OR $250,000+ pension/investment. Health insurance mandatory ($50K coverage). Benefits: Same as Wealthy Global Citizen.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Work-from-Thailand Professional</h4>
          <p class="text-neutral-700 text-sm">Requirements: $80,000+/year income, employed by established company ($150M+ revenue or VC-backed). Health insurance mandatory. Benefits: 10-year visa, can work remotely, 17% tax cap on Thai income.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Highly-Skilled Professional</h4>
          <p class="text-neutral-700 text-sm">Requirements: Expertise in targeted industries (tech, biotech, etc.), $80,000+/year income, work for Thai entity. Benefits: 10-year visa, work permit for Thai employment, tax incentives.</p>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">BOI Investment Visa</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For genuine business investors in BOI-promoted sectors. Requires ฿10M+ investment (or ฿3M for some sectors) in eligible industries:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Agriculture and food processing</li>
        <li>Technology and innovation</li>
        <li>Manufacturing (automotive, electronics)</li>
        <li>Renewable energy</li>
        <li>Tourism infrastructure</li>
      </ul>

      <p class="text-neutral-600">Benefits: 1-year visa (renewable), work permit, potential tax holidays on business income. Best for those making genuine business investments, not passive investors.</p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> Thailand Elite does NOT include work permit—you cannot work for Thai employers or clients. For remote work for non-Thai companies, it's tolerated in practice (many Elite members do this), but technically not authorized. LTR Visa explicitly allows remote work.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Insurance Requirements Vary by Visa Type</h3>
      <p class="text-green-800">
        Thailand Elite doesn't require insurance (but strongly recommends it). LTR Visa requires $50,000 coverage. Traditional retirement visas (O-A) require ฿40,000 OPD and ฿400,000 IPD coverage. Regardless of requirements, health insurance is essential—Thai hospitals expect payment upfront.
      </p>
    </div>

    <p class="mb-4">
      Thailand has excellent private healthcare at relatively low cost, but hospitals require payment or insurance guarantee before treatment. Without insurance, you'll pay out-of-pocket (still affordable by Western standards) or risk being turned away for non-emergencies.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Thailand</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Cigna, Allianz, Bupa Global</li>
          <li>• Premium: ฿8,000-20,000/month</li>
          <li>• Global coverage for travel</li>
          <li>• Direct billing at major hospitals</li>
          <li>• English-speaking support</li>
          <li>• Higher limits, fewer exclusions</li>
          <li>• Medical evacuation included</li>
          <li>• Best for frequent travelers</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Thai Local Insurance</h4>
        <ul class="space-y-2 text-green-800">
          <li>• AXA Thailand, Bupa Thailand, Luma</li>
          <li>• Premium: ฿3,000-12,000/month</li>
          <li>• Thailand-focused coverage</li>
          <li>• Strong hospital networks</li>
          <li>• Thai language support (English varies)</li>
          <li>• More affordable premiums</li>
          <li>• May have OPD limits</li>
          <li>• Best for Thailand-based living</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Choosing the Right Insurance</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Thailand Elite Holder</h4>
        <p class="text-neutral-600">No requirement, but essential. Consider Pacific Cross or AXA Thailand for cost-effective local coverage. Add international coverage (Cigna, Allianz) if you travel frequently. Budget ฿4,000-12,000/month.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">LTR Visa Holder</h4>
        <p class="text-neutral-600">$50,000 coverage mandatory. International plans easily meet this. Cigna Global or Allianz Care work well. Ensure your policy letter explicitly states the coverage amount. Budget ฿6,000-15,000/month.</p>
