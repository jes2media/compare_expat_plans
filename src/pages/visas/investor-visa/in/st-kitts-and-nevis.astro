---
/**
 * St. Kitts and Nevis Citizenship by Investment - Long-form CRO-optimized page
 * Pioneer CBI program since 1984, dual citizenship, visa-free travel
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in St. Kitts", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Dominica Investor Visa", href: "/visas/investor-visa/in/dominica" },
  { title: "Grenada Investor Visa", href: "/visas/investor-visa/in/grenada" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Investment Route" },
  { key: "investment", header: "Minimum Investment" },
  { key: "timeline", header: "Processing Time" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "Sustainable Island State Contribution (SISC)", investment: "$250,000 (single)", timeline: "45-60 days standard", benefits: "Lowest cost option, non-refundable" },
  { program: "SISC Family", investment: "$300,000 (family of 4)", timeline: "45-60 days standard", benefits: "Includes spouse + 2 dependents" },
  { program: "Real Estate (Approved Project)", investment: "$400,000 (7-year hold)", timeline: "45-60 days standard", benefits: "Asset ownership, potential appreciation" },
  { program: "Real Estate (Resale)", investment: "$200,000 (7-year hold)", timeline: "45-60 days standard", benefits: "Lower cost, resale properties" },
  { program: "Accelerated Application", investment: "+$25,000 fee", timeline: "45 days guaranteed", benefits: "Expedited processing" },
];

const insuranceColumns = [
  { key: "situation", header: "Situation" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "recommendation", header: "Recommended Coverage" },
];

const insuranceRows = [
  { situation: "CBI Application", requirement: "Not mandatory for application", recommendation: "International coverage recommended" },
  { situation: "Residing in St. Kitts", requirement: "No mandatory insurance", recommendation: "$100,000+ comprehensive" },
  { situation: "Caribbean Regional", requirement: "N/A", recommendation: "Regional plan with evacuation" },
  { situation: "Global Travelers", requirement: "N/A", recommendation: "Worldwide coverage essential" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$300-600", strengths: "Global coverage, US included" },
  { provider: "Allianz Care", type: "International", price: "$250-500", strengths: "Good value, worldwide network" },
  { provider: "IMG Global", type: "International", price: "$200-450", strengths: "Flexible plans, evacuation" },
  { provider: "Sagicor", type: "Regional Caribbean", price: "$150-350", strengths: "Caribbean specialist" },
  { provider: "Guardian Life", type: "Regional Caribbean", price: "$100-300", strengths: "Local Caribbean coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "SISC Contribution (Single)", amount: "$250,000", notes: "Non-refundable donation" },
  { item: "SISC Contribution (Family 4)", amount: "$300,000", notes: "Spouse + 2 children under 18" },
  { item: "Real Estate Minimum", amount: "$400,000 / $200,000", notes: "New project / Resale" },
  { item: "Due Diligence Fee (Main)", amount: "$10,000", notes: "Per main applicant" },
  { item: "Due Diligence (Spouse)", amount: "$7,500", notes: "Per spouse" },
  { item: "Due Diligence (Dependent 16+)", amount: "$7,500", notes: "Per dependent 16 and older" },
  { item: "Processing Fee", amount: "$1,500", notes: "Per application" },
  { item: "Legal/Agent Fees", amount: "$15,000-30,000", notes: "Authorized agent required" },
  { item: "Accelerated Processing", amount: "$25,000", notes: "Optional 45-day guarantee" },
];

const timelineColumns = [
  { key: "stage", header: "Stage" },
  { key: "duration", header: "Duration" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { stage: "Document Preparation", duration: "2-4 weeks", notes: "Gather documents, translations" },
  { stage: "Application Submission", duration: "1 week", notes: "Via authorized agent" },
  { stage: "Due Diligence", duration: "4-6 weeks", notes: "Background checks" },
  { stage: "Approval in Principle", duration: "Week 6-8", notes: "Conditional approval" },
  { stage: "Investment Payment", duration: "1-2 weeks", notes: "Complete investment" },
  { stage: "Citizenship Certificate", duration: "1-2 weeks", notes: "Certificate issued" },
  { stage: "Passport Issuance", duration: "2-4 weeks", notes: "Passport delivered" },
  { stage: "Total (Standard)", duration: "3-4 months", notes: "45 days if accelerated" },
];
---

<PageShell
  title="St. Kitts and Nevis Citizenship by Investment 2026: Complete CBI Guide"
  description="Complete guide to St. Kitts and Nevis CBI. $250K SISC donation or $400K real estate, 45-60 day processing, 157 countries visa-free, world's oldest citizenship by investment program."
  headline="St. Kitts Citizenship by Investment: Complete Guide"
  subheadline="Everything you need to know about the world's oldest citizenship by investment program—$250K donation or $400K real estate for a St. Kitts passport with visa-free access to 157 countries including the UK, EU Schengen, and Singapore."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/st-kitts-and-nevis-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official CBI Unit Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Established 1984 (40+ Years)
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      St. Kitts and Nevis operates the world's oldest citizenship by investment (CBI) program, established in 1984. For a minimum investment of $250,000 (donation) or $400,000 (real estate), applicants can obtain citizenship in as little as 45-60 days—granting visa-free access to 157 countries including the UK, EU Schengen zone, Singapore, and Hong Kong.
    </p>

    <p class="mb-4">
      As a British Commonwealth member, St. Kitts citizenship provides significant travel freedom and a respected second passport. The program has matured over four decades with established due diligence procedures, making it one of the most reputable CBI options. Unlike many programs, St. Kitts allows dual citizenship with no residency requirements—you never need to visit to maintain citizenship.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: St. Kitts CBI Program</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>SISC Donation:</strong> $250,000 single / $300,000 family of 4</li>
        <li>• <strong>Real Estate:</strong> $400,000 new / $200,000 resale (7-year hold)</li>
        <li>• <strong>Processing:</strong> 45-60 days (45-day accelerated available)</li>
        <li>• <strong>Visa-free travel:</strong> 157 countries (UK, EU, Singapore)</li>
        <li>• <strong>Dual citizenship:</strong> Fully permitted</li>
        <li>• <strong>Residency required:</strong> No (zero physical presence)</li>
        <li>• <strong>Passport validity:</strong> 10 years, renewable for life</li>
        <li>• <strong>Tax benefits:</strong> No income, capital gains, or wealth tax</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose St. Kitts and Nevis?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Oldest, most established CBI program</li>
          <li>• 157 countries visa-free including UK/EU</li>
          <li>• No residency requirement whatsoever</li>
          <li>• Fast processing (45-60 days)</li>
          <li>• No income, capital gains, wealth tax</li>
          <li>• Include family (spouse, children, parents)</li>
          <li>• Commonwealth membership benefits</li>
          <li>• Lifetime citizenship, inheritable</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• Higher cost than Dominica/Vanuatu</li>
          <li>• No US visa-free travel (ESTA required)</li>
          <li>• Real estate 7-year holding period</li>
          <li>• Small island with limited healthcare</li>
          <li>• Hurricane zone (June-November)</li>
          <li>• Must use authorized agents</li>
          <li>• Strict due diligence (rejections occur)</li>
          <li>• SISC donation is non-refundable</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Platinum Standard:</strong> St. Kitts CBI is considered the "platinum standard" of citizenship programs. Its 40-year track record, rigorous due diligence, and Commonwealth status make its passport highly respected. The program has processed over 25,000 successful applications with a strong reputation for integrity.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">St. Kitts CBI is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want prestigious, established program</li>
          <li>• You need UK/EU visa-free travel</li>
          <li>• You value zero residency requirement</li>
          <li>• You want fast processing (45-60 days)</li>
          <li>• You prefer Commonwealth citizenship</li>
          <li>• You want to include parents/siblings</li>
          <li>• You need tax-neutral jurisdiction</li>
          <li>• You have clean background (pass due diligence)</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Budget is under $200,000</li>
          <li>• You need US visa-free access (consider Grenada)</li>
          <li>• You want lowest possible cost (Dominica cheaper)</li>
          <li>• You plan to reside there (limited healthcare)</li>
          <li>• You have complex background history</li>
          <li>• You want EU citizenship (consider Malta/Portugal)</li>
          <li>• You need refundable investment option</li>
          <li>• You want immediate real estate liquidity</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">St. Kitts vs. Other Caribbean CBI Programs</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Minimum Investment</th>
            <th class="px-4 py-2 text-left">Processing</th>
            <th class="px-4 py-2 text-left">Visa-Free Countries</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">St. Kitts and Nevis</td>
            <td class="px-4 py-2">$250,000</td>
            <td class="px-4 py-2">45-60 days</td>
            <td class="px-4 py-2">157</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Dominica</td>
            <td class="px-4 py-2">$100,000</td>
            <td class="px-4 py-2">3-4 months</td>
            <td class="px-4 py-2">145</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Grenada</td>
            <td class="px-4 py-2">$150,000</td>
            <td class="px-4 py-2">4-6 months</td>
            <td class="px-4 py-2">146 + US E-2</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Antigua & Barbuda</td>
            <td class="px-4 py-2">$100,000</td>
            <td class="px-4 py-2">3-4 months</td>
            <td class="px-4 py-2">151</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Why St. Kitts costs more:</strong> The higher investment reflects the program's 40-year reputation, strongest due diligence, and broadest visa-free access. The "Platinum Standard" brand commands a premium, and the St. Kitts passport is widely considered the most respected Caribbean CBI option.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      St. Kitts offers two main pathways: a non-refundable donation to the Sustainable Island State Contribution (SISC) fund or investment in government-approved real estate. The donation route is simpler; real estate provides asset ownership but requires a 7-year holding period.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Option 1: SISC Donation</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The Sustainable Island State Contribution (SISC) is a non-refundable donation to the government fund. Simplest and fastest route:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Single Applicant</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $250,000</li>
            <li>• Processing fee: $1,500</li>
            <li>• Due diligence: $10,000</li>
            <li>• Non-refundable donation</li>
            <li>• Fastest processing available</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Family of Four</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Contribution: $300,000</li>
            <li>• Includes spouse + 2 children</li>
            <li>• Additional dependents: $50,000 each</li>
            <li>• Parents/grandparents eligible</li>
            <li>• Siblings under 30 eligible</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Option 2: Real Estate Investment</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Purchase government-approved real estate for asset ownership with potential appreciation:</p>

      <div class="space-y-4">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">New Development ($400,000)</h4>
          <p class="text-neutral-700 text-sm">Purchase in approved development project. Must hold for 7 years before sale. Resale to future CBI applicant possible. Government fees apply (~$35,000). Rental income potential during holding period.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Resale Property ($200,000)</h4>
          <p class="text-neutral-700 text-sm">Purchase property previously held for CBI for 7+ years by another applicant. Lower entry point. Same 7-year holding requirement. Limited inventory—resale properties are scarce.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Approved Projects Include</h4>
          <p class="text-neutral-700 text-sm">Luxury resort condos, hotel shares, villa developments. Properties in Park Hyatt, Christophe Harbour, and other branded projects. Must be government-approved—cannot purchase any property.</p>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Family Members Eligible</h3>

    <div class="bg-neutral-50 rounded-lg p-6 mb-6">
      <ul class="space-y-2 text-neutral-700">
        <li>• <strong>Spouse:</strong> Legally married spouse</li>
        <li>• <strong>Children under 18:</strong> Included automatically</li>
        <li>• <strong>Children 18-30:</strong> If financially dependent, full-time students</li>
        <li>• <strong>Parents/Grandparents 55+:</strong> If financially dependent</li>
        <li>• <strong>Siblings under 30:</strong> If unmarried and financially dependent</li>
      </ul>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> All applications must go through government-authorized agents. You cannot apply directly. Agents handle document preparation, submission, and communication with the CBI Unit. Budget $15,000-30,000 for agent fees. Use only licensed agents listed on the official CBI Unit website.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Insurance Not Mandatory for CBI</h3>
      <p class="text-green-800">
        St. Kitts does not require health insurance for citizenship application or maintenance. However, if you plan to spend time on the island, comprehensive international coverage with medical evacuation is strongly recommended. St. Kitts has limited healthcare facilities.
      </p>
    </div>

    <p class="mb-4">
      Most CBI applicants don't reside in St. Kitts—the citizenship is for passport and travel benefits. However, if you do visit or reside, healthcare options are limited. Joseph N. France General Hospital is the only hospital, with basic services. Serious conditions require evacuation to Miami, San Juan, or Barbados.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Strategy for CBI Citizens</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Passport Holders (Non-Resident)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Continue current country's coverage</li>
          <li>• Add travel insurance for trips</li>
          <li>• No St. Kitts-specific insurance needed</li>
          <li>• Consider global plan if frequently traveling</li>
          <li>• Evacuation coverage if visiting Caribbean</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Actual Residents</h4>
        <ul class="space-y-2 text-green-800">
          <li>• International insurance essential</li>
          <li>• Must include medical evacuation</li>
          <li>• Miami/San Juan for serious care</li>
          <li>• Budget $300-600/month minimum</li>
          <li>• Cigna Global or Allianz Care recommended</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Reality check:</strong> Less than 5% of CBI citizens actually reside in St. Kitts. Most obtain citizenship for the passport (travel freedom, tax planning, Plan B) while living elsewhere. Insurance needs depend on where you actually live, not your citizenship.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need international health coverage?"
    description="Compare global insurance options for worldwide coverage with evacuation benefits."
    buttonText="Compare Premium Insurance"
    buttonHref="/go/cigna-global"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For St. Kitts CBI citizens who travel frequently or spend time in the Caribbean, international coverage with strong evacuation benefits is essential. Here are the best options:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Lifestyle</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Global Business Travelers</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care provide seamless worldwide coverage. Important if using your St. Kitts passport to travel to 157 countries. Direct billing at hospitals globally. Budget $300-600/month for comprehensive coverage including US.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Caribbean Residents/Visitors</h4>
        <p class="text-neutral-600">IMG Global or regional Caribbean insurers (Sagicor, Guardian Life) work well. Essential: medical evacuation to Miami (1.5 hours) or San Juan. Caribbean specialists understand regional hospital networks. Budget $200-400/month.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Maintain Primary Residence Elsewhere</h4>
        <p class="text-neutral-600">Keep your existing coverage in your primary country. Add travel insurance for Caribbean visits. St. Kitts citizenship doesn't require changing your insurance setup. Most CBI citizens maintain coverage in their actual country of residence.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Total costs vary based on route chosen and family size. The SISC donation route has predictable costs; real estate involves additional transaction fees but provides an asset.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

