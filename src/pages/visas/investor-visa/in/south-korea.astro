---
/**
 * South Korea Investor/Entrepreneur Visa - Long-form CRO-optimized page
 * D-8 Investment Visa, F-2 Resident, and F-5 Permanent Residence guide
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in South Korea", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "South Korea Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/south-korea" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
  { title: "Allianz Care Review", href: "/providers/allianz-care" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Investment Requirement" },
  { key: "duration", header: "Duration" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "D-8-1 Corporate Investment", investment: "KRW 100M+ (~$75K)", duration: "2 years renewable", benefits: "Start/join Korean company, work permit" },
  { program: "D-8-4 Tech Startup Visa", investment: "Government-backed startup", duration: "2 years renewable", benefits: "For approved tech startups, lower capital" },
  { program: "F-2-7 Points System", investment: "Points (income, education, Korean)", duration: "5 years renewable", benefits: "Path to F-5, multiple employment" },
  { program: "F-5-5 Investor PR", investment: "KRW 300M (~$225K)", duration: "Permanent", benefits: "Permanent residence, unrestricted work" },
  { program: "F-5-6 Real Estate PR", investment: "KRW 500M-1.5B property", duration: "Permanent", benefits: "Property investment route, regional incentives" },
];

const insuranceColumns = [
  { key: "program", header: "Visa Type" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "system", header: "Healthcare Access" },
];

const insuranceRows = [
  { program: "D-8 Investment Visa", requirement: "Mandatory enrollment in NHI after 6 months", system: "National Health Insurance (NHI)" },
  { program: "F-2 Long-term Resident", requirement: "Mandatory NHI enrollment", system: "Full NHI benefits" },
  { program: "F-5 Permanent Resident", requirement: "Mandatory NHI enrollment", system: "Full NHI benefits, same as citizens" },
  { program: "First 6 months", requirement: "Private insurance recommended", system: "NHI not available initially" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "National Health Insurance", type: "Government", price: "~KRW 150K-400K", strengths: "Comprehensive, once eligible" },
  { provider: "Cigna Global", type: "International", price: "KRW 350K-800K", strengths: "First 6 months, premium coverage" },
  { provider: "Allianz Care", type: "International", price: "KRW 300K-700K", strengths: "Gap coverage, global travelers" },
  { provider: "Samsung Life", type: "Korean Local", price: "KRW 100K-300K", strengths: "Supplemental coverage" },
  { provider: "Hanwha Life", type: "Korean Local", price: "KRW 100K-250K", strengths: "Local plans, Korean support" },
  { provider: "DB Insurance", type: "Korean Local", price: "KRW 80K-200K", strengths: "Budget supplemental" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "D-8 Visa Fee", amount: "KRW 130,000 (~$100)", notes: "Visa application and stamp" },
  { item: "D-8 Minimum Investment", amount: "KRW 100,000,000 (~$75K)", notes: "Corporate investment capital" },
  { item: "F-5-5 Investor PR Investment", amount: "KRW 300,000,000 (~$225K)", notes: "Can include government bonds" },
  { item: "F-5-6 Real Estate PR", amount: "KRW 500M-1.5B (~$375K-1.1M)", notes: "Property investment, varies by region" },
  { item: "Business Registration", amount: "KRW 500K-2M", notes: "Legal, accounting setup" },
  { item: "National Health Insurance", amount: "KRW 150K-400K/month", notes: "Income-based premiums" },
  { item: "Private Insurance (gap)", amount: "KRW 100K-300K/month", notes: "Supplemental or first 6 months" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "D-8 Investment Visa", processing: "4-8 weeks", notes: "Business plan review required" },
  { program: "D-8-4 Startup Visa", processing: "2-4 weeks", notes: "Pre-approval from OASIS program" },
  { program: "F-2-7 Points Visa", processing: "4-6 weeks", notes: "Requires minimum 80 points" },
  { program: "F-5-5 Investor PR", processing: "2-4 months", notes: "Investment verification required" },
  { program: "F-5-6 Real Estate PR", processing: "2-4 months", notes: "Property registration verified" },
];
---

<PageShell
  title="South Korea Investor Visa 2026: D-8, F-2 & F-5 Permanent Residence Guide"
  description="Complete guide to South Korea investor visas. D-8 Investment (KRW 100M), F-5 Permanent Residence (KRW 300M), startup visa options, and paths to Korean citizenship."
  headline="South Korea Investor Visa: Complete Guide"
  subheadline="Everything you need to know about South Korea's investor visa options—D-8 Corporate Investment Visa, F-2 Long-term Resident, F-5 Permanent Residence, and paths to citizenship in Asia's most advanced economy."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/south-korea-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Korean Immigration
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Citizenship Pathway Available
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      South Korea offers structured pathways for investors and entrepreneurs seeking residence in Asia's fourth-largest economy. The D-8 Investment Visa provides entry for those investing KRW 100M+ (~$75,000) in a Korean company, while the F-5 Permanent Residence visa offers long-term stability for investors with KRW 300M+ (~$225,000). Unlike many Asian countries, South Korea offers a clear path to citizenship.
    </p>

    <p class="mb-4">
      Korea attracts tech entrepreneurs, investors looking for stable markets, and those seeking high quality of life with world-class infrastructure. The country offers excellent healthcare through mandatory National Health Insurance, advanced technology ecosystem, and strategic location in Northeast Asia. The main challenges are high living costs (especially Seoul), language barriers, and competitive business environment.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: South Korea Investor Visas</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>D-8 Investment:</strong> KRW 100M+ (~$75K) corporate investment</li>
        <li>• <strong>F-5 Investor PR:</strong> KRW 300M (~$225K) for permanent residence</li>
        <li>• <strong>F-5 Real Estate:</strong> KRW 500M-1.5B property investment</li>
        <li>• <strong>Processing:</strong> 4-8 weeks (D-8) to 2-4 months (F-5)</li>
        <li>• <strong>Citizenship path:</strong> Yes, after 5 years residence</li>
        <li>• <strong>Language:</strong> TOPIK Level 5+ for citizenship</li>
        <li>• <strong>Healthcare:</strong> Mandatory NHI after 6 months</li>
        <li>• <strong>Work rights:</strong> Restricted to sponsored company (D-8)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose South Korea?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• World-class healthcare system</li>
          <li>• Advanced technology infrastructure</li>
          <li>• Clear path to citizenship</li>
          <li>• Strong economy, stable currency</li>
          <li>• Excellent public transportation</li>
          <li>• Four distinct seasons</li>
          <li>• Safe, low crime rates</li>
          <li>• Growing startup ecosystem</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• High cost of living (Seoul)</li>
          <li>• Challenging Korean language</li>
          <li>• Competitive business culture</li>
          <li>• Complex visa requirements</li>
          <li>• Cold winters, humid summers</li>
          <li>• Work culture can be intense</li>
          <li>• North Korea geopolitical factor</li>
          <li>• Limited English outside cities</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Korea advantage:</strong> South Korea is one of few Asian countries offering clear citizenship pathway through investment. After 5 years of residence and TOPIK Level 5 Korean proficiency, investors can apply for naturalization. This makes Korea attractive for those seeking permanent ties to Asia, not just temporary residence.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">South Korea is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want citizenship pathway in Asia</li>
          <li>• You're building tech/innovation business</li>
          <li>• You value world-class healthcare</li>
          <li>• You appreciate four seasons climate</li>
          <li>• You want stable, developed market</li>
          <li>• You're willing to learn Korean</li>
          <li>• You prefer modern urban lifestyle</li>
          <li>• You want access to Northeast Asia</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want low cost of living</li>
          <li>• You prefer warm climate year-round</li>
          <li>• You need English-speaking environment</li>
          <li>• You want simpler visa process</li>
          <li>• You prefer relaxed business culture</li>
          <li>• You're not committed to learning Korean</li>
          <li>• You want immediate permanent residence</li>
          <li>• You prefer lower investment thresholds</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">South Korea vs. Other Options</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investment Route</th>
            <th class="px-4 py-2 text-left">Cost</th>
            <th class="px-4 py-2 text-left">Citizenship Path</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">South Korea</td>
            <td class="px-4 py-2">D-8 / F-5</td>
            <td class="px-4 py-2">$75K-$225K</td>
            <td class="px-4 py-2">Yes (5 years + Korean)</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Japan</td>
            <td class="px-4 py-2">Business Manager</td>
            <td class="px-4 py-2">~$40K+ (no minimum)</td>
            <td class="px-4 py-2">Yes (5-10 years)</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Singapore</td>
            <td class="px-4 py-2">GIP</td>
            <td class="px-4 py-2">$2.5M+</td>
            <td class="px-4 py-2">Yes (after PR)</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Thailand</td>
            <td class="px-4 py-2">Elite / LTR</td>
            <td class="px-4 py-2">$17K-$28K</td>
            <td class="px-4 py-2">No</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Why Korea stands out:</strong> Korea offers the best combination of developed-market stability, healthcare access, and citizenship pathway in Asia. Investment thresholds are reasonable compared to Singapore, and the tech ecosystem is stronger than most regional alternatives. The main trade-off is the need to learn Korean for full integration.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      South Korea offers multiple pathways based on investment level and business type. The D-8 visa is the standard entry point for corporate investors, while F-5 provides permanent residence for larger investments.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">D-8 Corporate Investment Visa</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The primary investor visa for foreign entrepreneurs. Requires KRW 100M+ investment in a Korean corporation:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">D-8-1: Corporate Investment</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Investment: KRW 100M+ (~$75,000)</li>
            <li>• Duration: 2 years, renewable</li>
            <li>• Register Korean corporation</li>
            <li>• Must maintain business operations</li>
            <li>• Work permit for own company</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">D-8-4: Tech Startup Visa</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Through OASIS program</li>
            <li>• Lower capital requirements</li>
            <li>• Government-backed incubators</li>
            <li>• Duration: 2 years</li>
            <li>• For innovative tech ventures</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">D-8-2/3: Venture Investment</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• For VC-backed companies</li>
            <li>• Investment in Korean startups</li>
            <li>• Special zones eligible</li>
            <li>• More flexibility on capital</li>
            <li>• Must meet venture criteria</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Renewal Requirements</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Business must remain operational</li>
            <li>• Employee Korean workers (bonus)</li>
            <li>• Maintain investment level</li>
            <li>• Tax compliance required</li>
            <li>• Can convert to F-2/F-5 later</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">F-5 Permanent Residence (Investor)</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Permanent residence for qualifying investors. Two main pathways:</p>

      <div class="space-y-4">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">F-5-5: Investment PR</h4>
          <p class="text-neutral-700 text-sm">Invest KRW 300M (~$225,000) in qualifying assets: government bonds, stocks approved by Ministry of Justice, or business investment. Maintain investment for 5 years minimum. No employment restrictions after approval. Can include spouse and minor children.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">F-5-6: Real Estate Investment PR</h4>
          <p class="text-neutral-700 text-sm">Purchase qualifying real estate: KRW 500M-1.5B depending on location. Jeju Island has special KRW 500M threshold. Must be leisure/resort property or approved development. Maintain ownership for 5 years. Pathway to citizenship available after 5 years residence.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">F-5 Benefits</h4>
          <p class="text-neutral-700 text-sm">Permanent residence with no employment restrictions. Can work for any employer or self-employ. Re-entry permit valid 2 years (extendable). Eligible for citizenship after 5 years. Family dependents included. Full National Health Insurance benefits.</p>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">F-2-7 Points System</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">An alternative pathway for those who don't meet F-5 investment thresholds. Points awarded for:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Income level (higher = more points)</li>
        <li>Educational qualifications</li>
        <li>Korean language ability (TOPIK)</li>
        <li>Age (younger = more points)</li>
        <li>Korean investment/assets</li>
        <li>Years of Korean residence</li>
      </ul>

      <p class="text-neutral-600">Requires 80+ points for F-2-7 visa. Valid 5 years, renewable. After 3 years, can apply for F-5 with 100+ points. Good pathway for entrepreneurs building businesses in Korea over time.</p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> D-8 visa ties you to your specific business—you cannot work for other companies. F-2 and F-5 offer more flexibility but have higher requirements. Plan your pathway based on whether you want to build a specific business (D-8) or have broader economic freedom (F-2/F-5).
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">National Health Insurance is Mandatory</h3>
      <p class="text-green-800">
        South Korea requires all long-term residents (6+ months) to enroll in National Health Insurance (NHI). The system covers 70% of most medical costs with excellent quality. Private insurance is useful for the first 6 months before NHI eligibility and as supplemental coverage afterward.
      </p>
    </div>

    <p class="mb-4">
      South Korea's healthcare system ranks among the world's best—advanced facilities, skilled doctors, and affordable costs thanks to NHI. Foreigners with long-term visas are included in this system, paying income-based premiums.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Strategy by Phase</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">First 6 Months</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• NHI not available yet</li>
          <li>• International insurance essential</li>
          <li>• Cigna or Allianz recommended</li>
          <li>• Coverage: KRW 350K-700K/month</li>
          <li>• Direct billing at major hospitals</li>
          <li>• English-speaking support</li>
          <li>• Emergency evacuation included</li>
          <li>• Travel coverage for trips</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">After NHI Enrollment</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Mandatory NHI enrollment</li>
          <li>• Premiums: KRW 150K-400K/month</li>
          <li>• 70% coverage for most care</li>
          <li>• Wide hospital network</li>
          <li>• Consider supplemental for gaps</li>
          <li>• Private rooms, dental extras</li>
          <li>• Global coverage if traveling</li>
          <li>• Cancer/major illness top-up</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">National Health Insurance (NHI) Details</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Calculation</h4>
        <p class="text-neutral-600">NHI premiums are based on income and assets. Employees pay ~3.5% of salary (split with employer). Self-employed/investors pay based on income declaration. Expect KRW 150,000-400,000/month for investor visa holders. Lower than private insurance with better coverage.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Coverage Benefits</h4>
        <p class="text-neutral-600">NHI covers approximately 70% of medical costs: outpatient visits (30% copay), hospitalization (20% copay), prescription drugs (30% copay), emergency care, and most procedures. Excludes cosmetic surgery, some dental work, and non-essential services. Annual out-of-pocket cap exists for major illness.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Supplemental Insurance Value</h4>
