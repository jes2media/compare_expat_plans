---
/**
 * Cyprus Investor/Entrepreneur Visa - Long-form CRO-optimized page
 * Cyprus Permanent Residence by Investment and non-dom tax regime guide
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-requirements", text: "Investment Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Cyprus", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Cyprus Insurance Guide", href: "/countries/cyprus/insurance" },
  { title: "Malta Investor Visa", href: "/visas/investor-visa/in/malta" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Allianz Care Review", href: "/providers/allianz-care" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const investmentColumns = [
  { key: "route", header: "Investment Route" },
  { key: "minimum", header: "Minimum Investment" },
  { key: "notes", header: "Key Features" },
];

const investmentRows = [
  { route: "New Property (from developer)", minimum: "€300,000 + VAT", notes: "Most popular route; must be new residential" },
  { route: "Resale Property", minimum: "€300,000", notes: "Must have paid full VAT at original purchase" },
  { route: "Commercial Property", minimum: "€300,000", notes: "Office, shop, hotel, or similar" },
  { route: "Company Shares", minimum: "€300,000", notes: "Cyprus-based company creating 5+ jobs" },
  { route: "Investment Fund Units", minimum: "€300,000", notes: "Cyprus Investment Funds (AIFs/RAIFs)" },
  { route: "Combined Investment", minimum: "€300,000 total", notes: "Mix of above options" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "requirement", header: "Visa Requirement" },
  { key: "notes", header: "Notes" },
];

const insuranceRows = [
  { feature: "Coverage Type", requirement: "Comprehensive health insurance", notes: "Medical, hospital, emergency" },
  { feature: "Geographic Scope", requirement: "Valid in Cyprus", notes: "EU-wide coverage recommended" },
  { feature: "Coverage Amount", requirement: "Not specified (comprehensive)", notes: "€50,000+ recommended" },
  { feature: "Duration", requirement: "Full permit duration", notes: "Renewable annually" },
  { feature: "Pre-existing Conditions", requirement: "No specific exclusion requirement", notes: "Better to have covered" },
  { feature: "After GeSY Enrollment", requirement: "Optional supplement", notes: "Can use public system" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Allianz Care", type: "International Private", price: "€150-350", strengths: "Global coverage, strong EU network" },
  { provider: "Cigna Global", type: "International Private", price: "€180-400", strengths: "Comprehensive plans, worldwide access" },
  { provider: "Passport Card", type: "International Private", price: "€100-250", strengths: "Expat specialist, good value" },
  { provider: "GeSY (GESY)", type: "Cyprus Public", price: "~2.65% of income", strengths: "Full Cyprus public healthcare" },
  { provider: "Eurolife", type: "Cyprus Private", price: "€80-200", strengths: "Local insurer, Cyprus network" },
  { provider: "Metlife Cyprus", type: "Cyprus Private", price: "€100-250", strengths: "International backing, local service" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Property Investment", amount: "€300,000 + VAT (5-19%)", notes: "Main investment; VAT varies by property" },
  { item: "Application Fee", amount: "€500", notes: "Per applicant, non-refundable" },
  { item: "Permit Issuance Fee", amount: "€70", notes: "Upon approval" },
  { item: "Legal Fees", amount: "€3,000-8,000", notes: "Immigration + property purchase" },
  { item: "Property Transfer Fees", amount: "0-8% of value", notes: "Reduced or waived for first property" },
  { item: "Stamp Duty", amount: "0.15-0.2%", notes: "On property contracts" },
  { item: "Health Insurance", amount: "€1,200-4,000/year", notes: "Annual premium varies by coverage" },
  { item: "Secure Deposit", amount: "€30,000", notes: "3-year fixed deposit in Cypriot bank" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Find property and sign contract", duration: "1-4 weeks", location: "Cyprus/remotely" },
  { step: "Pay deposit (min €200,000)", duration: "Upon signing", location: "Bank transfer" },
  { step: "Make €30,000 bank deposit", duration: "Before application", location: "Cypriot bank" },
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country + Cyprus" },
  { step: "Submit PR application", duration: "1 day", location: "Civil Registry" },
  { step: "Application review", duration: "2 months (fast-track)", location: "Ministry of Interior" },
  { step: "Approval notification", duration: "Within 2 months", location: "Email/letter" },
  { step: "Travel to Cyprus", duration: "Within 1 year", location: "Cyprus" },
  { step: "Collect Residence Permit", duration: "1-2 weeks after arrival", location: "Civil Registry" },
];
---

<PageShell
  title="Cyprus Investor Visa 2026: Permanent Residence by Investment & Non-Dom Tax Guide"
  description="Complete guide to Cyprus Permanent Residence by Investment. €300,000 property investment, 2-month processing, non-dom tax benefits, and path to EU citizenship."
  headline="Cyprus Investor Visa: Permanent Residence Guide"
  subheadline="Everything you need to know about Cyprus Permanent Residence by Investment—€300,000 property route, fast 2-month processing, attractive non-dom tax regime, and life in the EU's eastern Mediterranean."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/allianz-care"
  heroImage="/images/countries/cyprus-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Cyprus Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      €300,000 Property Route
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Cyprus offers one of Europe's most attractive investor residence programs: permanent residence through a €300,000 property investment with fast 2-month processing. Unlike temporary residence permits that require renewal, Cyprus grants actual permanent residence—valid for life as long as you maintain your investment and visit at least once every 2 years.
    </p>

    <p class="mb-4">
      The Cyprus program stands out for its combination of accessible investment threshold, fast processing, genuine permanent status, and exceptional tax benefits through the non-dom regime. For investors seeking an EU base with Mediterranean lifestyle, favorable taxation, and straightforward requirements, Cyprus delivers compelling value.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Cyprus Permanent Residence</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Investment minimum:</strong> €300,000 in new property (+ VAT)</li>
        <li>• <strong>Processing time:</strong> ~2 months (fast-track)</li>
        <li>• <strong>Permit type:</strong> Permanent Residence (lifetime validity)</li>
        <li>• <strong>Physical presence:</strong> Visit once every 2 years</li>
        <li>• <strong>Family included:</strong> Spouse, children under 25, parents</li>
        <li>• <strong>Path to citizenship:</strong> 5 years residence (12 months continuous before)</li>
        <li>• <strong>Non-dom benefits:</strong> 0% tax on dividends, interest, rental income abroad</li>
        <li>• <strong>EU benefits:</strong> Schengen travel, Cyprus healthcare access</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Cyprus?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Lowest Golden Visa threshold in EU (€300K)</li>
          <li>• Permanent residence (not temporary)</li>
          <li>• Fast 2-month processing</li>
          <li>• Non-dom tax regime (0% on foreign income)</li>
          <li>• English widely spoken (UK legacy)</li>
          <li>• Mediterranean climate (340 sunny days)</li>
          <li>• Low crime, high safety</li>
          <li>• Family-friendly (three generations)</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• Not Schengen (EU but separate visa regime)</li>
          <li>• Divided island (Turkish occupation in north)</li>
          <li>• Limited direct flights from some regions</li>
          <li>• Property market varies in quality</li>
          <li>• Summer heat (35-40°C July-August)</li>
          <li>• Car essential outside cities</li>
          <li>• Smaller expat community than Spain/Portugal</li>
          <li>• Banking sector has had past issues</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Non-dom advantage:</strong> Cyprus's non-domiciled tax regime is among Europe's most favorable. For 17 years after becoming tax resident, you pay 0% tax on dividends, interest, and most capital gains regardless of whether remitted to Cyprus. Combined with no inheritance tax and no wealth tax, this makes Cyprus exceptionally attractive for investors and entrepreneurs with international income.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Cyprus is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want the lowest EU investment threshold</li>
          <li>• Tax optimization is a priority (non-dom)</li>
          <li>• You prefer English-speaking environment</li>
          <li>• You want genuine permanent residence</li>
          <li>• You love Mediterranean/beach lifestyle</li>
          <li>• You don't need to be in Schengen zone</li>
          <li>• You want to include parents in application</li>
          <li>• You value fast processing (2 months)</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need Schengen zone access</li>
          <li>• You want to be in mainland Europe</li>
          <li>• You prefer cooler/wetter climate</li>
          <li>• You want faster citizenship path</li>
          <li>• You need frequent flights to many destinations</li>
          <li>• You prefer larger expat communities</li>
          <li>• You want rental income route (Portugal better)</li>
          <li>• You prefer urban/cosmopolitan lifestyle</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cyprus vs. Other EU Options</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Min. Investment</th>
            <th class="px-4 py-2 text-left">Processing</th>
            <th class="px-4 py-2 text-left">Permit Type</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Cyprus</td>
            <td class="px-4 py-2">€300,000 (property)</td>
            <td class="px-4 py-2">2 months</td>
            <td class="px-4 py-2">Permanent Residence</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Greece</td>
            <td class="px-4 py-2">€250,000-500,000</td>
            <td class="px-4 py-2">2-3 months</td>
            <td class="px-4 py-2">5-year renewable</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Malta</td>
            <td class="px-4 py-2">€300,000+ (property/rental)</td>
            <td class="px-4 py-2">4-6 months</td>
            <td class="px-4 py-2">Permanent Residence</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Portugal</td>
            <td class="px-4 py-2">€500,000 (funds)</td>
            <td class="px-4 py-2">8-12 months</td>
            <td class="px-4 py-2">2-year renewable</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Why Cyprus stands out:</strong> Cyprus offers genuine permanent residence (not temporary permits requiring renewal) with the lowest property investment threshold in the EU. The 2-month processing is among the fastest, and the non-dom tax regime provides ongoing benefits that Portugal's NHR changes have diminished. The main trade-off is not being in the Schengen zone.
      </p>
    </div>
  </section>

  <!-- Section: Investment Requirements -->
  <section id="investment-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Requirements</h2>

    <p class="mb-4">
      Cyprus offers multiple investment routes to permanent residence, all with a €300,000 minimum threshold. The most popular is purchasing new residential property from a developer, but commercial property, company shares, and investment funds also qualify.
    </p>

    <ComparisonTable columns={investmentColumns} rows={investmentRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Property Investment Details</h3>

    <div class="space-y-6 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">New Property from Developer (Most Common)</h4>
        <p class="text-neutral-600">Purchase new residential property directly from a developer for minimum €300,000 + VAT. VAT is 19% standard, but reduced 5% applies to primary residence (first 200m²). This is the most straightforward route with the fastest processing. Property must be from a single development (not multiple purchases).</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Resale Property</h4>
        <p class="text-neutral-600">Purchase resale property for minimum €300,000 if the property had VAT paid in full at original purchase. This applies to properties built after 2004 (Cyprus EU accession). Verify VAT payment history before purchase. No additional VAT due on resale transactions.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Commercial Property</h4>
        <p class="text-neutral-600">Invest €300,000 in commercial real estate: offices, retail units, hotels, or similar. Useful for investors who want income-generating property. VAT treatment may differ from residential. Consider rental market demand in chosen location.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Company Shares</h4>
        <p class="text-neutral-600">Invest €300,000 in shares of a Cyprus-registered company. The company must have physical presence in Cyprus and employ at least 5 people. Suitable for entrepreneurs who want to invest in an operating business rather than passive real estate.</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Additional Requirements</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Financial Requirements</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Bank deposit:</strong> €30,000 in Cyprus bank (3-year term)</li>
          <li>• <strong>Annual income:</strong> €30,000+ from abroad</li>
          <li>• <strong>Additional per dependent:</strong> €5,000/year each</li>
          <li>• <strong>Additional per parent:</strong> €8,000/year each</li>
          <li>• <strong>Property payment:</strong> Min €200,000 before application</li>
          <li>• Source of funds documentation required</li>
          <li>• Income must be from outside Cyprus</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Eligibility Criteria</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Clean criminal record</li>
          <li>• No prior Cyprus visa refusal/deportation</li>
          <li>• Not on sanctions lists</li>
          <li>• Health insurance coverage</li>
          <li>• Cannot work in Cyprus (investment income OK)</li>
          <li>• Must visit Cyprus once every 2 years</li>
          <li>• Must maintain investment while PR valid</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Family Inclusion</h3>

    <p class="mb-4">
      Cyprus allows extensive family inclusion—one of the program's significant advantages:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Spouse:</strong> Included in main application</li>
      <li><strong>Children under 18:</strong> Included automatically</li>
      <li><strong>Adult children 18-25:</strong> Included if unmarried and financially dependent</li>
      <li><strong>Parents (both applicant's and spouse's):</strong> Can be included with additional €8,000/year income per set</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> The permanent residence permit does not confer work rights in Cyprus. You can manage your own investments and company (if you invested in shares), but you cannot take employment. Most PR holders live off investment income, pensions, or remote work for non-Cyprus employers—which is permissible.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Health Insurance is Mandatory for PR Application</h3>
      <p class="text-green-800">
        You must show proof of comprehensive health insurance covering Cyprus when applying for permanent residence. After obtaining PR and becoming tax resident, you can enroll in GeSY (the Cyprus public health system) and optionally supplement with private insurance.
      </p>
    </div>

    <p class="mb-4">
      Cyprus introduced GeSY (General Healthcare System) in 2019-2020, providing universal public healthcare for residents. As a permanent resident, you're eligible to enroll. However, many expats maintain private insurance for faster access, broader coverage, and international portability.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Cyprus</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">GeSY Public Healthcare</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Available to all legal residents</li>
          <li>• Contribution: ~2.65% of income (capped)</li>
          <li>• Comprehensive coverage</li>
          <li>• Access to all registered providers</li>
          <li>• Prescription drugs included</li>
          <li>• Hospital care covered</li>
          <li>• Some waiting times for specialists</li>
          <li>• Good for routine and chronic care</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Private International Insurance</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Required for initial PR application</li>
          <li>• Premium: €100-400/month</li>
          <li>• Faster access to specialists</li>
          <li>• Private hospital rooms</li>
          <li>• Wider choice of doctors</li>
          <li>• International coverage for travel</li>
          <li>• Medical evacuation included</li>
          <li>• English-speaking service</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Recommended Insurance Approach</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Application Phase</h4>
        <p class="text-neutral-600">For your PR application, obtain private international insurance (Allianz Care, Cigna Global, or similar). This provides clear documentation and meets visa requirements. Budget €100-250/month for comprehensive coverage.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">After Becoming Resident</h4>
        <p class="text-neutral-600">Once tax resident in Cyprus, enroll in GeSY for comprehensive public coverage. You can then choose to maintain private insurance as supplement (faster access, private rooms) or primary coverage if you prefer private healthcare.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Frequent Travelers</h4>
        <p class="text-neutral-600">If you travel frequently or spend significant time outside Cyprus, maintain international private insurance for global coverage. Allianz Care and Cigna Global provide seamless care worldwide without referrals back to Cyprus.</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>GeSY tip:</strong> To enroll in GeSY, you need a Cyprus tax identification number and to register at your local healthcare center. Registration is done online through the GeSY portal. Once enrolled, you'll receive a GeSY card and can choose your personal doctor (GP) who acts as gatekeeper to specialists.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need insurance for your Cyprus Permanent Residence?"
    description="Compare international insurers that meet Cypriot visa requirements."
    buttonText="Compare Premium Insurance"
    buttonHref="/go/allianz-care"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For your Cyprus PR application, you'll need private health insurance. Here are the best options for different situations:
    </p>

