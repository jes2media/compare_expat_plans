---
/**
 * Malaysia Investor/MM2H Visa - Long-form CRO-optimized page
 * Malaysia My Second Home, Premium Visa Programme, and Labuan investment options
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Malaysia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Malaysia Insurance Guide", href: "/countries/malaysia/insurance" },
  { title: "Malaysia Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/malaysia" },
  { title: "Thailand Investor Visa", href: "/visas/investor-visa/in/thailand" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Investment/Deposit" },
  { key: "duration", header: "Duration" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "MM2H (Federal)", investment: "RM1M fixed deposit + RM40K/mo income", duration: "5 years renewable", benefits: "Long-term residence, property purchase" },
  { program: "Sarawak S-MM2H", investment: "RM150K-300K deposit", duration: "5-10 years", benefits: "Easier requirements, Borneo lifestyle" },
  { program: "Premium Visa Programme", investment: "RM1M-5M deposit", duration: "20 years", benefits: "New 2024 program, long duration" },
  { program: "Labuan Work Permit", investment: "RM50K company capital", duration: "2 years renewable", benefits: "Work rights, low tax jurisdiction" },
  { program: "Residence Pass-Talent", investment: "Employment-based", duration: "10 years", benefits: "Skilled workers, full work rights" },
];

const insuranceColumns = [
  { key: "program", header: "Visa Program" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "minimum", header: "Minimum Coverage" },
];

const insuranceRows = [
  { program: "MM2H (age 35+)", requirement: "Mandatory", minimum: "Basic medical coverage" },
  { program: "MM2H (under 35)", requirement: "Recommended", minimum: "N/A (recommended RM100K+)" },
  { program: "S-MM2H", requirement: "Mandatory (age 50+)", minimum: "Basic medical coverage" },
  { program: "Premium Visa", requirement: "Mandatory", minimum: "Comprehensive coverage" },
  { program: "Labuan", requirement: "Recommended", minimum: "N/A (recommended RM100K+)" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "RM1,500-3,500", strengths: "Comprehensive, global coverage" },
  { provider: "Allianz Care", type: "International", price: "RM1,200-2,800", strengths: "Good value, strong network" },
  { provider: "Pacific Cross Malaysia", type: "Regional", price: "RM800-2,000", strengths: "Asia specialist, local expertise" },
  { provider: "AIA Malaysia", type: "Malaysian", price: "RM400-1,500", strengths: "Local hospitals, affordable" },
  { provider: "Prudential Malaysia", type: "Malaysian", price: "RM500-1,800", strengths: "Established, wide network" },
  { provider: "Great Eastern", type: "Malaysian", price: "RM400-1,400", strengths: "Good value, medical cards" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (RM)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "MM2H Fixed Deposit (50+)", amount: "RM1,000,000", notes: "Can withdraw 50% after 1 year for property" },
  { item: "MM2H Fixed Deposit (35-49)", amount: "RM1,000,000", notes: "Higher deposit, stricter requirements" },
  { item: "MM2H Monthly Income (proof)", amount: "RM40,000/month", notes: "Offshore income required" },
  { item: "S-MM2H Deposit (50+)", amount: "RM150,000", notes: "Much lower than federal MM2H" },
  { item: "S-MM2H Deposit (35-49)", amount: "RM300,000", notes: "Still lower than federal program" },
  { item: "Premium Visa Deposit", amount: "RM1,000,000-5,000,000", notes: "Varies by tier, 20-year validity" },
  { item: "Visa Processing Fee", amount: "RM5,000-10,000", notes: "Application and approval fees" },
  { item: "Health Insurance", amount: "RM5,000-30,000/year", notes: "Mandatory for 35+ (MM2H)" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "MM2H (Federal)", processing: "3-6 months", notes: "Quota system, longer waits" },
  { program: "S-MM2H (Sarawak)", processing: "2-4 months", notes: "Separate application, faster" },
  { program: "Premium Visa", processing: "1-3 months", notes: "New program, expedited process" },
  { program: "Labuan Work Permit", processing: "4-8 weeks", notes: "Business setup required first" },
];
---

<PageShell
  title="Malaysia Investor Visa 2026: MM2H, Premium Visa & Investment Options Guide"
  description="Complete guide to Malaysia investor visas. MM2H (RM1M deposit), Sarawak S-MM2H (RM150K), Premium Visa Programme, and Labuan options for long-term residence."
  headline="Malaysia Investor Visa: Complete Guide"
  subheadline="Everything you need to know about Malaysia's investor visa options—MM2H (Malaysia My Second Home), Sarawak S-MM2H, the new Premium Visa Programme, and Labuan investment routes for long-term residence in Southeast Asia."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/malaysia-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Multiple Visa Pathways
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Malaysia's investor visa landscape changed dramatically in 2021 when the government significantly increased MM2H requirements. The fixed deposit jumped from RM300K to RM1M, and monthly income requirements increased to RM40K. While this made the federal program less accessible, alternatives like Sarawak's S-MM2H (RM150K deposit) and the new Premium Visa Programme offer different paths.
    </p>

    <p class="mb-4">
      Malaysia remains attractive for its low cost of living, English proficiency, excellent healthcare, diverse culture, and strategic location. For those who meet the higher requirements or choose the Sarawak route, Malaysia offers comfortable long-term residence in one of Southeast Asia's most developed countries.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Malaysia Investor Visas</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>MM2H (Federal):</strong> RM1M fixed deposit + RM40K/month income</li>
        <li>• <strong>Sarawak S-MM2H:</strong> RM150K-300K deposit (much easier)</li>
        <li>• <strong>Premium Visa:</strong> RM1M-5M deposit, 20-year validity (new 2024)</li>
        <li>• <strong>Processing:</strong> 2-6 months depending on program</li>
        <li>• <strong>Duration:</strong> 5-20 years depending on program</li>
        <li>• <strong>No citizenship path:</strong> Long-term residence only</li>
        <li>• <strong>Property purchase:</strong> Allowed (RM1M+ minimum for foreigners)</li>
        <li>• <strong>Healthcare:</strong> Insurance mandatory for age 35+ (MM2H)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Malaysia?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• English widely spoken</li>
          <li>• Low cost of living</li>
          <li>• Excellent private healthcare</li>
          <li>• Modern infrastructure</li>
          <li>• Multicultural (Malay, Chinese, Indian)</li>
          <li>• Good food and lifestyle</li>
          <li>• Strategic Asia-Pacific location</li>
          <li>• Stable, peaceful country</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• MM2H requirements increased significantly (2021)</li>
          <li>• No path to citizenship or PR</li>
          <li>• Property ownership restrictions</li>
          <li>• Work restrictions (limited employment)</li>
          <li>• Hot, humid climate year-round</li>
          <li>• Traffic in KL</li>
          <li>• Bureaucracy can be slow</li>
          <li>• Some areas less developed</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Post-2021 reality:</strong> The stricter MM2H requirements disappointed many. However, Sarawak's S-MM2H offers the original MM2H spirit at much lower cost (RM150K deposit for 50+). For those who can meet the federal requirements, Malaysia still offers excellent value. Consider your budget and which program best fits.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Malaysia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want English-speaking SE Asia base</li>
          <li>• You can meet RM1M deposit (or use S-MM2H)</li>
          <li>• You value multicultural environment</li>
          <li>• You want quality healthcare</li>
          <li>• You appreciate diverse cuisine</li>
          <li>• You prefer tropical but developed setting</li>
          <li>• You don't need work rights</li>
          <li>• You don't need citizenship pathway</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You can't meet RM1M deposit (try S-MM2H)</li>
          <li>• You want citizenship pathway</li>
          <li>• You need full work rights</li>
          <li>• You prefer four seasons</li>
          <li>• You want Western legal system</li>
          <li>• You dislike hot, humid weather</li>
          <li>• You want simpler visa process (try Thailand)</li>
          <li>• You want lower deposit (try Philippines)</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Malaysia vs. SE Asia Alternatives</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investor Route</th>
            <th class="px-4 py-2 text-left">Deposit/Investment</th>
            <th class="px-4 py-2 text-left">Duration</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Malaysia (MM2H)</td>
            <td class="px-4 py-2">Fixed Deposit</td>
            <td class="px-4 py-2">RM1,000,000</td>
            <td class="px-4 py-2">5 years renewable</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Malaysia (S-MM2H)</td>
            <td class="px-4 py-2">Sarawak Deposit</td>
            <td class="px-4 py-2">RM150K-300K</td>
            <td class="px-4 py-2">5-10 years</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Thailand</td>
            <td class="px-4 py-2">Elite / LTR</td>
            <td class="px-4 py-2">฿600K-1M / Income-based</td>
            <td class="px-4 py-2">5-20 years</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Philippines</td>
            <td class="px-4 py-2">SRRV</td>
            <td class="px-4 py-2">$10K-50K deposit</td>
            <td class="px-4 py-2">Permanent</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Indonesia</td>
            <td class="px-4 py-2">Second Home Visa</td>
            <td class="px-4 py-2">$130K assets + income</td>
            <td class="px-4 py-2">5-10 years</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>S-MM2H advantage:</strong> If the RM1M federal requirement is too high, Sarawak's S-MM2H offers similar benefits at RM150K-300K deposit. You can live in Sarawak (Kuching, Borneo) and travel freely throughout Malaysia. Many expats prefer this route since the 2021 changes.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Malaysia offers several pathways for long-term residence. The federal MM2H is the most well-known but has strict requirements since 2021. Sarawak's S-MM2H and the new Premium Visa Programme offer alternatives.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">MM2H (Malaysia My Second Home) - Federal</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The flagship long-term residence program. Requirements increased significantly in October 2021:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Financial Requirements</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Fixed deposit: <strong>RM1,000,000</strong></li>
            <li>• Monthly offshore income: <strong>RM40,000</strong></li>
            <li>• Liquid assets: RM1,500,000+</li>
            <li>• Can withdraw RM500K after 1 year (property, education, medical)</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Benefits</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• 5-year multiple entry visa (renewable)</li>
            <li>• Purchase property (RM1M+ minimum)</li>
            <li>• Bring dependents (spouse, children under 34)</li>
            <li>• Import one car duty-free</li>
            <li>• Live anywhere in Malaysia</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Age 50+ Considerations</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Same RM1M deposit as younger applicants</li>
            <li>• Can show pension instead of employment income</li>
            <li>• Health insurance mandatory (age 35+)</li>
            <li>• Medical check required</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Work Rights</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Part-time work allowed (20 hours/week max)</li>
            <li>• Must apply for work endorsement</li>
            <li>• Restricted sectors only</li>
            <li>• Cannot compete with locals</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Sarawak S-MM2H</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Sarawak (Malaysian Borneo) runs its own program with much lower requirements. Popular since federal MM2H increased:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Financial Requirements (50+)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Fixed deposit: <strong>RM150,000</strong></li>
            <li>• Monthly income: RM10,000 pension/income</li>
            <li>• Much more accessible than federal</li>
            <li>• Can withdraw RM50K for property</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Financial Requirements (35-49)</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Fixed deposit: <strong>RM300,000</strong></li>
            <li>• Monthly income: RM10,000</li>
            <li>• Still much lower than federal RM1M</li>
            <li>• Can withdraw RM100K for property</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Benefits</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• 5 or 10-year visa options</li>
            <li>• Live in Sarawak (Kuching, Miri)</li>
            <li>• Travel freely in all Malaysia</li>
            <li>• Simpler application process</li>
            <li>• Borneo nature and lifestyle</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Considerations</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Must reside primarily in Sarawak</li>
            <li>• Less developed than KL</li>
            <li>• Fewer international flights</li>
            <li>• Great for nature lovers</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Premium Visa Programme (New 2024)</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">A new program launched in 2024 targeting high-net-worth individuals with simpler requirements:</p>

      <div class="space-y-4">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Tier 1: Premium</h4>
          <p class="text-neutral-700 text-sm">Fixed deposit: RM1,000,000. Duration: 20 years. Multiple entry, renewable, bring dependents.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Tier 2: Platinum</h4>
          <p class="text-neutral-700 text-sm">Fixed deposit: RM2,500,000. Duration: 20 years. Additional benefits including premium services and faster processing.</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Tier 3: Diamond</h4>
          <p class="text-neutral-700 text-sm">Fixed deposit: RM5,000,000. Duration: 20 years. Highest tier with VIP services, priority processing, and enhanced benefits.</p>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Labuan Work Permit / Company Setup</h3>

    <div class="border-l-4 border-amber-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For those who need work rights, Labuan (federal territory) offers a business-friendly option:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Set up Labuan company (RM50K minimum capital)</li>
        <li>2-year work permit (renewable)</li>
        <li>Low tax jurisdiction (3% on profits or RM20K flat)</li>
        <li>International banking and business services</li>
        <li>Can employ foreign staff</li>
      </ul>

      <p class="text-neutral-600">Best for genuine business operators. Not a residence-only option—requires active business activities.</p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> MM2H is not a path to permanent residence or citizenship. Even after 20+ years, you remain on long-term visa. Malaysia does not offer citizenship by investment. If citizenship matters, consider other countries.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Insurance is Mandatory for MM2H (Age 35+)</h3>
      <p class="text-green-800">
        MM2H participants aged 35 and above must have valid medical insurance from a Malaysian-approved insurer. This is a visa condition—you cannot maintain MM2H status without current coverage. Local or international policies accepted, but must cover Malaysia.
      </p>
    </div>

    <p class="mb-4">
      Malaysia has excellent private healthcare, but hospitals expect payment upfront or insurance guarantee. Without coverage, you'll pay cash (still affordable) or face delays in non-emergency treatment.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Malaysia</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
