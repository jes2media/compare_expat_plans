---
import Layout from '../../../../layouts/Layout.astro';
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const title = "Egypt Golden Visa & Investor Residency Guide 2025";
const description = "Complete guide to Egypt's Golden Visa program launched 2024. Investment from $300,000, 3-5 year renewable residence, affordable healthcare, and strategic Africa-MENA gateway.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Compare Expat Plans"
  },
  "datePublished": "2025-01-15",
  "dateModified": "2025-01-15"
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <PageShell
    title={title}
    subtitle="Your complete guide to investor residency in Egypt"
    heroImage="/images/countries/egypt-hero-bg.png"
  >
    <!-- Quick Facts Box -->
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-bold text-primary-900 mb-4">Egypt Golden Visa: Quick Facts</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="font-semibold text-neutral-700">Minimum Investment:</span>
          <span class="text-neutral-900"> $300,000 (real estate/company)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Residency Duration:</span>
          <span class="text-neutral-900"> 3 or 5 years (renewable)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Processing Time:</span>
          <span class="text-neutral-900"> 2-4 months</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Path to Citizenship:</span>
          <span class="text-neutral-900"> Possible after 10+ years continuous residence</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Healthcare Quality:</span>
          <span class="text-neutral-900"> Good private care in Cairo, variable elsewhere</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Insurance Requirement:</span>
          <span class="text-neutral-900"> Recommended (not strictly mandatory)</span>
        </div>
      </div>
    </div>

    <!-- Overview Section -->
    <section id="overview" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>
      <p class="text-neutral-700 mb-4">
        Egypt launched its Golden Visa program in 2024, positioning itself as an affordable entry point into
        Africa and the Middle East. As the Arab world's most populous nation with 110+ million people, Egypt
        offers investors access to a vast domestic market, a young workforce, and strategic positioning
        between Europe, Africa, and Asia via the Suez Canal.
      </p>
      <p class="text-neutral-700 mb-4">
        Investment thresholds start at $300,000 for real estate or company formation, with higher tiers
        offering longer residency periods and additional benefits. The program targets investors, entrepreneurs,
        and retirees seeking an affordable base with rich cultural heritage and improving infrastructure.
        New cities like the New Administrative Capital showcase Egypt's modernization ambitions.
      </p>
      <p class="text-neutral-700 mb-4">
        Healthcare varies significantly between Cairo's excellent private hospitals and rural areas with
        limited facilities. International health insurance with evacuation coverage is strongly recommended—
        while routine care is affordable, complex procedures may require travel to Cairo or regional evacuation
        to Dubai or European centers.
      </p>
    </section>

    <!-- Quick Decision Guide -->
    <section id="decision-guide" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-green-800 mb-3">Egypt Golden Visa is Ideal If You:</h3>
          <ul class="space-y-2 text-green-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Want affordable Africa/MENA market access</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Seek low cost of living with rich culture</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Target Egypt's 110M+ domestic market</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Plan to base in Cairo with good private healthcare</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Want real estate investment in emerging market</span>
            </li>
          </ul>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-amber-800 mb-3">Consider Alternatives If You:</h3>
          <ul class="space-y-2 text-amber-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Need world-class healthcare throughout the country</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Want a faster path to citizenship</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Prefer established investor visa programs</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Uncomfortable with bureaucracy and currency volatility</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Need strong second passport for visa-free travel</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA Box -->
    <CTABox variant="highlight">
      <p class="mb-4">
        <strong>Planning your Egypt Golden Visa?</strong> Get international health insurance with evacuation
        coverage essential for life in Egypt.
      </p>
      <a href="/insurance-for/expats" class="inline-block bg-white text-primary-700 font-semibold px-6 py-2 rounded hover:bg-primary-50 transition" style="color: #1d4ed8 !important;">
        Compare Expat Insurance Plans
      </a>
    </CTABox>

    <!-- Official Requirements Section -->
    <section id="requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Official Requirements</h2>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Investment Options</h3>

        <div class="space-y-4">
          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 1: Real Estate Investment</h4>
            <p class="text-neutral-700 text-sm mt-1">
              Purchase property worth $300,000+ for 3-year residence, or $500,000+ for 5-year residence.
              Property must be in approved developments. New Administrative Capital and New Alamein popular choices.
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 2: Company Formation</h4>
            <p class="text-neutral-700 text-sm mt-1">
              Establish a company with $350,000+ paid-up capital for 3-year residence, or $500,000+ for 5-year.
              Company must be operational and create local employment.
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 3: Government Bonds/Treasury Bills</h4>
            <p class="text-neutral-700 text-sm mt-1">
              Deposit $500,000+ in Egyptian government bonds or treasury bills for 5-year residence.
              Funds must remain invested for the duration of residency.
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 4: Bank Deposit</h4>
            <p class="text-neutral-700 text-sm mt-1">
              Deposit $300,000+ in an Egyptian bank for 3 years (non-withdrawable) for 3-year residence,
              or $500,000+ for 5-year residence.
            </p>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Eligibility Criteria</h3>
        <ul class="space-y-2 text-neutral-700">
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Age:</strong> 18 years or older</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Clean criminal record:</strong> No serious criminal convictions</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Source of funds:</strong> Legitimate proof of investment capital</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Health clearance:</strong> Medical exam for infectious diseases</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Family inclusion:</strong> Spouse and dependent children eligible</span>
          </li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Required Documents</h3>
        <ul class="space-y-2 text-neutral-700">
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Valid passport (6+ months validity)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Completed Golden Visa application form</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Proof of investment (property deed, company registration, bank statement)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Source of funds documentation (bank statements, tax returns)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Police clearance certificate from home country (apostilled)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Medical examination report</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Passport-sized photos (white background)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span>Marriage certificate and children's birth certificates (if applicable)</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Insurance Requirements Section -->
    <section id="insurance-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-amber-800 mb-2">Insurance Status: Strongly Recommended</h3>
        <p class="text-amber-900">
          While Egypt doesn't strictly mandate health insurance for Golden Visa holders, comprehensive
          international coverage with evacuation benefits is essential due to healthcare quality variations
          outside Cairo. Most applicants provide insurance documentation as part of their application.
        </p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Recommended Coverage</h3>
        <ul class="space-y-2 text-neutral-700">
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Minimum coverage:</strong> $100,000+ recommended for comprehensive care</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Medical evacuation:</strong> Essential—coverage to Dubai, Europe, or home country</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Inpatient coverage:</strong> Hospital stays, surgeries, intensive care</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Outpatient coverage:</strong> Doctor visits, specialists, diagnostics</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Emergency coverage:</strong> 24/7 worldwide emergency assistance</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Provider note:</strong> International insurers preferred for MENA evacuation networks</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Recommended Insurance Providers -->
    <section id="insurance-providers" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>
      <p class="text-neutral-700 mb-6">
        International health insurance is strongly recommended for Egypt Golden Visa holders due to
        healthcare quality variations and the importance of evacuation coverage. These providers offer
        suitable plans:
      </p>

      <ComparisonTable
        columns={["Provider", "Best For", "Coverage", "Monthly Cost", "Key Feature"]}
        rows={[
          ["Cigna Global", "Comprehensive coverage", "$1M-$2M+", "$350-700+", "Strong MENA network"],
          ["Allianz Care", "Families", "$500K-$2M", "$300-600+", "Multi-country coverage"],
          ["BUPA Global", "Premium care seekers", "$1M+", "$400-800+", "Direct billing Cairo hospitals"],
          ["SafetyWing", "Budget/remote workers", "$250K", "$80-150", "Affordable with evacuation"],
          ["IMG Global", "Flexible plans", "$500K-$2M", "$200-450", "Good evacuation network"]
        ]}
      />

      <p class="text-sm text-neutral-600 mt-4">
        *Costs vary by age, coverage level, and deductible. Prices shown are estimates for individuals aged 35-45.
      </p>
    </section>

    <!-- CTA Box -->
    <CTABox>
      <p class="mb-4">
        <strong>Need insurance with MENA evacuation coverage?</strong> Compare international plans
        suitable for Egypt residents.
      </p>
      <a href="/best/expat-health-insurance" class="inline-block bg-primary-600 text-white font-semibold px-6 py-2 rounded hover:bg-primary-700 transition" style="color: white !important;">
        Compare Insurance Plans
      </a>
    </CTABox>

    <!-- Costs Breakdown Section -->
    <section id="costs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Golden Visa Fees</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Application fee</span>
            <span class="font-semibold text-neutral-900">$1,000-2,000</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Residence card issuance</span>
            <span class="font-semibold text-neutral-900">$200-500</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Legal and processing fees</span>
            <span class="font-semibold text-neutral-900">$2,000-5,000</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Document translation/legalization</span>
            <span class="font-semibold text-neutral-900">$500-1,000</span>
          </div>
          <div class="flex justify-between items-center pt-2">
            <span class="text-neutral-900 font-semibold">Total Processing Costs</span>
            <span class="font-bold text-primary-600">$4,000-8,500</span>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Investment Thresholds Summary</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Real estate (3-year)</span>
            <span class="font-semibold text-neutral-900">$300,000+</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Real estate (5-year)</span>
            <span class="font-semibold text-neutral-900">$500,000+</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Company formation (3-year)</span>
            <span class="font-semibold text-neutral-900">$350,000+</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Bank deposit (3-year)</span>
            <span class="font-semibold text-neutral-900">$300,000+</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-neutral-700">Government bonds (5-year)</span>
            <span class="font-semibold text-neutral-900">$500,000+</span>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Living Costs in Egypt (Monthly)</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Rent (1BR Cairo upscale area)</span>
            <span class="font-semibold text-neutral-900">$400-800</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Rent (3BR Cairo upscale area)</span>
            <span class="font-semibold text-neutral-900">$800-1,500</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Utilities (electricity, water, internet)</span>
            <span class="font-semibold text-neutral-900">$80-150</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Groceries</span>
            <span class="font-semibold text-neutral-900">$200-400</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Health insurance</span>
            <span class="font-semibold text-neutral-900">$150-500</span>
          </div>
          <div class="flex justify-between items-center border-b border-neutral-100 pb-2">
            <span class="text-neutral-700">Domestic help (common in Egypt)</span>
            <span class="font-semibold text-neutral-900">$100-200</span>
          </div>
          <div class="flex justify-between items-center pt-2">
            <span class="text-neutral-900 font-semibold">Comfortable Monthly Budget</span>
