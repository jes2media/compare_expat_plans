  { key: "notes", header: "Key Details" },
];

const investmentRows = [
  { option: "Enterprise Investment", amount: "€1,000,000", duration: "3+ years", notes: "Investment in Irish business creating/maintaining jobs" },
  { option: "Investment Fund", amount: "€1,000,000", duration: "3+ years", notes: "Approved fund investing in Irish SMEs" },
  { option: "Real Estate (REIT)", amount: "€2,000,000", duration: "3+ years", notes: "Irish Real Estate Investment Trust" },
