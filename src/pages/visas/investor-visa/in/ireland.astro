const insuranceRows = [
  { feature: "Visa Requirement", private: "REQUIRED for IIP", public: "Not accepted initially" },
  { feature: "Monthly Cost", private: "€150-500+", public: "Free (after residency)" },
  { feature: "Eligibility", private: "Anyone can purchase", public: "After ordinary residency" },
  { feature: "GP Access", private: "Immediate, full choice", public: "Free GP card if eligible" },
  { feature: "Hospital Care", private: "Private hospitals, no wait", public: "Public hospitals, may wait" },
  { feature: "Waiting Times", private: "Days to weeks", public: "Weeks to months" },
  { feature: "Coverage Level", private: "Comprehensive", public: "Basic to comprehensive" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "€300-600", strengths: "Global coverage, high net worth individuals" },
  { provider: "Bupa Global", type: "International", price: "€350-700", strengths: "Premium service, worldwide network" },
  { provider: "Allianz Care", type: "International", price: "€250-500", strengths: "Flexible plans, strong EU coverage" },
  { provider: "Laya Healthcare", type: "Irish Private", price: "€150-400", strengths: "Local network, established Irish insurer" },
  { provider: "Irish Life Health", type: "Irish Private", price: "€150-350", strengths: "Good value, broad hospital access" },
  { provider: "VHI Healthcare", type: "Irish Private", price: "€150-400", strengths: "Largest Irish insurer, comprehensive" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
