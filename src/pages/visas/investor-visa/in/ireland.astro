  { step: "Source of funds verification", duration: "1-2 months", location: "Financial advisors" },
  { step: "Select investment option", duration: "2-4 weeks", location: "With approved providers" },
  { step: "Gather documentation", duration: "4-8 weeks", location: "Various sources" },
  { step: "Submit IIP application", duration: "1 day", location: "Online to INIS" },
