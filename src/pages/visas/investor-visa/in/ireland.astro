  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Application Fee", amount: "€1,500", notes: "Non-refundable processing fee" },
  { item: "Investment (minimum)", amount: "€500,000-2,000,000", notes: "Depends on investment route" },
  { item: "Private Health Insurance", amount: "€1,800-8,400/year", notes: "€150-700/month for family" },
  { item: "Legal Fees", amount: "€5,000-20,000", notes: "Immigration and investment lawyers" },
  { item: "Due Diligence", amount: "€2,000-5,000", notes: "Background checks by approved fund" },
  { item: "Travel and Accommodation", amount: "€3,000-10,000", notes: "Dublin visits for application" },
