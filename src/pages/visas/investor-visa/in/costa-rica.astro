---
import Layout from '../../../../layouts/Layout.astro';
import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const title = "Costa Rica Investor Visa Insurance Guide 2025";
const description = "Complete guide to Costa Rica's Inversionista visa requiring $150,000 investment. Learn about insurance requirements, CAJA enrollment, and coverage for the Pura Vida lifestyle.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Compare Expat Plans"
  },
  "datePublished": "2025-01-15",
  "dateModified": "2025-01-15"
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <PageShell
    title={title}
    subtitle="Your complete guide to investor visa insurance in Costa Rica"
    heroImage="/images/countries/costa-rica-hero-bg.png"
  >
    <!-- Quick Facts Box -->
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-bold text-primary-900 mb-4">Costa Rica Investor Visa: Quick Facts</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="font-semibold text-neutral-700">Investment Minimum:</span>
          <span class="text-neutral-900"> $150,000 USD</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Processing Time:</span>
          <span class="text-neutral-900"> 3-6 months</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Initial Validity:</span>
          <span class="text-neutral-900"> 2 years (renewable)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Path to Citizenship:</span>
          <span class="text-neutral-900"> 7 years (5 for some nationalities)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Healthcare System:</span>
          <span class="text-neutral-900"> CAJA (mandatory enrollment)</span>
        </div>
        <div>
          <span class="font-semibold text-neutral-700">Insurance Requirement:</span>
          <span class="text-neutral-900"> Required for visa application</span>
        </div>
      </div>
    </div>

    <!-- Overview Section -->
    <section id="overview" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>
      <p class="text-neutral-700 mb-4">
        Costa Rica's Inversionista (Investor) visa offers a pathway to residency in one of Central America's most stable and
        popular expat destinations. With a minimum investment of $150,000 USD in approved sectors, investors gain the right
        to live in a country renowned for its "Pura Vida" lifestyle, excellent healthcare, and strong environmental
        commitment—Costa Rica has been carbon-neutral since 2021.
      </p>
      <p class="text-neutral-700 mb-4">
        Unlike many investment visa programs, Costa Rica requires investors to make productive investments that benefit the
        local economy—real estate alone doesn't qualify unless it's part of a tourism or business project. This makes the
        program more selective but ensures genuine economic contribution. The country doesn't offer citizenship by investment;
        instead, investors follow the standard naturalization path after 7 years of residency.
      </p>
      <p class="text-neutral-700 mb-4">
        Costa Rica's universal healthcare system (CAJA) is a major draw for expats. Residents must enroll and pay monthly
        contributions, but this provides access to comprehensive public healthcare. Many expats maintain private international
        insurance alongside CAJA for faster access to private facilities and evacuation coverage.
      </p>
    </section>

    <!-- Quick Decision Guide -->
    <section id="decision-guide" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-green-800 mb-3">Costa Rica Investor Visa is Ideal If You:</h3>
          <ul class="space-y-2 text-green-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Want to invest in a productive business or tourism project</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Prioritize quality healthcare access and lifestyle</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Value political stability and environmental sustainability</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Seek proximity to North America with easy US flights</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Are patient with bureaucratic processes (but comfortable in Spanish)</span>
            </li>
          </ul>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-amber-800 mb-3">Consider Alternatives If You:</h3>
          <ul class="space-y-2 text-amber-900">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Want pure real estate investment without business component</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Need fast-track citizenship (7-year minimum wait)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Prefer lower cost of living (Costa Rica is expensive for Latin America)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Want to avoid mandatory social security contributions</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <span>Seek significant tax advantages (Costa Rica taxes worldwide income)</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Official Requirements -->
    <section id="requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Official Requirements</h2>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Investment Options</h3>

        <div class="space-y-6">
          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 1: Business Investment ($150,000 minimum)</h4>
            <p class="text-neutral-700 mt-2">
              Investment in a Costa Rican business venture, company, or productive project. Must be registered with
              the National Registry and demonstrate economic activity. Common sectors include tourism, agriculture,
              technology, and manufacturing. Real estate projects qualify only if they generate income (hotels,
              vacation rentals, commercial development).
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 2: Forestry/Reforestation ($100,000 minimum)</h4>
            <p class="text-neutral-700 mt-2">
              Investment in certified reforestation or forestry projects. Must be approved by FONAFIFO (National
              Forestry Financing Fund). Lower investment threshold reflects Costa Rica's commitment to environmental
              sustainability. Projects must be maintained throughout the residency period.
            </p>
          </div>

          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold text-neutral-900">Option 3: Export/Manufacturing Investment ($150,000 minimum)</h4>
            <p class="text-neutral-700 mt-2">
              Investment in export-oriented businesses or manufacturing facilities. May qualify for additional
              Free Trade Zone benefits if located in designated areas. Requires formal business registration and
              compliance with export regulations.
            </p>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Eligibility Criteria</h3>
        <ul class="space-y-3 text-neutral-700">
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Clean criminal record:</strong> Police clearance from home country and any country lived in 12+ months in past 5 years</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Proof of investment:</strong> Bank statements, company registration, investment certificates</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Valid passport:</strong> At least 6 months validity remaining</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Health insurance:</strong> Coverage valid in Costa Rica (for application; CAJA enrollment required after approval)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">•</span>
            <span><strong>Proof of economic solvency:</strong> Demonstrate ability to support yourself and dependents</span>
          </li>
        </ul>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Required Documents</h3>
        <ul class="space-y-2 text-neutral-700">
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">1.</span>
            <span>Completed residency application form</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">2.</span>
            <span>Original and copy of valid passport (all pages)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">3.</span>
            <span>Birth certificate (apostilled and translated to Spanish)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">4.</span>
            <span>Marriage certificate if applicable (apostilled and translated)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">5.</span>
            <span>Criminal background check (apostilled, translated, less than 6 months old)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">6.</span>
            <span>Proof of investment ($150,000+ in approved project)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">7.</span>
            <span>Business registration documents from National Registry</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">8.</span>
            <span>Consular registration from Costa Rican consulate in home country</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">9.</span>
            <span>8 passport-sized photos</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">10.</span>
            <span>Health insurance certificate covering Costa Rica</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary-600 font-bold">11.</span>
            <span>Fingerprints taken at Organismo de Investigación Judicial (OIJ)</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Insurance Requirements -->
    <section id="insurance-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-amber-800 mb-2">Dual Insurance System</h3>
        <p class="text-amber-900">
          Costa Rica requires proof of health insurance for the visa application, but once approved, all residents
          <strong>must</strong> enroll in CAJA (Caja Costarricense de Seguro Social), the national healthcare system.
          Monthly contributions range from $50-$200+ based on declared income. Many expats maintain both CAJA and
          private international insurance for comprehensive coverage.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">For Visa Application</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Valid health insurance certificate</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Coverage valid in Costa Rica</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Duration covering residency period</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>International or local provider accepted</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">CAJA (After Approval)</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Mandatory enrollment within 3 months</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Monthly fee: $50-$200+ (income-based)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Comprehensive public healthcare access</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              <span>Includes hospitalization, medications, specialists</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-blue-800 mb-2">Why Many Expats Keep Both CAJA and Private Insurance</h3>
        <p class="text-blue-900 mb-4">
          CAJA provides excellent emergency care and affordable prescription medications, but wait times for non-emergency
          procedures can be long (months for specialists, years for elective surgery). Private insurance provides:
        </p>
        <ul class="space-y-2 text-blue-900">
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>Immediate access to private hospitals (CIMA, Clínica Bíblica, Hospital Metropolitano)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>Medical evacuation to Miami (3-hour flight) for complex procedures</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>English-speaking staff and international-standard facilities</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 font-bold">•</span>
            <span>Coverage when traveling outside Costa Rica</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Recommended Insurance Providers -->
    <section id="recommended-providers" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

      <p class="text-neutral-700 mb-6">
        These international health insurance providers are well-suited for Costa Rica investor visa holders, offering
        plans that complement CAJA coverage and provide access to private facilities.
      </p>

      <ComparisonTable
        columns={["Provider", "Annual Cost", "Best For", "Key Features"]}
        rows={[
          ["Cigna Global", "$3,000-$8,000", "Comprehensive coverage", "Global network, direct billing at private hospitals, evacuation included"],
          ["IMG Global", "$2,000-$5,000", "Flexible options", "Multiple plan tiers, US coverage optional, good value"],
          ["Allianz Care", "$2,500-$6,000", "Premium service", "Strong European network, 24/7 support, wellness benefits"],
          ["GeoBlue", "$2,500-$7,000", "US expats", "Blue Cross network, excellent US coverage, Costa Rica specialists"],
          ["SafetyWing", "$500-$1,500", "Budget option", "Nomad-friendly, basic coverage, good for younger applicants"]
        ]}
      />

      <div class="mt-6 grid md:grid-cols-2 gap-4">
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <h4 class="font-semibold text-green-800 mb-2">Local Alternative: INS (Instituto Nacional de Seguros)</h4>
          <p class="text-green-900 text-sm">
