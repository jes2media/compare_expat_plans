---
/**
 * Turkey Investor Visa - Long-form CRO-optimized page
 * Citizenship by Investment, Residence Permit, and investment options
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "investment-routes", text: "Investment Routes", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Turkey", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Turkey Insurance Guide", href: "/countries/turkey/insurance" },
  { title: "Turkey Digital Nomad Visa", href: "/visas/digital-nomad-visa/in/turkey" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Cigna Global Review", href: "/providers/cigna-global" },
  { title: "Portugal Investor Visa", href: "/visas/investor-visa/in/portugal" },
];

const visaRoutesColumns = [
  { key: "program", header: "Program" },
  { key: "investment", header: "Investment Required" },
  { key: "duration", header: "Outcome" },
  { key: "benefits", header: "Key Benefits" },
];

const visaRoutesRows = [
  { program: "Citizenship by Investment (Property)", investment: "$400,000 real estate", duration: "Turkish Citizenship", benefits: "Fast-track citizenship, passport" },
  { program: "Citizenship by Investment (Bank)", investment: "$500,000 bank deposit", duration: "Turkish Citizenship", benefits: "Liquid investment, 3-year hold" },
  { program: "Citizenship by Investment (Business)", investment: "$500,000 capital + 50 jobs", duration: "Turkish Citizenship", benefits: "Business owners, job creation" },
  { program: "Residence by Property", investment: "$200,000+ property (varies by city)", duration: "Residence Permit", benefits: "No citizenship, lower threshold" },
  { program: "Investor Residence Permit", investment: "Business investment", duration: "1-2 year residence", benefits: "Business activities, renewable" },
];

const insuranceColumns = [
  { key: "program", header: "Visa/Status" },
  { key: "requirement", header: "Insurance Requirement" },
  { key: "minimum", header: "Minimum Coverage" },
];

const insuranceRows = [
  { program: "Residence Permit (short-term)", requirement: "Mandatory", minimum: "Covers stay duration" },
  { program: "Residence Permit (long-term)", requirement: "SGK eligible or private", minimum: "Comprehensive coverage" },
  { program: "Citizenship Application", requirement: "Not required after citizenship", minimum: "N/A once citizen" },
  { program: "Work Permit holders", requirement: "SGK enrollment", minimum: "Employer-sponsored" },
  { program: "Private Insurance", requirement: "Optional/Required for residence", minimum: "Typically $50,000+" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", type: "International", price: "$200-500", strengths: "Comprehensive, global coverage" },
  { provider: "Allianz Care", type: "International", price: "$180-450", strengths: "European focus, good Turkey network" },
  { provider: "Bupa Global", type: "International", price: "$220-550", strengths: "Premium coverage, mental health" },
  { provider: "Acibadem Sigorta", type: "Turkish", price: "$100-300", strengths: "Acibadem hospital network" },
  { provider: "Allianz Turkey", type: "Turkish", price: "$80-250", strengths: "Local coverage, affordable" },
  { provider: "Anadolu Sigorta", type: "Turkish", price: "$70-200", strengths: "Budget option, basic coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Citizenship (Real Estate)", amount: "$400,000+", notes: "Property retains value, 3-year hold" },
  { item: "Citizenship (Bank Deposit)", amount: "$500,000", notes: "3-year fixed deposit, earns interest" },
  { item: "Citizenship (Capital + Jobs)", amount: "$500,000 + 50 employees", notes: "Active business investment" },
  { item: "Residence Permit Property", amount: "$200,000+ (city-dependent)", notes: "No citizenship, lower threshold" },
  { item: "Legal Fees", amount: "$5,000-15,000", notes: "Citizenship applications more complex" },
  { item: "Government Fees", amount: "$500-2,000", notes: "Varies by application type" },
  { item: "Title Transfer Tax", amount: "4%", notes: "Paid on property purchase" },
  { item: "Health Insurance", amount: "$1,000-5,000/year", notes: "Required for residence permit" },
];

const timelineColumns = [
  { key: "program", header: "Program" },
  { key: "processing", header: "Processing Time" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { program: "Citizenship by Investment", processing: "3-6 months", notes: "One of fastest CBI programs globally" },
  { program: "Property Purchase", processing: "1-3 months", notes: "Title transfer and registration" },
  { program: "Residence Permit", processing: "1-2 months", notes: "Application and biometrics" },
  { program: "Turkish Passport Issuance", processing: "2-4 weeks after citizenship", notes: "After citizenship granted" },
];
---

<PageShell
  title="Turkey Investor Visa 2026: Citizenship by Investment & Residence Guide"
  description="Complete guide to Turkey investor visas. Citizenship by Investment ($400K property), Turkish passport in 3-6 months, residence permits, and investment options."
  headline="Turkey Investor Visa: Complete Guide"
  subheadline="Everything you need to know about Turkey's investor visa options—Citizenship by Investment ($400,000 property), bank deposit routes, residence permits, and one of the fastest paths to a second passport in the world."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Premium Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/turkey-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official CBI Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Fast-Track Citizenship
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Turkey offers one of the most accessible and fastest Citizenship by Investment (CBI) programs in the world. With a $400,000 real estate investment, you can obtain Turkish citizenship—and a Turkish passport—in as little as 3-6 months. The Turkish passport provides visa-free or visa-on-arrival access to 110+ countries, making it an attractive second passport option.
    </p>

    <p class="mb-4">
      Beyond citizenship, Turkey offers residence permits for lower investment thresholds, making it accessible for those who want to live in Turkey without necessarily becoming citizens. Turkey's strategic location (Europe/Asia bridge), affordable cost of living, rich culture, and excellent healthcare make it compelling for investors, retirees, and digital nomads alike.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Turkey Investor Options</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Citizenship (Property):</strong> $400,000 real estate (3-year hold)</li>
        <li>• <strong>Citizenship (Bank):</strong> $500,000 deposit (3-year hold)</li>
        <li>• <strong>Processing:</strong> 3-6 months (one of fastest CBI globally)</li>
        <li>• <strong>Turkish Passport:</strong> 110+ countries visa-free/on-arrival</li>
        <li>• <strong>Residence Permit:</strong> $200,000+ property (city-dependent)</li>
        <li>• <strong>Family:</strong> Spouse and children under 18 included</li>
        <li>• <strong>No residency requirement:</strong> Can live anywhere after citizenship</li>
        <li>• <strong>Dual citizenship:</strong> Turkey allows dual citizenship</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Choose Turkey?</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Advantages</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Fast citizenship (3-6 months)</li>
          <li>• Relatively low threshold ($400K)</li>
          <li>• Turkish passport (110+ countries)</li>
          <li>• Dual citizenship allowed</li>
          <li>• No residency requirement after citizenship</li>
          <li>• Affordable cost of living</li>
          <li>• Excellent healthcare (medical tourism)</li>
          <li>• Strategic location (Europe/Asia)</li>
        </ul>
      </div>

      <div class="border border-amber-200 bg-amber-50 rounded-lg p-6">
        <h4 class="font-semibold text-amber-900 mb-3">Considerations</h4>
        <ul class="space-y-2 text-amber-800">
          <li>• Currency volatility (Turkish Lira)</li>
          <li>• Political uncertainty</li>
          <li>• Not EU membership (yet)</li>
          <li>• Property market risks</li>
          <li>• Regional security concerns</li>
          <li>• Bureaucracy in some processes</li>
          <li>• Language barrier (Turkish)</li>
          <li>• Male military service consideration</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Currency opportunity:</strong> The Turkish Lira has depreciated significantly, making $400,000 go much further in Turkish real estate. Some investors see this as an opportunity—buying quality property at relatively low prices. However, currency risk works both ways; property values in USD terms could decline if Lira weakens further.
      </p>
    </div>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Turkey is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want fast second passport (3-6 months)</li>
          <li>• You have $400K for real estate</li>
          <li>• You value Europe/Middle East access</li>
          <li>• You want affordable cost of living</li>
          <li>• You appreciate rich history and culture</li>
          <li>• You want quality healthcare at low cost</li>
          <li>• You don't need EU passport</li>
          <li>• You accept currency/political volatility</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need EU passport (try Portugal, Malta)</li>
          <li>• You want stable currency</li>
          <li>• You're risk-averse on politics</li>
          <li>• You want Schengen residence rights</li>
          <li>• You prefer Western European lifestyle</li>
          <li>• You want Caribbean speed ($100K options)</li>
          <li>• You need US visa-free travel</li>
          <li>• You can't commit $400K for 3 years</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Turkey vs. Other CBI Programs</h3>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm">
        <thead class="bg-neutral-100">
          <tr>
            <th class="px-4 py-2 text-left">Country</th>
            <th class="px-4 py-2 text-left">Investment</th>
            <th class="px-4 py-2 text-left">Processing</th>
            <th class="px-4 py-2 text-left">Passport Strength</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Turkey</td>
            <td class="px-4 py-2">$400K property</td>
            <td class="px-4 py-2">3-6 months</td>
            <td class="px-4 py-2">110+ countries</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Portugal (Golden Visa)</td>
            <td class="px-4 py-2">€500K+ (funds)</td>
            <td class="px-4 py-2">12-18 months (residence)</td>
            <td class="px-4 py-2">EU passport after 5 years</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Malta</td>
            <td class="px-4 py-2">€690K+ total</td>
            <td class="px-4 py-2">14-36 months</td>
            <td class="px-4 py-2">EU passport, 180+ countries</td>
          </tr>
          <tr class="border-b bg-neutral-50">
            <td class="px-4 py-2 font-medium">Caribbean (St. Kitts)</td>
            <td class="px-4 py-2">$250K donation</td>
            <td class="px-4 py-2">3-6 months</td>
            <td class="px-4 py-2">150+ countries</td>
          </tr>
          <tr class="border-b">
            <td class="px-4 py-2 font-medium">Greece</td>
            <td class="px-4 py-2">€250K property</td>
            <td class="px-4 py-2">2-3 months (residence)</td>
            <td class="px-4 py-2">EU residence, citizenship 7+ years</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Speed advantage:</strong> Turkey's 3-6 month processing to full citizenship is remarkable. Most CBI programs take 12-18 months minimum. For those who need a second passport quickly, Turkey is one of the fastest legitimate options available.
      </p>
    </div>
  </section>

  <!-- Section: Investment Routes -->
  <section id="investment-routes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Investment Routes</h2>

    <p class="mb-4">
      Turkey offers multiple pathways to citizenship and residence. The most popular is real estate investment for citizenship, but bank deposit and business routes also exist.
    </p>

    <ComparisonTable columns={visaRoutesColumns} rows={visaRoutesRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Citizenship by Investment: Real Estate ($400,000)</h3>

    <div class="border-l-4 border-blue-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">The most popular route—purchase property worth at least $400,000 and receive Turkish citizenship:</p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Requirements</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Property value: <strong>$400,000+</strong></li>
            <li>• Holding period: 3 years (cannot sell)</li>
            <li>• Can be residential or commercial</li>
            <li>• Multiple properties allowed</li>
            <li>• Must be newly purchased (not previously owned)</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Benefits</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Full Turkish citizenship</li>
            <li>• Turkish passport included</li>
            <li>• Family included (spouse + children)</li>
            <li>• No residency requirement after</li>
            <li>• Property retains value (can rent out)</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">Process</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Purchase property, get valuation report</li>
            <li>• Obtain Conformity Certificate</li>
            <li>• Apply for citizenship</li>
            <li>• Biometrics and interview</li>
            <li>• Receive citizenship (3-6 months)</li>
          </ul>
        </div>
        <div class="bg-neutral-50 rounded-lg p-4">
          <h4 class="font-semibold text-neutral-900 mb-2">After Citizenship</h4>
          <ul class="space-y-1 text-neutral-700 text-sm">
            <li>• Apply for Turkish passport</li>
            <li>• Can live anywhere (no requirement)</li>
            <li>• Can sell property after 3 years</li>
            <li>• Full citizen rights</li>
            <li>• Dual citizenship allowed</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Citizenship by Investment: Bank Deposit ($500,000)</h3>

    <div class="border-l-4 border-green-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Prefer liquid investment over real estate? Deposit $500,000 in a Turkish bank:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Deposit <strong>$500,000</strong> in Turkish bank account</li>
        <li>Fixed for 3 years (cannot withdraw)</li>
        <li>Earns interest during holding period</li>
        <li>Same citizenship outcome as property route</li>
        <li>Simpler than property (no due diligence on real estate)</li>
      </ul>

      <p class="text-neutral-600">Better for those who don't want property management or market risk. However, tied up for 3 years in Turkish bank (Lira/currency considerations).</p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Citizenship by Investment: Business ($500,000 + 50 Jobs)</h3>

    <div class="border-l-4 border-purple-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">For business owners willing to create Turkish jobs:</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Invest <strong>$500,000</strong> in Turkish company capital</li>
        <li>Create minimum 50 jobs for Turkish citizens</li>
        <li>Active business investment, not passive</li>
        <li>More complex, requires ongoing business management</li>
        <li>Same citizenship outcome</li>
      </ul>

      <p class="text-neutral-600">Best for serious business investors with capacity to manage Turkish operations. Most applicants prefer property or bank deposit routes.</p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Residence Permit by Property (No Citizenship)</h3>

    <div class="border-l-4 border-amber-500 pl-4 mb-6">
      <p class="text-neutral-600 mb-4">Lower investment threshold for residence only (not citizenship):</p>

      <ul class="list-disc pl-6 space-y-2 mb-4 text-neutral-700">
        <li>Property value: <strong>$200,000+</strong> (varies by city, higher in Istanbul)</li>
        <li>Provides residence permit (ikamet)</li>
        <li>Renewable annually</li>
        <li>Does NOT lead to citizenship</li>
        <li>Good for those who want to live in Turkey without citizenship</li>
      </ul>

      <p class="text-neutral-600">Note: Thresholds for residence by property have increased in major cities. Check current requirements—Istanbul may require higher investment than other areas.</p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important:</strong> For citizenship, property must be held for 3 years. If you sell before 3 years, citizenship can be revoked. After 3 years, you're free to sell—citizenship is permanent. Property annotation (takyidat) ensures you can't accidentally sell early.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-green-900 mb-2">Insurance Required for Residence Permit</h3>
      <p class="text-green-800">
        Turkish residence permit applications require valid health insurance covering your stay. Once you have citizenship, you can enroll in SGK (public system) or use private insurance. During the investment and application process, private health insurance is necessary.
      </p>
    </div>

    <p class="mb-4">
      Turkey has a two-tier healthcare system: SGK (public) for citizens and contributors, and excellent private hospitals for those with insurance. Private hospitals like Acibadem, Memorial, and American Hospital are world-class and popular with medical tourists.
    </p>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options in Turkey</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Cigna, Allianz, Bupa Global</li>
          <li>• Premium: $180-550/month</li>
          <li>• Global coverage</li>
          <li>• Direct billing at private hospitals</li>
          <li>• English-speaking support</li>
          <li>• Medical evacuation included</li>
          <li>• Best for expats and investors</li>
          <li>• Accepted for residence permits</li>
        </ul>
      </div>

      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Turkish Local Insurance</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Acibadem Sigorta, Allianz Turkey</li>
          <li>• Premium: $70-300/month</li>
          <li>• Turkey-focused coverage</li>
          <li>• Strong hospital networks</li>
          <li>• Turkish language (some English)</li>
          <li>• More affordable</li>
          <li>• Accepted for residence permits</li>
          <li>• Best for Turkey-based living</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Choosing the Right Insurance</h3>

    <div class="space-y-4 mb-6">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">During Citizenship Application</h4>
        <p class="text-neutral-600">Need valid insurance for residence permit during processing. Turkish local insurer (Allianz Turkey, Acibadem) is sufficient and accepted. Budget $100-200/month. Can upgrade to international after citizenship.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">After Citizenship (Resident in Turkey)</h4>
        <p class="text-neutral-600">As citizen, you can enroll in SGK (public). Many expats maintain private insurance for faster access to private hospitals. Acibadem Sigorta provides direct access to Acibadem network. Budget $100-250/month for quality private coverage.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">After Citizenship (Living Abroad)</h4>
        <p class="text-neutral-600">If you obtain citizenship but live elsewhere, international plan (Cigna, Allianz Care) provides global coverage including Turkey visits. Budget $200-400/month. Turkish passport doesn't require you to live in Turkey.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
