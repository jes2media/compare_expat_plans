---
/**
 * Italy Retirement Visa (Elective Residence Visa) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Italy", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Italy Health Insurance Guide", href: "/countries/italy/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Annual Income", details: "€31,000+/year (~$33,500) or equivalent assets", evidence: "Pension statements, bank statements, investment proof" },
  { requirement: "Accommodation", details: "Proof of suitable housing in Italy", evidence: "Rental contract, property deed" },
  { requirement: "Health Insurance", details: "Full coverage valid in Italy", evidence: "Insurance certificate" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Criminal background check (apostilled)" },
  { requirement: "No Work Intent", details: "Cannot work in Italy", evidence: "Declaration of non-employment" },
  { requirement: "Valid Passport", details: "Valid 3+ months beyond visa", evidence: "Passport with blank pages" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Italy Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive, no specific minimum", why: "Must cover hospitalization & treatment" },
  { feature: "Coverage Territory", minimum: "Valid in Italy/EU", why: "Schengen-compliant" },
  { feature: "Emergency Repatriation", minimum: "Recommended", why: "Consulates often verify" },
  { feature: "Duration", minimum: "Full visa period (1 year+)", why: "Must match or exceed visa dates" },
  { feature: "Pregnancy/Maternity", minimum: "Check if needed", why: "Some policies exclude this" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€200-450", strengths: "Premium comprehensive, pre-existing" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€180-400", strengths: "Strong EU network" },
  { provider: "AXA Global", coverage: "€500,000+", price: "€170-380", strengths: "Good Italy coverage" },
  { provider: "IMG Global", coverage: "€500,000+", price: "€150-350", strengths: "Flexible options" },
  { provider: "Italian SSN", coverage: "Public system", price: "~€400/year", strengths: "After residency established (voluntary)" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€116", notes: "National visa fee" },
  { item: "Permesso di Soggiorno", amount: "€100-150", notes: "Residence permit kit + fees" },
  { item: "Health Insurance (Annual)", amount: "€2,000-5,500", notes: "Age-dependent, private coverage" },
  { item: "Codice Fiscale", amount: "Free", notes: "Tax code (required for everything)" },
  { item: "Document Apostille", amount: "€50-200", notes: "Per document, home country" },
  { item: "Translation", amount: "€30-60/page", notes: "Certified translation if needed" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "4-8 weeks", location: "Home country" },
  { step: "Secure Italian accommodation", duration: "Varies", location: "Italy (remotely possible)" },
  { step: "Purchase health insurance", duration: "1-3 days", location: "Online" },
  { step: "Schedule consulate appointment", duration: "2-8 weeks", location: "Italian consulate" },
  { step: "Submit visa application", duration: "1 day", location: "Italian consulate" },
  { step: "Processing", duration: "30-90 days", location: "Consulate review" },
  { step: "Receive visa", duration: "Pick up", location: "Consulate" },
  { step: "Enter Italy", duration: "Within 90 days", location: "Italy" },
  { step: "Apply for Permesso di Soggiorno", duration: "Within 8 days of arrival", location: "Post office + Questura" },
];
---

<PageShell
  title="Italy Elective Residence Visa 2025: Retirement Visa Requirements, Insurance & Application Guide"
  description="Complete guide to Italy's Elective Residence Visa for retirees. Income requirements, health insurance, permesso di soggiorno process, and la dolce vita retirement."
  headline="Italy Elective Residence Visa: Retirement Insurance & Requirements Guide"
  subheadline="Everything you need to know about retiring to Italy—income requirements, healthcare access, the permesso process, and living la dolce vita."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Retirement Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU Pathway
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Italy's Visto per Residenza Elettiva (Elective Residence Visa) is designed for retirees and others who want to live in Italy without working. From Tuscan hillsides to Amalfi Coast views, Italian lakes to Roman piazzas, Italy offers retirees one of the world's most enviable lifestyles—la dolce vita is real.
    </p>

    <p class="mb-4">
      The visa is explicitly for those who can support themselves through pensions, savings, or passive income. Italy has higher income requirements than Portugal or Spain, but offers extraordinary cultural richness, cuisine, and quality of life that has drawn expats for centuries.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Italy Elective Residence Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Visto per Residenza Elettiva (Elective Residence)</li>
        <li>• <strong>Income requirement:</strong> €31,000+/year (~$33,500) or equivalent</li>
        <li>• <strong>Initial duration:</strong> 1-2 years</li>
        <li>• <strong>Renewal:</strong> 2-year permits thereafter</li>
        <li>• <strong>Work allowed:</strong> No—strictly passive income only</li>
        <li>• <strong>Path to citizenship:</strong> 10 years of residency</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Italy for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Unmatched cultural heritage:</strong> Art, history, architecture at every turn</li>
      <li><strong>World-class cuisine:</strong> Regional specialties, fresh ingredients, wine</li>
      <li><strong>Regional diversity:</strong> Alps, lakes, Tuscany, coast, islands—every landscape</li>
      <li><strong>Good healthcare:</strong> Italy's SSN ranks well internationally</li>
      <li><strong>Affordable (outside major cities):</strong> Southern Italy and small towns offer value</li>
      <li><strong>EU residency:</strong> Schengen travel, pathway to permanent residency</li>
      <li><strong>Climate variety:</strong> Mediterranean south, alpine north, mild central</li>
      <li><strong>Flat-rate tax option:</strong> 7% flat tax for retirees in certain southern regions</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Italy is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You have €31,000+/year in passive income</li>
          <li>✓ You don't need to work</li>
          <li>✓ You love Italian culture, food, and wine</li>
          <li>✓ You appreciate art, history, and beauty</li>
          <li>✓ You're willing to learn Italian</li>
          <li>✓ You can navigate bureaucracy patiently</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Income below €31,000/year (Portugal has lower threshold)</li>
          <li>• You need to work (Italy DNV instead)</li>
          <li>• You want English-speaking environment</li>
          <li>• You dislike bureaucracy (Italy has lots)</li>
          <li>• You want faster citizenship path</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Tax benefit:</strong> Italy offers a special 7% flat tax rate on foreign income for retirees who move to qualifying southern regions (including Sicily, Sardinia, Calabria, and others with populations under 20,000). This can result in significant tax savings.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Italy's Elective Residence Visa requires demonstrating sufficient passive income to live without working. The €31,000/year guideline is substantial but ensures applicants can live comfortably in Italy.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Requirements Detail</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Single Applicant</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Guideline:</strong> €31,000+/year (~$33,500)</li>
          <li>• <strong>Monthly:</strong> ~€2,580/month</li>
          <li>• <strong>Assets alternative:</strong> Substantial savings may qualify</li>
          <li>• <strong>Proof:</strong> Pension statements, bank statements</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Couple/Family</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Spouse:</strong> +20% (~€6,200 more)</li>
          <li>• <strong>Each dependent:</strong> +5% per child</li>
          <li>• <strong>Couple total:</strong> ~€37,200+/year</li>
          <li>• <strong>Consulate discretion:</strong> May vary</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Consulate variation:</strong> Italian consulates have significant discretion. Some may accept lower income with substantial assets; others strictly enforce the guideline. Your specific consulate's interpretation matters—research their requirements.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Accommodation Requirement</h3>

    <p class="mb-4">
      You must prove you have suitable accommodation in Italy before applying. This can be:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Rental contract:</strong> At least one year, registered properly</li>
      <li><strong>Property ownership:</strong> Deed to owned Italian property</li>
      <li><strong>Letter from host:</strong> If staying with someone (less common)</li>
    </ul>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mt-6">
      <p class="text-red-800">
        <strong>No work allowed:</strong> The Elective Residence Visa strictly prohibits any employment or self-employment in Italy. If you want to do any remote work, you need Italy's digital nomad visa instead.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required</h3>
      <p class="text-red-800">
        Italy requires comprehensive health insurance valid for the duration of your stay. Unlike Spain, Italy doesn't have strict no-copay requirements, but your policy must demonstrate adequate medical coverage including hospitalization.
      </p>
    </div>

    <p class="mb-4">
      After establishing residency, you have the option to voluntarily join Italy's public healthcare system (SSN) by paying an annual fee—currently around €400/year. Many expats do this while keeping private insurance for additional coverage.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Specifications</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Healthcare Options in Italy</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Private Insurance (Required Initially)</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Required for visa application</li>
          <li>✓ Faster access to specialists</li>
          <li>✓ Choice of doctors/hospitals</li>
          <li>✓ English-speaking options</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">SSN (Voluntary, After Residency)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ ~€400/year voluntary contribution</li>
          <li>✓ Access to public hospitals/doctors</li>
          <li>✓ Prescriptions at reduced cost</li>
          <li>✓ Many keep private too</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need comprehensive health insurance for Italy's Elective Residence Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Italy-Ready Insurance →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These international providers offer plans suitable for Italy's Elective Residence Visa. Italy's requirements are less strict than Spain's, giving you more flexibility in plan selection.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">Cigna Global for comprehensive coverage including pre-existing conditions. Higher cost but peace of mind for those with health concerns.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Good Value</h4>
        <p class="text-neutral-600">IMG Global offers competitive rates with solid coverage. Good balance of cost and comprehensive protection.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU Network</h4>
        <p class="text-neutral-600">Allianz Care provides strong networks throughout the EU, ideal if you plan to travel extensively from your Italian base.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Strategy</h4>
        <p class="text-neutral-600">After residency, many retirees join SSN (~€400/year) for basic coverage while keeping a lighter private policy for extras.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Italy offers significant cost variation. Milan and Rome are expensive, but southern Italy, small towns, and rural areas provide excellent value. Many retirees discover they can live well on far less than northern European costs.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Typical Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€4,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With Legal Help</p>
        <p class="text-3xl font-bold text-neutral-900">€6,500</p>
        <p class="text-sm text-neutral-500 mt-2">Full relocation assistance</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost of Living</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Milan/Rome:</strong> €2,500-4,000/month (city apartment, comfortable lifestyle)</li>
      <li><strong>Florence/Venice:</strong> €2,000-3,000/month (good apartment, dining out)</li>
      <li><strong>Tuscany/Umbria towns:</strong> €1,500-2,500/month (comfortable, beautiful setting)</li>
      <li><strong>Southern Italy:</strong> €1,200-2,000/month (very comfortable, excellent value)</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>€1 houses:</strong> You may have heard about Italy's €1 house programs in depopulating towns. These are real but require significant renovation investment. Consider them an adventure rather than a budget strategy.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Italian visa process involves applying at the consulate in your home country, then completing the permesso di soggiorno (residence permit) process after arrival. Italy's bureaucracy is legendary—patience is essential.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Secure Italian Accommodation</h4>
          <p class="text-neutral-600">Find and sign a rental contract or purchase property. You need proof of accommodation before applying. Consider a scouting trip or work with a relocation agent.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect proof of income/assets, criminal background check, passport photos, accommodation proof. Check your specific consulate's requirements—they vary.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apostille and Translate Documents</h4>
          <p class="text-neutral-600">Get Hague Apostilles for official documents. Some consulates require Italian translations; others accept English. Verify with your consulate.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get comprehensive health insurance covering Italy for the visa duration. Request a certificate showing coverage details.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Schedule Consulate Appointment</h4>
          <p class="text-neutral-600">Book an appointment at your Italian consulate. Wait times vary significantly. Bring all originals and copies as specified.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Visa Application</h4>
          <p class="text-neutral-600">Attend your appointment with all documents. Pay the €116 fee. Processing takes 30-90 days. You may be asked for additional documentation.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Italy and Apply for Permesso</h4>
          <p class="text-neutral-600">Within 8 days of arrival, go to a post office to submit your permesso di soggiorno kit. You'll receive an appointment at the Questura (police station) for fingerprinting.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>8-day deadline:</strong> Italy requires you to apply for your residence permit within 8 days of arrival. This is strict—don't delay. Go to any post office and ask for the "Kit per Permesso di Soggiorno."
      </p>
    </div>
  </section>

