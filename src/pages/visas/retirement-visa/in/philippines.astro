---
/**
 * Philippines Retirement Visa (SRRV) - Long-form CRO-optimized page
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in the Philippines", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Philippines Health Insurance Guide", href: "/countries/philippines/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "visaType", header: "SRRV Type" },
  { key: "age", header: "Age Requirement" },
  { key: "deposit", header: "Required Deposit" },
  { key: "pension", header: "Pension Option" },
];

const requirementsRows = [
  { visaType: "SRRV Smile", age: "35+", deposit: "$20,000", pension: "N/A" },
  { visaType: "SRRV Classic", age: "50+ with pension", deposit: "$10,000", pension: "$800/month pension" },
  { visaType: "SRRV Classic", age: "50+ no pension", deposit: "$20,000", pension: "N/A" },
  { visaType: "SRRV Human Touch", age: "35+ (medical)", deposit: "$10,000", pension: "For medical treatment" },
  { visaType: "SRRV Courtesy", age: "50+", deposit: "$1,500", pension: "Former Filipino citizens" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Philippines Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Health Insurance", minimum: "Recommended (not mandatory)", why: "Healthcare costs add up" },
  { feature: "PhilHealth Option", minimum: "Available after residency", why: "Subsidized public coverage" },
  { feature: "Private Option", minimum: "International or local", why: "Better hospital access" },
  { feature: "Emergency Evacuation", minimum: "Strongly recommended", why: "For serious conditions" },
  { feature: "Coverage Area", minimum: "Philippines + home country", why: "Many travel back for care" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "PhilHealth", coverage: "Basic public", price: "$20-50 (subsidized)", strengths: "Cheapest, local hospitals" },
  { provider: "Maxicare", coverage: "₱500K-5M", price: "$80-200", strengths: "Best local HMO" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-450", strengths: "Comprehensive, evacuation" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$150-350", strengths: "Good value, flexible" },
  { provider: "Pacific Cross", coverage: "₱1M-10M", price: "$100-250", strengths: "Regional specialist" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "SRRV Deposit", amount: "$10,000-20,000", notes: "Refundable upon visa cancellation" },
  { item: "Processing Fee", amount: "$1,400", notes: "Non-refundable" },
  { item: "Annual Fee", amount: "$360", notes: "Yearly renewal" },
  { item: "ID Card", amount: "$10", notes: "SRRV ID" },
  { item: "Medical Exam", amount: "$50-100", notes: "Required for application" },
  { item: "Document Authentication", amount: "$100-200", notes: "Apostilles and translations" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Submit pre-application", duration: "1-2 weeks", location: "Online/PRA" },
  { step: "Arrive in Philippines", duration: "Travel", location: "Manila" },
  { step: "Medical exam", duration: "1-2 days", location: "Accredited clinic" },
  { step: "Deposit funds", duration: "1-2 days", location: "Accredited bank" },
  { step: "PRA processing", duration: "2-4 weeks", location: "PRA office, Manila" },
  { step: "Visa issuance", duration: "1-2 days", location: "Bureau of Immigration" },
];
---

<PageShell
  title="Philippines Retirement Visa 2025: SRRV Requirements & Insurance Guide"
  description="Complete guide to the Philippines SRRV retirement visa. $10,000-$20,000 deposit, English-speaking country, low cost of living, and tropical island lifestyle."
  headline="Philippines Retirement Visa: SRRV Insurance & Requirements Guide"
  subheadline="Everything you need to know about the Special Resident Retiree's Visa—deposit requirements, why English-speaking retirees love the Philippines, and navigating the healthcare system."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Retirement Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      PRA Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      English-Speaking Country
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The Philippines offers one of the most accessible retirement visa programs in Asia through its Special Resident Retiree's Visa (SRRV), administered by the Philippine Retirement Authority (PRA). With English as an official language and a low cost of living, it's particularly popular with American, British, and Australian retirees.
    </p>

    <p class="mb-4">
      Unlike income-based retirement visas in other countries, the SRRV requires a one-time deposit ($10,000-$20,000 depending on age and pension) held in a Philippine bank. This deposit is fully refundable if you cancel the visa and leave the country, making it more of a "bond" than a fee.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Philippines SRRV</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>SRRV Classic (50+):</strong> $10,000 with pension, $20,000 without</li>
        <li>• <strong>SRRV Smile (35+):</strong> $20,000 deposit (can invest in condo)</li>
        <li>• <strong>Deposit:</strong> Refundable upon visa cancellation</li>
        <li>• <strong>Annual fee:</strong> $360/year</li>
        <li>• <strong>Language:</strong> English widely spoken</li>
        <li>• <strong>Duration:</strong> Indefinite (renewable annually)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why the Philippines for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>English-speaking:</strong> Official language, easy communication</li>
      <li><strong>Low cost of living:</strong> $1,000-2,000/month comfortable lifestyle</li>
      <li><strong>Tropical climate:</strong> Beaches, islands, warm year-round</li>
      <li><strong>Friendly culture:</strong> Filipinos known for hospitality</li>
      <li><strong>Large expat community:</strong> Established support networks</li>
      <li><strong>US-influenced:</strong> Familiar culture, food, systems</li>
      <li><strong>Direct flights:</strong> From US West Coast and major Asian cities</li>
      <li><strong>7,000+ islands:</strong> Beach, mountain, or city—your choice</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Philippines is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ English fluency is important to you</li>
          <li>✓ You have $10,000-$20,000 for deposit</li>
          <li>✓ You love tropical beach/island lifestyle</li>
          <li>✓ You want very low cost of living</li>
          <li>✓ You appreciate American-influenced culture</li>
          <li>✓ You're comfortable with developing infrastructure</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want top-tier healthcare (Thailand, Malaysia better)</li>
          <li>• You prefer first-world infrastructure</li>
          <li>• You're concerned about typhoons and natural disasters</li>
          <li>• You want easy land ownership (foreigners restricted)</li>
          <li>• You prefer cooler climates</li>
          <li>• Political stability is a priority</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Popular retirement areas:</strong> Cebu (best infrastructure, international airport), Dumaguete (university town, expat-friendly), Davao (safest major city), Baguio (cooler mountain climate), Subic Bay (former US base, familiar feel).
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The SRRV comes in several variants. Most retirees use SRRV Classic (age 50+) or SRRV Smile (age 35+). The key difference is deposit amount and whether you have pension income.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">SRRV Classic (Most Popular)</h3>

    <div class="border border-green-200 bg-green-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">For Retirees 50 and Older</h4>
      <ul class="space-y-2 text-green-800">
        <li>✓ <strong>With pension ($800+/month):</strong> $10,000 deposit</li>
        <li>✓ <strong>Without pension:</strong> $20,000 deposit</li>
        <li>✓ Deposit held in accredited Philippine bank</li>
        <li>✓ Fully refundable upon visa cancellation</li>
        <li>✓ Can convert deposit to condo purchase (specific conditions)</li>
        <li>✓ Spouse and dependents can be included</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">SRRV Smile (Younger Retirees)</h3>

    <div class="border border-blue-200 bg-blue-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-blue-900 mb-3">For Ages 35 and Older</h4>
      <ul class="space-y-2 text-blue-800">
        <li>✓ $20,000 deposit required</li>
        <li>✓ Can convert to active investment (condo, stocks)</li>
        <li>✓ No pension requirement</li>
        <li>✓ Popular with early retirees</li>
        <li>✓ Same benefits as Classic</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Requirements</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Passport:</strong> Valid 6+ months, with certified copies</li>
      <li><strong>Police clearance:</strong> From home country (apostilled)</li>
      <li><strong>Medical exam:</strong> From accredited Philippine clinic</li>
      <li><strong>Pension proof:</strong> If using $10,000 option (apostilled)</li>
      <li><strong>Passport photos:</strong> 12 pieces (2x2 inches)</li>
      <li><strong>Bank certificate:</strong> Showing deposit funds available</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Deposit investment option:</strong> SRRV Smile holders can convert their $20,000 deposit into an investment—typically a condo unit. However, the condo must be in an accredited development, and you lose the option to get the deposit refunded. Consider this carefully.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Insurance Recommended, Not Mandatory</h3>
      <p class="text-blue-800">
        The Philippines doesn't require health insurance for the SRRV visa. However, comprehensive coverage is strongly recommended. Healthcare quality varies significantly, and serious conditions often require evacuation to Singapore or Hong Kong. Don't rely solely on PhilHealth.
      </p>
    </div>

    <p class="mb-4">
      While not mandatory, health insurance is essential for peace of mind. Philippine healthcare is affordable for routine care but can be expensive for serious conditions. Medical evacuation insurance is particularly important given the healthcare limitations.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Considerations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">PhilHealth vs Private Insurance</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">PhilHealth (Public Insurance)</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Available to SRRV holders</li>
          <li>✓ Very affordable (~$20-50/month)</li>
          <li>✓ Covers government hospitals</li>
          <li>✓ Some private hospital coverage</li>
          <li>△ Limited coverage amounts</li>
          <li>△ Bureaucratic claims process</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Private/International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Access to best private hospitals</li>
          <li>✓ Medical evacuation included</li>
          <li>✓ Coverage in Singapore, Hong Kong</li>
          <li>✓ Direct billing at major hospitals</li>
          <li>△ Higher cost ($150-400/month)</li>
          <li>△ Pre-existing condition limits</li>
        </ul>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Medical evacuation is critical:</strong> For serious conditions (heart attacks, strokes, major surgeries), many expats evacuate to Singapore or Bangkok. Ensure your policy includes medical evacuation coverage of at least $100,000. This could save your life.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance with medical evacuation coverage?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Retirement Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      A combination of local HMO (for routine care) and international insurance (for serious conditions and evacuation) works best for most Philippines retirees.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Option</h4>
        <p class="text-neutral-600">PhilHealth + Maxicare local HMO. Total cost ~$100-150/month. Covers routine care and most hospitalizations locally. Add travel insurance for trips home that includes medical evacuation.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Coverage</h4>
        <p class="text-neutral-600">Cigna Global or IMG Global international plan. Covers Philippines plus evacuation to Singapore/Hong Kong for serious care. Best for those with health conditions or wanting peace of mind. $200-400/month.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Regional Specialist</h4>
        <p class="text-neutral-600">Pacific Cross specializes in Southeast Asia. Good hospital networks in Philippines, Thailand, Singapore. Often better value than global insurers for Asia-focused coverage.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">$1,000</p>
        <p class="text-sm text-neutral-500 mt-2">Provincial, local lifestyle</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Cebu or Dumaguete, nice condo</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Upscale</p>
        <p class="text-3xl font-bold text-neutral-900">$2,500+</p>
        <p class="text-sm text-neutral-500 mt-2">Manila, Western lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost by Location</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Metro Manila:</strong> $1,500-3,000/month (expensive, traffic, modern amenities)</li>
      <li><strong>Cebu City:</strong> $1,200-2,200/month (best infrastructure outside Manila)</li>
      <li><strong>Dumaguete:</strong> $1,000-1,800/month (university town, expat-friendly)</li>
      <li><strong>Davao:</strong> $1,000-1,800/month (safest city, Duterte's hometown)</li>
      <li><strong>Baguio:</strong> $1,000-1,600/month (mountain climate, cooler)</li>
      <li><strong>Provincial beach towns:</strong> $800-1,500/month (cheapest, basic infrastructure)</li>
    </ul>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Deposit is refundable:</strong> Unlike other retirement visas that require ongoing income proof, the SRRV deposit sits in a bank account. If you leave the Philippines permanently, you get it back (minus any conversion to investment). Think of it as a bond, not a fee.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The SRRV application is handled by the Philippine Retirement Authority (PRA). You must apply in person at their office in Manila, though some documents can be submitted in advance. Processing typically takes 2-4 weeks once you're in the Philippines.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Process</h3>

    <ol class="list-decimal pl-6 space-y-3 mb-6">
      <li><strong>Prepare documents</strong> in home country (police clearance, pension letter if applicable)</li>
      <li><strong>Get apostilles</strong> from Secretary of State</li>
      <li><strong>Submit pre-application</strong> to PRA online or via email</li>
      <li><strong>Fly to Manila</strong> (must process in person)</li>
      <li><strong>Complete medical exam</strong> at PRA-accredited clinic</li>
      <li><strong>Open bank account</strong> at accredited bank (BDO, BPI, etc.)</li>
      <li><strong>Transfer deposit</strong> to Philippine bank account</li>
      <li><strong>Submit application</strong> at PRA office with all documents</li>
      <li><strong>Wait for processing</strong> (2-4 weeks)</li>
      <li><strong>Receive SRRV visa</strong> stamped in passport</li>
      <li><strong>Get ACR I-Card</strong> (Alien Certificate of Registration)</li>
    </ol>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Manila requirement:</strong> You must process the SRRV application in Manila at the PRA office. Budget 2-4 weeks in Manila for the complete process. Some applicants use this time to explore potential retirement locations around the country.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">US Veteran, 65, with Pension</h3>
        <p class="text-neutral-600 mb-4">Military pension $2,500/month, wanted warm climate.</p>
        <p class="text-green-700 font-medium">✓ SRRV Classic with $10,000 deposit. Living in Dumaguete, $1,400/month total costs. Has Cigna Global for medical. Loves the friendly locals and English communication. Visits beaches weekly.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Early Retiree, 52, No Pension</h3>
        <p class="text-neutral-600 mb-4">$3,000/month from investments, wanted beach lifestyle.</p>
        <p class="text-green-700 font-medium">✓ SRRV Classic with $20,000 deposit. Converted $10K to condo down payment in Cebu. Maxicare HMO plus international evacuation policy. Works remotely part-time. Perfect setup for island hopping.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple on Social Security</h3>
        <p class="text-neutral-600 mb-4">Combined $2,800/month, limited savings.</p>
        <p class="text-green-700 font-medium">✓ Both have SRRV with $10,000 deposit each. Living in Davao, safest major city. $1,600/month for both including nice condo. PhilHealth plus local HMO keeps healthcare affordable. Stretching Social Security further than ever imagined.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Health-Conscious Retiree</h3>
        <p class="text-neutral-600 mb-4">Heart condition, worried about healthcare quality.</p>
        <p class="text-amber-700 font-medium">△ Living in Cebu for best hospital access. Has Cigna Global with evacuation to Singapore. Had minor cardiac episode—flew to Singapore for procedure. Insurance covered $45,000. Glad he has comprehensive coverage but Philippines healthcare improving.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Beach Bum on Tight Budget</h3>
        <p class="text-neutral-600 mb-4">$1,200/month total, wanted ultimate low cost.</p>
        <p class="text-green-700 font-medium">✓ SRRV Smile with $20,000 deposit. Living in small beach town in Palawan. $800/month covers everything including rent, food, utilities. Simple life but exactly what he wanted. PhilHealth only—taking the risk on major medical.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Expected First-World Standards</h3>
        <p class="text-neutral-600 mb-4">Used to US convenience and infrastructure.</p>
        <p class="text-red-700 font-medium">✗ Struggled with power outages, slow internet, traffic. Found provincial life too quiet, Manila too chaotic. Healthcare concerns grew after minor emergency. Returned to US after 18 months. Philippines not for everyone.</p>
      </div>
    </div>
  </section>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Skipping Medical Evacuation Insurance</h3>
        <p class="text-neutral-600">Philippines healthcare can handle routine issues but complex cases often require evacuation to Singapore or Bangkok. A medical evacuation can cost $50,000-100,000. Don't gamble—get evacuation coverage.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Converting Deposit to Condo Too Quickly</h3>
        <p class="text-neutral-600">SRRV allows converting your deposit to a condo investment, but then you can't get it back. Live in the Philippines for at least a year before committing to real estate. Many expats' preferences change after experiencing reality.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Underestimating Typhoon Season</h3>
        <p class="text-neutral-600">June-November brings typhoons that can devastate areas. Some provinces are hit harder than others. Research typhoon patterns for your target area and have emergency plans. Cebu and Davao are less affected than Luzon.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Expecting Land Ownership</h3>
        <p class="text-neutral-600">Foreigners cannot own land in the Philippines—only condos or buildings (not the land underneath). House purchases require a Filipino spouse or corporation setup. Understand these limitations before planning real estate investments.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Choosing Location Based on Vacation Experience</h3>
        <p class="text-neutral-600">Boracay or El Nido are amazing for vacation but difficult for long-term living (expensive, touristy, limited services). Practical retirement locations like Cebu, Dumaguete, or Davao offer better infrastructure and community.</p>
      </div>
    </div>
  </section>

  <!-- Section: Healthcare -->
  <section id="healthcare" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Healthcare in the Philippines</h2>

    <p class="mb-4">
      Philippine healthcare varies dramatically by location. Metro Manila and Cebu have international-standard private hospitals, while provincial areas may have limited facilities. For serious conditions, medical evacuation to Singapore or Bangkok is common.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Major Hospitals</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Makati Medical Center</strong> - Manila, JCI-accredited, top private hospital</li>
      <li><strong>St. Luke's Medical Center</strong> - Manila and BGC, excellent specialists</li>
      <li><strong>Cebu Doctors' Hospital</strong> - Cebu, best in Visayas region</li>
      <li><strong>Chong Hua Hospital</strong> - Cebu, good private option</li>
      <li><strong>Davao Doctors Hospital</strong> - Davao, best in Mindanao</li>
      <li><strong>Adventist Medical Center</strong> - Multiple locations, reliable care</li>
    </ul>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Sample Costs (Private, Without Insurance)</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>GP visit:</strong> $10-30</li>
      <li><strong>Specialist:</strong> $25-60</li>
      <li><strong>MRI:</strong> $150-300</li>
      <li><strong>Dental cleaning:</strong> $15-30</li>
      <li><strong>Hospital room (private):</strong> $50-150/night</li>
      <li><strong>Emergency evacuation to Singapore:</strong> $20,000-50,000</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Location matters:</strong> If healthcare quality is important, prioritize Cebu or Manila for retirement. Provincial beach towns may be cheaper and prettier, but you'll need to travel hours for quality medical care. Many expats compromise with provincial living plus international insurance that covers evacuation.
      </p>
    </div>
  </section>

  <!-- Section: FAQ -->
  <section id="faq" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Frequently Asked Questions</h2>

    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Can I work on the SRRV?</h3>
        <p class="text-neutral-600">
          The SRRV doesn't authorize employment in the Philippines. However, you can work remotely for foreign companies, receive passive income, and run online businesses. Local employment requires a separate work permit.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">What happens to my deposit if I die?</h3>
        <p class="text-neutral-600">
          The deposit can be inherited by your designated beneficiary. Include clear instructions in your application and maintain updated beneficiary information with PRA. The process requires some paperwork but the funds are recoverable.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Can I buy property?</h3>
        <p class="text-neutral-600">
          Foreigners can own condominium units (up to 40% of a building's units). You cannot own land directly. Workarounds include long-term leases, Filipino spouse ownership, or corporation structures, but each has complications.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Is the Philippines safe?</h3>
        <p class="text-neutral-600">
          Safety varies by location. Davao is considered very safe. Cebu, Dumaguete, and most retirement areas are reasonably safe with normal precautions. Avoid areas with travel advisories (parts of Mindanao). Most expats report feeling safe in their daily lives.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">What's the climate like?</h3>
        <p class="text-neutral-600">
          Tropical year-round: hot and humid (30-35°C / 86-95°F). Dry season December-May, wet season June-November with typhoons. Baguio (mountains) is cooler (15-25°C). Most expats adapt, but air conditioning is essential.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">How's the internet?</h3>
        <p class="text-neutral-600">
          Internet has improved but varies widely. Metro Manila and Cebu have fiber options (50-100+ Mbps). Provincial areas may be limited to slower connections. Starlink is becoming available. If you work remotely, prioritize location with good connectivity.
        </p>
      </div>
    </div>
  </section>

  <!-- Section: Final Verdict -->
  <section id="verdict" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Final Verdict</h2>

    <p class="mb-4">
      The Philippines SRRV offers one of Asia's most accessible retirement visas—a refundable deposit instead of ongoing income requirements, English as an official language, and extremely low cost of living. For retirees comfortable with developing-country infrastructure, it's hard to beat the value.
    </p>

    <p class="mb-4">
      The main considerations are healthcare limitations (plan for evacuation coverage), natural disaster risk (typhoons), and infrastructure gaps. But for those who embrace Filipino culture and the island lifestyle, the Philippines delivers an affordable, English-speaking tropical retirement.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <h3 class="font-semibold text-primary-900 mb-3">Bottom Line</h3>
      <p class="text-primary-800 mb-4">
        The SRRV is ideal for English-speaking retirees seeking ultra-low cost of living in a tropical setting. The $10,000-$20,000 refundable deposit is more accessible than ongoing income requirements in other countries. Prioritize medical evacuation insurance, choose your location carefully, and embrace the adventure.
      </p>
