---
/**
 * Spain Retirement Visa (Non-Lucrative Visa) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Spain", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Spain Health Insurance Guide", href: "/countries/spain/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€2,400/month (~$2,600) minimum", evidence: "Pension statements, bank statements, investment proof" },
  { requirement: "Savings Alternative", details: "€29,000+ in savings for one year", evidence: "Bank statements showing balance" },
  { requirement: "Health Insurance", details: "Full coverage, no copays", evidence: "Insurance certificate (in Spanish)" },
  { requirement: "Accommodation", details: "Proof of housing in Spain", evidence: "Rental contract or property deed" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "FBI background check (apostilled)" },
  { requirement: "No Work", details: "Cannot work in Spain", evidence: "Declaration of intent" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Spain Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive, no maximum", why: "Spain requires 'full coverage'" },
  { feature: "Copays/Deductibles", minimum: "None allowed", why: "Strict Spanish requirement" },
  { feature: "Coverage Territory", minimum: "Valid in Spain", why: "Must cover Spanish territory" },
  { feature: "Repatriation", minimum: "Required", why: "Spanish consulates verify this" },
  { feature: "Duration", minimum: "Full visa period (1 year)", why: "Must match or exceed visa dates" },
  { feature: "Pre-existing Conditions", minimum: "Coverage recommended", why: "Many retirees need this" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€220-500", strengths: "No copay plans, pre-existing" },
  { provider: "Sanitas (Spanish)", coverage: "Full coverage", price: "€150-350", strengths: "Local Spanish insurer, accepted" },
  { provider: "Adeslas (Spanish)", coverage: "Full coverage", price: "€140-320", strengths: "Largest Spanish network" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€180-400", strengths: "EU-wide coverage" },
  { provider: "AXA Global", coverage: "€500,000+", price: "€170-380", strengths: "Strong Spain presence" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€80", notes: "Consulate fee (varies by country)" },
  { item: "NIE Application", amount: "€12", notes: "Foreigner ID number" },
  { item: "TIE Card", amount: "€16", notes: "Residence card" },
  { item: "Health Insurance (Annual)", amount: "€2,000-6,000", notes: "Age-dependent, no copay plans" },
  { item: "Document Apostille", amount: "€50-200", notes: "Per document, home country" },
  { item: "Translation/Notary", amount: "€200-500", notes: "Sworn translations required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "4-8 weeks", location: "Home country" },
  { step: "Get sworn translations", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1-3 days", location: "Online" },
  { step: "Schedule consulate appointment", duration: "Varies widely", location: "Spanish consulate" },
  { step: "Submit visa application", duration: "1 day", location: "Spanish consulate" },
  { step: "Processing", duration: "30-90 days", location: "Consulate review" },
  { step: "Receive visa", duration: "Pick up", location: "Consulate" },
  { step: "Enter Spain", duration: "Within 90 days", location: "Spain" },
  { step: "Apply for TIE", duration: "Within 30 days of arrival", location: "Police station/Extranjería" },
];
---

<PageShell
  title="Spain Non-Lucrative Visa 2025: Retirement Visa Requirements, Insurance & Application Guide"
  description="Complete guide to Spain's Non-Lucrative Visa for retirees. Income requirements, no-copay insurance rules, application process, and pathway to EU residency."
  headline="Spain Non-Lucrative Visa: Retirement Insurance & Requirements Guide"
  subheadline="Everything you need to know about retiring to Spain—income requirements, strict insurance rules, regional healthcare, and the pathway to EU permanent residency."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Consulate Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU Pathway
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Spain's Non-Lucrative Visa (Visado de Residencia No Lucrativa) is designed specifically for retirees and others who can support themselves without working. With world-class healthcare, diverse regions from beaches to mountains, and a famously relaxed lifestyle, Spain attracts more expat retirees than almost any other European country.
    </p>

    <p class="mb-4">
      The "non-lucrative" part is important: this visa explicitly prohibits working in Spain. It's meant for those living on pensions, savings, or investment income. The income requirements are higher than Portugal, but Spain offers exceptional healthcare, infrastructure, and that unmatched Spanish quality of life.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Spain Non-Lucrative Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Non-Lucrative Residence Visa</li>
        <li>• <strong>Income requirement:</strong> €2,400/month (~$2,600) or €29,000 savings</li>
        <li>• <strong>Initial duration:</strong> 1-year residence permit</li>
        <li>• <strong>Renewal:</strong> 2-year permits thereafter</li>
        <li>• <strong>Work allowed:</strong> No—strictly passive income only</li>
        <li>• <strong>Path to citizenship:</strong> 10 years (or 2 years for Latin Americans)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Spain for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Excellent healthcare:</strong> Spain's public system ranks among the world's best</li>
      <li><strong>Climate variety:</strong> Mediterranean beaches, mountain regions, green north</li>
      <li><strong>Rich culture:</strong> World-class museums, historic cities, vibrant festivals</li>
      <li><strong>Affordable (outside Barcelona/Madrid):</strong> Excellent value in smaller cities</li>
      <li><strong>Established expat communities:</strong> Large retiree communities in Costa del Sol, Costa Blanca</li>
      <li><strong>EU residency:</strong> Schengen travel, pathway to permanent residency</li>
      <li><strong>Safety:</strong> One of Europe's safest countries</li>
      <li><strong>Great food:</strong> Mediterranean diet, excellent wine, tapas culture</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Spain is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You have €2,400+/month in passive income</li>
          <li>✓ You don't need to work</li>
          <li>✓ You want world-class healthcare</li>
          <li>✓ You love Mediterranean climate and culture</li>
          <li>✓ You want large English-speaking expat communities</li>
          <li>✓ You appreciate fine food, wine, and relaxed lifestyle</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need to work (Spain DNV or Portugal D7 instead)</li>
          <li>• Your income is under €2,400/month</li>
          <li>• You want lower insurance costs (no-copay requirement is expensive)</li>
          <li>• You prefer tropical climate</li>
          <li>• You want faster citizenship (Spain requires 10 years)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Insurance alert:</strong> Spain has the strictest insurance requirements in Europe for retirement visas. Your policy must have NO copays and NO deductibles. This is non-negotiable at Spanish consulates. Plan for higher insurance costs accordingly.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Spain's Non-Lucrative Visa has clear financial requirements. You need to prove you can support yourself without working—through pension, savings, investments, or other passive income sources.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Requirements Breakdown</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Single Applicant</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Monthly:</strong> €2,400/month (~$2,600)</li>
          <li>• <strong>Annual savings:</strong> €29,000+ for one year</li>
          <li>• <strong>Calculation:</strong> 400% IPREM (public indicator)</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Couple/Family</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Spouse:</strong> +€600/month (~25% more)</li>
          <li>• <strong>Each dependent:</strong> +€600/month</li>
          <li>• <strong>Example couple:</strong> €3,000/month (~$3,250)</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Consulate variations:</strong> Requirements can vary slightly between Spanish consulates. Some accept savings in lieu of monthly income; others prefer ongoing income proof. Check with your specific consulate for their interpretation.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">What Qualifies as Passive Income</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Pensions:</strong> Government (Social Security) or private pensions</li>
      <li><strong>Investment income:</strong> Dividends, interest, capital gains</li>
      <li><strong>Rental income:</strong> Property you own and rent out</li>
      <li><strong>Retirement withdrawals:</strong> 401(k), IRA distributions</li>
      <li><strong>Savings:</strong> Bank statements showing sufficient funds</li>
    </ul>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mt-6">
      <p class="text-red-800">
        <strong>No work allowed:</strong> The Non-Lucrative Visa strictly prohibits any employment or self-employment in Spain. If you need to work remotely, you must apply for Spain's digital nomad visa instead.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Spain's Strict "No Copay" Insurance Rule</h3>
      <p class="text-red-800">
        Spain requires health insurance with NO copays and NO deductibles. This is the strictest requirement in Europe. Many standard international health plans don't qualify because they include copays or deductibles. You need a specific "Spain-compliant" policy or a Spanish domestic insurer.
      </p>
    </div>

    <p class="mb-4">
      The no-copay requirement significantly increases insurance costs compared to other countries. Budget for this when planning your move. Many applicants use Spanish insurers (Sanitas, Adeslas) or international plans with Spain-specific zero-deductible options.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Specifications</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Policy Requirements</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Acceptable for Spanish Visa</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Zero deductible / €0 copay</li>
          <li>✓ Full hospitalization coverage</li>
          <li>✓ Repatriation included</li>
          <li>✓ Coverage for full visa period</li>
          <li>✓ Certificate in Spanish</li>
        </ul>
      </div>

      <div class="border border-red-200 bg-red-50 rounded-lg p-6">
        <h4 class="font-semibold text-red-900 mb-3">NOT Acceptable</h4>
        <ul class="space-y-2 text-red-800">
          <li>✗ Any copay (even €10)</li>
          <li>✗ Any deductible</li>
          <li>✗ Travel insurance</li>
          <li>✗ Coverage with gaps/waiting periods</li>
          <li>✗ US Medicare (not valid abroad)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Spanish insurers recommended:</strong> Sanitas and Adeslas are Spanish health insurers commonly used for visa applications. They automatically meet the no-copay requirement and are familiar to consulates. Consider these alongside international options.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need no-copay health insurance for Spain's Non-Lucrative Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Spain-Compliant Insurance →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer no-copay plans that meet Spain's strict requirements. Spanish domestic insurers (Sanitas, Adeslas) are often the easiest choice as they're pre-approved for visa purposes.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Easiest Visa Approval</h4>
        <p class="text-neutral-600">Sanitas or Adeslas (Spanish insurers). Consulates are familiar with these policies, reducing potential questions. Networks are extensive throughout Spain.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Cigna Global with their Spain-compliant no-copay plans. Higher cost but broader pre-existing condition coverage than Spanish insurers typically offer.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Multi-Country Coverage</h4>
        <p class="text-neutral-600">Allianz Care or AXA Global if you plan to travel frequently throughout Europe. Ensure you select the zero-deductible option for Spain compliance.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Value (Healthy Retirees)</h4>
        <p class="text-neutral-600">Adeslas often offers competitive rates for healthy applicants. Large network, well-known to Spanish authorities, reasonable premiums.</p>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Certificate in Spanish:</strong> Your insurance certificate must be in Spanish (or officially translated) and clearly state "sin copago" (no copay) and full coverage. Request this specifically from your insurer.
      </p>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Spain offers excellent value outside the major cities. Barcelona and Madrid are expensive by European standards, but the Costa del Sol, Valencia, and smaller cities provide comfortable living at reasonable costs.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€3,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + Spanish insurer</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Typical Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€5,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With Lawyer</p>
        <p class="text-3xl font-bold text-neutral-900">€7,000</p>
        <p class="text-sm text-neutral-500 mt-2">Full concierge service</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost of Living</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Madrid/Barcelona:</strong> €2,200-3,500/month (city center apartment, comfortable lifestyle)</li>
      <li><strong>Valencia/Málaga:</strong> €1,600-2,500/month (good apartment, dining out, activities)</li>
      <li><strong>Costa del Sol/Alicante:</strong> €1,400-2,200/month (comfortable, beach lifestyle)</li>
      <li><strong>Smaller cities:</strong> €1,200-1,800/month (very comfortable)</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Regional variation:</strong> Costs vary dramatically by region. The Costa del Sol has huge expat communities with varying prices. The Costa Blanca (Alicante area) often offers better value. Valencia combines city amenities with reasonable costs.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Non-Lucrative Visa is applied for at the Spanish consulate in your home country. Unlike Portugal, you don't need to set up a Spanish bank account or tax number before applying—these come after arrival.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Required Documents</h4>
          <p class="text-neutral-600">Collect proof of income/savings, criminal background check (FBI for US citizens), passport copies, and medical certificate. All documents less than 90 days old.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get Sworn Translations</h4>
          <p class="text-neutral-600">All documents must be translated into Spanish by an official sworn translator (traductor jurado). This includes bank statements, background check, and medical certificate.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apostille Documents</h4>
          <p class="text-neutral-600">Get Hague Apostilles for your background check and any official documents. In the US, state documents go to the Secretary of State; FBI checks go to the State Department.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get a no-copay policy from a Spanish insurer or international provider with Spain-compliant zero-deductible options. Request certificate in Spanish showing "sin copago."</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Schedule Consulate Appointment</h4>
          <p class="text-neutral-600">Book an appointment at your Spanish consulate. Wait times vary significantly—some consulates require booking months ahead. Check VFS Global or consulate website.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Attend Consulate Interview</h4>
          <p class="text-neutral-600">Submit application with all documents in person. Bring originals and copies of everything. Pay the visa fee (approximately €80). Processing takes 30-90 days.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Spain and Apply for TIE</h4>
          <p class="text-neutral-600">Enter Spain within 90 days of visa approval. Within 30 days of arrival, apply for your TIE (residence card) at the Extranjería or police station. Get your NIE (tax number).</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Consulate variations:</strong> Each Spanish consulate has slightly different procedures and requirements. The San Francisco, Miami, and Houston consulates have different appointment systems and document preferences. Research your specific consulate carefully.
      </p>
    </div>
  </section>

