---
/**
 * Croatia Retirement Visa (Temporary Stay Permit) - Long-form CRO-optimized page
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Croatia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Croatia Health Insurance Guide", href: "/countries/croatia/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Income", details: "~€1,500/month (~$1,600)", notes: "Sufficient funds proof" },
  { requirement: "Health Insurance", details: "Mandatory", notes: "Covering Croatia" },
  { requirement: "Accommodation", details: "Proof required", notes: "Ownership or rental contract" },
  { requirement: "Criminal Record", details: "Clean record", notes: "From home country" },
  { requirement: "Initial Duration", details: "1 year", notes: "Renewable annually" },
  { requirement: "Path to PR", details: "5 years", notes: "Then permanent residence" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Croatia Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Health Insurance", minimum: "Mandatory", why: "Required for visa" },
  { feature: "Coverage Amount", minimum: "€30,000+ recommended", why: "Adequate for hospitalization" },
  { feature: "Coverage Area", minimum: "Croatia/EU", why: "Schengen compliance" },
  { feature: "Provider", minimum: "EU or international", why: "Must be valid in Croatia" },
  { feature: "Duration", minimum: "Match visa duration", why: "Full coverage period" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Croatia Osiguranje", coverage: "HRK 500K-2M", price: "€80-200", strengths: "Local, visa-compliant" },
  { provider: "Allianz Croatia", coverage: "€100,000-500,000", price: "€100-250", strengths: "International backing" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-450", strengths: "Comprehensive, worldwide" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€180-400", strengths: "EU-wide coverage" },
  { provider: "BUPA Global", coverage: "£1,000,000+", price: "£180-400", strengths: "British expat favorite" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€70-100", notes: "Government fee" },
  { item: "Residence Permit", amount: "€35-70", notes: "Biometric card" },
  { item: "Health Insurance (Annual)", amount: "€1,000-3,500", notes: "Mandatory" },
  { item: "Document Translations", amount: "€100-300", notes: "Certified translations" },
  { item: "Apostilles", amount: "€50-150", notes: "Per document" },
  { item: "Legal Assistance", amount: "€500-1,500", notes: "Optional but helpful" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Apostilles & translations", duration: "1-2 weeks", location: "Home country" },
  { step: "Find accommodation", duration: "1-4 weeks", location: "Croatia (visit)" },
  { step: "Submit application", duration: "1 day", location: "Croatian consulate/police" },
  { step: "Processing", duration: "1-3 months", location: "Croatian authorities" },
  { step: "Receive permit", duration: "1-2 weeks", location: "Croatia" },
];
---

<PageShell
  title="Croatia Retirement Visa 2025: Residency Requirements & Adriatic Living Guide"
  description="Complete guide to retiring in Croatia. EU member, Schengen zone, stunning Adriatic coast, affordable living, and straightforward residency for retirees with pension income."
  headline="Croatia Retirement Visa: Residency Requirements & Insurance Guide"
  subheadline="Everything you need to know about retiring to Croatia—income requirements, mandatory insurance, why the Adriatic coast attracts European and American retirees, and navigating EU residency."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Retirement Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU & Schengen Member
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Adriatic Coast Paradise
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Croatia has emerged as one of Europe's most desirable retirement destinations, combining stunning Adriatic coastline, rich history, affordable living costs, and EU membership with Schengen zone access. Since joining Schengen in January 2023, Croatia offers even more flexibility for retirees wanting a European base.
    </p>

    <p class="mb-4">
      While Croatia doesn't have a specific "retirement visa," non-EU citizens can obtain temporary residence for "other purposes" which includes retirement on pension income. The requirements are straightforward: prove sufficient income, have health insurance, and secure accommodation.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Croatia Retirement Residency</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Income requirement:</strong> ~€1,500/month (sufficient means)</li>
        <li>• <strong>Health insurance:</strong> Mandatory</li>
        <li>• <strong>Initial permit:</strong> 1 year, renewable</li>
        <li>• <strong>Path to PR:</strong> After 5 years continuous residence</li>
        <li>• <strong>EU status:</strong> Full EU member, Schengen since 2023</li>
        <li>• <strong>Euro adoption:</strong> January 2023</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Croatia for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Stunning coastline:</strong> 1,200+ islands, crystal-clear Adriatic</li>
      <li><strong>Affordable:</strong> 30-40% cheaper than Western Europe</li>
      <li><strong>EU & Schengen:</strong> Travel freely throughout Europe</li>
      <li><strong>Rich history:</strong> Roman ruins, medieval towns, UNESCO sites</li>
      <li><strong>Good healthcare:</strong> Quality public and private options</li>
      <li><strong>Safe:</strong> Low crime rate, peaceful society</li>
      <li><strong>Mediterranean climate:</strong> Warm summers, mild winters on coast</li>
      <li><strong>Growing expat community:</strong> Especially in Istria and Dalmatia</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Croatia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You love coastal Mediterranean lifestyle</li>
          <li>✓ You want EU residency at lower cost</li>
          <li>✓ You enjoy history and culture</li>
          <li>✓ You have €1,500+/month income</li>
          <li>✓ You want Schengen travel freedom</li>
          <li>✓ You appreciate slower pace of life</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need English everywhere (Croatian areas variable)</li>
          <li>• You want year-round warm weather (winters are cooler)</li>
          <li>• You prefer established English-speaking expat scene</li>
          <li>• You want lowest possible costs (Albania, Bulgaria cheaper)</li>
          <li>• You prefer larger country with more variety</li>
          <li>• You want immediate path to citizenship</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Popular retirement areas:</strong> Istria (Italian influence, truffles, wine), Split (Dalmatian coast, lively), Dubrovnik (stunning but touristy), Zadar (underrated, good value), Zagreb (capital, cultural, cooler). Many retirees split time between coast and inland.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Non-EU citizens seeking to retire in Croatia apply for a Temporary Stay Permit (Privremeni boravak) for "other purposes" which includes living on pension income. Requirements are relatively straightforward compared to some EU countries.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Financial Requirements</h3>

    <div class="border border-green-200 bg-green-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">Proving Sufficient Means</h4>
      <ul class="space-y-2 text-green-800">
        <li>✓ Minimum ~€1,500/month recommended (no fixed amount)</li>
        <li>✓ Bank statements showing regular income</li>
        <li>✓ Pension statements or Social Security letters</li>
        <li>✓ Investment income documentation</li>
        <li>✓ Savings showing 12+ months coverage also accepted</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Accommodation Requirements</h3>

    <div class="border border-blue-200 bg-blue-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-blue-900 mb-3">Proof of Housing</h4>
      <ul class="space-y-2 text-blue-800">
        <li>✓ Property ownership deed (if you own)</li>
        <li>✓ Rental contract (notarized, minimum 1 year)</li>
        <li>✓ Host declaration from property owner</li>
        <li>✓ Hotel booking NOT sufficient for long-term</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Requirements</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Passport:</strong> Valid 3+ months beyond intended stay</li>
      <li><strong>Application form:</strong> Completed and signed</li>
      <li><strong>Photos:</strong> Passport-style (35x45mm)</li>
      <li><strong>Police clearance:</strong> From home country (apostilled)</li>
      <li><strong>Financial proof:</strong> Bank statements, pension letters</li>
      <li><strong>Health insurance:</strong> Certificate of coverage</li>
      <li><strong>Accommodation proof:</strong> Ownership or rental contract</li>
      <li><strong>Translations:</strong> Certified Croatian translations</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Apostille requirement:</strong> Documents from the US need apostille from Secretary of State. Then certified translation into Croatian. Start this process early—it takes time. Many applicants use Croatian translation services for convenience.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-red-800">
        Croatia requires comprehensive health insurance for all residence permit applications. Coverage must be valid in Croatia and cover the full permit period. This is strictly enforced.
      </p>
    </div>

    <p class="mb-4">
      You can use Croatian local insurance, EU-wide insurance, or international insurance—as long as it provides adequate coverage in Croatia. After residency, you may become eligible for the Croatian public healthcare system (HZZO).
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Specifications</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Options</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Croatian Local Insurance</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Croatia Osiguranje, Allianz Croatia</li>
          <li>✓ Guaranteed visa-compliant</li>
          <li>✓ Local network, Croatian support</li>
          <li>✓ Often more affordable</li>
          <li>△ Limited coverage outside Croatia</li>
          <li>△ Croatian language policies</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Cigna Global, Allianz Care, BUPA</li>
          <li>✓ EU-wide and worldwide coverage</li>
          <li>✓ Travel throughout Schengen covered</li>
          <li>✓ English-language support</li>
          <li>△ More expensive</li>
          <li>△ Verify Croatia compliance</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Public healthcare access:</strong> After establishing residency and meeting requirements, you may enroll in HZZO (Croatian Health Insurance Fund). This provides access to public healthcare. Many residents maintain private insurance for faster service and choice of providers.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Croatia residency?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Retirement Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For initial visa compliance, Croatian local insurers are safest. For ongoing coverage with European travel, international insurers offer more flexibility.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Visa Application</h4>
        <p class="text-neutral-600">Croatia Osiguranje or Allianz Croatia for local coverage. Guaranteed acceptance by Croatian authorities. €80-200/month depending on age and coverage level.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">European Travelers</h4>
        <p class="text-neutral-600">Allianz Care or Cigna Global for EU-wide coverage. Use Schengen access freely without worrying about coverage. Higher cost but covers throughout Europe.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">British/Irish Expats</h4>
        <p class="text-neutral-600">BUPA Global is popular with British retirees in Croatia. Good coverage, familiar brand, helpful for coordinating with UK healthcare on return visits.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">€1,200</p>
        <p class="text-sm text-neutral-500 mt-2">Smaller town, local lifestyle</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">€1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Coastal town, nice apartment</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Upscale</p>
        <p class="text-3xl font-bold text-neutral-900">€3,000+</p>
        <p class="text-sm text-neutral-500 mt-2">Dubrovnik/Split, premium living</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost by Location</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Dubrovnik:</strong> €2,000-3,500/month (most expensive, touristy)</li>
      <li><strong>Split:</strong> €1,500-2,500/month (good balance, lively)</li>
      <li><strong>Istria (Rovinj, Pula):</strong> €1,400-2,200/month (Italian influence)</li>
      <li><strong>Zadar:</strong> €1,200-1,800/month (underrated, good value)</li>
      <li><strong>Zagreb:</strong> €1,300-2,200/month (capital, cooler climate)</li>
      <li><strong>Inland Croatia:</strong> €1,000-1,500/month (cheapest, fewer tourists)</li>
    </ul>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h4 class="font-semibold text-green-900 mb-3">Sample Monthly Budget (Split, Comfortable)</h4>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>Rent (2BR apartment):</strong> €600-900</li>
        <li>• <strong>Utilities:</strong> €100-150</li>
        <li>• <strong>Food & groceries:</strong> €300-450</li>
        <li>• <strong>Transportation:</strong> €50-100</li>
        <li>• <strong>Health insurance:</strong> €100-250</li>
        <li>• <strong>Entertainment & dining:</strong> €150-300</li>
        <li>• <strong>Total:</strong> €1,300-2,150</li>
      </ul>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      You can apply from your home country (at Croatian consulate) or in Croatia (at local police station). Many applicants find applying in Croatia easier once they've secured accommodation.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Process</h3>

    <ol class="list-decimal pl-6 space-y-3 mb-6">
      <li><strong>Gather documents</strong> in home country (police clearance, financial proof)</li>
      <li><strong>Get apostilles</strong> from Secretary of State</li>
      <li><strong>Arrange certified translations</strong> into Croatian</li>
      <li><strong>Visit Croatia</strong> (90-day tourist stay for Americans)</li>
      <li><strong>Find and secure accommodation</strong> (rental contract or purchase)</li>
      <li><strong>Obtain health insurance</strong> from approved provider</li>
      <li><strong>Submit application</strong> at local police station (Policijska Postaja)</li>
      <li><strong>Wait for processing</strong> (1-3 months typical)</li>
      <li><strong>Receive residence permit</strong> (biometric card)</li>
      <li><strong>Register address</strong> with local authorities</li>
      <li><strong>Renew annually</strong> before expiration</li>
    </ol>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>In-country application:</strong> Many find it easier to apply while in Croatia on a tourist visa. You can explore, find housing, and submit at the local police station. Just ensure you have all documents ready, as the 90-day tourist stay has limits.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">American Couple, $3,500/month Combined</h3>
        <p class="text-neutral-600 mb-4">Wanted European lifestyle, loved Mediterranean.</p>
        <p class="text-green-700 font-medium">✓ Living in Split, 2BR apartment €750/month. Love the old town, beaches, and food. Cigna Global insurance covers their European travel. Use Croatia as base for exploring Italy, Greece, Slovenia. Perfect balance of cost and lifestyle.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">British Retiree, £2,000/month Pension</h3>
        <p class="text-neutral-600 mb-4">Post-Brexit, wanted EU base with good weather.</p>
        <p class="text-green-700 font-medium">✓ Istria region, close to Italy. Bought small house in village for €120,000. BUPA Global insurance. Loves the wine, truffles, and Italian influence. Schengen access restored European travel freedom lost with Brexit.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">History Buff, 68, €1,800/month</h3>
        <p class="text-neutral-600 mb-4">Fascinated by Roman and medieval history.</p>
        <p class="text-green-700 font-medium">✓ Based in Zadar, exploring Dalmatian coast. UNESCO sites everywhere—Diocletian's Palace, Plitvice Lakes, Dubrovnik. Affordable lifestyle lets him travel extensively. Local Croatia Osiguranje insurance keeps costs down.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Sailing Enthusiast, €2,500/month</h3>
        <p class="text-neutral-600 mb-4">Wanted to live near his boat.</p>
        <p class="text-green-700 font-medium">✓ Marina berth near Split. Croatia has over 1,200 islands to explore. Sailing community is active. Residency was straightforward with boat as partial "accommodation" proof (combined with rented apartment).</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Winter Weather Concerns</h3>
        <p class="text-neutral-600 mb-4">Expected year-round warm Mediterranean.</p>
        <p class="text-amber-700 font-medium">△ Coast is mild but not tropical—winters 5-15°C. Zagreb colder. Some retirees leave for warmer spots November-March. Now splits time between Croatia (spring/summer/fall) and Canary Islands (winter). Works well but wasn't the plan.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Expected Everyone to Speak English</h3>
        <p class="text-neutral-600 mb-4">No Croatian language preparation.</p>
        <p class="text-amber-700 font-medium">△ Tourist areas have good English, but daily life (bureaucracy, doctors, shopping) often requires Croatian. Had to hire translators for official matters. Now taking Croatian lessons. Manageable but harder than expected—not like Malta.</p>
      </div>
    </div>
  </section>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Not Getting Documents Apostilled in Advance</h3>
        <p class="text-neutral-600">US documents need apostille from Secretary of State. This can take weeks. Getting apostilles while in Croatia is much harder. Prepare everything before your trip.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Underestimating Language Barrier</h3>
        <p class="text-neutral-600">Croatian is challenging. While tourist areas have English, bureaucracy, healthcare, and daily life often require Croatian. Budget for translation help or start learning early.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Only Visiting in Summer</h3>
        <p class="text-neutral-600">Croatia's coast is magical in summer—crowded, expensive, and festive. Winter is quiet, some businesses close, weather is cooler. Visit off-season before committing to understand the full year.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Choosing Dubrovnik for Full-Time Living</h3>
        <p class="text-neutral-600">Dubrovnik is stunning but overrun with tourists, expensive, and somewhat isolated. Great for visits, challenging for daily life. Split, Zadar, or Istria offer better balance for residents.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Forgetting Annual Renewal</h3>
        <p class="text-neutral-600">The permit is initially for 1 year and requires renewal. Start renewal process 1-2 months before expiration. Overstaying or late renewal creates problems for future applications.</p>
      </div>
    </div>
  </section>

  <!-- Section: Healthcare -->
  <section id="healthcare" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Healthcare in Croatia</h2>

    <p class="mb-4">
      Croatia has a solid healthcare system with both public (HZZO) and private options. The public system is good for EU standards, while private clinics offer faster service and often English-speaking staff.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Major Hospitals</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>KBC Zagreb</strong> - Largest hospital, comprehensive services</li>
      <li><strong>KBC Split</strong> - Main hospital for Dalmatian region</li>
      <li><strong>KBC Rijeka</strong> - Serves northern coast</li>
      <li><strong>Poliklinika Medikol</strong> - Private, Zagreb, English-speaking</li>
      <li><strong>Poliklinika Sunce</strong> - Private clinics, multiple locations</li>
    </ul>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Sample Costs (Private, Without Insurance)</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>GP visit:</strong> €40-80</li>
      <li><strong>Specialist:</strong> €60-120</li>
      <li><strong>MRI:</strong> €150-350</li>
      <li><strong>Dental cleaning:</strong> €40-70</li>
      <li><strong>Hospital room (private):</strong> €100-200/night</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Medical tourism:</strong> Croatia is itself a medical tourism destination, especially for dental work. Prices are 50-70% lower than Western Europe with good quality. You might find yourself recommending Croatian dentists to visitors.
      </p>
    </div>
  </section>

  <!-- Section: FAQ -->
  <section id="faq" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Frequently Asked Questions</h2>

    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Can I buy property in Croatia?</h3>
        <p class="text-neutral-600">
          Yes. Americans can buy property with government approval (usually straightforward). The process takes longer than for EU citizens but is well-established. Many retirees buy apartments or houses without issues.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Can I work on this permit?</h3>
        <p class="text-neutral-600">
          The "other purposes" permit for retirement doesn't authorize employment. Remote work for foreign companies is a gray area—technically not allowed but commonly practiced. Local employment requires a work permit.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">How's the internet?</h3>
        <p class="text-neutral-600">
          Good in cities and tourist areas. Fiber is expanding. 50-100 Mbps common in urban areas. Rural areas may be slower. Croatia is workable for remote work in most locations.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">What about citizenship?</h3>
        <p class="text-neutral-600">
          Citizenship requires 8 years of residence (5 for permanent residence + 3 more) plus Croatian language proficiency and cultural knowledge tests. It's a long path but possible.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Is Croatia safe?</h3>
        <p class="text-neutral-600">
          Very safe. Croatia has low crime rates, comparable to or better than most Western European countries. Petty theft exists in tourist areas but violent crime is rare. Most expats feel completely safe.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">How are the winters?</h3>
        <p class="text-neutral-600">
          Coastal Dalmatia: Mild (5-15°C), some rain. Istria: Similar with more fog. Zagreb and inland: Colder (around 0°C), occasional snow. Not tropical but milder than Northern Europe.
        </p>
      </div>
    </div>
  </section>

  <!-- Section: Final Verdict -->
  <section id="verdict" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Final Verdict</h2>

    <p class="mb-4">
      Croatia offers one of Europe's most attractive combinations: stunning Adriatic coastline, rich history, EU membership with Schengen access, and costs 30-40% below Western Europe. For retirees seeking Mediterranean lifestyle without Mediterranean prices, it's compelling.
    </p>

    <p class="mb-4">
      The tradeoffs are a language barrier (Croatian is challenging), cooler winters than expected, and less established English-speaking expat infrastructure compared to Spain or Portugal. But for those who embrace Croatian culture, the rewards are substantial.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <h3 class="font-semibold text-primary-900 mb-3">Bottom Line</h3>
      <p class="text-primary-800 mb-4">
        Croatia is ideal for retirees with €1,500+/month seeking affordable EU residency with stunning coastal scenery. Best for those who enjoy history, sailing, and Mediterranean food culture. Visit in multiple seasons before committing, and be prepared for language challenges. Split, Zadar, and Istria offer the best balance of lifestyle and practicality.
      </p>
