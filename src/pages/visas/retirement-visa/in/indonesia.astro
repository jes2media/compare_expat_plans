---
/**
 * Indonesia Retirement Visa (KITAS/ITAS Lansia) - Long-form CRO-optimized page
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Indonesia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Indonesia Health Insurance Guide", href: "/countries/indonesia/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "notes", header: "Notes" },
];

const requirementsRows = [
  { requirement: "Age", details: "55 years or older", notes: "No exceptions" },
  { requirement: "Pension/Income", details: "$1,500/month minimum", notes: "Pension statement required" },
  { requirement: "Health Insurance", details: "Mandatory", notes: "From Indonesian or international insurer" },
  { requirement: "Accommodation", details: "Proof required", notes: "Rental contract or property ownership" },
  { requirement: "Sponsor", details: "Indonesian sponsor", notes: "Agent or sponsor company" },
  { requirement: "Duration", details: "1 year, renewable", notes: "Renewable up to 5 years total" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Indonesia Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Health Insurance", minimum: "Mandatory for visa", why: "Required for application" },
  { feature: "Coverage Amount", minimum: "$25,000+ recommended", why: "Covers hospitalization" },
  { feature: "Provider", minimum: "Indonesian or international", why: "Both accepted" },
  { feature: "Evacuation", minimum: "Strongly recommended", why: "Singapore/Bangkok for serious care" },
  { feature: "COVID Coverage", minimum: "May be required", why: "Check current requirements" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "BPJS Kesehatan", coverage: "Basic public", price: "$15-50 (subsidized)", strengths: "Cheapest, local system" },
  { provider: "Allianz Indonesia", coverage: "Rp 500M-2B", price: "$100-250", strengths: "Good local coverage" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-450", strengths: "Comprehensive, evacuation" },
  { provider: "Pacific Cross", coverage: "$500,000+", price: "$150-350", strengths: "Asia specialist" },
  { provider: "AXA Indonesia", coverage: "Rp 500M-1.5B", price: "$80-200", strengths: "Local with expat focus" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Agent Fee", amount: "$500-1,500", notes: "Required for most applicants" },
  { item: "ITAS Fee", amount: "$100-200", notes: "Government processing" },
  { item: "Exit-Reentry Permit", amount: "$100", notes: "For leaving Indonesia" },
  { item: "SKTT (Registration)", amount: "$30-50", notes: "Local police registration" },
  { item: "Health Insurance (Annual)", amount: "$1,200-4,000", notes: "Varies by coverage level" },
  { item: "Annual Renewal", amount: "$300-800", notes: "Agent + government fees" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Find visa agent/sponsor", duration: "1-2 weeks", location: "Remote" },
  { step: "Submit application", duration: "1-2 weeks", location: "Indonesian consulate" },
  { step: "Receive visa approval", duration: "2-4 weeks", location: "Wait" },
  { step: "Enter Indonesia", duration: "Travel", location: "Any entry point" },
  { step: "Convert to KITAS", duration: "1-2 weeks", location: "Immigration office" },
  { step: "Complete SKTT", duration: "1-2 weeks", location: "Local police" },
];
---

<PageShell
  title="Indonesia Retirement Visa 2025: KITAS Requirements & Bali Retirement Guide"
  description="Complete guide to Indonesia's retirement visa (KITAS Lansia). Age 55+, $1,500/month pension, mandatory insurance, and living the dream in Bali or beyond."
  headline="Indonesia Retirement Visa: KITAS Insurance & Requirements Guide"
  subheadline="Everything you need to know about retiring in Indonesia—age and income requirements, mandatory health insurance, why Bali tops retirement lists, and navigating the visa process."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Retirement Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Immigration Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Bali & Beyond
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Indonesia's Retirement KITAS (Kartu Izin Tinggal Terbatas) offers retirees aged 55+ the opportunity to live long-term in one of the world's most beautiful and affordable countries. Bali alone attracts thousands of retirees seeking tropical paradise, vibrant culture, and a low cost of living.
    </p>

    <p class="mb-4">
      The retirement visa requires a minimum pension of $1,500/month and mandatory health insurance. While the bureaucracy can be challenging (most applicants use a visa agent), the reward is access to Bali's beaches, Ubud's rice terraces, or quieter spots across Indonesia's 17,000 islands.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Indonesia Retirement Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Age requirement:</strong> 55 years or older</li>
        <li>• <strong>Income:</strong> $1,500/month pension minimum</li>
        <li>• <strong>Health insurance:</strong> Mandatory</li>
        <li>• <strong>Duration:</strong> 1 year, renewable up to 5 years</li>
        <li>• <strong>Sponsor:</strong> Indonesian sponsor/agent required</li>
        <li>• <strong>Work:</strong> Not permitted</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Indonesia for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Stunning natural beauty:</strong> Beaches, volcanoes, rice terraces, temples</li>
      <li><strong>Low cost of living:</strong> $1,500-2,500/month comfortable lifestyle</li>
      <li><strong>Rich culture:</strong> Hindu Bali, diverse islands, warm people</li>
      <li><strong>Tropical climate:</strong> Warm year-round, dry and wet seasons</li>
      <li><strong>Expat community:</strong> Large, established communities in Bali</li>
      <li><strong>Affordable help:</strong> Housekeepers, drivers, cooks readily available</li>
      <li><strong>Food:</strong> Excellent local and international cuisine</li>
      <li><strong>Wellness culture:</strong> Yoga, meditation, healing retreats</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Indonesia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You're 55+ and have $1,500+/month pension</li>
          <li>✓ You love tropical beach/island lifestyle</li>
          <li>✓ You enjoy rich cultural experiences</li>
          <li>✓ You want affordable cost of living</li>
          <li>✓ You're comfortable with developing infrastructure</li>
          <li>✓ You appreciate wellness and spiritual communities</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You're under 55 (strict age requirement)</li>
          <li>• You want top-tier healthcare (Thailand, Malaysia better)</li>
          <li>• You need English everywhere (limited outside tourist areas)</li>
          <li>• You dislike humidity and heat</li>
          <li>• You want simple visa process (Indonesia is bureaucratic)</li>
          <li>• You prefer cooler climates</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Popular retirement areas:</strong> Bali (Ubud, Canggu, Sanur, Seminyak), Lombok (quieter alternative), Yogyakarta (cultural capital), and emerging spots in Flores and Sulawesi. Most retirees choose Bali for infrastructure and community.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Indonesia's retirement visa (officially ITAS Lansia or Retirement KITAS) has specific requirements. Unlike some countries, the age requirement is strict—you must be 55 or older.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Documentation</h3>

    <div class="border border-green-200 bg-green-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">Proving $1,500/Month Pension</h4>
      <ul class="space-y-2 text-green-800">
        <li>✓ Social Security statement (SSA-1099 or benefit letter)</li>
        <li>✓ Government pension documentation</li>
        <li>✓ Corporate pension statements</li>
        <li>✓ Documents must be notarized and apostilled</li>
        <li>✓ Some agents accept investment income with proper documentation</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Sponsor Requirement</h3>

    <div class="border border-blue-200 bg-blue-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-blue-900 mb-3">Indonesian Sponsor/Agent</h4>
      <p class="text-blue-800 mb-3">
        All retirement visa applicants need an Indonesian sponsor. In practice, this means hiring a visa agent who acts as your sponsor. The agent handles the complex paperwork, liaises with immigration, and manages renewals.
      </p>
      <ul class="space-y-2 text-blue-800">
        <li>✓ Visa agents cost $500-1,500</li>
        <li>✓ They manage the entire process</li>
        <li>✓ Annual renewal through same agent recommended</li>
        <li>✓ Reputable agents save significant headaches</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Requirements</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Passport:</strong> Valid 18+ months, with blank pages</li>
      <li><strong>Pension proof:</strong> Notarized and apostilled</li>
      <li><strong>CV/Resume:</strong> Education and work history</li>
      <li><strong>Passport photos:</strong> Red background (4x6 cm)</li>
      <li><strong>Health insurance:</strong> Certificate of coverage</li>
      <li><strong>Accommodation proof:</strong> Rental agreement or sponsor letter</li>
      <li><strong>Statement of intent:</strong> Not to work in Indonesia</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Under 55?</strong> Indonesia has no retirement visa option for those under 55. Alternatives include the B211A social visa (6 months, extendable), or the new Second Home Visa (requires ~$130,000 deposit or property). Many younger expats do visa runs every 2-6 months.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance is Mandatory</h3>
      <p class="text-red-800">
        Indonesia requires health insurance for retirement visa applications. You must provide a certificate of coverage from an Indonesian-registered or internationally recognized insurer. This is verified during the visa process.
      </p>
    </div>

    <p class="mb-4">
      While the minimum requirements aren't strictly specified, immigration expects comprehensive coverage. Most applicants use international insurers for the application, then may add local coverage after arrival.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Specifications</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">BPJS vs Private Insurance</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">BPJS Kesehatan (Public)</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Available to KITAS holders</li>
          <li>✓ Very affordable (~$15-50/month)</li>
          <li>✓ Covers public and some private hospitals</li>
          <li>✓ No pre-existing condition exclusions</li>
          <li>△ Long wait times</li>
          <li>△ Basic facilities in some areas</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Private/International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Access to best private hospitals</li>
          <li>✓ BIMC, Siloam, international standards</li>
          <li>✓ Evacuation to Singapore included</li>
          <li>✓ English-speaking providers</li>
          <li>△ Higher cost ($150-400/month)</li>
          <li>△ Pre-existing condition limits</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Best approach:</strong> Use international insurance for the visa application (it's what immigration expects). After arrival, consider enrolling in BPJS for basic coverage (very cheap) while maintaining private insurance for serious conditions and evacuation.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for your Indonesia retirement visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Retirement Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For visa applications, international insurers are generally preferred. After residency, you can add local options. Here are providers that work well for Indonesia retirees.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Visa Application</h4>
        <p class="text-neutral-600">Cigna Global or Pacific Cross for initial application—both are well-recognized by Indonesian immigration and provide the coverage certificate required. Include evacuation coverage to Singapore.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-Term Coverage</h4>
        <p class="text-neutral-600">BPJS Kesehatan (public, ~$30/month) for basic coverage plus a private policy for serious conditions. BPJS covers routine care; private handles quality hospitals and evacuation.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Bali-Focused</h4>
        <p class="text-neutral-600">Local insurers like Allianz Indonesia or AXA Indonesia have good networks at Bali's international hospitals (BIMC, Siloam). Often more affordable than global policies for Indonesia-specific coverage.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">$1,200</p>
        <p class="text-sm text-neutral-500 mt-2">Basic villa, local food</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$2,000</p>
        <p class="text-sm text-neutral-500 mt-2">Nice villa, mixed lifestyle</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Upscale</p>
        <p class="text-3xl font-bold text-neutral-900">$3,500+</p>
        <p class="text-sm text-neutral-500 mt-2">Luxury villa, Western lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost by Location (Bali)</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Ubud:</strong> $1,500-2,500/month (rice paddies, arts, wellness)</li>
      <li><strong>Sanur:</strong> $1,400-2,400/month (quieter beach, retiree-friendly)</li>
      <li><strong>Canggu:</strong> $1,800-3,000/month (trendy, younger crowd)</li>
      <li><strong>Seminyak:</strong> $2,000-3,500/month (upscale, restaurants)</li>
      <li><strong>Amed/East Bali:</strong> $1,000-1,800/month (quiet, diving)</li>
      <li><strong>Lombok:</strong> $1,000-2,000/month (less developed, cheaper)</li>
    </ul>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Affordable help:</strong> One major advantage in Indonesia is affordable household help. A full-time housekeeper costs $150-300/month. A driver costs $300-500/month. Many retirees employ both, dramatically improving quality of life.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Indonesia retirement visa process involves multiple steps and agencies. Most applicants hire a visa agent to navigate the bureaucracy. The process takes 4-8 weeks total.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Process</h3>

    <ol class="list-decimal pl-6 space-y-3 mb-6">
      <li><strong>Find a visa agent</strong> in Bali or your target location (research reviews, costs)</li>
      <li><strong>Gather documents</strong> in home country (pension proof, criminal check)</li>
      <li><strong>Get notarization and apostille</strong> for official documents</li>
      <li><strong>Agent submits telex</strong> (visa approval letter) application</li>
      <li><strong>Receive telex approval</strong> (2-4 weeks)</li>
      <li><strong>Visit Indonesian consulate</strong> in home country for visa stamp</li>
      <li><strong>Enter Indonesia</strong> within 90 days of visa issuance</li>
      <li><strong>Convert visa to KITAS</strong> at immigration office</li>
      <li><strong>Complete SKTT</strong> (local police registration)</li>
      <li><strong>Receive KITAS card</strong> (your stay permit)</li>
    </ol>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Agent is essential:</strong> While technically possible to DIY, Indonesian immigration is bureaucratic and requirements change frequently. A good agent ($500-1,500) handles everything, knows the officials, and solves problems quickly. Worth every dollar.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Yoga Enthusiast, 62, $2,500/month</h3>
        <p class="text-neutral-600 mb-4">Social Security plus small pension, drawn to Bali spirituality.</p>
        <p class="text-green-700 font-medium">✓ KITAS approved. Living in Ubud among rice terraces. Daily yoga, meditation, healing ceremonies. Housekeeper costs $200/month. Best decision ever—found community and purpose. Cigna Global insurance for peace of mind.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Beach Lovers, Couple, $3,500/month Combined</h3>
        <p class="text-neutral-600 mb-4">Both 58+, wanted tropical beach retirement.</p>
        <p class="text-green-700 font-medium">✓ Both have KITAS. Renting beautiful villa in Sanur for $1,200/month with pool. Scooters for transport, eat local and Western. Active expat social scene. Using local AXA insurance, very satisfied with coverage.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Solo Retiree, 67, $1,800/month</h3>
        <p class="text-neutral-600 mb-4">Modest pension, wanted affordable tropical living.</p>
        <p class="text-green-700 font-medium">✓ Living well in Amed (East Bali) on $1,400/month. Quieter than south Bali, great diving, small expat community. BPJS plus travel insurance for evacuation. Simple life but exactly what he wanted.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Health-Conscious Retiree</h3>
        <p class="text-neutral-600 mb-4">Cardiac history, worried about healthcare.</p>
        <p class="text-amber-700 font-medium">△ Living in Sanur, close to BIMC hospital. Has Cigna Global with evacuation. Had minor episode—flown to Singapore for procedure within 24 hours. Insurance covered $60,000. Bali healthcare adequate for monitoring but Singapore for serious care.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Digital Creative, 55, Investment Income</h3>
        <p class="text-neutral-600 mb-4">No traditional pension, $2,000/month from investments.</p>
        <p class="text-green-700 font-medium">✓ Worked with agent to document investment income as pension equivalent. Took extra paperwork but approved. Living in Canggu, still does some remote creative work. Technically shouldn't work, but remote consulting is in gray area.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Expected Modern Infrastructure</h3>
        <p class="text-neutral-600 mb-4">Used to US conveniences and standards.</p>
        <p class="text-red-700 font-medium">✗ Struggled with power outages, slow internet, traffic. Water quality issues. Visa bureaucracy frustrating. Found the heat exhausting. Returned after 8 months. Indonesia requires flexibility and patience.</p>
      </div>
    </div>
  </section>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Using a Cheap or Unknown Visa Agent</h3>
        <p class="text-neutral-600">Not all visa agents are equal. Some take money and disappear or bungle applications. Research thoroughly, ask for expat recommendations, and use established agents. The cheapest option often causes the most problems.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Skipping Medical Evacuation Coverage</h3>
        <p class="text-neutral-600">Bali has good basic healthcare, but serious conditions require evacuation to Singapore (4+ hours by air). A medevac can cost $30,000-100,000. Don't gamble—get evacuation coverage.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Overstaying Your Visa</h3>
        <p class="text-neutral-600">Indonesia takes overstays seriously—$100/day fine, potential detention, and future visa issues. Set calendar reminders for renewal well in advance. Your agent should help with this.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Expecting Western Standards Everywhere</h3>
        <p class="text-neutral-600">Indonesia is a developing country. Expect power fluctuations, occasional water issues, traffic, and bureaucracy. Those who embrace the adventure thrive; those expecting Western standards struggle.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Not Doing a Trial Stay First</h3>
        <p class="text-neutral-600">Bali on vacation is different from Bali as home. Spend at least 2-3 months on a tourist visa before committing. Experience rainy season, daily life, and healthcare firsthand. Many people's dream destination becomes their nightmare when they actually try living there.</p>
      </div>
    </div>
  </section>

  <!-- Section: Healthcare -->
  <section id="healthcare" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Healthcare in Indonesia</h2>

    <p class="mb-4">
      Healthcare in Indonesia varies dramatically by location. Bali has several international-standard hospitals, while rural areas may have only basic clinics. For serious conditions, Singapore is the regional medical hub (4-hour flight from Bali).
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Major Hospitals (Bali)</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>BIMC Hospital Kuta</strong> - International standard, English-speaking, 24/7 ER</li>
      <li><strong>BIMC Nusa Dua</strong> - Newer facility, premium care</li>
      <li><strong>Siloam Hospital Bali</strong> - Large network, good specialists</li>
      <li><strong>Kasih Ibu Hospital</strong> - Local private, more affordable</li>
      <li><strong>Sanglah Hospital</strong> - Public, teaching hospital, cheapest</li>
    </ul>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Sample Costs (Private, Without Insurance)</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>GP visit:</strong> $30-60</li>
      <li><strong>Specialist:</strong> $50-100</li>
      <li><strong>MRI:</strong> $200-400</li>
      <li><strong>Dental cleaning:</strong> $25-50</li>
      <li><strong>Hospital room (private):</strong> $100-300/night</li>
      <li><strong>Evacuation to Singapore:</strong> $15,000-40,000</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Medical tourism:</strong> Many Indonesians and expats fly to Singapore, Malaysia, or Thailand for major procedures. Singapore is 2.5 hours from Bali and has world-class hospitals. Your insurance should cover regional treatment.
      </p>
    </div>
  </section>

  <!-- Section: FAQ -->
  <section id="faq" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Frequently Asked Questions</h2>

    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Can I work on the retirement KITAS?</h3>
        <p class="text-neutral-600">
          No. The retirement KITAS explicitly prohibits employment. Remote work for foreign companies exists in a gray area—technically not allowed but widely practiced. Don't take local employment or advertise services locally.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">What if I'm under 55?</h3>
        <p class="text-neutral-600">
          Indonesia has no retirement visa for under-55s. Options include: B211A social visa (6 months, extendable), Second Home Visa (~$130,000 deposit), or visa runs every 60-90 days. Many younger expats do visa runs for years.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Can I buy property?</h3>
        <p class="text-neutral-600">
          Foreigners cannot own freehold property. Options include: leasehold (up to 80 years), Hak Pakai (right to use), or through a PT PMA company structure. Many expats successfully lease long-term. Consult a property lawyer.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">How's the internet?</h3>
        <p class="text-neutral-600">
          Bali has good fiber internet in most areas (20-100 Mbps). Rural areas may be limited to 4G. Starlink is available. Coffee shops and coworking spaces have reliable WiFi. Remote work is feasible in tourist areas.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Is Bali safe?</h3>
        <p class="text-neutral-600">
          Bali is generally safe—violent crime against foreigners is rare. Main concerns are petty theft (bag snatching from scooters), traffic accidents (scooter accidents are common), and natural disasters (earthquakes, volcanic activity). Use normal precautions.
        </p>
      </div>

      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">What about the rainy season?</h3>
        <p class="text-neutral-600">
          November-March is rainy season—daily afternoon storms, higher humidity, occasional flooding. Many expats love it (cooler, less crowded, green landscapes). Others leave during these months. Try experiencing it before committing.
        </p>
      </div>
    </div>
  </section>

  <!-- Section: Final Verdict -->
  <section id="verdict" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Final Verdict</h2>

    <p class="mb-4">
      Indonesia's retirement KITAS offers access to one of the world's most beautiful and culturally rich countries at a remarkably low cost of living. Bali's combination of natural beauty, spiritual culture, wellness scene, and established expat community makes it a top retirement destination for those 55+.
    </p>

    <p class="mb-4">
      The tradeoffs are healthcare limitations (plan for evacuation), bureaucratic visa process (use an agent), infrastructure gaps, and the strict 55+ age requirement. But for those who embrace the Indonesian way of life, the rewards are extraordinary.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <h3 class="font-semibold text-primary-900 mb-3">Bottom Line</h3>
      <p class="text-primary-800 mb-4">
        Indonesia's retirement visa is ideal for 55+ retirees with $1,500+/month pension who want affordable tropical living in a culturally rich environment. Bali offers the best infrastructure and community. Use a reputable visa agent, get comprehensive insurance with evacuation, and do a trial stay before committing. For the right person, it's paradise.
      </p>
