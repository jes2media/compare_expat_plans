---
/**
 * Vietnam Retirement Visa (Long-Term Stay Options) - Long-form CRO-optimized page
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Options", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Vietnam", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Vietnam Health Insurance Guide", href: "/countries/vietnam/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "visaType", header: "Visa Type" },
  { key: "duration", header: "Duration" },
  { key: "requirements", header: "Requirements" },
  { key: "best", header: "Best For" },
];

const requirementsRows = [
  { visaType: "Tourist Visa (E-visa)", duration: "90 days", requirements: "Passport, online application", best: "Short stays, testing Vietnam" },
  { visaType: "Business Visa (DN)", duration: "1-3 years", requirements: "Sponsor company", best: "Long-term stay option" },
  { visaType: "Investor Visa (DT)", duration: "1-5 years", requirements: "$50,000+ investment", best: "Business-minded retirees" },
  { visaType: "Visa Exemption", duration: "5 years", requirements: "Vietnamese spouse/ancestry", best: "Married to Vietnamese" },
  { visaType: "TRC (Temporary Residence)", duration: "1-3 years", requirements: "Business/investor visa holders", best: "Established residents" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Vietnam Situation" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Health Insurance", minimum: "Not mandatory (recommended)", why: "No visa requirement" },
  { feature: "Public Healthcare", minimum: "Not accessible to foreigners", why: "VSS requires employment" },
  { feature: "Private Insurance", minimum: "Highly recommended", why: "Quality care access" },
  { feature: "Evacuation Coverage", minimum: "Essential", why: "Bangkok/Singapore for complex care" },
  { feature: "Coverage Amount", minimum: "$100,000+ recommended", why: "International hospital costs" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Pacific Cross Vietnam", coverage: "$150,000-500,000", price: "$100-250", strengths: "Vietnam specialist" },
  { provider: "Bao Viet Insurance", coverage: "VND 500M-2B", price: "$50-150", strengths: "Local, affordable" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-450", strengths: "Comprehensive, worldwide" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$180-400", strengths: "Good regional coverage" },
  { provider: "Liberty Insurance", coverage: "VND 1B+", price: "$80-200", strengths: "International hospital access" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "E-visa (90 days)", amount: "$25", notes: "Online application" },
  { item: "Business Visa (1 year)", amount: "$200-400", notes: "Plus sponsor fees" },
  { item: "Visa Agent/Sponsor", amount: "$300-800/year", notes: "For business visa" },
  { item: "TRC Application", amount: "$100-200", notes: "If eligible" },
  { item: "Health Insurance (Annual)", amount: "$1,000-4,000", notes: "Varies by coverage" },
  { item: "Visa Extensions", amount: "$50-100/time", notes: "If extending tourist visa" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "notes", header: "Notes" },
];

const timelineRows = [
  { step: "E-visa application", duration: "3-5 days", notes: "Online, simple" },
  { step: "Arrive in Vietnam", duration: "Travel", notes: "90-day stay" },
  { step: "Find visa sponsor/agent", duration: "1-2 weeks", notes: "For long-term stay" },
  { step: "Business visa processing", duration: "5-10 days", notes: "Agent handles paperwork" },
  { step: "TRC application (optional)", duration: "2-4 weeks", notes: "After business visa" },
  { step: "Annual renewal", duration: "1-2 weeks", notes: "Before expiration" },
];
---

<PageShell
  title="Vietnam Retirement 2025: Long-Term Visa Options & Insurance Guide"
  description="Complete guide to retiring in Vietnam. No formal retirement visa—but business visas, investor options, and visa workarounds let retirees enjoy affordable living in Da Nang, Hoi An, and beyond."
  headline="Vietnam Long-Term Stay: Retirement Visa Options & Insurance Guide"
  subheadline="Vietnam doesn't have a retirement visa—but thousands of retirees live there happily. Here's how to navigate the visa options, healthcare system, and affordable lifestyle."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Retirement Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Visa Workarounds Explained
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Ultra-Low Cost of Living
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-amber-900 mb-2">Important: Vietnam Has No Retirement Visa</h3>
      <p class="text-amber-800">
        Unlike Thailand, Philippines, or Indonesia, Vietnam does not offer a dedicated retirement visa. However, thousands of retirees live in Vietnam using business visas, investor visas, or visa runs. This guide explains how to navigate these options legally.
      </p>
    </div>

    <p class="mb-4">
      Vietnam has emerged as a popular retirement destination for those seeking ultra-low cost of living, excellent food, friendly people, and a fascinating culture. Cities like Da Nang, Hoi An, and Ho Chi Minh City have growing expat communities of retirees who've figured out the visa situation.
    </p>

    <p class="mb-4">
      The most common approach is a business visa sponsored by a visa agency, which provides 1-3 year stays without actually requiring you to work. It's not officially a retirement visa, but it functions as one for thousands of long-term residents.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Vietnam Long-Term Stay</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Retirement visa:</strong> Does not exist</li>
        <li>• <strong>Common workaround:</strong> Business visa with sponsor ($500-800/year)</li>
        <li>• <strong>Tourist visa:</strong> 90 days, extendable or visa run</li>
        <li>• <strong>Health insurance:</strong> Not required but essential</li>
        <li>• <strong>Cost of living:</strong> $1,000-2,000/month comfortable</li>
        <li>• <strong>Popular areas:</strong> Da Nang, Hoi An, HCMC, Hanoi</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Vietnam for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Ultra-low cost:</strong> One of Asia's most affordable countries</li>
      <li><strong>Excellent food:</strong> World-famous cuisine, fresh and cheap</li>
      <li><strong>Beautiful scenery:</strong> Beaches, mountains, rice terraces</li>
      <li><strong>Friendly people:</strong> Welcoming to foreigners</li>
      <li><strong>Growing infrastructure:</strong> Improving rapidly</li>
      <li><strong>Expat communities:</strong> Established in major cities</li>
      <li><strong>Climate variety:</strong> Tropical south, temperate north</li>
      <li><strong>Rich culture:</strong> History, temples, festivals</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Vietnam is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want the lowest possible cost of living</li>
          <li>✓ You're comfortable with visa workarounds</li>
          <li>✓ You love Vietnamese food and culture</li>
          <li>✓ You enjoy adventure and flexibility</li>
          <li>✓ You don't need a formal retirement program</li>
          <li>✓ You can handle some bureaucratic uncertainty</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want a proper retirement visa (Thailand, Philippines)</li>
          <li>• You need healthcare certainty (Thailand, Malaysia)</li>
          <li>• You prefer Western standards (Portugal, Spain)</li>
          <li>• You want English everywhere (Philippines)</li>
          <li>• You're uncomfortable with gray-area visas</li>
          <li>• You need stability in immigration status</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Popular retirement areas:</strong> Da Nang (beach + city, best infrastructure), Hoi An (charming ancient town, 30 min from Da Nang), Ho Chi Minh City (big city, most amenities), Nha Trang (beach resort town), Hanoi (cultural capital, cooler climate).
      </p>
    </div>
  </section>

  <!-- Section: Visa Options -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Options for Retirees</h2>

    <p class="mb-4">
      Without a dedicated retirement visa, retirees in Vietnam use several workarounds. Here are the main options, from simplest to most committed.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Option 1: Business Visa (Most Common)</h3>

    <div class="border border-green-200 bg-green-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-green-900 mb-3">The Practical Retirement Solution</h4>
      <p class="text-green-800 mb-3">
        Most long-term retirees use a business visa (DN category) sponsored by a visa agency or company. You don't need to actually work—the sponsor provides the paperwork.
      </p>
      <ul class="space-y-2 text-green-800">
        <li>✓ 1-3 year validity available</li>
        <li>✓ Multiple entry permitted</li>
        <li>✓ Renewable indefinitely</li>
        <li>✓ Can apply for TRC (residence card) after</li>
        <li>✓ Visa agencies charge $500-800/year</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Option 2: Tourist Visa + Extensions/Runs</h3>

    <div class="border border-blue-200 bg-blue-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-blue-900 mb-3">For Testing or Short-Term</h4>
      <p class="text-blue-800 mb-3">
        The 90-day e-visa can be extended once, or you can do visa runs to neighboring countries (Cambodia, Thailand) and return for another 90 days.
      </p>
      <ul class="space-y-2 text-blue-800">
        <li>✓ Simple, no sponsor needed</li>
        <li>✓ Good for testing Vietnam</li>
        <li>✓ Can extend up to 90 additional days</li>
        <li>△ Requires periodic travel</li>
        <li>△ Not ideal for long-term</li>
        <li>△ Rules change—check current requirements</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Option 3: Investor Visa</h3>

    <div class="border border-purple-200 bg-purple-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-purple-900 mb-3">For Business-Minded Retirees</h4>
      <p class="text-purple-800 mb-3">
        Investing $50,000+ in a Vietnamese business can qualify you for an investor visa with multi-year validity. Some retirees do this legitimately with small businesses.
      </p>
      <ul class="space-y-2 text-purple-800">
        <li>✓ 1-5 year visa possible</li>
        <li>✓ Legitimate long-term status</li>
        <li>✓ Can lead to permanent residence</li>
        <li>△ Requires actual investment</li>
        <li>△ Business compliance requirements</li>
        <li>△ Complex setup</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Option 4: 5-Year Visa Exemption</h3>

    <div class="border border-amber-200 bg-amber-50 rounded-lg p-6 mb-6">
      <h4 class="font-semibold text-amber-900 mb-3">For Those With Vietnamese Connections</h4>
      <ul class="space-y-2 text-amber-800">
        <li>✓ Married to Vietnamese citizen</li>
        <li>✓ Vietnamese ancestry (overseas Vietnamese)</li>
        <li>✓ Parents of Vietnamese citizens</li>
        <li>✓ 5-year unlimited entry</li>
        <li>✓ Best long-term option if eligible</li>
      </ul>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Visa rules change:</strong> Vietnam's visa policies have changed several times in recent years. Always verify current requirements before making plans. What worked in 2023 may not work in 2025.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Insurance Not Visa-Required—But Essential</h3>
      <p class="text-blue-800">
        Vietnam doesn't require health insurance for any visa type. However, as a foreigner, you won't have access to the public healthcare system (VSS). Private health insurance is essential for quality care and financial protection.
      </p>
    </div>

    <p class="mb-4">
      Vietnam's healthcare has improved dramatically, with excellent private hospitals in major cities. But costs at international-standard facilities are significant, and serious conditions may require evacuation to Bangkok or Singapore.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Considerations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Healthcare Access Options</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Local Private Insurance</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Affordable ($50-200/month)</li>
          <li>✓ Good local hospital networks</li>
          <li>✓ Vietnamese + international hospitals</li>
          <li>✓ Pacific Cross, Bao Viet popular</li>
          <li>△ May exclude pre-existing conditions</li>
          <li>△ Limited evacuation coverage</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Comprehensive coverage</li>
          <li>✓ Medical evacuation to Bangkok/Singapore</li>
          <li>✓ Worldwide coverage when traveling</li>
          <li>✓ Higher coverage limits</li>
          <li>△ More expensive ($200-450/month)</li>
          <li>△ May require treatment abroad for major claims</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Evacuation is important:</strong> While Vietnam's healthcare is improving, complex cardiac surgery, cancer treatment, or major trauma may require evacuation to Bangkok (2 hours) or Singapore (2.5 hours). Include evacuation coverage in your policy.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for long-term Vietnam stay?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Retirement Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      A combination of local and international coverage often works best. Local insurance for routine care, international for serious conditions and evacuation.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Option</h4>
        <p class="text-neutral-600">Pacific Cross Vietnam or Bao Viet for local coverage ($50-150/month). Covers most needs at local and international hospitals in Vietnam. Add travel insurance for trips that includes evacuation.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Coverage</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care for international coverage ($200-400/month). Includes Vietnam, regional evacuation, and worldwide coverage. Best for those with health conditions or wanting peace of mind.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Hybrid Approach</h4>
        <p class="text-neutral-600">Local insurance (Bao Viet ~$100/month) for routine care plus Cigna Global with higher deductible for catastrophic coverage and evacuation. Balances cost and comprehensive protection.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">$800</p>
        <p class="text-sm text-neutral-500 mt-2">Local lifestyle, basic apartment</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Nice apartment, mixed lifestyle</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Upscale</p>
        <p class="text-3xl font-bold text-neutral-900">$2,500+</p>
        <p class="text-sm text-neutral-500 mt-2">Serviced apartment, Western lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost by Location</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Da Nang:</strong> $1,000-2,000/month (beach + city, best value)</li>
      <li><strong>Hoi An:</strong> $1,200-2,200/month (charming, slightly touristy)</li>
      <li><strong>Ho Chi Minh City:</strong> $1,200-2,500/month (big city, most options)</li>
      <li><strong>Hanoi:</strong> $1,000-2,200/month (cultural, cooler climate)</li>
      <li><strong>Nha Trang:</strong> $800-1,800/month (beach resort, Russian influence)</li>
      <li><strong>Vung Tau:</strong> $800-1,500/month (beach, close to HCMC)</li>
    </ul>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h4 class="font-semibold text-green-900 mb-3">Sample Monthly Budget (Da Nang, Comfortable)</h4>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>Rent (2BR apartment):</strong> $400-600</li>
        <li>• <strong>Utilities:</strong> $50-100</li>
        <li>• <strong>Food (eating out often):</strong> $300-500</li>
        <li>• <strong>Transportation:</strong> $50-100</li>
        <li>• <strong>Health insurance:</strong> $100-300</li>
        <li>• <strong>Entertainment:</strong> $100-200</li>
        <li>• <strong>Visa costs (amortized):</strong> $50-75</li>
        <li>• <strong>Total:</strong> $1,050-1,875</li>
      </ul>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The process depends on which visa option you choose. Here's the typical path for the business visa approach most retirees use.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step (Business Visa Route)</h3>

    <ol class="list-decimal pl-6 space-y-3 mb-6">
      <li><strong>Apply for e-visa online</strong> (3-5 days, $25)</li>
      <li><strong>Arrive in Vietnam</strong> on 90-day tourist visa</li>
      <li><strong>Explore and settle</strong> in your chosen city</li>
      <li><strong>Find visa agent/sponsor</strong> (recommendations from expat groups)</li>
      <li><strong>Agent arranges business visa</strong> (1-3 year options)</li>
      <li><strong>Exit to Cambodia or fly out</strong> (visa run required for some)</li>
      <li><strong>Re-enter with business visa</strong></li>
      <li><strong>Optionally apply for TRC</strong> (Temporary Residence Card)</li>
      <li><strong>Renew annually</strong> through your agent</li>
    </ol>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Recommended agents:</strong> Ask in expat Facebook groups for current recommendations. Vietnam Visa Pro, Vietnam-Visa.com, and local agents in Da Nang/HCMC are commonly used. Prices and service quality vary—get referrals.
      </p>
    </div>
  </section>

