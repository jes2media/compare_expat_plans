---
/**
 * France Retirement Visa (Long-Stay Visitor Visa) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in France", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "France Health Insurance Guide", href: "/countries/france/insurance" },
  { title: "Insurance for Retirees Abroad", href: "/insurance-for/retirees" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Financial Resources", details: "~€1,700/month (~$1,850) or equivalent savings", evidence: "Bank statements, pension proof, investment income" },
  { requirement: "Accommodation", details: "Proof of housing in France", evidence: "Rental contract, property deed, or attestation d'hébergement" },
  { requirement: "Health Insurance", details: "Full coverage for France", evidence: "Insurance certificate (ideally in French)" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "FBI background check (apostilled)" },
  { requirement: "No Work Intent", details: "Cannot work in France", evidence: "Attestation of non-employment" },
  { requirement: "Valid Passport", details: "Valid 3+ months beyond visa", evidence: "Passport with blank pages" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "France Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive (€30,000+ recommended)", why: "Must cover hospitalization & treatment" },
  { feature: "Coverage Territory", minimum: "Valid in France/EU", why: "Schengen-compliant" },
  { feature: "Emergency Repatriation", minimum: "Required", why: "French consulates verify this" },
  { feature: "Duration", minimum: "Full visa period (1 year)", why: "Must match or exceed visa dates" },
  { feature: "COVID Coverage", minimum: "Recommended", why: "Some consulates still ask" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost (60-70 yr)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€200-450", strengths: "Premium comprehensive, pre-existing" },
  { provider: "AXA Global", coverage: "€500,000+", price: "€170-380", strengths: "French company, strong local network" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€180-400", strengths: "EU-wide coverage" },
  { provider: "April International", coverage: "€500,000+", price: "€160-350", strengths: "French-based, expat specialist" },
  { provider: "CFE (Caisse des Français)", coverage: "French system rates", price: "€150-400", strengths: "Access to French healthcare system" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€99", notes: "Long-stay visa fee" },
  { item: "OFII Tax", amount: "€200-225", notes: "Immigration office tax upon arrival" },
  { item: "Carte de Séjour (renewal)", amount: "€225", notes: "Annual residence permit renewal" },
  { item: "Health Insurance (Annual)", amount: "€2,000-5,500", notes: "Age-dependent" },
  { item: "Document Apostille", amount: "€50-200", notes: "Per document, home country" },
  { item: "Translation (assermentée)", amount: "€30-80/page", notes: "Sworn translator required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "4-8 weeks", location: "Home country" },
  { step: "Get sworn translations", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1-3 days", location: "Online" },
  { step: "Schedule consulate appointment", duration: "2-8 weeks", location: "French consulate" },
  { step: "Submit visa application", duration: "1 day", location: "French consulate" },
  { step: "Processing", duration: "2-8 weeks", location: "Consulate review" },
  { step: "Receive visa", duration: "Pick up or mail", location: "Consulate" },
  { step: "Enter France", duration: "Within 3 months", location: "France" },
  { step: "OFII validation", duration: "Within 3 months of arrival", location: "Online + medical exam" },
];
---

<PageShell
  title="France Long-Stay Visitor Visa 2026: Retirement Visa Requirements, Insurance & Application Guide"
  description="Complete guide to France's long-stay visitor visa for retirees. Financial requirements, health insurance, OFII process, and pathway to EU residency in France."
  headline="France Long-Stay Visitor Visa: Retirement Insurance & Requirements Guide"
  subheadline="Everything you need to know about retiring to France—financial requirements, healthcare access, the OFII process, and living the French dream."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Retirement Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU Pathway
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      France's Visa de Long Séjour Visiteur (Long-Stay Visitor Visa) is the pathway for retirees and others who want to live in France without working. From Parisian apartments to Provençal farmhouses, France offers retirees world-renowned culture, cuisine, healthcare, and a quality of life that has attracted expats for generations.
    </p>

    <p class="mb-4">
      The visitor visa is explicitly for those who can support themselves—no work permitted. France wants proof you won't become a burden on its social systems, but in exchange offers access to one of the world's best healthcare systems and eventual pathway to permanent residency and citizenship.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: France Long-Stay Visitor Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Visa de Long Séjour Visiteur (VLS-TS)</li>
        <li>• <strong>Income requirement:</strong> ~€1,700/month (~$1,850) or equivalent</li>
        <li>• <strong>Initial duration:</strong> 1 year</li>
        <li>• <strong>Renewal:</strong> Annual carte de séjour</li>
        <li>• <strong>Work allowed:</strong> No—strictly passive income only</li>
        <li>• <strong>Path to citizenship:</strong> 5 years of residency</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why France for Retirement?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>World-class healthcare:</strong> France's system consistently ranks among the world's best</li>
      <li><strong>Unmatched culture:</strong> Museums, history, arts, and that inimitable French lifestyle</li>
      <li><strong>Incredible food and wine:</strong> No explanation needed</li>
      <li><strong>Regional diversity:</strong> Paris, Provence, Normandy, Alps, Riviera, Bordeaux</li>
      <li><strong>EU residency:</strong> Schengen travel, pathway to citizenship</li>
      <li><strong>Excellent infrastructure:</strong> TGV trains, airports, modern amenities</li>
      <li><strong>Rich expat history:</strong> Americans have retired to France for over a century</li>
      <li><strong>Affordable outside Paris:</strong> Smaller cities and countryside offer excellent value</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">France is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You have €1,700+/month in passive income</li>
          <li>✓ You don't need to work</li>
          <li>✓ You love French culture, food, and wine</li>
          <li>✓ You want access to excellent healthcare</li>
          <li>✓ You're willing to learn some French</li>
          <li>✓ You appreciate history, art, and architecture</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need to work remotely (France DNV instead)</li>
          <li>• You want to stay entirely in English</li>
          <li>• You prefer beach/tropical lifestyle</li>
          <li>• You want the lowest possible costs</li>
          <li>• You don't enjoy paperwork (France has lots)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Healthcare access:</strong> After 3 months of legal residency, you can apply for PUMA (Protection Universelle Maladie)—France's universal healthcare coverage. Private insurance is still needed for the visa, but you'll eventually gain access to France's excellent public system.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      France doesn't publish a specific minimum income for the visitor visa, but consulates typically want to see roughly the French minimum wage (~€1,700/month) or equivalent savings. The key is demonstrating you can support yourself without working.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Financial Requirements</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Monthly Income Approach</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Guideline:</strong> ~€1,700/month (~$1,850)</li>
          <li>• <strong>Paris:</strong> Higher amounts preferred (€2,500+)</li>
          <li>• <strong>Provinces:</strong> Lower amounts may suffice</li>
          <li>• <strong>Proof:</strong> Pension statements, investment income</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Savings Approach</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Guideline:</strong> €20,000-30,000 in liquid savings</li>
          <li>• <strong>Proof:</strong> Recent bank statements</li>
          <li>• <strong>Combination:</strong> Income + savings acceptable</li>
          <li>• <strong>Property:</strong> Owned French property helps</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Consulate discretion:</strong> French consulates have significant discretion in evaluating applications. A strong overall application (good income, health insurance, housing arranged, ties to France) can compensate for being on the lower end of income requirements.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">What Qualifies as Income</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Pensions:</strong> Government or private retirement income</li>
      <li><strong>Social Security:</strong> US Social Security payments</li>
      <li><strong>Investment income:</strong> Dividends, interest, capital gains</li>
      <li><strong>Rental income:</strong> From properties you own</li>
      <li><strong>Savings withdrawals:</strong> From retirement accounts</li>
      <li><strong>Spousal support:</strong> If documented</li>
    </ul>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mt-6">
      <p class="text-red-800">
        <strong>No work allowed:</strong> The visitor visa prohibits all work—employed or self-employed. If you want to do any remote work, even occasionally, you need France's digital nomad visa (Passeport Talent) instead.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required for Visa</h3>
      <p class="text-red-800">
        France requires comprehensive health insurance valid for the duration of your visa. Your policy must cover hospitalization, medical treatment, and repatriation. While there's no strict minimum coverage amount, €30,000+ is recommended to demonstrate adequate protection.
      </p>
    </div>

    <p class="mb-4">
      Insurance is critical both for the visa application and for your first months in France before you can access the public healthcare system (PUMA). Many retirees maintain private insurance even after gaining PUMA access for additional coverage.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Specifications</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Insurance Timeline in France</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Months 1-3</h4>
        <ul class="space-y-2 text-green-800 text-sm">
          <li>✓ Private insurance required</li>
          <li>✓ No public healthcare access</li>
          <li>✓ Complete OFII process</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">After 3 Months</h4>
        <ul class="space-y-2 text-blue-800 text-sm">
          <li>✓ Apply for PUMA (public)</li>
          <li>✓ Can add mutuelle (top-up)</li>
          <li>✓ Private still useful</li>
        </ul>
      </div>

      <div class="border border-purple-200 bg-purple-50 rounded-lg p-6">
        <h4 class="font-semibold text-purple-900 mb-3">Long-term</h4>
        <ul class="space-y-2 text-purple-800 text-sm">
          <li>✓ PUMA covers most care</li>
          <li>✓ Consider mutuelle top-up</li>
          <li>✓ Private optional but helpful</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need comprehensive health insurance for France's long-stay visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare France-Ready Insurance →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer plans suitable for France's long-stay visitor visa. French-based insurers (AXA, April) are well-known to consulates and may streamline approval.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">French Company Preference</h4>
        <p class="text-neutral-600">AXA Global or April International. Being French companies, consulates are familiar with their policies. Good local networks and French-language support.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Pre-existing Conditions</h4>
        <p class="text-neutral-600">Cigna Global offers broader pre-existing condition coverage. Higher premiums but essential if you have ongoing health needs.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Access to French System</h4>
        <p class="text-neutral-600">CFE (Caisse des Français de l'Étranger) offers a unique option—joining France's social security system as an expat. Good for those wanting French-style coverage immediately.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Wide Travel</h4>
        <p class="text-neutral-600">Allianz Care provides strong EU-wide networks if you plan extensive Schengen travel from your French base.</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Certificate language:</strong> Having your insurance certificate in French (or with French translation) can help with consulate processing. Most international insurers can provide French-language documentation upon request.
      </p>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Paris is expensive by any measure, but France offers excellent value in the provinces. Cities like Lyon, Bordeaux, Toulouse, and smaller towns provide comfortable living at reasonable costs.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€2,800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance + OFII</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Typical Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€4,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With Legal Help</p>
        <p class="text-3xl font-bold text-neutral-900">€6,500</p>
        <p class="text-sm text-neutral-500 mt-2">Full relocation assistance</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost of Living</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Paris:</strong> €3,000-5,000/month (small apartment, comfortable lifestyle)</li>
      <li><strong>Lyon/Bordeaux:</strong> €2,000-3,000/month (good apartment, dining out)</li>
      <li><strong>Provence/Southwest:</strong> €1,800-2,800/month (comfortable, regional lifestyle)</li>
      <li><strong>Smaller cities/towns:</strong> €1,500-2,200/month (very comfortable)</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Paris vs. provinces:</strong> Many retirees dream of Paris but find better value and quality of life in cities like Lyon, Bordeaux, Nice, or smaller towns. Paris can consume €50,000+/year easily; the provinces offer the French lifestyle at half the cost.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The French visa process involves applying at the consulate in your home country, then completing the OFII (Office Français de l'Immigration et de l'Intégration) process after arrival. France loves paperwork—be prepared for a thorough process.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Create France-Visas Account</h4>
          <p class="text-neutral-600">Register on France-Visas.gouv.fr to start your application. Complete the online questionnaire to determine your visa type and required documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect proof of income/savings, criminal background check (FBI for US citizens), proof of accommodation, and passport photos. Some documents need apostilles.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get Sworn Translations</h4>
          <p class="text-neutral-600">Documents not in French must be translated by a traducteur assermenté (sworn translator). The translation is attached to the original document.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get comprehensive health insurance covering France for the visa duration. Request a certificate (attestation d'assurance) clearly showing coverage details.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Schedule VFS/Consulate Appointment</h4>
          <p class="text-neutral-600">Book an appointment through VFS Global or directly with the French consulate (varies by location). Bring all originals and copies.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Attend Appointment</h4>
          <p class="text-neutral-600">Submit your application in person. Biometrics (fingerprints, photo) are collected. Pay the €99 fee. Processing takes 2-8 weeks typically.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter France and Complete OFII</h4>
          <p class="text-neutral-600">After arrival, complete the OFII validation online within 3 months. You'll pay the OFII tax (€200-225) and may need a medical exam. Your visa becomes your first-year residence permit.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>VLS-TS visa:</strong> The visitor visa is a "Visa Long Séjour valant Titre de Séjour" (VLS-TS), meaning it doubles as your first-year residence permit once validated through OFII. No separate residence card needed for year one.
      </p>
    </div>
  </section>

