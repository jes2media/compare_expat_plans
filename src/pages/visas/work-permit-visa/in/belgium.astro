---
/**
 * Belgium Single Permit - Long-form CRO-optimized page
 * Static page for work permit visa in Belgium
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Belgium", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Insurance for Remote Workers", href: "/insurance-for/remote-workers" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
  { title: "Netherlands Kennismigrant", href: "/visas/work-permit-visa/in/netherlands" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Job Offer", details: "From Belgian employer", evidence: "Employment contract" },
  { requirement: "Labor Market Test", details: "Employer proves no EU candidate (exceptions apply)", evidence: "Recruitment documentation" },
  { requirement: "Qualifications", details: "Relevant to the position", evidence: "Degree certificates, experience" },
  { requirement: "Salary (Highly Skilled)", details: "€47,703/year minimum (2026)", evidence: "Stated in contract" },
  { requirement: "Health Insurance", details: "Mutualiteit enrollment mandatory", evidence: "Registration confirmation" },
  { requirement: "Valid Passport", details: "Valid 12+ months beyond stay", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No serious criminal convictions", evidence: "Police certificate (uittreksel strafregister)" },
];

const permitColumns = [
  { key: "category", header: "Category" },
  { key: "salary", header: "Salary Threshold" },
  { key: "laborTest", header: "Labor Market Test" },
  { key: "duration", header: "Duration" },
];

const permitRows = [
  { category: "Highly Skilled Worker", salary: "€47,703/year", laborTest: "Exempted", duration: "Up to 3 years" },
  { category: "EU Blue Card", salary: "€59,460/year", laborTest: "Exempted", duration: "Up to 4 years" },
  { category: "Standard Worker", salary: "No minimum", laborTest: "Required", duration: "1 year (renewable)" },
  { category: "Intra-Company Transfer", salary: "Varies", laborTest: "Exempted", duration: "Up to 3 years" },
  { category: "Researcher", salary: "No minimum", laborTest: "Exempted", duration: "Up to 5 years" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "mutualiteit", header: "Mutualiteit (Mandatory)" },
  { key: "hospitalization", header: "Hospitalization Insurance" },
];

const insuranceRows = [
  { feature: "Enrollment", mutualiteit: "Required within 3 months", hospitalization: "Optional but common" },
  { feature: "Cost", mutualiteit: "€100-150/year membership", hospitalization: "€10-50/month" },
  { feature: "Coverage", mutualiteit: "~75% of healthcare costs", hospitalization: "Hospital room, extras" },
  { feature: "Reimbursement", mutualiteit: "Pay first, claim back", hospitalization: "Direct billing often" },
  { feature: "Family", mutualiteit: "Dependents covered", hospitalization: "Each person pays" },
  { feature: "Required for Visa", mutualiteit: "Yes—proof needed", hospitalization: "No, but recommended" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "CM/MC (Christelijke Mutualiteit)", type: "Mutualiteit", price: "€8-12/month", strengths: "Largest, good service" },
  { provider: "Solidaris/Socialistische Mutualiteit", type: "Mutualiteit", price: "€7-10/month", strengths: "Good coverage, progressive" },
  { provider: "DKV Belgium", type: "Hospitalization", price: "€20-50/month", strengths: "Comprehensive hospital cover" },
  { provider: "AG Insurance", type: "Hospitalization", price: "€15-40/month", strengths: "Often via employer" },
  { provider: "Cigna Global", type: "International", price: "€250-400/month", strengths: "Expats who may relocate" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Single Permit Application", amount: "€172", notes: "Municipal fee" },
  { item: "Residence Card", amount: "€20-50", notes: "Biometric card" },
  { item: "Visa D (if from abroad)", amount: "€180", notes: "Long-stay visa" },
  { item: "Mutualiteit Membership", amount: "€100-150/year", notes: "Mandatory" },
  { item: "Hospitalization Insurance", amount: "€120-600/year", notes: "Optional but recommended" },
  { item: "Document Legalization", amount: "€50-200", notes: "Apostille, translations" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Secure job offer from Belgian employer", duration: "Varies", location: "Job search" },
  { step: "Employer submits Single Permit application", duration: "1 day", location: "Regional authority" },
  { step: "Regional processing (work authorization)", duration: "4-8 weeks", location: "Brussels/Flanders/Wallonia" },
  { step: "Immigration processing (residence)", duration: "2-4 weeks", location: "Immigration Office" },
  { step: "Apply for Visa D (if abroad)", duration: "2-4 weeks", location: "Belgian embassy" },
  { step: "Travel to Belgium, register at commune", duration: "8 days", location: "Gemeente/Commune" },
  { step: "Join mutualiteit", duration: "Within 3 months", location: "Mutualiteit office" },
  { step: "Receive residence card", duration: "2-4 weeks", location: "Commune" },
];
---

<PageShell
  title="Belgium Work Permit 2026: Single Permit, Mutualiteit Insurance & Application Guide"
  description="Complete guide to Belgium work permits. Single Permit requirements, mandatory mutualiteit health insurance, EU Blue Card option, salary thresholds, and step-by-step application for working in Belgium."
  headline="Belgium Work Permit: Insurance & Requirements Guide"
  subheadline="Everything about working in Belgium—the Single Permit system, mandatory mutualiteit enrollment, EU institution opportunities, and the complete application process for Brussels, Flanders, and Wallonia."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Health Insurance"
  ctaButtonHref="/best/expat-health-insurance"
  heroBackgroundImage="/images/countries/belgium-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Belgian Immigration Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Mutualiteit Insurance Mandatory
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Belgium's Single Permit (gecombineerde vergunning / permis unique) combines work and residence authorization into one application. As the de facto capital of the EU, Belgium attracts international workers to its EU institutions, NATO headquarters, and multinational corporations. Brussels is one of Europe's most international cities, with over 180 nationalities.
    </p>

    <p class="mb-4">
      Health insurance in Belgium works through mutualiteiten (Dutch) or mutuelles (French)—non-profit health insurance funds that everyone must join. Unlike private insurance, mutualiteiten reimburse about 75% of healthcare costs under the national RIZIV/INAMI system. Most Belgians and expats also add hospitalization insurance for private rooms and extras. The system is straightforward once you understand the reimbursement model.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Belgium Single Permit</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Permit type:</strong> Single Permit (gecombineerde vergunning)</li>
        <li>• <strong>Highly skilled threshold:</strong> €47,703/year (no labor market test)</li>
        <li>• <strong>EU Blue Card threshold:</strong> €59,460/year</li>
        <li>• <strong>Health insurance:</strong> Mutualiteit mandatory within 3 months</li>
        <li>• <strong>Duration:</strong> Up to 3 years (renewable)</li>
        <li>• <strong>Permanent residence:</strong> After 5 years legal residence</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Work in Belgium?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>EU capital:</strong> European Commission, Parliament, NATO, 1,000+ international organizations</li>
      <li><strong>Central location:</strong> Paris 1.5 hours, London 2 hours, Amsterdam 2 hours by train</li>
      <li><strong>Multilingual:</strong> French, Dutch, English widely spoken in Brussels</li>
      <li><strong>Tax benefits:</strong> Special expat tax regime (30% exclusion) for qualifying roles</li>
      <li><strong>Quality healthcare:</strong> Excellent Belgian healthcare system</li>
      <li><strong>International schools:</strong> Many options for expat families</li>
      <li><strong>Work-life balance:</strong> 20 vacation days minimum, strong labor protections</li>
      <li><strong>Cultural richness:</strong> Historic cities, cuisine, art, central European access</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Belgium is Right If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You work in EU institutions or international organizations</li>
          <li>✓ Your salary exceeds €47,703 (highly skilled exemption)</li>
          <li>✓ You want central European location</li>
          <li>✓ You value multilingual environment</li>
          <li>✓ You qualify for expat tax regime</li>
          <li>✓ You work in pharma, tech, or finance</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You don't meet highly skilled salary threshold</li>
          <li>• You want faster processing (Belgium can be slow)</li>
          <li>• You prefer English-only environment outside Brussels</li>
          <li>• High taxes concern you (without expat regime)</li>
          <li>• You want simpler healthcare system</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Expat tax regime:</strong> Belgium offers a special tax status for qualifying expats—30% of salary can be excluded from taxation as "cost allowance." This significantly reduces your tax burden. Requires employer application within 6 months of arrival. Not available for Belgian nationals or those who lived in Belgium before.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Belgium's Single Permit combines work authorization and residence into one application. The process involves both regional authorities (for work) and federal immigration (for residence). Processing is handled by the region where you'll work: Brussels, Flanders, or Wallonia.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Permit Categories</h3>

    <p class="mb-4">
      Belgium has different categories with varying requirements. Highly skilled workers and EU Blue Card holders are exempt from labor market testing.
    </p>

    <ComparisonTable columns={permitColumns} rows={permitRows} />

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6 mb-6">
      <p class="text-green-800">
        <strong>Highly skilled exemption:</strong> If your gross annual salary is at least €47,703 (2026), you're exempt from labor market testing. This is the most common route for international professionals. Your employer doesn't need to prove no Belgian/EU candidate is available.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Regional Differences</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Brussels-Capital Region</h4>
        <p class="text-neutral-600">Most international employers. Bilingual (French/Dutch). Processing through Brussels Economy and Employment. Generally good English acceptance. EU institutions concentrated here.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Flanders (Flemish Region)</h4>
        <p class="text-neutral-600">Dutch-speaking. Antwerp, Ghent, Leuven. Processing through Vlaams Departement Werk. Tech and pharma hubs (Ghent, Leuven). Generally efficient processing.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Wallonia (Walloon Region)</h4>
        <p class="text-neutral-600">French-speaking. Liège, Charleroi, Namur. Processing through SPW Emploi. Smaller international community. Often faster processing due to lower volume.</p>
      </div>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-amber-900 mb-2">Mutualiteit Membership is Mandatory</h3>
      <p class="text-amber-800">
        Within 3 months of starting work in Belgium, you must join a mutualiteit (health insurance fund). This isn't private insurance—it's the Belgian social security healthcare system. Your employer registers you with ONSS/RSZ (social security), and you choose which mutualiteit to join. Coverage is about 75% of costs; you pay the remainder out-of-pocket or with supplementary insurance.
      </p>
    </div>

    <p class="mb-4">
      Belgium's healthcare system works on a reimbursement model through mutualiteiten. You pay for care upfront, then claim back approximately 75% from your mutualiteit. The remaining 25% (remgeld/ticket modérateur) comes from your pocket or hospitalization insurance. This is different from countries where insurance pays directly.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Mutualiteit vs. Hospitalization Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">How the Reimbursement System Works</h3>

    <div class="bg-neutral-50 rounded-lg p-6 mb-6">
      <ol class="list-decimal pl-6 space-y-3">
        <li><strong>Visit doctor:</strong> Pay full fee (e.g., €30 for GP)</li>
        <li><strong>Get attestation:</strong> Doctor gives you a paper (getuigschrift/attestation)</li>
        <li><strong>Submit to mutualiteit:</strong> Online, by app, or in person</li>
        <li><strong>Receive reimbursement:</strong> ~75% back to your account (e.g., €22.50)</li>
        <li><strong>Your cost:</strong> The remaining ~25% (e.g., €7.50)</li>
      </ol>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Choosing a Mutualiteit</h3>

    <p class="mb-4">
      All mutualiteiten provide the same basic RIZIV/INAMI reimbursements—the difference is in supplementary benefits and service. Major ones include:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Dutch-Speaking (Flanders/Brussels)</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>CM (Christelijke Mutualiteit):</strong> Largest, good service</li>
          <li>• <strong>Solidaris:</strong> Progressive, good extras</li>
          <li>• <strong>Liberale Mutualiteit:</strong> Liberal-oriented</li>
          <li>• <strong>Onafhankelijke Ziekenfondsen:</strong> Neutral</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">French-Speaking (Wallonia/Brussels)</h4>
        <ul class="space-y-2 text-neutral-600">
          <li>• <strong>MC (Mutualité Chrétienne):</strong> Largest, extensive network</li>
          <li>• <strong>Solidaris:</strong> Socialist-oriented</li>
          <li>• <strong>Mutualités Libérales:</strong> Liberal-oriented</li>
          <li>• <strong>Mutualités Libres:</strong> Neutral</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Hospitalization insurance:</strong> Most Belgians and expats add hospitalization insurance (hospitalisatieverzekering) on top of the mutualiteit. This covers private hospital rooms, extra comfort, and reduces out-of-pocket costs during hospital stays. Many employers provide this as a benefit. If not, expect €15-50/month depending on coverage.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need additional coverage beyond mutualiteit?"
    description="Compare hospitalization and international insurance options."
    buttonText="Compare Health Insurance Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Everyone needs a mutualiteit (mandatory). Hospitalization insurance is optional but common. International insurance is only needed if you travel frequently or may relocate.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Most Expats: CM/MC + Employer Hospitalization</h4>
        <p class="text-neutral-600">Join CM (Dutch) or MC (French)—they're the largest with best service and English support in Brussels. If your employer offers hospitalization insurance (common), that's sufficient. Total cost: ~€10/month mutualiteit + employer-provided hospitalization.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">No Employer Hospitalization: Add DKV or AG</h4>
        <p class="text-neutral-600">If your employer doesn't provide hospitalization insurance, add it yourself. DKV Belgium and AG Insurance are main providers. €20-50/month covers private rooms and reduces hospital costs significantly.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">May Leave Belgium: Cigna Global Supplement</h4>
        <p class="text-neutral-600">If you might relocate, international insurance offers portability. Note: you still need mutualiteit for Belgian residence. International coverage supplements or replaces when you leave Belgium.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU Institution Workers: Check JSIS</h4>
        <p class="text-neutral-600">EU institution employees have their own system (JSIS/RCAM). You may not need Belgian mutualiteit. Verify your institution's coverage—it's often comprehensive and replaces national systems.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Belgium has moderate visa fees and low mandatory health insurance costs (mutualiteit is cheap). The main healthcare expense is hospitalization insurance if your employer doesn't provide it.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Annual Healthcare Costs</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Mutualiteit Only</p>
        <p class="text-3xl font-bold text-neutral-900">€100-150/year</p>
        <p class="text-sm text-neutral-500 mt-2">Mandatory, basic coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">+ Hospitalization</p>
        <p class="text-3xl font-bold text-neutral-900">€300-600/year</p>
        <p class="text-sm text-neutral-500 mt-2">Adding hospital insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Employer-Provided</p>
        <p class="text-3xl font-bold text-neutral-900">€100-150/year</p>
        <p class="text-sm text-neutral-500 mt-2">If employer covers hospitalization</p>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Compared to neighbors:</strong> Belgium's mandatory healthcare cost is much lower than Switzerland (CHF 300-600/month) or Netherlands (€120-150/month for basisverzekering). The mutualiteit system is affordable, though out-of-pocket costs add up without hospitalization insurance.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Single Permit application is employer-initiated. Your employer submits to the regional authority (Brussels, Flanders, or Wallonia), who handles work authorization. Then federal immigration approves residence. If you're outside Belgium, you also need a Visa D from the embassy.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Secure Job Offer from Belgian Employer</h4>
          <p class="text-neutral-600">Find a job with a Belgian company. For highly skilled exemption, ensure salary is €47,703+ (gross annual). Get a signed employment contract specifying role, salary, and start date.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Employer Submits Single Permit Application</h4>
          <p class="text-neutral-600">Your employer submits to the regional authority where you'll work. Documents include contract, qualifications, passport copy, and criminal record. For non-highly-skilled roles, labor market test documentation is required.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Regional Processing (Work Authorization)</h4>
          <p class="text-neutral-600">The regional authority reviews the application. Takes 4-8 weeks typically. They verify salary, qualifications, and (if applicable) labor market test. Highly skilled applications are usually straightforward.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Federal Processing (Residence Authorization)</h4>
          <p class="text-neutral-600">After regional approval, the file goes to federal Immigration Office (Dienst Vreemdelingenzaken/Office des Étrangers). They approve residence. Takes 2-4 weeks additional. You're notified of final approval.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Visa D (If Outside Belgium)</h4>
          <p class="text-neutral-600">Once approved, apply for Visa D at the Belgian embassy in your country. Bring approval letter, passport, photos. Processing takes 2-4 weeks. Some nationalities can enter visa-free and apply for residence directly.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Register at the Commune</h4>
          <p class="text-neutral-600">Within 8 days of arrival, register at your local gemeente/commune. Bring rental contract, passport, visa. A police officer may visit to verify your address. You'll receive a temporary registration (Annexe 15).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Join a Mutualiteit</h4>
          <p class="text-neutral-600">Within 3 months, join a mutualiteit. Your employer will have registered you with ONSS/RSZ (social security). Choose CM, Solidaris, or another. Register online or at their office. You'll receive your mutualiteit card.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">8</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Residence Card</h4>
          <p class="text-neutral-600">After address verification, you'll be called to collect your electronic residence card (A-kaart for Single Permit). This is your proof of legal residence and work rights. Valid for permit duration (up to 3 years).</p>
        </div>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Processing delays:</strong> Belgium's immigration processing can be slow, especially in Brussels due to high volume. Plan for 3-4 months total from application to starting work. Highly skilled applications are prioritized but still take time. Start the process early.
      </p>
    </div>
  </section>

