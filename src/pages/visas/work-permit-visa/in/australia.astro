---
/**
 * Australia Temporary Skill Shortage (TSS 482) Visa - Long-form CRO-optimized page
 * Static page for work permit visa in Australia
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Australia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Australia Health Insurance Guide", href: "/countries/australia/insurance" },
  { title: "Insurance for Remote Workers", href: "/insurance-for/remote-workers" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const streamColumns = [
  { key: "feature", header: "Feature" },
  { key: "shortTerm", header: "Short-term Stream" },
  { key: "mediumTerm", header: "Medium-term Stream" },
  { key: "labour", header: "Labour Agreement" },
];

const streamRows = [
  { feature: "Duration", shortTerm: "Up to 2 years", mediumTerm: "Up to 4 years", labour: "Up to 4 years" },
  { feature: "Occupation list", shortTerm: "STSOL (Short-term)", mediumTerm: "MLTSSL (Medium/Long)", labour: "Per agreement" },
  { feature: "PR pathway", shortTerm: "No", mediumTerm: "Yes (ENS 186)", labour: "Varies" },
  { feature: "Renewals", shortTerm: "Once (onshore)", mediumTerm: "Unlimited", labour: "Per agreement" },
  { feature: "Common roles", shortTerm: "Marketing, HR, Chefs", mediumTerm: "Engineers, IT, Medical", labour: "Regional, trade-specific" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Sponsorship", details: "Approved Australian employer sponsor", evidence: "Nomination from sponsor" },
  { requirement: "Occupation", details: "On relevant skilled occupation list", evidence: "Skills assessment (some occupations)" },
  { requirement: "Experience", details: "At least 2 years relevant experience", evidence: "Employment references, payslips" },
  { requirement: "English Language", details: "IELTS 5.0 overall (5.0 each band) minimum", evidence: "IELTS, PTE, TOEFL, OET score" },
  { requirement: "Health Insurance", details: "Adequate health cover for visa duration", evidence: "Insurance policy confirmation" },
  { requirement: "Salary Threshold", details: "AUD $73,150/year (TSMIT) from July 2024", evidence: "Employment contract" },
  { requirement: "Health & Character", details: "Medical exam, police checks", evidence: "Health exam, police certificates" },
];

const insuranceColumns = [
  { key: "feature", header: "Feature" },
  { key: "medicare", header: "Medicare (RHCA countries)" },
  { key: "private", header: "Private Health Insurance" },
];

const insuranceRows = [
  { feature: "Eligibility", medicare: "UK, Ireland, NZ, Belgium, Netherlands, etc.", private: "All TSS 482 holders" },
  { feature: "Cost", medicare: "Free (tax-funded)", private: "AUD $150-400/month" },
  { feature: "GP visits", medicare: "Free or subsidized", private: "Often included, faster access" },
  { feature: "Hospital", medicare: "Public hospitals free", private: "Private hospital choice" },
  { feature: "Waiting times", medicare: "Public system waits", private: "Typically shorter" },
  { feature: "Visa requirement", medicare: "Supplements but doesn't replace", private: "Required for visa" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "type", header: "Type" },
  { key: "price", header: "Monthly Cost (AUD)" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Bupa Australia", type: "Australian Private", price: "$180-350", strengths: "Largest network, visa-compliant" },
  { provider: "Medibank", type: "Australian Private", price: "$170-320", strengths: "Strong hospital cover" },
  { provider: "NIB", type: "Australian Private", price: "$150-280", strengths: "Budget-friendly, good extras" },
  { provider: "Cigna Global", type: "International", price: "$250-450", strengths: "Global coverage, portable" },
  { provider: "Allianz Care", type: "International", price: "$220-400", strengths: "Worldwide cover, flexible" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (AUD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$1,455-2,645", notes: "Short-term $1,455, Medium-term $2,645" },
  { item: "Nomination Fee", amount: "$330", notes: "Paid by employer" },
  { item: "Skilling Australians Fund", amount: "$1,200-1,800/year", notes: "Paid by employer (small/large business)" },
  { item: "Health Exam", amount: "$300-500", notes: "Panel doctor examination" },
  { item: "Police Checks", amount: "$50-150", notes: "Per country lived in" },
  { item: "Skills Assessment", amount: "$300-1,000", notes: "Required for some occupations" },
  { item: "English Test", amount: "$350-400", notes: "IELTS, PTE, or equivalent" },
  { item: "Health Insurance", amount: "$1,800-4,200/year", notes: "Mandatory for visa duration" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "responsibility", header: "Who" },
];

const timelineRows = [
  { step: "Employer becomes approved sponsor", duration: "4-6 weeks", responsibility: "Employer" },
  { step: "Employer lodges nomination", duration: "1-4 months", responsibility: "Employer" },
  { step: "Skills assessment (if required)", duration: "4-12 weeks", responsibility: "You" },
  { step: "Health exam and police checks", duration: "2-4 weeks", responsibility: "You" },
  { step: "Lodge visa application", duration: "1-2 hours", responsibility: "You" },
  { step: "Visa processing", duration: "2-6 months", responsibility: "Home Affairs" },
  { step: "Visa grant notification", duration: "Via email", responsibility: "Home Affairs" },
  { step: "Travel to Australia", duration: "Within validity", responsibility: "You" },
];
---

<PageShell
  title="Australia TSS 482 Visa 2026: Requirements, Insurance & Application Guide"
  description="Complete guide to Australia's Temporary Skill Shortage (TSS 482) visa. Occupation lists, salary thresholds, mandatory health insurance, and step-by-step application process for skilled workers."
  headline="Australia TSS 482 Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working in Australia—visa streams, the $73,150 salary threshold, mandatory health insurance, and the complete application process for skilled workers."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Health Insurance"
  ctaButtonHref="/go/cigna-global"
  heroBackgroundImage="/images/countries/australia-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated February 2026
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Home Affairs Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Health Insurance Mandatory
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The Temporary Skill Shortage (TSS) visa (subclass 482) is Australia's primary employer-sponsored work visa. It allows Australian employers to address labor shortages by sponsoring skilled overseas workers for up to 4 years. The medium-term stream offers a pathway to permanent residence through the Employer Nomination Scheme (ENS 186).
    </p>

    <p class="mb-4">
      Unlike some countries, Australia requires private health insurance for TSS 482 holders throughout their stay—even if they're from countries with Reciprocal Health Care Agreements (RHCA). Understanding insurance options is essential, as inadequate coverage can affect your visa status.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Australia TSS 482 Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Temporary Skill Shortage (subclass 482)</li>
        <li>• <strong>Streams:</strong> Short-term (2 years), Medium-term (4 years), Labour Agreement</li>
        <li>• <strong>Salary threshold:</strong> AUD $73,150/year (TSMIT from July 2024)</li>
        <li>• <strong>Health insurance:</strong> Mandatory private health insurance</li>
        <li>• <strong>PR pathway:</strong> Medium-term stream leads to ENS 186</li>
        <li>• <strong>Work rights:</strong> Full-time for sponsoring employer</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Work in Australia?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>High salaries:</strong> Competitive wages, especially in mining, tech, healthcare</li>
      <li><strong>Quality of life:</strong> Great weather, outdoor lifestyle, safe cities</li>
      <li><strong>PR pathway:</strong> Medium-term stream leads to permanent residence</li>
      <li><strong>English speaking:</strong> No language barrier</li>
      <li><strong>Strong economy:</strong> Low unemployment, growing sectors</li>
      <li><strong>Work-life balance:</strong> 4 weeks annual leave, good working conditions</li>
      <li><strong>Family friendly:</strong> Dependents can work and study</li>
      <li><strong>Healthcare quality:</strong> Excellent medical facilities</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">TSS 482 is Right If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ Your occupation is on the skilled occupation list</li>
          <li>✓ You have 2+ years relevant experience</li>
          <li>✓ Salary meets $73,150 threshold</li>
          <li>✓ You want a PR pathway (medium-term)</li>
          <li>✓ You can arrange employer sponsorship</li>
          <li>✓ You meet English requirements</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Your occupation isn't on the list</li>
          <li>• Less than 2 years experience</li>
          <li>• No employer willing to sponsor</li>
          <li>• Salary below $73,150 threshold</li>
          <li>• You prefer independent PR pathway (consider 189/190)</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Understanding the Streams</h3>

    <ComparisonTable columns={streamColumns} rows={streamRows} />

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>PR pathway tip:</strong> If you want permanent residence, ensure your occupation is on the Medium and Long-term Strategic Skills List (MLTSSL). Short-term stream occupations (STSOL) don't lead to PR via the employer nomination route.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The TSS 482 visa requires employer sponsorship, relevant experience, English proficiency, and health insurance. Your occupation must appear on Australia's skilled occupation lists, and some occupations require a formal skills assessment.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Salary Threshold (TSMIT)</h3>

    <p class="mb-4">
      The Temporary Skilled Migration Income Threshold (TSMIT) increased to AUD $73,150/year in July 2024. This is a significant increase from the previous $70,000 threshold. Your salary must meet or exceed this amount.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Market salary rate:</strong> Beyond TSMIT, your salary must also meet the annual market salary rate—what an Australian would be paid for the same role. If the market rate is higher than $73,150, you must be paid the market rate.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Skills Assessments</h3>

    <p class="mb-4">
      Some occupations require a skills assessment from a relevant assessing authority. This verifies your qualifications and experience match Australian standards.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>IT professionals:</strong> ACS (Australian Computer Society)</li>
      <li><strong>Engineers:</strong> Engineers Australia</li>
      <li><strong>Accountants:</strong> CPA, CA ANZ, or IPA</li>
      <li><strong>Medical professionals:</strong> AHPRA, relevant medical boards</li>
      <li><strong>Trades:</strong> TRA (Trades Recognition Australia)</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Check requirements early:</strong> Skills assessments can take 4-12 weeks. Start the process as soon as you have a job offer. Some assessments require additional qualifications or bridging courses, which add months.
      </p>
    </div>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-amber-900 mb-2">Health Insurance is Mandatory for TSS 482</h3>
      <p class="text-amber-800">
        All TSS 482 visa holders must maintain "adequate health insurance" for the duration of their stay. This is a visa condition—letting insurance lapse can affect your visa status. Private health insurance from an Australian provider is required.
      </p>
    </div>

    <p class="mb-4">
      Australia has a two-tier healthcare system: Medicare (public) and private health insurance. While some TSS 482 holders from RHCA countries can access Medicare, this doesn't satisfy the visa's insurance requirement—you still need private cover.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Medicare vs. Private Insurance</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Reciprocal Health Care Agreement Countries</h3>

    <p class="mb-4">
      Citizens of these countries can access Medicare for essential medical treatment, but still need private insurance for the visa:
    </p>

    <div class="grid md:grid-cols-3 gap-4 mb-6">
      <div class="bg-green-50 p-4 rounded-lg">
        <h4 class="font-semibold text-green-900 mb-2">Full Coverage</h4>
        <ul class="text-green-800 text-sm space-y-1">
          <li>• United Kingdom</li>
          <li>• Ireland</li>
          <li>• New Zealand</li>
          <li>• Belgium</li>
          <li>• Netherlands</li>
          <li>• Sweden</li>
          <li>• Finland</li>
          <li>• Norway</li>
          <li>• Malta</li>
          <li>• Slovenia</li>
          <li>• Italy</li>
        </ul>
      </div>

      <div class="bg-amber-50 p-4 rounded-lg">
        <h4 class="font-semibold text-amber-900 mb-2">Limited Coverage</h4>
        <ul class="text-amber-800 text-sm space-y-1">
          <li>• RHCA covers "immediately necessary" treatment only</li>
          <li>• Doesn't cover elective procedures</li>
          <li>• Doesn't cover private hospitals</li>
          <li>• Doesn't satisfy visa requirements</li>
        </ul>
      </div>

      <div class="bg-blue-50 p-4 rounded-lg">
        <h4 class="font-semibold text-blue-900 mb-2">No RHCA</h4>
        <ul class="text-blue-800 text-sm space-y-1">
          <li>• USA, Canada</li>
          <li>• Most of Asia</li>
          <li>• Most of Europe</li>
          <li>• South America</li>
          <li>• Africa</li>
          <li>Must rely entirely on private insurance</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">What "Adequate Health Insurance" Means</h3>

    <p class="mb-4">
      The Department of Home Affairs doesn't specify exact requirements, but your policy should cover:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Hospital treatment:</strong> Public and/or private hospital admission</li>
      <li><strong>Medical services:</strong> GP visits, specialists, surgery</li>
      <li><strong>Emergency care:</strong> Ambulance and emergency treatment</li>
      <li><strong>Duration:</strong> Cover for your entire visa validity</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>OSHC not accepted:</strong> Overseas Student Health Cover (OSHC) is for students only. TSS 482 holders need standard private health insurance or overseas visitors health cover (OVHC) designed for working visa holders.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox
    variant="highlight"
    title="Need health insurance for your TSS 482 visa?"
    description="Compare plans from Australian and international providers."
    buttonText="Compare Health Insurance Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      TSS 482 holders need private health insurance that meets visa requirements. Australian providers offer OVHC (Overseas Visitors Health Cover) specifically designed for working visa holders.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Visa Compliance Priority: Bupa Australia OVHC</h4>
        <p class="text-neutral-600">Bupa's Overseas Visitors Health Cover (OVHC) is specifically designed for TSS 482 holders. It's widely accepted for visa purposes and includes hospital, medical, and emergency ambulance cover. The largest private health insurance network in Australia.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious: NIB OVHC</h4>
        <p class="text-neutral-600">NIB offers competitive OVHC rates with solid coverage. Good choice if you're healthy and want to minimize costs while meeting visa requirements. Their extras cover (dental, optical) is competitively priced.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">International Portability: Cigna Global</h4>
        <p class="text-neutral-600">If you might not stay in Australia long-term, or travel frequently, international insurance offers portability. Cigna Global covers you worldwide, so you keep the same policy if you relocate. Note: verify it meets Australian visa requirements.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Family Coverage: Medibank</h4>
        <p class="text-neutral-600">Medibank offers strong family OVHC packages covering spouses and children. Good maternity coverage (after waiting periods) and pediatric care. Dependents on 482 visas also need health insurance.</p>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Waiting periods:</strong> Most Australian private health insurance has waiting periods—2 months for general treatment, 12 months for pre-existing conditions and pregnancy. Factor this into your planning, especially if you have known healthcare needs.
      </p>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The TSS 482 visa has significant costs, split between you and your employer. The visa application fee varies by stream, and health insurance is an ongoing cost throughout your stay.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Total Costs by Stream</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Short-term Stream (2 years)</p>
        <p class="text-3xl font-bold text-neutral-900">AUD $5,500-8,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + 2 years insurance + assessments</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Medium-term Stream (4 years)</p>
        <p class="text-3xl font-bold text-neutral-900">AUD $10,000-15,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + 4 years insurance + assessments</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Employer vs. Employee Costs</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Employer Typically Pays</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Nomination fee: $330</li>
          <li>• Skilling Australians Fund: $1,200-1,800/year</li>
          <li>• Sometimes: Visa application fee</li>
          <li>• Sometimes: Relocation costs</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">You Typically Pay</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Visa application: $1,455-2,645</li>
          <li>• Health insurance: $1,800-4,200/year</li>
          <li>• Skills assessment: $300-1,000</li>
          <li>• Health exam: $300-500</li>
          <li>• Police checks: $50-150 per country</li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Negotiate costs:</strong> Some employers will cover all visa-related costs as part of relocation packages, especially for in-demand skills like IT and engineering. Ask during negotiations—this can save you $5,000-10,000.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The TSS 482 process involves three stages: employer sponsorship approval, occupation nomination, and visa application. The employer handles the first two steps; you handle the visa application.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Secure Job Offer from Approved Sponsor</h4>
          <p class="text-neutral-600">Find an employer who's either already an approved sponsor or willing to become one. The job must be on the relevant skilled occupation list and pay at least $73,150. Get a written job offer with salary details.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Employer Applies for Sponsorship (if needed)</h4>
          <p class="text-neutral-600">If not already approved, your employer applies to become a Standard Business Sponsor. This takes 4-6 weeks. Large companies are often already approved; check the sponsor register.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Employer Lodges Nomination</h4>
          <p class="text-neutral-600">Your employer nominates the specific position for you. This includes job details, salary, location, and evidence the position is genuine. Processing takes 1-4 months depending on case complexity.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete Skills Assessment (if required)</h4>
          <p class="text-neutral-600">Some occupations require skills assessment from a relevant body (ACS for IT, Engineers Australia for engineering, etc.). Start this early—it can take 4-12 weeks and may require additional documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrange Health Insurance</h4>
          <p class="text-neutral-600">Get quotes from Australian OVHC providers (Bupa, Medibank, NIB). Purchase a policy that starts from your planned arrival date and covers your full visa period. Keep the policy certificate for your application.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete Health Exam and Police Checks</h4>
          <p class="text-neutral-600">Attend a medical examination with a panel-approved doctor. Obtain police certificates from every country you've lived in for 12+ months in the past 10 years. These are valid for 12 months.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">7</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Lodge Visa Application</h4>
          <p class="text-neutral-600">Apply online through ImmiAccount. Include nomination TRN, skills assessment, health insurance certificate, English test results, and all supporting documents. Pay the visa application fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">8</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Grant and Travel</h4>
          <p class="text-neutral-600">Processing takes 2-6 months. You can apply from outside Australia (recommended) or onshore on a valid visa. Once granted, you'll receive a visa grant notification email. Travel within the validity period.</p>
        </div>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Processing times vary:</strong> Current processing times range from 50 days to 6+ months depending on occupation and completeness of application. Submit a complete application with all documents to avoid delays from additional information requests.
      </p>
    </div>
  </section>

