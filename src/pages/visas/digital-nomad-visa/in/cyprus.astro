---
/**
 * Cyprus Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Cyprus", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Cyprus Health Insurance Guide", href: "/countries/cyprus/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€3,500/month (non-EU citizens)", evidence: "Bank statements, employment contracts" },
  { requirement: "Remote Work", details: "Work for company outside Cyprus", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "Private health insurance mandatory", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "Valid for visa duration", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal convictions", evidence: "Criminal record certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Cyprus Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive coverage", why: "Cyprus requires private insurance" },
  { feature: "Coverage Territory", minimum: "Valid in Cyprus", why: "Must cover your stay" },
  { feature: "Duration", minimum: "Full visa period", why: "No gaps permitted" },
  { feature: "Inpatient/Outpatient", minimum: "Both required", why: "Full medical access" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "Nearest major hospital in Israel/Greece" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive global" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-280", strengths: "EU-focused" },
  { provider: "BUPA Global", coverage: "€2,000,000+", price: "€280-450", strengths: "Premium service" },
  { provider: "Local Cypriot", coverage: "Varies", price: "€50-120", strengths: "Cyprus-focused" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€70", notes: "Non-refundable" },
  { item: "Residence Permit", amount: "€70-140", notes: "Annual permit" },
  { item: "Health Insurance (Annual)", amount: "€600-3,000", notes: "Private coverage required" },
  { item: "Document Apostille", amount: "€30-80", notes: "If required" },
  { item: "Translation Services", amount: "€50-100", notes: "For non-English documents" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-3 weeks", location: "Home country" },
  { step: "Submit application", duration: "1 day", location: "Online or Civil Registry" },
  { step: "Processing", duration: "1-4 weeks", location: "Civil Registry Department" },
  { step: "Receive decision", duration: "Via email", location: "Digital notification" },
  { step: "Collect permit", duration: "Within 2 weeks", location: "Immigration office" },
  { step: "Enter/remain in Cyprus", duration: "Immediately", location: "Cyprus" },
];
---

<PageShell
  title="Cyprus Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Cyprus Digital Nomad Visa. €3,500/month income requirement, year-round sunshine, English widely spoken, and pathway to 3 years of EU residence."
  headline="Cyprus Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the Mediterranean's sunniest EU island—insurance requirements, non-dom tax benefits, and island lifestyle."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Civil Registry Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU Member State
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Cyprus launched its Digital Nomad Visa in 2021, becoming one of the first EU countries to welcome remote workers with a dedicated program. The island offers 340 days of sunshine per year, English as a widely spoken language, and attractive non-dom tax status for those who qualify.
    </p>

    <p class="mb-4">
      As an EU member but not in the Schengen Area, Cyprus has its own visa rules. The DNV allows up to 3 years of residence (1 year initially, renewable twice), making it one of the longer-term options available. The €3,500/month income requirement is substantial but in line with other EU programs.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Cyprus Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year (renewable for up to 3 years total)</li>
        <li>• <strong>Income requirement:</strong> €3,500/month (+20% for spouse, +15% per child)</li>
        <li>• <strong>Processing time:</strong> 1-4 weeks (one of the fastest)</li>
        <li>• <strong>Insurance:</strong> Private health insurance mandatory</li>
        <li>• <strong>Tax benefit:</strong> Non-dom status can eliminate tax on foreign income for 17 years</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Cyprus for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Year-round sunshine:</strong> 340+ sunny days per year, Mediterranean climate</li>
      <li><strong>English widely spoken:</strong> Former British colony, English is official language</li>
      <li><strong>Non-dom tax benefits:</strong> No tax on foreign dividends and interest for 17 years</li>
      <li><strong>3-year potential:</strong> One of the longer DNV durations in Europe</li>
      <li><strong>EU membership:</strong> Access to EU banking, services, and stability</li>
      <li><strong>Safety:</strong> Extremely low crime rate, family-friendly environment</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Cyprus is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €3,500+/month from remote work</li>
          <li>✓ You want year-round warm weather</li>
          <li>✓ You prefer English-speaking environment</li>
          <li>✓ You're interested in non-dom tax benefits</li>
          <li>✓ You want up to 3 years of EU residence</li>
          <li>✓ You enjoy beach and outdoor lifestyle</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need Schengen Area access (Cyprus isn't in Schengen)</li>
          <li>• You prefer larger nomad communities</li>
          <li>• You want very low cost of living</li>
          <li>• You prefer cooler climates</li>
          <li>• You want path to permanent EU residency</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Cyprus offers the Digital Nomad Visa to non-EU citizens who work remotely for companies outside Cyprus. EU citizens don't need this visa but can still benefit from Cyprus's attractive tax regime.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate €3,500/month net income after taxes. For families, add 20% for a spouse and 15% per dependent child. Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 6 months showing consistent income</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>For freelancers:</strong> Client contracts, invoices, and proof of payment</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Family Addition:</strong> €3,500 base + €700 for spouse + €525 per child. A family of four would need approximately €5,250/month.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (valid for visa duration)</li>
      <li>Completed visa application form</li>
      <li>Passport photos</li>
      <li>Proof of income (€3,500/month net)</li>
      <li>Private health insurance certificate</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Criminal record certificate from country of residence</li>
      <li>Proof of accommodation in Cyprus (rental agreement or ownership)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Private Insurance Required</h3>
      <p class="text-blue-800">
        Cyprus requires private health insurance for Digital Nomad Visa holders. You cannot rely on the public GESY system initially. International or Cypriot private insurance is accepted.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Cyprus's Digital Nomad Visa. While Cyprus has universal healthcare (GESY), DNV holders must maintain private coverage.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Cyprus Healthcare Context</h3>

    <p class="mb-4">
      Cyprus introduced universal healthcare (GESY) in 2019. However, Digital Nomad Visa holders are not automatically enrolled and must use private healthcare and insurance.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (GESY)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Not for DNV holders initially</li>
          <li>• <strong>Quality:</strong> Good, improving since 2019</li>
          <li>• <strong>Contribution:</strong> 2.75% of income if enrolled</li>
          <li>• <strong>Language:</strong> Greek primarily, English available</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With private insurance</li>
          <li>• <strong>Quality:</strong> Excellent in major cities</li>
          <li>• <strong>Facilities:</strong> Apollonion, Aretaeio, Ygia Polyclinic</li>
          <li>• <strong>Language:</strong> English widely available</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need private health insurance for Cyprus's Digital Nomad Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer coverage suitable for Cyprus's Digital Nomad Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €45-85/month. Meets requirements affordably for solo nomads.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Coverage</h4>
        <p class="text-neutral-600">Allianz Care. Strong European network, portable for travel to EU countries.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global or BUPA Global. Full worldwide coverage for frequent travelers.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Cyprus Residents</h4>
        <p class="text-neutral-600">Local Cypriot insurers. Cheaper for those planning to stay all 3 years.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Cyprus has moderate visa fees. The cost of living is higher than Eastern Europe but lower than Western Europe.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€3,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Cyprus is moderately expensive by European standards. Limassol is the priciest city; Paphos and Larnaca are more affordable.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> €1,500-2,000/month (shared housing, cooking at home)</li>
      <li><strong>Comfortable:</strong> €2,500-3,500/month (own apartment, dining out)</li>
      <li><strong>Premium:</strong> €4,000+/month (sea view, car, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Cyprus has one of the fastest Digital Nomad Visa processing times—often just 1-4 weeks. Applications can be submitted online or in person at the Civil Registry and Migration Department.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documentation</h4>
          <p class="text-neutral-600">Gather income proof (6 months), insurance certificate, passport, criminal record, and accommodation proof. Translations in English or Greek are accepted.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Apply online through the Civil Registry portal or in person at their offices. Pay €70 application fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing is fast—typically 1-4 weeks. Cyprus has streamlined the process for digital nomads.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Decision</h4>
          <p class="text-neutral-600">Approval notification comes via email. If approved, schedule appointment to collect permit.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect Permit</h4>
          <p class="text-neutral-600">Pick up your residence permit at the immigration office. You can then legally reside in Cyprus for 1 year.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> You can enter Cyprus visa-free (most nationalities) and apply from within the country. This lets you explore before committing to a full year.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Cyprus's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, €5,500/month</h3>
        <p class="text-neutral-600 mb-4">British citizen post-Brexit, wants EU residence and sunshine.</p>
        <p class="text-green-700 font-medium">✓ Approved quickly. Enjoying non-dom tax benefits on investment income. Plans to stay all 3 years.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Manager, €4,200/month</h3>
        <p class="text-neutral-600 mb-4">Works remotely for US company, attracted by English-speaking environment.</p>
        <p class="text-green-700 font-medium">✓ Approved. Appreciates not needing to learn new language for daily life.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Designer, €2,800/month</h3>
        <p class="text-neutral-600 mb-4">Income below €3,500 threshold.</p>
        <p class="text-red-700 font-medium">✗ Denied. €700 below threshold. Advised to increase income or consider lower-requirement countries.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Family of Four, €8,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Parents work remotely, two children. Need €5,250 minimum.</p>
        <p class="text-green-700 font-medium">✓ Approved. Kids enrolled in international school, enjoying beach lifestyle.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Crypto Investor, €6,000/month</h3>
        <p class="text-neutral-600 mb-4">Interested in Cyprus's favorable crypto tax treatment.</p>
        <p class="text-green-700 font-medium">✓ Approved. Using non-dom status—no tax on foreign dividends, favorable crypto treatment.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, €7,500/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, €4,000 + €3,500. Need €4,200 total (€3,500 + €700).</p>
        <p class="text-green-700 font-medium">✓ Both applied—primary applicant at €4,000, spouse as dependent. Living in Paphos.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
