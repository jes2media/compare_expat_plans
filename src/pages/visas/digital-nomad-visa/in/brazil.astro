---
/**
 * Brazil Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Brazil", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Brazil Health Insurance Guide", href: "/countries/brazil/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "$1,500+/month", evidence: "Bank statements, contracts" },
  { requirement: "Savings Alternative", details: "$18,000 in bank account", evidence: "Bank statements" },
  { requirement: "Remote Work", details: "Work for company outside Brazil", evidence: "Employment contract" },
  { requirement: "Health Insurance", details: "Valid in Brazil for visa duration", evidence: "Insurance certificate" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Criminal record certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Brazil Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Must cover Brazil", why: "Healthcare access" },
  { feature: "Hospitalization", minimum: "Included", why: "Private hospital costs vary" },
  { feature: "Coverage Duration", minimum: "Full visa period", why: "1 year minimum" },
  { feature: "COVID-19", minimum: "Recommended", why: "May be checked" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "Remote areas may need it" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive coverage" },
  { provider: "IMG Global", coverage: "$1,000,000", price: "$100-200", strengths: "Americas focus" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Global network" },
  { provider: "GeoBlue", coverage: "$1,000,000", price: "$150-300", strengths: "US expats" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$80-290", notes: "Varies by nationality" },
  { item: "Health Insurance (Annual)", amount: "$500-3,500", notes: "International coverage" },
  { item: "Criminal Record Certificate", amount: "$20-50", notes: "From home country" },
  { item: "Document Translation", amount: "$50-150", notes: "If required" },
  { item: "CPF Registration", amount: "Free", notes: "Tax ID (optional but useful)" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit visa application", duration: "1 day", location: "Brazilian consulate" },
  { step: "Processing", duration: "15-45 days", location: "Consulate" },
  { step: "Receive visa", duration: "Via passport", location: "Consulate pickup" },
  { step: "Enter Brazil", duration: "Within 90 days", location: "Any entry point" },
  { step: "Register with Federal Police", duration: "Within 90 days of arrival", location: "Federal Police office" },
];
---

<PageShell
  title="Brazil Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Brazil's Digital Nomad Visa. South American adventure, $1,500 income requirement, beaches and cities, and step-by-step application process."
  headline="Brazil Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from Brazil—beaches, culture, and adventure await."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/brazil-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Brazilian Immigration
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Low Income Threshold
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Brazil launched its Digital Nomad Visa in January 2022, opening South America's largest country to remote workers. With just $1,500/month income requirement, stunning beaches, vibrant cities, and diverse landscapes, Brazil offers an unmatched combination of affordability and adventure.
    </p>

    <p class="mb-4">
      From the urban energy of São Paulo to the beaches of Rio de Janeiro, the natural beauty of Florianópolis, and the charm of Salvador, Brazil provides endless variety. The digital nomad visa lets you explore it all legally for up to a year.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Brazil Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year (renewable for 1 more year)</li>
        <li>• <strong>Income requirement:</strong> $1,500/month or $18,000 savings</li>
        <li>• <strong>Processing time:</strong> 15-45 days typical</li>
        <li>• <strong>Insurance:</strong> Mandatory health coverage</li>
        <li>• <strong>Renewable:</strong> Yes, once for additional year</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Brazil for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Low income threshold:</strong> $1,500/month is one of the lowest DNV requirements</li>
      <li><strong>Incredible diversity:</strong> Beaches, rainforest, cities, mountains—all in one country</li>
      <li><strong>Affordable living:</strong> Your money stretches far outside major tourist areas</li>
      <li><strong>Vibrant culture:</strong> Music, food, festivals, warm people</li>
      <li><strong>Growing tech scene:</strong> São Paulo and Florianópolis have strong startup ecosystems</li>
      <li><strong>Adventure opportunities:</strong> Surfing, hiking, wildlife—endless options</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Brazil is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn $1,500+/month from remote work</li>
          <li>✓ You want beach and nature lifestyle</li>
          <li>✓ You enjoy vibrant, social culture</li>
          <li>✓ You're willing to learn Portuguese</li>
          <li>✓ You want adventure and variety</li>
          <li>✓ You value warmth and sunshine</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• Safety is your top priority</li>
          <li>• You need everything in English</li>
          <li>• You prefer highly efficient systems</li>
          <li>• You want EU/Schengen access</li>
          <li>• You dislike humidity</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Brazil's Digital Nomad Visa has one of the most accessible income thresholds at $1,500/month. Alternatively, you can show $18,000 in savings—making this visa achievable for most remote workers.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification Options</h3>

    <p class="mb-4">
      Brazil offers flexibility in proving financial stability:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-2">Option A: Monthly Income</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Show $1,500/month income</li>
          <li>• Employment contracts or invoices</li>
          <li>• 3-6 months bank statements</li>
        </ul>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-2">Option B: Savings</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Show $18,000+ in bank account</li>
          <li>• Bank statements proving balance</li>
          <li>• Good for variable income earners</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Consulate Variation:</strong> Requirements may vary slightly by Brazilian consulate. Some are stricter than others. Check with your specific consulate for exact requirements.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (Brazilian specifications)</li>
      <li>Proof of income ($1,500/month) or savings ($18,000)</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Health insurance certificate</li>
      <li>Criminal record certificate</li>
      <li>Proof of accommodation (optional but helpful)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Coverage Must Include Brazil</h3>
      <p class="text-blue-800">
        Brazil requires health insurance valid in the country for your entire stay. Most international health insurance and travel medical plans are accepted if they cover Brazil.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Brazil's Digital Nomad Visa. Your policy must cover you in Brazil for the full duration of your planned stay.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Brazilian Healthcare Context</h3>

    <p class="mb-4">
      Brazil has both public (SUS) and private healthcare. Digital nomads typically use private healthcare, which is excellent in major cities but varies in quality in rural areas.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (SUS)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Available to all, including foreigners</li>
          <li>• <strong>Cost:</strong> Free</li>
          <li>• <strong>Quality:</strong> Variable, often long waits</li>
          <li>• <strong>Language:</strong> Portuguese only</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With insurance or direct payment</li>
          <li>• <strong>Quality:</strong> Excellent in São Paulo, Rio</li>
          <li>• <strong>Language:</strong> English in major hospitals</li>
          <li>• <strong>Cost:</strong> Affordable by US standards</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Brazil's Digital Nomad Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer coverage suitable for Brazil's Digital Nomad Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at $40-75/month. Good Brazil coverage at lowest cost.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Americas Focus</h4>
        <p class="text-neutral-600">IMG Global. Strong Americas network, good for regional travel.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage with excellent network.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US Expats</h4>
        <p class="text-neutral-600">GeoBlue. Familiar to US residents, good Latin America coverage.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Brazil's visa fees vary by nationality. The overall process is affordable, especially given the low income threshold.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$700</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$4,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive plan</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living in Brazil</h3>

    <p class="mb-4">
      Brazil's cost of living varies dramatically. São Paulo and Rio are more expensive; beach towns and the Northeast offer incredible value.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget (Northeast, small towns):</strong> $1,000-1,500/month</li>
      <li><strong>Comfortable (Floripa, mid-tier):</strong> $1,500-2,500/month</li>
      <li><strong>Premium (São Paulo, Rio center):</strong> $3,000+/month</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Brazil's visa application goes through your local Brazilian consulate. Processing times vary but typically run 15-45 days.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documents</h4>
          <p class="text-neutral-600">Gather all required documents: income proof, insurance, criminal record. Check specific requirements with your consulate.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Book Consulate Appointment</h4>
          <p class="text-neutral-600">Schedule appointment at Brazilian consulate. Bring all documents in person.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Attend appointment, submit documents, pay visa fee. Provide biometrics if required.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 15-45 days. Consulate may contact you for additional documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Brazil & Register</h4>
          <p class="text-neutral-600">Enter within 90 days of visa issuance. Register with Federal Police within 90 days of arrival.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Get a CPF (Brazilian tax ID) after arrival—it makes banking, phone contracts, and many services much easier. It's free and can be done at Receita Federal offices.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Brazil's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $5,000/month</h3>
        <p class="text-neutral-600 mb-4">Works for US company, wants to experience Rio lifestyle.</p>
        <p class="text-green-700 font-medium">✓ Approved in 3 weeks. Strong documentation, clear income.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $2,000/month</h3>
        <p class="text-neutral-600 mb-4">Content writer with multiple clients, wants beach lifestyle.</p>
        <p class="text-green-700 font-medium">✓ Approved. Provided client contracts and bank statements.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Beginning Freelancer, $1,200/month</h3>
        <p class="text-neutral-600 mb-4">Just starting remote work, limited income history.</p>
        <p class="text-red-700 font-medium">✗ Denied. $300 below threshold. Used savings option on reapplication.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Digital Marketer, $3,500/month</h3>
        <p class="text-neutral-600 mb-4">Works for European agency, interested in Florianópolis tech scene.</p>
        <p class="text-green-700 font-medium">✓ Approved quickly. Excellent documentation.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">YouTuber, variable income</h3>
        <p class="text-neutral-600 mb-4">Income varies monthly. Has $25,000 in savings.</p>
        <p class="text-green-700 font-medium">✓ Approved using savings option. $25,000 exceeded $18,000 requirement.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, $2,500/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, each earns about $1,250.</p>
        <p class="text-amber-700 font-medium">△ Applied separately. Each needed to meet $1,500 threshold independently.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Compare insurance plans for your Brazilian adventure—get quotes in minutes.</p>
