---
/**
 * Ecuador Digital Nomad Visa (RIMPE) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Ecuador", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Ecuador Health Insurance Guide", href: "/countries/ecuador/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "$1,350/month (~3x minimum wage)", evidence: "Bank statements, employment letter" },
  { requirement: "Remote Work", details: "Work for company outside Ecuador", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "Required for visa duration", evidence: "Insurance certificate with coverage dates" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No serious criminal history", evidence: "Police clearance (apostilled)" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Ecuador Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Required (no minimum stated)", why: "Must cover medical expenses" },
  { feature: "Coverage Territory", minimum: "Valid in Ecuador", why: "Required for visa" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "Limited facilities in some areas" },
  { feature: "Duration", minimum: "Full visa period", why: "Mandatory requirement" },
  { feature: "Repatriation", minimum: "Recommended", why: "Return transport if needed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive global" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Latin America coverage" },
  { provider: "GeoBlue", coverage: "$500,000+", price: "$150-280", strengths: "US expats" },
  { provider: "Local Ecuadorian", coverage: "Varies", price: "$30-80", strengths: "Long-term residents" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$50", notes: "Government fee" },
  { item: "Visa Processing", amount: "$200-400", notes: "Depending on consulate" },
  { item: "Health Insurance (Annual)", amount: "$500-2,000", notes: "International coverage" },
  { item: "Document Apostille", amount: "$50-150", notes: "Per document" },
  { item: "Cedula (ID)", amount: "$20-30", notes: "After arrival" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-3 weeks", location: "Home country" },
  { step: "Apostille documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit application", duration: "1 day", location: "Ecuadorian consulate or online" },
  { step: "Processing", duration: "2-4 weeks", location: "Ministry review" },
  { step: "Receive visa", duration: "Pickup or email", location: "Consulate" },
  { step: "Enter Ecuador", duration: "Within visa validity", location: "Any entry point" },
  { step: "Register and get cedula", duration: "Within 30 days", location: "Local civil registry" },
];
---

<PageShell
  title="Ecuador Digital Nomad Visa 2025: RIMPE Visa Insurance & Requirements Guide"
  description="Complete guide to Ecuador's digital nomad visa for remote workers. Dollarized economy, Galápagos access, affordable Andes living, and straightforward requirements."
  headline="Ecuador Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the land of eternal spring—dollarized economy, stunning nature, and affordable mountain living."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      USD Currency
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Ecuador offers one of South America's most accessible digital nomad visas through its RIMPE (Simplified Tax Regime) pathway for remote workers. With a dollarized economy, you won't deal with exchange rate headaches—prices are in USD, and your income stays stable.
    </p>

    <p class="mb-4">
      From the colonial charm of Cuenca to the cosmopolitan energy of Quito, Ecuador offers incredible geographic diversity: Andean highlands, Pacific beaches, Amazon jungle, and the legendary Galápagos Islands—all in a country the size of Colorado.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Ecuador for Digital Nomads</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Professional/RIMPE visa for remote workers</li>
        <li>• <strong>Income requirement:</strong> $1,350/month (~3x minimum wage)</li>
        <li>• <strong>Duration:</strong> Up to 2 years, renewable</li>
        <li>• <strong>Insurance:</strong> Required for visa application</li>
        <li>• <strong>Currency:</strong> US Dollar (no exchange risk)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Ecuador for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Dollarized economy:</strong> No currency exchange headaches, prices in USD</li>
      <li><strong>Low cost of living:</strong> Comfortable life on $1,200-1,800/month</li>
      <li><strong>Perfect climate:</strong> Cuenca has "eternal spring" weather year-round</li>
      <li><strong>Incredible nature:</strong> Galápagos, Andes, Amazon, Pacific coast</li>
      <li><strong>Expat-friendly:</strong> Large established expat community, especially in Cuenca</li>
      <li><strong>Accessible requirements:</strong> Lower income threshold than most countries</li>
      <li><strong>Strategic location:</strong> Direct flights to US, hub for South America travel</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Ecuador is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want USD pricing with no exchange rate risk</li>
          <li>✓ You prefer mountains and temperate climate</li>
          <li>✓ You have moderate income ($1,350+/month)</li>
          <li>✓ You want access to incredible nature</li>
          <li>✓ You're interested in established expat communities</li>
          <li>✓ You want a path to residency</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need fast, reliable internet everywhere</li>
          <li>• You want major metropolitan nightlife</li>
          <li>• You prefer everything in English</li>
          <li>• You need cutting-edge infrastructure</li>
          <li>• You want Southeast Asian-level affordability</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Cuenca is the most popular expat destination—excellent weather, beautiful colonial architecture, and a large English-speaking community. Quito offers more urban amenities but is at 9,350 feet elevation (takes adjustment).
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Ecuador's digital nomad visa falls under the professional/RIMPE category for those working remotely for foreign companies. Requirements are straightforward compared to many countries.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Visa Options for Digital Nomads</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Professional/RIMPE Visa (Recommended)</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> Up to 2 years</li>
          <li>• <strong>Income:</strong> $1,350/month minimum</li>
          <li>• <strong>Path to residency:</strong> Yes</li>
          <li>• <strong>Work permitted:</strong> Remote work for foreign entities</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Tourist Visa Alternative</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Duration:</strong> 90 days, extendable to 180</li>
          <li>• <strong>Income:</strong> No requirement</li>
          <li>• <strong>Renewal:</strong> Leave and re-enter</li>
          <li>• <strong>Work:</strong> Gray area, no local work</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Income Calculation:</strong> The ~$1,350/month threshold is approximately 3x Ecuador's minimum wage. You'll need to show consistent income over several months—bank statements and employment letters work well.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Completed visa application form</li>
      <li>Passport-size photos</li>
      <li>Proof of income ($1,350+/month) - 3-6 months of bank statements</li>
      <li>Employment contract or freelance agreements</li>
      <li>Health insurance certificate (covering visa duration)</li>
      <li>Police clearance certificate (apostilled)</li>
      <li>All documents apostilled and translated to Spanish</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required</h3>
      <p class="text-red-800">
        Ecuador requires health insurance for the digital nomad visa. Your policy must cover the full duration of your intended stay. While there's no stated minimum coverage amount, comprehensive coverage is strongly recommended.
      </p>
    </div>

    <p class="mb-4">
      Your insurance certificate must clearly state: your name, coverage dates matching your visa period, and that it's valid in Ecuador. International policies are accepted.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Why Good Coverage Matters</h3>

    <p class="mb-4">
      Ecuador has good healthcare in major cities (Quito, Guayaquil, Cuenca) but more limited options in rural areas. If you plan to visit the Galápagos, Amazon, or remote highland areas, evacuation coverage becomes important.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Major Cities</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Quality:</strong> Good private hospitals</li>
          <li>• <strong>Cost:</strong> Affordable by US standards</li>
          <li>• <strong>Access:</strong> Easy, no referral needed</li>
          <li>• <strong>English:</strong> Some staff speak English</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Rural/Remote Areas</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Quality:</strong> Basic facilities</li>
          <li>• <strong>Evacuation:</strong> May be necessary</li>
          <li>• <strong>Galápagos:</strong> Limited options</li>
          <li>• <strong>Amazon:</strong> Very basic</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need qualifying health insurance for Ecuador?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These international providers offer plans that meet Ecuador's visa requirements:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious Nomads</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Meets visa requirements, easy to purchase, flexible monthly billing.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Adventure Seekers</h4>
        <p class="text-neutral-600">IMG Global or Cigna. Get comprehensive evacuation coverage for Galápagos, Amazon, and highland trekking.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US Expats</h4>
        <p class="text-neutral-600">GeoBlue. Maintains US network access for visits home, good Latin America coverage.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Residents (2+ years)</h4>
        <p class="text-neutral-600">Consider local Ecuadorian insurance after establishing residency. Much cheaper at $30-80/month.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Ecuador's dollarized economy means no exchange rate surprises. What you see is what you pay—in USD.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Typical Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,200</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + premium global coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost of Living</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget (Cuenca):</strong> $1,000-1,400/month (basic apartment, cooking, local lifestyle)</li>
      <li><strong>Comfortable:</strong> $1,400-2,000/month (nice apartment, dining out, activities)</li>
      <li><strong>Premium (Quito):</strong> $2,500+/month (upscale neighborhood, full amenities)</li>
    </ul>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Cuenca value:</strong> Many expats live comfortably in Cuenca on $1,200-1,500/month including rent, food, healthcare, and entertainment. It's consistently ranked among the world's best retirement destinations.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      You can apply for Ecuador's digital nomad visa at an Ecuadorian consulate abroad or, in some cases, complete initial steps online before arrival.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Core Documents</h4>
          <p class="text-neutral-600">Collect passport, birth certificate, police clearance. Get 3-6 months of bank statements showing $1,350+/month income.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get Health Insurance</h4>
          <p class="text-neutral-600">Purchase international health insurance covering your full visa period. Get a certificate showing your name, dates, and Ecuador coverage.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apostille Documents</h4>
          <p class="text-neutral-600">Get apostilles for police clearance and birth certificate. Have everything translated to Spanish by a certified translator.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Apply at your nearest Ecuadorian consulate. Some processes can start online. Pay the application fee ($50 + processing).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Processing takes 2-4 weeks typically. Once approved, you'll receive your visa or authorization to enter.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Register in Ecuador</h4>
          <p class="text-neutral-600">After arrival, register with local authorities and obtain your cedula (Ecuadorian ID) within 30 days.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The cedula is important for daily life—you'll need it for phone contracts, bank accounts, and many services. Don't delay getting it after arrival.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out for digital nomads in Ecuador:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $4,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable mountain town with good internet.</p>
        <p class="text-green-700 font-medium">✓ Settled in Cuenca. Living well on $1,800/month, saving $2,000+. Perfect weather, colonial architecture, established expat community.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $2,000/month</h3>
        <p class="text-neutral-600 mb-4">Low income threshold appealed, loves nature.</p>
        <p class="text-green-700 font-medium">✓ Easily qualified. Living in Vilcabamba (Valley of Longevity). Comfortable budget lifestyle, weekend trips to coast.</p>
      </div>

