---
/**
 * Greece Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Greece", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Greece Health Insurance Guide", href: "/countries/greece/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€3,500/month minimum", evidence: "Bank statements, tax returns" },
  { requirement: "Remote Work", details: "Employed/self-employed outside Greece", evidence: "Employment contract" },
  { requirement: "Health Insurance", details: "Mandatory full coverage", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "3+ months beyond stay", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Greece Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "€30,000+ (Schengen)", why: "EU minimum standard" },
  { feature: "Hospitalization", minimum: "Full coverage", why: "Required for visa" },
  { feature: "Repatriation", minimum: "Required", why: "Schengen requirement" },
  { feature: "Coverage Duration", minimum: "Full visa period", why: "No gaps allowed" },
  { feature: "EU/Schengen", minimum: "Must be covered", why: "Travel within EU" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-300", strengths: "EU network" },
  { provider: "BUPA Global", coverage: "€2,000,000+", price: "€280-450", strengths: "Premium" },
  { provider: "World Nomads", coverage: "€100,000", price: "€70-140", strengths: "Island hopping" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€75-100", notes: "Consulate fee" },
  { item: "Residence Permit", amount: "€150-300", notes: "Upon arrival" },
  { item: "Health Insurance (Annual)", amount: "€500-3,500", notes: "Schengen-compliant" },
  { item: "Tax Registration", amount: "€50-100", notes: "AFM number" },
  { item: "Document Apostille", amount: "€30-80", notes: "If required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-3 weeks", location: "Home country" },
  { step: "Embassy appointment", duration: "1-4 weeks wait", location: "Greek consulate" },
  { step: "Submit application", duration: "1 day", location: "Consulate" },
  { step: "Processing", duration: "2-4 weeks", location: "Greek authorities" },
  { step: "Collect visa", duration: "1-3 days", location: "Consulate" },
  { step: "Enter Greece", duration: "Within validity", location: "Any entry point" },
  { step: "Register locally", duration: "Within 7 days", location: "Local authorities" },
];

const locationColumns = [
  { key: "location", header: "Location" },
  { key: "vibe", header: "Vibe" },
  { key: "cost", header: "Monthly Cost" },
  { key: "internet", header: "Internet" },
];

const locationRows = [
  { location: "Athens", vibe: "Capital, cultural hub", cost: "€1,500-2,500", internet: "Excellent" },
  { location: "Thessaloniki", vibe: "Student city, lively", cost: "€1,200-2,000", internet: "Very good" },
  { location: "Crete", vibe: "Island, diverse", cost: "€1,400-2,400", internet: "Good" },
  { location: "Santorini", vibe: "Tourist hotspot", cost: "€2,000-3,500", internet: "Variable" },
  { location: "Rhodes", vibe: "Historic island", cost: "€1,300-2,200", internet: "Good" },
];
---

<PageShell
  title="Greece Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Greece's Digital Nomad Visa. €3,500 income requirement, island living, Mediterranean lifestyle, and application process."
  headline="Greece Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from Greece—insurance requirements, costs, and Mediterranean island lifestyle."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Ministry Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU/Schengen Member
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Greece launched its Digital Nomad Visa in late 2021, offering remote workers the chance to live in one of Europe's most beloved destinations. With 6,000+ islands, ancient history, and Mediterranean lifestyle, Greece attracts nomads seeking sun, culture, and affordable EU living.
    </p>

    <p class="mb-4">
      The Greek DN visa offers up to 1 year of residency (renewable) for those earning €3,500+ monthly from foreign employers. A unique 50% tax reduction on foreign income makes Greece particularly attractive for higher earners.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Greece Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year, renewable up to 2 more years</li>
        <li>• <strong>Income requirement:</strong> €3,500/month minimum</li>
        <li>• <strong>Processing time:</strong> 2-4 weeks typical</li>
        <li>• <strong>Insurance:</strong> Mandatory Schengen-compliant</li>
        <li>• <strong>Tax benefit:</strong> 50% reduction on foreign income (7 years)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Popular Locations</h3>

    <ComparisonTable columns={locationColumns} rows={locationRows} />

    <p class="mt-4">
      Athens offers the best infrastructure and year-round living. Thessaloniki is the budget-friendly alternative with great food scene. Islands are seasonal—amazing in summer but quiet in winter.
    </p>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Greece is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €3,500+/month from remote work</li>
          <li>✓ You love Mediterranean climate and food</li>
          <li>✓ You want island-hopping lifestyle (summer)</li>
          <li>✓ You work European/Middle East time zones</li>
          <li>✓ You appreciate ancient history and culture</li>
          <li>✓ You want the 50% tax reduction benefit</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need fast, consistent internet everywhere</li>
          <li>• You dislike bureaucracy</li>
          <li>• You want a large established nomad community</li>
          <li>• You work Americas time zones</li>
          <li>• You prefer year-round warm island weather</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Greece's Digital Nomad Visa has a €3,500/month income threshold—one of the higher requirements in Europe, but offset by the significant tax benefit.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate €3,500/month income. For dependents, add €20% for spouse and €15% per child. Accepted evidence:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 6-12 months showing income</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>For freelancers:</strong> Client contracts and invoices</li>
    </ul>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-green-800">
        <strong>Tax Benefit:</strong> Greece offers a 50% tax reduction on foreign-source income for up to 7 years for those who become tax residents. This can mean significant savings for higher earners.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (3+ months beyond intended stay)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (Schengen specifications)</li>
      <li>Proof of income (€3,500+/month)</li>
      <li>Health insurance certificate</li>
      <li>Employment contract or business documentation</li>
      <li>Police clearance certificate</li>
      <li>Proof of accommodation in Greece</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Schengen Standards Apply</h3>
      <p class="text-blue-800">
        As an EU/Schengen member, Greece requires health insurance meeting Schengen visa standards: minimum €30,000 coverage, hospitalization, and repatriation for your entire stay.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Greece's Digital Nomad Visa. Your policy must cover the full visa duration and meet EU standards.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Greek Healthcare Context</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (ESY)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Limited for DN visa holders</li>
          <li>• <strong>Quality:</strong> Variable, often overcrowded</li>
          <li>• <strong>Emergency:</strong> Will treat emergencies</li>
          <li>• <strong>Language:</strong> Greek primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With international insurance</li>
          <li>• <strong>Quality:</strong> Excellent in Athens</li>
          <li>• <strong>Language:</strong> English available</li>
          <li>• <strong>Cost:</strong> Moderate by EU standards</li>
        </ul>
      </div>
    </div>

    <p class="mb-4">
      Private healthcare in Athens and major cities is excellent. Islands have limited facilities—serious issues may require transfer to the mainland or Athens.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need Schengen-compliant insurance for Greece?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer Schengen-compliant coverage for Greece's Digital Nomad Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €40-75/month. Meets requirements at affordable rates.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Island Hoppers</h4>
        <p class="text-neutral-600">World Nomads. Covers water sports and adventure activities common in Greek islands.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-Term Residents</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care. Comprehensive coverage for 1-3 year stays.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">BUPA Global. Top-tier coverage with Athens private hospital access.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Greece's visa fees are reasonable. Living costs are moderate by EU standards, with significant variation between Athens and islands.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€2,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€4,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + premium coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Greece is affordable by Western European standards. Monthly budgets:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> €1,300-1,800/month (Athens shared housing, cooking)</li>
      <li><strong>Comfortable:</strong> €2,000-3,000/month (own apartment, dining out)</li>
      <li><strong>Premium:</strong> €3,500+/month (Cycladic islands, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Greece's process involves applying at a Greek consulate abroad, then registering locally after arrival. Greek bureaucracy can be slow—patience is essential.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documentation</h4>
          <p class="text-neutral-600">Prepare all required documents. Get police clearance, apostilles where needed, and ensure insurance is Schengen-compliant.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Book Consulate Appointment</h4>
          <p class="text-neutral-600">Schedule an appointment at your nearest Greek consulate. Wait times vary by location.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Attend appointment with all documents. Pay application fee. You may be interviewed about your plans.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 2-4 weeks typically. Greek bureaucracy can be unpredictable—be patient.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect Visa & Enter Greece</h4>
          <p class="text-neutral-600">Pick up your visa at the consulate. Enter Greece within the validity period.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Local Registration</h4>
          <p class="text-neutral-600">Register with local authorities within 7 days. Get your AFM (tax number) if claiming tax benefits.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Consider hiring a Greek lawyer or relocation specialist to navigate the bureaucracy. They can expedite processes and handle Greek paperwork.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Greece's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Tech Lead, €7,000/month</h3>
        <p class="text-neutral-600 mb-4">Works for UK company, wants Mediterranean lifestyle with tax benefits.</p>
        <p class="text-green-700 font-medium">✓ Approved. 50% tax reduction saves €15,000+ annually. Living in Athens.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Designer, €4,000/month</h3>
        <p class="text-neutral-600 mb-4">Various EU clients, wants island lifestyle.</p>
        <p class="text-green-700 font-medium">✓ Approved. Summers on Crete, winters in Athens for better internet.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Writer, €3,000/month</h3>
        <p class="text-neutral-600 mb-4">Stable but below threshold.</p>
        <p class="text-red-700 font-medium">✗ Denied. €500 below €3,500 requirement. Advised to take additional clients.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Family of 4, €6,000/month</h3>
        <p class="text-neutral-600 mb-4">Parents remote workers, two school-age children.</p>
        <p class="text-green-700 font-medium">✓ Approved. Income exceeded €3,500 + 20% spouse + 30% children requirement.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Consultant, €5,500/month</h3>
        <p class="text-neutral-600 mb-4">US citizen, wants Schengen base near Middle East clients.</p>
        <p class="text-green-700 font-medium">✓ Approved. Greece's location ideal for Europe/Middle East time zones.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
