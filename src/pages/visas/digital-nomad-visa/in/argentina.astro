---
/**
 * Argentina Digital Nomad Visa (Rentista) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Argentina", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Argentina Health Insurance Guide", href: "/countries/argentina/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "~$1,500-2,000/month (Rentista)", evidence: "Bank statements, income proof" },
  { requirement: "Remote Work", details: "Work for company outside Argentina", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "Recommended but not strictly required", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No serious criminal history", evidence: "Police clearance (apostilled)" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Argentina Recommendation" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "$100,000+ recommended", why: "Private healthcare can be costly" },
  { feature: "Coverage Territory", minimum: "Valid in Argentina", why: "Must cover your stay" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "For specialized care if needed" },
  { feature: "Duration", minimum: "Full visa period", why: "Continuous coverage important" },
  { feature: "Repatriation", minimum: "Included", why: "Return transport if needed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive global" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Latin America focus" },
  { provider: "Local Argentine", coverage: "Varies", price: "$50-150", strengths: "Prepaga plans (OSDE, Swiss Medical)" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Global coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$150-250", notes: "Varies by consulate" },
  { item: "DNI (ID Card)", amount: "$5-10", notes: "After arrival" },
  { item: "Health Insurance (Annual)", amount: "$500-2,500", notes: "International or local prepaga" },
  { item: "Document Apostille", amount: "$50-150", notes: "Required for most documents" },
  { item: "Translation Services", amount: "$50-150", notes: "Certified Spanish translations" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Apostille documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit application", duration: "1 day", location: "Argentine consulate" },
  { step: "Processing", duration: "2-8 weeks", location: "Consulate review" },
  { step: "Receive visa", duration: "Pickup", location: "Consulate" },
  { step: "Enter Argentina", duration: "Within visa validity", location: "Any entry point" },
  { step: "Apply for DNI", duration: "Within 30 days", location: "Local Registro Civil" },
];
---

<PageShell
  title="Argentina Digital Nomad Visa 2025: Rentista Visa Insurance & Requirements Guide"
  description="Complete guide to Argentina's Rentista visa for digital nomads. Blue dollar rates, Buenos Aires lifestyle, affordable living, and how to navigate the unique Argentine system."
  headline="Argentina Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from South America's most European city—visa options, blue dollar economics, and the Buenos Aires lifestyle."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Migraciones Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Blue Dollar Economics
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Argentina doesn't have a dedicated "Digital Nomad Visa" but offers several paths for remote workers, most commonly the Rentista (passive income) visa. Combined with Argentina's unique parallel exchange rates, digital nomads can enjoy an exceptional quality of life in Buenos Aires—one of South America's most sophisticated cities.
    </p>

    <p class="mb-4">
      The "blue dollar" parallel exchange rate means your USD goes 20-40% further than official rates, making Argentina remarkably affordable for those earning in foreign currency. Buenos Aires offers European-style culture, world-class food, tango, and a thriving expat community.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Argentina for Digital Nomads</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa options:</strong> Rentista visa, or 90-day tourist stays (renewable)</li>
        <li>• <strong>Income requirement:</strong> ~$1,500-2,000/month for Rentista</li>
        <li>• <strong>Processing time:</strong> 2-8 weeks at consulate</li>
        <li>• <strong>Insurance:</strong> Recommended but not strictly required</li>
        <li>• <strong>Currency advantage:</strong> Blue dollar rate gives 20-40% bonus</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Argentina for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Blue dollar advantage:</strong> Parallel exchange rate stretches your money significantly</li>
      <li><strong>European culture:</strong> Buenos Aires feels like a European city in South America</li>
      <li><strong>World-class food:</strong> Steak, wine, Italian influence, vibrant cafe culture</li>
      <li><strong>Affordable luxury:</strong> Fine dining, apartments, and services at fraction of US/EU prices</li>
      <li><strong>Thriving expat scene:</strong> Large international community, especially in Palermo</li>
      <li><strong>Cultural richness:</strong> Tango, theater, art, nightlife, football passion</li>
      <li><strong>Good healthcare:</strong> Quality private healthcare at reasonable prices</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Argentina is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn in USD/EUR and want maximum value</li>
          <li>✓ You appreciate European-style urban culture</li>
          <li>✓ You love food, wine, and nightlife</li>
          <li>✓ You're comfortable with some bureaucracy</li>
          <li>✓ You want to learn Spanish in an immersive setting</li>
          <li>✓ You enjoy a sophisticated city lifestyle</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need simple, predictable bureaucracy</li>
          <li>• You want beach/tropical lifestyle</li>
          <li>• You prefer everything in English</li>
          <li>• You need very stable currency/economy</li>
          <li>• You want a clear path to permanent residency</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Blue Dollar Note:</strong> Argentina has parallel exchange rates. The "blue dollar" (informal market) rate is significantly better than the official rate. Most nomads exchange USD cash for pesos at blue rate through "cuevas" (exchange houses) or Western Union. This is widely practiced and makes Argentina extremely affordable.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Argentina offers several visa paths for digital nomads. The Rentista visa is most suitable for those with provable income, though many nomads use tourist visa renewals.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Visa Options for Digital Nomads</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Rentista Visa (Recommended)</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> 1 year, renewable</li>
          <li>• <strong>Income:</strong> ~$1,500-2,000/month provable</li>
          <li>• <strong>Path to residency:</strong> Yes, after 2 years</li>
          <li>• <strong>Work permitted:</strong> Remote work for foreign companies</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Tourist Visa Strategy</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Duration:</strong> 90 days, extendable once</li>
          <li>• <strong>Renewal:</strong> Exit to Uruguay/Chile and re-enter</li>
          <li>• <strong>Pros:</strong> No paperwork, immediate</li>
          <li>• <strong>Cons:</strong> Gray area for work, no residency path</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Tourist Visa Reality:</strong> Many digital nomads use the 90-day tourist visa with "border runs" to Uruguay. While technically remote work isn't permitted on tourist status, enforcement is minimal. For longer stays or legal certainty, the Rentista visa is better.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Rentista Visa Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Completed visa application form</li>
      <li>Passport photos</li>
      <li>Proof of income ($1,500-2,000/month) - bank statements, employment letter</li>
      <li>Police clearance certificate (apostilled)</li>
      <li>Birth certificate (apostilled)</li>
      <li>All documents translated to Spanish by certified translator</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Insurance Recommended, Not Required</h3>
      <p class="text-blue-800">
        Argentina doesn't strictly require health insurance for visa applications, but having coverage is strongly recommended. Argentine private healthcare (prepaga) is excellent and affordable, but international insurance provides peace of mind and evacuation coverage.
      </p>
    </div>

    <p class="mb-4">
      While not mandatory, health insurance is important in Argentina. You have two main options: international coverage or local "prepaga" (prepaid health plans).
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Argentine Healthcare Context</h3>

    <p class="mb-4">
      Argentina has three healthcare tiers: public (free but variable quality), obras sociales (union-based), and prepaga (private prepaid). Expats typically use prepaga plans, which offer excellent care at reasonable prices.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Cost:</strong> Free</li>
          <li>• <strong>Quality:</strong> Variable, can be excellent</li>
          <li>• <strong>Access:</strong> Available to all</li>
          <li>• <strong>Wait times:</strong> Can be long</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Prepaga (Private)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Cost:</strong> $50-200/month</li>
          <li>• <strong>Quality:</strong> Excellent</li>
          <li>• <strong>Providers:</strong> OSDE, Swiss Medical, Galeno</li>
          <li>• <strong>Note:</strong> May have waiting periods</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for your Argentina move?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      You can choose between international coverage or local Argentine prepaga plans:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Short-term / Flexible Nomads</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Easy to maintain, covers travel, no local bureaucracy.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Residents (6+ months)</h4>
        <p class="text-neutral-600">Local prepaga (OSDE, Swiss Medical). Better value for extended stays, excellent local network.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive + Travel</h4>
        <p class="text-neutral-600">Cigna Global or IMG Global. Best if you'll travel regionally or need evacuation coverage.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Value Local</h4>
        <p class="text-neutral-600">OSDE 210 or 310 plan. Excellent private hospitals, $80-150/month depending on plan level.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Argentina offers exceptional value when using the blue dollar rate. Your USD stretches 20-40% further than official exchange suggests.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Tourist Strategy</p>
        <p class="text-3xl font-bold text-neutral-900">$600</p>
        <p class="text-sm text-neutral-500 mt-2">Border runs + insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Rentista Visa</p>
        <p class="text-3xl font-bold text-neutral-900">$1,200</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + local prepaga</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + international coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living (Blue Dollar Rates)</h3>

    <p class="mb-4">
      These estimates assume you're exchanging USD at the blue dollar rate, not the official rate:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> $1,000-1,400/month (shared apartment, cooking, limited dining)</li>
      <li><strong>Comfortable:</strong> $1,500-2,200/month (own apartment in Palermo, dining out, activities)</li>
      <li><strong>Premium:</strong> $3,000+/month (upscale Palermo/Recoleta, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The Rentista visa requires applying at an Argentine consulate in your home country. The process involves significant paperwork but is straightforward.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide (Rentista Visa)</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect birth certificate, police clearance, income proof, bank statements. All must be recent (within 90 days typically).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apostille Everything</h4>
          <p class="text-neutral-600">Get apostilles for all official documents (birth certificate, police clearance). This authenticates them for international use.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Translate Documents</h4>
          <p class="text-neutral-600">Have all documents translated to Spanish by a certified translator. The consulate can often recommend translators.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit at Consulate</h4>
          <p class="text-neutral-600">Book appointment at your nearest Argentine consulate. Submit all documents and pay the visa fee ($150-250).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Argentina</h4>
          <p class="text-neutral-600">Once approved, travel to Argentina. Your visa allows entry for 1 year.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get Your DNI</h4>
          <p class="text-neutral-600">Within 30 days, apply for your DNI (national ID card) at the Registro Civil. This is essential for daily life in Argentina.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The DNI is crucial—you'll need it to sign rental contracts, get a local phone plan, access certain services, and use the blue dollar rate at Western Union. Get it as soon as possible after arrival.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out for digital nomads in Argentina:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $5,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable city with great food and culture.</p>
        <p class="text-green-700 font-medium">✓ Living like a king in Palermo on $2,000/month. Saving the rest. Blue dollar rate makes Buenos Aires incredibly affordable.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Designer, $2,500/month</h3>
        <p class="text-neutral-600 mb-4">Got Rentista visa, wanted legal status and DNI.</p>
