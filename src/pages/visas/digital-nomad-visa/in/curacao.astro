---
/**
 * Curaçao Digital Nomad Visa (@Home in Curaçao) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Curaçao", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Curaçao Health Insurance Guide", href: "/countries/curacao/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "~$3,000/month minimum", evidence: "Bank statements, employment letter" },
  { requirement: "Remote Work", details: "Work for company outside Curaçao", evidence: "Employment contract" },
  { requirement: "Health Insurance", details: "Required for visa duration", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Curaçao Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Required (comprehensive)", why: "Mandatory for visa" },
  { feature: "Coverage Territory", minimum: "Valid in Curaçao", why: "Must cover your stay" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "Complex cases go to Colombia/US" },
  { feature: "Duration", minimum: "Full visa period (6-12 months)", why: "Continuous coverage needed" },
  { feature: "Repatriation", minimum: "Recommended", why: "Return transport if needed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive global" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Caribbean coverage" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Trusted brand" },
  { provider: "Dutch Insurance", coverage: "Varies", price: "$100-200", strengths: "EU connection via Netherlands" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "~$80-150", notes: "Varies by nationality" },
  { item: "Health Insurance (Annual)", amount: "$600-2,500", notes: "International coverage" },
  { item: "Police Clearance", amount: "$50-100", notes: "From home country" },
  { item: "Residence Permit", amount: "~$300", notes: "If staying longer" },
  { item: "Extension Fee", amount: "~$100", notes: "After initial period" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1 day", location: "Online" },
  { step: "Apply online", duration: "1 day", location: "@Home portal" },
  { step: "Processing", duration: "2-4 weeks", location: "Immigration review" },
  { step: "Receive approval", duration: "Email notification", location: "Online" },
  { step: "Travel to Curaçao", duration: "At your convenience", location: "Hato International Airport" },
];
---

<PageShell
  title="Curaçao Digital Nomad Visa 2025: @Home in Curaçao Insurance & Requirements Guide"
  description="Complete guide to Curaçao's @Home digital nomad program. Dutch Caribbean charm, colorful Willemstad, affordable island living, and European-quality infrastructure."
  headline="Curaçao Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the colorful Dutch Caribbean—affordable island living with European standards and UNESCO World Heritage charm."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Dutch Caribbean
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Curaçao's @Home in Curaçao program invites digital nomads to work from one of the Caribbean's most distinctive islands. As a constituent country of the Kingdom of the Netherlands, Curaçao offers Dutch-quality infrastructure with Caribbean warmth and UNESCO World Heritage architecture.
    </p>

    <p class="mb-4">
      Willemstad's colorful Handelskade waterfront is instantly recognizable—pastel-painted Dutch colonial buildings against crystal-blue Caribbean waters. Outside the hurricane belt, Curaçao offers year-round sunny weather without the storm anxiety of other Caribbean destinations.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: @Home in Curaçao</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Program:</strong> @Home in Curaçao</li>
        <li>• <strong>Income requirement:</strong> ~$3,000/month</li>
        <li>• <strong>Duration:</strong> 6 months, extendable to 12+ months</li>
        <li>• <strong>Insurance:</strong> Required</li>
        <li>• <strong>Currency:</strong> Netherlands Antillean guilder (pegged to USD)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Curaçao for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Outside hurricane belt:</strong> No hurricane season stress</li>
      <li><strong>Dutch standards:</strong> European-quality infrastructure and services</li>
      <li><strong>UNESCO heritage:</strong> Stunning Willemstad architecture</li>
      <li><strong>Affordable Caribbean:</strong> Lower costs than Bahamas or Cayman</li>
      <li><strong>Multilingual:</strong> Dutch, English, Spanish, and Papiamentu spoken</li>
      <li><strong>EU connection:</strong> Part of Kingdom of Netherlands</li>
      <li><strong>Excellent diving:</strong> World-class shore diving</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Curaçao is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want Caribbean without hurricane risk</li>
          <li>✓ You appreciate Dutch/European culture</li>
          <li>✓ You want more affordable island living</li>
          <li>✓ Architecture and history interest you</li>
          <li>✓ You enjoy diving and water sports</li>
          <li>✓ You want multilingual environment</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You prefer English-only environments</li>
          <li>• You want large island with varied terrain</li>
          <li>• You need easy US access (fewer direct flights)</li>
          <li>• You prefer lush, green tropical settings</li>
          <li>• You want extensive nightlife scene</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Hurricane-free zone:</strong> Curaçao sits below the hurricane belt, making it one of the safest Caribbean destinations weather-wise. While other islands evacuate during hurricane season, Curaçao remains calm and sunny.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The @Home in Curaçao program has moderate requirements, making it accessible to mid-income digital nomads seeking Caribbean living.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Program Details</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Initial Stay</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> 6 months</li>
          <li>• <strong>Income:</strong> ~$3,000/month</li>
          <li>• <strong>Extension:</strong> Can extend to 12+ months</li>
          <li>• <strong>Work:</strong> Remote for foreign companies</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Nationality Considerations</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>EU/Dutch:</strong> Easiest process</li>
          <li>• <strong>US/Canada:</strong> Visa-free entry, then apply</li>
          <li>• <strong>Others:</strong> May need Schengen-style visa</li>
          <li>• <strong>Note:</strong> Check specific requirements for your nationality</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Proof of remote employment or self-employment</li>
      <li>Bank statements showing $3,000+/month income</li>
      <li>Health insurance certificate (covering Curaçao)</li>
      <li>Police clearance certificate</li>
      <li>Proof of accommodation (rental agreement or hotel booking)</li>
      <li>Passport-size photos</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required</h3>
      <p class="text-red-800">
        Curaçao requires health insurance for the @Home program. Your policy must cover medical expenses in Curaçao for the duration of your stay. While no minimum coverage is stated, comprehensive coverage is recommended.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Healthcare Context</h3>

    <p class="mb-4">
      Curaçao has good basic healthcare with Dutch standards, but complex cases may require evacuation to Colombia, Miami, or the Netherlands. The main hospital in Willemstad handles most needs.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Available on Island</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• General practitioners</li>
          <li>• Basic specialists</li>
          <li>• Emergency care</li>
          <li>• Dental services</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">May Require Evacuation</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Complex surgeries</li>
          <li>• Specialized oncology</li>
          <li>• Advanced cardiac care</li>
          <li>• Rare conditions</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Curaçao's @Home program?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      International policies covering the Caribbean work well in Curaçao. The Dutch connection also opens options through European insurers.
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Option</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Meets requirements, good for younger nomads with basic health needs.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Coverage</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care. Better for those wanting peace of mind and evacuation coverage.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU Citizens</h4>
        <p class="text-neutral-600">Check if your European health insurance extends to Curaçao (Kingdom of Netherlands), potentially simplifying coverage.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Curaçao offers more affordable Caribbean living than the Bahamas or Cayman Islands while maintaining high standards.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">$1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Basic apartment, cooking</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$2,800</p>
        <p class="text-sm text-neutral-500 mt-2">Nice place, dining out</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium</p>
        <p class="text-3xl font-bold text-neutral-900">$4,500+</p>
        <p class="text-sm text-neutral-500 mt-2">Waterfront, full lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost Comparison</h3>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <p class="text-green-800 mb-3">
        <strong>Curaçao vs. other Caribbean:</strong>
      </p>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>vs. Bahamas:</strong> 30-40% cheaper</li>
        <li>• <strong>vs. Cayman:</strong> 40-50% cheaper</li>
        <li>• <strong>vs. Barbados:</strong> Similar pricing</li>
        <li>• <strong>vs. Jamaica:</strong> 20-30% more expensive</li>
      </ul>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The @Home in Curaçao application is primarily online, though some nationalities may have additional steps.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Check Your Nationality Requirements</h4>
          <p class="text-neutral-600">EU/Dutch citizens have simplified access. US, Canadian, and most Western nationals can enter visa-free and apply. Others may need advance visa.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect proof of income ($3,000+/month), remote work verification, and police clearance from your home country.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get international health insurance covering Curaçao for your intended stay. Obtain certificate showing dates and coverage.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Submit your application through the @Home in Curaçao portal. Upload all documents and pay the application fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Processing typically takes 2-4 weeks. You'll receive email confirmation with your approval documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive in Curaçao</h4>
          <p class="text-neutral-600">Travel to Curaçao through Hato International Airport. Present your approval at immigration. Welcome home!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Dutch Developer, €4,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted Caribbean with Dutch connection and no hurricanes.</p>
        <p class="text-green-700 font-medium">✓ Perfect fit. Dutch spoken, familiar systems, amazing diving. Living in Pietermaai, loving the colorful architecture.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">US Designer, $4,500/month</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable Caribbean alternative to expensive islands.</p>
        <p class="text-green-700 font-medium">✓ Saving $1,500/month vs. Bahamas estimate. Great apartment in Willemstad. Beach every afternoon. Worth the longer flight.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Canadian Writer, $3,200/month</h3>
        <p class="text-neutral-600 mb-4">Just above threshold, escaping winter.</p>
        <p class="text-amber-700 font-medium">△ Qualified but budget-conscious. Found affordable place outside tourist area. Cooking most meals. Still better than Canadian winter.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Scuba Instructor/Remote Worker, $3,500/month</h3>
        <p class="text-neutral-600 mb-4">Diving enthusiast, wanted work + dive lifestyle.</p>
        <p class="text-green-700 font-medium">✓ Shore diving paradise. Working mornings, diving afternoons. 60+ dive sites accessible from shore. Dream come true.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">European Couple, €5,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Wanted EU-connected Caribbean experience together.</p>
        <p class="text-green-700 font-medium">✓ Dutch infrastructure feels familiar. Split costs work well. Renting beautiful place in Jan Thiel. Frequent KLM flights to Amsterdam.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Manager, $5,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted unique Caribbean destination off the beaten path.</p>
        <p class="text-green-700 font-medium">✓ Curaçao feels less touristy than other islands. Rich culture, great food scene, interesting history. Instagram-worthy everywhere.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Planning your Curaçao move? Compare insurance plans now.</p>
