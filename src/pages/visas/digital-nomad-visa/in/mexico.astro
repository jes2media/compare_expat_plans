---
/**
 * Mexico Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Mexico", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Mexico Health Insurance Guide", href: "/countries/mexico/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "$2,500+ USD/month (or ~$1,500 with savings)", evidence: "6 months bank statements" },
  { requirement: "Savings Alternative", details: "$45,000+ USD in savings", evidence: "Investment/bank statements" },
  { requirement: "Health Insurance", details: "Recommended but not mandatory", evidence: "Policy document if asked" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance may be required" },
  { requirement: "Remote Work", details: "Employed by non-Mexican company", evidence: "Employment letter or contracts" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Recommended Minimum" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "$100,000 USD", why: "Private hospital costs add up quickly" },
  { feature: "Emergency Evacuation", minimum: "$50,000 USD", why: "Transport to US hospitals if needed" },
  { feature: "Coverage Area", minimum: "Mexico + home country", why: "Flexibility for border runs" },
  { feature: "Outpatient Coverage", minimum: "Included", why: "Doctor visits without hospitalization" },
  { feature: "Pre-existing Conditions", minimum: "After waiting period", why: "Long-term residents need this" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget-conscious nomads" },
  { provider: "World Nomads", coverage: "$100,000", price: "$70-150", strengths: "Adventure activities included" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-400", strengths: "Comprehensive long-term coverage" },
  { provider: "GeoBlue", coverage: "$500,000", price: "$150-300", strengths: "US expats with US network access" },
  { provider: "BUPA Global", coverage: "$2,000,000+", price: "$300-500", strengths: "Premium hospital access" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$50-60", notes: "Paid at consulate" },
  { item: "Temporary Resident Card", amount: "$180-250", notes: "Paid at INM in Mexico" },
  { item: "Health Insurance (Annual)", amount: "$540-3,600", notes: "Varies by age and coverage" },
  { item: "Consulate Appointment", amount: "Free", notes: "But may require travel" },
  { item: "Document Translation", amount: "$50-150", notes: "If required by consulate" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Consulate appointment", duration: "1-4 weeks wait", location: "Mexican consulate" },
  { step: "Visa approval", duration: "1-10 business days", location: "Consulate" },
  { step: "Enter Mexico", duration: "Within 180 days", location: "Any port of entry" },
  { step: "Exchange at INM", duration: "30 days from entry", location: "INM office in Mexico" },
  { step: "Receive resident card", duration: "2-4 weeks", location: "Pick up at INM" },
];

const visaTypeColumns = [
  { key: "visa", header: "Visa Type" },
  { key: "duration", header: "Duration" },
  { key: "work", header: "Remote Work" },
  { key: "healthcare", header: "Healthcare Access" },
  { key: "best", header: "Best For" },
];

const visaTypeRows = [
  { visa: "Tourist Visa (FMM)", duration: "180 days", work: "Gray area", healthcare: "Private only", best: "Short stays, testing Mexico" },
  { visa: "Temporary Resident", duration: "1-4 years", work: "Yes, for foreign employers", healthcare: "IMSS eligible", best: "Long-term digital nomads" },
  { visa: "Permanent Resident", duration: "Indefinite", work: "Yes, any work", healthcare: "Full IMSS access", best: "Committing to Mexico" },
];
---

<PageShell
  title="Mexico Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Mexico's Temporary Resident Visa for remote workers. Learn insurance requirements, costs, and which providers meet official criteria."
  headline="Mexico Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about Mexico's Temporary Resident Visa—insurance requirements, costs, and how to apply successfully."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/mexico-hero-bg.png"
>
    <!-- Trust Signals -->
    <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
        Updated January 2025
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
        Official INM Requirements
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
        1,500+ Expats Helped
      </span>
    </div>

    <!-- Section: Overview -->
    <section id="overview" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

      <p class="mb-4">
        Mexico doesn't have a dedicated "digital nomad visa" like some countries. Instead, remote workers use the <strong>Temporary Resident Visa</strong>, which allows you to live in Mexico for 1-4 years while working remotely for non-Mexican companies.
      </p>

      <p class="mb-4">
        The good news? Mexico has one of the most accessible residency pathways in the world. The income requirements are reasonable, the process is straightforward, and the visa gives you real resident benefits including access to Mexico's social security healthcare system (IMSS).
      </p>

      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
        <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Mexico Temporary Resident Visa</h3>
        <ul class="space-y-2 text-primary-800">
          <li>• <strong>Duration:</strong> 1 year initially, renewable up to 4 years total</li>
          <li>• <strong>Income requirement:</strong> ~$2,500 USD/month or $45,000 savings</li>
          <li>• <strong>Processing time:</strong> 2-8 weeks total</li>
          <li>• <strong>Insurance:</strong> Not legally required, but strongly recommended</li>
          <li>• <strong>Work rights:</strong> Remote work for foreign employers allowed</li>
        </ul>
      </div>

      <h3 class="text-xl font-semibold text-neutral-900 mb-3">Visa Options Comparison</h3>

      <p class="mb-4">
        Many digital nomads start on a tourist visa to test Mexico before committing. Here's how your options compare:
      </p>

      <ComparisonTable columns={visaTypeColumns} rows={visaTypeRows} />

      <p class="mt-4">
        The tourist visa's 180-day limit works for short stays, but it doesn't provide legal clarity for remote work. The Temporary Resident visa gives you proper status and unlocks benefits like IMSS healthcare enrollment.
      </p>
    </section>

    <!-- Section: Quick Decision Guide -->
    <section id="quick-decision" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-semibold text-green-900 mb-3">Mexico's Temporary Resident Visa is Right For You If:</h3>
          <ul class="space-y-2 text-green-800">
            <li>✓ You earn $2,500+/month from remote work</li>
            <li>✓ You want to stay in Mexico long-term (1+ years)</li>
            <li>✓ You prefer low cost of living with good infrastructure</li>
            <li>✓ You value proximity to the US for trips home</li>
            <li>✓ You want access to quality, affordable healthcare</li>
            <li>✓ You enjoy vibrant culture and diverse landscapes</li>
          </ul>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
          <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
          <ul class="space-y-2 text-amber-800">
            <li>• You earn under $2,500/month and have limited savings</li>
            <li>• You need to work for Mexican clients (requires work permit)</li>
            <li>• You prefer European time zones for work</li>
            <li>• Safety concerns are a dealbreaker for you</li>
            <li>• You want to stay less than 6 months</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Section: Visa Requirements -->
    <section id="requirements" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

      <p class="mb-4">
        Mexico's Temporary Resident visa has clear financial requirements. Unlike some countries, they focus on proof of stable income or sufficient savings—not specific documentation like employment contracts.
      </p>

      <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

      <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Thresholds</h3>

      <p class="mb-4">
        The income requirements are tied to Mexico's minimum wage and updated periodically. As of 2025, you'll need to show approximately:
      </p>

      <ul class="list-disc pl-6 space-y-2 mb-6">
        <li><strong>Monthly income route:</strong> ~$2,500 USD/month for the past 6 months</li>
        <li><strong>Savings route:</strong> ~$45,000 USD average balance for 12 months</li>
        <li><strong>Combination:</strong> Lower income + savings may work at consulate discretion</li>
      </ul>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
        <p class="text-amber-800">
          <strong>Important:</strong> Requirements vary by consulate. Some are stricter than others. Check your specific consulate's requirements before applying—they may ask for higher amounts or different documentation.
        </p>
      </div>

      <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

      <ul class="list-disc pl-6 space-y-2">
        <li>Valid passport (6+ months validity, blank pages)</li>
        <li>Completed visa application form</li>
        <li>Passport-sized photos (consulate specifications)</li>
        <li>Proof of income: 6 months of bank statements</li>
        <li>Employment verification letter or freelance contracts</li>
        <li>Proof of address in home country</li>
        <li>Travel itinerary (some consulates)</li>
      </ul>
    </section>

    <!-- Section: Insurance Requirements -->
    <section id="insurance-requirements" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">The Key Difference</h3>
        <p class="text-blue-800">
          Unlike Spain or Portugal, Mexico does <strong>not</strong> legally require health insurance for the Temporary Resident visa. However, insurance is still essential for practical reasons—and some consulates may ask for proof anyway.
        </p>
      </div>

      <p class="mb-4">
        While you can technically get the visa without insurance, going without coverage in Mexico is risky. Private hospital stays can cost $1,000-5,000+ per night, and you won't have IMSS access immediately after arrival.
      </p>

      <h3 class="text-xl font-semibold text-neutral-900 mb-3">Recommended Coverage Levels</h3>

      <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

      <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">IMSS vs Private Insurance</h3>

      <p class="mb-4">
        As a temporary resident, you're eligible to enroll in IMSS (Mexico's social security healthcare). Here's how they compare:
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="border border-neutral-200 rounded-lg p-6">
          <h4 class="font-semibold text-neutral-900 mb-3">IMSS (Public Healthcare)</h4>
          <ul class="space-y-2 text-neutral-700">
            <li>• <strong>Cost:</strong> ~$400-600 USD/year</li>
            <li>• <strong>Coverage:</strong> Comprehensive including medications</li>
            <li>• <strong>Wait times:</strong> Can be long for non-emergencies</li>
            <li>• <strong>Language:</strong> Spanish required</li>
            <li>• <strong>Quality:</strong> Varies by location</li>
          </ul>
        </div>

        <div class="border border-neutral-200 rounded-lg p-6">
          <h4 class="font-semibold text-neutral-900 mb-3">Private Insurance</h4>
          <ul class="space-y-2 text-neutral-700">
            <li>• <strong>Cost:</strong> $1,000-5,000+ USD/year</li>
            <li>• <strong>Coverage:</strong> Depends on plan</li>
            <li>• <strong>Wait times:</strong> Minimal</li>
            <li>• <strong>Language:</strong> English available</li>
            <li>• <strong>Quality:</strong> Consistent high standard</li>
          </ul>
        </div>
      </div>

      <p class="mb-4">
        Many expats use a hybrid approach: IMSS for routine care and prescriptions, private insurance for major medical events and hospital stays. This keeps costs low while ensuring quality care when it matters most.
      </p>
    </section>

    <!-- CTA Box -->
    <CTABox variant="highlight">
      <p class="mb-4">Ready to find the right insurance for your Mexico move?</p>
      <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
        Compare Plans Now →
      </a>
    </CTABox>

    <!-- Section: Recommended Providers -->
    <section id="recommended-providers" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

      <p class="mb-4">
        Since Mexico doesn't mandate specific coverage levels, you have flexibility in choosing a plan. Here are providers that work well for digital nomads in Mexico:
      </p>

      <ComparisonTable columns={providerColumns} rows={providerRows} />

      <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

      <div class="space-y-4">
        <div class="border-l-4 border-green-500 pl-4">
          <h4 class="font-semibold text-neutral-900">Budget-Focused Nomads</h4>
          <p class="text-neutral-600">SafetyWing or World Nomads. Pair with IMSS enrollment for comprehensive coverage at low cost.</p>
        </div>

        <div class="border-l-4 border-blue-500 pl-4">
          <h4 class="font-semibold text-neutral-900">US Citizens Planning Border Runs</h4>
          <p class="text-neutral-600">GeoBlue provides seamless US coverage. Useful if you're visiting family or need US-based care.</p>
        </div>

        <div class="border-l-4 border-purple-500 pl-4">
          <h4 class="font-semibold text-neutral-900">Long-Term Residents (2+ Years)</h4>
          <p class="text-neutral-600">Cigna Global or BUPA Global. Worth the investment for comprehensive coverage and no coverage gaps.</p>
        </div>

        <div class="border-l-4 border-amber-500 pl-4">
          <h4 class="font-semibold text-neutral-900">Families with Children</h4>
          <p class="text-neutral-600">Cigna Global family plans. Maternity coverage available with waiting periods.</p>
        </div>
      </div>
    </section>

    <!-- Section: Costs Breakdown -->
    <section id="costs" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

      <p class="mb-4">
        Mexico's visa fees are among the lowest for residency programs. Here's what to budget for the application process:
      </p>

      <ComparisonTable columns={costColumns} rows={costRows} />

      <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

      <div class="grid md:grid-cols-3 gap-6 mb-6">
        <div class="bg-neutral-50 rounded-lg p-6 text-center">
          <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
          <p class="text-3xl font-bold text-neutral-900">$750</p>
          <p class="text-sm text-neutral-500 mt-2">Visa + basic travel insurance</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-6 text-center">
          <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
          <p class="text-3xl font-bold text-neutral-900">$1,500</p>
          <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier insurance + IMSS</p>
        </div>
        <div class="bg-neutral-50 rounded-lg p-6 text-center">
          <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
          <p class="text-3xl font-bold text-neutral-900">$4,500</p>
          <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive global coverage</p>
        </div>
      </div>

      <h3 class="text-xl font-semibold text-neutral-900 mb-3">Renewal Costs</h3>

      <p class="mb-4">
        Renewing your Temporary Resident status is simpler than the initial application. You'll pay approximately $200-300 USD at INM for each annual renewal. After 4 years, you're eligible for Permanent Residency.
      </p>
    </section>

    <!-- Section: Application Process -->
    <section id="application" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

      <p class="mb-4">
        Mexico's visa process involves two main steps: getting the visa at a consulate abroad, then exchanging it for a resident card at INM in Mexico.
      </p>

      <ComparisonTable columns={timelineColumns} rows={timelineRows} />

      <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div>
            <h4 class="font-semibold text-neutral-900">Book Consulate Appointment</h4>
            <p class="text-neutral-600">Schedule online at your nearest Mexican consulate. Appointment availability varies—some consulates have weeks-long waits. Book early.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div>
            <h4 class="font-semibold text-neutral-900">Gather Financial Documents</h4>
            <p class="text-neutral-600">Get 6 months of bank statements showing income deposits. Statements should clearly show your name, account number, and transaction history.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div>
            <h4 class="font-semibold text-neutral-900">Attend Consulate Interview</h4>
            <p class="text-neutral-600">Bring all documents, application form, photos, and visa fee. The interview is usually brief—they'll verify documents and ask about your plans.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
          <div>
            <h4 class="font-semibold text-neutral-900">Receive Visa Stamp</h4>
            <p class="text-neutral-600">If approved, you'll get a visa sticker in your passport. This is valid for 180 days to enter Mexico—it's not your residence permit yet.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
          <div>
            <h4 class="font-semibold text-neutral-900">Enter Mexico and Visit INM</h4>
            <p class="text-neutral-600">Within 30 days of entry, go to your local INM office to exchange the visa for a Temporary Resident Card. Bring your passport, the visa, and proof of address in Mexico.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
          <div>
            <h4 class="font-semibold text-neutral-900">Receive Resident Card</h4>
            <p class="text-neutral-600">After fingerprinting and payment, you'll receive your card in 2-4 weeks. This is your official proof of residency.</p>
          </div>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
        <p class="text-blue-800">
          <strong>Pro tip:</strong> Choose your consulate strategically. Some (like Houston, Denver) are known for faster processing. Others (like LA, NYC) have longer wait times.
        </p>
      </div>
    </section>

    <!-- Section: Real-World Scenarios -->
    <section id="scenarios" class="scroll-mt-24 mb-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

      <p class="mb-6">
        Here's how different digital nomad situations typically play out with Mexico's Temporary Resident visa:
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="border border-neutral-200 rounded-lg p-6">
          <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $8,000/month</h3>
          <p class="text-neutral-600 mb-4">W-2 employee for US company, wants to live in Mexico City for 2+ years.</p>
          <p class="text-green-700 font-medium">✓ Approved easily. Income far exceeds requirements. Used employment letter and bank statements.</p>
        </div>

        <div class="border border-neutral-200 rounded-lg p-6">
          <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $2,000/month</h3>
          <p class="text-neutral-600 mb-4">Variable income from multiple clients, limited savings.</p>
          <p class="text-amber-700 font-medium">△ Conditional. Income slightly below threshold. Had to show $30,000 savings as supplement.</p>
        </div>

        <div class="border border-neutral-200 rounded-lg p-6">
          <h3 class="font-semibold text-neutral-900 mb-2">Retired Couple, $4,000/month pension</h3>
          <p class="text-neutral-600 mb-4">Selling US home, want to retire in Guanajuato.</p>
          <p class="text-green-700 font-medium">✓ Approved. Pension income qualifies. Applied for two separate visas at same appointment.</p>
        </div>

        <div class="border border-neutral-200 rounded-lg p-6">
