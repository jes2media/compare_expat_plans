---
/**
 * Hungary Digital Nomad Visa (White Card) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Hungary", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Hungary Health Insurance Guide", href: "/countries/hungary/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€2,000/month minimum", evidence: "Bank statements, contracts" },
  { requirement: "Savings Alternative", details: "€6,000+ in bank account", evidence: "Bank statement" },
  { requirement: "Remote Work", details: "Work for non-Hungarian employer", evidence: "Employment contract" },
  { requirement: "Health Insurance", details: "Mandatory comprehensive coverage", evidence: "Insurance certificate" },
  { requirement: "Accommodation", details: "Proof of housing in Hungary", evidence: "Rental agreement or booking" },
  { requirement: "Valid Passport", details: "Valid for duration of stay", evidence: "Passport copy" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Hungary Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "€30,000+ (Schengen)", why: "EU minimum standard" },
  { feature: "Repatriation", minimum: "Required", why: "Return transport coverage" },
  { feature: "Coverage Duration", minimum: "Full visa period", why: "No gaps allowed" },
  { feature: "EU/Schengen Area", minimum: "Must be covered", why: "Travel within Schengen" },
  { feature: "Emergency Care", minimum: "Included", why: "24/7 access required" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive coverage" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-300", strengths: "Strong EU network" },
  { provider: "Feather", coverage: "Varies", price: "€80-180", strengths: "EU expat specialist" },
  { provider: "IMG Global", coverage: "€1,000,000", price: "€100-200", strengths: "Mid-range coverage" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "White Card Application", amount: "€110", notes: "Online application fee" },
  { item: "Residence Permit Card", amount: "€40-60", notes: "Physical card production" },
  { item: "Health Insurance (Annual)", amount: "€500-3,000", notes: "Schengen-compliant" },
  { item: "Document Translation", amount: "€50-150", notes: "If required" },
  { item: "Address Registration", amount: "Free", notes: "Required within 30 days" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Online application", duration: "1-2 hours", location: "Enter Hungary portal" },
  { step: "Processing", duration: "21-30 days", location: "Immigration authority" },
  { step: "Receive decision", duration: "Via email", location: "Online notification" },
  { step: "Enter Hungary", duration: "Within 90 days", location: "Any entry point" },
  { step: "Collect residence card", duration: "Within 30 days", location: "Local immigration office" },
  { step: "Register address", duration: "Within 30 days", location: "Local government office" },
];
---

<PageShell
  title="Hungary Digital Nomad Visa (White Card) 2026: Insurance & Complete Guide"
  description="Complete guide to Hungary's White Card for digital nomads. Affordable Budapest living, €2,000 income threshold, Schengen access, and step-by-step application."
  headline="Hungary White Card: Insurance & Requirements Guide"
  subheadline="Everything you need to know about Hungary's digital nomad visa—affordable Central European living with Schengen benefits."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/hungary-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Immigration Authority
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU/Schengen Member
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Hungary launched its "White Card" digital nomad visa in January 2022, creating one of Europe's most accessible pathways for remote workers. With a €2,000/month income requirement and affordable living costs, Hungary offers exceptional value in the heart of Central Europe.
    </p>

    <p class="mb-4">
      Budapest has become a digital nomad hotspot for good reason: stunning architecture, vibrant nightlife, thermal baths, excellent internet, and living costs that stretch your earnings further than Western Europe. The White Card makes this lifestyle officially accessible.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Hungary White Card</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year (renewable for 1 additional year)</li>
        <li>• <strong>Income requirement:</strong> €2,000/month or €6,000 savings</li>
        <li>• <strong>Processing time:</strong> 21-30 days typical</li>
        <li>• <strong>Insurance:</strong> Mandatory Schengen-compliant</li>
        <li>• <strong>Application:</strong> Fully online process</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Hungary for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Affordable living:</strong> Western quality at Eastern European prices</li>
      <li><strong>Fast internet:</strong> Hungary has excellent fiber coverage</li>
      <li><strong>Central location:</strong> Easy flights to anywhere in Europe</li>
      <li><strong>Schengen access:</strong> Travel freely across 27 European countries</li>
      <li><strong>Digital-friendly:</strong> Fully online application process</li>
      <li><strong>Vibrant expat scene:</strong> Large international community in Budapest</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Hungary is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €2,000+/month from remote work</li>
          <li>✓ You want affordable European living</li>
          <li>✓ You prefer a digital-first application</li>
          <li>✓ You enjoy city life with nightlife</li>
          <li>✓ You want central European base</li>
          <li>✓ You appreciate history and architecture</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want Mediterranean beaches</li>
          <li>• You need English everywhere</li>
          <li>• You prefer warmer climates</li>
          <li>• You want path to permanent residency</li>
          <li>• You need more than 2 years total</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Hungary's White Card has one of the lowest income thresholds in the EU at €2,000/month. Alternatively, you can qualify with €6,000 in savings—making this accessible even for newer remote workers.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification Options</h3>

    <p class="mb-4">
      Hungary offers flexibility in how you prove financial stability:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-2">Option A: Monthly Income</h4>
        <ul class="space-y-2 text-green-800">
          <li>• Show €2,000/month income</li>
          <li>• Employment contracts or invoices</li>
          <li>• 3-6 months of bank statements</li>
        </ul>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-2">Option B: Savings</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Show €6,000+ in bank account</li>
          <li>• Single bank statement sufficient</li>
          <li>• Good for variable income earners</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport</li>
      <li>Completed online application</li>
      <li>Passport photo (digital)</li>
      <li>Proof of income or savings</li>
      <li>Health insurance certificate</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Proof of accommodation</li>
      <li>Criminal record certificate (some nationalities)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Schengen Standards Apply</h3>
      <p class="text-blue-800">
        As an EU/Schengen member, Hungary requires health insurance meeting Schengen standards: minimum €30,000 coverage, repatriation, and full duration coverage.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for the White Card. Your policy must meet EU standards and cover your entire planned stay in Hungary and the Schengen area.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Hungarian Healthcare Context</h3>

    <p class="mb-4">
      Hungary has universal healthcare for residents, but White Card holders don't automatically qualify. You'll rely on private insurance, which gives you access to excellent private facilities in Budapest.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Not for White Card holders</li>
          <li>• <strong>Emergency:</strong> Will treat, bill later</li>
          <li>• <strong>Quality:</strong> Variable, long waits common</li>
          <li>• <strong>Language:</strong> Hungarian primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With international insurance</li>
          <li>• <strong>Quality:</strong> Excellent in Budapest</li>
          <li>• <strong>Language:</strong> English widely available</li>
          <li>• <strong>Cost:</strong> Very affordable by EU standards</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need Schengen-compliant insurance for Hungary?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer Schengen-compliant coverage suitable for Hungary's White Card:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €40-75/month. Best value for Hungary's low cost of living.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Coverage</h4>
        <p class="text-neutral-600">Allianz Care or Feather. Designed for EU expats with strong regional networks.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage including travel outside Europe.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Mid-Range Value</h4>
        <p class="text-neutral-600">IMG Global. Solid coverage at moderate prices, good for balanced needs.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Hungary's White Card is remarkably affordable—both in visa fees and overall living costs. It's one of the best-value nomad visas in Europe.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€650</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€3,200</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive plan</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living in Budapest</h3>

    <p class="mb-4">
      Budapest offers Western European quality at significantly lower costs. Your remote income stretches much further here than in Germany, France, or the Netherlands.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> €1,000-1,400/month (shared flat, cooking)</li>
      <li><strong>Comfortable:</strong> €1,800-2,500/month (own apartment, dining out)</li>
      <li><strong>Premium:</strong> €3,000+/month (central location, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Hungary's White Card application is fully online through the "Enter Hungary" portal. This digital-first approach makes it one of the easiest nomad visas to apply for.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Create Account</h4>
          <p class="text-neutral-600">Register on the Enter Hungary portal (enterhungary.gov.hu). Verify your email.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete Application</h4>
          <p class="text-neutral-600">Fill out the online form. Select "White Card" as your permit type. Upload all required documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Fee Online</h4>
          <p class="text-neutral-600">Pay the €110 application fee via the portal. Payment confirmation is immediate.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 21-30 days. Track status through the portal. May request additional documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Travel & Register</h4>
          <p class="text-neutral-600">Enter Hungary within 90 days. Register your address and collect your physical residence card within 30 days.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The entire application can be done from anywhere—you don't need to visit an embassy. Just ensure your documents are clear scans and properly formatted.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Hungary's White Card:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Junior Developer, €2,500/month</h3>
        <p class="text-neutral-600 mb-4">Entry-level remote job with US company, wants affordable EU base.</p>
        <p class="text-green-700 font-medium">✓ Approved quickly. Income exceeds threshold, online application smooth.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, variable income</h3>
        <p class="text-neutral-600 mb-4">Some months €3,000, others €1,500. Has €8,000 in savings.</p>
        <p class="text-green-700 font-medium">✓ Approved using savings option. €8,000 exceeds €6,000 minimum.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Social Media Manager, €1,800/month</h3>
        <p class="text-neutral-600 mb-4">Just below income threshold, minimal savings.</p>
        <p class="text-red-700 font-medium">✗ Denied. €200 below income threshold and insufficient savings. Advised to build savings first.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, €4,000/month</h3>
        <p class="text-neutral-600 mb-4">Employed remotely, wants Budapest's vibrant scene.</p>
        <p class="text-green-700 font-medium">✓ Approved within 3 weeks. Strong application, clear documentation.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Creator, €2,200/month</h3>
        <p class="text-neutral-600 mb-4">YouTube and sponsorship income, wants to explore ruin bars.</p>
        <p class="text-amber-700 font-medium">△ Requested additional docs. Needed clearer income breakdown from multiple sources.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, €3,500/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, one earns €2,100, other €1,400.</p>
        <p class="text-green-700 font-medium">✓ Applied separately. Main earner approved on income, partner used savings option.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Compare insurance plans for your Hungarian adventure—get quotes in minutes.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
    </a>
