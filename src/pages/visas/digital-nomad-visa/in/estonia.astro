---
/**
 * Estonia Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Estonia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Estonia Health Insurance Guide", href: "/countries/estonia/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€3,504/month (6-month average)", evidence: "Bank statements, contracts" },
  { requirement: "Remote Work", details: "Work for company outside Estonia", evidence: "Employment contract" },
  { requirement: "Health Insurance", details: "Mandatory Schengen-compliant", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "3+ months beyond stay", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "May be requested" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Estonia Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "€30,000+ (Schengen)", why: "EU minimum standard" },
  { feature: "Repatriation", minimum: "Required", why: "Return transport coverage" },
  { feature: "Coverage Duration", minimum: "Full visa period", why: "No gaps allowed" },
  { feature: "EU/Schengen Area", minimum: "Must be covered", why: "Travel within EU" },
  { feature: "Emergency Care", minimum: "Included", why: "24/7 access required" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive coverage" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-300", strengths: "EU-focused" },
  { provider: "BUPA Global", coverage: "€2,000,000+", price: "€280-450", strengths: "Premium coverage" },
  { provider: "Feather", coverage: "Varies", price: "€80-180", strengths: "EU expat specialist" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€80-100", notes: "Embassy/consulate" },
  { item: "Residence Permit", amount: "€64-96", notes: "If staying 1 year" },
  { item: "Health Insurance (Annual)", amount: "€500-3,500", notes: "Schengen-compliant" },
  { item: "e-Residency Card", amount: "€100-120", notes: "Optional, for business" },
  { item: "Document Apostille", amount: "€20-50", notes: "If required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit application", duration: "1 day", location: "Estonian embassy or online" },
  { step: "Processing", duration: "15-30 days", location: "Police and Border Guard" },
  { step: "Receive decision", duration: "Via email", location: "Digital notification" },
  { step: "Collect visa", duration: "1-5 days", location: "Embassy or in Estonia" },
  { step: "Enter Estonia", duration: "Within validity", location: "Any Schengen entry" },
];
---

<PageShell
  title="Estonia Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Estonia's Digital Nomad Visa. The world's most digital country, €3,504 income requirement, e-Residency benefits, and application process."
  headline="Estonia Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the world's most digital nation—insurance requirements, costs, and e-Estonia lifestyle."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Police & Border Guard
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU/Schengen Member
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Estonia was the first country in the world to launch a dedicated Digital Nomad Visa in June 2020. Known as the world's most digitally advanced nation, Estonia pioneered e-Residency and now welcomes remote workers with a visa designed specifically for location-independent professionals.
    </p>

    <p class="mb-4">
      Estonia offers what tech-focused nomads love: blazing fast internet, a fully digital government, startup culture, and Schengen access. The capital Tallinn combines medieval charm with cutting-edge tech infrastructure—a unique combination for digital workers.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Estonia Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> Up to 1 year</li>
        <li>• <strong>Income requirement:</strong> €3,504/month (6-month average)</li>
        <li>• <strong>Processing time:</strong> 15-30 days typical</li>
        <li>• <strong>Insurance:</strong> Mandatory Schengen-compliant</li>
        <li>• <strong>Bonus:</strong> e-Residency available for EU business setup</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Estonia for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Digital infrastructure:</strong> 99% of government services online, free public WiFi everywhere</li>
      <li><strong>Tech ecosystem:</strong> Birthplace of Skype, TransferWise (Wise), Bolt</li>
      <li><strong>e-Residency:</strong> Run an EU company from anywhere in the world</li>
      <li><strong>Schengen access:</strong> Travel freely across 27 European countries</li>
      <li><strong>English proficiency:</strong> One of the highest in continental Europe</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Estonia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €3,500+/month from remote work</li>
          <li>✓ You value fast internet and digital services</li>
          <li>✓ You want to establish an EU business (e-Residency)</li>
          <li>✓ You prefer European time zones</li>
          <li>✓ You enjoy four distinct seasons</li>
          <li>✓ You appreciate Nordic/Baltic culture</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want warm weather year-round</li>
          <li>• You prefer a larger nomad community</li>
          <li>• You're looking for very low cost of living</li>
          <li>• You work Americas time zones primarily</li>
          <li>• You want beach or tropical lifestyle</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Estonia's Digital Nomad Visa has clear requirements focused on proving stable remote work income. The €3,504/month threshold is based on average Estonian wages.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate €3,504/month average income over the past 6 months. Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 6 months showing consistent deposits</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>For freelancers:</strong> Client contracts and invoices</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Two Visa Types:</strong> Estonia offers both a short-stay visa (Type C, up to 90 days) and long-stay visa (Type D, up to 1 year). Most nomads apply for the Type D for maximum flexibility.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (3+ months beyond intended stay)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (Schengen specifications)</li>
      <li>Proof of income (€3,504/month average)</li>
      <li>Health insurance certificate (Schengen-compliant)</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Proof of accommodation (if available)</li>
      <li>Travel itinerary</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Schengen Standards Apply</h3>
      <p class="text-blue-800">
        As an EU/Schengen country, Estonia requires health insurance meeting Schengen visa standards: minimum €30,000 coverage, repatriation, and coverage for your entire stay.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for the Estonia Digital Nomad Visa. Your policy must meet EU standards and cover the full duration of your planned stay.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Estonian Healthcare Context</h3>

    <p class="mb-4">
      Estonia has universal healthcare for residents, but digital nomads aren't automatically enrolled. You'll rely on private insurance and private healthcare facilities.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (EHIF)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Not for DN visa holders</li>
          <li>• <strong>Emergency:</strong> Will treat, bill later</li>
          <li>• <strong>Quality:</strong> Good, EU standards</li>
          <li>• <strong>Language:</strong> Estonian/Russian primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With international insurance</li>
          <li>• <strong>Quality:</strong> Excellent in Tallinn</li>
          <li>• <strong>Language:</strong> English available</li>
          <li>• <strong>Cost:</strong> Moderate by EU standards</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need Schengen-compliant insurance for Estonia?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer Schengen-compliant coverage suitable for Estonia's Digital Nomad Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €40-75/month. Meets Schengen requirements at the lowest cost.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Coverage</h4>
        <p class="text-neutral-600">Allianz Care or Feather. Strong European networks, designed for EU expats.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage including trips outside Europe.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">BUPA Global. Top-tier coverage with excellent customer service.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Estonia's visa fees are reasonable. The main costs are insurance and living expenses in Tallinn.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€700</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With e-Residency</p>
        <p class="text-3xl font-bold text-neutral-900">€2,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + insurance + e-Residency</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Tallinn is affordable by Western European standards but pricier than Eastern Europe. Monthly budgets:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> €1,500-2,000/month (shared housing, cooking)</li>
      <li><strong>Comfortable:</strong> €2,500-3,500/month (own apartment, dining out)</li>
      <li><strong>Premium:</strong> €4,000+/month (central location, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Estonia's application process reflects its digital-first approach. Much can be done online, though you'll need to submit documents at an embassy.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documentation</h4>
          <p class="text-neutral-600">Gather 6 months of income proof, insurance certificate, passport, and photos. Complete the application form online.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Book Embassy Appointment</h4>
          <p class="text-neutral-600">Schedule an appointment at your nearest Estonian embassy or consulate for document submission.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Attend appointment with all documents. Pay the application fee. Provide biometrics if required.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 15-30 days. The Police and Border Guard Board reviews applications.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect Visa & Travel</h4>
          <p class="text-neutral-600">Pick up your visa at the embassy. Enter Estonia or any Schengen country within the validity period.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Consider applying for e-Residency separately if you want to run an EU business. It's a different program but complements the DN visa nicely.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Estonia's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, €6,000/month</h3>
        <p class="text-neutral-600 mb-4">Works for UK tech company, interested in e-Residency for side projects.</p>
        <p class="text-green-700 font-medium">✓ Approved quickly. Income far exceeds threshold. Applied for e-Residency separately.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, €4,000/month</h3>
        <p class="text-neutral-600 mb-4">Freelancer with multiple clients, wants Nordic lifestyle.</p>
        <p class="text-green-700 font-medium">✓ Approved. Provided client contracts and 6 months of bank statements.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Writer, €2,800/month</h3>
        <p class="text-neutral-600 mb-4">Steady income but below threshold.</p>
        <p class="text-red-700 font-medium">✗ Denied. €704 below €3,504 requirement. Advised to increase income before reapplying.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Startup Founder, variable income</h3>
        <p class="text-neutral-600 mb-4">Some months €8,000, others €2,000. Averaging €4,500.</p>
        <p class="text-green-700 font-medium">✓ Approved. 6-month average exceeded threshold despite variation.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Consultant, €5,500/month</h3>
        <p class="text-neutral-600 mb-4">Already has e-Residency, wants to actually live in Estonia.</p>
        <p class="text-green-700 font-medium">✓ Approved. e-Residency and DN visa are separate but complementary.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, €7,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, one earns €4,000, other €3,000.</p>
        <p class="text-amber-700 font-medium">△ Applied separately. One approved, other just below threshold—had to show additional contracts.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Compare insurance plans for your Estonia move—get quotes in minutes.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
    </a>
  </CTABox>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Confusing e-Residency with Visa</h3>
        <p class="text-neutral-600">e-Residency is for digital business, not physical residency. You still need the DN visa to live in Estonia. They're separate programs.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Insufficient Insurance</h3>
        <p class="text-neutral-600">Travel insurance or policies below €30,000 coverage will be rejected. Ensure Schengen compliance with repatriation coverage.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Missing the Income Average</h3>
        <p class="text-neutral-600">It's €3,504/month averaged over 6 months. A few good months don't help if the average is below threshold.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Underestimating Winter</h3>
        <p class="text-neutral-600">Estonian winters are dark and cold (as low as -20°C). If you're from a warm climate, plan for significant adjustment.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Not Registering Address</h3>
        <p class="text-neutral-600">You must register your address with local authorities. This enables access to various services and is legally required.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Expecting Nightlife</h3>
        <p class="text-neutral-600">Tallinn has some bars and clubs, but it's not a party destination. If vibrant nightlife is important, consider other locations.</p>
      </div>
    </div>
