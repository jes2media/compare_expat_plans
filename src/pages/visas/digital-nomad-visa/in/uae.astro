---
/**
 * UAE Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in the UAE", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "UAE Health Insurance Guide", href: "/countries/uae/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "$3,500 USD/month minimum", evidence: "3 months bank statements" },
  { requirement: "Employment Status", details: "Employed or self-employed", evidence: "Employment contract or business license" },
  { requirement: "Health Insurance", details: "Mandatory UAE-valid coverage", evidence: "Insurance policy certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Photo", details: "White background passport photo", evidence: "Digital file required" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "UAE Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "AED 150,000+ (~$40,000)", why: "DHA/HAAD minimum standard" },
  { feature: "Coverage Area", minimum: "UAE mandatory", why: "Must cover treatment in UAE" },
  { feature: "Inpatient Coverage", minimum: "Required", why: "Hospital stays covered" },
  { feature: "Outpatient Coverage", minimum: "Usually required", why: "Doctor visits, diagnostics" },
  { feature: "Emergency Care", minimum: "Required", why: "24/7 emergency access" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "uae", header: "UAE Status" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-400", uae: "Widely accepted" },
  { provider: "BUPA Global", coverage: "$2,000,000+", price: "$300-550", uae: "Premium choice" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$180-350", uae: "Good network" },
  { provider: "Aetna International", coverage: "$1,000,000+", price: "$250-450", uae: "Strong US ties" },
  { provider: "Now Health", coverage: "$1,500,000", price: "$200-380", uae: "Asia-Pacific focus" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$287 (AED 1,055)", notes: "Government fee" },
  { item: "Emirates ID", amount: "$70 (AED 270)", notes: "Biometric ID card" },
  { item: "Medical Fitness Test", amount: "$80-150", notes: "Required health screening" },
  { item: "Health Insurance (Annual)", amount: "$1,200-5,500", notes: "UAE-compliant required" },
  { item: "Establishment Card (if freelance)", amount: "$500-2,000", notes: "For self-employed" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Online application", duration: "1-2 hours", location: "GDRFA/ICP portal" },
  { step: "Document upload", duration: "Same day", location: "Online" },
  { step: "Initial approval", duration: "5-7 business days", location: "Online" },
  { step: "Entry to UAE", duration: "Within 60 days", location: "Dubai/Abu Dhabi" },
  { step: "Medical fitness test", duration: "1-2 days", location: "Approved centers" },
  { step: "Emirates ID application", duration: "1 day", location: "Typing center" },
  { step: "Final visa stamp", duration: "3-7 days", location: "GDRFA office" },
];

const visaTypeColumns = [
  { key: "visa", header: "Visa Type" },
  { key: "duration", header: "Duration" },
  { key: "income", header: "Income Req" },
  { key: "best", header: "Best For" },
];

const visaTypeRows = [
  { visa: "Virtual Working Visa (Dubai)", duration: "1 year", income: "$3,500/mo", best: "Remote workers, Dubai base" },
  { visa: "Freelancer Visa", duration: "1-3 years", income: "Varies", best: "Self-employed, need UAE clients" },
  { visa: "Golden Visa", duration: "10 years", income: "Investment required", best: "High net worth, investors" },
  { visa: "Green Visa", duration: "5 years", income: "Varies", best: "Skilled professionals, investors" },
];

const emirateColumns = [
  { key: "emirate", header: "Emirate" },
  { key: "visa", header: "DN Visa Name" },
  { key: "cost", header: "Approx Cost" },
  { key: "notes", header: "Key Notes" },
];

const emirateRows = [
  { emirate: "Dubai", visa: "Virtual Working Program", cost: "$287/year", notes: "Most popular, streamlined process" },
  { emirate: "Abu Dhabi", visa: "Remote Work Visa", cost: "Similar", notes: "Alternative if Dubai capacity full" },
  { emirate: "Ras Al Khaimah", visa: "Remote Working Visa", cost: "$150-250", notes: "Lower cost option" },
];
---

<PageShell
  title="UAE Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to UAE's Virtual Working Visa for Dubai and other emirates. Insurance requirements, $3,500 income threshold, and application process."
  headline="UAE Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from Dubai and the UAE—insurance requirements, costs, and how to apply."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/uae-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official GDRFA Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      1,000+ Expats Helped
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The UAE launched its Digital Nomad Visa program in 2020, with Dubai's "Virtual Working Program" becoming the most popular option. The visa allows remote workers to live in the UAE while working for employers outside the country—enjoying tax-free income, world-class infrastructure, and a strategic location between Europe and Asia.
    </p>

    <p class="mb-4">
      The UAE offers the unique combination of zero income tax, exceptional safety, and luxury living standards. It's positioned as a premium destination for digital nomads who can meet the $3,500/month income threshold and want to maximize their take-home pay.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: UAE Virtual Working Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year, renewable</li>
        <li>• <strong>Income requirement:</strong> $3,500 USD/month (~AED 13,000)</li>
        <li>• <strong>Processing time:</strong> 5-14 business days typical</li>
        <li>• <strong>Insurance:</strong> Mandatory UAE-compliant coverage</li>
        <li>• <strong>Tax status:</strong> 0% income tax on foreign earnings</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Visa Options by Emirate</h3>

    <p class="mb-4">
      Each emirate has its own digital nomad program. Dubai is most popular, but alternatives exist:
    </p>

    <ComparisonTable columns={emirateColumns} rows={emirateRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">UAE Visa Options Comparison</h3>

    <p class="mb-4">
      Beyond the digital nomad visa, the UAE offers several residency pathways:
    </p>

    <ComparisonTable columns={visaTypeColumns} rows={visaTypeRows} />

    <p class="mt-4">
      The Virtual Working Visa is designed specifically for remote workers employed outside the UAE. If you want to work with UAE clients or start a business, you'll need a freelancer visa or business license instead.
    </p>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">UAE is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn $3,500+/month and want tax-free income</li>
          <li>✓ You value safety, infrastructure, and luxury</li>
          <li>✓ You work with Europe, Asia, or Africa time zones</li>
          <li>✓ You want a central hub for global travel</li>
          <li>✓ You can afford higher cost of living</li>
          <li>✓ You're comfortable in cosmopolitan, modern cities</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You prefer natural landscapes over urban environments</li>
          <li>• You want low cost of living</li>
          <li>• You work primarily with Americas time zones</li>
          <li>• You're looking for cultural immersion</li>
          <li>• You prefer nightlife and liberal social environment</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The UAE's Virtual Working Visa requirements are straightforward. The $3,500/month income threshold is higher than many countries, but reflects the premium positioning of the destination.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You'll need to demonstrate $3,500 USD monthly income (approximately AED 13,000). Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary of $3,500+ monthly</li>
      <li><strong>Bank statements:</strong> 3 months showing consistent deposits</li>
      <li><strong>Pay stubs:</strong> Recent payslips from employer</li>
      <li><strong>Business income:</strong> If self-employed, profit statements or contracts</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Self-Employed:</strong> Freelancers need to show consistent income through contracts and bank statements. Variable income is acceptable if the average exceeds the threshold.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity, clean pages)</li>
      <li>Passport-sized photo (white background, digital)</li>
      <li>Proof of income (contract, bank statements, pay stubs)</li>
      <li>Health insurance certificate (UAE-compliant)</li>
      <li>Employment letter or proof of self-employment</li>
      <li>Completed online application form</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Mandatory Requirement</h3>
      <p class="text-blue-800">
        Health insurance is <strong>mandatory</strong> in the UAE for all residents, including digital nomad visa holders. Your policy must meet UAE regulatory standards (DHA in Dubai, HAAD in Abu Dhabi).
      </p>
    </div>

    <p class="mb-4">
      The UAE takes health insurance seriously. Unlike some countries where requirements are loosely enforced, you'll need proper coverage to complete your visa process and must maintain it throughout your stay.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">DHA vs International Insurance</h3>

    <p class="mb-4">
      For the Virtual Working Visa, you have two main options:
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">UAE Local Insurance</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Providers:</strong> Daman, Oman Insurance, Orient</li>
          <li>• <strong>Cost:</strong> $800-2,000/year</li>
          <li>• <strong>Pros:</strong> Always compliant, local network</li>
          <li>• <strong>Cons:</strong> UAE-only coverage</li>
          <li>• <strong>Best for:</strong> UAE-focused residents</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">International Insurance</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Providers:</strong> Cigna, BUPA, Allianz</li>
          <li>• <strong>Cost:</strong> $1,500-5,500/year</li>
          <li>• <strong>Pros:</strong> Global coverage, travel included</li>
          <li>• <strong>Cons:</strong> Higher cost, verify UAE compliance</li>
          <li>• <strong>Best for:</strong> Frequent travelers, multi-country</li>
        </ul>
      </div>
    </div>

    <p class="mb-4">
      If you travel frequently or plan to move around, international insurance makes more sense. If you're settling in Dubai long-term, local insurance is more cost-effective and always compliant.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need insurance that meets UAE requirements?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare UAE-Compliant Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These international providers offer UAE-compliant coverage suitable for the Virtual Working Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Dubai-Based, Some Travel</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care. Good UAE networks with worldwide coverage for trips.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">BUPA Global. Best hospitals, highest coverage limits, premium service.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US Citizens</h4>
        <p class="text-neutral-600">Aetna International. Strong US network if you travel home frequently.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Cost-Conscious</h4>
        <p class="text-neutral-600">Consider local UAE insurance (Daman, Orient) for lower premiums if UAE-focused.</p>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Important:</strong> Verify your international policy meets DHA requirements before applying. Some travel insurance or basic nomad policies may not qualify. Get written confirmation from your insurer.
      </p>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The UAE's visa fees are straightforward, but the overall cost of living is high. Budget for premium lifestyle costs alongside visa expenses.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,700</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + local basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$3,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + international coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$6,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + premium global plan</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living Context</h3>

    <p class="mb-4">
      Dubai is expensive—comparable to major European cities. Monthly budgets for digital nomads:
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> $3,000-4,000/month (shared housing, cooking at home)</li>
      <li><strong>Comfortable:</strong> $5,000-7,000/month (1BR apartment, dining out)</li>
      <li><strong>Premium:</strong> $10,000+/month (luxury apartment, full lifestyle)</li>
    </ul>

    <p class="mt-4">
      The 0% income tax partially offsets high costs. A $100,000 salary is worth more in Dubai than in the US or Europe after taxes.
    </p>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The UAE's Virtual Working Visa process is largely online and relatively fast. Dubai's process is the most streamlined.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Submit application through the GDRFA portal (Dubai) or relevant emirate authority. Upload passport, photo, and income documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Fees</h4>
          <p class="text-neutral-600">Pay the visa application fee (~$287) online. Additional fees for Emirates ID and medical test apply later.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Entry Permit</h4>
          <p class="text-neutral-600">Within 5-7 business days, you'll receive an entry permit allowing you to enter the UAE within 60 days.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter UAE and Complete Medical</h4>
          <p class="text-neutral-600">After arrival, complete the medical fitness test at an approved center. Results typically same-day.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Emirates ID</h4>
          <p class="text-neutral-600">Visit a typing center or apply online for your Emirates ID. Biometrics required. Card arrives in 1-2 weeks.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Visa Stamping</h4>
          <p class="text-neutral-600">Final step: get your residence visa stamped in your passport at GDRFA. Your 1-year residency is now active.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The medical test is quick (blood test, chest X-ray) but can have queues. Go early morning on weekdays. Some VIP services offer faster processing for a premium.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with the UAE Virtual Working Visa:
