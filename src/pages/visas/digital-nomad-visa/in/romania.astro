---
/**
 * Romania Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Romania", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Romania Health Insurance Guide", href: "/countries/romania/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€3,700/month (3x average gross salary)", evidence: "Bank statements, contracts, tax returns" },
  { requirement: "Remote Work", details: "Work for company outside Romania", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "Valid health coverage in Romania", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months beyond intended stay", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal convictions", evidence: "Criminal record certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Romania Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "€30,000+ recommended", why: "Standard EU minimum" },
  { feature: "Coverage Territory", minimum: "Valid in Romania", why: "Must cover your stay" },
  { feature: "Duration", minimum: "Full visa period", why: "No gaps permitted" },
  { feature: "Repatriation", minimum: "Recommended", why: "Return transport if needed" },
  { feature: "Emergency Care", minimum: "24/7 coverage", why: "Round-the-clock access" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€170-320", strengths: "Comprehensive global" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€140-260", strengths: "EU-focused coverage" },
  { provider: "IMG Global", coverage: "€500,000+", price: "€110-230", strengths: "Flexible options" },
  { provider: "Local Romanian", coverage: "Varies", price: "€30-80", strengths: "Romania-only, affordable" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€120", notes: "Long-stay visa fee" },
  { item: "Residence Permit", amount: "€120", notes: "Annual permit fee" },
  { item: "Health Insurance (Annual)", amount: "€400-2,500", notes: "International or local" },
  { item: "Document Apostille", amount: "€30-100", notes: "If required" },
  { item: "Translation Services", amount: "€50-150", notes: "For non-Romanian documents" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Submit visa application", duration: "1 day", location: "Romanian embassy/consulate" },
  { step: "Visa processing", duration: "30-60 days", location: "Ministry of Foreign Affairs" },
  { step: "Receive visa", duration: "Via pickup", location: "Embassy/consulate" },
  { step: "Enter Romania", duration: "Within visa validity", location: "Romanian border" },
  { step: "Apply for residence permit", duration: "Within 30 days", location: "IGI (Immigration Office)" },
];
---

<PageShell
  title="Romania Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Romania's Digital Nomad Visa. €3,700/month income requirement, 1% micro-company tax option, excellent private healthcare, and growing tech scene in Bucharest."
  headline="Romania Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from one of Europe's most affordable countries—insurance requirements, tax benefits, and the Bucharest tech scene."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official IGI Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU Member State
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Romania launched its Digital Nomad Visa in January 2022, joining the wave of European countries welcoming remote workers. With fast internet, affordable costs, and a growing tech ecosystem in Bucharest, Romania offers compelling value for nomads willing to meet its €3,700/month income threshold.
    </p>

    <p class="mb-4">
      Romania isn't in the Schengen Area yet (expected 2024-2025), which affects travel flexibility. However, its EU membership means you get access to European banking, SIM cards, and the ability to easily travel to other EU countries with proper documentation.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Romania Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year (renewable for another year, 2 years max)</li>
        <li>• <strong>Income requirement:</strong> €3,700/month (3x average gross salary)</li>
        <li>• <strong>Processing time:</strong> 30-60 days</li>
        <li>• <strong>Insurance:</strong> Mandatory health coverage</li>
        <li>• <strong>Tax benefit:</strong> 1% micro-company tax option available</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Romania for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Very fast internet:</strong> Romania consistently ranks top 5 globally for internet speed</li>
      <li><strong>Affordable living:</strong> 40-50% cheaper than Western Europe for comparable lifestyle</li>
      <li><strong>1% micro-company tax:</strong> Attractive option for freelancers who set up local company</li>
      <li><strong>Growing tech scene:</strong> Bucharest has strong IT sector and coworking spaces</li>
      <li><strong>English proficiency:</strong> High among younger population, especially in cities</li>
      <li><strong>Dental tourism:</strong> Excellent dental care at fraction of Western prices</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Romania is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €3,700+/month from remote work</li>
          <li>✓ You want affordable European living</li>
          <li>✓ You value fast, reliable internet</li>
          <li>✓ You're interested in 1% micro-company tax</li>
          <li>✓ You enjoy city life (Bucharest, Cluj)</li>
          <li>✓ You don't require Schengen access</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need immediate Schengen Area access</li>
          <li>• You want warm weather year-round</li>
          <li>• You prefer established nomad communities</li>
          <li>• Your income is below €3,700/month</li>
          <li>• You want longer-term path to residency</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Romania's Digital Nomad Visa has a notably high income threshold—€3,700/month (3x the average Romanian gross salary). This is among the highest in Europe.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate €3,700/month income (approximately €44,400/year). This is calculated as 3x the average Romanian gross salary. Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 6 months showing consistent income</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>For freelancers:</strong> Client contracts, invoices, and proof of payment</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Renewable Once:</strong> Unlike some non-renewable DNVs, Romania allows one renewal for a second year. After 2 years total, you'd need to apply through a different visa category for longer stays.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months beyond intended stay)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (Romanian specifications)</li>
      <li>Proof of income (€3,700/month average)</li>
      <li>Health insurance certificate valid in Romania</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Criminal record certificate (apostilled)</li>
      <li>Proof of accommodation in Romania</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Insurance Required</h3>
      <p class="text-blue-800">
        Romania requires valid health insurance covering your stay. While specific coverage minimums aren't strictly defined, international standards (€30,000+) are expected. Both international and local Romanian insurance are accepted.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Romania's Digital Nomad Visa. You have flexibility in choosing between international coverage or local Romanian insurance.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Romanian Healthcare Context</h3>

    <p class="mb-4">
      Romania has a public healthcare system (CNAS) funded by 10% health insurance contributions. Digital nomads aren't automatically enrolled but can access excellent private healthcare at very affordable prices.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (CNAS)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Requires 10% CASS contribution</li>
          <li>• <strong>Quality:</strong> Variable, underfunded</li>
          <li>• <strong>Emergency:</strong> Free for emergencies</li>
          <li>• <strong>Language:</strong> Romanian primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With any insurance or out-of-pocket</li>
          <li>• <strong>Quality:</strong> Excellent in Bucharest/Cluj</li>
          <li>• <strong>Networks:</strong> MedLife, Regina Maria, Sanador</li>
          <li>• <strong>Cost:</strong> Very affordable by EU standards</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Romania's Digital Nomad Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer coverage suitable for Romania's Digital Nomad Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €40-75/month or local Romanian insurance (€30-80/month). Both meet requirements affordably.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Coverage</h4>
        <p class="text-neutral-600">Allianz Care or IMG Global. Strong European networks, portable if you travel to Schengen countries.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage for frequent travelers.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Romania-Focused</h4>
        <p class="text-neutral-600">Local providers (MedLife, Regina Maria insurance plans). Cheapest option but only covers Romania.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Romania's visa fees are moderate. The real savings come from the low cost of living and affordable private healthcare.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€700</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + local insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€1,400</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + international coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€3,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Romania is one of the most affordable EU countries. Even Bucharest is significantly cheaper than Western European capitals.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> €1,000-1,400/month (shared housing, cooking at home)</li>
      <li><strong>Comfortable:</strong> €1,800-2,500/month (own apartment, dining out, activities)</li>
      <li><strong>Premium:</strong> €3,000+/month (central Bucharest, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Romania's application involves getting a long-stay visa (Type D) at an embassy, then applying for a residence permit (permis de ședere) after arrival.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documentation</h4>
          <p class="text-neutral-600">Gather income proof, insurance certificate, passport, criminal record (apostilled), and photos. Get certified translations for non-Romanian documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Long-Stay Visa</h4>
          <p class="text-neutral-600">Submit application at Romanian embassy/consulate in your country of residence. Pay €120 visa fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 30-60 days. The Ministry of Foreign Affairs reviews applications.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Romania</h4>
          <p class="text-neutral-600">Once visa is approved, enter Romania within its validity period.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for Residence Permit</h4>
          <p class="text-neutral-600">Within 30 days of arrival, visit IGI (Immigration Office) to apply for your residence permit. Pay €120 permit fee.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Consider visiting Romania first on the 90-day visa-free period (for most nationalities) to explore before committing to the full visa application.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Romania's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, €5,500/month</h3>
        <p class="text-neutral-600 mb-4">Works for German company, attracted by 1% micro-company tax possibility.</p>
        <p class="text-green-700 font-medium">✓ Approved easily. Set up Romanian SRL for tax optimization, enjoying significant savings.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Consultant, €4,200/month</h3>
        <p class="text-neutral-600 mb-4">Freelancer with multiple US clients, wants affordable European base.</p>
        <p class="text-green-700 font-medium">✓ Approved. Provided client contracts and 6 months of bank statements.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Writer, €2,800/month</h3>
        <p class="text-neutral-600 mb-4">Steady income but below the €3,700 threshold.</p>
        <p class="text-red-700 font-medium">✗ Denied. €900 below threshold. Romania has one of the highest income requirements—consider Bulgaria or Portugal.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, €6,000/month</h3>
        <p class="text-neutral-600 mb-4">Wants to explore Eastern Europe, impressed by internet speeds.</p>
        <p class="text-green-700 font-medium">✓ Approved. Enjoying blazing fast internet and low costs. Plans to renew for second year.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Product Manager, €4,500/month</h3>
        <p class="text-neutral-600 mb-4">British citizen post-Brexit, wanted EU residency option.</p>
        <p class="text-green-700 font-medium">✓ Approved. Using Romania as EU base for work and travel.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, €7,500/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, €4,500 + €3,000.</p>
        <p class="text-green-700 font-medium">✓ Both approved. Each applied individually—one comfortably above, one marginally above threshold.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
