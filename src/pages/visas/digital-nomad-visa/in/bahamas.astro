---
/**
 * Bahamas Digital Nomad Visa (BEATS) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Bahamas", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Bahamas Health Insurance Guide", href: "/countries/bahamas/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Income", details: "No minimum stated", evidence: "Proof of employment/self-employment" },
  { requirement: "Remote Work", details: "Work for company outside Bahamas", evidence: "Employment letter or business proof" },
  { requirement: "Health Insurance", details: "Required for duration", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "Valid for stay duration", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Bahamas Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Required (no stated minimum)", why: "Healthcare is expensive" },
  { feature: "Coverage Territory", minimum: "Valid in Bahamas", why: "Must cover your stay" },
  { feature: "Emergency Evacuation", minimum: "Highly recommended", why: "Limited specialists on islands" },
  { feature: "Duration", minimum: "Full visa period (1 year)", why: "Continuous coverage needed" },
  { feature: "Repatriation", minimum: "Recommended", why: "Return transport if needed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-400", strengths: "Comprehensive + US access" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$180-350", strengths: "Global coverage" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$150-300", strengths: "Americas coverage" },
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget option" },
  { provider: "GeoBlue", coverage: "$500,000+", price: "$180-350", strengths: "US expats, Florida access" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "BEATS Application Fee", amount: "$25", notes: "Individual applicant" },
  { item: "Family Application Fee", amount: "$50", notes: "For dependents" },
  { item: "Health Insurance (Annual)", amount: "$1,000-4,000", notes: "International coverage" },
  { item: "Police Clearance", amount: "$50-100", notes: "From home country" },
  { item: "Renewal Fee", amount: "$25", notes: "After first year" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1 day", location: "Online" },
  { step: "Apply online", duration: "1 day", location: "BEATS portal" },
  { step: "Processing", duration: "5-10 business days", location: "Immigration review" },
  { step: "Receive approval", duration: "Email notification", location: "Online" },
  { step: "Travel to Bahamas", duration: "At your convenience", location: "Nassau or other entry" },
];
---

<PageShell
  title="Bahamas Digital Nomad Visa 2026: BEATS Program Insurance & Requirements Guide"
  description="Complete guide to the Bahamas BEATS program for digital nomads. Crystal-clear waters, $25 application fee, no income tax, and island paradise living."
  headline="Bahamas Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from paradise—the BEATS program offers 1-year stays for just $25 in one of the world's most beautiful destinations."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official BEATS Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      No Income Tax
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The Bahamas Extended Access Travel Stay (BEATS) program, launched in October 2020, offers one of the most accessible digital nomad visas in the Caribbean. For just $25, you can live and work remotely from 700 islands for up to one year—renewable indefinitely.
    </p>

    <p class="mb-4">
      With crystal-clear turquoise waters, world-class beaches, and proximity to Florida (just 50 miles from Miami), the Bahamas offers a tropical paradise for remote workers who can handle the higher cost of living.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Bahamas BEATS Program</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> BEATS (Bahamas Extended Access Travel Stay)</li>
        <li>• <strong>Application fee:</strong> Just $25 individual / $50 family</li>
        <li>• <strong>Duration:</strong> 1 year, renewable</li>
        <li>• <strong>Income requirement:</strong> No minimum stated</li>
        <li>• <strong>Currency:</strong> Bahamian Dollar (pegged 1:1 to USD)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Bahamas for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Lowest visa fee:</strong> Just $25—among the cheapest DNV programs globally</li>
      <li><strong>No income tax:</strong> Bahamas has no personal income tax</li>
      <li><strong>USD parity:</strong> Bahamian dollar is pegged 1:1 to USD</li>
      <li><strong>Close to US:</strong> 50 miles from Florida, quick flights to Miami</li>
      <li><strong>English-speaking:</strong> Official language is English</li>
      <li><strong>Paradise setting:</strong> 700 islands, world-class beaches, clear water</li>
      <li><strong>Simple application:</strong> Fast online process, quick approval</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Bahamas is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You have high income to afford island living</li>
          <li>✓ You want quick, easy US access</li>
          <li>✓ You prefer English-speaking Caribbean</li>
          <li>✓ Beach lifestyle is your priority</li>
          <li>✓ You want zero income tax</li>
          <li>✓ You value simple visa processes</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You're on a tight budget</li>
          <li>• You want nightlife and urban energy</li>
          <li>• You need advanced medical facilities</li>
          <li>• You want cheap local food options</li>
          <li>• You prefer mountain or city settings</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Cost reality check:</strong> The $25 visa fee is deceptively cheap. The Bahamas has one of the highest costs of living in the Caribbean. Budget $3,000-5,000/month minimum for a comfortable lifestyle. This is a premium destination.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The BEATS program has notably simple requirements compared to most digital nomad visas. There's no stated minimum income—just proof that you work remotely.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">BEATS Program Details</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Program Benefits</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> 1 year</li>
          <li>• <strong>Renewable:</strong> Yes, indefinitely</li>
          <li>• <strong>Fee:</strong> $25 (lowest in Caribbean)</li>
          <li>• <strong>Dependents:</strong> Included for $50 total</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">What You Can Do</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Work remotely for foreign employers</li>
          <li>• Run online business serving foreign clients</li>
          <li>• Live anywhere in the 700 islands</li>
          <li>• Travel freely in/out of Bahamas</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport</li>
      <li>Proof of employment or self-employment (letter from employer or business registration)</li>
      <li>Health insurance certificate covering Bahamas</li>
      <li>Police clearance certificate</li>
      <li>Passport-size photo</li>
      <li>$25 application fee</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required</h3>
      <p class="text-red-800">
        The BEATS program requires health insurance valid in the Bahamas for your entire stay. While no minimum coverage is stated, comprehensive coverage is strongly recommended given the high cost of healthcare and limited facilities outside Nassau.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Comprehensive Coverage Matters</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6 mb-6">
      <p class="text-amber-800">
        <strong>Medical evacuation critical:</strong> The Bahamas has decent hospitals in Nassau but limited specialists. Serious conditions often require evacuation to Florida. Make sure your policy includes emergency medical evacuation with adequate coverage ($100,000+).
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Healthcare Realities</h3>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Nassau (New Providence)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Facilities:</strong> Several hospitals available</li>
          <li>• <strong>Quality:</strong> Adequate for most needs</li>
          <li>• <strong>Specialists:</strong> Limited selection</li>
          <li>• <strong>Cost:</strong> Expensive by US standards</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Out Islands</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Facilities:</strong> Basic clinics only</li>
          <li>• <strong>Serious cases:</strong> Evacuation to Nassau or Miami</li>
          <li>• <strong>Pharmacies:</strong> Limited availability</li>
          <li>• <strong>Evacuation:</strong> Essential coverage</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance with evacuation coverage for the Bahamas?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Given the Bahamas' proximity to Florida and limited local healthcare, plans with US network access are particularly valuable:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Overall for Bahamas</h4>
        <p class="text-neutral-600">Cigna Global or GeoBlue. Both offer US network access—crucial since many Bahamians fly to Florida for serious care.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Option</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Meets requirements but verify evacuation coverage limits for island living.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Out Islands Living</h4>
        <p class="text-neutral-600">IMG Global or Allianz Care with high evacuation limits. Essential if you're not in Nassau.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The BEATS visa is incredibly cheap. Living in the Bahamas is not.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget (Tight)</p>
        <p class="text-3xl font-bold text-neutral-900">$3,000</p>
        <p class="text-sm text-neutral-500 mt-2">Basic studio, cooking mostly</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$4,500</p>
        <p class="text-sm text-neutral-500 mt-2">Nice 1BR, dining out, activities</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium</p>
        <p class="text-3xl font-bold text-neutral-900">$7,000+</p>
        <p class="text-sm text-neutral-500 mt-2">Beachfront, full island lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why So Expensive?</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Imports:</strong> Almost everything is imported, adding 30-50% to prices</li>
      <li><strong>Housing:</strong> Limited supply, high demand from tourists</li>
      <li><strong>Groceries:</strong> 2-3x US prices for most items</li>
      <li><strong>Dining:</strong> Restaurant meals $25-75+</li>
      <li><strong>Utilities:</strong> Electricity is expensive (no natural resources)</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The Out Islands (Exumas, Eleuthera, Abaco) can be slightly cheaper than Nassau, but have fewer amenities. Many nomads do a mix—months in the Out Islands, occasional trips to Nassau for supplies and socializing.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The BEATS application is entirely online and notably quick—one of the most streamlined processes in the Caribbean.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect passport, proof of remote employment, and police clearance certificate.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get international health insurance covering Bahamas for 1 year. Request certificate with coverage dates.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Visit the official BEATS portal. Complete the application and upload documents. Pay the $25 fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Approval</h4>
          <p class="text-neutral-600">Processing typically takes 5-10 business days. You'll receive email confirmation with your approval.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Travel to Bahamas</h4>
          <p class="text-neutral-600">Book your flight and arrive. Present your BEATS approval at immigration. Your 1-year stay begins.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Tech Consultant, $12,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted Caribbean paradise with easy US access.</p>
        <p class="text-green-700 font-medium">✓ Living the dream in Nassau. 50-minute flight to Miami for client meetings. Zero income tax saving $40k+/year.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Remote Developer, $6,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted beach lifestyle, English-speaking.</p>
        <p class="text-amber-700 font-medium">△ Doable but tight. Found affordable apartment in less touristy area. Cooks most meals. Still loving island life.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $3,500/month</h3>
        <p class="text-neutral-600 mb-4">Underestimated costs.</p>
        <p class="text-red-700 font-medium">✗ Struggled with budget. Moved to cheaper Caribbean destination (Curaçao) after 4 months. Bahamas needs higher income.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Finance Professional, $15,000/month</h3>
        <p class="text-neutral-600 mb-4">Tax optimization was primary goal.</p>
        <p class="text-green-700 font-medium">✓ Tax savings more than cover premium cost of living. Beachfront condo in Paradise Island. Best lifestyle decision ever.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, $9,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, wanted tropical base.</p>
        <p class="text-green-700 font-medium">✓ Split costs make it work. Nice 2BR in Cable Beach. Weekend boat trips to Out Islands. Living their best life.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Entrepreneur, $8,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted Out Island escape from hustle.</p>
        <p class="text-green-700 font-medium">✓ Based in Harbour Island. Slower pace, smaller community. Monthly trips to Nassau. Perfect work-life balance.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Planning your Bahamas move? Compare insurance plans now.</p>
