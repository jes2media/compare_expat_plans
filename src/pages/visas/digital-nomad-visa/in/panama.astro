---
/**
 * Panama Digital Nomad Visa (Short Stay for Remote Workers) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Panama", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Panama Health Insurance Guide", href: "/countries/panama/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "$3,000/month minimum", evidence: "Employment letter, bank statements" },
  { requirement: "Remote Work", details: "Work for company outside Panama", evidence: "Employment contract or company letter" },
  { requirement: "Health Insurance", details: "$50,000 minimum coverage", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Panama Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "$50,000 minimum", why: "Mandatory visa requirement" },
  { feature: "Coverage Territory", minimum: "Valid in Panama", why: "Must include Panama" },
  { feature: "COVID Coverage", minimum: "Included", why: "Panama still requires this" },
  { feature: "Duration", minimum: "Full visa period (9-18 months)", why: "Continuous coverage required" },
  { feature: "Repatriation", minimum: "Recommended", why: "Not required but advisable" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget option, meets requirements" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Premium comprehensive" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Good Americas coverage" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Trusted global brand" },
  { provider: "Local Panamanian", coverage: "Varies", price: "$80-200", strengths: "Long-term residents" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$250", notes: "Government fee" },
  { item: "Extension Fee", amount: "$250", notes: "After initial 9 months" },
  { item: "Health Insurance (Annual)", amount: "$600-2,500", notes: "Meeting $50k minimum" },
  { item: "Document Apostille", amount: "$50-150", notes: "Per document" },
  { item: "Immigration Lawyer (Optional)", amount: "$500-1,500", notes: "Speeds up process" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1 day", location: "Online" },
  { step: "Apply online", duration: "1 day", location: "Panama digital portal" },
  { step: "Processing", duration: "30 days (typical)", location: "Immigration review" },
  { step: "Receive approval", duration: "Email notification", location: "Online" },
  { step: "Enter Panama", duration: "Within 6 months of approval", location: "Tocumen Airport" },
  { step: "Register locally", duration: "Within 30 days", location: "Immigration office" },
];
---

<PageShell
  title="Panama Digital Nomad Visa 2025: Remote Worker Visa Insurance & Requirements Guide"
  description="Complete guide to Panama's digital nomad visa for remote workers. USD economy, tax advantages, Panama Canal lifestyle, and straightforward online application."
  headline="Panama Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the Crossroads of the Americas—USD currency, tax benefits, modern infrastructure, and 9-18 month stays."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      USD Economy
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Panama's Short Stay Visa for Remote Workers, launched in 2021, offers digital nomads up to 18 months in one of Latin America's most modern and business-friendly countries. With the US dollar as its currency, Panama eliminates exchange rate headaches while providing tax advantages on foreign-earned income.
    </p>

    <p class="mb-4">
      Panama City offers world-class infrastructure—think Miami meets the tropics. Modern high-rises, excellent hospitals, reliable internet, and the historic Panama Canal create a unique backdrop for remote work, with beaches and mountain towns just hours away.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Panama for Digital Nomads</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Short Stay Visa for Remote Workers</li>
        <li>• <strong>Income requirement:</strong> $3,000/month minimum</li>
        <li>• <strong>Duration:</strong> 9 months, extendable to 18 months</li>
        <li>• <strong>Insurance:</strong> $50,000 minimum coverage required</li>
        <li>• <strong>Currency:</strong> US Dollar (Balboa pegged 1:1)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Panama for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>USD economy:</strong> No currency exchange, prices in dollars</li>
      <li><strong>Tax advantages:</strong> No tax on foreign-earned income</li>
      <li><strong>Modern infrastructure:</strong> Fast internet, excellent hospitals, direct US flights</li>
      <li><strong>Strategic location:</strong> Hub of the Americas, easy travel to North/South America</li>
      <li><strong>Banking hub:</strong> International banking center, easy to manage finances</li>
      <li><strong>Climate variety:</strong> Tropical coast, cool highlands in Boquete</li>
      <li><strong>English widely spoken:</strong> Especially in Panama City business areas</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Panama is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want USD currency with no exchange risk</li>
          <li>✓ You earn $3,000+/month remotely</li>
          <li>✓ You value modern infrastructure</li>
          <li>✓ You want tax-free foreign income</li>
          <li>✓ You need easy Americas travel</li>
          <li>✓ You prefer a business-friendly environment</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You're on a tight budget (under $3,000/month)</li>
          <li>• You want a more laid-back, less urban vibe</li>
          <li>• You prefer European-style cities</li>
          <li>• You want longer than 18-month stays</li>
          <li>• You're seeking the cheapest option possible</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Tax advantage:</strong> Panama uses a territorial tax system—you only pay taxes on Panama-sourced income. Your remote work income from foreign companies is tax-free. This makes Panama extremely attractive for higher earners.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Panama's digital nomad visa has clear requirements. The $3,000/month income threshold is higher than some countries, but the tax benefits often offset this for qualifying nomads.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Visa Details</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Initial Visa (9 months)</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> 9 months</li>
          <li>• <strong>Fee:</strong> $250</li>
          <li>• <strong>Application:</strong> Online portal</li>
          <li>• <strong>Processing:</strong> ~30 days</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Extension (Additional 9 months)</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Duration:</strong> 9 more months (18 total)</li>
          <li>• <strong>Fee:</strong> $250</li>
          <li>• <strong>Application:</strong> Before initial expires</li>
          <li>• <strong>Requirements:</strong> Same as initial</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Income proof:</strong> The $3,000/month can be shown through employment letter stating salary, bank statements showing regular deposits, or a combination. Self-employed freelancers need client contracts and bank statements.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Employment letter confirming remote work status and $3,000+ salary</li>
      <li>3 months bank statements showing income</li>
      <li>Health insurance certificate ($50,000 minimum coverage)</li>
      <li>Police clearance from country of residence (apostilled)</li>
      <li>Passport-size photo</li>
      <li>Application fee payment ($250)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">$50,000 Minimum Coverage Required</h3>
      <p class="text-red-800">
        Panama requires health insurance with at least $50,000 in medical coverage for the digital nomad visa. Your policy must explicitly cover Panama and include COVID-19 coverage. The insurance certificate must match your intended stay duration.
      </p>
    </div>

    <p class="mb-4">
      Your insurance certificate should clearly state: coverage amount ($50,000+), coverage territory (including Panama), COVID coverage, and validity dates matching your visa period.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Specifications</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">What Meets Panama's Requirements</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Acceptable Policies</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ $50,000+ medical coverage</li>
          <li>✓ Explicitly includes Panama</li>
          <li>✓ Includes COVID-19 treatment</li>
          <li>✓ Covers full visa duration</li>
          <li>✓ Certificate in English or Spanish</li>
        </ul>
      </div>

      <div class="border border-red-200 bg-red-50 rounded-lg p-6">
        <h4 class="font-semibold text-red-900 mb-3">Not Acceptable</h4>
        <ul class="space-y-2 text-red-800">
          <li>✗ Coverage under $50,000</li>
          <li>✗ Travel insurance without medical</li>
          <li>✗ Policies excluding Panama</li>
          <li>✗ Policies without COVID coverage</li>
          <li>✗ Short-term policies (unless renewable)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need $50,000+ coverage for Panama's visa requirements?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These international providers offer plans meeting Panama's $50,000 minimum requirement:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget-Conscious (Meeting Minimum)</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Exceeds the $50,000 requirement with $250,000 coverage. Easy monthly billing.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">Cigna Global at $180-350/month. $1M+ coverage, extensive hospital network, worldwide protection.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Americas Focus</h4>
        <p class="text-neutral-600">IMG Global at $120-250/month. Strong network throughout North/Central/South America.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Residents</h4>
        <p class="text-neutral-600">After establishing residency, local Panamanian plans become available at better rates for extended stays.</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> When purchasing, request a certificate specifically stating your coverage amount and that it includes Panama and COVID-19. Some providers have templates for Panama visa applications.
      </p>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Panama's dollarized economy means straightforward pricing. What you see is what you pay—no exchange rate surprises.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First 18 Months Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,400</p>
        <p class="text-sm text-neutral-500 mt-2">Visa fees + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Typical Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">With Lawyer</p>
        <p class="text-3xl font-bold text-neutral-900">$4,000</p>
        <p class="text-sm text-neutral-500 mt-2">Full concierge service</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Monthly Cost of Living</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> $1,500-2,000/month (basic apartment, cooking, local lifestyle)</li>
      <li><strong>Comfortable:</strong> $2,500-3,500/month (nice apartment, dining out, activities)</li>
      <li><strong>Premium:</strong> $4,500+/month (luxury condo, car, full lifestyle)</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Panama City vs. elsewhere:</strong> The capital is significantly more expensive than places like Boquete or Pedasi. Budget-conscious nomads often base in the highlands or beach towns while visiting the city for flights and amenities.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Panama's digital nomad visa can be applied for entirely online—one of the most streamlined processes in Latin America. You don't need to visit a consulate.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect employment letter (stating remote work status and $3,000+ salary), bank statements (3 months), passport copy, and police clearance.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get a policy with $50,000+ coverage including Panama and COVID. Request a certificate showing coverage details and dates matching your visa period.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Submit your application through Panama's digital immigration portal. Upload all documents and pay the $250 fee online.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Typical processing takes about 30 days. You may receive requests for additional documentation via email.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">You'll receive email confirmation with your visa approval. You have 6 months to enter Panama.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter and Register</h4>
          <p class="text-neutral-600">Arrive in Panama and register with the immigration office within 30 days. Your 9-month visa period starts from your entry date.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Online advantage:</strong> Panama's fully digital application is a major plus—no consulate visits required. You can apply from anywhere and arrive with your visa already approved.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out for digital nomads in Panama:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Engineer, $8,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted tax-free income and modern city life.</p>
        <p class="text-green-700 font-medium">✓ Saving thousands in taxes. Living in Punta Pacifica with ocean views. Fast internet, direct flights to SF. Best financial decision he's made.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Manager, $4,500/month</h3>
        <p class="text-neutral-600 mb-4">US company, needed same timezone and easy travel.</p>
        <p class="text-green-700 font-medium">✓ EST timezone perfect for meetings. Flies to Miami in 3 hours. Modern apartment in Casco Viejo, historic charm with modern amenities.</p>
