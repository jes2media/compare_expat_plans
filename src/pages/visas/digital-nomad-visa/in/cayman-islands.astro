---
/**
 * Cayman Islands Digital Nomad Visa (Global Citizen Concierge) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Cayman Islands", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Cayman Islands Health Insurance Guide", href: "/countries/cayman-islands/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "individual", header: "Individual" },
  { key: "couple", header: "Couple/Family" },
];

const requirementsRows = [
  { requirement: "Annual Income", individual: "$100,000 minimum", couple: "$150,000 minimum" },
  { requirement: "Application Fee", individual: "$1,469", couple: "$1,949" },
  { requirement: "Duration", individual: "2 years", couple: "2 years" },
  { requirement: "Health Insurance", individual: "Required", couple: "Required for all" },
  { requirement: "Remote Work", individual: "Non-Cayman employer", couple: "Non-Cayman employer" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Cayman Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive required", why: "Expensive local healthcare" },
  { feature: "Coverage Territory", minimum: "Valid in Cayman Islands", why: "Must cover your stay" },
  { feature: "Emergency Evacuation", minimum: "Highly recommended", why: "Specialists often in Miami" },
  { feature: "Duration", minimum: "Full visa period (2 years)", why: "Continuous coverage needed" },
  { feature: "Hospitalization", minimum: "Included", why: "Hospital costs very high" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$250-450", strengths: "Premium global + US access" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$200-400", strengths: "Comprehensive worldwide" },
  { provider: "Aetna International", coverage: "$1,000,000+", price: "$300-500", strengths: "US expats" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$180-350", strengths: "Good Americas coverage" },
  { provider: "Local Cayman", coverage: "Varies", price: "$300-600", strengths: "Island network" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Application Fee (Individual)", amount: "$1,469", notes: "Non-refundable" },
  { item: "Application Fee (Couple)", amount: "$1,949", notes: "Includes dependents" },
  { item: "Health Insurance (Annual)", amount: "$3,000-6,000", notes: "Comprehensive coverage" },
  { item: "Background Check", amount: "Included", notes: "Part of application" },
  { item: "Certificate Fee", amount: "$100", notes: "Upon approval" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1 day", location: "Online" },
  { step: "Apply online", duration: "1 day", location: "Official portal" },
  { step: "Processing", duration: "2-3 weeks", location: "Immigration review" },
  { step: "Receive approval", duration: "Email notification", location: "Online" },
  { step: "Travel to Cayman", duration: "Within validity period", location: "Owen Roberts Airport" },
];
---

<PageShell
  title="Cayman Islands Digital Nomad Visa 2025: Global Citizen Concierge Insurance & Requirements"
  description="Complete guide to the Cayman Islands Global Citizen Concierge program. $100k income requirement, zero taxes, British Caribbean luxury, and world-class diving."
  headline="Cayman Islands Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about the premium Global Citizen Concierge program—2-year stays in a tax-free British Caribbean paradise for high earners."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Zero Income Tax
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      The Cayman Islands Global Citizen Concierge Program is the premium digital nomad visa of the Caribbean. With a $100,000 minimum income requirement and $1,469 application fee, it's designed for high earners who want the ultimate tax-free Caribbean experience.
    </p>

    <p class="mb-4">
      As a British Overseas Territory, the Cayman Islands offer political stability, strong rule of law, and zero direct taxation. World-class diving, pristine beaches, and sophisticated infrastructure make this the luxury choice for remote workers.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Cayman Global Citizen Concierge</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Program:</strong> Global Citizen Concierge</li>
        <li>• <strong>Income requirement:</strong> $100,000/year (individual) / $150,000 (couple)</li>
        <li>• <strong>Duration:</strong> 2 years</li>
        <li>• <strong>Application fee:</strong> $1,469 (individual) / $1,949 (couple/family)</li>
        <li>• <strong>Taxes:</strong> Zero income tax, capital gains tax, or wealth tax</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Cayman Islands for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Zero taxes:</strong> No income tax, capital gains tax, inheritance tax, or sales tax</li>
      <li><strong>British stability:</strong> Overseas territory with strong legal system</li>
      <li><strong>World-class diving:</strong> Some of the best diving sites globally</li>
      <li><strong>Premium infrastructure:</strong> Excellent internet, modern amenities</li>
      <li><strong>Banking hub:</strong> Major offshore financial center</li>
      <li><strong>Low crime:</strong> One of the safest Caribbean destinations</li>
      <li><strong>2-year duration:</strong> Longer than most DNV programs</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Cayman is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn $100,000+/year remotely</li>
          <li>✓ Tax optimization is a priority</li>
          <li>✓ You want British legal system stability</li>
          <li>✓ You're into diving or water sports</li>
          <li>✓ You prefer premium, safe environments</li>
          <li>✓ You want a 2-year commitment option</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You earn under $100,000/year</li>
          <li>• Budget is a primary concern</li>
          <li>• You want nightlife and party scene</li>
          <li>• You prefer larger land mass / variety</li>
          <li>• You want cheaper application fees</li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800">
        <strong>Tax math:</strong> If you earn $150,000/year, zero income tax saves you $30,000-50,000+ annually compared to living in the US or UK. The premium cost of living and visa fees are often offset by tax savings for high earners.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The Global Citizen Concierge has the highest income requirements of any Caribbean DNV program. This is intentional—Cayman positions itself as a premium destination.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Requirements Explained</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Individual Applicant</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Income:</strong> $100,000/year minimum</li>
          <li>• <strong>Fee:</strong> $1,469</li>
          <li>• <strong>Evidence:</strong> Tax returns, employment letter</li>
          <li>• <strong>Duration:</strong> 2 years</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Couple or Family</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Income:</strong> $150,000/year combined</li>
          <li>• <strong>Fee:</strong> $1,949 (includes dependents)</li>
          <li>• <strong>Evidence:</strong> Combined proof of income</li>
          <li>• <strong>Children:</strong> School-age can attend local schools</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Proof of annual income ($100k+) - tax returns, employment contracts, bank statements</li>
      <li>Proof of remote employment or business ownership</li>
      <li>Health insurance certificate (comprehensive coverage)</li>
      <li>Police clearance certificate</li>
      <li>Passport-size photos</li>
      <li>Application fee ($1,469 or $1,949)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Comprehensive Health Insurance Required</h3>
      <p class="text-red-800">
        The Cayman Islands require comprehensive health insurance for the Global Citizen Concierge program. Given the high cost of local healthcare and limited specialist services, premium coverage with evacuation is essential.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6 mb-6">
      <p class="text-amber-800">
        <strong>Miami connection:</strong> For complex procedures, many Cayman residents fly to Miami (1-hour flight). Consider insurance with strong US network access, or plan for out-of-pocket Miami visits.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Premium Coverage Matters</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>High local costs:</strong> Healthcare in Cayman is expensive, even by US standards</li>
      <li><strong>Limited specialists:</strong> Complex cases often require Miami evacuation</li>
      <li><strong>2-year stay:</strong> Long duration increases likelihood of needing care</li>
      <li><strong>No public option:</strong> No subsidized healthcare for non-residents</li>
    </ul>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need premium health insurance for the Cayman Islands?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Premium Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      Given Cayman's premium positioning and Miami connection, prioritize comprehensive coverage with strong US network access:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Overall</h4>
        <p class="text-neutral-600">Cigna Global or Aetna International. Premium coverage, US network access for Miami care, appropriate for $100k+ earners.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US Expats</h4>
        <p class="text-neutral-600">Aetna International. Excellent US network integration for those who'll visit Miami for care.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Strategy</h4>
        <p class="text-neutral-600">Start with international coverage, then consider local Cayman providers after establishing residency.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The Cayman Islands are expensive. The upfront visa costs are just the beginning—budget for premium Caribbean living.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Modest</p>
        <p class="text-3xl font-bold text-neutral-900">$4,500</p>
        <p class="text-sm text-neutral-500 mt-2">Basic apartment, cooking</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$7,000</p>
        <p class="text-sm text-neutral-500 mt-2">Nice condo, dining, activities</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium</p>
        <p class="text-3xl font-bold text-neutral-900">$12,000+</p>
        <p class="text-sm text-neutral-500 mt-2">Luxury living, Seven Mile Beach</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why the High Costs Are Worth It</h3>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <p class="text-green-800 mb-3">
        <strong>Tax savings example:</strong>
      </p>
      <ul class="space-y-2 text-green-800">
        <li>• Income: $150,000/year</li>
        <li>• US federal + state taxes avoided: ~$40,000-50,000</li>
        <li>• Cayman cost premium over budget destination: ~$36,000/year</li>
        <li>• <strong>Net benefit: $4,000-14,000+ annually</strong> (plus asset protection benefits)</li>
      </ul>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The application is online and professionally managed—befitting a premium program. Processing is typically efficient.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Verify Income</h4>
          <p class="text-neutral-600">Confirm you meet the $100k (individual) or $150k (couple) threshold. Gather tax returns and employment documentation.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Purchase Health Insurance</h4>
          <p class="text-neutral-600">Get comprehensive international health insurance covering Cayman for 2 years. Premium providers recommended.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Submit application through official Global Citizen Concierge portal. Pay the $1,469 (or $1,949) fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Background Check</h4>
          <p class="text-neutral-600">Cayman conducts thorough background verification. This is included in the application fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Approval typically arrives within 2-3 weeks. Pay the $100 certificate fee to receive your documentation.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive in Cayman</h4>
          <p class="text-neutral-600">Present your Global Citizen certificate at immigration. Your 2-year stay begins.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Hedge Fund Analyst, $200,000/year</h3>
        <p class="text-neutral-600 mb-4">Primary goal: tax optimization while maintaining quality of life.</p>
        <p class="text-green-700 font-medium">✓ Saving $60k+/year in taxes. Diving every weekend. Seven Mile Beach condo. Zero regrets about the premium costs.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Tech Entrepreneur, $150,000/year</h3>
        <p class="text-neutral-600 mb-4">Wanted safe, stable Caribbean base with good internet.</p>
        <p class="text-green-700 font-medium">✓ Excellent internet, professional environment. Easy flights to US for meetings. Tax savings cover the premium living costs.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Finance Couple, $180,000 combined</h3>
        <p class="text-neutral-600 mb-4">Both remote, wanted premium Caribbean experience together.</p>
        <p class="text-green-700 font-medium">✓ Qualified with combined income. Split costs make it work well. Diving, sailing, beach lifestyle. Best decision ever.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $110,000/year</h3>
        <p class="text-neutral-600 mb-4">Just over threshold, testing the waters.</p>
        <p class="text-amber-700 font-medium">△ Qualified but tight budget after high living costs. Had to be careful with spending. Worth it for the experience but not maximum comfort.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Consultant, $90,000/year</h3>
        <p class="text-neutral-600 mb-4">Income below threshold.</p>
        <p class="text-red-700 font-medium">✗ Didn't qualify. Applied for Bahamas BEATS instead ($25, no minimum). May try Cayman when income increases.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Crypto Investor, $250,000+/year</h3>
        <p class="text-neutral-600 mb-4">Capital gains tax optimization was critical.</p>
        <p class="text-green-700 font-medium">✓ Zero capital gains tax saving hundreds of thousands. Banking relationships solid. Using Cayman as permanent base.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Planning your move to the Cayman Islands? Get insurance quotes.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
    </a>
  </CTABox>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Underestimating Total Costs</h3>
        <p class="text-neutral-600">Meeting the $100k income requirement doesn't mean comfortable living. Budget $4,500-7,000/month for a reasonable lifestyle. At $100k income, you'll be quite budget-conscious.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Cheap Insurance</h3>
        <p class="text-neutral-600">Cayman healthcare is expensive, and complex cases require Miami evacuation. Don't skimp on insurance—premium coverage protects you in a high-cost environment.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Expecting Budget Caribbean</h3>
        <p class="text-neutral-600">Cayman is not Jamaica or Dominican Republic. It's closer to Bermuda pricing. Adjust expectations—this is premium Caribbean, priced accordingly.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Not Considering Miami Access</h3>
        <p class="text-neutral-600">Many things (healthcare, shopping, entertainment) are cheaper and better in Miami, just 1 hour away. Factor in regular Miami trips for best value.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Ignoring Hurricane Season</h3>
        <p class="text-neutral-600">Hurricane season (June-November) is real. Cayman has excellent infrastructure but storms do hit. Have plans and appropriate insurance coverage.</p>
      </div>
    </div>
  </section>

