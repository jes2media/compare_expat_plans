---
/**
 * Aruba Digital Nomad Visa (One Happy Workation) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Aruba", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Aruba Health Insurance Guide", href: "/countries/aruba/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Remote Work", details: "Employed by non-Aruba company", evidence: "Employment letter" },
  { requirement: "Health Insurance", details: "Required coverage in Aruba", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "Valid for stay duration", evidence: "Passport copy" },
  { requirement: "Return Flight", details: "Or proof of onward travel", evidence: "Flight booking" },
  { requirement: "Accommodation", details: "Proof of stay", evidence: "Hotel or rental confirmation" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Aruba Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Required", why: "Mandatory for visa" },
  { feature: "Coverage Territory", minimum: "Valid in Aruba", why: "Must cover your stay" },
  { feature: "COVID Coverage", minimum: "Required", why: "Part of entry requirements" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "Complex cases go to Colombia/US" },
  { feature: "Duration", minimum: "Full stay (up to 90 days)", why: "Continuous coverage needed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive global" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Caribbean coverage" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Trusted brand" },
  { provider: "World Nomads", coverage: "$100,000+", price: "$50-120", strengths: "Adventure activities" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Workation Application", amount: "Free", notes: "No visa fee" },
  { item: "ED Card", amount: "$15", notes: "Embarkation/Disembarkation card" },
  { item: "Health Insurance (3 months)", amount: "$150-600", notes: "International coverage" },
  { item: "AZV Insurance (Optional)", amount: "~$20/month", notes: "Local health fund" },
  { item: "Extension Fee", amount: "Varies", notes: "If staying beyond 90 days" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 days", location: "Home" },
  { step: "Purchase health insurance", duration: "1 day", location: "Online" },
  { step: "Complete ED Card", duration: "15 minutes", location: "Online" },
  { step: "Apply for Workation", duration: "30 minutes", location: "Online portal" },
  { step: "Receive approval", duration: "1-3 business days", location: "Email" },
  { step: "Travel to Aruba", duration: "At your convenience", location: "Queen Beatrix Airport" },
];
---

<PageShell
  title="Aruba Digital Nomad Visa 2025: One Happy Workation Insurance & Requirements Guide"
  description="Complete guide to Aruba's One Happy Workation program. Perfect beaches, no hurricanes, no visa fee, and 90-day remote work paradise in the Dutch Caribbean."
  headline="Aruba Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about One Happy Workation—free application, no income requirement, and 90 days on one of the Caribbean's most beautiful islands."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      No Visa Fee
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Hurricane-Free
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Aruba's "One Happy Workation" program lives up to its name. With no visa fee, no minimum income requirement, and up to 90 days on one of the world's most beautiful islands, Aruba offers an accessible taste of Caribbean remote work life.
    </p>

    <p class="mb-4">
      Known as "One Happy Island," Aruba delivers stunning beaches, consistent sunny weather, and a position outside the hurricane belt. As part of the Kingdom of the Netherlands, it combines Dutch efficiency with Caribbean relaxation.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: One Happy Workation</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Program:</strong> One Happy Workation</li>
        <li>• <strong>Application fee:</strong> Free (just $15 ED card)</li>
        <li>• <strong>Income requirement:</strong> None stated</li>
        <li>• <strong>Duration:</strong> Up to 90 days (extendable)</li>
        <li>• <strong>Insurance:</strong> Required</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Aruba for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>No visa fee:</strong> Free application (just $15 ED card)</li>
      <li><strong>No income requirement:</strong> Open to all remote workers</li>
      <li><strong>Hurricane-free:</strong> Outside the hurricane belt</li>
      <li><strong>Stunning beaches:</strong> Eagle Beach consistently rated world's best</li>
      <li><strong>Easy US access:</strong> Direct flights from many US cities</li>
      <li><strong>English widely spoken:</strong> Plus Dutch, Spanish, Papiamento</li>
      <li><strong>Safe and stable:</strong> Dutch territory with low crime</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Aruba is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want easy, free application process</li>
          <li>✓ Beach lifestyle is your priority</li>
          <li>✓ You want hurricane-free Caribbean</li>
          <li>✓ You need easy US flight access</li>
          <li>✓ You prefer English-speaking Caribbean</li>
          <li>✓ 90 days is enough (or willing to extend)</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want longer initial stays (12+ months)</li>
          <li>• Budget is extremely tight (Aruba is pricey)</li>
          <li>• You want lush, green tropical setting</li>
          <li>• You need varied terrain (Aruba is small/flat)</li>
          <li>• You prefer big city amenities</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-blue-800">
        <strong>Perfect for trying Caribbean:</strong> With no fees and minimal requirements, Aruba is ideal for testing the Caribbean nomad lifestyle before committing to longer programs elsewhere.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Aruba's One Happy Workation has minimal requirements—making it one of the most accessible digital nomad programs globally.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Program Details</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">What You Get</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> Up to 90 days</li>
          <li>• <strong>Cost:</strong> Free application</li>
          <li>• <strong>Extensions:</strong> Possible beyond 90 days</li>
          <li>• <strong>Work:</strong> Remote for non-Aruba employers</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">What's Required</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• Proof of remote employment</li>
          <li>• Health insurance</li>
          <li>• Accommodation booking</li>
          <li>• Return/onward flight</li>
        </ul>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-green-800">
        <strong>No income minimum:</strong> Unlike most DNV programs, Aruba doesn't specify a minimum income. You just need to prove you work remotely for a company outside Aruba.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport</li>
      <li>Proof of remote employment (letter from employer)</li>
      <li>Health insurance certificate covering Aruba</li>
      <li>Proof of accommodation (hotel/rental confirmation)</li>
      <li>Return or onward flight booking</li>
      <li>Completed ED Card ($15)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required</h3>
      <p class="text-red-800">
        Aruba requires health insurance covering your stay, including COVID-19 coverage. Your policy must be valid in Aruba. While no minimum amount is specified, comprehensive coverage is recommended.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Healthcare in Aruba</h3>

    <p class="mb-4">
      Aruba has one main hospital (Dr. Horacio Oduber Hospital) with decent care for most needs. Complex cases are evacuated to Colombia or the US.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Available on Island</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• General medical care</li>
          <li>• Basic emergency services</li>
          <li>• Common specialists</li>
          <li>• Dental services</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">May Need Evacuation</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Complex surgeries</li>
          <li>• Specialized care</li>
          <li>• Rare conditions</li>
          <li>• Advanced treatments</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Aruba's One Happy Workation?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For a 90-day stay, flexible monthly or trip-based policies work well:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Value</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Perfect for 90-day stays, includes COVID, easy monthly billing.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Adventure Activities</h4>
        <p class="text-neutral-600">World Nomads. Good if you'll be windsurfing, kiteboarding, or other adventure sports Aruba is famous for.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">Cigna Global for peace of mind, especially if you have pre-existing conditions or want extensive evacuation coverage.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      The workation application is free, but Aruba is not a budget destination. Plan accordingly.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">$2,500</p>
        <p class="text-sm text-neutral-500 mt-2">Basic rental, cooking</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$3,800</p>
        <p class="text-sm text-neutral-500 mt-2">Nice place, dining out</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium</p>
        <p class="text-3xl font-bold text-neutral-900">$6,000+</p>
        <p class="text-sm text-neutral-500 mt-2">Beachfront, full lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Aruba is Expensive</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Tourism economy:</strong> Prices oriented toward vacationers</li>
      <li><strong>Small island:</strong> Limited housing supply</li>
      <li><strong>Imports:</strong> Almost everything is imported</li>
      <li><strong>High demand:</strong> Popular destination drives prices</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Look for monthly rentals away from Eagle Beach/Palm Beach tourist zones. Oranjestad and Noord have more local pricing while still offering easy beach access.
      </p>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Aruba's application is one of the fastest and simplest—often approved within days.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get Health Insurance</h4>
          <p class="text-neutral-600">Purchase international health insurance covering Aruba including COVID. Get your certificate ready.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete ED Card</h4>
          <p class="text-neutral-600">Fill out the Embarkation/Disembarkation card online. Pay the $15 fee. Required for entry.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply for One Happy Workation</h4>
          <p class="text-neutral-600">Visit the official portal. Upload employment proof, insurance, and accommodation booking. Free application.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Typically approved within 1-3 business days. You'll receive email confirmation.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Book Travel</h4>
          <p class="text-neutral-600">Book your flights and accommodation (if not already done). Many US cities have direct flights to Aruba.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Arrive and Enjoy</h4>
          <p class="text-neutral-600">Present your approval and ED card at immigration. Welcome to One Happy Island!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Manager, $5,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted easy beach escape from US winter.</p>
        <p class="text-green-700 font-medium">✓ Applied Monday, approved Wednesday, flew Saturday. 3 months of beach sunsets and productive mornings. Best winter ever.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Developer, $4,000/month</h3>
        <p class="text-neutral-600 mb-4">Testing Caribbean life before longer commitment.</p>
        <p class="text-green-700 font-medium">✓ 90 days was perfect trial. Loved it. Now planning return with longer visa (Curaçao for 6 months next).</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Creator, $3,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable Caribbean option.</p>
        <p class="text-amber-700 font-medium">△ Aruba more expensive than expected. Found affordable studio outside tourist zone. Made it work but tight. Great content though!</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Kiteboarding Enthusiast, $6,000/month</h3>
        <p class="text-neutral-600 mb-4">Wanted to combine work with wind sports.</p>
        <p class="text-green-700 font-medium">✓ Aruba's wind is incredible. Working mornings, kiteboarding afternoons. Fisherman's Huts every day. Living the dream.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Remote Couple, $7,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Wanted easy romantic getaway with work flexibility.</p>
        <p class="text-green-700 font-medium">✓ Both applied, both approved same day. Beachfront condo split between us. Perfect balance of productivity and romance.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Project Manager, $5,500/month</h3>
        <p class="text-neutral-600 mb-4">Needed reliable internet and US timezone.</p>
        <p class="text-green-700 font-medium">✓ Aruba's internet is solid. Same timezone as East Coast. Team didn't even notice I was in paradise during calls.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Ready for One Happy Workation? Compare insurance plans.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
