---
/**
 * Taiwan Digital Nomad Visa (Gold Card) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Taiwan", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Taiwan Health Insurance Guide", href: "/countries/taiwan/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Salary/Income", details: "NT$160,000+/month (~$5,000) OR expertise", evidence: "Tax returns, pay stubs, employment letter" },
  { requirement: "Professional Expertise", details: "8+ fields: tech, science, economy, etc.", evidence: "Publications, patents, portfolio" },
  { requirement: "Health Insurance", details: "Required (NHI after 6 months)", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Taiwan Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive", why: "Required for first 6 months" },
  { feature: "Coverage Territory", minimum: "Valid in Taiwan", why: "Must cover your stay" },
  { feature: "Duration", minimum: "Until NHI eligible (6 months)", why: "Bridge coverage needed" },
  { feature: "Hospitalization", minimum: "Covered", why: "Private hospitals can be costly" },
  { feature: "Emergency Services", minimum: "24/7 coverage", why: "Round-the-clock access" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "First 6 months coverage" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-400", strengths: "Comprehensive global" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$170-320", strengths: "Asia-Pacific focus" },
  { provider: "Taiwan NHI", coverage: "Comprehensive", price: "~$25-50", strengths: "After 6 months (mandatory)" },
  { provider: "BUPA Global", coverage: "$2,000,000+", price: "$300-500", strengths: "Premium worldwide" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Gold Card Application", amount: "$100-310", notes: "Varies by duration (1-3 years)" },
  { item: "Health Insurance (First 6 mo)", amount: "$300-1,500", notes: "International coverage" },
  { item: "NHI (After 6 months)", amount: "~$25-50/mo", notes: "Mandatory, income-based" },
  { item: "ARC Processing", amount: "Included", notes: "In Gold Card fee" },
  { item: "Background Check", amount: "$20-50", notes: "Home country" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Online application", duration: "1-2 hours", location: "Gold Card website" },
  { step: "Document review", duration: "1-4 weeks", location: "National Immigration Agency" },
  { step: "Background check", duration: "1-2 weeks", location: "Ministry review" },
  { step: "Approval notification", duration: "Via email", location: "Online portal" },
  { step: "Card pickup", duration: "Within 30 days", location: "Taiwan (airport or NIA)" },
  { step: "NHI enrollment", duration: "After 6 months", location: "Local NHI office" },
];
---

<PageShell
  title="Taiwan Gold Card 2025: Digital Nomad Visa Insurance & Requirements Guide"
  description="Complete guide to Taiwan's Employment Gold Card for digital nomads. NHI healthcare after 6 months, $5,000/month income path, and why Taiwan is Asia's hidden gem for remote workers."
  headline="Taiwan Gold Card: Digital Nomad Visa Guide"
  subheadline="Everything you need to know about Taiwan's Employment Gold Card—the gold standard for working remotely in one of Asia's safest, friendliest, and most affordable tech hubs."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Gold Card Program
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      NHI Healthcare Access
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Taiwan's Employment Gold Card is one of the world's best digital nomad programs. Launched in 2018 and expanded significantly since, it combines work permit, residence visa, and re-entry permit in one card—giving you the freedom to live, work, and travel freely from Taiwan for 1-3 years.
    </p>

    <p class="mb-4">
      The Gold Card stands out because of Taiwan itself: exceptional healthcare (ranked top 3 globally), incredible food culture, high safety, fast internet, and living costs well below other developed Asian economies. After 6 months, you qualify for Taiwan's world-renowned National Health Insurance at just $25-50/month.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Taiwan Employment Gold Card</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1, 2, or 3 years (renewable)</li>
        <li>• <strong>Income path:</strong> NT$160,000+/month (~$5,000) in most recent year</li>
        <li>• <strong>Expertise path:</strong> Demonstrated expertise in 8 professional fields</li>
        <li>• <strong>Processing time:</strong> 2-6 weeks (online application)</li>
        <li>• <strong>Healthcare:</strong> NHI access after 6 months (~$25-50/month)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Taiwan for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>World-class healthcare:</strong> NHI ranked top 3 globally, costs ~$25-50/month after 6 months</li>
      <li><strong>Exceptional safety:</strong> One of the lowest crime rates in the world</li>
      <li><strong>Amazing food:</strong> Night markets, incredible cuisine, affordable eating out</li>
      <li><strong>Fast, reliable internet:</strong> Average speeds over 100 Mbps</li>
      <li><strong>Affordable living:</strong> $1,500-2,500/month for comfortable lifestyle</li>
      <li><strong>Friendly to foreigners:</strong> Welcoming culture, growing English proficiency</li>
      <li><strong>Geographic hub:</strong> Easy flights to Japan, Korea, Southeast Asia</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Taiwan Gold Card is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn $5,000+/month OR have professional expertise</li>
          <li>✓ You want exceptional, affordable healthcare</li>
          <li>✓ You value safety and quality of life</li>
          <li>✓ You love food culture and night markets</li>
          <li>✓ You want a base for exploring Asia</li>
          <li>✓ You appreciate friendly, welcoming culture</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You earn below $5,000/month without expertise</li>
          <li>• You need everything in English</li>
          <li>• You prefer European lifestyle/culture</li>
          <li>• You dislike humidity and typhoon season</li>
          <li>• You want immediate NHI access (6-month wait)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Taiwan's Gold Card has two main qualification paths: income-based or expertise-based. Most digital nomads use the income path through the "Economy" field.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Qualification Paths</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Income Path (Most Common)</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Requirement:</strong> NT$160,000+/month (~$5,000)</li>
          <li>• <strong>Period:</strong> Most recent taxable year</li>
          <li>• <strong>Field:</strong> Apply under "Economy"</li>
          <li>• <strong>Evidence:</strong> Tax returns, pay stubs, employment letters</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Expertise Path</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Fields:</strong> Science, Tech, Economy, Education, Culture, Sports, Finance, Law, Architecture</li>
          <li>• <strong>Evidence:</strong> Publications, patents, awards, portfolio</li>
          <li>• <strong>Note:</strong> More subjective evaluation</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Digital Economy Field:</strong> A "Digital Economy" category exists for tech workers. If you work in software, AI, blockchain, or digital services, you may qualify through expertise rather than pure income.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Digital passport photo</li>
      <li>Proof of income (tax returns, pay stubs, employment letter)</li>
      <li>OR proof of expertise (publications, patents, portfolio, awards)</li>
      <li>Police clearance certificate (may be requested)</li>
      <li>Health insurance proof (for first 6 months)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Two-Phase Coverage</h3>
      <p class="text-blue-800">
        You need international health insurance for the first 6 months. After 6 months of residence, you become eligible for Taiwan's National Health Insurance (NHI)—one of the world's best systems at ~$25-50/month.
      </p>
    </div>

    <p class="mb-4">
      Taiwan's healthcare is exceptional. The 6-month waiting period for NHI means you need private coverage initially, but once enrolled, you'll have access to world-class care at minimal cost.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Taiwan's National Health Insurance (NHI)</h3>

    <p class="mb-4">
      Taiwan's NHI is consistently ranked among the world's best healthcare systems. After 6 months of residence with your Gold Card, you're required to enroll.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">First 6 Months (Private Insurance)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Private hospitals and clinics</li>
          <li>• <strong>Cost:</strong> $50-300/month (international plans)</li>
          <li>• <strong>Quality:</strong> Excellent in major cities</li>
          <li>• <strong>Language:</strong> English available at major hospitals</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">After 6 Months (NHI)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Cost:</strong> ~$25-50/month (income-based)</li>
          <li>• <strong>Coverage:</strong> Comprehensive, including dental</li>
          <li>• <strong>Quality:</strong> World-class (top 3 globally)</li>
          <li>• <strong>Wait times:</strong> Minimal for most services</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need insurance for your first 6 months in Taiwan?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For your first 6 months before NHI eligibility, these providers offer suitable coverage:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">First 6 Months (Bridge Coverage)</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Affordable coverage until NHI kicks in.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Asia-Pacific Travel</h4>
        <p class="text-neutral-600">Allianz Care. Strong regional network if you'll travel frequently to Japan, Korea, Southeast Asia.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage for those with global travel needs.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">After 6 Months</h4>
        <p class="text-neutral-600">Taiwan NHI (mandatory). At $25-50/month, it's one of the world's best deals in healthcare.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Taiwan has very reasonable visa costs and exceptional value for healthcare once on NHI.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">1-Year Card</p>
        <p class="text-3xl font-bold text-neutral-900">$500</p>
        <p class="text-sm text-neutral-500 mt-2">Card + 6mo insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">2-Year Card</p>
        <p class="text-3xl font-bold text-neutral-900">$600</p>
        <p class="text-sm text-neutral-500 mt-2">Card + 6mo insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">3-Year Card</p>
        <p class="text-3xl font-bold text-neutral-900">$700</p>
        <p class="text-sm text-neutral-500 mt-2">Card + 6mo insurance</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Taiwan offers excellent value. Taipei is the most expensive city but still very affordable by developed country standards.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> $1,200-1,500/month (studio, local food, public transit)</li>
      <li><strong>Comfortable:</strong> $1,800-2,500/month (1BR apartment, dining out, activities)</li>
      <li><strong>Premium:</strong> $3,500+/month (central Taipei, premium lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Taiwan's Gold Card application is entirely online—one of the most streamlined processes globally. You can apply from anywhere in the world.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Visit goldcard.nat.gov.tw and create an account. Complete the application form and upload documents. The entire process takes 1-2 hours.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Application Fee</h4>
          <p class="text-neutral-600">Pay online via credit card. Fees: 1-year ($100), 2-year ($200), 3-year ($310). Choose based on your planned stay.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 2-6 weeks. Track status online. You may receive requests for additional documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Approval notification comes via email. Download your approval letter from the portal.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pick Up Card in Taiwan</h4>
          <p class="text-neutral-600">Collect your physical Gold Card at Taoyuan Airport (upon arrival) or any National Immigration Agency office within 30 days of approval.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enroll in NHI (After 6 Months)</h4>
          <p class="text-neutral-600">After 6 months of consecutive residence, visit your local NHI office to enroll. Bring your Gold Card and passport.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Pick up your Gold Card at Taoyuan Airport when you arrive—there's a dedicated desk for Gold Card holders. This saves you a trip to an NIA office.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Taiwan's Gold Card:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Engineer, $7,000/month</h3>
        <p class="text-neutral-600 mb-4">Works for US tech company, loves Japanese culture and wants an Asia base.</p>
        <p class="text-green-700 font-medium">✓ Approved via income path (Economy field). Now enjoying Taiwan's food, safety, and easy travel to Japan.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">AI Researcher, $4,500/month</h3>
        <p class="text-neutral-600 mb-4">Income below threshold but has published papers and conference presentations.</p>
        <p class="text-green-700 font-medium">✓ Approved via expertise path (Science & Technology). Publications demonstrated professional expertise.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $3,500/month</h3>
        <p class="text-neutral-600 mb-4">Below income threshold, no academic publications.</p>
