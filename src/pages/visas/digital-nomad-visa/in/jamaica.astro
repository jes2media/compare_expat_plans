---
/**
 * Jamaica Digital Nomad Visa (Digital Nomad Visa) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Jamaica", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Jamaica Health Insurance Guide", href: "/countries/jamaica/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Annual Income", details: "$50,000/year minimum", evidence: "Tax returns, bank statements" },
  { requirement: "Remote Work", details: "Work for non-Jamaica employer", evidence: "Employment letter or business proof" },
  { requirement: "Health Insurance", details: "Required for visa duration", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Jamaica Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Required", why: "Mandatory for visa" },
  { feature: "Coverage Territory", minimum: "Valid in Jamaica", why: "Must cover your stay" },
  { feature: "Emergency Evacuation", minimum: "Highly recommended", why: "Limited specialists on island" },
  { feature: "Duration", minimum: "Full visa period (1-2 years)", why: "Continuous coverage needed" },
  { feature: "Repatriation", minimum: "Recommended", why: "Return transport if needed" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive + US access" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Caribbean coverage" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Global coverage" },
  { provider: "GeoBlue", coverage: "$500,000+", price: "$150-280", strengths: "US expats" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "DNV Application Fee", amount: "$100", notes: "Non-refundable" },
  { item: "Dependent Fee", amount: "$50 each", notes: "Per dependent" },
  { item: "Health Insurance (Annual)", amount: "$600-2,500", notes: "International coverage" },
  { item: "Police Clearance", amount: "$50-100", notes: "From home country" },
  { item: "Renewal Fee", amount: "$100", notes: "After first year" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Purchase health insurance", duration: "1 day", location: "Online" },
  { step: "Apply online", duration: "1 day", location: "PICA portal" },
  { step: "Processing", duration: "2-4 weeks", location: "Immigration review" },
  { step: "Receive approval", duration: "Email notification", location: "Online" },
  { step: "Travel to Jamaica", duration: "At your convenience", location: "Montego Bay or Kingston" },
];
---

<PageShell
  title="Jamaica Digital Nomad Visa 2026: DNV Insurance & Requirements Guide"
  description="Complete guide to Jamaica's Digital Nomad Visa. $50k income requirement, 1-2 year stays, reggae culture, Blue Mountains, and affordable Caribbean living."
  headline="Jamaica Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the birthplace of reggae—1-2 year stays, vibrant culture, and the most affordable Caribbean DNV destination."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official PICA Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Most Affordable Caribbean
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Jamaica's Digital Nomad Visa offers up to 2 years in the Caribbean's most culturally rich destination. From reggae music to Blue Mountain coffee, jerk chicken to stunning beaches, Jamaica delivers an immersive experience unlike the more polished Dutch Caribbean islands.
    </p>

    <p class="mb-4">
      With the lowest cost of living among major Caribbean DNV destinations, Jamaica lets your money go further. The $50,000/year income requirement ensures financial stability while keeping the program accessible to mid-level remote workers.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Jamaica Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Visa type:</strong> Digital Nomad Visa (DNV)</li>
        <li>• <strong>Income requirement:</strong> $50,000/year minimum</li>
        <li>• <strong>Duration:</strong> 1 year, renewable for additional year</li>
        <li>• <strong>Application fee:</strong> $100 (+ $50/dependent)</li>
        <li>• <strong>Currency:</strong> Jamaican Dollar (JMD)</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Jamaica for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Most affordable Caribbean:</strong> Significantly cheaper than Bahamas, Cayman, or Aruba</li>
      <li><strong>Rich culture:</strong> Reggae, Rastafari, unique Jamaican identity</li>
      <li><strong>English-speaking:</strong> Official language is English</li>
      <li><strong>Geographic diversity:</strong> Beaches, mountains, rivers, waterfalls</li>
      <li><strong>Long stay:</strong> Up to 2 years possible</li>
      <li><strong>Easy US access:</strong> Direct flights from many US cities</li>
      <li><strong>Vibrant food scene:</strong> Jerk everything, Blue Mountain coffee</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Jamaica is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You want affordable Caribbean living</li>
          <li>✓ You value authentic cultural experiences</li>
          <li>✓ You earn $50,000+/year remotely</li>
          <li>✓ You want longer stays (1-2 years)</li>
          <li>✓ You enjoy adventure (hiking, waterfalls)</li>
          <li>✓ You're comfortable with some roughness</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want ultra-polished infrastructure</li>
          <li>• Safety concerns are paramount</li>
          <li>• You need cutting-edge healthcare</li>
          <li>• You prefer quiet, controlled environments</li>
          <li>• You want to avoid hurricane season</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Real talk:</strong> Jamaica is vibrant and affordable but has higher crime rates than other Caribbean DNV destinations. Stick to safe areas (tourist zones, gated communities) and use common sense. Most nomads have great experiences.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Jamaica's DNV requires $50,000/year income—higher than some programs but appropriate for the up-to-2-year duration.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Program Details</h3>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-green-200 bg-green-50 rounded-lg p-6">
        <h4 class="font-semibold text-green-900 mb-3">Initial Application</h4>
        <ul class="space-y-2 text-green-800">
          <li>• <strong>Duration:</strong> 1 year</li>
          <li>• <strong>Fee:</strong> $100</li>
          <li>• <strong>Dependents:</strong> $50 each</li>
          <li>• <strong>Processing:</strong> 2-4 weeks</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-3">Renewal Option</h4>
        <ul class="space-y-2 text-blue-800">
          <li>• <strong>Duration:</strong> Additional 1 year</li>
          <li>• <strong>Fee:</strong> $100</li>
          <li>• <strong>Total possible:</strong> 2 years</li>
          <li>• <strong>Requirements:</strong> Same as initial</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Income Proof Options</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Recent tax returns showing $50,000+ income</li>
      <li>Employment letter stating annual salary</li>
      <li>6-12 months bank statements showing consistent income</li>
      <li>Business revenue documentation (if self-employed)</li>
      <li>Combination of above showing total $50,000+</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-red-900 mb-2">Health Insurance Required</h3>
      <p class="text-red-800">
        Jamaica requires health insurance for the DNV application. Your policy must cover medical expenses in Jamaica for your visa duration. Given limited local healthcare, comprehensive coverage with evacuation is strongly recommended.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Recommendations</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Why Evacuation Coverage Matters</h3>

    <p class="mb-4">
      Jamaica has adequate basic healthcare but limited advanced care. Complex cases often require evacuation to Miami. Make sure your policy includes strong evacuation coverage.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Available in Jamaica</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Basic and intermediate care</li>
          <li>• Common procedures</li>
          <li>• General practitioners</li>
          <li>• Basic emergency services</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">May Require Evacuation</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• Complex surgeries</li>
          <li>• Specialized oncology</li>
          <li>• Advanced cardiac care</li>
          <li>• Rare conditions</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Jamaica's Digital Nomad Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Jamaica, prioritize providers with strong evacuation coverage and US network access:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Option</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Adequate for healthy young nomads. Verify evacuation coverage limits.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Best Overall</h4>
        <p class="text-neutral-600">Cigna Global or IMG Global. Strong evacuation coverage and US network access for Miami care.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">US Expats</h4>
        <p class="text-neutral-600">GeoBlue. Excellent US network integration—important given Jamaica's Miami evacuation pattern.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Jamaica is the most affordable major Caribbean DNV destination—your income goes significantly further here.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Monthly Cost of Living</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget</p>
        <p class="text-3xl font-bold text-neutral-900">$1,200</p>
        <p class="text-sm text-neutral-500 mt-2">Basic living, local food</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Comfortable</p>
        <p class="text-3xl font-bold text-neutral-900">$2,000</p>
        <p class="text-sm text-neutral-500 mt-2">Nice apartment, dining out</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium</p>
        <p class="text-3xl font-bold text-neutral-900">$3,500+</p>
        <p class="text-sm text-neutral-500 mt-2">Upscale area, full lifestyle</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost Comparison</h3>

    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <p class="text-green-800 mb-3">
        <strong>Jamaica vs. other Caribbean DNV destinations:</strong>
      </p>
      <ul class="space-y-2 text-green-800">
        <li>• <strong>vs. Bahamas:</strong> 50-60% cheaper</li>
        <li>• <strong>vs. Cayman:</strong> 60-70% cheaper</li>
        <li>• <strong>vs. Aruba:</strong> 40-50% cheaper</li>
        <li>• <strong>vs. Barbados:</strong> 30-40% cheaper</li>
      </ul>
    </div>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Applications are handled through PICA (Passport, Immigration and Citizenship Agency) online portal.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Verify Income</h4>
          <p class="text-neutral-600">Confirm you meet the $50,000/year threshold. Gather tax returns, bank statements, or employment documentation.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Get Health Insurance</h4>
          <p class="text-neutral-600">Purchase international health insurance covering Jamaica for 1 year. Obtain certificate showing dates and coverage.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Gather Documents</h4>
          <p class="text-neutral-600">Collect passport copy, police clearance, proof of remote work, and income documentation.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Submit application through PICA portal. Upload all documents and pay the $100 fee.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Await Approval</h4>
          <p class="text-neutral-600">Processing takes 2-4 weeks typically. You'll receive email notification with approval.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">6</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Travel to Jamaica</h4>
          <p class="text-neutral-600">Fly to Montego Bay or Kingston. Present your approval at immigration. Welcome to Jamaica!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $80,000/year</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable Caribbean with authentic culture.</p>
        <p class="text-green-700 font-medium">✓ Living well on $2,000/month in Ocho Rios. Saving huge amounts vs. Bahamas plan. Loving jerk chicken and reggae nights.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Manager, $65,000/year</h3>
        <p class="text-neutral-600 mb-4">Wanted 2-year Caribbean stay on budget.</p>
        <p class="text-green-700 font-medium">✓ Montego Bay beachfront apartment for what a studio costs in Cayman. Weekend trips to Blue Mountains. Best value Caribbean DNV.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Designer, $52,000/year</h3>
        <p class="text-neutral-600 mb-4">Just over the income threshold.</p>
        <p class="text-amber-700 font-medium">△ Qualified! Living budget-conscious but happy. Negril vibes are perfect. Would struggle in more expensive islands.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Music Producer, $70,000/year</h3>
        <p class="text-neutral-600 mb-4">Wanted to immerse in reggae culture.</p>
        <p class="text-green-700 font-medium">✓ Living in Kingston, connected with local music scene. Collaborating with Jamaican artists. Dream come true for a reggae lover.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Project Manager, $45,000/year</h3>
        <p class="text-neutral-600 mb-4">Income below threshold.</p>
        <p class="text-red-700 font-medium">✗ Didn't qualify for Jamaica DNV. Applied for Aruba instead (no income minimum). May try Jamaica when income increases.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Remote Couple, $90,000 combined</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable Caribbean adventure together.</p>
        <p class="text-green-700 font-medium">✓ Both applied and approved. Beautiful 2BR in Treasure Beach for $1,200/month. Living like royalty on their budget.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Ready for Jamaica? Compare insurance plans now.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
    </a>
  </CTABox>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Ignoring Safety Considerations</h3>
        <p class="text-neutral-600">Jamaica has higher crime rates than other Caribbean DNV destinations. Stick to safe areas (resort towns, gated communities), avoid walking alone at night, and use registered taxis. Most nomads stay safe with basic precautions.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Skimping on Evacuation Coverage</h3>
        <p class="text-neutral-600">Jamaica's healthcare has limits. Complex medical situations may require evacuation to Miami. Don't skip evacuation coverage—it could be critical.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Expecting Resort-Level Everything</h3>
        <p class="text-neutral-600">Jamaica outside resort areas is real Caribbean—beautiful but not polished. Infrastructure varies. Embrace the authentic experience rather than expecting Cayman-level refinement.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Not Checking Internet</h3>
        <p class="text-neutral-600">Internet quality varies significantly by location. Verify connectivity before booking long-term accommodation. Urban areas and resort towns have better coverage.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Hurricane Season Naivety</h3>
        <p class="text-neutral-600">Jamaica is in the hurricane belt (June-November). Unlike Aruba or Curaçao, hurricanes are real. Have plans and appropriate insurance coverage.</p>
      </div>
    </div>
