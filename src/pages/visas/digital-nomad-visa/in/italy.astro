---
/**
 * Italy Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Italy", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Italy Health Insurance Guide", href: "/countries/italy/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Annual Income", details: "€28,000+/year (minimum)", evidence: "Tax returns, contracts, bank statements" },
  { requirement: "Remote Work", details: "Work for non-Italian clients/employers", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "Mandatory comprehensive coverage", evidence: "Insurance certificate" },
  { requirement: "Accommodation", details: "Proof of housing in Italy", evidence: "Lease agreement or property deed" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Qualifications", details: "Highly qualified remote worker", evidence: "Degree, portfolio, or professional credentials" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Italy Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive (no cap specified)", why: "Italian healthcare is expensive for non-residents" },
  { feature: "Hospitalization", minimum: "Required", why: "Inpatient costs can exceed €1,000/day" },
  { feature: "Repatriation", minimum: "Strongly recommended", why: "Return transport coverage" },
  { feature: "Coverage Area", minimum: "Italy + Schengen", why: "Free travel within EU" },
  { feature: "Duration", minimum: "Full visa period", why: "No gaps permitted" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive coverage" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-300", strengths: "Strong EU network" },
  { provider: "IMG Global", coverage: "€1,000,000", price: "€100-200", strengths: "Mid-range coverage" },
  { provider: "Feather", coverage: "Varies", price: "€80-180", strengths: "EU expat specialist" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€116", notes: "Standard long-stay visa" },
  { item: "Residence Permit", amount: "€100-200", notes: "Permesso di soggiorno" },
  { item: "Health Insurance (Annual)", amount: "€500-3,500", notes: "Comprehensive coverage" },
  { item: "Document Translation", amount: "€100-300", notes: "Sworn translations" },
  { item: "Apostille/Legalization", amount: "€50-100", notes: "Per document" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "2-4 weeks", location: "Home country" },
  { step: "Submit visa application", duration: "1 day", location: "Italian consulate" },
  { step: "Processing", duration: "30-90 days", location: "Consulate" },
  { step: "Receive visa", duration: "Via passport", location: "Consulate pickup" },
  { step: "Enter Italy", duration: "Within 90 days", location: "Any Italian entry point" },
  { step: "Apply for residence permit", duration: "Within 8 days of arrival", location: "Local Questura" },
];
---

<PageShell
  title="Italy Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Italy's new Digital Nomad Visa. Live la dolce vita legally—€28,000 income requirement, insurance requirements, and step-by-step application."
  headline="Italy Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from Italy—la dolce vita meets location independence."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/italy-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Italian Immigration Law
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU/Schengen Member
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Italy officially launched its Digital Nomad Visa in April 2024, finally giving remote workers a legal pathway to experience la dolce vita. After years of nomads navigating gray areas with tourist visas, Italy now welcomes location-independent professionals with a dedicated residence permit.
    </p>

    <p class="mb-4">
      From the Renaissance art of Florence to the ancient ruins of Rome, the Amalfi Coast to the Dolomites, Italy offers unparalleled cultural richness. Now you can legally work while savoring espresso in piazzas, enjoying three-hour lunches, and exploring one of the world's most beloved countries.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Italy Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> Up to 1 year (renewable)</li>
        <li>• <strong>Income requirement:</strong> €28,000+/year minimum</li>
        <li>• <strong>Processing time:</strong> 30-90 days typical</li>
        <li>• <strong>Insurance:</strong> Mandatory comprehensive health coverage</li>
        <li>• <strong>Tax status:</strong> Potential flat tax benefits available</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Italy for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Cultural immersion:</strong> Art, history, food, wine—nowhere compares</li>
      <li><strong>Geographic variety:</strong> Alps, beaches, lakes, countryside, cities</li>
      <li><strong>Schengen access:</strong> Travel freely across 27 European countries</li>
      <li><strong>Quality of life:</strong> Mediterranean lifestyle, outdoor living</li>
      <li><strong>Tax incentives:</strong> Potential 7% flat tax for new residents in select regions</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Italy is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €28,000+/year from remote work</li>
          <li>✓ You prioritize culture, food, and lifestyle</li>
          <li>✓ You want EU/Schengen base</li>
          <li>✓ You can handle bureaucracy patiently</li>
          <li>✓ You appreciate slower pace of life</li>
          <li>✓ You want to learn Italian</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need fast, efficient processes</li>
          <li>• You work US hours exclusively</li>
          <li>• You want rock-bottom costs</li>
          <li>• You hate bureaucracy</li>
          <li>• You need everything in English</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Italy's Digital Nomad Visa targets "highly qualified" remote workers. The income threshold is relatively accessible at €28,000/year (about €2,333/month), making it one of the more achievable European nomad visas.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate €28,000/year in remote work income. Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from non-Italian employer</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>Bank statements:</strong> 6-12 months showing consistent income</li>
      <li><strong>Client contracts:</strong> For freelancers, active agreements</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Highly Qualified:</strong> Italy requires applicants to be "highly qualified" workers. This typically means a university degree, specialized professional credentials, or demonstrable expertise in your field.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Visa application form</li>
      <li>Passport photos (Italian specifications)</li>
      <li>Proof of income (€28,000+/year)</li>
      <li>Health insurance certificate</li>
      <li>Proof of accommodation in Italy</li>
      <li>Employment contract or freelance agreements</li>
      <li>Qualification documents (degree, certifications)</li>
      <li>Criminal record certificate (apostilled)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Comprehensive Coverage Required</h3>
      <p class="text-blue-800">
        Italy requires comprehensive health insurance covering all medical risks for the full duration of your stay. Unlike some Schengen countries, there's no specific minimum coverage amount—but the policy must be genuinely comprehensive.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Italy's Digital Nomad Visa. Your policy must cover all healthcare needs since digital nomads don't qualify for Italy's public healthcare system (SSN).
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Italian Healthcare Context</h3>

    <p class="mb-4">
      Italy's Servizio Sanitario Nazionale (SSN) is excellent for residents, but digital nomads must use private healthcare. Major cities have English-speaking private clinics, but Italian proficiency helps significantly.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (SSN)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Not available to DN visa holders</li>
          <li>• <strong>Emergency:</strong> Will treat, charge full cost</li>
          <li>• <strong>Quality:</strong> Varies by region (north excellent)</li>
          <li>• <strong>Language:</strong> Italian primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With international insurance</li>
          <li>• <strong>Quality:</strong> Excellent in major cities</li>
          <li>• <strong>Language:</strong> English in Rome, Milan, Florence</li>
          <li>• <strong>Cost:</strong> High without insurance</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need comprehensive insurance for Italy's Digital Nomad Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer comprehensive coverage suitable for Italy's Digital Nomad Visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €40-75/month. Solid coverage at the lowest cost point.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Coverage</h4>
        <p class="text-neutral-600">Allianz Care or Feather. Strong European networks, designed for EU expats.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage with excellent Italian network.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Mid-Range Value</h4>
        <p class="text-neutral-600">IMG Global. Good coverage at moderate prices, EU-friendly.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Italy's visa fees are moderate by European standards. Budget for document translation and legalization costs.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€900</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€2,200</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€4,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive plan</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Italy's cost of living varies dramatically by location. Rome and Milan are expensive; southern regions and smaller cities are surprisingly affordable.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget (south/small cities):</strong> €1,500-2,000/month</li>
      <li><strong>Comfortable (mid-sized cities):</strong> €2,500-3,500/month</li>
      <li><strong>Premium (Rome/Milan center):</strong> €4,000-6,000/month</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Italy's visa process involves applying at your local Italian consulate, then registering for a residence permit (permesso di soggiorno) after arrival. Patience with Italian bureaucracy is essential.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documentation</h4>
          <p class="text-neutral-600">Gather all required documents. Get translations into Italian by sworn translators. Apostille documents as required.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Book Consulate Appointment</h4>
          <p class="text-neutral-600">Schedule appointment at Italian consulate in your home country. Wait times vary—book early.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Attend appointment with all documents. Pay visa fee. Provide biometrics.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 30-90 days. Consulates may request additional documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Italy & Register</h4>
          <p class="text-neutral-600">Within 8 days of arrival, apply for your permesso di soggiorno at the local Questura (police immigration office).</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The permesso di soggiorno application requires visiting a post office (Poste Italiane) to submit your kit. Bring patience and ideally an Italian speaker for your Questura appointment.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Italy's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, €45,000/year</h3>
        <p class="text-neutral-600 mb-4">Works for US startup, dreams of Florentine life. Has design degree.</p>
        <p class="text-green-700 font-medium">✓ Approved. Income exceeds threshold, degree qualifies as "highly qualified."</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Writer, €32,000/year</h3>
        <p class="text-neutral-600 mb-4">Freelancer with multiple clients, no degree but 10 years experience.</p>
        <p class="text-green-700 font-medium">✓ Approved. Portfolio demonstrated expertise compensating for lack of degree.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Junior Developer, €24,000/year</h3>
        <p class="text-neutral-600 mb-4">Entry-level remote job, wants Rome experience.</p>
        <p class="text-red-700 font-medium">✗ Denied. €4,000 below €28,000 minimum. Advised to increase income first.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Consultant, €80,000/year</h3>
        <p class="text-neutral-600 mb-4">High earner interested in Italy's tax incentives for new residents.</p>
        <p class="text-green-700 font-medium">✓ Approved quickly. Also qualified for 7% flat tax in southern region.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">YouTuber, €35,000/year</h3>
        <p class="text-neutral-600 mb-4">Self-employed content creator, income from ads and sponsorships.</p>
        <p class="text-amber-700 font-medium">△ Requested additional docs. Needed detailed income breakdown showing consistent earnings.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, €50,000/year combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, one earns €30,000, other €20,000.</p>
        <p class="text-amber-700 font-medium">△ Applied separately. One approved, other below threshold—restructured income.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Compare insurance plans for your Italian adventure—get quotes in minutes.</p>
