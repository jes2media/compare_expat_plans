---
/**
 * Sri Lanka Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Sri Lanka", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Sri Lanka Health Insurance Guide", href: "/countries/sri-lanka/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "$2,000/month", evidence: "Bank statements, employment contract" },
  { requirement: "Remote Work", details: "Work for company outside Sri Lanka", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "Mandatory comprehensive coverage", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "Police clearance certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Sri Lanka Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "$50,000+ recommended", why: "Required for visa" },
  { feature: "COVID Coverage", minimum: "Required", why: "Explicitly mandated" },
  { feature: "Medical Evacuation", minimum: "Essential", why: "Limited local facilities" },
  { feature: "Coverage Territory", minimum: "Valid in Sri Lanka", why: "Must cover your stay" },
  { feature: "Duration", minimum: "Full visa period", why: "No gaps permitted" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "World Nomads", coverage: "$100,000", price: "$50-120", strengths: "Adventure coverage" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive + evacuation" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Asia focus" },
  { provider: "IMG Global", coverage: "$500,000+", price: "$120-250", strengths: "Flexible deductibles" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Digital Nomad Visa Fee", amount: "$500", notes: "1-year visa" },
  { item: "Visa Extension", amount: "$250", notes: "Per 6-month extension" },
  { item: "Health Insurance (Annual)", amount: "$500-2,500", notes: "With evacuation coverage" },
  { item: "ETA (if required)", amount: "$35-50", notes: "Online application" },
  { item: "Document Notarization", amount: "$20-50", notes: "If required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Online application", duration: "1-2 hours", location: "Sri Lanka Immigration website" },
  { step: "Document review", duration: "5-10 working days", location: "Online processing" },
  { step: "Approval notification", duration: "Via email", location: "Digital notification" },
  { step: "Travel to Sri Lanka", duration: "Within approval validity", location: "Any international airport" },
  { step: "Collect visa on arrival", duration: "At immigration", location: "Colombo or Mattala airport" },
  { step: "Register locally", duration: "Within 1 week", location: "Local police station (if required)" },
];
---

<PageShell
  title="Sri Lanka Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Sri Lanka's Digital Nomad Visa. $2,000/month income requirement, tropical paradise lifestyle, affordable living, and what to know about post-crisis Sri Lanka."
  headline="Sri Lanka Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the Pearl of the Indian Ocean—visa requirements, insurance needs, and life in post-recovery Sri Lanka."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official Immigration Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Post-Crisis Recovery
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Sri Lanka launched its Digital Nomad Visa in early 2024 as part of its economic recovery efforts following the 2022 crisis. The program offers remote workers a chance to experience one of South Asia's most beautiful countries—beaches, mountains, ancient temples, and incredible wildlife—at remarkably affordable prices.
    </p>

    <p class="mb-4">
      With a relatively low income requirement ($2,000/month), Sri Lanka is accessible to more nomads than programs in Taiwan or Europe. The country is actively rebuilding its tourism infrastructure and welcomes foreign workers bringing in outside income.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Sri Lanka Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year (extendable)</li>
        <li>• <strong>Income requirement:</strong> $2,000/month</li>
        <li>• <strong>Processing time:</strong> 5-10 working days</li>
        <li>• <strong>Insurance:</strong> Mandatory (including COVID coverage)</li>
        <li>• <strong>Visa fee:</strong> $500 for first year</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Sri Lanka for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Very affordable:</strong> $1,000-1,500/month for comfortable living</li>
      <li><strong>Natural beauty:</strong> Beaches, hill country, ancient cities, wildlife</li>
      <li><strong>English widely spoken:</strong> Former British colony, English is common</li>
      <li><strong>Warm climate:</strong> Tropical weather year-round</li>
      <li><strong>Cultural richness:</strong> UNESCO sites, ancient temples, diverse traditions</li>
      <li><strong>Low income requirement:</strong> $2,000/month is achievable for many nomads</li>
      <li><strong>Surfing and beaches:</strong> World-class surf spots, pristine coastlines</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Sri Lanka is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn $2,000+/month from remote work</li>
          <li>✓ You want very affordable tropical living</li>
          <li>✓ You enjoy nature, wildlife, and beaches</li>
          <li>✓ You're flexible with infrastructure quality</li>
          <li>✓ You appreciate cultural experiences</li>
          <li>✓ You're comfortable in developing countries</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You need consistently fast internet</li>
          <li>• You require advanced medical facilities</li>
          <li>• You want established nomad infrastructure</li>
          <li>• You're risk-averse about economic stability</li>
          <li>• You prefer Western-style amenities</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-800">
        <strong>Important Context:</strong> Sri Lanka experienced a severe economic crisis in 2022. The country is recovering, but power cuts, supply issues, and economic volatility may still occur. Research current conditions before committing.
      </p>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Sri Lanka's Digital Nomad Visa has relatively accessible requirements, designed to attract remote workers who can bring foreign income into the economy.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate $2,000/month income—one of the lower thresholds globally. Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 3-6 months showing consistent deposits</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>For freelancers:</strong> Client contracts and invoices</li>
    </ul>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <p class="text-blue-800">
        <strong>Currency Note:</strong> The Sri Lankan Rupee (LKR) experienced significant devaluation during the 2022 crisis. Your US dollars go much further now than before, making the country exceptionally affordable.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (digital)</li>
      <li>Proof of income ($2,000/month)</li>
      <li>Health insurance certificate (with COVID coverage)</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Police clearance certificate</li>
      <li>Proof of accommodation (initial booking)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Insurance is Mandatory</h3>
      <p class="text-blue-800">
        Sri Lanka requires comprehensive health insurance including COVID-19 coverage. Given limited local medical facilities for serious conditions, medical evacuation coverage is essential—not optional.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Sri Lanka's Digital Nomad Visa. The requirement includes COVID coverage, and given healthcare limitations, evacuation coverage is strongly recommended.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Sri Lankan Healthcare Context</h3>

    <p class="mb-4">
      Sri Lanka has free public healthcare but quality varies significantly. Private hospitals in Colombo are decent for routine care, but serious conditions often require evacuation to India, Singapore, or Thailand.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Cost:</strong> Free</li>
          <li>• <strong>Quality:</strong> Basic, variable</li>
          <li>• <strong>Wait times:</strong> Can be long</li>
          <li>• <strong>Language:</strong> Sinhala/Tamil primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With insurance or out-of-pocket</li>
          <li>• <strong>Quality:</strong> Good in Colombo for routine care</li>
          <li>• <strong>Facilities:</strong> Asiri, Nawaloka, Lanka Hospitals</li>
          <li>• <strong>Limitations:</strong> Complex cases need evacuation</li>
        </ul>
      </div>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800">
        <strong>Critical:</strong> Medical evacuation coverage is essential. For serious trauma, cardiac events, or complex surgeries, evacuation to Singapore, Bangkok, or India is standard. A medical evacuation can cost $50,000+. Don't skip this coverage.
      </p>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need insurance with evacuation coverage for Sri Lanka?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Insurance Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      For Sri Lanka, prioritize plans with strong evacuation coverage. Here are recommended providers:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Includes evacuation coverage and meets Sri Lanka requirements.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Adventure Activities</h4>
        <p class="text-neutral-600">World Nomads. Covers surfing, diving, trekking—popular activities in Sri Lanka.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive + Strong Evacuation</h4>
        <p class="text-neutral-600">Cigna Global or Allianz Care. Best evacuation networks for serious medical situations.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Don't Skip Evacuation</h4>
        <p class="text-neutral-600">Whatever plan you choose, ensure medical evacuation is included. This is non-negotiable for Sri Lanka.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Sri Lanka's visa fee is moderate, and living costs are exceptionally low post-currency devaluation.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,100</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$3,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Sri Lanka is extremely affordable. The currency devaluation means your dollars stretch very far.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> $800-1,200/month (guesthouse, local food, minimal spending)</li>
      <li><strong>Comfortable:</strong> $1,200-1,800/month (nice apartment, dining out, activities)</li>
      <li><strong>Premium:</strong> $2,500+/month (beachfront villa, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Sri Lanka's Digital Nomad Visa application is primarily online, with relatively fast processing times.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Apply Online</h4>
          <p class="text-neutral-600">Visit the Sri Lanka Department of Immigration website. Complete the Digital Nomad Visa application form and upload required documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Visa Fee</h4>
          <p class="text-neutral-600">Pay the $500 visa fee online via credit card. You'll receive a receipt for your records.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing typically takes 5-10 working days. You'll receive email updates on your application status.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Approval notification comes via email with your visa authorization letter. Print this for travel.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Travel and Collect Visa</h4>
          <p class="text-neutral-600">Fly to Sri Lanka (Colombo or Mattala airport). Present your approval letter at immigration to receive your visa stamp.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Have printed copies of your approval letter, insurance certificate, and accommodation booking ready for immigration. Officers may request to see them.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Sri Lanka's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $2,500/month</h3>
        <p class="text-neutral-600 mb-4">Wanted affordable tropical destination with interesting culture.</p>
        <p class="text-green-700 font-medium">✓ Approved. Living in Galle, surfing on weekends, writing from cafes. Internet good enough for text-based work.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $4,500/month</h3>
        <p class="text-neutral-600 mb-4">Needed video calls and consistent connectivity.</p>
        <p class="text-amber-700 font-medium">△ Approved but struggled. Internet inconsistent for video calls. Moved to Colombo coworking space for reliable connection.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Creator, $3,000/month</h3>
        <p class="text-neutral-600 mb-4">Creates travel content, attracted by photogenic locations.</p>
        <p class="text-green-700 font-medium">✓ Approved. Incredible content opportunities—ancient temples, beaches, tea country, wildlife. Very happy.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Consultant, $2,200/month</h3>
        <p class="text-neutral-600 mb-4">Just above income threshold, wanted maximum budget stretching.</p>
        <p class="text-green-700 font-medium">✓ Approved. Living well on $1,400/month including nice apartment, saving the rest.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Retiree/Part-time Consultant, $1,800/month</h3>
        <p class="text-neutral-600 mb-4">Semi-retired, income slightly below threshold.</p>
        <p class="text-red-700 font-medium">✗ Denied. $200 below threshold. Added a small consulting contract to boost income and reapplied successfully.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, $4,500/month combined</h3>
