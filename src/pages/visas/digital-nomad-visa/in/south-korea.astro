---
/**
 * South Korea Digital Nomad Visa (Workcation Visa) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in South Korea", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "South Korea Health Insurance Guide", href: "/countries/south-korea/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "Approx. $2,500/month (varies)", evidence: "Bank statements, employment contract" },
  { requirement: "Remote Work", details: "Work for company outside Korea", evidence: "Employment contract or business proof" },
  { requirement: "Health Insurance", details: "Mandatory coverage", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Age Requirement", details: "18-60 years (typical)", evidence: "Passport" },
  { requirement: "Clean Record", details: "No criminal history", evidence: "May be requested" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Korea Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Comprehensive", why: "Required for visa" },
  { feature: "Coverage Territory", minimum: "Valid in South Korea", why: "Must cover your stay" },
  { feature: "Duration", minimum: "Full visa period", why: "No gaps permitted" },
  { feature: "Hospitalization", minimum: "Covered", why: "Korean healthcare can be expensive" },
  { feature: "Emergency Services", minimum: "24/7 coverage", why: "Round-the-clock access" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$200-400", strengths: "Comprehensive global" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$170-320", strengths: "Asia-Pacific focus" },
  { provider: "BUPA Global", coverage: "$2,000,000+", price: "$300-500", strengths: "Premium service" },
  { provider: "Korean NHIS", coverage: "Varies", price: "~$100-150", strengths: "Local integration (if eligible)" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "$50-80", notes: "Single/multiple entry" },
  { item: "Alien Registration Card", amount: "$30", notes: "Required for stays 90+ days" },
  { item: "Health Insurance (Annual)", amount: "$600-3,500", notes: "International coverage" },
  { item: "Document Translation", amount: "$30-100", notes: "If required" },
  { item: "Background Check", amount: "$20-50", notes: "Home country" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit application", duration: "1 day", location: "Korean embassy/consulate" },
  { step: "Processing", duration: "1-3 weeks", location: "Embassy review" },
  { step: "Receive visa", duration: "Pickup or mail", location: "Embassy/consulate" },
  { step: "Enter Korea", duration: "Within visa validity", location: "Korean airport/port" },
  { step: "Register as alien", duration: "Within 90 days", location: "Immigration office" },
];
---

<PageShell
  title="South Korea Digital Nomad Visa 2026: Workcation Visa Insurance & Requirements"
  description="Complete guide to South Korea's Workcation Visa for digital nomads. K-culture immersion, world-class internet, excellent healthcare, and application requirements explained."
  headline="South Korea Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the land of K-pop, kimchi, and lightning-fast internet—visa requirements, healthcare access, and Seoul lifestyle."
  heroImage="/images/visas/digital-nomad-visa-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Korean Immigration Service
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      World-Class Healthcare
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      South Korea launched its "Workcation" visa program in 2023, joining the growing list of countries welcoming digital nomads. Korea offers a unique combination: cutting-edge technology, world-class healthcare, exceptional public safety, and deep cultural experiences from K-pop to ancient temples.
    </p>

    <p class="mb-4">
      The program is still evolving, with Korea testing the concept through bilateral agreements and pilot programs. Requirements vary by nationality and program phase, but the direction is clear: Korea wants to attract remote workers who can contribute to local economies while experiencing Korean culture.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: South Korea Workcation Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> Up to 1-2 years (varies by program)</li>
        <li>• <strong>Income requirement:</strong> ~$2,500/month (varies)</li>
        <li>• <strong>Processing time:</strong> 1-3 weeks typical</li>
        <li>• <strong>Insurance:</strong> Mandatory health coverage</li>
        <li>• <strong>Internet:</strong> World's fastest average speeds</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why South Korea for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Fastest internet globally:</strong> Average speeds over 200 Mbps, ubiquitous 5G</li>
      <li><strong>World-class healthcare:</strong> Affordable, high-quality medical care</li>
      <li><strong>Exceptional safety:</strong> One of the lowest crime rates in the world</li>
      <li><strong>K-culture immersion:</strong> K-pop, K-drama, Korean cuisine, traditional culture</li>
      <li><strong>Efficient infrastructure:</strong> KTX high-speed rail, excellent public transit</li>
      <li><strong>Four distinct seasons:</strong> Cherry blossoms, beach summers, fall foliage, ski winters</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">South Korea is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You need ultra-fast, reliable internet</li>
          <li>✓ You're interested in K-culture</li>
          <li>✓ You value safety and cleanliness</li>
          <li>✓ You want excellent healthcare access</li>
          <li>✓ You enjoy four distinct seasons</li>
          <li>✓ You're open to learning basic Korean</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want an established DNV program</li>
          <li>• You need everything in English</li>
          <li>• You prefer very low cost of living</li>
          <li>• You want path to permanent residency</li>
          <li>• You dislike cold winters</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      South Korea's digital nomad program is newer and requirements may vary based on bilateral agreements and program phases. Check with the Korean embassy for the most current information.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      Income requirements are approximately $2,500/month, though this varies by program. Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 3-6 months showing consistent income</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>Business registration:</strong> For self-employed applicants</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Program Status:</strong> Korea's Workcation visa is relatively new and evolving. Requirements may change. Always verify current requirements with your local Korean embassy before applying.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (Korean specifications)</li>
      <li>Proof of income/employment</li>
      <li>Health insurance certificate</li>
      <li>Proof of accommodation (or travel itinerary)</li>
      <li>Criminal record check (if required)</li>
      <li>Round-trip ticket or travel itinerary</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Insurance Mandatory</h3>
      <p class="text-blue-800">
        South Korea requires health insurance for the Workcation visa. International health insurance is accepted. After 6 months of residence, you may become eligible for Korea's excellent National Health Insurance System (NHIS).
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Korea's digital nomad program. While Korean healthcare is excellent and relatively affordable, having proper coverage is essential.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Korean Healthcare Context</h3>

    <p class="mb-4">
      South Korea has one of the world's best healthcare systems—efficient, high-tech, and affordable. The National Health Insurance System (NHIS) covers residents, and you may become eligible after 6 months.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">National Health Insurance (NHIS)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> After 6 months of residence</li>
          <li>• <strong>Cost:</strong> ~$100-150/month</li>
          <li>• <strong>Coverage:</strong> 70% of costs covered</li>
          <li>• <strong>Quality:</strong> Excellent, world-class</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Immediate with insurance</li>
          <li>• <strong>Quality:</strong> World-class facilities</li>
          <li>• <strong>Language:</strong> English available at major hospitals</li>
          <li>• <strong>Cost:</strong> Still affordable vs. Western countries</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for South Korea's Workcation Visa?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer coverage suitable for South Korea's digital nomad visa:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads (Short-term)</h4>
        <p class="text-neutral-600">SafetyWing at $45-85/month. Good for initial coverage before NHIS eligibility.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Asia-Pacific Focus</h4>
        <p class="text-neutral-600">Allianz Care. Strong network across Asia, good for regional travel.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global or BUPA Global. Full worldwide coverage for frequent travelers.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Long-term Residents (6+ months)</h4>
        <p class="text-neutral-600">Consider enrolling in Korean NHIS once eligible—excellent value at ~$100-150/month.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Korea has low visa fees. The main costs are insurance and living expenses, which are moderate by developed country standards.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$750</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,800</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$4,000</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Seoul is moderately expensive; other cities like Busan or Daegu are more affordable. Food is excellent value.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> $1,500-2,000/month (studio outside Seoul center, cooking)</li>
      <li><strong>Comfortable:</strong> $2,500-3,500/month (1BR in good area, dining out)</li>
      <li><strong>Premium:</strong> $4,500+/month (central Seoul, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The application process is handled through Korean embassies and consulates. Processing is typically efficient.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Check Eligibility</h4>
          <p class="text-neutral-600">Contact your local Korean embassy to confirm current program availability and requirements for your nationality.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documentation</h4>
          <p class="text-neutral-600">Gather income proof, insurance certificate, passport, photos, and any other required documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Apply at Korean embassy/consulate. Pay visa fee and submit all documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Enter Korea</h4>
          <p class="text-neutral-600">Once approved, enter Korea and proceed to immigration. Your visa allows entry.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Register as Alien</h4>
          <p class="text-neutral-600">Within 90 days, register at local immigration office and receive your Alien Registration Card (ARC). This is essential for banking, phone contracts, and daily life.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> The Alien Registration Card (ARC) is crucial in Korea. Get it as soon as possible—you'll need it for opening bank accounts, getting a phone plan, and many other services.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out for digital nomads in South Korea:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $5,000/month</h3>
        <p class="text-neutral-600 mb-4">K-drama fan, wants to immerse in Korean culture while working remotely.</p>
        <p class="text-green-700 font-medium">✓ Approved. Living in Hongdae area, enrolled in Korean classes, loving the internet speeds and food scene.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Consultant, $3,500/month</h3>
        <p class="text-neutral-600 mb-4">Wants to try living in Asia, chose Korea for safety and infrastructure.</p>
        <p class="text-green-700 font-medium">✓ Approved. Appreciates the clean streets, efficient public transport, and excellent wifi everywhere.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, $2,000/month</h3>
        <p class="text-neutral-600 mb-4">Income slightly below typical threshold.</p>
        <p class="text-amber-700 font-medium">△ Application required additional documentation. Consider checking current requirements carefully.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, $4,500/month</h3>
        <p class="text-neutral-600 mb-4">Interested in Korean tech scene and design culture.</p>
        <p class="text-green-700 font-medium">✓ Approved. Networking with Korean designers, enjoying the tech-forward culture and cafe culture.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Language Teacher (Online), $3,000/month</h3>
        <p class="text-neutral-600 mb-4">Teaches English online to students in other countries.</p>
        <p class="text-green-700 font-medium">✓ Approved. Time zone works well for teaching Asian students. Using coworking spaces with excellent facilities.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, $7,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, exploring Asia together.</p>
        <p class="text-green-700 font-medium">✓ Both approved. Using Korea as base for exploring Japan, Taiwan, and Southeast Asia during holidays.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Compare insurance plans for your Korea move—get quotes in minutes.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
