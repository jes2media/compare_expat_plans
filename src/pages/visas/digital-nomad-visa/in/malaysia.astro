---
/**
 * Malaysia Digital Nomad Visa (DE Rantau) - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Malaysia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Malaysia Health Insurance Guide", href: "/countries/malaysia/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Annual Income", details: "$24,000+/year", evidence: "Bank statements, contracts" },
  { requirement: "Remote Work", details: "Work in digital/tech fields", evidence: "Employment contract or portfolio" },
  { requirement: "Health Insurance", details: "Mandatory coverage", evidence: "Insurance certificate" },
  { requirement: "Valid Passport", details: "6+ months validity", evidence: "Passport copy" },
  { requirement: "Industry", details: "IT, digital content, digital marketing, or related", evidence: "CV, portfolio, or work samples" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Malaysia Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "Must cover Malaysia", why: "Healthcare access" },
  { feature: "Hospitalization", minimum: "Included", why: "Private hospital costs high" },
  { feature: "Coverage Duration", minimum: "Full visa period", why: "12-month pass" },
  { feature: "Outpatient Care", minimum: "Recommended", why: "Day-to-day medical needs" },
  { feature: "Emergency Evacuation", minimum: "Recommended", why: "Optional but wise" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "$250,000", price: "$40-75", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "$1,000,000+", price: "$180-350", strengths: "Comprehensive coverage" },
  { provider: "Allianz Care", coverage: "$500,000+", price: "$150-300", strengths: "Strong Asia network" },
  { provider: "Pacific Cross", coverage: "Varies", price: "$80-180", strengths: "Asia specialist" },
  { provider: "AXA", coverage: "$500,000+", price: "$120-250", strengths: "Malaysia presence" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (USD)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "DE Rantau Pass", amount: "$218 (1,000 MYR)", notes: "12-month professional pass" },
  { item: "Dependent Pass", amount: "$109 (500 MYR)", notes: "Per dependent" },
  { item: "Processing Fee", amount: "$22 (100 MYR)", notes: "Application processing" },
  { item: "Health Insurance (Annual)", amount: "$500-3,000", notes: "International coverage" },
  { item: "Medical Checkup", amount: "$50-100", notes: "If required" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Prepare documents", duration: "1-2 weeks", location: "Home country" },
  { step: "Submit online application", duration: "1-2 hours", location: "MDEC portal" },
  { step: "Processing", duration: "7-14 days", location: "MDEC review" },
  { step: "Receive approval", duration: "Via email", location: "Digital notification" },
  { step: "Travel to Malaysia", duration: "Within validity", location: "Any entry point" },
  { step: "Collect pass", duration: "Upon arrival", location: "Immigration or MDEC" },
];
---

<PageShell
  title="Malaysia DE Rantau (Digital Nomad Visa) 2026: Insurance & Complete Guide"
  description="Complete guide to Malaysia's DE Rantau digital nomad visa. Affordable Southeast Asian living, $24,000 income requirement, KL and Penang lifestyle, and application process."
  headline="Malaysia DE Rantau Pass: Insurance & Requirements Guide"
  subheadline="Everything you need to know about Malaysia's digital nomad visa—affordable Asian living with excellent infrastructure."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/go/cigna-global"
  heroImage="/images/countries/malaysia-hero-bg.png"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official MDEC Program
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Fast Processing (7-14 Days)
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Malaysia launched the DE Rantau program in late 2022, creating one of Southeast Asia's most accessible digital nomad visas. Run by MDEC (Malaysia Digital Economy Corporation), it targets digital professionals with a reasonable $24,000/year income requirement.
    </p>

    <p class="mb-4">
      Malaysia offers an exceptional combination: modern infrastructure, affordable living, English widely spoken, excellent food, and strategic location for exploring Asia. Kuala Lumpur and Penang have become major nomad hubs.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Malaysia DE Rantau Pass</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 3-12 months (renewable)</li>
        <li>• <strong>Income requirement:</strong> $24,000+/year</li>
        <li>• <strong>Processing time:</strong> 7-14 days typical</li>
        <li>• <strong>Insurance:</strong> Mandatory health coverage</li>
        <li>• <strong>Cost:</strong> Only ~$218 for 12-month pass</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Malaysia for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Affordable living:</strong> Western quality at a fraction of Western prices</li>
      <li><strong>English widely spoken:</strong> Easy communication everywhere</li>
      <li><strong>Excellent food:</strong> World-class street food and restaurants</li>
      <li><strong>Modern infrastructure:</strong> Fast internet, good transport</li>
      <li><strong>Strategic location:</strong> Gateway to Southeast Asia</li>
      <li><strong>Diverse culture:</strong> Malay, Chinese, Indian influences create unique experience</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Malaysia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn $24,000+/year from digital work</li>
          <li>✓ You want affordable Asian living</li>
          <li>✓ You appreciate diverse food culture</li>
          <li>✓ You want English-speaking environment</li>
          <li>✓ You want to explore Southeast Asia</li>
          <li>✓ You work in tech or digital fields</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want path to permanent residency</li>
          <li>• You prefer Mediterranean climate</li>
          <li>• You work outside digital/tech fields</li>
          <li>• You want EU/Schengen access</li>
          <li>• You prefer Western cultural environment</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      The DE Rantau program targets digital professionals—IT workers, digital marketers, content creators, and similar fields. The $24,000/year income threshold (~$2,000/month) is one of the lowest in the DNV world.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Eligible Professions</h3>

    <p class="mb-4">
      DE Rantau specifically targets digital economy workers. Eligible fields include:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>IT/Software:</strong> Developers, engineers, architects</li>
      <li><strong>Digital Marketing:</strong> SEO, SEM, social media, content marketing</li>
      <li><strong>Digital Content:</strong> Writers, designers, video creators, podcasters</li>
      <li><strong>Data/Analytics:</strong> Data scientists, analysts, BI professionals</li>
      <li><strong>Cybersecurity:</strong> Security professionals, ethical hackers</li>
      <li><strong>Other Digital:</strong> UX/UI designers, product managers, etc.</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Industry Focus:</strong> DE Rantau is specifically for digital economy workers. Traditional professions (lawyers, accountants, etc.) without a digital focus may not qualify. Your application should emphasize your digital skills.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months validity)</li>
      <li>Passport-sized photo</li>
      <li>Proof of income ($24,000+/year)</li>
      <li>Employment contract or freelance evidence</li>
      <li>CV/resume highlighting digital skills</li>
      <li>Portfolio or work samples (if applicable)</li>
      <li>Health insurance certificate</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Flexible Insurance Requirements</h3>
      <p class="text-blue-800">
        Malaysia requires health insurance but is less prescriptive than European countries. International travel insurance and comprehensive health plans are both typically accepted.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for the DE Rantau pass. Malaysia is relatively flexible about what qualifies—most international health insurance and travel medical plans are accepted.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Malaysian Healthcare Context</h3>

    <p class="mb-4">
      Malaysia has excellent private healthcare at very affordable prices. KL's private hospitals are world-class. With insurance, you'll have access to top-tier medical care.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Available but long waits</li>
          <li>• <strong>Cost:</strong> Very affordable</li>
          <li>• <strong>Quality:</strong> Adequate basic care</li>
          <li>• <strong>Language:</strong> Malay primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Immediate with insurance</li>
          <li>• <strong>Quality:</strong> World-class in KL/Penang</li>
          <li>• <strong>Language:</strong> English standard</li>
          <li>• <strong>Cost:</strong> Affordable by global standards</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need health insurance for Malaysia's DE Rantau pass?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer coverage suitable for Malaysia's DE Rantau program:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at $40-75/month. Widely accepted, good value for Malaysia.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Asia-Focused Coverage</h4>
        <p class="text-neutral-600">Pacific Cross or AXA. Strong regional networks, Asia specialist options.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage with excellent Malaysia network.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Regional Explorer</h4>
        <p class="text-neutral-600">Allianz Care. Strong across Asia if you plan to travel the region.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Malaysia's DE Rantau is remarkably affordable—one of the cheapest digital nomad visas in the world at just ~$218 for a full year.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$750</p>
        <p class="text-sm text-neutral-500 mt-2">Pass + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Pass + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">$3,500</p>
        <p class="text-sm text-neutral-500 mt-2">Pass + comprehensive plan</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living in Malaysia</h3>

    <p class="mb-4">
      Malaysia offers exceptional value. KL is modern and affordable; Penang is even cheaper with great food and beaches.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget (Penang):</strong> $1,000-1,400/month</li>
      <li><strong>Comfortable (KL):</strong> $1,500-2,500/month</li>
      <li><strong>Premium (KL central):</strong> $3,000+/month</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      The DE Rantau application is fully online through MDEC's portal. Processing is fast—typically 7-14 days.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Create MDEC Account</h4>
          <p class="text-neutral-600">Register on the MDEC DE Rantau portal. You'll receive confirmation email.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Complete Application</h4>
          <p class="text-neutral-600">Fill out the online form. Upload all required documents including income proof and insurance.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Processing Fee</h4>
          <p class="text-neutral-600">Pay the ~$22 processing fee online. Then wait for MDEC review.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Receive Approval</h4>
          <p class="text-neutral-600">Processing takes 7-14 days. You'll receive approval notification via email.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Pass Fee & Travel</h4>
          <p class="text-neutral-600">Pay the ~$218 pass fee. Travel to Malaysia and collect your pass.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Many nationalities can enter Malaysia visa-free for 90 days. You can arrive, explore, find housing, then complete your DE Rantau while already in-country.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Malaysia's DE Rantau:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, $60,000/year</h3>
        <p class="text-neutral-600 mb-4">Works remotely for US tech company, wants KL lifestyle.</p>
        <p class="text-green-700 font-medium">✓ Approved in 10 days. Clear tech role, strong documentation.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Digital Marketer, $30,000/year</h3>
        <p class="text-neutral-600 mb-4">Freelances for multiple clients in SEO/content marketing.</p>
        <p class="text-green-700 font-medium">✓ Approved. Digital marketing qualifies, income above threshold.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Accountant, $45,000/year</h3>
        <p class="text-neutral-600 mb-4">Remote accountant for European firm.</p>
        <p class="text-red-700 font-medium">✗ Rejected. Traditional profession doesn't qualify—DE Rantau is for digital economy roles.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Creator, $28,000/year</h3>
        <p class="text-neutral-600 mb-4">YouTuber and blogger with consistent ad revenue.</p>
        <p class="text-green-700 font-medium">✓ Approved. Digital content creation qualifies, income verified.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, $50,000/year</h3>
        <p class="text-neutral-600 mb-4">Contract designer for various tech companies.</p>
        <p class="text-green-700 font-medium">✓ Approved quickly. Strong portfolio, clear digital role.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">New Freelancer, $20,000/year</h3>
        <p class="text-neutral-600 mb-4">Just started freelancing, income below threshold.</p>
        <p class="text-red-700 font-medium">✗ Denied. $4,000 below $24,000 requirement. Advised to build income first.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
    <p class="mb-4">Compare insurance plans for your Malaysian adventure—get quotes in minutes.</p>
    <a href="/get-quotes" class="inline-block bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
      Get Insurance Quotes →
    </a>
  </CTABox>

  <!-- Section: Common Mistakes -->
  <section id="mistakes" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Common Mistakes to Avoid</h2>

    <div class="space-y-6">
      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Applying with Non-Digital Profession</h3>
        <p class="text-neutral-600">DE Rantau is specifically for digital economy workers. Traditional professions (law, medicine, accounting) don't qualify unless there's a clear digital component.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Weak Portfolio/Evidence</h3>
        <p class="text-neutral-600">Your application should clearly demonstrate digital work. Include portfolio, work samples, or client testimonials showing your digital expertise.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Forgetting Insurance</h3>
        <p class="text-neutral-600">Health insurance is mandatory. Have your certificate ready before applying—applications without insurance proof are delayed or rejected.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Expecting Permanent Residency Path</h3>
        <p class="text-neutral-600">DE Rantau doesn't lead to permanent residency. It's a professional pass for digital workers, not an immigration pathway.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Overstaying Visa-Free Entry</h3>
        <p class="text-neutral-600">If you arrive visa-free while waiting for DE Rantau, don't overstay the 90-day limit. Overstays result in fines and potential entry bans.</p>
      </div>

      <div class="border-l-4 border-red-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Not Researching Locations</h3>
        <p class="text-neutral-600">Malaysia varies dramatically by location. KL is urban and modern; Penang is more relaxed with better food; Langkawi is beach-focused. Research before committing.</p>
      </div>
    </div>
  </section>

