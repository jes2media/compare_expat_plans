---
/**
 * Latvia Digital Nomad Visa - Long-form CRO-optimized page
 * Static page (overrides dynamic route for this specific country)
 */

import PageShell from '../../../../components/PageShell.astro';
import CTABox from '../../../../components/CTABox.astro';
import ComparisonTable from '../../../../components/ComparisonTable.astro';

const tocItems = [
  { id: "overview", text: "Overview", level: 2 },
  { id: "quick-decision", text: "Quick Decision Guide", level: 2 },
  { id: "requirements", text: "Visa Requirements", level: 2 },
  { id: "insurance-requirements", text: "Insurance Requirements", level: 2 },
  { id: "recommended-providers", text: "Recommended Providers", level: 2 },
  { id: "costs", text: "Costs Breakdown", level: 2 },
  { id: "application", text: "Application Process", level: 2 },
  { id: "scenarios", text: "Real-World Scenarios", level: 2 },
  { id: "mistakes", text: "Common Mistakes", level: 2 },
  { id: "healthcare", text: "Healthcare in Latvia", level: 2 },
  { id: "faq", text: "FAQ", level: 2 },
  { id: "verdict", text: "Final Verdict", level: 2 },
];

const relatedLinks = [
  { title: "Latvia Health Insurance Guide", href: "/countries/latvia/insurance" },
  { title: "Insurance for Digital Nomads", href: "/insurance-for/digital-nomads" },
  { title: "Best Expat Health Insurance", href: "/best/expat-health-insurance" },
];

const requirementsColumns = [
  { key: "requirement", header: "Requirement" },
  { key: "details", header: "Details" },
  { key: "evidence", header: "Evidence Needed" },
];

const requirementsRows = [
  { requirement: "Monthly Income", details: "€2,857/month (2.5x average salary)", evidence: "Bank statements, contracts, tax returns" },
  { requirement: "Remote Work", details: "Work for company outside Latvia", evidence: "Employment contract or client agreements" },
  { requirement: "Health Insurance", details: "€42,500 minimum coverage", evidence: "Insurance certificate in English" },
  { requirement: "Valid Passport", details: "6+ months beyond intended stay", evidence: "Passport copy" },
  { requirement: "Clean Record", details: "No serious criminal convictions", evidence: "Criminal record certificate" },
];

const insuranceColumns = [
  { key: "feature", header: "Coverage Feature" },
  { key: "minimum", header: "Latvia Requirement" },
  { key: "why", header: "Why It Matters" },
];

const insuranceRows = [
  { feature: "Medical Coverage", minimum: "€42,500 minimum", why: "Higher than standard Schengen €30,000" },
  { feature: "Coverage Territory", minimum: "Valid in Latvia/EU", why: "Schengen travel included" },
  { feature: "Duration", minimum: "Full visa period", why: "No gaps permitted" },
  { feature: "Repatriation", minimum: "Required", why: "EU visa standard" },
  { feature: "Emergency Care", minimum: "24/7 coverage", why: "Round-the-clock access" },
];

const providerColumns = [
  { key: "provider", header: "Provider" },
  { key: "coverage", header: "Coverage" },
  { key: "price", header: "Monthly Cost" },
  { key: "strengths", header: "Best For" },
];

const providerRows = [
  { provider: "SafetyWing", coverage: "€250,000", price: "€45-85", strengths: "Budget nomads" },
  { provider: "Cigna Global", coverage: "€1,000,000+", price: "€180-350", strengths: "Comprehensive global" },
  { provider: "Allianz Care", coverage: "€500,000+", price: "€150-280", strengths: "EU-focused coverage" },
  { provider: "IMG Global", coverage: "€500,000+", price: "€120-250", strengths: "Flexible deductibles" },
  { provider: "BUPA Global", coverage: "€2,000,000+", price: "€280-450", strengths: "Premium service" },
];

const costColumns = [
  { key: "item", header: "Cost Item" },
  { key: "amount", header: "Amount (EUR)" },
  { key: "notes", header: "Notes" },
];

const costRows = [
  { item: "Visa Application Fee", amount: "€60", notes: "State fee" },
  { item: "Residence Permit Card", amount: "€14-28", notes: "Depends on processing speed" },
  { item: "Health Insurance (Annual)", amount: "€550-3,000", notes: "Meeting €42,500 minimum" },
  { item: "Document Apostille", amount: "€30-100", notes: "If required for your country" },
  { item: "Translation Services", amount: "€50-150", notes: "For non-English documents" },
];

const timelineColumns = [
  { key: "step", header: "Step" },
  { key: "duration", header: "Timeline" },
  { key: "location", header: "Where" },
];

const timelineRows = [
  { step: "Gather documents", duration: "1-3 weeks", location: "Home country" },
  { step: "Submit application", duration: "1 day", location: "Latvian embassy or PMLP" },
  { step: "Processing", duration: "30-60 days", location: "Office of Citizenship and Migration Affairs" },
  { step: "Receive decision", duration: "Via email/post", location: "Notification" },
  { step: "Collect permit", duration: "1-2 weeks", location: "Embassy or in Latvia" },
  { step: "Enter Latvia", duration: "Within 90 days of issue", location: "Any Schengen entry" },
];
---

<PageShell
  title="Latvia Digital Nomad Visa 2025: Insurance Requirements & Complete Guide"
  description="Complete guide to Latvia's Digital Nomad Visa. €2,857/month income requirement, €42,500 insurance minimum, 1-year non-renewable permit, and the most affordable Baltic destination."
  headline="Latvia Digital Nomad Visa: Insurance & Requirements Guide"
  subheadline="Everything you need to know about working remotely from the most affordable Baltic state—insurance requirements, costs, and Riga lifestyle."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Qualifying Insurance"
  ctaButtonHref="/best/expat-health-insurance"
>

  <!-- Trust Signals -->
  <div class="flex flex-wrap gap-4 mb-8 text-sm text-neutral-600">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Updated January 2025
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      Official PMLP Requirements
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
      EU/Schengen Member
    </span>
  </div>

  <!-- Section: Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      Latvia launched its Digital Nomad Visa in 2022, offering remote workers a path to live in the most affordable Baltic state while enjoying full Schengen access. Riga, the capital, blends Art Nouveau architecture with a growing tech scene.
    </p>

    <p class="mb-4">
      Latvia stands out for its notably high insurance requirement (€42,500 minimum) compared to the standard Schengen €30,000. The visa is valid for 1 year and cannot be renewed—you must leave for 180 days before reapplying. This makes it best suited for nomads wanting a Baltic experience rather than long-term settlement.
    </p>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-primary-900 mb-3">Key Facts: Latvia Digital Nomad Visa</h3>
      <ul class="space-y-2 text-primary-800">
        <li>• <strong>Duration:</strong> 1 year (non-renewable)</li>
        <li>• <strong>Income requirement:</strong> €2,857/month (€34,280/year)</li>
        <li>• <strong>Processing time:</strong> 30-60 days</li>
        <li>• <strong>Insurance minimum:</strong> €42,500 coverage (higher than Schengen standard)</li>
        <li>• <strong>Gap before reapply:</strong> 180 days outside Latvia</li>
      </ul>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Why Latvia for Digital Nomads?</h3>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Most affordable Baltic:</strong> 20-30% cheaper than Estonia, significantly cheaper than Scandinavia</li>
      <li><strong>Excellent internet:</strong> Consistently ranked top 10 globally for internet speed</li>
      <li><strong>Schengen access:</strong> Travel freely across 27 European countries</li>
      <li><strong>English proficiency:</strong> High English fluency, especially in Riga</li>
      <li><strong>Four seasons:</strong> Cold winters, pleasant summers—distinct seasonal variety</li>
    </ul>
  </section>

  <!-- Section: Quick Decision Guide -->
  <section id="quick-decision" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Decision Guide</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="font-semibold text-green-900 mb-3">Latvia is Right For You If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>✓ You earn €2,900+/month from remote work</li>
          <li>✓ You want affordable Baltic living</li>
          <li>✓ You value fast, reliable internet</li>
          <li>✓ You prefer European time zones</li>
          <li>✓ You want 1-year Schengen base</li>
          <li>✓ You enjoy seasonal variety (including cold winters)</li>
        </ul>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
        <h3 class="font-semibold text-amber-900 mb-3">Consider Other Options If:</h3>
        <ul class="space-y-2 text-amber-800">
          <li>• You want visa that leads to residency</li>
          <li>• You need renewable multi-year permit</li>
          <li>• You dislike cold, dark winters</li>
          <li>• You want larger digital nomad community</li>
          <li>• Your insurance doesn't meet €42,500 minimum</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Section: Visa Requirements -->
  <section id="requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Requirements</h2>

    <p class="mb-4">
      Latvia's Digital Nomad Visa requires proof of remote work income and notably higher insurance coverage than most Schengen countries.
    </p>

    <ComparisonTable columns={requirementsColumns} rows={requirementsRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Income Verification</h3>

    <p class="mb-4">
      You must demonstrate €2,857/month average income (2.5x Latvia's average salary). Accepted evidence includes:
    </p>

    <ul class="list-disc pl-6 space-y-2 mb-6">
      <li><strong>Employment contract:</strong> Showing salary from foreign employer</li>
      <li><strong>Bank statements:</strong> 6 months showing consistent deposits</li>
      <li><strong>Tax returns:</strong> Previous year's income documentation</li>
      <li><strong>For freelancers:</strong> Client contracts, invoices, and bank statements</li>
    </ul>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800">
        <strong>Non-Renewable:</strong> Unlike some countries, Latvia's DNV cannot be renewed. After 1 year, you must leave Latvia for at least 180 days before you can apply again. Plan accordingly.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Document Checklist</h3>

    <ul class="list-disc pl-6 space-y-2">
      <li>Valid passport (6+ months beyond intended stay)</li>
      <li>Completed visa application form</li>
      <li>Passport photos (Schengen specifications)</li>
      <li>Proof of income (€2,857/month average)</li>
      <li>Health insurance certificate (€42,500 minimum coverage)</li>
      <li>Employment contract or proof of self-employment</li>
      <li>Criminal record certificate (apostilled if required)</li>
      <li>Proof of accommodation in Latvia (or statement of intent)</li>
    </ul>
  </section>

  <!-- Section: Insurance Requirements -->
  <section id="insurance-requirements" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Requirements</h2>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-2">Higher Than Standard Schengen</h3>
      <p class="text-blue-800">
        Latvia requires €42,500 minimum coverage—42% higher than the standard Schengen €30,000 requirement. Verify your policy meets this specific threshold before applying.
      </p>
    </div>

    <p class="mb-4">
      Health insurance is mandatory for Latvia's Digital Nomad Visa. Your policy must meet the €42,500 minimum and cover the full duration of your planned stay.
    </p>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Coverage Requirements</h3>

    <ComparisonTable columns={insuranceColumns} rows={insuranceRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Latvian Healthcare Context</h3>

    <p class="mb-4">
      Latvia has universal healthcare for residents (funded through taxes), but digital nomads aren't enrolled in the public system. You'll rely on private insurance and private healthcare facilities.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Public Healthcare (NVD)</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> Not for DNV holders</li>
          <li>• <strong>Quality:</strong> Underfunded, long waits</li>
          <li>• <strong>Emergency:</strong> Will treat, bill later</li>
          <li>• <strong>Language:</strong> Latvian/Russian primarily</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h4 class="font-semibold text-neutral-900 mb-3">Private Healthcare</h4>
        <ul class="space-y-2 text-neutral-700">
          <li>• <strong>Access:</strong> With international insurance</li>
          <li>• <strong>Quality:</strong> Good in Riga</li>
          <li>• <strong>Facilities:</strong> Veselības centrs 4, ARS</li>
          <li>• <strong>Language:</strong> English available in Riga</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox variant="highlight">
    <p class="mb-4">Need insurance meeting Latvia's €42,500 minimum?</p>
    <a href="/get-quotes" class="inline-block bg-white text-primary-700 font-semibold px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors" style="color: #1d4ed8 !important;">
      Compare Qualifying Plans →
    </a>
  </CTABox>

  <!-- Section: Recommended Providers -->
  <section id="recommended-providers" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>

    <p class="mb-4">
      These providers offer coverage meeting Latvia's €42,500 minimum requirement:
    </p>

    <ComparisonTable columns={providerColumns} rows={providerRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Provider Recommendations by Situation</h3>

    <div class="space-y-4">
      <div class="border-l-4 border-green-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Budget Nomads</h4>
        <p class="text-neutral-600">SafetyWing at €45-85/month. Meets the €42,500 requirement at low cost.</p>
      </div>

      <div class="border-l-4 border-blue-500 pl-4">
        <h4 class="font-semibold text-neutral-900">EU-Focused Coverage</h4>
        <p class="text-neutral-600">Allianz Care or IMG Global. Strong European networks, designed for EU expats.</p>
      </div>

      <div class="border-l-4 border-purple-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Comprehensive Global</h4>
        <p class="text-neutral-600">Cigna Global. Full worldwide coverage if you travel outside Europe frequently.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h4 class="font-semibold text-neutral-900">Premium Coverage</h4>
        <p class="text-neutral-600">BUPA Global. Top-tier service with excellent claims support.</p>
      </div>
    </div>
  </section>

  <!-- Section: Costs Breakdown -->
  <section id="costs" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Costs Breakdown</h2>

    <p class="mb-4">
      Latvia has low visa fees, but the higher insurance requirement adds to total costs.
    </p>

    <ComparisonTable columns={costColumns} rows={costRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">First Year Total Cost Estimates</h3>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Budget Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€700</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + basic insurance</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Standard Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€1,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + mid-tier coverage</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6 text-center">
        <p class="text-sm text-neutral-600 mb-2">Premium Setup</p>
        <p class="text-3xl font-bold text-neutral-900">€3,500</p>
        <p class="text-sm text-neutral-500 mt-2">Visa + comprehensive coverage</p>
      </div>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mb-3">Cost of Living</h3>

    <p class="mb-4">
      Latvia is the most affordable Baltic state—significantly cheaper than Estonia or Lithuania for comparable living standards.
    </p>

    <ul class="list-disc pl-6 space-y-2">
      <li><strong>Budget:</strong> €1,200-1,500/month (shared housing, cooking at home)</li>
      <li><strong>Comfortable:</strong> €1,800-2,500/month (own apartment, dining out regularly)</li>
      <li><strong>Premium:</strong> €3,000+/month (central Riga, full lifestyle)</li>
    </ul>
  </section>

  <!-- Section: Application Process -->
  <section id="application" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Application Process</h2>

    <p class="mb-4">
      Latvia's application process goes through PMLP (Office of Citizenship and Migration Affairs). You can apply at a Latvian embassy abroad or in-country if already legally in Latvia.
    </p>

    <ComparisonTable columns={timelineColumns} rows={timelineRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Step-by-Step Guide</h3>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Prepare Documentation</h4>
          <p class="text-neutral-600">Gather income proof, insurance certificate (€42,500 minimum), passport, criminal record, and photos. Get translations and apostilles where required.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Submit Application</h4>
          <p class="text-neutral-600">Apply at Latvian embassy/consulate in your home country, or at PMLP office if already legally in Latvia on tourist visa.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Pay Fees</h4>
          <p class="text-neutral-600">€60 state fee for visa application plus residence permit card fee (€14-28 depending on processing speed).</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Wait for Processing</h4>
          <p class="text-neutral-600">Processing takes 30-60 days. PMLP reviews applications and may request additional documents.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
        <div>
          <h4 class="font-semibold text-neutral-900">Collect Permit & Enter</h4>
          <p class="text-neutral-600">Pick up your residence permit at embassy or PMLP office. Enter Latvia or any Schengen country within validity period.</p>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Pro tip:</strong> Consider applying while in Latvia on a tourist visa (90-day Schengen entry). This lets you explore the country while your application is processed.
      </p>
    </div>
  </section>

  <!-- Section: Real-World Scenarios -->
  <section id="scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how different situations typically play out with Latvia's Digital Nomad Visa:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Software Developer, €4,500/month</h3>
        <p class="text-neutral-600 mb-4">Works for Estonian startup, wants to try affordable Baltic living.</p>
        <p class="text-green-700 font-medium">✓ Approved easily. Income well above threshold, comprehensive insurance from employer.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Freelance Writer, €3,200/month</h3>
        <p class="text-neutral-600 mb-4">Variable income, averages above threshold. Has SafetyWing insurance.</p>
        <p class="text-green-700 font-medium">✓ Approved. SafetyWing meets €42,500 requirement. Provided 6 months of bank statements showing average.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Content Creator, €2,400/month</h3>
        <p class="text-neutral-600 mb-4">Income below threshold, hoping savings would help.</p>
        <p class="text-red-700 font-medium">✗ Denied. €457 below €2,857 requirement. Latvia doesn't have a savings alternative path.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Marketing Consultant, €5,000/month</h3>
        <p class="text-neutral-600 mb-4">Has travel insurance with only €30,000 coverage.</p>
        <p class="text-red-700 font-medium">✗ Denied initially. Insurance below €42,500 minimum. Reapplied with upgraded coverage and approved.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">UX Designer, €3,800/month</h3>
        <p class="text-neutral-600 mb-4">Previously stayed in Estonia, wanted a change of scenery.</p>
        <p class="text-green-700 font-medium">✓ Approved. Enjoyed the lower costs compared to Tallinn.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Couple, €6,000/month combined</h3>
        <p class="text-neutral-600 mb-4">Both remote workers, one earns €4,000, other €2,000.</p>
        <p class="text-amber-700 font-medium">△ Applied separately. Higher earner approved, lower earner denied—each must meet threshold individually.</p>
      </div>
    </div>
  </section>

  <!-- CTA Box -->
  <CTABox>
