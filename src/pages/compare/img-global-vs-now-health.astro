---
/**
 * IMG Global vs Now Health International - Provider Comparison
 * US-based flexible coverage vs Asia-Pacific specialist
 */

import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'pricing', text: 'Pricing Breakdown', level: 2 },
  { id: 'network-access', text: 'Network & Direct Billing', level: 2 },
  { id: 'regional-strengths', text: 'Regional Strengths', level: 2 },
  { id: 'claims-experience', text: 'Claims Experience', level: 2 },
  { id: 'pre-existing-conditions', text: 'Pre-existing Conditions', level: 2 },
  { id: 'real-scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'verdict', text: 'Final Verdict', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
  { title: 'Best Budget Expat Insurance', href: '/best/budget-expat-insurance' },
  { title: 'Thailand Insurance Guide', href: '/countries/thailand/insurance' },
  { title: 'Mexico Insurance Guide', href: '/countries/mexico/insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Coverage Feature' },
  { key: 'img', header: 'IMG Global' },
  { key: 'nowhealth', header: 'Now Health' },
];

const coverageRows = [
  { feature: 'Inpatient Hospital', img: 'Up to $8M (Select)', nowhealth: 'Up to $2.6M' },
  { feature: 'Outpatient Care', img: 'Full coverage', nowhealth: 'Full coverage' },
  { feature: 'Mental Health', img: 'Included (varies by plan)', nowhealth: 'Included (enhanced)' },
  { feature: 'Maternity', img: 'Optional add-on', nowhealth: 'Optional add-on' },
  { feature: 'Dental', img: 'Optional add-on', nowhealth: 'Optional add-on' },
  { feature: 'Vision', img: 'Optional add-on', nowhealth: 'Included in some plans' },
  { feature: 'Wellness/Preventive', img: 'Included (varies)', nowhealth: 'Included' },
  { feature: 'Medical Evacuation', img: 'Up to $1M', nowhealth: 'Up to $1M' },
  { feature: 'Alternative Medicine', img: 'Limited', nowhealth: 'Traditional Chinese Medicine included' },
  { feature: 'US Coverage', img: 'Excellent (native)', nowhealth: 'Limited (add-on)' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'img', header: 'IMG Global' },
  { key: 'nowhealth', header: 'Now Health' },
];

const pricingRows = [
  { profile: 'Single, Age 30 (excl. US)', img: '$100-150/mo', nowhealth: '$120-170/mo' },
  { profile: 'Single, Age 40 (excl. US)', img: '$150-220/mo', nowhealth: '$180-250/mo' },
  { profile: 'Single, Age 50 (excl. US)', img: '$250-350/mo', nowhealth: '$280-380/mo' },
  { profile: 'Single, Age 30 (incl. US)', img: '$180-280/mo', nowhealth: '$200-300/mo' },
  { profile: 'Family of 4 (excl. US)', img: '$380-520/mo', nowhealth: '$420-600/mo' },
];

const networkColumns = [
  { key: 'region', header: 'Region' },
  { key: 'img', header: 'IMG Global' },
  { key: 'nowhealth', header: 'Now Health' },
];

const networkRows = [
  { region: 'Global Network Size', img: '900K+ providers', nowhealth: '900K+ providers' },
  { region: 'United States', img: 'Excellent (native)', nowhealth: 'Limited' },
  { region: 'Latin America', img: 'Strong', nowhealth: 'Good' },
  { region: 'Hong Kong', img: 'Good', nowhealth: 'Excellent (HQ)' },
  { region: 'Singapore', img: 'Good', nowhealth: 'Excellent' },
  { region: 'UAE/Middle East', img: 'Good', nowhealth: 'Excellent' },
  { region: 'Thailand', img: 'Strong', nowhealth: 'Strong' },
  { region: 'Europe', img: 'Strong', nowhealth: 'Good' },
  { region: 'Direct Billing', img: 'Good globally', nowhealth: 'Strong in Asia' },
];

const plansColumns = [
  { key: 'tier', header: 'Plan Tier' },
  { key: 'img', header: 'IMG Global' },
  { key: 'nowhealth', header: 'Now Health' },
];

const plansRows = [
  { tier: 'Entry Level', img: 'Global Medical Insurance', nowhealth: 'WorldCare Lite' },
  { tier: 'Mid-Range', img: 'Global Select', nowhealth: 'WorldCare Classic' },
  { tier: 'Comprehensive', img: 'Global Select Plus', nowhealth: 'WorldCare Prestige' },
  { tier: 'Deductible Range', img: '$0 - $25,000', nowhealth: '$0 - $5,000' },
  { tier: 'Annual Maximum', img: '$1M - $8M', nowhealth: '$2.6M (Prestige)' },
  { tier: 'Lifetime Maximum', img: 'Varies by plan', nowhealth: 'Unlimited' },
];
---

<PageShell
  title="IMG Global vs Now Health 2026: Complete Comparison for Expats"
  description="In-depth comparison of IMG Global and Now Health International for expats. Coverage, pricing, networks, US coverage, and which is best for your situation."
  headline="IMG Global vs Now Health: Which Is Better for You?"
  subheadline="US-based global insurer meets Asia-Pacific specialist. Two different approaches to international health insurance—here's how to choose."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes from Both"
  ctaButtonHref="/go/img-global"
  heroBackgroundImage="/images/pages/provider-card-generic.png"
>

  <!-- Quick Verdict Box -->
  <section id="quick-verdict" class="scroll-mt-24 mb-12">
    <div class="bg-primary-50 border-2 border-primary-200 rounded-xl p-6">
      <h2 class="text-2xl font-bold text-primary-900 mb-4">Quick Verdict</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg p-5 border border-primary-100">
          <h3 class="font-bold text-lg text-neutral-900 mb-2">Choose IMG Global If:</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You need strong US coverage</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You're in Latin America or Caribbean</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You want high deductible options ($25K)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You're American or have US family ties</span>
            </li>
          </ul>
          <a href="/go/img-global" class="mt-4 inline-block bg-primary-600 text-white font-semibold px-5 py-2 rounded-lg hover:bg-primary-700 transition-colors" style="color: white !important;">
            Get IMG Quote →
          </a>
        </div>

        <div class="bg-white rounded-lg p-5 border border-primary-100">
          <h3 class="font-bold text-lg text-neutral-900 mb-2">Choose Now Health If:</h3>
          <ul class="space-y-2 text-neutral-700">
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You're based in Asia or Middle East long-term</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You don't need US coverage</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You value Traditional Chinese Medicine</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 mt-1">✓</span>
              <span>You want enhanced mental health benefits</span>
            </li>
          </ul>
          <a href="/go/now-health" class="mt-4 inline-block bg-white text-primary-700 font-semibold px-5 py-2 rounded-lg border border-primary-300 hover:bg-primary-50 transition-colors">
            Get Now Health Quote →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section id="overview" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>

    <p class="mb-4">
      IMG Global and Now Health International serve the international health insurance market from opposite sides of the Pacific. IMG, based in Indianapolis, has deep roots in US healthcare and serves expats worldwide with particular strength in the Americas. Now Health, headquartered in Hong Kong, specializes in Asia-Pacific and Middle East markets.
    </p>

    <p class="mb-4">
      The key differentiator is US coverage. IMG handles US healthcare seamlessly—if you're American, have family in the US, or need occasional US coverage, IMG has clear advantages. If you're based in Asia with no US ties, Now Health offers better regional expertise and often better pricing.
    </p>

    <p class="mb-6">
      Both are mid-tier insurers offering solid coverage at reasonable prices. Neither commands the premium of Cigna or Bupa, but both deliver reliable service and comprehensive plans for their target markets.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-3">IMG Global at a Glance</h3>
        <ul class="space-y-2 text-neutral-600">
          <li><strong>Parent Company:</strong> International Medical Group</li>
          <li><strong>Founded:</strong> 1990</li>
          <li><strong>Network:</strong> 900K+ providers globally</li>
          <li><strong>Headquarters:</strong> Indianapolis, Indiana, USA</li>
          <li><strong>Best For:</strong> Americans abroad, US coverage needs</li>
          <li><strong>Pricing:</strong> Competitive mid-tier</li>
        </ul>
      </div>

      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-neutral-900 mb-3">Now Health at a Glance</h3>
        <ul class="space-y-2 text-neutral-600">
          <li><strong>Parent Company:</strong> Now Health International</li>
          <li><strong>Founded:</strong> 2012 (by Cigna/Aetna veterans)</li>
          <li><strong>Network:</strong> 900K+ providers</li>
          <li><strong>Headquarters:</strong> Hong Kong</li>
          <li><strong>Best For:</strong> Asia/Middle East expats</li>
          <li><strong>Pricing:</strong> Competitive mid-tier</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Coverage Comparison -->
  <section id="coverage-comparison" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Coverage Comparison</h2>

    <p class="mb-4">
      Both insurers offer comprehensive international coverage. IMG provides higher maximum limits and stronger US options, while Now Health includes unique benefits like Traditional Chinese Medicine and enhanced mental health.
    </p>

    <ComparisonTable columns={coverageColumns} rows={coverageRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Plan Tiers Compared</h3>

    <ComparisonTable columns={plansColumns} rows={plansRows} />

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6">
      <p class="text-blue-800">
        <strong>Key difference:</strong> IMG offers higher annual maximums ($8M vs $2.6M) and much higher deductible options ($25K vs $5K). This flexibility lets cost-conscious expats reduce premiums significantly. Now Health's advantage is included benefits like TCM and enhanced mental health coverage.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Coverage Highlights</h3>

    <div class="grid md:grid-cols-2 gap-6 mt-4">
      <div class="border border-green-200 bg-green-50 rounded-lg p-5">
        <h4 class="font-semibold text-green-900 mb-3">IMG Global Strengths</h4>
        <ul class="space-y-2 text-green-800">
          <li>✓ Higher coverage maximums (up to $8M)</li>
          <li>✓ Excellent US coverage (native insurer)</li>
          <li>✓ High deductible options ($25K)</li>
          <li>✓ Strong Latin America network</li>
          <li>✓ 24/7 multilingual support</li>
        </ul>
      </div>

      <div class="border border-blue-200 bg-blue-50 rounded-lg p-5">
        <h4 class="font-semibold text-blue-900 mb-3">Now Health Strengths</h4>
        <ul class="space-y-2 text-blue-800">
          <li>✓ Traditional Chinese Medicine coverage</li>
          <li>✓ Enhanced mental health benefits</li>
          <li>✓ Vision included in some plans</li>
          <li>✓ Unlimited lifetime maximum</li>
          <li>✓ Superior Asia hospital relationships</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- First CTA -->
  <CTABox
    variant="highlight"
    title="Ready to compare quotes?"
    description="Get personalized pricing from both IMG Global and Now Health based on your specific situation."
    buttonText="Get Free Quotes"
    buttonHref="/go/img-global"
  />

  <!-- Pricing -->
  <section id="pricing" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Pricing Breakdown</h2>

    <p class="mb-4">
      IMG and Now Health are competitively priced—often within 10-15% of each other for comparable coverage. IMG can be cheaper when you use high deductibles; Now Health is often cheaper for comprehensive plans in Asia.
    </p>

    <ComparisonTable columns={pricingColumns} rows={pricingRows} />

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Pricing note:</strong> IMG's higher deductible options ($10K-$25K) can reduce premiums dramatically—sometimes 40-50%. If you're healthy and want catastrophic-only coverage, IMG's flexibility is valuable. Now Health maxes out at $5,000 deductible.
      </p>
    </div>

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Deductible Comparison</h3>

    <p class="mb-4">
      IMG offers broader deductible flexibility, which significantly impacts pricing:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-neutral-50 rounded-lg p-5">
        <h4 class="font-semibold text-neutral-900 mb-3">IMG Deductible Options</h4>
        <ul class="space-y-1 text-neutral-700">
          <li>$0 — Full premium</li>
          <li>$500 — ~12% discount</li>
          <li>$2,500 — ~28% discount</li>
          <li>$5,000 — ~35% discount</li>
          <li>$10,000 — ~45% discount</li>
          <li>$25,000 — ~55% discount</li>
        </ul>
      </div>

      <div class="bg-neutral-50 rounded-lg p-5">
        <h4 class="font-semibold text-neutral-900 mb-3">Now Health Deductible Options</h4>
        <ul class="space-y-1 text-neutral-700">
          <li>$0 — Full premium</li>
          <li>$500 — ~15% discount</li>
          <li>$1,500 — ~25% discount</li>
          <li>$3,000 — ~35% discount</li>
          <li>$5,000 — ~40% discount</li>
          <li class="text-neutral-400">(No higher options)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Network & Direct Billing -->
  <section id="network-access" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Network & Direct Billing</h2>

    <p class="mb-4">
      Both insurers maintain similar-sized networks (900K+ providers), but their regional strengths differ significantly. IMG excels in the Americas; Now Health excels in Asia-Pacific.
    </p>

    <ComparisonTable columns={networkColumns} rows={networkRows} />

    <h3 class="text-xl font-semibold text-neutral-900 mt-8 mb-3">Direct Billing Experience</h3>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-5">
        <h4 class="font-semibold text-neutral-900 mb-3">IMG Direct Billing</h4>
        <p class="text-neutral-600 mb-3">
          IMG's US roots show in their Americas coverage—excellent direct billing throughout the US, Mexico, Costa Rica, and other popular expat destinations. Their guarantee of payment system works smoothly with major US hospitals.
        </p>
        <p class="text-neutral-600">
          In Asia, IMG's direct billing works but isn't as deeply established as regional specialists. You may encounter more reimbursement situations in Asia compared to Now Health.
        </p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-5">
        <h4 class="font-semibold text-neutral-900 mb-3">Now Health Direct Billing</h4>
        <p class="text-neutral-600 mb-3">
          Now Health's Hong Kong headquarters gives them exceptional relationships with Asian hospitals. Direct billing is seamless in Hong Kong, Singapore, Thailand, and UAE. Their local teams know the hospitals personally.
        </p>
        <p class="text-neutral-600">
          In the US and Latin America, Now Health's direct billing is more limited. Members in these regions often pay upfront and submit for reimbursement, which Now Health processes quickly.
        </p>
      </div>
    </div>
  </section>

  <!-- Regional Strengths -->
  <section id="regional-strengths" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Regional Strengths</h2>

    <p class="mb-6">
      Geography should heavily influence your choice between these two insurers:
    </p>

    <div class="space-y-6">
      <div class="border-l-4 border-primary-500 pl-4">
        <h3 class="font-semibold text-neutral-900">United States</h3>
        <p class="text-neutral-600"><strong>Winner: IMG Global (clearly)</strong> — IMG is a US company with deep US healthcare integration. If you need US coverage—even occasionally—IMG is the obvious choice. Now Health can add US coverage, but it's an afterthought compared to IMG's native capabilities.</p>
      </div>

      <div class="border-l-4 border-primary-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Latin America & Caribbean</h3>
        <p class="text-neutral-600"><strong>Winner: IMG Global</strong> — IMG has strong presence in Mexico, Costa Rica, Panama, and throughout the Caribbean. Many American retirees in these regions choose IMG. Now Health covers these areas but isn't specialized.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Hong Kong & Singapore</h3>
        <p class="text-neutral-600"><strong>Winner: Now Health</strong> — Now Health's home turf. Superior hospital relationships, faster claims processing, and deep local expertise. The choice is clear for these financial centers.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h3 class="font-semibold text-neutral-900">UAE & Middle East</h3>
        <p class="text-neutral-600"><strong>Winner: Now Health</strong> — Now Health has expanded aggressively in the UAE market. Better hospital networks in Dubai and Abu Dhabi. IMG works but isn't their focus market.</p>
      </div>

      <div class="border-l-4 border-green-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Thailand & Southeast Asia</h3>
        <p class="text-neutral-600"><strong>Winner: Now Health (edge)</strong> — Now Health's TCM coverage appeals to many Southeast Asia expats. Better Bangkok hospital relationships. IMG is solid but Now Health has regional advantages.</p>
      </div>

      <div class="border-l-4 border-amber-500 pl-4">
        <h3 class="font-semibold text-neutral-900">Europe</h3>
        <p class="text-neutral-600"><strong>Winner: Tie</strong> — Neither specializes in Europe. Both work adequately, but Europe-based expats might consider Allianz or AXA instead. If choosing between these two, IMG has slightly better European coverage.</p>
      </div>
    </div>
  </section>

  <!-- Claims Experience -->
  <section id="claims-experience" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Claims Experience</h2>

    <p class="mb-4">
      Both insurers process claims professionally without significant complaints. The experience differs based on where you're located and how you prefer to interact with your insurer.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-3">IMG Global Claims</h3>
        <ul class="space-y-2 text-neutral-600">
          <li><strong>Submission:</strong> App, portal, email, fax</li>
          <li><strong>Processing time:</strong> 5-10 business days</li>
          <li><strong>Reimbursement:</strong> Direct deposit, check</li>
          <li><strong>Languages:</strong> English, Spanish, other major</li>
          <li><strong>24/7 support:</strong> Yes</li>
        </ul>
        <p class="mt-3 text-neutral-600 text-sm">
          IMG's US headquarters means great phone support during US business hours and 24/7 emergency assistance. Their mobile app handles claims submission well. Spanish-speaking support is strong for Latin America members.
        </p>
      </div>

      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-3">Now Health Claims</h3>
        <ul class="space-y-2 text-neutral-600">
          <li><strong>Submission:</strong> App, portal, email</li>
          <li><strong>Processing time:</strong> 5-7 business days</li>
          <li><strong>Reimbursement:</strong> Direct deposit preferred</li>
          <li><strong>Languages:</strong> English, Chinese, Arabic</li>
          <li><strong>Support hours:</strong> Extended hours (Asia-focused)</li>
        </ul>
        <p class="mt-3 text-neutral-600 text-sm">
          Now Health's Hong Kong team processes claims efficiently within Asia. Chinese and Arabic language support serves their core markets well. Not 24/7 but covers Asian business hours comprehensively.
        </p>
      </div>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-6">
      <p class="text-green-800">
        <strong>Both perform well:</strong> Neither has significant claims issues. Choose based on location and language preferences rather than claims reputation—both deliver.
      </p>
    </div>
  </section>

  <!-- Second CTA -->
  <CTABox
    title="Get personalized quotes from both providers"
    description="Compare actual pricing for your specific situation—age, location, coverage needs, and family size."
    buttonText="Compare Quotes Now"
    buttonHref="/go/img-global"
  />

  <!-- Pre-existing Conditions -->
  <section id="pre-existing-conditions" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Pre-existing Conditions</h2>

    <p class="mb-4">
      Both insurers require medical underwriting with similar approaches to pre-existing conditions.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-3">IMG Global Approach</h3>
        <ul class="space-y-2 text-neutral-600">
          <li>• Full medical underwriting</li>
          <li>• Case-by-case evaluation</li>
          <li>• May exclude, load premium, or add waiting periods</li>
          <li>• Some plans offer "look-back" options</li>
          <li>• Typically 12-24 month wait for pre-existing</li>
        </ul>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-3">Now Health Approach</h3>
        <ul class="space-y-2 text-neutral-600">
          <li>• Medical underwriting required</li>
          <li>• Individual assessment</li>
          <li>• Exclusions or premium loading possible</li>
          <li>• Generally 24-month wait for pre-existing</li>
          <li>• Group scheme flexibility available</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-6">
      <p class="text-amber-800">
        <strong>Important:</strong> Always disclose pre-existing conditions fully. Non-disclosure can void your policy. Both insurers investigate claims related to pre-existing conditions carefully.
      </p>
    </div>
  </section>

  <!-- Real-World Scenarios -->
  <section id="real-scenarios" class="scroll-mt-24 mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <p class="mb-6">
      Here's how each insurer typically performs in realistic expat situations:
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">American Retiree in Mexico</h3>
        <p class="text-neutral-600 mb-3">65-year-old, wants coverage for occasional US visits to see grandchildren. Budget-conscious.</p>
        <p class="text-green-700 font-medium">→ <strong>IMG Global Select</strong> — US coverage is essential. IMG's Latin America network is strong. High deductible ($10K+) keeps costs manageable. Better fit than Now Health for this scenario.</p>
      </div>

      <div class="border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">British Family in Hong Kong</h3>
        <p class="text-neutral-600 mb-3">Family of 4, parents age 40. No US ties. Value comprehensive coverage and local expertise.</p>
