---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "img", title: "IMG Global" },
  { id: "cigna", title: "Cigna Global" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "remote-details", title: "Remote Worker Considerations" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/safetywing", title: "SafetyWing Review" },
  { href: "/providers/img-global", title: "IMG Global Review" },
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/insurance-for/digital-nomads", title: "Insurance for Digital Nomads" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const mainComparisonRows = [
  { feature: "Monthly Cost", safetywing: "$45–85", img: "$150–350", cigna: "$350–600" },
  { feature: "Coverage Limit", safetywing: "$250K", img: "$1M–5M", cigna: "$1M–Unlimited" },
  { feature: "Country Hopping", safetywing: "Built for it", img: "Supported", cigna: "Full support" },
  { feature: "Home Country Visits", safetywing: "30 days/90 days", img: "Varies", cigna: "Full coverage" },
  { feature: "Co-working Injury", safetywing: "Covered", img: "Covered", cigna: "Covered" },
  { feature: "Mental Health", safetywing: "Limited", img: "Available", cigna: "Comprehensive" },
  { feature: "Ergonomic Issues", safetywing: "Covered", img: "Covered", cigna: "Covered" },
  { feature: "Visa Letters", safetywing: "Available", img: "Available", cigna: "Available" },
  { feature: "Telehealth", safetywing: "Basic", img: "Available", cigna: "Comprehensive" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const pricingRows = [
  { profile: "Remote worker, 28yo", safetywing: "$540–1,020/yr", img: "$1,800–4,200/yr", cigna: "$4,200–7,200/yr" },
  { profile: "Remote worker, 35yo", safetywing: "$600–1,140/yr", img: "$2,100–4,800/yr", cigna: "$5,100–8,400/yr" },
  { profile: "Couple, both remote", safetywing: "$1,080–2,040/yr", img: "$3,600–8,400/yr", cigna: "$8,400–14,400/yr" },
  { profile: "Family (2 adults, 2 kids)", safetywing: "$1,620–3,060/yr", img: "$5,400–12,600/yr", cigna: "$14,400–24,000/yr" },
];
---

<PageShell
  title="SafetyWing vs IMG vs Cigna: Insurance for Remote Workers (2025)"
  description="Compare health insurance for remote workers and location-independent professionals. Analysis of SafetyWing, IMG Global, and Cigna Global for the work-from-anywhere lifestyle."
  headline="SafetyWing vs IMG vs Cigna: Insurance for Remote Workers"
  intro="Working remotely from anywhere in the world is increasingly common—but health insurance hasn't fully caught up. Remote workers need coverage that follows them across countries, handles digital nomad visa requirements, and fits the location-independent budget. Here's how SafetyWing, IMG Global, and Cigna Global compare for remote workers."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 font-semibold mb-2">Best for Nomadic Remote Workers</p>
        <p class="text-neutral-700 text-sm">Built specifically for location-independent workers. Monthly billing, no commitment, coverage across 185+ countries. Affordable for remote work budgets.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best Mid-Range Option</p>
        <p class="text-neutral-700 text-sm">Higher coverage for remote workers with health concerns. Mental health options for remote work stress. Good for established remote professionals.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 font-semibold mb-2">Best Comprehensive Coverage</p>
        <p class="text-neutral-700 text-sm">Premium coverage for high-earning remote workers. Comprehensive telehealth, mental health, and worldwide access. Worth it when budget permits.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- SafetyWing Section -->
  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Remote Worker Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Built for nomads:</strong> Designed specifically for location-independent workers</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Monthly billing:</strong> No annual commitment, pay as you travel</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>185+ countries:</strong> Coverage wherever your laptop takes you</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Home visits:</strong> 30 days per 90-day period in home country</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Affordable:</strong> Under $100/month fits remote work budgets</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      SafetyWing built their Nomad Insurance specifically for remote workers. The monthly billing model mirrors how many remote workers think about finances—no big annual premium, just ongoing coverage that flexes with your lifestyle. Change countries monthly? No problem.
    </p>
    <p class="text-neutral-700">
      The $250K coverage limit is the main constraint. For young, healthy remote workers, it's usually adequate. But if you have health concerns or work in high-cost countries, the limit might feel restrictive. Still, for the price point, it's hard to beat.
    </p>
  </section>

  <!-- IMG Global Section -->
  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Remote Worker Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Higher coverage:</strong> $1M–5M limits for serious protection</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Mental health:</strong> Coverage for remote work stress and burnout</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Pre-existing options:</strong> Some conditions coverable</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Telehealth:</strong> Virtual doctor access worldwide</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Quarterly billing:</strong> More flexible than annual, more stable than monthly</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      IMG Global provides a step up for remote workers who've moved beyond the startup phase. Higher coverage limits mean real protection. Mental health coverage addresses the isolation and burnout that affect many remote workers. The quarterly billing offers compromise between flexibility and stability.
    </p>
    <p class="text-neutral-700">
      The pricing is 3-4x SafetyWing's, but the coverage is substantially better. For remote workers earning $60K+ annually, the premium is manageable and the protection is worth it—especially if you have any health concerns.
    </p>
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Remote Worker Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Unlimited coverage:</strong> No financial worries if something serious happens</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Full home country:</strong> Complete coverage during extended home visits</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Comprehensive telehealth:</strong> Virtual care including specialists</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Mental health:</strong> Unlimited therapy sessions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Global network:</strong> Direct billing at quality facilities worldwide</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global is the premium choice for successful remote workers. If you're earning $100K+ remotely, the $350-600/month premium is a reasonable business expense. You get unlimited coverage, comprehensive telehealth (essential for location-independent life), and mental health support.
    </p>
    <p class="text-neutral-700">
      The annual commitment is the main friction point for remote workers used to flexibility. But the coverage quality justifies it for those who can afford it. Many high-earning remote workers see Cigna as non-negotiable.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Remote Worker Insurance Quotes"
    description="Compare plans from SafetyWing, IMG, and Cigna for your location-independent lifestyle."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Remote worker incomes vary widely—from scraping by to six figures. Consider insurance cost as a percentage of your income, and factor in the coverage you actually need.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for worldwide coverage excluding US. SafetyWing bills monthly; others typically annual.
    </p>
  </section>

  <!-- Remote Details Section -->
  <section id="remote-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Key Considerations for Remote Workers</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Country Hopping Coverage</h3>
        <p class="text-neutral-700 mb-3">
          Remote workers often move frequently—a month in Portugal, then Mexico, then Thailand. Your insurance needs to follow without complications. SafetyWing is built for this. IMG and Cigna handle it well with global plans. Verify that frequent country changes don't trigger administrative issues.
        </p>
        <p class="text-neutral-700">
          Some policies have "base country" requirements or notification rules for extended stays. Understand these before signing up to avoid coverage complications when you're in a new country needing care.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Digital Nomad Visa Requirements</h3>
        <p class="text-neutral-700 mb-3">
          Many countries now offer digital nomad visas (Portugal, Spain, Estonia, Costa Rica, Thailand, and more). Most require proof of health insurance. All three insurers provide visa-compliant letters. Verify specific coverage minimums for your target visa—some require higher limits than SafetyWing's $250K.
        </p>
        <p class="text-neutral-700">
          Planning your visa strategy? Research requirements early. Some visas have specific insurance requirements that only certain providers meet. Building your insurance history now can smooth visa applications later.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Remote Work Health Issues</h3>
        <p class="text-neutral-700 mb-3">
          Remote work creates specific health challenges: back problems from poor ergonomics, eye strain from screens, repetitive strain injuries, and mental health issues from isolation. All these are covered as medical conditions—though SafetyWing's mental health coverage is limited.
        </p>
        <p class="text-neutral-700">
          Telehealth becomes especially valuable when working remotely. Being able to consult a doctor without leaving your co-working space or apartment saves time and hassle. Cigna's comprehensive telehealth options are particularly useful.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Company vs Personal Coverage</h3>
        <p class="text-neutral-700 mb-3">
          Some remote employers provide health insurance; most don't. Even when offered, employer coverage may not fit the nomadic lifestyle—it might require a home base or have geographic restrictions. Personal insurance gives you independence from employment decisions.
        </p>
        <p class="text-neutral-700">
          If you're freelancing or running your own business, personal insurance is essential. Consider it a business expense—it's often tax-deductible depending on your jurisdiction and structure.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose SafetyWing If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're young and healthy</li>
          <li>• Budget is a primary concern</li>
          <li>• You move countries frequently</li>
          <li>• Monthly flexibility matters</li>
          <li>• You're testing the nomad lifestyle</li>
          <li>• Basic coverage is sufficient</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose IMG If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want higher coverage limits</li>
          <li>• Mental health support matters</li>
          <li>• You have some health concerns</li>
          <li>• You're an established remote worker</li>
          <li>• Balance of cost and coverage matters</li>
          <li>• Quarterly billing works for you</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're a high-earning remote worker</li>
          <li>• Comprehensive telehealth is priority</li>
          <li>• Unlimited coverage provides peace of mind</li>
          <li>• Mental health support is essential</li>
          <li>• Full home country coverage needed</li>
          <li>• Budget isn't the primary constraint</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Do I need insurance if I work for a US company remotely?</h3>
        <p class="text-neutral-700">
          Probably yes. Most employer plans don't cover you outside the US, or have limited international coverage. Even if your employer offers international insurance, having personal coverage gives you independence and continuity if employment changes.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I use telemedicine instead of seeing doctors locally?</h3>
        <p class="text-neutral-700">
          For many issues, yes. Telehealth is perfect for minor illnesses, prescription refills, and mental health. But physical examinations, lab work, and procedures require in-person care. Cigna's telehealth is most comprehensive; SafetyWing's is more basic.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I stay in one country long-term?</h3>
        <p class="text-neutral-700">
          If you settle down, you might transition to local insurance or residency-based coverage. SafetyWing works fine for indefinite travel but isn't designed for permanent residence. IMG and Cigna work for both nomadic and settled expat lifestyles.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I handle insurance for coworking space injuries?</h3>
        <p class="text-neutral-700">
          Injuries at coworking spaces are covered like any other medical condition. Slip and fall? Covered. Repetitive strain from bad ergonomics? Covered. The coworking space's liability insurance is separate from your health coverage—your insurance handles your medical costs.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I write off health insurance as a business expense?</h3>
        <p class="text-neutral-700">
          Often yes, especially if you're self-employed or run a business. The specifics depend on your tax residency and business structure. Consult a tax professional familiar with remote work situations—many specialize in location-independent workers.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about coverage during flights and travel days?</h3>
        <p class="text-neutral-700">
          You're covered during transit. If you have a medical emergency on a flight or during airport layovers, your insurance applies. Some travel insurance also covers trip interruption, lost luggage, etc.—consider separate travel coverage for those aspects.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by specific plan, policy year, and individual circumstances. Digital nomad visa requirements vary by country—verify insurance meets specific requirements. Tax treatment of insurance premiums depends on your situation. This comparison reflects general plan features as of the publication date.
    </p>
  </aside>
</PageShell>
