---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'couple-considerations', text: 'Coverage for Couples', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'Family Insurance Guide', href: '/insurance-for/families' },
  { title: 'Partner Coverage Tips', href: '/guides/partner-coverage' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const mainComparisonRows = [
  { feature: 'Couple Discount', cigna: '~10%', bupa: '~10%', axa: '~12%' },
  { feature: 'Coverage Limit', cigna: 'Unlimited each', bupa: 'Unlimited each', axa: '€3M each' },
  { feature: 'Unmarried Partners', cigna: 'Yes', bupa: 'Yes', axa: 'Yes' },
  { feature: 'Different Ages', cigna: 'Priced individually', bupa: 'Priced individually', axa: 'Priced individually' },
  { feature: 'Maternity Add-on', cigna: 'Available', bupa: 'Available', axa: 'Available' },
  { feature: 'Shared Deductible', cigna: 'No', bupa: 'Optional', axa: 'No' },
  { feature: 'Mental Health', cigna: 'Good', bupa: 'Good', axa: 'Good' },
  { feature: 'Best For', cigna: 'Best service', bupa: 'Premium coverage', axa: 'Best value' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const pricingRows = [
  { profile: 'Couple, Both Age 30', cigna: '$500-750/mo', bupa: '$550-800/mo', axa: '$400-600/mo' },
  { profile: 'Couple, Both Age 40', cigna: '$700-1,000/mo', bupa: '$780-1,100/mo', axa: '$560-820/mo' },
  { profile: 'Couple, Ages 35 & 40', cigna: '$620-900/mo', bupa: '$680-980/mo', axa: '$500-730/mo' },
  { profile: 'Couple, Both Age 50', cigna: '$1,000-1,500/mo', bupa: '$1,100-1,600/mo', axa: '$800-1,200/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs AXA: Best Insurance for Expat Couples 2026"
  description="Compare health insurance for expat couples: Cigna Global, Bupa Global, and AXA Global. Couple discounts, partner coverage, and pricing for two adults abroad."
  headline="Cigna vs Bupa vs AXA: Insurance for Couples Compared"
  subheadline="Coverage for two adults without children. Find the best value, partner options, and couple-specific benefits from the major insurers."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Service</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Best app and claims. Easy to manage two policies. Couple discount available.</p>
      <a href="/go/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Cigna Quote</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Premium Coverage</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Shared deductible option. Lifetime renewal. Best if one partner has health needs.</p>
      <a href="/go/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Bupa Quote</a>
    </div>
    <div class="bg-green-50 border-2 border-green-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">AXA Global</p>
      <p class="text-sm text-neutral-600 mb-3">Biggest couple discount (12%). Save $150-300/month vs. competitors.</p>
      <a href="/go/axa-global" class="inline-block w-full text-center bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get AXA Quote</a>
    </div>
  </div>

  <p>
    Couples get modest discounts (10-12%) vs. two individual policies. All three insurers cover unmarried partners. AXA offers the best value; Cigna the best experience; Bupa the most flexibility with shared deductible options.
  </p>

  <h2 id="comparison-table">Side-by-Side Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="cigna-global">Cigna Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Best App</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Easy Management</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Fast Claims</span>
  </div>

  <p>
    Cigna Global's app makes managing two policies simple—both partners can be on one account with separate cards and coverage. Fast claims processing means neither of you waits long for reimbursements. Premium pricing, but premium experience.
  </p>

  <p><strong>Strengths:</strong></p>
  <ul>
    <li>Best mobile app for managing coverage</li>
    <li>Both partners on one account</li>
    <li>~10% couple discount</li>
    <li>Fast claims for both members</li>
    <li>Largest provider network</li>
    <li>Unlimited coverage per person</li>
  </ul>

  <p><strong>Weaknesses:</strong></p>
  <ul>
    <li>No shared deductible option</li>
    <li>Most expensive option</li>
    <li>Strict pre-existing condition handling</li>
  </ul>

  <p><strong>Best for:</strong> Couples who value convenience and the best digital experience. Tech-savvy pairs who want easy policy management. Those willing to pay more for better service.</p>

  <div class="my-6">
    <a href="/go/cigna-global" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Cigna Quote</a>
    <a href="/providers/cigna-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="bupa-global">Bupa Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Shared Deductible</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Lifetime Renewal</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Flexible</span>
  </div>

  <p>
    Bupa Global stands out with an optional shared deductible—one deductible for both partners instead of two. This can save money if one partner uses healthcare more than the other. Lifetime renewal means neither of you can be dropped for developing conditions.
  </p>

  <p><strong>Strengths:</strong></p>
  <ul>
    <li>Shared deductible option available</li>
    <li>Lifetime renewal guarantee for both</li>
    <li>~10% couple discount</li>
    <li>Flexible on pre-existing conditions</li>
    <li>Excellent customer service</li>
    <li>Good if one partner has health needs</li>
  </ul>

  <p><strong>Weaknesses:</strong></p>
  <ul>
    <li>Most expensive base pricing</li>
    <li>App not as polished as Cigna</li>
    <li>Shared deductible adds complexity</li>
  </ul>

  <p><strong>Best for:</strong> Couples where one partner expects to use healthcare more. Those who want lifetime renewal protection. Long-term expat couples planning to age abroad.</p>

  <div class="my-6">
    <a href="/go/bupa-global" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Bupa Quote</a>
    <a href="/providers/bupa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="axa-global">AXA Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Best Value</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">12% Discount</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Strong Coverage</span>
  </div>

  <p>
    AXA Global offers the biggest couple discount (12%) on top of already-lower base pricing. For couples, this compounds into significant savings—$150-300/month less than Cigna or Bupa. Same comprehensive coverage, just better value.
  </p>

  <p><strong>Strengths:</strong></p>
  <ul>
    <li>Biggest couple discount (12%)</li>
    <li>Lowest overall pricing</li>
    <li>Strong mental health coverage</li>
    <li>Comprehensive benefits included</li>
    <li>Good for European couples</li>
    <li>Save $1,800-3,600/year vs. Bupa</li>
  </ul>

  <p><strong>Weaknesses:</strong></p>
  <ul>
    <li>€3M coverage limit (vs unlimited)</li>
    <li>Smaller direct billing network</li>
    <li>No shared deductible option</li>
    <li>App less polished</li>
  </ul>

  <p><strong>Best for:</strong> Value-conscious couples. Those who prioritize savings over premium features. Couples in Europe where AXA's network is strongest.</p>

  <div class="my-6">
    <a href="/go/axa-global" class="inline-block bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get AXA Quote</a>
    <a href="/providers/axa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <CTABox
    title="Compare Couple Options"
    description="Get personalized quotes for both of you. See couple discounts applied to your specific situation."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
    variant="highlight"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p>
    Couple pricing is essentially two individual premiums minus a small discount. AXA's lower base price plus higher discount makes it the clear value winner.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">
    *Estimated ranges for comprehensive coverage excluding US. Age-based pricing means different ages = different per-person costs combined.
  </p>

  <h2 id="couple-considerations">What Couples Need to Consider</h2>

  <h3>Unmarried Partners</h3>
  <p>
    Good news: all three insurers cover unmarried partners. You don't need a marriage certificate to get couple rates. Domestic partners, civil unions, and long-term relationships all qualify. Just declare you're applying as a couple.
  </p>

  <h3>Different Ages</h3>
  <p>
    If there's a significant age gap, each partner is priced separately. A couple with ages 35 and 50 pays more than two 35-year-olds. The couple discount still applies, but the total reflects each person's individual risk.
  </p>

  <h3>Different Health Needs</h3>
  <p>
    If one partner has pre-existing conditions, consider:
  </p>
  <ul>
    <li><strong>Bupa:</strong> Most flexible underwriting, shared deductible helps if one uses more</li>
    <li><strong>Cigna:</strong> Strict underwriting, may exclude conditions for one partner</li>
    <li><strong>AXA:</strong> Moderate approach, good value even with some exclusions</li>
  </ul>

  <h3>Future Family Planning</h3>
  <p>
    If pregnancy is possible, consider adding maternity coverage now—there's a waiting period. All three offer maternity add-ons, but Bupa tends to have the highest maternity limits.
  </p>

  <h3>One Partner Works, One Doesn't</h3>
  <p>
    This is common for trailing spouses. Options:
  </p>
  <ul>
    <li>Both on one international policy (what we're comparing here)</li>
    <li>Working partner on employer plan, other on individual international</li>
    <li>Both on employer plan if dependent coverage included</li>
  </ul>

  <h2 id="best-for">Which Is Best For You?</h2>

  <div class="space-y-4 my-8">
    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Cigna Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the best app and digital experience</li>
        <li>Value fast claims processing</li>
        <li>Are both relatively healthy</li>
        <li>Prioritize convenience over cost</li>
        <li>Travel frequently and need global access</li>
        <li>Like managing everything from your phone</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Bupa Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>One partner has ongoing health needs</li>
        <li>Want shared deductible option</li>
        <li>Value lifetime renewal guarantee</li>
        <li>Plan to stay abroad long-term</li>
        <li>Have pre-existing conditions to cover</li>
        <li>Want premium customer service</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose AXA Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the best value for couples</li>
        <li>Are budget-conscious</li>
        <li>Live in Europe</li>
        <li>Don't need unlimited coverage</li>
        <li>Are comfortable with some reimbursement claims</li>
        <li>Want to save $1,800-3,600/year</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Do we need to be married to get couple rates?</h3>
  <p>
    No. All three insurers accept domestic partners, civil unions, and long-term relationships. You just need to apply together as a couple. No marriage certificate required.
  </p>

  <h3>Can we have different coverage levels?</h3>
  <p>
    Generally no—couples need to be on the same plan. However, one partner can add optional riders (like maternity) that the other doesn't need. Deductibles can sometimes differ.
  </p>

  <h3>What if one of us travels more than the other?</h3>
  <p>
    International plans cover both of you globally, regardless of who travels more. The stay-at-home partner has the same worldwide coverage as the frequent traveler.
  </p>

  <h3>Can we add children later if we have them?</h3>
  <p>
    Yes. All three allow adding children to an existing couple policy. Newborns get automatic coverage for 14-30 days (depending on insurer) while you add them officially.
  </p>

  <h3>Is it cheaper to get two individual policies?</h3>
  <p>
    No. Individual policies cost the same or more than couple pricing per person. The 10-12% couple discount makes joint coverage the better deal.
  </p>

  <h3>What happens if we break up?</h3>
  <p>
    You can convert to individual policies. The person leaving keeps their coverage history, which matters for pre-existing conditions. Talk to your insurer about the process—it's usually straightforward.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This comparison is for informational purposes only. Couple discounts and pricing vary by age, location, and health status. Get actual quotes for both partners for accurate pricing.
    </p>
  </div>
</PageShell>
