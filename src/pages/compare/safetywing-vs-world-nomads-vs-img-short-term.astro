---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', title: 'Quick Verdict' },
  { id: 'comparison', title: 'Side-by-Side Comparison' },
  { id: 'safetywing', title: 'SafetyWing' },
  { id: 'world-nomads', title: 'World Nomads' },
  { id: 'img', title: 'IMG' },
  { id: 'pricing', title: 'Pricing Comparison' },
  { id: 'short-term-details', title: 'Short-term Coverage Details' },
  { id: 'best-for', title: 'Best For' },
  { id: 'faqs', title: 'FAQs' },
];

const relatedLinks = [
  { href: '/providers/safetywing', title: 'SafetyWing Full Review' },
  { href: '/providers/world-nomads', title: 'World Nomads Full Review' },
  { href: '/providers/img', title: 'IMG Full Review' },
  { href: '/best/travel-insurance', title: 'Best Travel Insurance' },
  { href: '/guides/trip-insurance-vs-expat-insurance', title: 'Trip vs Expat Insurance' },
];

const mainComparisonColumns = ['Feature', 'SafetyWing', 'World Nomads', 'IMG'];
const mainComparisonRows = [
  ['Minimum Term', '4 weeks (auto-renews)', '1 day', '5 days'],
  ['Maximum Term', 'Unlimited (monthly)', '12 months', '2 years'],
  ['Trip Cancellation', 'Not included', 'Up to $10,000', 'Optional add-on'],
  ['Adventure Sports', 'Basic included', 'Extensive coverage', 'Activity-specific'],
  ['Gear Protection', 'Up to $3,000', 'Up to $5,000', 'Up to $2,500'],
  ['Medical Maximum', '$250,000', '$100,000', '$1,000,000+'],
  ['Purchase Flexibility', 'While traveling', 'Before departure', 'Before or during'],
  ['Age Limit', '69 years', '69 years', '74 years'],
  ['Home Country Coverage', 'Up to 30 days', 'Not included', 'Optional'],
];

const pricingColumns = ['Duration', 'SafetyWing', 'World Nomads', 'IMG'];
const pricingRows = [
  ['1 Week', 'N/A (4-week min)', '$45-75', '$35-50'],
  ['1 Month', '$48', '$180-300', '$95-150'],
  ['3 Months', '$144', '$540-900', '$275-400'],
  ['6 Months', '$288', '$1,080-1,800', '$525-750'],
  ['12 Months', '$576', 'N/A (renew at 6)', '$1,000-1,400'],
];
---

<PageShell
  title="SafetyWing vs World Nomads vs IMG: Short-term Coverage Comparison 2025"
  description="Compare SafetyWing, World Nomads, and IMG for short-term expat and travel insurance. Detailed analysis of coverage, flexibility, and pricing."
  headline="SafetyWing vs World Nomads vs IMG"
  subheadline="Which Provider is Best for Short-term Coverage?"
  heroImage="/images/compare/short-term-hero.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">SafetyWing</h3>
        <p class="text-neutral-700 mb-4">Best for digital nomads and long-term travelers who want simple, affordable coverage without trip cancellation needs.</p>
        <p class="text-sm font-medium text-primary-700">From $48/month</p>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">World Nomads</h3>
        <p class="text-neutral-700 mb-4">Best for adventure travelers who need trip cancellation, gear protection, and coverage for extreme sports and activities.</p>
        <p class="text-sm font-medium text-purple-700">From $45/week</p>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">IMG</h3>
        <p class="text-neutral-700 mb-4">Best for those needing higher medical limits, longer coverage periods, or more flexibility with plan customization.</p>
        <p class="text-sm font-medium text-green-700">From $35/week</p>
      </div>
    </div>
  </section>

  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <div class="bg-primary-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-primary-800 mb-4">SafetyWing</h2>
      <p class="text-lg text-neutral-700 mb-6">SafetyWing's Nomad Insurance operates like a subscription—pay monthly, cancel anytime, and buy while already traveling. This flexibility makes it popular among digital nomads and remote workers who don't have fixed travel dates.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Short-term Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Purchase coverage from anywhere in the world (no need to start from home)</li>
        <li>Monthly billing with no long-term commitment required</li>
        <li>Automatic renewal means no coverage gaps if you lose track of dates</li>
        <li>Includes 30 days of home country coverage per 90-day period</li>
        <li>Simple, straightforward pricing without confusing tiers</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Short-term Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>4-week minimum—not suitable for quick 1-2 week trips</li>
        <li>No trip cancellation or interruption coverage</li>
        <li>$250 deductible applies to each incident</li>
        <li>Limited adventure sports coverage compared to World Nomads</li>
      </ul>
    </div>
  </section>

  <section id="world-nomads" class="mb-12">
    <div class="bg-purple-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-purple-800 mb-4">World Nomads</h2>
      <p class="text-lg text-neutral-700 mb-6">World Nomads pioneered travel insurance for adventurers, offering coverage for over 200 activities that other insurers exclude. Their focus is on trip-based protection including cancellation and gear coverage.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Short-term Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Coverage for 200+ adventure activities including extreme sports</li>
        <li>Trip cancellation up to $10,000 (Explorer plan)</li>
        <li>Gear and electronics protection for travelers' equipment</li>
        <li>Can purchase for trips as short as one day</li>
        <li>24/7 emergency assistance with multilingual support</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Short-term Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Must purchase before leaving home country (limited exceptions)</li>
        <li>Lower medical maximum ($100,000) than competitors</li>
        <li>More expensive for longer trips—pricing becomes less competitive after 2-3 months</li>
        <li>6-month maximum coverage period per trip</li>
      </ul>
    </div>
  </section>

  <section id="img" class="mb-12">
    <div class="bg-green-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-green-800 mb-4">IMG Global</h2>
      <p class="text-lg text-neutral-700 mb-6">IMG offers multiple short-term products (iTravelInsured, Patriot Travel) that can be customized with higher limits and optional add-ons. Good for travelers wanting more comprehensive medical coverage.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Short-term Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Medical limits up to $8 million for serious coverage needs</li>
        <li>Higher age limit (74) than most competitors</li>
        <li>Flexible deductible options from $0 to $2,500</li>
        <li>Can add trip cancellation, baggage, and other optional coverage</li>
        <li>Coverage periods from 5 days to 2 years</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Short-term Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>More complex product lineup can be confusing</li>
        <li>Adventure sports require checking specific activity coverage</li>
        <li>Less brand recognition among digital nomad community</li>
        <li>Some plans require purchasing before departure</li>
      </ul>
    </div>
  </section>

  <CTABox
    title="Need Help Choosing Short-term Coverage?"
    description="Get personalized recommendations based on your trip length, activities, and coverage needs."
    buttonText="Compare Plans"
    buttonHref="/best/travel-insurance"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-600 mb-6">Estimated costs for a 30-year-old traveler. Prices vary by age, destination, and plan options.</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">World Nomads range reflects Standard vs Explorer plans. IMG range reflects different coverage levels.</p>
  </section>

  <section id="short-term-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Short-term Coverage Considerations</h2>
    
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Duration Flexibility</h3>
        <p class="text-neutral-700">SafetyWing requires a 4-week minimum but offers unlimited extensions. World Nomads is ideal for 1 day to 6 months. IMG fills the middle ground with 5-day minimum and up to 2-year coverage. Consider whether you need precise date coverage or prefer ongoing protection.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Trip Cancellation Needs</h3>
        <p class="text-neutral-700">If you have non-refundable flights, hotels, or tours booked, World Nomads provides the most comprehensive cancellation protection. SafetyWing doesn't offer trip cancellation at all, while IMG offers it as an optional add-on for some plans.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Adventure Activities</h3>
        <p class="text-neutral-700">World Nomads covers 200+ activities including skydiving, bungee jumping, and motorsports. SafetyWing covers basic activities like hiking and snorkeling but excludes extreme sports. IMG coverage varies by specific plan and may require additional premiums.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Medical Coverage Depth</h3>
        <p class="text-neutral-700">For serious medical emergencies, IMG offers the highest limits (up to $8 million). SafetyWing's $250,000 is adequate for most situations. World Nomads' $100,000 limit may be insufficient for major emergencies in expensive healthcare markets like the US.</p>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Choose SafetyWing If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You're a digital nomad or long-term traveler</li>
          <li>You want to buy coverage while abroad</li>
          <li>You prefer simple monthly billing</li>
          <li>Trip cancellation isn't important</li>
          <li>You're on a tight budget</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Choose World Nomads If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You're taking a 1-week to 3-month trip</li>
          <li>You need trip cancellation coverage</li>
          <li>You're doing adventure activities</li>
          <li>You have expensive gear to protect</li>
          <li>You're booking before departure</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Choose IMG If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You need high medical coverage limits</li>
          <li>You're over 70 years old</li>
          <li>You want customizable coverage options</li>
          <li>You need coverage for 1-2 years</li>
          <li>You're traveling to the US</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I extend my short-term coverage if my trip goes longer?</h3>
        <p class="text-neutral-700">SafetyWing auto-renews monthly, so extending is automatic. World Nomads allows one extension while traveling. IMG plans can typically be extended if you apply before your current coverage expires.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Do these plans cover pre-existing conditions?</h3>
        <p class="text-neutral-700">Generally, short-term travel insurance excludes pre-existing conditions. IMG offers some plans with limited pre-existing condition coverage if conditions are controlled. For comprehensive pre-existing coverage, you'll need a full expat health plan.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Which is best for US citizens traveling abroad?</h3>
        <p class="text-neutral-700">All three work well for US citizens abroad. IMG has the most established US presence. SafetyWing is popular among US digital nomads. World Nomads is good for adventure trips. For returning to the US, ensure your plan covers US healthcare costs.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I need to make a claim while traveling?</h3>
        <p class="text-neutral-700">All three providers offer 24/7 emergency assistance hotlines. For non-emergencies, SafetyWing and IMG have online claims portals. World Nomads claims can be filed online or by phone. Keep all receipts and documentation.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is short-term travel insurance the same as expat health insurance?</h3>
        <p class="text-neutral-700">No. Short-term travel insurance is designed for trips and includes travel-specific benefits like trip cancellation. Expat health insurance is comprehensive medical coverage for people living abroad, similar to domestic health insurance.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Do these plans meet Schengen visa requirements?</h3>
        <p class="text-neutral-700">All three can provide documentation for Schengen visas, but verify specific requirements. Schengen visas require €30,000 medical coverage and repatriation. World Nomads Explorer plan includes this. SafetyWing and IMG can provide compliant coverage.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 mb-12">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Coverage details, pricing, and availability vary by location, age, and plan selection. This comparison is for informational purposes only. Always verify current terms directly with providers before purchasing. Coverage for specific activities and conditions should be confirmed in the policy documents.
    </p>
  </div>
</PageShell>
