---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'axa', text: 'AXA Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'africa-considerations', text: 'Africa Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Bupa Global Full Review', href: '/providers/bupa-global' },
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'AXA Global Full Review', href: '/providers/axa-global' },
  { title: 'Insurance for Africa Expats', href: '/insurance-for/africa-expats' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
];

const mainComparisonRows = [
  { feature: 'South Africa network', bupa: 'Excellent', cigna: 'Excellent', axa: 'Good' },
  { feature: 'East Africa (Kenya)', bupa: 'Good', cigna: 'Very good', axa: 'Good' },
  { feature: 'West Africa (Nigeria)', bupa: 'Limited', cigna: 'Good', axa: 'Limited' },
  { feature: 'North Africa', bupa: 'Good', cigna: 'Good', axa: 'Strong' },
  { feature: 'Medical evacuation', bupa: 'Comprehensive', cigna: 'Comprehensive', axa: 'Comprehensive' },
  { feature: 'Air ambulance', bupa: 'Included', cigna: 'Included', axa: 'Included' },
  { feature: 'Tropical diseases', bupa: 'Covered', cigna: 'Covered', axa: 'Covered' },
  { feature: 'Security evacuation', bupa: 'Add-on', cigna: 'Add-on', axa: 'Add-on' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
];

const pricingRows = [
  { scenario: 'Age 35, South Africa', bupa: '$3,200-4,500/yr', cigna: '$3,000-4,200/yr', axa: '$2,600-3,800/yr' },
  { scenario: 'Age 35, Kenya', bupa: '$3,500-5,000/yr', cigna: '$3,200-4,500/yr', axa: '$2,800-4,000/yr' },
  { scenario: 'Age 45, Africa region', bupa: '$4,800-7,000/yr', cigna: '$4,500-6,500/yr', axa: '$4,000-5,800/yr' },
  { scenario: 'Family (2+2), Africa', bupa: '$10,000-14,500/yr', cigna: '$9,500-13,500/yr', axa: '$8,500-12,000/yr' },
  { scenario: 'With evacuation enhanced', bupa: '+$500-800/yr', cigna: '+$400-700/yr', axa: '+$400-700/yr' },
];
---

<PageShell
  title="Bupa vs Cigna vs AXA: Best for Africa Expats 2025"
  description="Compare Bupa, Cigna, and AXA for expats in Africa. South Africa, Kenya, Nigeria coverage, medical evacuation, and tropical disease protection."
  headline="Bupa vs Cigna vs AXA: Africa Expat Insurance"
  subheadline="Which insurer is best for expats in Africa? Regional networks, medical evacuation, and coverage for the continent's diverse healthcare landscape."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Overall</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Strongest Africa-wide network coverage. Good presence across East, West, and Southern Africa. Best for mobile expats across the continent.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best for South Africa</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Excellent South African hospital network. Premium service standards. Best for expats based primarily in South Africa.</p>
      <a href="/providers/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">AXA Global</p>
      <p class="text-sm text-neutral-600 mb-3">Most affordable premiums. Good basic coverage. Best for budget-conscious expats in Africa.</p>
      <a href="/providers/axa-global" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="bupa">Bupa Global</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Bupa Global has an excellent South African network and premium service standards. For expats based primarily in South Africa or Southern Africa, Bupa offers strong local coverage with world-class hospital access.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Africa Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Excellent South Africa hospital network</li>
      <li>Good coverage across Southern Africa</li>
      <li>Comprehensive medical evacuation</li>
      <li>Air ambulance to regional centers</li>
      <li>Tropical disease coverage</li>
      <li>Premium service standards</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Highest premiums of the three</li>
      <li>West Africa network limited</li>
      <li>East Africa coverage less comprehensive than Cigna</li>
      <li>Less ideal for pan-African mobility</li>
    </ul>
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global has the strongest continent-wide coverage in Africa, with good networks across East, West, and Southern regions. For expats who work across multiple African countries, Cigna offers the most consistent coverage.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Africa Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Strongest pan-African coverage</li>
      <li>Excellent South Africa network</li>
      <li>Good East Africa presence (Kenya, Tanzania)</li>
      <li>Better West Africa coverage than competitors</li>
      <li>Comprehensive evacuation services</li>
      <li>Good for mobile African expats</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Mid-to-high pricing</li>
      <li>West Africa still has network gaps</li>
      <li>Remote areas require evacuation</li>
      <li>Corporate focus may not suit individuals</li>
    </ul>
  </div>

  <h2 id="axa">AXA Global Healthcare</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">AXA Global offers the most affordable coverage for Africa expats while still providing essential protections. Their strong North Africa presence and good South Africa coverage make them suitable for budget-conscious expats.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Africa Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most affordable premiums</li>
      <li>Good South Africa coverage</li>
      <li>Strong North Africa networks</li>
      <li>Comprehensive evacuation included</li>
      <li>Tropical disease coverage</li>
      <li>Good value for money</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Sub-Saharan networks more limited</li>
      <li>East Africa coverage less comprehensive</li>
      <li>West Africa very limited</li>
      <li>Less premium service</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage for Your African Assignment"
    description="Compare plans designed for Africa expats. Medical evacuation, tropical disease coverage, and protection across the continent."
    buttonText="Compare Africa Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Annual premiums for Africa-based expats. Prices vary significantly by country and specific risk factors.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Africa premiums include evacuation coverage—essential for the continent. Higher-risk countries may have premium loading. Enhanced security evacuation is available as add-on.</p>

  <h2 id="africa-considerations">Africa Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Medical Evacuation is Essential</h3>
      <p class="text-neutral-700">Africa has world-class hospitals in South Africa and Kenya, but many areas lack adequate medical facilities. Medical evacuation to regional centers (Johannesburg, Nairobi) or international destinations (Europe, UAE) is essential. All three insurers include comprehensive evacuation—verify your specific policy limits.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Tropical Disease Coverage</h3>
      <p class="text-neutral-700">Malaria, typhoid, yellow fever, and other tropical diseases are real risks across much of Africa. All three insurers cover tropical diseases as any other illness. Prevention (antimalarials, vaccinations) may be covered under wellness benefits. Treatment costs can be significant—ensure adequate coverage limits.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Security Considerations</h3>
      <p class="text-neutral-700">Some African locations have security risks. Medical evacuation covers health emergencies, but security evacuation (for civil unrest, kidnapping risk, etc.) is typically a separate add-on. Consider your specific location's risks. Corporate expats often have employer-provided security coverage.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Healthcare Quality Varies Dramatically</h3>
      <p class="text-neutral-700">South Africa has excellent private hospitals comparable to Western standards. Kenya's Nairobi has good facilities. West Africa is more challenging. Rural areas across the continent have limited care. Choose your insurer based on where you'll spend most time—and ensure evacuation coverage for times when you're in areas with limited healthcare.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Corporate vs Individual Coverage</h3>
      <p class="text-neutral-700">Many Africa expats work for corporations that provide insurance. If self-funding, prioritize evacuation coverage and verify network hospitals in your specific location. Corporate policies often include security evacuation—individual policies may require add-ons for this coverage.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose Bupa If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>South Africa is your primary base</li>
        <li>Premium service matters</li>
        <li>You want established brand</li>
        <li>Southern Africa focused</li>
        <li>Quality over cost</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You work across multiple African countries</li>
        <li>East Africa coverage matters</li>
        <li>West Africa presence needed</li>
        <li>Continental mobility</li>
        <li>Corporate expat assignment</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose AXA If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is primary concern</li>
        <li>North Africa focused</li>
        <li>South Africa based</li>
        <li>Basic coverage suffices</li>
        <li>Value over premium service</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is medical evacuation really necessary in Africa?</h3>
      <p class="text-neutral-700">Yes—it's essential. While South Africa and Kenya have excellent hospitals, serious conditions in many African countries require evacuation to regional medical centers or international destinations. Air ambulance costs $50,000-200,000+. All three insurers include evacuation—it's not optional coverage in Africa.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about coverage in Nigeria?</h3>
      <p class="text-neutral-700">West Africa including Nigeria is the most challenging region. Cigna has the best coverage but still limited. All three cover emergencies and evacuation. For routine care in Lagos, you may need to pay upfront and claim reimbursement. Corporate expats often have dedicated solutions for West Africa.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Are vaccinations covered before travel to Africa?</h3>
      <p class="text-neutral-700">Travel vaccinations (yellow fever, typhoid, hepatitis, etc.) may be covered under wellness benefits on comprehensive plans. Verify your specific policy. Many expats pay for initial vaccinations out of pocket—they're a one-time expense. Antimalarials are typically covered as prescription medication.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What if there's political instability in my country?</h3>
      <p class="text-neutral-700">Medical evacuation covers health emergencies, not security situations. Security evacuation (for civil unrest, political instability, etc.) is typically a separate add-on or provided through corporate employers. If you're in a higher-risk country, consider security evacuation coverage or ensure your employer provides it.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I fly home for treatment instead of using local hospitals?</h3>
      <p class="text-neutral-700">Your insurance covers treatment—where you receive it depends on medical necessity and your plan. For emergencies, you'll be treated locally or evacuated to nearest appropriate facility. For planned treatment, you can often choose where to go (local, regional center, or home country) within your coverage area.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about coverage for safari or adventure activities?</h3>
      <p class="text-neutral-700">Standard safari activities and tourism are covered. Extreme adventure sports may have limitations—verify specific activities. If you're injured on safari in a remote area, medical evacuation covers transport to appropriate care. The insurers understand Africa includes wilderness activities.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Africa is a diverse continent with vastly different healthcare systems by country and region. This comparison provides general guidance—verify specific network coverage for your exact location. Security situations change; consult travel advisories. Coverage options and pricing change regularly.
    </p>
  </div>
</PageShell>
