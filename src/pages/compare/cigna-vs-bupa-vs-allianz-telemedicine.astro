---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'telehealth-features', text: 'Telehealth Features Compared', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/compare/cigna-vs-bupa-vs-allianz-wellness', text: 'Wellness Coverage Comparison' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Telehealth Platform', cigna: 'Cigna Telehealth', bupa: 'Bupa Anytime', allianz: 'MyHealth Telehealth' },
  { feature: '24/7 Availability', cigna: 'Yes', bupa: 'Yes', allianz: 'Yes' },
  { feature: 'Languages Supported', cigna: '15+', bupa: '12+', allianz: '20+' },
  { feature: 'Mental Health Sessions', cigna: 'Included', bupa: 'Excellent', allianz: 'Basic' },
  { feature: 'Specialist Consultations', cigna: 'Yes', bupa: 'Yes (premium)', allianz: 'Limited' },
  { feature: 'Prescription Delivery', cigna: 'Coordinated', bupa: 'Coordinated', allianz: 'Some regions' },
  { feature: 'App Quality', cigna: 'Excellent', bupa: 'Excellent', allianz: 'Good' },
  { feature: 'Wait Times', cigna: '< 15 min', bupa: '< 10 min', allianz: '< 20 min' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Individual (35, comprehensive)', cigna: '$300-400/mo', bupa: '$350-480/mo', allianz: '$260-350/mo' },
  { profile: 'Telehealth included?', cigna: 'Yes (all plans)', bupa: 'Yes (all plans)', allianz: 'Yes (all plans)' },
  { profile: 'Mental health telehealth', cigna: 'Included', bupa: 'Included', allianz: 'Basic only' },
  { profile: 'Specialist video consult', cigna: 'Included', bupa: 'Premium plans', allianz: 'Limited' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Telemedicine | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for telemedicine and virtual healthcare. Expert analysis of telehealth platforms, mental health access, and 24/7 availability."
  headline="Cigna vs Bupa vs Allianz: Best Telemedicine Coverage"
  subheadline="Complete comparison of three leading providers for expats who value 24/7 virtual healthcare access from anywhere in the world."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Telehealth</p>
        <p class="text-neutral-700 text-sm mb-4">Most comprehensive telehealth with specialist access, mental health, and prescription coordination all included.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Mental Health Telehealth</p>
        <p class="text-neutral-700 text-sm mb-4">Excellent mental health focus with therapy sessions, coaching, and fastest wait times for consultations.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Language Support</p>
        <p class="text-neutral-700 text-sm mb-4">Most languages supported (20+) with solid basic telehealth at the most competitive price.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Cigna Telehealth</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Specialist Access</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Prescription Coordination</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna's telehealth platform stands out for comprehensive access to both general practitioners and specialists via video consultation. Whether you need a routine check-in, a dermatology opinion, or a mental health session, Cigna connects you with qualified physicians 24/7 in 15+ languages.</p>

    <p class="text-neutral-700 mb-4">Prescription coordination is particularly strong—Cigna works with international pharmacies to ensure medications prescribed during telehealth visits are available where you are. The app experience is polished, with easy appointment booking, medical record access, and one-click consultation options.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Telehealth Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Specialist video consultations included</li>
          <li>• Mental health sessions unlimited</li>
          <li>• Prescription delivery coordination</li>
          <li>• 15+ languages supported</li>
          <li>• Under 15 minute wait times</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher premiums than Allianz</li>
          <li>• Some specialties limited in certain regions</li>
          <li>• Video quality depends on your connection</li>
          <li>• Not a replacement for in-person care when needed</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Bupa Anytime</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Mental Health Focus</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Fastest Wait Times</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa's Anytime telehealth platform excels particularly for mental health support. Expats often struggle with isolation, culture shock, and stress—Bupa understands this and provides easy access to therapists, counselors, and mental health coaches via video at any hour.</p>

    <p class="text-neutral-700 mb-4">Wait times are the shortest in the industry, typically under 10 minutes to connect with a GP. The app is intuitive, with symptom checkers that help determine whether telehealth, urgent care, or emergency services are appropriate. Premium plan members get specialist video consultations at no additional cost.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Telehealth Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best mental health telehealth</li>
          <li>• Fastest wait times (< 10 min)</li>
          <li>• Therapy and coaching available</li>
          <li>• Excellent app experience</li>
          <li>• Symptom checker built in</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• Specialist access on premium plans only</li>
          <li>• 12 languages (fewer than Allianz)</li>
          <li>• Some features UK/Europe optimized</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">20+ Languages</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Value Pricing</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">MyHealth App</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care's MyHealth telehealth platform offers solid functionality at a more accessible price point. With support for 20+ languages—more than any competitor—Allianz is ideal for expats who prefer consultations in their native language or live in regions where English isn't widely spoken.</p>

    <p class="text-neutral-700 mb-4">Basic telehealth consultations are available 24/7, covering general health questions, minor illness diagnosis, and prescription renewals. Mental health support exists but is more limited than Cigna or Bupa. Specialist video consultations are available but not as comprehensive.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Telehealth Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most languages supported (20+)</li>
          <li>• Most affordable premiums</li>
          <li>• 24/7 basic telehealth included</li>
          <li>• MyHealth app is user-friendly</li>
          <li>• Good for routine consultations</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited mental health telehealth</li>
          <li>• Specialist access restricted</li>
          <li>• Longer wait times (< 20 min)</li>
          <li>• Prescription coordination limited</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Telehealth Coverage Quotes"
    description="Get personalized quotes with comprehensive telehealth benefits from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Telehealth is included in all plans from these providers—the difference is in depth of coverage:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*All three providers include basic telehealth. Cigna includes the most comprehensive telehealth in standard premiums.</p>
  </section>

  <section id="telehealth-features" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Telehealth Features Compared</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Consultation Types</h3>
        <p class="text-neutral-700 text-sm mb-4">What you can do via video consultation:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> GP, specialist, mental health, second opinions</li>
          <li>• <strong>Bupa:</strong> GP, mental health, wellness coaching, some specialists</li>
          <li>• <strong>Allianz:</strong> GP primarily, limited mental health, few specialists</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Prescription Handling</h3>
        <p class="text-neutral-700 text-sm mb-4">How prescriptions work after telehealth visits:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> E-prescriptions sent to local pharmacies, delivery coordination</li>
          <li>• <strong>Bupa:</strong> E-prescriptions available, pharmacy finder in app</li>
          <li>• <strong>Allianz:</strong> Prescriptions issued, member arranges pharmacy</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Mental Health via Telehealth</h3>
      <p class="text-blue-700 mb-4">Increasingly important for expat wellbeing:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">Unlimited video sessions with therapists. EAP program included. Crisis support 24/7. Multiple therapy modalities available.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">Best mental health focus. Therapy plus life coaching. Mindfulness programs. Resilience training. Fastest access to mental health professionals.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Allianz</h4>
          <p class="text-blue-700 text-sm">Basic mental health consultations. Limited session counts. Adequate for mild concerns. May need upgrade for ongoing therapy.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the most comprehensive telehealth experience</li>
          <li>• Specialist video consultations are important to you</li>
          <li>• You need prescription coordination across countries</li>
          <li>• You value mental health and second opinions via video</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Mental health support is your priority</li>
          <li>• You want the fastest wait times</li>
          <li>• Wellness coaching and therapy appeal to you</li>
          <li>• You value the best app experience</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a significant consideration</li>
          <li>• You need consultations in less common languages</li>
          <li>• Basic GP telehealth meets your needs</li>
          <li>• You mainly want telehealth for routine issues</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use telehealth from anywhere in the world?</h3>
        <p class="text-neutral-700">Yes, all three providers offer global telehealth access. As long as you have a stable internet connection, you can consult with doctors via video from any country. Some countries have regulations about medical practice that may limit certain services, but basic consultations work everywhere.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What conditions are appropriate for telehealth?</h3>
        <p class="text-neutral-700">Telehealth works well for: colds and flu, skin conditions, minor injuries, mental health, prescription renewals, second opinions, and chronic condition management. It's not appropriate for emergencies, conditions requiring physical examination, or situations needing immediate intervention.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I get prescriptions via telehealth?</h3>
        <p class="text-neutral-700">Yes, doctors can prescribe medications during telehealth consultations. However, controlled substances and certain medications may have restrictions. Cigna coordinates delivery to many locations; Bupa and Allianz typically issue prescriptions for you to fill locally. Always verify your medication is available in your country.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is there a limit to how many telehealth consultations I can have?</h3>
        <p class="text-neutral-700">Cigna offers unlimited telehealth consultations on most plans. Bupa typically has generous limits that most members never reach. Allianz may have visit limits on basic plans—check your specific policy. Mental health session limits vary more than general consultations.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Telehealth features and availability change frequently. Some services may be limited in certain countries due to local regulations. Always verify specific telehealth benefits with providers before purchasing. This comparison is for informational purposes only and does not constitute medical or insurance advice.</p>
  </div>
</PageShell>
