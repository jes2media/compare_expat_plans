---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'caribbean-healthcare', text: 'Caribbean Healthcare Realities', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/countries/costa-rica/insurance', text: 'Costa Rica Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Caribbean Network', allianz: 'Good', cigna: 'Excellent', img: 'Limited' },
  { feature: 'US Evacuation', allianz: 'Miami included', cigna: 'Miami/US included', img: 'Covered' },
  { feature: 'Medical Evacuation', allianz: 'Up to $1M', cigna: 'Unlimited', img: 'Up to $500K' },
  { feature: 'Hurricane Season Coverage', allianz: 'Included', cigna: 'Included', img: 'Included' },
  { feature: 'US Treatment Option', allianz: 'Add-on', cigna: 'Include/exclude', img: 'Optional' },
  { feature: 'Local Hospital Coverage', allianz: 'Direct billing limited', cigna: 'Good direct billing', img: 'Reimbursement mostly' },
  { feature: 'Island Hopping Coverage', allianz: 'Regional plan', cigna: 'Worldwide', img: 'Regional available' },
  { feature: 'Retiree Friendly', allianz: 'Good', cigna: 'Excellent', img: 'Very good' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Individual (40, excl. US)', allianz: '$250-350/mo', cigna: '$300-400/mo', img: '$180-260/mo' },
  { profile: 'Individual (40, incl. US)', allianz: '$380-520/mo', cigna: '$450-580/mo', img: '$300-420/mo' },
  { profile: 'Retiree couple (65s)', allianz: '$650-900/mo', cigna: '$800-1,100/mo', img: '$520-720/mo' },
  { profile: 'Family', allianz: '$700-950/mo', cigna: '$850-1,150/mo', img: '$550-780/mo' },
];
---

<PageShell
  title="Allianz vs Cigna vs IMG for Caribbean Expats | 2025 Comparison"
  description="Compare Allianz Care, Cigna Global, and IMG Global for Caribbean expats. Expert analysis of medical evacuation, US treatment access, and island healthcare coverage."
  headline="Allianz vs Cigna vs IMG: Best Insurance for Caribbean Expats"
  subheadline="Complete comparison of three leading providers for expats living in the Caribbean islands with critical evacuation coverage."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Allianz Care</h3>
        <p class="text-primary-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Competitive pricing with solid evacuation coverage. Good choice for budget-conscious expats on smaller islands.</p>
        <a href="/providers/allianz-care" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Cigna Global</h3>
        <p class="text-purple-700 mb-3">Best Overall Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Best Caribbean network with unlimited medical evacuation. Ideal for serious conditions requiring US treatment.</p>
        <a href="/providers/cigna-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">IMG Global</h3>
        <p class="text-green-700 mb-3">Best Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable option with adequate coverage. Good for younger, healthier expats and short-term stays.</p>
        <a href="/providers/img-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Value Pricing</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Miami Evacuation</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Plans</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers competitive Caribbean coverage with their regional plans. For expats who don't need frequent US treatment, excluding the US from your plan significantly reduces premiums while still covering medical evacuation to Miami when local facilities can't handle your condition.</p>

    <p class="text-neutral-700 mb-4">Their network across the Caribbean is decent, with partnerships at major hospitals in Puerto Rico, Dominican Republic, Jamaica, and the larger islands. For smaller islands, you'll typically pay out of pocket and seek reimbursement, but evacuation coverage ensures you can access better facilities when needed.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Caribbean Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Competitive regional pricing</li>
          <li>• Up to $1M medical evacuation</li>
          <li>• Miami evacuation standard</li>
          <li>• Flexible US include/exclude</li>
          <li>• Good for island hopping</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited direct billing locally</li>
          <li>• Smaller Caribbean network</li>
          <li>• Claims processing can be slower</li>
          <li>• Less presence on small islands</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Best Caribbean Network</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Evacuation</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">US Treatment Access</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global provides the most comprehensive Caribbean coverage with direct billing relationships at the best hospitals across the islands. Their unlimited medical evacuation is crucial—Caribbean medical evacuations to Miami or the US mainland can cost $20,000-$100,000, far exceeding IMG's $500K cap in complex cases.</p>

    <p class="text-neutral-700 mb-4">For serious conditions, Cigna's plans with US coverage let you fly to Miami or Houston for treatment at world-class facilities. This is particularly valuable for cancer care, cardiac surgery, and other specialized treatments not available on most Caribbean islands.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Caribbean Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best hospital network in Caribbean</li>
          <li>• Unlimited medical evacuation</li>
          <li>• Direct billing at major facilities</li>
          <li>• Seamless US treatment access</li>
          <li>• 24/7 coordination services</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• US coverage adds significant cost</li>
          <li>• May be more than some need</li>
          <li>• 12-month minimum</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Duration</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Good for Short-Term</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers the most affordable Caribbean coverage, making it attractive for younger expats, seasonal residents, and those on tighter budgets. Their Patriot plans provide solid coverage for most situations you'll encounter living on the islands.</p>

    <p class="text-neutral-700 mb-4">The $500K evacuation limit is generally adequate but could be strained in complex cases requiring extended ICU transport. Direct billing is limited in the Caribbean—expect to pay providers directly and submit claims for reimbursement, which IMG processes reasonably quickly.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Caribbean Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest premiums</li>
          <li>• Flexible duration (5 days to 3 years)</li>
          <li>• $500K evacuation coverage</li>
          <li>• Quick online enrollment</li>
          <li>• Good for seasonal residents</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Very limited Caribbean network</li>
          <li>• Mostly reimbursement-based</li>
          <li>• Lower evacuation limit</li>
          <li>• Less suitable for seniors with health issues</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <CTABox
    title="Compare Caribbean Coverage Quotes"
    description="Get personalized quotes from all three providers with evacuation coverage for your island."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Caribbean pricing varies significantly based on whether US treatment is included:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Including US coverage adds 40-60% to premiums but provides access to world-class facilities 2-3 hours away by air.</p>
  </section>

  <section id="caribbean-healthcare" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Caribbean Healthcare Realities</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Medical Evacuation Critical</h3>
        <p class="text-neutral-700 text-sm mb-4">Caribbean islands have limited medical facilities:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Most islands lack advanced care (ICU, cardiac surgery, oncology)</li>
          <li>• Air ambulance to Miami: $20,000-$100,000</li>
          <li>• Evacuation coverage is essential, not optional</li>
          <li>• Cigna's unlimited coverage provides maximum peace of mind</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Island-Specific Facilities</h3>
        <p class="text-neutral-700 text-sm mb-4">Healthcare quality varies dramatically:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Puerto Rico:</strong> Best facilities, near US standards</li>
          <li>• <strong>Cayman Islands:</strong> Good private hospitals</li>
          <li>• <strong>Jamaica/DR:</strong> Quality private options exist</li>
          <li>• <strong>Small islands:</strong> Basic clinics, evacuation likely</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-amber-800 mb-3">Hurricane Season Considerations</h3>
      <p class="text-amber-700 mb-4">June-November brings unique challenges:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-amber-800 mb-2">Coverage Continues</h4>
          <p class="text-amber-700 text-sm">All three providers maintain coverage during hurricanes. Medical emergencies remain covered.</p>
        </div>
        <div>
          <h4 class="font-bold text-amber-800 mb-2">Evacuation Coordination</h4>
          <p class="text-amber-700 text-sm">Providers coordinate with emergency services. May evacuate before storms if medical situation warrants.</p>
        </div>
        <div>
          <h4 class="font-bold text-amber-800 mb-2">Post-Storm Access</h4>
          <p class="text-amber-700 text-sm">After major hurricanes, local facilities may be damaged. Evacuation becomes even more critical.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Budget is a significant consideration</li>
          <li>• You're healthy and mainly need emergency coverage</li>
          <li>• You're comfortable with the reimbursement process</li>
          <li>• You don't need routine US treatment access</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You want the most comprehensive Caribbean coverage</li>
          <li>• Unlimited evacuation is important for peace of mind</li>
          <li>• You may need specialized treatment in the US</li>
          <li>• You have pre-existing conditions or health concerns</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• You're young and healthy with minimal health risks</li>
          <li>• You're a seasonal resident (winter months only)</li>
          <li>• Budget is your primary concern</li>
          <li>• You need flexible short-term coverage</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Should I include US coverage for Caribbean living?</h3>
        <p class="text-neutral-700">For most Caribbean expats, yes. Many serious conditions require treatment in Miami, Houston, or other US cities. Without US coverage, you'd pay cash for US treatment—potentially hundreds of thousands for cancer care or cardiac surgery. The 40-60% premium increase is worthwhile insurance against catastrophic costs.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What happens if I'm evacuated during hurricane season?</h3>
        <p class="text-neutral-700">All three providers cover medical evacuations before, during, and after hurricanes. If you have a medical condition requiring evacuation during a storm, the insurer coordinates with available air ambulance services. Note that evacuations may be delayed until weather permits safe travel.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use Puerto Rico facilities with my Caribbean coverage?</h3>
        <p class="text-neutral-700">Puerto Rico is complicated—it's US territory but in the Caribbean. With US coverage included, you have full access to Puerto Rico's excellent facilities. Without US coverage, treatment in Puerto Rico may be excluded or limited. Cigna and Allianz handle this more clearly than IMG.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if my island doesn't have direct billing hospitals?</h3>
        <p class="text-neutral-700">You'll pay the hospital directly and submit claims for reimbursement. All three providers have online claim submission. Cigna typically reimburses fastest (5-10 days). Keep all receipts and medical records. For large bills, contact your insurer first—they may be able to arrange direct payment.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Caribbean healthcare facilities vary significantly by island. Always verify evacuation coverage details and US treatment access with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
