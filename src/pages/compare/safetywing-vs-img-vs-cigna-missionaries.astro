---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'missionary-details', text: 'Missionary Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/missionaries', text: 'Missionary Insurance Guide' },
  { href: '/insurance-for/ngo-workers', text: 'NGO Worker Insurance' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const mainComparisonRows = [
  { feature: 'Remote Location Coverage', safetywing: 'Covered', img: 'Covered', cigna: 'Covered' },
  { feature: 'Medical Evacuation', safetywing: '\$100,000', img: '\$500,000+', cigna: 'Unlimited' },
  { feature: 'Developing World Focus', safetywing: 'Good', img: 'Excellent', cigna: 'Excellent' },
  { feature: 'Political Evacuation', safetywing: 'Not covered', img: 'Available', cigna: 'Available' },
  { feature: 'Group Rates', safetywing: 'Limited', img: 'Yes (mission orgs)', cigna: 'Yes' },
  { feature: 'Preventive Care', safetywing: 'Limited', img: 'Plan dependent', cigna: 'Comprehensive' },
  { feature: 'Mental Health', safetywing: 'Limited', img: 'Good coverage', cigna: 'Comprehensive' },
  { feature: 'Home Country Coverage', safetywing: '30 days/90', img: 'Varies', cigna: 'Full year' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const pricingRows = [
  { profile: 'Individual (30)', safetywing: '\$42/mo', img: '\$150-300/mo', cigna: '\$300-450/mo' },
  { profile: 'Couple', safetywing: '\$84/mo', img: '\$280-550/mo', cigna: '\$550-850/mo' },
  { profile: 'Family (2 adults, 2 kids)', safetywing: '\$84/mo (kids free)', img: '\$400-800/mo', cigna: '\$700-1,100/mo' },
  { profile: 'Mission org group (10+)', safetywing: 'Standard rates', img: '10-20% discount', cigna: '15-25% discount' },
];
---

<PageShell
  title="SafetyWing vs IMG vs Cigna for Missionaries | 2025 Comparison"
  description="Compare SafetyWing, IMG Global, and Cigna Global for missionaries and NGO workers. Expert analysis of remote location coverage, medical evacuation, and developing world support."
  headline="SafetyWing vs IMG vs Cigna: Missionaries & NGO Workers"
  subheadline="Complete comparison for missionaries and humanitarian workers—covering remote locations, medical evacuation, political evacuation, and developing world healthcare."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget</p>
        <p class="text-neutral-700 text-sm mb-4">Lowest cost with decent remote coverage. Best for short-term missions or budget-conscious organizations with basic needs.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 mb-3">Best for Missions</p>
        <p class="text-neutral-700 text-sm mb-4">Purpose-built missionary plans with strong evacuation and developing world expertise. Best value for mission organizations.</p>
        <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 mb-3">Most Comprehensive</p>
        <p class="text-neutral-700 text-sm mb-4">Premium coverage with unlimited evacuation and full benefits worldwide. Best for long-term workers needing comprehensive care.</p>
        <a href="/providers/cigna-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Simple Setup</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Flexible</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing offers the most affordable option for missionaries at around $42/month. Coverage extends to most countries including developing world locations. The subscription model works well for missions with uncertain timelines—no long-term commitment required. Children under 10 are covered free with a parent.</p>

    <p class="text-neutral-700 mb-4">The tradeoff is coverage depth. Medical evacuation is capped at $100,000 (sufficient for many situations but not all), and there is no political evacuation coverage. Mental health support is limited. For short-term missions or as supplemental coverage, SafetyWing provides good basic protection at minimal cost.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Missionary Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest monthly cost</li>
          <li>• Kids under 10 free</li>
          <li>• Flexible subscription</li>
          <li>• Remote locations covered</li>
          <li>• Easy to set up</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• \$100K evacuation cap</li>
          <li>• No political evacuation</li>
          <li>• Limited mental health</li>
          <li>• Basic preventive care</li>
          <li>• No group discounts</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Mission Specialist</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Strong Evacuation</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Group Rates</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global has long served the missionary community with purpose-built plans. Medical evacuation limits of $500,000+ handle even complex situations from remote locations. Political evacuation coverage protects against civil unrest or security threats. Group rates for mission organizations (10+ members) provide 10-20% savings.</p>

    <p class="text-neutral-700 mb-4">Developing world expertise sets IMG apart—they understand the healthcare realities in Africa, Southeast Asia, and Latin America. Pre-trip consultations help missionaries prepare medically. Mental health coverage acknowledges the emotional challenges of mission work. For organizations sending teams abroad, IMG offers the best missionary-specific value.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Missionary Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Mission-focused plans</li>
          <li>• High evacuation limits</li>
          <li>• Political evacuation option</li>
          <li>• Group discounts available</li>
          <li>• Developing world expertise</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher than SafetyWing</li>
          <li>• Annual commitment often</li>
          <li>• Preventive care varies</li>
          <li>• Some restrictions apply</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Evac</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Full Benefits</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global provides the most comprehensive coverage for long-term missionaries and NGO workers. Unlimited medical evacuation removes any concern about complex extractions from remote areas. Political evacuation is available. Home country coverage for full years (not just visits) suits workers on furlough.</p>

    <p class="text-neutral-700 mb-4">Preventive care and mental health coverage are comprehensive—important for workers in high-stress environments. The global network provides access to quality care even in developing regions, with evacuation to major centers when local care is inadequate. Premium pricing reflects premium coverage for those who need the best protection available.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Missionary Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Unlimited evacuation</li>
          <li>• Full preventive care</li>
          <li>• Comprehensive mental health</li>
          <li>• Home country coverage</li>
          <li>• Group rates available</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premium cost</li>
          <li>• May exceed needs</li>
          <li>• Annual commitment</li>
          <li>• Complex plan options</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <CTABox
    title="Get Missionary Coverage Quotes"
    description="Compare coverage for your mission location, duration, and organizational needs."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Monthly costs for missionary and NGO worker coverage:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative for developing world coverage. Costs vary by specific countries, coverage level, and group size. Mission organizations should request group quotes for best rates.</p>
  </section>

  <section id="missionary-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Missionary Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Essential Coverages</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Medical evacuation (air ambulance)</li>
          <li>• Political/security evacuation</li>
          <li>• Remote location coverage</li>
          <li>• Tropical disease treatment</li>
          <li>• Emergency dental</li>
          <li>• Mental health support</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Valuable Add-ons</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Pre-trip medical screening</li>
          <li>• Vaccinations and prophylaxis</li>
          <li>• Security briefings</li>
          <li>• Repatriation of remains</li>
          <li>• Home country visits</li>
          <li>• Dependent coverage</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Regional Considerations</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Sub-Saharan Africa</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Malaria prophylaxis</li>
            <li>• Evacuation to South Africa</li>
            <li>• Limited local facilities</li>
            <li>• Security concerns vary</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Southeast Asia</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Good urban facilities</li>
            <li>• Rural areas challenging</li>
            <li>• Singapore/Bangkok evac</li>
            <li>• Tropical disease risk</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Latin America</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Variable healthcare quality</li>
            <li>• US evacuation option</li>
            <li>• Spanish support helpful</li>
            <li>• Security varies by area</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Budget is the primary constraint</li>
          <li>• Short-term mission (under 1 year)</li>
          <li>• Basic coverage is sufficient</li>
          <li>• Family with young children</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Mission organization sending teams</li>
          <li>• Strong evacuation coverage needed</li>
          <li>• Political risk is a concern</li>
          <li>• Best value for mission-specific needs</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Long-term assignment (multi-year)</li>
          <li>• Comprehensive coverage is essential</li>
          <li>• Mental health support is important</li>
          <li>• Home country coverage needed</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Does insurance cover medical missions and volunteer healthcare work?</h3>
        <p class="text-neutral-700">Most plans cover you as a patient but not for professional liability when providing care. Medical professionals on mission should obtain separate malpractice coverage. Standard missionary insurance covers your personal health needs, not your work activities.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about coverage in high-risk or conflict areas?</h3>
        <p class="text-neutral-700">Coverage varies significantly. Active war zones are typically excluded. Areas with travel warnings may have restrictions. Political evacuation coverage helps if situations deteriorate. Always verify specific country coverage before deploying to high-risk areas.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does medical evacuation from remote locations work?</h3>
        <p class="text-neutral-700">Insurance coordinates evacuation via helicopter, small plane, or ground transport to the nearest appropriate facility. For serious cases, air ambulance to major regional centers (Johannesburg, Singapore, Miami) may be arranged. Available 24/7 with dedicated evacuation teams.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can our mission organization get group coverage?</h3>
        <p class="text-neutral-700">Yes, IMG and Cigna offer group rates for mission organizations with 10+ members. Discounts of 10-25% are typical. Group plans simplify administration and often include additional benefits like pre-trip screening. Contact insurers directly for organizational quotes.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Missionary and NGO coverage varies by location, activities, and organizational structure. This comparison represents typical offerings—actual coverage depends on your specific deployment. Always verify country-specific coverage, activity exclusions, and evacuation capabilities before departure.</p>
  </div>
</PageShell>
