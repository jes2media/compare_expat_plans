---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Malta Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Malta's Nomad Residence Permit. Expert analysis of Cigna Global, SafetyWing, and Allianz Care for remote workers in Malta.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "Malta DNV Acceptance", cigna: "✓ Accepted", safetywing: "✓ Accepted", allianz: "✓ Accepted" },
  { feature: "Malta Network", cigna: "Mater Dei, private clinics", safetywing: "Reimbursement", allianz: "Good coverage" },
  { feature: "Schengen Coverage", cigna: "✓ Worldwide", safetywing: "✓ Outside home country", allianz: "✓ Worldwide" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Not covered", allianz: "Moratorium option" },
  { feature: "Monthly Cost (35yo)", cigna: "$350-520", safetywing: "$69", allianz: "$300-460" },
  { feature: "Annual Maximum", cigna: "Unlimited", safetywing: "$250,000", allianz: "€1-2 million" },
  { feature: "Best For", cigna: "Comprehensive needs", safetywing: "Budget nomads", allianz: "European focus" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "$250K limit", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100K limit", allianz: "Included" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", allianz: "Optional" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Maternity", cigna: "Optional add-on", safetywing: "Limited", allianz: "Optional add-on" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "$260-400/month", safetywing: "$69/month", allianz: "$230-350/month" },
  { age: "30-35", cigna: "$330-500/month", safetywing: "$69/month", allianz: "$290-440/month" },
  { age: "40-45", cigna: "$470-720/month", safetywing: "$99/month", allianz: "$420-630/month" },
  { age: "50-55", cigna: "$680-1,040/month", safetywing: "$148/month", allianz: "$600-900/month" },
];

const networkColumns = [
  { key: "location", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { location: "Malta (Mater Dei)", cigna: "Direct billing available", safetywing: "Reimbursement", allianz: "Direct billing" },
  { location: "Private Clinics Malta", cigna: "Good coverage", safetywing: "Reimbursement", allianz: "Good coverage" },
  { location: "Sicily (nearby Italy)", cigna: "Full coverage", safetywing: "Covered", allianz: "Full coverage" },
  { location: "Schengen Zone", cigna: "Worldwide", safetywing: "Covered", allianz: "Worldwide" },
  { location: "UK (common travel)", cigna: "Covered", safetywing: "Covered", allianz: "Covered" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Malta's Nomad Residence Permit"
    heroImage="/images/countries/malta-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Malta Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Malta's Nomad Residence Permit allows remote workers to live in this EU island nation for up to one year (renewable for 2 more years). Malta offers English as an official language, Mediterranean lifestyle, EU membership, and favorable tax treatment.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for visa application</li>
          <li>• Must cover medical treatment in Malta</li>
          <li>• Minimum coverage: €30,000 (Schengen standard)</li>
          <li>• Policy must cover entire stay duration</li>
          <li>• International insurance accepted</li>
          <li>• Income requirement: €2,700/month gross</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Malta has good healthcare with Mater Dei Hospital (the main public hospital) and several private clinics. As an EU member, Malta follows Schengen requirements. For complex cases, Sicily (Italy) is a short ferry ride away with larger hospitals.
      </p>

      <p class="text-neutral-700">
        The visa is valid for 1 year and renewable up to 3 years total. Malta's small size means you're never far from medical facilities. English is widely spoken, making healthcare access straightforward.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Malta DNV</h2>

      <p class="text-neutral-700 mb-6">
        Malta accepts various international insurers. Here are the top options:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive international coverage that works well for Malta-based nomads who travel throughout Europe and beyond.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Worldwide coverage including Schengen</li>
            <li>• Direct billing at Malta facilities</li>
            <li>• Exceeds €30,000 requirement</li>
            <li>• Pre-existing condition options</li>
            <li>• 24/7 English support</li>
            <li>• Portable throughout EU travel</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Higher cost than SafetyWing</li>
            <li>• May be more than needed for healthy nomads</li>
            <li>• Malta healthcare is affordable anyway</li>
            <li>• Deductibles can be significant</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive global coverage for Malta digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing Nomad Insurance</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing is popular among digital nomads for its affordable pricing. At $69/month, it exceeds Malta's €30,000 minimum requirement and covers Schengen travel.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable ($69/month under 40)</li>
            <li>• Exceeds €30,000 minimum ($250K coverage)</li>
            <li>• Accepted for Malta visa applications</li>
            <li>• Covers Schengen travel</li>
            <li>• Month-to-month flexibility</li>
            <li>• Popular in nomad community</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No direct billing—pay and claim</li>
            <li>• Pre-existing conditions not covered</li>
            <li>• $250 deductible per incident</li>
            <li>• Limited outpatient coverage</li>
            <li>• Not suitable for those with health conditions</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget nomad insurance starting at $69/month."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers European-focused international coverage with strong EU networks. Their plans work well for nomads spending most time in Europe.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong European network</li>
            <li>• Direct billing in EU</li>
            <li>• Pre-existing condition options</li>
            <li>• Multiple plan tiers</li>
            <li>• European-based support</li>
            <li>• Good for EU-focused lifestyle</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Less competitive outside Europe</li>
            <li>• Similar pricing to Cigna</li>
            <li>• Claims can take time</li>
            <li>• Plan complexity</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="European-focused coverage with strong EU networks."
        buttonText="Get Quote"
        buttonHref="/go/allianz-care"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares across the main options:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        All three options exceed Malta's €30,000 minimum. The difference is in coverage depth and pricing. SafetyWing covers basics affordably; Cigna and Allianz provide comprehensive protection.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically cheaper than comprehensive options:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing's flat-rate pricing makes it attractive for younger nomads. Cigna and Allianz cost more but provide significantly better coverage for those who need it.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Malta and Europe</h2>

      <p class="text-neutral-700 mb-6">
        Malta is small but has good healthcare. Sicily is nearby for more options:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Mater Dei is Malta's main hospital. Private clinics offer faster service. For specialized care, Sicily (90-minute ferry) or other EU countries are accessible with your Schengen-compliant insurance.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Remote Worker</h3>
          <p class="text-neutral-600 mb-3">28-year-old software developer, healthy, enjoying Malta's lifestyle.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">SafetyWing meets visa requirements at $69/month and covers your Schengen travel. Malta healthcare is affordable out-of-pocket for routine care. Save the premium difference.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Frequent EU Traveler</h3>
          <p class="text-neutral-600 mb-3">35-year-old consultant, Malta base but travels to EU cities monthly.</p>
          <p class="text-green-700 font-medium">Recommendation: Allianz Care</p>
          <p class="text-neutral-600 text-sm">Allianz's European network shines for frequent EU travelers. Direct billing in major EU cities, comprehensive coverage, and European-based support suit your mobile lifestyle.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Family Relocating to Malta</h3>
          <p class="text-neutral-600 mb-3">40-year-old couple with young child, seeking EU base.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global family plan</p>
          <p class="text-neutral-600 text-sm">Families need comprehensive pediatric coverage. Cigna's family plans cover children well and provide worldwide protection. Worth the premium for family peace of mind.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Pre-existing Health Condition</h3>
          <p class="text-neutral-600 mb-3">45-year-old with managed chronic condition.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global with moratorium</p>
          <p class="text-neutral-600 text-sm">SafetyWing won't cover pre-existing conditions. Cigna's moratorium option covers after waiting period (typically 2 years). Budget for out-of-pocket during the wait period.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Tax-Motivated Relocation</h3>
          <p class="text-neutral-600 mb-3">38-year-old high earner attracted by Malta's tax programs.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Allianz Care</p>
          <p class="text-neutral-600 text-sm">If you're relocating for tax benefits, you likely have budget for comprehensive coverage. Cigna or Allianz provide premium protection matching your financial profile. Don't skimp on health insurance when optimizing taxes.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most Malta digital nomads, <strong>SafetyWing</strong> is the practical choice—affordable, meets requirements, and covers Schengen travel. <strong>Cigna Global</strong> or <strong>Allianz Care</strong> are worth the extra cost for families, those with health conditions, or anyone wanting comprehensive EU coverage.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Young and healthy</li>
            <li>• Budget-conscious</li>
            <li>• Typical nomad lifestyle</li>
            <li>• No pre-existing conditions</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Family with children</li>
            <li>• Pre-existing conditions</li>
            <li>• Want comprehensive coverage</li>
            <li>• Prefer direct billing</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz Care If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Frequent EU travel</li>
            <li>• Prefer European insurer</li>
            <li>• Strong EU network priority</li>
            <li>• European-based support</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What documents do I need for Malta visa insurance?</h3>
          <p class="text-neutral-600">You need proof of health insurance with minimum €30,000 coverage covering Malta and emergency repatriation. Most insurers provide a certificate letter. SafetyWing, Cigna, and Allianz all offer visa-compliant documentation.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing accepted for Malta's Nomad Residence Permit?</h3>
          <p class="text-neutral-600">Yes. SafetyWing's $250,000 coverage exceeds Malta's €30,000 minimum. Many nomads successfully use SafetyWing for Malta applications. Request a visa letter from SafetyWing if needed.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How is Malta's healthcare system?</h3>
          <p class="text-neutral-600">Malta has good healthcare. Mater Dei Hospital is the main public facility—modern and well-equipped. Private clinics offer faster service. English is an official language, so communication is easy. For highly specialized care, Italy is nearby.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I access Malta's public healthcare?</h3>
          <p class="text-neutral-600">As a nomad visa holder, you don't automatically qualify for Malta's public healthcare. Private insurance is required. However, emergency care is available to everyone. Most nomads use private clinics for routine care.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about dental care in Malta?</h3>
          <p class="text-neutral-600">Dental care in Malta is good and affordable by Western European standards. Most insurance covers emergency dental only. Many nomads pay out-of-pocket for routine dental—cleanings cost €50-80, extractions €80-150.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I travel the Schengen zone with my Malta insurance?</h3>
          <p class="text-neutral-600">Yes. Malta is in the Schengen zone, and your insurance must cover Schengen travel anyway. SafetyWing, Cigna, and Allianz all cover you throughout the 27 Schengen countries. Perfect for nomads exploring Europe from Malta.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Malta visa requirements can change. Verify current Nomad Residence Permit requirements with Residency Malta Agency. Confirm policy details and visa compliance directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
