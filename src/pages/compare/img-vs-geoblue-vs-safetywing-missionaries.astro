---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'geoblue', text: 'GeoBlue', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'missionary-needs', text: 'Missionary Work Needs', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/compare/cigna-vs-msh-vs-img-humanitarian', text: 'Humanitarian Worker Insurance' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/guides/international-health-insurance-101', text: 'Insurance 101' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'img', header: 'IMG Global' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mainComparisonRows = [
  { feature: 'Minimum Duration', img: '5 days', geoblue: '15 days', safetywing: '1 month' },
  { feature: 'Maximum Duration', img: '3 years', geoblue: '1 year', safetywing: 'Unlimited' },
  { feature: 'Group/Church Plans', img: 'Yes', geoblue: 'Yes', safetywing: 'Limited' },
  { feature: 'Emergency Evacuation', img: 'Up to $500K', geoblue: 'Up to $500K', safetywing: '$100K' },
  { feature: 'Pre-existing Conditions', img: 'Limited coverage', geoblue: 'Excluded short-term', safetywing: 'Acute onset only' },
  { feature: 'Family Coverage', img: 'Yes', geoblue: 'Yes', safetywing: 'Yes (kids free)' },
  { feature: 'Mental Health', img: 'Limited', geoblue: 'Good', safetywing: 'Basic' },
  { feature: 'Prescription Coverage', img: 'Included', geoblue: 'Included', safetywing: 'Emergency only' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'img', header: 'IMG Global' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const pricingRows = [
  { profile: 'Individual (30, 6 months)', img: '$120-180/mo', geoblue: '$150-220/mo', safetywing: '$42-56/mo' },
  { profile: 'Couple (35s, 1 year)', img: '$220-320/mo', geoblue: '$280-380/mo', safetywing: '$84-112/mo' },
  { profile: 'Family (2 adults + 2 kids)', img: '$350-480/mo', geoblue: '$420-550/mo', safetywing: '$84-112/mo' },
  { profile: 'Short mission (2 weeks)', img: '$80-120 total', geoblue: '$100-150 total', safetywing: 'N/A (1 mo min)' },
];
---

<PageShell
  title="IMG vs GeoBlue vs SafetyWing for Missionaries | 2025 Comparison"
  description="Compare IMG Global, GeoBlue, and SafetyWing for missionaries and mission trips. Expert analysis of short-term coverage, group plans, and family options for 2025."
  headline="IMG vs GeoBlue vs SafetyWing: Best Insurance for Missionaries"
  subheadline="Complete comparison of three leading providers for missionaries, church mission trips, and long-term religious workers abroad."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">IMG Global</h3>
        <p class="text-primary-700 mb-3">Best for Short-Term Missions</p>
        <p class="text-neutral-700 text-sm mb-4">Most flexible duration options (5 days to 3 years) with excellent group plans for church mission trips.</p>
        <a href="/providers/img-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">GeoBlue</h3>
        <p class="text-purple-700 mb-3">Best Coverage Quality</p>
        <p class="text-neutral-700 text-sm mb-4">Highest quality coverage with Blue Cross Blue Shield network access. Best for US-based missionaries needing comprehensive care.</p>
        <a href="/get-quotes" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Get Quote</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">SafetyWing</h3>
        <p class="text-green-700 mb-3">Best Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable option with free coverage for children. Unlimited duration for long-term mission work.</p>
        <a href="/providers/safetywing" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Duration</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Group Plans</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Mission Trip Expert</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global is the go-to choice for church mission trips and short-term missionary work. With coverage starting from just 5 days, they accommodate everything from brief humanitarian missions to multi-year assignments. Their group plans make it easy to insure entire church groups traveling together.</p>

    <p class="text-neutral-700 mb-4">The online enrollment process is straightforward, and you can add or remove group members easily. IMG provides digital ID cards immediately after purchase, essential when you need to prove coverage quickly. Their 24/7 assistance line handles emergencies in multiple languages.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Missionaries</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Minimum 5-day coverage (short missions)</li>
          <li>• Excellent church group plans</li>
          <li>• Easy online group management</li>
          <li>• Strong evacuation coverage ($500K)</li>
          <li>• Covers up to age 84</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited pre-existing condition coverage</li>
          <li>• Basic mental health benefits</li>
          <li>• Higher premiums than SafetyWing</li>
          <li>• 3-year maximum duration</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="geoblue" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">GeoBlue</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">BCBS Network</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Quality Coverage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">US-Based Missionaries</span>
    </div>

    <p class="text-neutral-700 mb-4">GeoBlue, backed by Blue Cross Blue Shield, offers the highest quality coverage for missionaries. Their global network includes carefully vetted providers, and US-based missionaries benefit from seamless BCBS network access when returning home between assignments.</p>

    <p class="text-neutral-700 mb-4">The GeoBlue app provides real-time access to nearby providers, translation services, and direct claims submission. Mental health coverage is notably better than competitors, important for missionaries facing isolation, culture shock, and the psychological demands of field work.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Missionaries</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Blue Cross Blue Shield backing</li>
          <li>• Highest quality provider network</li>
          <li>• Better mental health coverage</li>
          <li>• Excellent US coverage for home visits</li>
          <li>• Strong prescription drug benefits</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher premiums than alternatives</li>
          <li>• 15-day minimum (no ultra-short trips)</li>
          <li>• 1-year maximum requires renewal</li>
          <li>• Pre-existing conditions excluded</li>
        </ul>
      </div>
    </div>

    <a href="/get-quotes" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get GeoBlue Quote</a>
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Kids Free</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Duration</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing offers by far the most affordable option for missionaries, with the added benefit of free coverage for children under 10. Their subscription model with unlimited duration makes them ideal for long-term missionary families who don't know when they'll return.</p>

    <p class="text-neutral-700 mb-4">Coverage is basic but adequate for healthy missionaries without pre-existing conditions. The automatic monthly billing eliminates the hassle of renewals, and you can cancel anytime. SafetyWing is particularly popular among younger missionaries and those serving with smaller organizations on tight budgets.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Missionaries</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest premiums by far</li>
          <li>• Children under 10 covered free</li>
          <li>• Unlimited duration (no renewals)</li>
          <li>• Simple subscription billing</li>
          <li>• Good for long-term mission work</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• 1-month minimum (no short trips)</li>
          <li>• Lower evacuation limits ($100K)</li>
          <li>• Emergency prescriptions only</li>
          <li>• Basic mental health coverage</li>
          <li>• No group plan options</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <CTABox
    title="Compare Missionary Insurance Quotes"
    description="Get personalized quotes from providers experienced in missionary and religious worker coverage."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Missionary insurance pricing varies by age, destination, and coverage level. SafetyWing's family pricing is particularly attractive:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*SafetyWing family pricing includes free coverage for children under 10. IMG and GeoBlue charge per person.</p>
  </section>

  <section id="missionary-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Missionary Work Needs</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Short-Term Missions</h3>
        <p class="text-neutral-700 text-sm mb-4">For 1-2 week church mission trips:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>IMG:</strong> Best choice—5-day minimum, easy group enrollment</li>
          <li>• <strong>GeoBlue:</strong> Good option—15-day minimum, higher quality</li>
          <li>• <strong>SafetyWing:</strong> Not suitable—1-month minimum</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Long-Term Missions</h3>
        <p class="text-neutral-700 text-sm mb-4">For 2+ year missionary assignments:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>IMG:</strong> Up to 3 years, renewable</li>
          <li>• <strong>GeoBlue:</strong> Annual renewal required</li>
          <li>• <strong>SafetyWing:</strong> Unlimited duration, no renewals needed</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Family Missionary Coverage</h3>
      <p class="text-blue-700 mb-4">Important considerations for missionary families:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">IMG</h4>
          <p class="text-blue-700 text-sm">Per-person pricing. Good coverage for children including routine care. Strong pediatric network globally.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">GeoBlue</h4>
          <p class="text-blue-700 text-sm">Per-person pricing. Excellent pediatric coverage with BCBS network access for US visits.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">SafetyWing</h4>
          <p class="text-blue-700 text-sm">Children under 10 FREE (up to 2 per adult). Major cost savings for missionary families.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Your church is organizing a short-term mission trip</li>
          <li>• You need flexible duration (5 days to 3 years)</li>
          <li>• Group enrollment and management is important</li>
          <li>• You want strong emergency evacuation coverage</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose GeoBlue if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Quality of coverage is your top priority</li>
          <li>• You're a US-based missionary who returns home regularly</li>
          <li>• Mental health support is important to you</li>
          <li>• You want Blue Cross Blue Shield network access</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is your primary concern</li>
          <li>• You have young children (free coverage under 10)</li>
          <li>• You're serving long-term with no defined end date</li>
          <li>• You prefer simple, automatic monthly billing</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Does my sending organization provide insurance?</h3>
        <p class="text-neutral-700">Many mission organizations and denominations provide group insurance for their missionaries. Check with your sending organization first—their coverage may be comprehensive. If not provided or if you need supplemental coverage, these individual options work well alongside organizational plans.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are pre-existing conditions covered?</h3>
        <p class="text-neutral-700">Coverage is limited for all three providers. IMG offers some acute onset coverage for pre-existing conditions. GeoBlue excludes them on short-term plans. SafetyWing only covers acute onset emergencies. If you have significant pre-existing conditions, consider Cigna Global or MSH for more comprehensive coverage.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about coverage for dangerous activities?</h3>
        <p class="text-neutral-700">Standard missionary work is covered by all three providers. However, activities like construction work, diving, or mountain climbing may have exclusions or require add-ons. Review policy exclusions carefully if your mission involves physical labor or adventure activities.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How do I add group members for a church trip?</h3>
        <p class="text-neutral-700">IMG makes group enrollment easiest with online management tools. A group leader can add/remove members, and everyone can be enrolled with one application. GeoBlue also offers group plans but requires more coordination. SafetyWing doesn't offer true group plans—each person enrolls individually.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. The information provided is based on publicly available data and may not reflect current offerings. Always verify details directly with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
