---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Hungary White Card (2025)";
const description = "Compare top health insurance options for Hungary's White Card digital nomad visa. Expert analysis of Cigna Global, SafetyWing, and Allianz for remote workers in Budapest.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "White Card Acceptance", cigna: "✓ Accepted", safetywing: "✓ Accepted", allianz: "✓ Accepted" },
  { feature: "Hungary Network", cigna: "Good (private hospitals)", safetywing: "Reimbursement", allianz: "Good (private hospitals)" },
  { feature: "Schengen Coverage", cigna: "✓ Worldwide", safetywing: "✓ Outside home country", allianz: "✓ Worldwide" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Not covered", allianz: "Moratorium option" },
  { feature: "Monthly Cost (35yo)", cigna: "$350-500", safetywing: "$69", allianz: "$300-450" },
  { feature: "Annual Maximum", cigna: "Unlimited", safetywing: "$250,000", allianz: "€1-2 million" },
  { feature: "Best For", cigna: "Comprehensive needs", safetywing: "Budget nomads", allianz: "European focus" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "$250K limit", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100K limit", allianz: "Included" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", allianz: "Optional" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Pregnancy", cigna: "Optional add-on", safetywing: "Limited maternity", allianz: "Optional add-on" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "$250-380/month", safetywing: "$69/month", allianz: "$220-340/month" },
  { age: "30-35", cigna: "$320-480/month", safetywing: "$69/month", allianz: "$280-420/month" },
  { age: "40-45", cigna: "$450-680/month", safetywing: "$99/month", allianz: "$400-600/month" },
  { age: "50-55", cigna: "$650-980/month", safetywing: "$148/month", allianz: "$580-870/month" },
];

const networkColumns = [
  { key: "location", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { location: "Budapest Private", cigna: "FirstMed, Rózsákert", safetywing: "Reimbursement", allianz: "FirstMed, Rózsákert" },
  { location: "Budapest Public", cigna: "Reimbursement", safetywing: "Reimbursement", allianz: "Reimbursement" },
  { location: "Other Hungarian Cities", cigna: "Limited direct billing", safetywing: "Reimbursement", allianz: "Limited direct billing" },
  { location: "Vienna (2hr away)", cigna: "Full access", safetywing: "Covered", allianz: "Full access" },
  { location: "Schengen Zone", cigna: "Worldwide", safetywing: "Covered", allianz: "Worldwide" },
  { location: "Home Country", cigna: "Plan-dependent", safetywing: "Limited coverage", allianz: "Plan-dependent" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Hungary's White Card digital nomad visa"
    heroImage="/images/countries/hungary-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Hungary White Card Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Hungary's White Card is a digital nomad visa allowing remote workers to live in Hungary (and travel the Schengen zone) for up to one year, renewable once. Budapest has become increasingly popular with digital nomads for its low cost of living, excellent internet, and vibrant expat community.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for visa application</li>
          <li>• Minimum coverage: €30,000 (Schengen standard)</li>
          <li>• Must cover medical treatment and emergency repatriation</li>
          <li>• Policy must be valid for entire stay period</li>
          <li>• International insurance accepted (unlike Czech Republic)</li>
          <li>• Income requirement: ~€2,000/month minimum</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Unlike the Czech Zivno visa, Hungary accepts international health insurance for the White Card. This gives you more flexibility to use global insurers like Cigna, SafetyWing, or Allianz. The €30,000 minimum is the standard Schengen requirement.
      </p>

      <p class="text-neutral-700">
        Hungary has good private healthcare in Budapest (FirstMed is the primary expat clinic) and access to excellent care in Vienna, just 2.5 hours away. The public healthcare system is functional but can involve language barriers and longer waits.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for White Card</h2>

      <p class="text-neutral-700 mb-6">
        White Card holders can choose from various international insurers. Here are the top options:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global offers comprehensive international coverage that works well for digital nomads who want premium protection and may travel frequently within Europe and beyond.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Worldwide coverage including Schengen</li>
            <li>• Direct billing at FirstMed Budapest</li>
            <li>• Vienna hospital access (2hr from Budapest)</li>
            <li>• Pre-existing condition options</li>
            <li>• Comprehensive outpatient coverage</li>
            <li>• 24/7 multilingual support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Higher cost than SafetyWing</li>
            <li>• May be more than needed for healthy nomads</li>
            <li>• Limited direct billing in smaller Hungarian cities</li>
            <li>• Deductibles can be significant</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive global coverage for digital nomads in Hungary."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing Nomad Insurance</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing is the budget-friendly choice popular among digital nomads. At $69/month, it easily meets the €30,000 Schengen minimum requirement and works well for the White Card.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable ($69/month under 40)</li>
            <li>• Exceeds €30,000 minimum ($250K coverage)</li>
            <li>• Accepted for White Card applications</li>
            <li>• Covers Schengen travel</li>
            <li>• Month-to-month flexibility</li>
            <li>• Popular in nomad community</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No direct billing—pay and claim</li>
            <li>• Pre-existing conditions not covered</li>
            <li>• $250 deductible per incident</li>
            <li>• Limited outpatient coverage</li>
            <li>• Not suitable for those with health conditions</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget nomad insurance starting at $69/month."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers European-focused international coverage with strong networks across the EU. Their plans are well-suited for nomads who spend most of their time in Europe.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong European network</li>
            <li>• Direct billing available</li>
            <li>• Pre-existing condition options</li>
            <li>• Vienna and Munich access excellent</li>
            <li>• Multiple plan tiers</li>
            <li>• European-based support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Less competitive outside Europe</li>
            <li>• Similar pricing to Cigna</li>
            <li>• Hungarian network still limited</li>
            <li>• Claims can take time</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="European-focused coverage with strong EU networks."
        buttonText="Get Quote"
        buttonHref="/go/allianz"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares across the main options:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        All three options exceed Hungary's €30,000 minimum requirement. The difference is in coverage depth—Cigna and Allianz provide more comprehensive protection, while SafetyWing covers the basics at a lower price.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically cheaper than comprehensive options:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing's flat-rate pricing makes it attractive for younger nomads. Cigna and Allianz cost more but provide significantly better coverage for those who need it.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Hungary and Europe</h2>

      <p class="text-neutral-700 mb-6">
        Budapest has good private healthcare, and Vienna is easily accessible for specialized care:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        FirstMed in Budapest is the primary expat clinic and accepts most international insurers for direct billing. For serious conditions, Vienna is 2.5 hours by train and has world-class hospitals.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Remote Worker in Budapest</h3>
          <p class="text-neutral-600 mb-3">27-year-old software developer, healthy, enjoys Budapest's low cost of living.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">At $69/month, SafetyWing meets visa requirements and provides adequate coverage. Young, healthy nomads rarely need comprehensive plans. Save the premium difference for other expenses in affordable Budapest.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Frequent Europe Traveler</h3>
          <p class="text-neutral-600 mb-3">35-year-old consultant, Budapest base but travels to EU cities monthly.</p>
          <p class="text-green-700 font-medium">Recommendation: Allianz Care</p>
          <p class="text-neutral-600 text-sm">Allianz's European network shines for frequent EU travelers. Direct billing in major European cities, comprehensive coverage, and European-based support make it ideal for this lifestyle.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Family with Children</h3>
          <p class="text-neutral-600 mb-3">38-year-old couple with young child, working remotely from Budapest.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global family plan</p>
          <p class="text-neutral-600 text-sm">Families need comprehensive pediatric coverage. Cigna's family plans cover children well, and direct billing at FirstMed makes sick visits easy. Vienna is accessible for any specialist pediatric needs.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Pre-existing Health Condition</h3>
          <p class="text-neutral-600 mb-3">42-year-old with managed chronic condition, needs regular specialist visits.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global with moratorium</p>
          <p class="text-neutral-600 text-sm">SafetyWing won't cover pre-existing conditions. Cigna's moratorium option covers after a waiting period (typically 2 years). Budget for out-of-pocket during the wait period. Vienna access is valuable for specialist care.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Short-term Stay (6 months)</h3>
          <p class="text-neutral-600 mb-3">30-year-old trying Budapest for 6 months before deciding on permanent base.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">For a trial period, SafetyWing's month-to-month flexibility is perfect. No annual commitment, easy to continue or cancel. If you decide to stay long-term, you can upgrade to comprehensive coverage later.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most White Card holders, <strong>SafetyWing</strong> is the practical choice—affordable, meets requirements, and suits the digital nomad lifestyle. <strong>Cigna Global</strong> or <strong>Allianz Care</strong> are worth the extra cost for families, those with health conditions, or anyone wanting comprehensive coverage with direct billing.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Young and healthy</li>
            <li>• Budget-conscious</li>
            <li>• Flexible nomad lifestyle</li>
            <li>• No pre-existing conditions</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Family with children</li>
            <li>• Pre-existing conditions</li>
            <li>• Want comprehensive coverage</li>
            <li>• Prefer direct billing</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz Care If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Frequent EU travel</li>
            <li>• Prefer European insurer</li>
            <li>• Strong EU network priority</li>
            <li>• Vienna/Munich access important</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What insurance documents do I need for the White Card?</h3>
          <p class="text-neutral-600">You need proof of health insurance with minimum €30,000 coverage and emergency repatriation. Most insurers provide a certificate letter for visa purposes. SafetyWing, Cigna, and Allianz all offer visa-compliant documentation.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing actually accepted for the White Card?</h3>
          <p class="text-neutral-600">Yes. Hungary accepts international insurance unlike Czech Republic. SafetyWing's $250,000 coverage exceeds the €30,000 minimum. Many nomads successfully use SafetyWing for White Card applications. Request a visa letter from SafetyWing if needed.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use Hungarian public healthcare with the White Card?</h3>
          <p class="text-neutral-600">White Card holders don't automatically qualify for Hungarian public healthcare (TAJ). However, emergency care is available to everyone. Most expats use private clinics (FirstMed) or travel to Vienna for specialized care.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What's the best clinic for expats in Budapest?</h3>
          <p class="text-neutral-600">FirstMed is the primary expat clinic in Budapest—English-speaking doctors, international standards, and direct billing with most insurers. Rózsákert Medical Center is another good option. Both handle routine care and referrals well.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Should I consider Vienna for healthcare?</h3>
          <p class="text-neutral-600">For specialized or complex care, yes. Vienna is 2.5 hours by train from Budapest and has world-class hospitals. International insurance covers Vienna. For routine care, Budapest's private clinics are sufficient and more convenient.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I renew the White Card with the same insurance?</h3>
          <p class="text-neutral-600">Yes, as long as your insurance remains valid and meets the requirements. The White Card is renewable once for another year. Simply maintain continuous coverage and provide updated proof when renewing.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Hungary visa requirements can change. Verify current White Card requirements with Hungarian immigration authorities. Confirm policy details and visa compliance directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
