---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "AXA vs Allianz vs IMG: Best International Health Insurance for the Caribbean";
const description = "Compare AXA Global Healthcare, Allianz Care, and IMG Global for expats in the Caribbean. Coverage analysis for Jamaica, Bahamas, Barbados, Trinidad, Cayman Islands, and other island nations.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Caribbean Network', axa: 'Good coverage', allianz: 'Good coverage', img: 'Moderate' },
  { feature: 'US Evacuation', axa: 'Miami/US included', allianz: 'Included', img: 'Included' },
  { feature: 'Hurricane Coverage', axa: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { feature: 'Direct Billing', axa: 'Major facilities', allianz: 'Major facilities', img: 'Limited' },
  { feature: 'Tropical Disease', axa: 'Comprehensive', allianz: 'Comprehensive', img: 'Covered' },
  { feature: 'US Coverage Option', axa: 'Available', allianz: 'Available', img: 'Available' },
  { feature: 'Starting Price', axa: '$$$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', axa: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', axa: 'Comprehensive', allianz: 'Optional/Included', img: 'Plan dependent' },
  { coverage: 'Emergency Evacuation', axa: 'To US mainland', allianz: 'To nearest facility', img: 'Included' },
  { coverage: 'Mental Health', axa: 'Comprehensive', allianz: 'Good coverage', img: 'Limited' },
  { coverage: 'Maternity', axa: '12-month wait', allianz: '12-month wait', img: 'Limited/None' },
  { coverage: 'Pre-existing Conditions', axa: 'Underwritten', allianz: 'Moratorium option', img: 'Excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Single, 35, Jamaica', axa: '$4,500-6,200/yr', allianz: '$3,800-5,200/yr', img: '$2,400-3,400/yr' },
  { profile: 'Single, 35, Cayman Islands', axa: '$5,200-7,000/yr', allianz: '$4,400-6,000/yr', img: '$2,800-3,800/yr' },
  { profile: 'Couple, 50, Bahamas', axa: '$10,000-13,500/yr', allianz: '$8,500-11,500/yr', img: '$5,500-7,500/yr' },
  { profile: 'With US coverage', axa: '+40-50%', allianz: '+35-45%', img: '+$1,500-2,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'caribbean-considerations', text: 'Caribbean Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Island Living', href: '/insurance-for/island-expats' },
  { title: 'AXA Global Review', href: '/providers/axa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-blue-800 text-sm">You want premium coverage with excellent US evacuation options, comprehensive wellness benefits, and the peace of mind that comes with a top-tier global insurer.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at a more competitive price, with good evacuation options and flexibility that works for Caribbean lifestyle needs.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're budget-conscious, relatively healthy, and want basic international coverage with evacuation benefits at the most affordable price point.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Caribbean islands present unique insurance challenges: limited local healthcare facilities, hurricane exposure, distance from major medical centers, and variable infrastructure. Medical evacuation coverage—typically to Miami or other US cities—is essential for serious conditions.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global offers premium coverage well-suited to Caribbean expats, with strong US evacuation options and comprehensive benefits. Their wellness focus and global reputation provide peace of mind for those living in remote island locations.</p>

      <h3>Strengths for Caribbean</h3>
      <ul>
        <li>Excellent medical evacuation to US mainland (typically Miami)</li>
        <li>Comprehensive coverage including tropical diseases</li>
        <li>Strong wellness and preventive care benefits</li>
        <li>Good network at major Caribbean private hospitals</li>
        <li>24/7 support for emergencies in any time zone</li>
        <li>Coverage continues during hurricane evacuations</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>12-month minimum commitment</li>
        <li>Direct billing options limited on smaller islands</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid international coverage at more moderate pricing, making them attractive for Caribbean expats who want comprehensive protection without premium costs. Their evacuation coverage and global network serve island residents well.</p>

      <h3>Strengths for Caribbean</h3>
      <ul>
        <li>More competitive pricing than AXA</li>
        <li>Reliable medical evacuation coverage</li>
        <li>Good coverage for tropical diseases and island health risks</li>
        <li>Flexible plan options for different budget levels</li>
        <li>6-month minimum allows seasonal flexibility</li>
        <li>Moratorium option for some pre-existing conditions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Network may be smaller on some islands</li>
        <li>Mental health coverage may have session limits</li>
        <li>Direct billing less extensive than AXA</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers the most affordable international coverage for Caribbean residents, with essential evacuation benefits and flexibility. Best suited for younger, healthier expats who want basic protection at minimal cost.</p>

      <h3>Strengths for Caribbean</h3>
      <ul>
        <li>Most affordable option for island coverage</li>
        <li>Flexible terms—no long-term commitment required</li>
        <li>Emergency evacuation to US mainland included</li>
        <li>Good basic coverage for hospitalizations</li>
        <li>Easy online enrollment and management</li>
        <li>Can upgrade coverage as needs evolve</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited direct billing network in Caribbean</li>
        <li>Outpatient coverage may be restricted</li>
        <li>Mental health coverage minimal</li>
        <li>Pre-existing conditions excluded</li>
        <li>May require more out-of-pocket claims</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Medical evacuation is the most critical coverage feature for Caribbean residents. All three providers include it, but comprehensiveness of other benefits varies significantly.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Caribbean premiums vary by island—wealthier territories like Cayman Islands have higher medical costs and thus higher premiums. US coverage adds significant cost but may be essential given evacuation patterns.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific island, age, health history, and coverage level. US coverage is recommended for most Caribbean residents due to evacuation needs.</p>
    </section>

    <section id="caribbean-considerations" class="mb-12">
      <h2>Caribbean Insurance Considerations</h2>

      <h3>Medical Evacuation is Essential</h3>
      <p>Most Caribbean islands lack advanced medical facilities for serious conditions. Evacuation to Miami, Houston, or other US medical centers is common for cancer treatment, cardiac care, complex surgeries, and serious trauma. All three providers cover evacuation, but verify limits and conditions.</p>

      <h3>Hurricane Season</h3>
      <p>June through November brings hurricane risk. Your insurance covers medical emergencies during and after hurricanes, and continues if you evacuate to the US or elsewhere. Verify coverage doesn't lapse if you temporarily relocate due to storm damage.</p>

      <h3>US Coverage Considerations</h3>
      <p>Many Caribbean expats travel to the US regularly or may be evacuated there for treatment. Including US coverage in your plan eliminates complications and ensures seamless care. Without it, US treatment can be prohibitively expensive.</p>

      <h3>Island-Specific Healthcare</h3>
      <p>Healthcare quality varies dramatically. Cayman Islands, Barbados, and Jamaica have better private facilities. Smaller islands may have basic clinics only. Research your specific island's healthcare capabilities and plan accordingly.</p>

      <h3>Tropical Health Risks</h3>
      <p>Dengue fever, chikungunya, Zika, and other mosquito-borne illnesses exist in the Caribbean. All three providers cover these conditions. Some islands have specific health considerations—verify coverage for your location.</p>

      <h3>Retiree Considerations</h3>
      <p>Many Caribbean expats are retirees. Age affects premiums significantly, and pre-existing conditions matter more. AXA and Allianz handle older applicants better than IMG, though at higher cost.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Affluent expats on premium islands</li>
            <li>• Retirees wanting comprehensive coverage</li>
            <li>• Those prioritizing wellness benefits</li>
            <li>• Expats with complex health needs</li>
            <li>• Those frequently traveling to the US</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-budget Caribbean expats</li>
            <li>• Working professionals on islands</li>
            <li>• Families seeking value</li>
            <li>• Those wanting flexible terms</li>
            <li>• Expats supplementing local coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Young, healthy island residents</li>
            <li>• Budget-conscious expats</li>
            <li>• Digital nomads in Caribbean</li>
            <li>• Those primarily needing evacuation</li>
            <li>• Short-term Caribbean stays</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How does medical evacuation work from Caribbean islands?</h3>
          <p class="text-neutral-700">When local facilities can't provide needed care, your insurer arranges air ambulance or medical flight to the nearest appropriate facility—typically Miami for most Caribbean islands. All three providers cover evacuation costs, which can exceed $50,000.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Am I covered during hurricane evacuations?</h3>
          <p class="text-neutral-700">Yes, your coverage continues if you evacuate due to hurricanes. Medical emergencies during and after storms are covered. If you relocate temporarily to the US or another country, verify your plan covers that region.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I include US coverage for Caribbean insurance?</h3>
          <p class="text-neutral-700">Strongly recommended. Most serious medical evacuations go to the US (primarily Miami). Without US coverage, you could face massive bills for evacuation-related treatment. The additional premium is worth the protection.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are dengue and other tropical diseases covered?</h3>
          <p class="text-neutral-700">Yes, all three providers cover tropical diseases including dengue fever, chikungunya, Zika, and other regional health risks. Treatment, hospitalization, and any necessary evacuation are included.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get direct billing at Caribbean hospitals?</h3>
          <p class="text-neutral-700">AXA and Allianz have direct billing at major private hospitals in larger islands (Jamaica, Bahamas, Barbados, Caymans). Smaller islands may require upfront payment and reimbursement. IMG has more limited direct billing.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What if I'm on a small island with limited healthcare?</h3>
          <p class="text-neutral-700">Medical evacuation coverage becomes even more critical. All three providers will evacuate you to appropriate facilities when local care is insufficient. Consider plans with comprehensive evacuation benefits and pre-positioning in larger islands for planned procedures.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
