---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Allianz vs SafetyWing vs IMG: Best International Health Insurance for Writers & Journalists";
const description = "Compare Allianz Care, SafetyWing, and IMG Global for writers, journalists, and authors working abroad. Coverage analysis for freelance writers with variable income and location flexibility needs.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Monthly Flexibility', allianz: '6-month minimum', safetywing: 'Monthly subscription', img: 'Flexible terms' },
  { feature: 'Variable Income Friendly', allianz: 'Fixed annual/monthly', safetywing: 'Very flexible', img: 'Flexible' },
  { feature: 'Mental Health Coverage', allianz: 'Good', safetywing: 'Limited', img: 'Limited' },
  { feature: 'Global Mobility', allianz: 'Worldwide options', safetywing: 'Built-in global', img: 'Worldwide options' },
  { feature: 'RSI/Ergonomic Issues', allianz: 'Comprehensive', safetywing: 'Emergency only', img: 'Plan dependent' },
  { feature: 'Comprehensive Health', allianz: 'Full coverage', safetywing: 'Basic', img: 'Good' },
  { feature: 'Starting Price', allianz: '$$-$$$', safetywing: '$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', allianz: 'Full coverage', safetywing: 'Up to $250K', img: 'Full coverage' },
  { coverage: 'Outpatient', allianz: 'Comprehensive', safetywing: 'Emergency only', img: 'Plan dependent' },
  { coverage: 'Mental Health', allianz: 'Annual limits', safetywing: 'Limited', img: 'Limited' },
  { coverage: 'Vision Care', allianz: 'Optional add-on', safetywing: 'Emergency only', img: 'Optional' },
  { coverage: 'Preventive Care', allianz: 'Available', safetywing: 'Not included', img: 'Basic' },
  { coverage: 'Pre-existing Conditions', allianz: 'Moratorium option', safetywing: 'Excluded', img: 'Excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Freelance writer, 30', allianz: '$2,400-3,400/yr', safetywing: '$550-700/yr', img: '$1,400-2,000/yr' },
  { profile: 'Journalist, 38', allianz: '$3,200-4,500/yr', safetywing: '$700-900/yr', img: '$1,800-2,600/yr' },
  { profile: 'Author, 45', allianz: '$4,200-5,800/yr', safetywing: '$900-1,200/yr', img: '$2,400-3,400/yr' },
  { profile: 'Writer + spouse, 40', allianz: '$5,800-8,000/yr', safetywing: '$1,400-1,800/yr', img: '$3,200-4,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'writer-considerations', text: 'Writer & Journalist Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Freelancers', href: '/insurance-for/freelancers' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-blue-800 text-sm">You're an established writer with steady income who wants comprehensive coverage including mental health support and outpatient care for writing-related health issues.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-green-800 text-sm">You're a young freelance writer with variable income who values monthly flexibility and can accept basic coverage while building your career.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You want a middle ground—better coverage than SafetyWing at moderate cost, with flexibility that works for freelance journalism and writing careers.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Writers and journalists face unique insurance challenges: irregular income from freelance work, location flexibility requirements, mental health needs from deadline stress, and physical issues from sedentary computer work. These three providers offer different approaches to serving writing professionals abroad.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides comprehensive coverage suitable for established writers and journalists who want full health protection. Their mental health coverage and outpatient benefits address the specific health challenges writers face.</p>

      <h3>Strengths for Writers</h3>
      <ul>
        <li>Comprehensive outpatient coverage for RSI, back pain, eye strain</li>
        <li>Mental health coverage for deadline stress and burnout</li>
        <li>Vision care available as add-on for screen-intensive work</li>
        <li>Global network for internationally mobile writers</li>
        <li>Monthly payment options to help cash flow</li>
        <li>Moratorium option for some pre-existing conditions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>6-month minimum commitment</li>
        <li>Higher cost than budget alternatives</li>
        <li>May be more than needed for young, healthy writers</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing has become popular among freelance writers and digital nomad journalists for its affordability and flexibility. The monthly subscription model aligns well with variable freelance income, though coverage is more limited.</p>

      <h3>Strengths for Writers</h3>
      <ul>
        <li>Monthly subscription—cancel or adjust anytime</li>
        <li>Affordable for writers with variable income</li>
        <li>Global coverage built-in for nomadic writers</li>
        <li>Simple signup in minutes</li>
        <li>Popular in writing/journalism communities</li>
        <li>Good emergency and hospitalization coverage</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>$250K annual limit may concern some</li>
        <li>Limited mental health coverage—significant gap for writers</li>
        <li>Outpatient coverage emergency-only—no RSI/ergonomic treatment</li>
        <li>No vision care for screen-intensive work</li>
        <li>Pre-existing conditions excluded</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers a middle ground for writers—better coverage than SafetyWing at moderate cost, with flexibility that works for freelance careers. Their plans bridge the gap between basic and comprehensive coverage.</p>

      <h3>Strengths for Writers</h3>
      <ul>
        <li>Moderate pricing between SafetyWing and Allianz</li>
        <li>Flexible terms matching freelance work patterns</li>
        <li>Good hospitalization and emergency coverage</li>
        <li>International coverage for mobile writers</li>
        <li>Easy enrollment and management</li>
        <li>Option to upgrade as writing career grows</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Outpatient coverage may have limitations</li>
        <li>Mental health coverage not comprehensive</li>
        <li>Pre-existing conditions excluded</li>
        <li>May need to supplement for specific needs</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Writers should pay attention to outpatient coverage (for RSI and ergonomic issues), mental health (for stress and burnout), and vision care (for screen-intensive work). Allianz is strongest here; SafetyWing and IMG have gaps.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>The pricing range is substantial—SafetyWing costs roughly 20-25% of Allianz. The question is whether budget savings justify coverage limitations for your specific health needs and writing career stage.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by age, location, health history, and coverage level. Consider mental health and outpatient needs when comparing value.</p>
    </section>

    <section id="writer-considerations" class="mb-12">
      <h2>Writer & Journalist Considerations</h2>

      <h3>Variable Freelance Income</h3>
      <p>Freelance writing income fluctuates with assignments and publications. SafetyWing's monthly model accommodates this best—you can adjust during lean months. Allianz's monthly payment option helps, but the 6-month minimum requires planning. IMG offers moderate flexibility.</p>

      <h3>Mental Health is Critical</h3>
      <p>Writing and journalism involve deadline pressure, rejection, isolation, and irregular schedules—all stress factors. Depression and anxiety are common in the profession. Allianz's mental health coverage provides therapy access. SafetyWing and IMG's limited mental health benefits may leave gaps.</p>

      <h3>Ergonomic and RSI Issues</h3>
      <p>Writers commonly develop carpal tunnel, back pain, neck strain, and eye problems from prolonged computer work. Allianz's comprehensive outpatient coverage includes physiotherapy and specialist care. SafetyWing's emergency-only outpatient coverage doesn't address ongoing ergonomic health needs.</p>

      <h3>Vision Care</h3>
      <p>Screen-intensive work strains eyes. Regular eye exams and updated prescriptions matter for writing productivity. Allianz offers vision care add-ons. SafetyWing and IMG cover only emergency eye issues, not routine vision care.</p>

      <h3>Location Flexibility</h3>
      <p>Many writers work from multiple countries. All three providers support global mobility, but SafetyWing is specifically built for nomadic work patterns. Allianz and IMG accommodate moves with regional coverage options.</p>

      <h3>Journalist-Specific Risks</h3>
      <p>Foreign correspondents and investigative journalists may face additional risks. Standard health insurance covers medical emergencies anywhere, but conflict zone coverage may have limitations. Verify coverage for your reporting destinations.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Established authors with steady income</li>
            <li>• Writers prioritizing mental health</li>
            <li>• Those with RSI or ergonomic issues</li>
            <li>• Staff journalists at publications</li>
            <li>• Writers wanting comprehensive coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Young freelance writers</li>
            <li>• Bloggers and content creators</li>
            <li>• Writers with variable income</li>
            <li>• Digital nomad journalists</li>
            <li>• Budget-conscious writers</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-career freelance writers</li>
            <li>• Journalists seeking moderate coverage</li>
            <li>• Writers wanting value balance</li>
            <li>• Those building writing careers</li>
            <li>• Travel writers and correspondents</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is SafetyWing's mental health coverage adequate for writers?</h3>
          <p class="text-neutral-700">SafetyWing covers acute psychiatric emergencies but not ongoing therapy. Given writing's stress and isolation, this gap can be significant. If you have mental health needs, budget for Allianz or supplement SafetyWing with out-of-pocket therapy costs.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does insurance cover carpal tunnel and RSI for writers?</h3>
          <p class="text-neutral-700">Allianz's comprehensive outpatient coverage includes treatment for carpal tunnel, RSI, and ergonomic injuries—physiotherapy, specialist consultations, and ongoing care. SafetyWing's emergency-only outpatient coverage typically doesn't cover these chronic/recurring conditions.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How do I handle insurance during months with low writing income?</h3>
          <p class="text-neutral-700">SafetyWing's monthly subscription lets you maintain coverage affordably during lean periods. For Allianz or IMG, budget throughout the year or set aside funds during good months. Consider insurance a necessary business expense for your writing career.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is there coverage for journalists in conflict zones?</h3>
          <p class="text-neutral-700">Standard international health insurance covers medical emergencies globally, but some policies exclude certain high-risk countries or situations. If you're covering conflict or high-risk stories, verify coverage for specific destinations and consider specialized journalist insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get vision coverage for screen-related eye strain?</h3>
          <p class="text-neutral-700">Allianz offers optional vision care coverage including eye exams and glasses. SafetyWing and IMG cover only emergency eye conditions, not routine vision care. Budget for out-of-pocket eye care or add Allianz's vision option.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is health insurance tax-deductible for freelance writers?</h3>
          <p class="text-neutral-700">In many countries, self-employed writers can deduct health insurance premiums as a business expense. This effectively reduces the net cost of coverage. Consult a tax professional familiar with freelance/self-employment deductions in your tax residence.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
