---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'aetna-international', text: 'Aetna International', level: 2 },
  { id: 'coverage-details', text: 'Maternity Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Family Insurance Guide', href: '/insurance-for/families' },
  { title: 'Pregnancy Abroad Guide', href: '/guides/pregnancy-abroad' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'Maternity Available', cigna: 'Optional add-on', bupa: 'Optional add-on', aetna: 'Optional add-on' },
  { feature: 'Waiting Period', cigna: '12 months', bupa: '10-12 months', aetna: '12 months' },
  { feature: 'Normal Delivery', cigna: 'Up to $15K', bupa: 'Up to $20K', aetna: 'Up to $12K' },
  { feature: 'C-Section', cigna: 'Up to $25K', bupa: 'Up to $30K', aetna: 'Up to $20K' },
  { feature: 'Complications', cigna: 'Full coverage', bupa: 'Full coverage', aetna: 'Full coverage' },
  { feature: 'Prenatal Care', cigna: 'Included', bupa: 'Included', aetna: 'Included' },
  { feature: 'Newborn Coverage', cigna: '30 days auto', bupa: '30 days auto', aetna: '14 days auto' },
  { feature: 'Best For', cigna: 'Best app/service', bupa: 'Highest limits', aetna: 'US connections' },
];

const coverageColumns = [
  { key: 'benefit', header: 'Benefit' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const coverageRows = [
  { benefit: 'Prenatal visits', cigna: 'All covered', bupa: 'All covered', aetna: 'All covered' },
  { benefit: 'Ultrasounds', cigna: 'All covered', bupa: 'All covered', aetna: 'All covered' },
  { benefit: 'Lab work/screenings', cigna: 'Covered', bupa: 'Covered', aetna: 'Covered' },
  { benefit: 'Hospital stay (normal)', cigna: '2-3 days', bupa: '3-4 days', aetna: '2 days' },
  { benefit: 'Hospital stay (C-section)', cigna: '4-5 days', bupa: '5-6 days', aetna: '3-4 days' },
  { benefit: 'Epidural/anesthesia', cigna: 'Covered', bupa: 'Covered', aetna: 'Covered' },
  { benefit: 'NICU if needed', cigna: 'Covered', bupa: 'Covered', aetna: 'Covered' },
  { benefit: 'Postnatal checkups', cigna: '6-8 weeks', bupa: '6-8 weeks', aetna: '6 weeks' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Woman, Age 30 (with maternity)', cigna: '$450-650/mo', bupa: '$500-700/mo', aetna: '$400-550/mo' },
  { profile: 'Woman, Age 35 (with maternity)', cigna: '$550-750/mo', bupa: '$600-800/mo', aetna: '$480-650/mo' },
  { profile: 'Couple, Age 32 (with maternity)', cigna: '$750-1,000/mo', bupa: '$850-1,100/mo', aetna: '$680-900/mo' },
  { profile: 'Maternity add-on alone', cigna: '$150-250/mo', bupa: '$180-280/mo', aetna: '$120-200/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna: Best Maternity Coverage for Expats 2026"
  description="Compare maternity benefits from Cigna Global, Bupa Global, and Aetna International. Waiting periods, coverage limits, and what's included for pregnancy abroad."
  headline="Cigna vs Bupa vs Aetna: Maternity Coverage Compared"
  subheadline="Planning a pregnancy abroad? Here's how the three major insurers compare on maternity benefits, waiting periods, and newborn coverage."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Highest Limits</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Most generous maternity limits. Longest hospital stays covered. 10-month waiting period option.</p>
      <a href="/go/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Bupa Quote</a>
    </div>
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Service</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Best app and claims experience. Solid maternity benefits. 30-day automatic newborn coverage.</p>
      <a href="/go/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Cigna Quote</a>
    </div>
    <div class="bg-green-50 border border-green-200 rounded-lg p-5">
      <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">US Network</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Aetna International</p>
      <p class="text-sm text-neutral-600 mb-3">Best if you might deliver in the US. CVS/Aetna network. Lower limits but lower cost.</p>
      <a href="/go/aetna-international" class="inline-block w-full text-center bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Aetna Quote</a>
    </div>
  </div>

  <p>
    All three require maternity as an add-on with a waiting period—you can't buy coverage when already pregnant. Bupa offers the highest limits and most generous benefits. Cigna provides the best service and app experience. Aetna is the choice if you may deliver in the US.
  </p>

  <h2 id="comparison-table">Side-by-Side Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="cigna-global">Cigna Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Best App</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Fast Claims</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">30-Day Newborn</span>
  </div>

  <p>
    Cigna Global's maternity coverage offers solid benefits with the best digital experience for managing prenatal care, finding providers, and processing claims. Their 30-day automatic newborn coverage gives you time to add your baby to the policy properly.
  </p>

  <p><strong>Maternity strengths:</strong></p>
  <ul>
    <li>Up to $15K normal delivery, $25K C-section</li>
    <li>All prenatal care included</li>
    <li>30 days automatic newborn coverage</li>
    <li>Best app for finding maternity providers</li>
    <li>Fast claims processing</li>
    <li>Excellent direct billing network</li>
  </ul>

  <p><strong>Limitations:</strong></p>
  <ul>
    <li>12-month waiting period</li>
    <li>Lower limits than Bupa</li>
    <li>Maternity add-on required (not included)</li>
    <li>Some elective procedures excluded</li>
  </ul>

  <p><strong>Best for:</strong> Expats who want the best service experience during pregnancy. Those who value the app for managing care. Anyone who wants straightforward claims.</p>

  <div class="my-6">
    <a href="/go/cigna-global" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Cigna Quote</a>
    <a href="/providers/cigna-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="bupa-global">Bupa Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Highest Limits</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Best Coverage</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">10-Month Wait</span>
  </div>

  <p>
    Bupa Global offers the most generous maternity benefits of the three—highest coverage limits, longest hospital stays, and a potential 10-month waiting period option. If you're planning ahead and want comprehensive maternity coverage, Bupa delivers the most.
  </p>

  <p><strong>Maternity strengths:</strong></p>
  <ul>
    <li>Up to $20K normal delivery, $30K C-section</li>
    <li>Longer hospital stays covered (3-6 days)</li>
    <li>10-12 month waiting period (some plans 10)</li>
    <li>Comprehensive prenatal care</li>
    <li>30 days automatic newborn coverage</li>
    <li>Strong maternity network worldwide</li>
  </ul>

  <p><strong>Limitations:</strong></p>
  <ul>
    <li>Most expensive option</li>
    <li>Maternity add-on required</li>
    <li>Some plans have 12-month wait</li>
    <li>App less polished than Cigna</li>
  </ul>

  <p><strong>Best for:</strong> Those who want the most comprehensive maternity coverage. Expats in expensive healthcare markets (Singapore, Hong Kong). Anyone planning a C-section or expecting complications.</p>

  <div class="my-6">
    <a href="/go/bupa-global" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Bupa Quote</a>
    <a href="/providers/bupa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="aetna-international">Aetna International</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">US Network</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">CVS Integration</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Lower Cost</span>
  </div>

  <p>
    Aetna International is the best choice if you might deliver in the US or want US healthcare access. Lower maternity limits than competitors, but also lower cost—and the CVS/Aetna network means easy access to US providers if needed.
  </p>

  <p><strong>Maternity strengths:</strong></p>
  <ul>
    <li>Best US network (CVS/Aetna)</li>
    <li>Lower cost for maternity add-on</li>
    <li>Good prenatal care coverage</li>
    <li>NICU coverage if needed</li>
    <li>Complications fully covered</li>
    <li>Postnatal care included</li>
  </ul>

  <p><strong>Limitations:</strong></p>
  <ul>
    <li>Lower limits ($12K normal, $20K C-section)</li>
    <li>Only 14 days automatic newborn coverage</li>
    <li>12-month waiting period</li>
    <li>Shorter hospital stays covered</li>
    <li>Smaller network outside US</li>
  </ul>

  <p><strong>Best for:</strong> US expats who might return for delivery. Those who want US network access. Budget-conscious families who want maternity coverage without paying premium prices.</p>

  <div class="my-6">
    <a href="/go/aetna-international" class="inline-block bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Aetna Quote</a>
    <a href="/providers/aetna-international" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <CTABox
    title="Compare Maternity Coverage"
    description="Get personalized quotes with maternity benefits explained. Plan ahead—waiting periods mean you need coverage before pregnancy."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
    variant="highlight"
  />

  <h2 id="coverage-details">Maternity Coverage Details</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>What's Typically Covered</h3>
  <ul>
    <li><strong>Prenatal care:</strong> All routine visits, ultrasounds, screenings</li>
    <li><strong>Delivery:</strong> Hospital, midwife, doctor fees (up to limits)</li>
    <li><strong>Anesthesia:</strong> Epidural and other pain management</li>
    <li><strong>Hospital stay:</strong> Room and board post-delivery</li>
    <li><strong>Complications:</strong> Covered beyond maternity limits (under medical benefits)</li>
    <li><strong>Postnatal:</strong> Follow-up checkups for mother</li>
    <li><strong>Newborn:</strong> Automatic coverage for 14-30 days</li>
  </ul>

  <h3>What's Often Excluded</h3>
  <ul>
    <li><strong>Elective C-section:</strong> Some plans exclude non-medically-necessary C-sections</li>
    <li><strong>Fertility treatment:</strong> IVF, IUI usually separate or excluded</li>
    <li><strong>Surrogacy:</strong> Typically excluded</li>
    <li><strong>Home birth midwife:</strong> May not be covered</li>
    <li><strong>Doula services:</strong> Usually excluded</li>
    <li><strong>Breast pumps:</strong> Often not covered</li>
  </ul>

  <h3>The Waiting Period Reality</h3>
  <p>
    All insurers require a waiting period—you must have the maternity add-on for 10-12 months before coverage begins. This means:
  </p>
  <ul>
    <li>You cannot buy maternity coverage when already pregnant</li>
    <li>If already pregnant, you need the policy for complications only</li>
    <li>Plan at least a year ahead if pregnancy is possible</li>
    <li>Add maternity now even if not actively planning—it protects you</li>
  </ul>

  <h2 id="pricing">Pricing Comparison</h2>

  <p>
    Maternity significantly increases premiums—expect to pay $120-280/month extra for the maternity add-on. Over a year, that's $1,500-3,400 before you even use it. But one complicated delivery can cost $50,000+.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">
    *Estimated ranges for comprehensive plans with maternity. Prices vary based on age, health, and location. Maternity add-on cost shown separately.
  </p>

  <h3>Is Maternity Coverage Worth It?</h3>
  <p>
    Consider the math: A normal delivery costs $5,000-20,000 depending on location. A C-section: $10,000-40,000. Complications can exceed $100,000. If there's any chance of pregnancy, the $1,500-3,400/year for maternity coverage is worth it.
  </p>

  <h2 id="best-for">Which Is Best For You?</h2>

  <div class="space-y-4 my-8">
    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Bupa Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the highest coverage limits</li>
        <li>Live in expensive healthcare markets</li>
        <li>Want the most comprehensive prenatal coverage</li>
        <li>May need a C-section or expect complications</li>
        <li>Want the longest hospital stays covered</li>
        <li>Can afford premium pricing</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Cigna Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Value the best digital experience</li>
        <li>Want easy claims processing</li>
        <li>Prefer the largest provider network</li>
        <li>Want 30 days newborn coverage (vs 14)</li>
        <li>Live where $15-25K limits are sufficient</li>
        <li>Prioritize service quality</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Aetna International if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Might deliver in the United States</li>
        <li>Want US network access (CVS/Aetna)</li>
        <li>Are budget-conscious</li>
        <li>Live where $12-20K limits are sufficient</li>
        <li>Already have Aetna through employer</li>
        <li>Prioritize cost over maximum coverage</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Can I buy maternity coverage if I'm already pregnant?</h3>
  <p>
    No. All insurers require a 10-12 month waiting period. If you're already pregnant, you cannot get maternity coverage for that pregnancy. However, you can still get coverage for complications under medical benefits—which is important for high-risk situations.
  </p>

  <h3>What if I give birth before the waiting period ends?</h3>
  <p>
    Maternity benefits won't apply. However, if there are complications (emergency C-section, premature birth, NICU), those may be covered under your medical benefits as emergencies. Check your specific policy terms.
  </p>

  <h3>Is my newborn automatically covered?</h3>
  <p>
    Yes, for 14-30 days depending on insurer. Cigna and Bupa: 30 days. Aetna: 14 days. You must add your baby to the policy within this window, or coverage ends. Don't delay—newborn care can be expensive.
  </p>

  <h3>Can I deliver in a different country than where I live?</h3>
  <p>
    Usually yes—international insurance covers you worldwide. Many expats choose to deliver in their home country or a country with better facilities. Just confirm with your insurer and understand how limits apply in different locations.
  </p>

  <h3>Are home births covered?</h3>
  <p>
    Coverage varies. Midwife-attended home births may be partially covered by some plans. Hospital is always covered. If you're considering a home birth, check your specific policy and consider a hospital backup plan.
  </p>

  <h3>What about fertility treatments?</h3>
  <p>
    Fertility treatments (IVF, IUI) are typically excluded from standard maternity coverage. Some insurers offer separate fertility riders at additional cost. If you need fertility coverage, ask specifically when getting quotes.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This comparison is for informational purposes only. Maternity coverage terms vary by plan and location. We are not insurance brokers. Verify specific maternity benefits and waiting periods directly with each insurer before purchasing.
    </p>
  </div>
</PageShell>
