---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'worldnomads', text: 'World Nomads', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'adventure-coverage', text: 'Adventure Activity Coverage', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/travel-insurance', text: 'Best Travel Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/compare/safetywing-vs-img-vs-cigna-digital-nomads', text: 'Digital Nomad Insurance' },
  { href: '/guides/international-health-insurance-101', text: 'Insurance 101' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'worldnomads', header: 'World Nomads' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Best For', safetywing: 'Long-term travel', worldnomads: 'Adventure activities', img: 'Flexible trips' },
  { feature: 'Minimum Duration', safetywing: '1 month (subscription)', worldnomads: '1 day', img: '5 days' },
  { feature: 'Maximum Duration', safetywing: 'Unlimited', worldnomads: '12 months', img: '3 years' },
  { feature: 'Adventure Sports', safetywing: 'Basic included', worldnomads: 'Extensive coverage', img: 'Add-on available' },
  { feature: 'Trip Cancellation', safetywing: 'Not included', worldnomads: 'Included', img: 'Optional' },
  { feature: 'Gear/Equipment', safetywing: 'Limited ($3K)', worldnomads: 'Good coverage', img: 'Limited' },
  { feature: 'Buy After Departure', safetywing: 'Yes', worldnomads: 'Yes', img: 'Yes' },
  { feature: 'Emergency Evacuation', safetywing: '$100K', worldnomads: '$300K', img: '$500K' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'worldnomads', header: 'World Nomads' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: '1 month trip (age 25)', safetywing: '$42', worldnomads: '$80-150', img: '$50-80' },
  { profile: '3 month trip (age 25)', safetywing: '$126', worldnomads: '$200-350', img: '$130-200' },
  { profile: '6 month trip (age 30)', safetywing: '$280', worldnomads: '$380-550', img: '$250-380' },
  { profile: '1 year trip (age 30)', safetywing: '$560', worldnomads: '$700-1,000', img: '$480-720' },
];
---

<PageShell
  title="SafetyWing vs World Nomads vs IMG for Backpackers | 2025 Comparison"
  description="Compare SafetyWing, World Nomads, and IMG Global for backpackers and adventure travelers. Expert analysis of adventure sports coverage, pricing, and gap year options."
  headline="SafetyWing vs World Nomads vs IMG: Best Insurance for Backpackers"
  subheadline="Complete comparison of three leading providers for backpackers, gap year travelers, and adventure seekers worldwide."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget Long-Term</p>
        <p class="text-neutral-700 text-sm mb-4">Cheapest option for extended travel with unlimited duration and subscription billing. Perfect for long-term backpackers.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">World Nomads</h3>
        <p class="text-purple-700 mb-3">Best Adventure Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Most comprehensive adventure sports coverage with trip cancellation included. Ideal for active travelers.</p>
        <a href="/get-quotes" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Get Quote</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">IMG Global</h3>
        <p class="text-green-700 mb-3">Best Flexibility</p>
        <p class="text-neutral-700 text-sm mb-4">Most flexible duration options with highest evacuation limits. Great balance of price and coverage.</p>
        <a href="/providers/img-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Cheapest Option</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Duration</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Subscription Model</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing revolutionized backpacker insurance with their affordable subscription model. At roughly $42/month for travelers under 40, it's the cheapest comprehensive option available. The subscription auto-renews monthly, so you never have to worry about your coverage expiring mid-trip.</p>

    <p class="text-neutral-700 mb-4">Perfect for indefinite travelers, digital nomads transitioning to backpacking, and anyone on a tight budget. Coverage is basic but adequate for most situations. The main trade-off is limited adventure sports coverage and lower evacuation limits compared to competitors.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Backpackers</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest price by far</li>
          <li>• Unlimited trip duration</li>
          <li>• Buy anytime (even mid-trip)</li>
          <li>• Children under 10 free</li>
          <li>• Simple subscription billing</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited adventure sports</li>
          <li>• No trip cancellation</li>
          <li>• Lower evacuation limit ($100K)</li>
          <li>• 1-month minimum purchase</li>
          <li>• Basic gear coverage ($3K max)</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="worldnomads" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">World Nomads</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Adventure Expert</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">150+ Activities</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Trip Cancellation</span>
    </div>

    <p class="text-neutral-700 mb-4">World Nomads is the gold standard for adventure travelers. They cover 150+ adventure activities that other insurers exclude—from bungee jumping to mountaineering to motorbike riding. If your backpacking trip involves adrenaline-pumping activities, World Nomads should be your first choice.</p>

    <p class="text-neutral-700 mb-4">Their Explorer plan includes trip cancellation and interruption coverage, rare for backpacker insurance. Gear and equipment coverage is solid, protecting your camera, laptop, and travel electronics. The premium price reflects this comprehensive protection.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Backpackers</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best adventure sports coverage</li>
          <li>• 150+ activities included</li>
          <li>• Trip cancellation included</li>
          <li>• Good gear/equipment coverage</li>
          <li>• Higher evacuation limit ($300K)</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Most expensive option</li>
          <li>• 12-month maximum duration</li>
          <li>• Must specify trip dates upfront</li>
          <li>• Extension process required for long trips</li>
          <li>• Some extreme activities still excluded</li>
        </ul>
      </div>
    </div>

    <a href="/get-quotes" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get World Nomads Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Duration</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">High Evac Limits</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers the best balance of price, coverage, and flexibility for backpackers. Coverage starts from just 5 days, extends up to 3 years, and includes the highest evacuation limits at $500K. Their Patriot Travel insurance is particularly popular among American backpackers.</p>

    <p class="text-neutral-700 mb-4">Adventure sports coverage is available as an add-on, letting you customize coverage for your specific activities. The online platform makes it easy to extend coverage if your trip runs longer than expected. IMG is a solid middle-ground between SafetyWing's budget option and World Nomads' premium coverage.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Backpackers</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Great value pricing</li>
          <li>• Flexible duration (5 days to 3 years)</li>
          <li>• Highest evacuation limits ($500K)</li>
          <li>• Optional adventure sports add-on</li>
          <li>• Easy online extensions</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Adventure sports require add-on</li>
          <li>• No trip cancellation on basic plans</li>
          <li>• Limited gear coverage</li>
          <li>• Less adventure activity variety</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <CTABox
    title="Compare Backpacker Insurance Quotes"
    description="Get personalized quotes from all three providers based on your trip details and activities."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Prices vary by age, destination, and coverage level. SafetyWing's pricing advantage grows with longer trips:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*World Nomads prices vary significantly by country of residence and destination. Adventure activities may increase premiums.</p>
  </section>

  <section id="adventure-coverage" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Adventure Activity Coverage</h2>

    <div class="grid md:grid-cols-3 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">SafetyWing</h3>
        <p class="text-neutral-700 text-sm mb-3">Basic activities only:</p>
        <ul class="text-green-700 text-sm space-y-1 mb-3">
          <li>✓ Hiking (non-technical)</li>
          <li>✓ Snorkeling</li>
          <li>✓ Kayaking</li>
          <li>✓ Cycling</li>
        </ul>
        <ul class="text-red-700 text-sm space-y-1">
          <li>✗ Scuba diving</li>
          <li>✗ Bungee jumping</li>
          <li>✗ Motorbike riding</li>
          <li>✗ Mountaineering</li>
        </ul>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">World Nomads</h3>
        <p class="text-purple-700 text-sm mb-3">150+ activities covered:</p>
        <ul class="text-green-700 text-sm space-y-1 mb-3">
          <li>✓ Scuba diving (40m)</li>
          <li>✓ Bungee jumping</li>
          <li>✓ Skydiving</li>
          <li>✓ Motorbike (with license)</li>
          <li>✓ Rock climbing</li>
          <li>✓ Paragliding</li>
          <li>✓ White water rafting</li>
        </ul>
        <p class="text-purple-700 text-xs">*Explorer plan for full coverage</p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">IMG Global</h3>
        <p class="text-neutral-700 text-sm mb-3">With adventure add-on:</p>
        <ul class="text-green-700 text-sm space-y-1 mb-3">
          <li>✓ Scuba diving (basic)</li>
          <li>✓ Hiking/trekking</li>
          <li>✓ Skiing (on-piste)</li>
          <li>✓ Zip-lining</li>
        </ul>
        <ul class="text-red-700 text-sm space-y-1">
          <li>✗ Bungee jumping</li>
          <li>✗ Skydiving</li>
          <li>✗ Base jumping</li>
        </ul>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-amber-800 mb-3">Motorbike Coverage Warning</h3>
      <p class="text-amber-700 mb-4">Motorbike accidents are the #1 cause of backpacker insurance claims in Southeast Asia. Coverage varies significantly:</p>
      <ul class="text-amber-700 space-y-2">
        <li>• <strong>SafetyWing:</strong> Does NOT cover motorbike riding</li>
        <li>• <strong>World Nomads:</strong> Covers if you have a valid motorcycle license</li>
        <li>• <strong>IMG:</strong> Limited coverage, check policy for specifics</li>
      </ul>
      <p class="text-amber-700 text-sm mt-3">If you plan to ride motorbikes, World Nomads is your only reliable option—but you MUST have a valid motorcycle license from your home country.</p>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Budget is your top priority</li>
          <li>• You're traveling long-term with no end date</li>
          <li>• You stick to basic activities (hiking, beaches, cities)</li>
          <li>• You want simple subscription billing</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose World Nomads if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You'll be doing adventure sports regularly</li>
          <li>• You need motorbike coverage</li>
          <li>• Trip cancellation protection is important</li>
          <li>• You have expensive gear to protect</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• You want the best value with solid coverage</li>
          <li>• You need flexible duration options</li>
          <li>• High evacuation limits are important to you</li>
          <li>• You want optional adventure add-ons</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I buy insurance after I've already left home?</h3>
        <p class="text-neutral-700">Yes, all three providers allow purchase after departure. SafetyWing is particularly flexible—you can sign up from anywhere. World Nomads has a 72-hour waiting period for some benefits. IMG also allows mid-trip enrollment with similar waiting periods for certain coverage.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if my trip runs longer than expected?</h3>
        <p class="text-neutral-700">SafetyWing auto-renews monthly (until you cancel), so you're always covered. World Nomads requires purchasing an extension before your coverage expires. IMG allows easy online extensions. Plan ahead if using World Nomads or IMG—don't let coverage lapse.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is my laptop/camera covered if stolen?</h3>
        <p class="text-neutral-700">Coverage varies significantly. World Nomads offers the best gear protection. SafetyWing covers up to $3,000 total with sub-limits per item. IMG has limited coverage on basic plans. For expensive electronics, consider separate travel electronics insurance or World Nomads' Explorer plan.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need travel insurance if I have a credit card with travel benefits?</h3>
        <p class="text-neutral-700">Credit card travel insurance is typically limited to short trips (15-30 days) and has restrictions. For backpacking trips longer than a month, dedicated travel insurance is essential. Credit card benefits can supplement your coverage but shouldn't replace proper backpacker insurance.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Adventure activity coverage has specific requirements and exclusions—always verify your activities are covered before participating. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
