---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'regional-details', text: 'Middle East Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/expats', text: 'Expat Insurance Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/aetna-international', text: 'Aetna International Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'UAE Network', cigna: 'Excellent (500+)', bupa: 'Excellent (400+)', aetna: 'Very Good (300+)' },
  { feature: 'Saudi Arabia', cigna: 'Very Good', bupa: 'Good', aetna: 'Good' },
  { feature: 'Qatar', cigna: 'Excellent', bupa: 'Very Good', aetna: 'Good' },
  { feature: 'Direct Billing', cigna: 'Best in region', bupa: 'Excellent', aetna: 'Good' },
  { feature: 'Coverage Limit', cigna: 'Unlimited', bupa: 'Unlimited', aetna: 'Up to $5M' },
  { feature: 'DHA Compliant', cigna: 'Yes', bupa: 'Yes', aetna: 'Yes' },
  { feature: 'Arabic Support', cigna: 'Full', bupa: 'Available', aetna: 'Limited' },
  { feature: 'Regional Pricing', cigna: 'Mid-range', bupa: 'Premium', aetna: 'Most affordable' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Individual (35)', cigna: '$380-520/mo', bupa: '$450-620/mo', aetna: '$320-440/mo' },
  { profile: 'Individual (50)', cigna: '$580-780/mo', bupa: '$680-920/mo', aetna: '$500-680/mo' },
  { profile: 'Couple (35/35)', cigna: '$720-980/mo', bupa: '$850-1,150/mo', aetna: '$610-840/mo' },
  { profile: 'Family (2+2)', cigna: '$1,050-1,400/mo', bupa: '$1,250-1,680/mo', aetna: '$900-1,200/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna for Middle East Expats | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Aetna International for expats in the Middle East. Expert analysis covering UAE, Saudi Arabia, Qatar, Kuwait, Bahrain, and Oman."
  headline="Cigna vs Bupa vs Aetna: Best Insurance for Middle East"
  subheadline="Complete comparison for expats in UAE, Saudi Arabia, Qatar, and the Gulf region—covering networks, DHA compliance, and premium healthcare access."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall for ME</p>
        <p class="text-neutral-700 text-sm mb-4">Largest regional network, best direct billing coverage, and full Arabic support. The go-to choice for most Middle East expats.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Premium Hospitals</p>
        <p class="text-neutral-700 text-sm mb-4">Access to the region's top-tier hospitals with VIP service. Premium choice for executives and those wanting the best facilities.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable option with solid networks in major UAE cities. Good choice for budget-conscious expats.</p>
        <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Largest Network</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Arabic Support</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">UAE Leader</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global dominates the Middle East expat insurance market with over 500 network providers in the UAE alone. From Dubai's premium facilities to Abu Dhabi's world-class hospitals, direct billing works seamlessly. This regional depth means rarely paying upfront, even for routine visits.</p>

    <p class="text-neutral-700 mb-4">Full Arabic customer support is available 24/7, crucial for navigating healthcare in the region. Coverage extends excellently throughout Qatar, Bahrain, Kuwait, and Oman. DHA compliance for Dubai residency is automatic. The unlimited coverage handles the region's expensive healthcare costs.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 500+ UAE providers</li>
          <li>• 24/7 Arabic support</li>
          <li>• Best direct billing</li>
          <li>• Excellent Gulf coverage</li>
          <li>• DHA compliant</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Mid-range pricing</li>
          <li>• Some rural areas limited</li>
          <li>• US add-on expensive</li>
          <li>• Prior auth for some treatments</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Hospitals</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">VIP Service</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Executive Focus</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global focuses on premium access in the Middle East. Their network includes the region's most prestigious facilities—Cleveland Clinic Abu Dhabi, American Hospital Dubai, King's College Hospital Dubai—with VIP treatment and executive health services. If you want the best hospitals, Bupa delivers.</p>

    <p class="text-neutral-700 mb-4">Care coordination helps navigate the region's complex healthcare landscape, particularly valuable for serious conditions. Coverage throughout the Gulf is strong, with good networks in Saudi Arabia and Qatar. The premium positioning means higher costs but premium service.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Premium hospital access</li>
          <li>• VIP and executive services</li>
          <li>• Excellent UAE coverage</li>
          <li>• Care coordination</li>
          <li>• International evacuations</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• Fewer mid-tier options</li>
          <li>• Limited Arabic support</li>
          <li>• Premium-focused network</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Good Networks</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">DHA Compliant</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International offers the best value for Middle East coverage. Premiums run 20-30% lower than competitors while providing solid networks in Dubai, Abu Dhabi, and other major Gulf cities. The $5M limit is more than adequate for most needs, even given regional healthcare costs.</p>

    <p class="text-neutral-700 mb-4">DHA compliance means Aetna meets Dubai's mandatory health insurance requirements. Networks in Saudi Arabia and Qatar are adequate, particularly in major cities. For expats prioritizing value over premium access, Aetna provides quality coverage at accessible prices.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 20-30% lower premiums</li>
          <li>• 300+ UAE providers</li>
          <li>• DHA compliant</li>
          <li>• Good major city coverage</li>
          <li>• US brand familiarity</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• $5M limit (vs unlimited)</li>
          <li>• Smaller overall network</li>
          <li>• Limited Arabic support</li>
          <li>• Fewer premium hospitals</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Aetna Quote</a>
  </section>

  <CTABox
    title="Compare Middle East Coverage"
    description="Get quotes optimized for your Gulf destination."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Middle East premiums reflect high regional healthcare costs:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Middle East premiums are among the highest globally due to expensive healthcare. All prices for comprehensive inpatient + outpatient coverage.</p>
  </section>

  <section id="regional-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Middle East Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Country-by-Country</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>UAE (Dubai):</strong> All three excellent; DHA mandatory</li>
          <li>• <strong>UAE (Abu Dhabi):</strong> All three excellent; HAAD requirements</li>
          <li>• <strong>Saudi Arabia:</strong> Cigna strongest; Aetna growing</li>
          <li>• <strong>Qatar:</strong> Cigna excellent; others good</li>
          <li>• <strong>Kuwait:</strong> Cigna and Bupa solid</li>
          <li>• <strong>Bahrain:</strong> All three adequate</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Regulatory Requirements</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Dubai:</strong> DHA-compliant insurance mandatory</li>
          <li>• <strong>Abu Dhabi:</strong> HAAD-approved coverage required</li>
          <li>• <strong>Saudi Arabia:</strong> CCHI-compliant for residency</li>
          <li>• <strong>Qatar:</strong> Employer typically provides</li>
          <li>• All three providers meet these requirements</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Healthcare Quality</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">World-Class (UAE/Qatar)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Cleveland Clinic Abu Dhabi</li>
            <li>• Mayo Clinic affiliates</li>
            <li>• JCI-accredited hospitals</li>
            <li>• Expensive but excellent</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">High Quality (Saudi)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Major city facilities excellent</li>
            <li>• International hospital chains</li>
            <li>• Quality varies by location</li>
            <li>• Good expat-focused options</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Smaller Gulf States</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Kuwait, Bahrain, Oman</li>
            <li>• Good private facilities</li>
            <li>• Dubai evacuation option</li>
            <li>• Growing healthcare sectors</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the largest regional network</li>
          <li>• Arabic support is important</li>
          <li>• You may travel between Gulf countries</li>
          <li>• Direct billing convenience matters</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Premium hospital access is priority</li>
          <li>• You're an executive or in senior management</li>
          <li>• VIP service matters</li>
          <li>• Care coordination is valuable</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Aetna International if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a significant factor</li>
          <li>• You're based in a major city</li>
          <li>• $5M coverage is sufficient</li>
          <li>• You prefer a US-based insurer</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Does my employer need to provide insurance in the UAE?</h3>
        <p class="text-neutral-700">In Dubai and Abu Dhabi, employers are legally required to provide health insurance to employees. Many expats supplement employer coverage with international insurance for better benefits, global coverage, or continuity if they leave their job. Check your employer's coverage limits before deciding.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Why are Middle East premiums so high?</h3>
        <p class="text-neutral-700">Healthcare costs in the Gulf are among the highest globally. A routine hospital stay in Dubai can cost $5,000-10,000+. Premium hospitals charge Western prices. The region also has high utilization rates—access to quality care means people use it. Insurance pricing reflects these realities.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What's the difference between DHA and HAAD?</h3>
        <p class="text-neutral-700">DHA (Dubai Health Authority) regulates Dubai; HAAD (now Department of Health Abu Dhabi) covers Abu Dhabi. Each has specific insurance requirements for residents. All three insurers compared here are compliant with both. Other emirates have less stringent requirements.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my insurance in other GCC countries?</h3>
        <p class="text-neutral-700">Yes, international insurance works throughout the Gulf. Your UAE policy covers you in Saudi Arabia, Qatar, or Bahrain. Network depth varies—Cigna typically has the best cross-border coverage. Direct billing may be more limited outside your home country; reimbursement claims are straightforward.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing, networks, and regulatory requirements change frequently. UAE and Gulf healthcare regulations vary by emirate and country. Always verify current coverage and compliance directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
