---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'student-needs', text: 'Student-Specific Considerations', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/students', text: 'Student Insurance Guide' },
  { href: '/visas/student-visa/in/germany', text: 'Germany Student Visa' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'img', header: 'IMG Global' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'cigna', header: 'Cigna Global' },
];

const mainComparisonRows = [
  { feature: 'Monthly Cost (22)', img: '$80-120', safetywing: '$42', cigna: '$200-350' },
  { feature: 'Coverage Limit', img: '$500K-2M', safetywing: '$250,000', cigna: 'Unlimited' },
  { feature: 'Visa Compliant', img: 'Most countries', safetywing: 'Many countries', cigna: 'All countries' },
  { feature: 'Mental Health', img: 'Limited', safetywing: 'Crisis only', cigna: 'Comprehensive' },
  { feature: 'Sports Coverage', img: 'Basic included', safetywing: 'Limited', cigna: 'Good' },
  { feature: 'Home Visits', img: 'Up to 30 days', safetywing: '30 days/90', cigna: 'Up to 180 days' },
  { feature: 'Routine Care', img: 'Optional', safetywing: 'Not covered', cigna: 'Included' },
  { feature: 'Contract Length', img: 'Semester/Year', safetywing: 'Monthly', cigna: 'Annual' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'img', header: 'IMG Global' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'cigna', header: 'Cigna Global' },
];

const pricingRows = [
  { profile: 'Undergraduate (20)', img: '$70-100/mo', safetywing: '$42/mo', cigna: '$180-280/mo' },
  { profile: 'Graduate student (26)', img: '$90-140/mo', safetywing: '$45/mo', cigna: '$220-340/mo' },
  { profile: 'PhD student (30)', img: '$110-170/mo', safetywing: '$45/mo', cigna: '$280-420/mo' },
  { profile: 'One semester (4 mo)', img: '$320-480', safetywing: '$168', cigna: 'Annual only' },
];
---

<PageShell
  title="IMG vs SafetyWing vs Cigna for International Students | 2025 Comparison"
  description="Compare health insurance for students abroad: IMG's student plans, SafetyWing's budget option, and Cigna's premium coverage. Expert analysis for study abroad and degree programs."
  headline="IMG vs SafetyWing vs Cigna: Insurance for Students Abroad"
  subheadline="From semester exchange to full degree programs—find the right health coverage for your international studies."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">IMG Global</h3>
        <p class="text-primary-700 mb-3">Best for Most Students</p>
        <p class="text-neutral-700 text-sm mb-4">Purpose-built student plans with semester options, visa compliance, and solid coverage. The balanced choice for degree programs.</p>
        <a href="/providers/img-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">SafetyWing</h3>
        <p class="text-purple-700 mb-3">Best Budget</p>
        <p class="text-neutral-700 text-sm mb-4">Lowest cost at $42/month with monthly flexibility. Perfect for short exchanges or budget-conscious students with basic needs.</p>
        <a href="/providers/safetywing" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 mb-3">Best Comprehensive</p>
        <p class="text-neutral-700 text-sm mb-4">Premium coverage with mental health, routine care, and unlimited limits. For students who need comprehensive protection.</p>
        <a href="/providers/cigna-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Student Plans</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Visa Compliant</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Semester Options</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers purpose-built student health insurance with their Patriot Exchange and Global Student plans. Coverage starts at $500K with options up to $2M—sufficient for serious medical events. Semester-length policies avoid paying for summer months when you're home.</p>

    <p class="text-neutral-700 mb-4">Visa compliance certificates are provided for most study destinations (Germany, France, UK, Spain). Basic sports coverage is included, covering intramural and recreational activities. Optional outpatient coverage adds routine care for those wanting comprehensive protection during their studies.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Student Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Purpose-built student plans</li>
          <li>• Semester-length options</li>
          <li>• Visa compliance letters</li>
          <li>• Sports activities covered</li>
          <li>• Affordable mid-range pricing</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited mental health</li>
          <li>• Some countries not accepted</li>
          <li>• Pre-existing excluded</li>
          <li>• Routine care costs extra</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">$42/Month</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Monthly Billing</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">No Commitment</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing is the budget champion for international students. At $42/month for those under 27, it's affordable even on a student budget. Monthly billing with no annual commitment means you can cancel when the semester ends or adjust as plans change—perfect for the uncertainty of student life.</p>

    <p class="text-neutral-700 mb-4">Coverage is basic—emergency medical up to $250K, no routine care, limited sports. But for healthy young students, this often suffices. Note: SafetyWing may not meet visa requirements for Germany and some other countries that mandate specific coverage types. Always verify before enrolling.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Student Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest cost ($42/mo)</li>
          <li>• No commitment required</li>
          <li>• Simple signup process</li>
          <li>• Monthly flexibility</li>
          <li>• Covers 180+ countries</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Limitations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Not visa-compliant everywhere</li>
          <li>• $250K limit (lower)</li>
          <li>• No routine care</li>
          <li>• Limited sports coverage</li>
          <li>• Mental health crisis only</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Mental Health</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global is the premium choice for students who need comprehensive protection. Unlimited coverage, proper mental health benefits (crucial given student stress levels), and routine care included. For students with health conditions, family history, or those wanting peace of mind, Cigna delivers full protection.</p>

    <p class="text-neutral-700 mb-4">All visa requirements are met globally. Home country visits up to 180 days cover long summer breaks. The trade-off is cost—at $200-400/month, this is a significant expense. Best for students whose families prioritize comprehensive coverage or those with specific health needs.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Student Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Unlimited coverage</li>
          <li>• Comprehensive mental health</li>
          <li>• Routine care included</li>
          <li>• All visa requirements met</li>
          <li>• 180 days home visits</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest cost</li>
          <li>• Annual commitment</li>
          <li>• Overkill for healthy students</li>
          <li>• No semester options</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <CTABox
    title="Compare Student Coverage Quotes"
    description="Get quotes tailored to your study destination and program length."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Student budgets vary—here's what to expect:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*IMG offers semester options; SafetyWing is month-to-month; Cigna is annual only. Prices for healthy students, no US coverage.</p>
  </section>

  <section id="student-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Student-Specific Considerations</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Program Types</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Semester exchange:</strong> SafetyWing or IMG semester</li>
          <li>• <strong>Year abroad:</strong> IMG annual or Cigna</li>
          <li>• <strong>Full degree (3-4 years):</strong> Cigna or host country plan</li>
          <li>• <strong>Graduate school:</strong> Consider comprehensive coverage</li>
          <li>• <strong>PhD program:</strong> University insurance often available</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">University Requirements</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Many universities mandate health insurance</li>
          <li>• Some require specific minimum coverage</li>
          <li>• University plans may be available (check cost)</li>
          <li>• Waiver possible with proof of coverage</li>
          <li>• Verify requirements before purchasing</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Country-Specific Requirements</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Germany</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Strict visa requirements</li>
            <li>• SafetyWing often NOT accepted</li>
            <li>• IMG or Cigna usually work</li>
            <li>• Public insurance option for some</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">France/Spain</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Less strict requirements</li>
            <li>• All three typically accepted</li>
            <li>• Budget options usually work</li>
            <li>• Public system supplements</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">UK/Australia</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• University often mandates plan</li>
            <li>• NHS access (UK) for some</li>
            <li>• OSHC required (Australia)</li>
            <li>• Check specific visa type</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You need visa-compliant coverage</li>
          <li>• Semester-length options are valuable</li>
          <li>• You want balanced coverage and cost</li>
          <li>• You'll participate in sports</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Budget is your top priority</li>
          <li>• You're healthy with no pre-existing conditions</li>
          <li>• Your visa doesn't have strict requirements</li>
          <li>• Flexibility matters (short program)</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Mental health coverage is important</li>
          <li>• You have health conditions to manage</li>
          <li>• Family wants comprehensive protection</li>
          <li>• You'll be abroad long-term (full degree)</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my parents' insurance abroad?</h3>
        <p class="text-neutral-700">Typically no—most US health insurance doesn't cover overseas care except emergencies. Even with emergency coverage, you'd need to pay upfront and seek reimbursement. International student insurance is generally more practical and provides direct billing access abroad.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about sports and activities?</h3>
        <p class="text-neutral-700">Basic recreational and intramural sports are typically covered by IMG and Cigna. Extreme sports (skydiving, bungee jumping) usually require add-ons or aren't covered. SafetyWing covers basic activities but has more exclusions. Check your specific activities before purchasing.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Will my insurance work during summer breaks?</h3>
        <p class="text-neutral-700">IMG semester plans can be timed to end when you leave. SafetyWing monthly billing lets you cancel during summer. Cigna annual plans cover you year-round, including summer. Home country coverage varies—30-180 days depending on provider.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is mental health really that important for students?</h3>
        <p class="text-neutral-700">International students face significant stress—homesickness, cultural adjustment, academic pressure. Studies show elevated mental health needs. If you have any history of anxiety or depression, or simply want coverage available, consider Cigna's comprehensive mental health or expect to pay out-of-pocket with other options.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance requirements vary by university and visa type. Country-specific requirements change frequently. Always verify coverage meets your specific visa and university requirements before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
