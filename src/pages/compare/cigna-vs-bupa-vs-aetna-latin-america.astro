---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'regional-details', text: 'Latin America Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/countries/mexico/insurance', text: 'Mexico Insurance' },
  { href: '/countries/costa-rica/insurance', text: 'Costa Rica Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/aetna-international', text: 'Aetna International Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'Mexico Network', cigna: 'Excellent (300+)', bupa: 'Good (150+)', aetna: 'Good (200+)' },
  { feature: 'Costa Rica Network', cigna: 'Very Good', bupa: 'Limited', aetna: 'Good' },
  { feature: 'Colombia Network', cigna: 'Good', bupa: 'Limited', aetna: 'Very Good' },
  { feature: 'Direct Billing', cigna: 'Best in region', bupa: 'Major cities', aetna: 'Good coverage' },
  { feature: 'Coverage Limit', cigna: 'Unlimited', bupa: 'Unlimited', aetna: 'Up to $5M' },
  { feature: 'US Coverage Option', cigna: 'Yes (add-on)', bupa: 'Yes (add-on)', aetna: 'Yes (add-on)' },
  { feature: 'Spanish Support', cigna: 'Full support', bupa: 'Available', aetna: 'Full support' },
  { feature: 'Regional Pricing', cigna: 'Mid-range', bupa: 'Premium', aetna: 'Most affordable' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Individual (35)', cigna: '$250-350/mo', bupa: '$300-420/mo', aetna: '$200-280/mo' },
  { profile: 'Individual (50)', cigna: '$400-550/mo', bupa: '$480-650/mo', aetna: '$340-460/mo' },
  { profile: 'Couple (35/35)', cigna: '$480-650/mo', bupa: '$570-780/mo', aetna: '$380-520/mo' },
  { profile: 'Family (2+2)', cigna: '$720-980/mo', bupa: '$860-1,180/mo', aetna: '$580-800/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna for Latin America | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Aetna International for expats in Latin America. Expert analysis covering Mexico, Costa Rica, Colombia, Panama, and beyond."
  headline="Cigna vs Bupa vs Aetna: Best Insurance for Latin America"
  subheadline="Complete comparison for expats in Mexico, Costa Rica, Colombia, Panama, and other Latin American destinations—covering networks, US access, and Spanish support."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall for LATAM</p>
        <p class="text-neutral-700 text-sm mb-4">Largest network in Mexico, strong throughout the region, excellent Spanish support. Best balance of coverage and accessibility.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Premium Hospitals</p>
        <p class="text-neutral-700 text-sm mb-4">Access to top medical tourism facilities. Premium service for those wanting the best private hospitals in Mexico City and beyond.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable option with good regional networks. Strong presence in Colombia and growing throughout Latin America.</p>
        <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Largest Network</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Spanish Support</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Mexico Leader</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global dominates the Latin American expat insurance market, particularly in Mexico. With over 300 network providers in Mexico alone—from Mexico City's top hospitals to clinics in San Miguel de Allende and Lake Chapala—expat coverage is comprehensive. Direct billing works at most major facilities.</p>

    <p class="text-neutral-700 mb-4">Spanish-language customer service is available 24/7, crucial when navigating healthcare in Spanish-speaking countries. Coverage extends well throughout Costa Rica, Panama, Colombia, and beyond. The unlimited coverage ensures peace of mind even if you need treatment in the US, available as an add-on.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 300+ Mexico providers</li>
          <li>• 24/7 Spanish support</li>
          <li>• Strong Costa Rica network</li>
          <li>• Direct billing throughout</li>
          <li>• US coverage option</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Mid-range pricing</li>
          <li>• Some rural areas limited</li>
          <li>• US coverage costs extra</li>
          <li>• Prior auth sometimes needed</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Facilities</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Medical Tourism</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Mexico City Focus</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global focuses on premium medical access in Latin America, particularly the region's best hospitals. Their network includes Mexico's top medical tourism facilities—ABC Hospital, Hospital Ángeles, Christus Muguerza—where international patients receive excellent care with English-speaking staff.</p>

    <p class="text-neutral-700 mb-4">Coverage outside major cities is more limited than Cigna, making Bupa better suited for expats based in or near major metros. Care coordination helps navigate complex treatments, and the premium positioning means VIP service at partner hospitals. Ideal if you prioritize hospital quality over network breadth.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Top-tier hospital partnerships</li>
          <li>• Medical tourism facilities</li>
          <li>• Excellent Mexico City coverage</li>
          <li>• Care coordination</li>
          <li>• VIP hospital service</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• Limited outside major cities</li>
          <li>• Costa Rica network sparse</li>
          <li>• Colombia coverage limited</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Growing Network</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Colombia Strong</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International offers the best value for Latin American expats. Premiums run 20-30% lower than competitors while providing solid coverage and growing regional networks. Their presence in Colombia is particularly strong—valuable given Medellín's growing expat community.</p>

    <p class="text-neutral-700 mb-4">Spanish support is fully available, and networks in Mexico and Costa Rica are adequate for urban expats. The $5M limit is more than sufficient for the region's healthcare costs. For cost-conscious expats who want real coverage without premium pricing, Aetna delivers strong regional value.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 20-30% lower premiums</li>
          <li>• Strong Colombia presence</li>
          <li>• Full Spanish support</li>
          <li>• Good Mexico network</li>
          <li>• US brand familiarity</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• $5M limit (vs unlimited)</li>
          <li>• Smaller overall network</li>
          <li>• Some areas less coverage</li>
          <li>• Fewer premium hospital ties</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Aetna Quote</a>
  </section>

  <CTABox
    title="Compare Latin America Coverage"
    description="Get quotes optimized for your Latin American destination."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Regional pricing for Latin America (excluding US coverage):</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Adding US coverage increases premiums by 40-60%. Latin America rates are among the lowest globally due to affordable local healthcare.</p>
  </section>

  <section id="regional-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Latin America Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Country-by-Country</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Mexico:</strong> All three excellent; Cigna leads</li>
          <li>• <strong>Costa Rica:</strong> Cigna best; Aetna good; Bupa limited</li>
          <li>• <strong>Colombia:</strong> Aetna and Cigna strong; Bupa limited</li>
          <li>• <strong>Panama:</strong> Cigna best; others adequate</li>
          <li>• <strong>Ecuador:</strong> Cigna and Aetna; network varies</li>
          <li>• <strong>Brazil:</strong> All three present; Cigna strongest</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">US Access Considerations</h3>
        <p class="text-neutral-700 text-sm mb-4">Many Latin American expats value US healthcare access:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Border proximity (Mexico, Caribbean)</li>
          <li>• Specialty care not available locally</li>
          <li>• Family visits to US</li>
          <li>• Medical tourism in reverse</li>
          <li>• Adds 40-60% to premiums</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Healthcare Quality Tiers</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Medical Tourism Hubs</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Mexico City, Guadalajara</li>
            <li>• Medellín, Bogotá</li>
            <li>• San José, Costa Rica</li>
            <li>• US-level quality, lower costs</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Good Private Care</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Most capital cities</li>
            <li>• Major expat destinations</li>
            <li>• Quality varies by facility</li>
            <li>• English availability varies</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Evacuation May Be Needed</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Rural areas</li>
            <li>• Smaller countries</li>
            <li>• Complex procedures</li>
            <li>• All plans include evacuation</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Mexico is your destination</li>
          <li>• You want the largest regional network</li>
          <li>• Spanish-language support matters</li>
          <li>• You may travel between countries</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You're in a major metro (Mexico City)</li>
          <li>• Premium hospital access is priority</li>
          <li>• Medical tourism facilities matter</li>
          <li>• Service quality is most important</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Aetna International if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a significant factor</li>
          <li>• Colombia is your destination</li>
          <li>• $5M coverage is sufficient</li>
          <li>• You prefer a US-based insurer</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Should I include US coverage for Latin America?</h3>
        <p class="text-neutral-700">It depends on your needs. If you're near the US border (Mexico), plan to visit family, or want access to US specialists, adding it makes sense despite the 40-60% premium increase. For those committed to staying in Latin America with quality local healthcare, it may be unnecessary.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does direct billing work in Latin America?</h3>
        <p class="text-neutral-700">At network hospitals, show your insurance card at admission. The hospital contacts your insurer for authorization and bills them directly. This works well in major cities; in smaller towns, expect to pay upfront and submit claims for reimbursement. All three insurers have user-friendly claims apps.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my international insurance for local healthcare?</h3>
        <p class="text-neutral-700">Yes, international insurance typically covers care anywhere, including your country of residence. However, for routine care in low-cost countries like Mexico, some expats pay cash for minor visits and use insurance for major expenses. Check if your plan has outpatient coverage.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about visa requirements for residency?</h3>
        <p class="text-neutral-700">Many Latin American countries require health insurance for residency visas (Mexico's temporary/permanent resident, Costa Rica's rentista, Panama's pensionado). All three insurers can provide visa compliance letters. Verify specific requirements with your destination's immigration authority.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing, networks, and coverage details change frequently. Healthcare quality and availability vary significantly across Latin America. Always verify current coverage and networks directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
