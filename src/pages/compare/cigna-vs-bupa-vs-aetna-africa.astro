---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'regional-details', text: 'Africa Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/insurance-for/expats', text: 'Expat Insurance Guide' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/aetna-international', text: 'Aetna International Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'South Africa Network', cigna: 'Excellent', bupa: 'Very Good', aetna: 'Good' },
  { feature: 'Kenya/East Africa', cigna: 'Good', bupa: 'Limited', aetna: 'Limited' },
  { feature: 'Nigeria/West Africa', cigna: 'Limited', bupa: 'Very Limited', aetna: 'Growing' },
  { feature: 'Evacuation Coverage', cigna: 'Comprehensive', bupa: 'Comprehensive', aetna: 'Good' },
  { feature: 'Coverage Limit', cigna: 'Unlimited', bupa: 'Unlimited', aetna: 'Up to $5M' },
  { feature: 'Tropical Disease', cigna: 'Full coverage', bupa: 'Full coverage', aetna: 'Full coverage' },
  { feature: 'Direct Billing', cigna: 'Best available', bupa: 'Major cities', aetna: 'Limited' },
  { feature: 'Regional Pricing', cigna: 'Mid-range', bupa: 'Premium', aetna: 'Most affordable' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Individual (35)', cigna: '$320-450/mo', bupa: '$380-530/mo', aetna: '$270-380/mo' },
  { profile: 'Individual (50)', cigna: '$500-680/mo', bupa: '$580-800/mo', aetna: '$420-580/mo' },
  { profile: 'Couple (35/35)', cigna: '$610-850/mo', bupa: '$720-1,000/mo', aetna: '$520-720/mo' },
  { profile: 'Family (2+2)', cigna: '$900-1,250/mo', bupa: '$1,080-1,480/mo', aetna: '$780-1,080/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna for Africa Expats | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Aetna International for expats in Africa. Expert analysis covering South Africa, Kenya, Nigeria, Ghana, and evacuation coverage."
  headline="Cigna vs Bupa vs Aetna: Best Insurance for Africa"
  subheadline="Complete comparison for expats in South Africa, Kenya, Nigeria, Ghana, and across the continent—covering networks, evacuation, and tropical disease coverage."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall for Africa</p>
        <p class="text-neutral-700 text-sm mb-4">Strongest networks across the continent, best evacuation support, and most direct billing options. The clear leader for African expats.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best for South Africa</p>
        <p class="text-neutral-700 text-sm mb-4">Excellent coverage in South Africa with premium hospital partnerships. Strong care coordination for complex cases.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable option with adequate coverage in major cities. Good for budget-conscious expats in developed African cities.</p>
        <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Best Networks</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Full Evacuation</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Direct Billing</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global has the most extensive African network among international insurers. In South Africa, coverage rivals local plans with excellent hospital partnerships in Johannesburg, Cape Town, and Pretoria. East Africa (Kenya, Tanzania, Uganda) has meaningful network presence—unusual for international insurers.</p>

    <p class="text-neutral-700 mb-4">Evacuation coverage is comprehensive—critical in Africa where local facilities may be inadequate for serious conditions. Cigna will evacuate to South Africa, Europe, or your home country depending on medical needs. Tropical disease coverage is full, including malaria, typhoid, and dengue. Direct billing works at major facilities.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best continental coverage</li>
          <li>• Strong South Africa network</li>
          <li>• East Africa presence</li>
          <li>• Comprehensive evacuation</li>
          <li>• Direct billing available</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• West Africa limited</li>
          <li>• Remote areas sparse</li>
          <li>• Mid-range pricing</li>
          <li>• Evacuation may be needed often</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">South Africa Focus</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Hospitals</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Care Coordination</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's African coverage concentrates on South Africa, where their network includes the continent's best hospitals—Netcare, Life Healthcare, and Mediclinic facilities. If you're based in Johannesburg, Cape Town, or Durban, Bupa provides premium access comparable to anywhere globally.</p>

    <p class="text-neutral-700 mb-4">Coverage elsewhere in Africa is limited—primarily evacuation-focused with minimal local networks in East or West Africa. Care coordination becomes essential, helping navigate complex medical situations and arranging evacuations when needed. For South Africa-based expats, Bupa is excellent; for elsewhere, consider Cigna.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Excellent South Africa coverage</li>
          <li>• Premium hospital partnerships</li>
          <li>• Care coordination</li>
          <li>• Strong evacuation support</li>
          <li>• VIP treatment available</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Very limited outside South Africa</li>
          <li>• Highest premiums</li>
          <li>• Evacuation primary option elsewhere</li>
          <li>• East/West Africa sparse</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Growing Network</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Nigeria Focus</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International offers the most affordable coverage for African expats. Their network is concentrated in major cities—Johannesburg, Lagos, Nairobi—with growing presence in West Africa unusual among international insurers. Nigeria, Africa's largest economy, has meaningful Aetna network development.</p>

    <p class="text-neutral-700 mb-4">The $5M limit is adequate for most scenarios, and evacuation coverage is included. Direct billing is limited compared to Cigna—expect to pay upfront and claim in many situations. For budget-conscious expats in major cities, Aetna provides solid value without premium pricing.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Regional Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable option</li>
          <li>• Growing Nigeria presence</li>
          <li>• Good major city coverage</li>
          <li>• Evacuation included</li>
          <li>• Familiar US brand</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited direct billing</li>
          <li>• Smaller overall network</li>
          <li>• $5M limit (vs unlimited)</li>
          <li>• Remote areas not covered</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Aetna Quote</a>
  </section>

  <CTABox
    title="Compare Africa Coverage"
    description="Get quotes optimized for your African destination."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Africa premiums reflect evacuation needs and healthcare variability:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Prices include evacuation coverage. South Africa-only plans may cost less; multi-country coverage costs more.</p>
  </section>

  <section id="regional-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Africa Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Region-by-Region</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>South Africa:</strong> All three good; Cigna/Bupa best</li>
          <li>• <strong>Kenya/Tanzania:</strong> Cigna leads; others limited</li>
          <li>• <strong>Nigeria:</strong> Aetna growing; Cigna present</li>
          <li>• <strong>Ghana/Senegal:</strong> Very limited all providers</li>
          <li>• <strong>Morocco/Egypt:</strong> Better coverage (North Africa)</li>
          <li>• <strong>Remote areas:</strong> Evacuation-focused all providers</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Critical Considerations</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Evacuation coverage is essential</li>
          <li>• Tropical disease coverage mandatory</li>
          <li>• Local quality varies dramatically</li>
          <li>• Many treatments require South Africa/Europe</li>
          <li>• Pre-trip vaccinations important</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Healthcare Quality by Region</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Good Private (South Africa)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• World-class private hospitals</li>
            <li>• Medical tourism destination</li>
            <li>• Full specialty care</li>
            <li>• English standard</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Developing (Kenya/Nigeria)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Good urban private hospitals</li>
            <li>• Nairobi/Lagos have options</li>
            <li>• Complex cases need evacuation</li>
            <li>• Quality varies significantly</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Limited (Most Elsewhere)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Basic care available</li>
            <li>• Serious conditions need evacuation</li>
            <li>• Remote areas very limited</li>
            <li>• Evacuation plan essential</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You're anywhere in Africa (best coverage)</li>
          <li>• Direct billing matters</li>
          <li>• You may travel between countries</li>
          <li>• Comprehensive evacuation is important</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You're based in South Africa</li>
          <li>• Premium hospital access matters</li>
          <li>• Care coordination is valuable</li>
          <li>• You won't travel much elsewhere</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Aetna International if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a primary concern</li>
          <li>• You're in a major city (Lagos, Nairobi)</li>
          <li>• $5M coverage is sufficient</li>
          <li>• You prefer a US-based insurer</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does medical evacuation work in Africa?</h3>
        <p class="text-neutral-700">When local care is inadequate, your insurer arranges air ambulance or commercial flight (medical escort) to appropriate facilities—typically South Africa, Europe, or your home country. All three insurers have 24/7 assistance to coordinate. Evacuation costs can exceed $50,000-100,000; it's essential coverage.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is malaria and tropical disease covered?</h3>
        <p class="text-neutral-700">Yes, all three providers fully cover tropical diseases including malaria, typhoid, dengue, and yellow fever as standard medical conditions. Take preventive measures (antimalarials, vaccinations, mosquito prevention) but know treatment is covered if you contract tropical illness.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use South African hospitals if I'm based elsewhere?</h3>
        <p class="text-neutral-700">Yes, you can travel to South Africa for elective or planned treatment—it's common among African expats. Your insurance covers treatment globally. For emergencies, local stabilization then evacuation to South Africa is typical. South Africa is effectively the regional medical hub.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about security evacuations?</h3>
        <p class="text-neutral-700">Security/political evacuations are typically separate from medical evacuations. Some comprehensive policies include security evacuation, but many don't. Consider separate security evacuation coverage (from providers like Global Rescue or ISOS) if you're in politically unstable regions.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing, networks, and coverage details change frequently. African healthcare quality and availability vary dramatically by location. Always verify current coverage, evacuation provisions, and networks directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
