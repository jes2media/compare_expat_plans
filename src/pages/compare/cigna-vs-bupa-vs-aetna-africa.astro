---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "cigna", title: "Cigna Global" },
  { id: "bupa", title: "Bupa Global" },
  { id: "aetna", title: "Aetna International" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "africa-details", title: "Africa Considerations" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/providers/bupa-global", title: "Bupa Global Review" },
  { href: "/providers/aetna-international", title: "Aetna International Review" },
  { href: "/countries/south-africa/insurance", title: "South Africa Insurance Guide" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "aetna", header: "Aetna International" },
];

const mainComparisonRows = [
  { feature: "Africa Network", cigna: "Extensive", bupa: "Good", aetna: "Limited" },
  { feature: "South Africa", cigna: "Strong network", bupa: "Strong network", aetna: "Good network" },
  { feature: "East Africa", cigna: "Good coverage", bupa: "Moderate", aetna: "Limited" },
  { feature: "West Africa", cigna: "Good coverage", bupa: "Moderate", aetna: "Limited" },
  { feature: "Evacuation", cigna: "Comprehensive", bupa: "Comprehensive", aetna: "Comprehensive" },
  { feature: "Tropical Disease", cigna: "Full coverage", bupa: "Full coverage", aetna: "Full coverage" },
  { feature: "Security Evacuation", cigna: "Add-on", bupa: "Add-on", aetna: "Add-on" },
  { feature: "Regional Support", cigna: "24/7 Africa line", bupa: "Global line", aetna: "Global line" },
  { feature: "Telemedicine", cigna: "Strong", bupa: "Available", aetna: "Available" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "aetna", header: "Aetna International" },
];

const pricingRows = [
  { profile: "35-year-old, individual", cigna: "$3,400–4,600/yr", bupa: "$3,000–4,200/yr", aetna: "$3,200–4,400/yr" },
  { profile: "45-year-old, individual", cigna: "$5,000–6,800/yr", bupa: "$4,400–6,200/yr", aetna: "$4,600–6,400/yr" },
  { profile: "Couple (both 40)", cigna: "$8,000–10,800/yr", bupa: "$7,200–10,000/yr", aetna: "$7,600–10,400/yr" },
  { profile: "Family (2 adults, 2 kids)", cigna: "$13,600–18,400/yr", bupa: "$12,000–16,800/yr", aetna: "$12,800–17,600/yr" },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna: Health Insurance for Africa (2025)"
  description="Compare international health insurance for expats in Africa. Analysis of Cigna Global, Bupa Global, and Aetna International for South Africa, Kenya, Nigeria, and beyond."
  headline="Cigna vs Bupa vs Aetna: Africa Coverage Compared"
  intro="Africa presents unique healthcare challenges—from world-class facilities in South Africa to limited options in remote regions. Expats need coverage that handles tropical diseases, provides reliable evacuation, and works across diverse healthcare systems. Here's how Cigna Global, Bupa Global, and Aetna International compare for expats across Africa."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 font-semibold mb-2">Best Overall for Africa</p>
        <p class="text-neutral-700 text-sm">Strongest Africa network across the continent. Dedicated Africa support line. Best for expats outside South Africa or those needing extensive regional coverage.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best for Southern Africa</p>
        <p class="text-neutral-700 text-sm">Strong South Africa network with competitive pricing. Good option for expats based in the more developed southern regions. Value-focused coverage.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 font-semibold mb-2">Best for US Citizens in Africa</p>
        <p class="text-neutral-700 text-sm">Limited Africa network but integrated US coverage. Best for Americans who travel home frequently. Solid for South Africa-based expats with US ties.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Africa Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Continental coverage:</strong> Network spans South Africa, Kenya, Nigeria, Ghana, Tanzania, and more</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Dedicated Africa line:</strong> 24/7 support team familiar with regional challenges</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Tropical disease:</strong> Full coverage for malaria, typhoid, dengue, and regional illnesses</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Evacuation:</strong> Air ambulance to South Africa, Europe, or home country</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Telemedicine:</strong> Virtual consultations when local care is limited</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global has invested significantly in African infrastructure, understanding that the continent requires specialized expertise. Their Africa support line is staffed by people who understand regional healthcare realities—not just reading from a global script.
    </p>
    <p class="text-neutral-700">
      The network includes quality facilities in major cities: Nairobi Hospital, Aga Khan hospitals across East Africa, top South African medical centers, and select facilities in West Africa. For remote locations, telemedicine and evacuation fill the gaps.
    </p>
  </section>

  <!-- Bupa Global Section -->
  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Africa Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>South Africa strength:</strong> Extensive network in Cape Town, Johannesburg, Durban</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Competitive pricing:</strong> Lower premiums than Cigna for Africa coverage</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Tropical coverage:</strong> Regional diseases fully covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Evacuation:</strong> Medical transport when needed</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Moratorium underwriting:</strong> Easier enrollment with health history</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Bupa Global's Africa coverage is strongest in the south. South Africa has world-class medical facilities—Netcare, Mediclinic, Life Healthcare—and Bupa has excellent relationships with these networks. For expats based in South Africa with occasional continental travel, Bupa offers good value.
    </p>
    <p class="text-neutral-700">
      Coverage in East and West Africa is more limited. You'll find direct billing in major cities like Nairobi and Lagos, but smaller locations often require upfront payment and reimbursement. If your work takes you frequently beyond South Africa, Cigna's broader network may justify the premium difference.
    </p>
  </section>

  <!-- Aetna International Section -->
  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Africa Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>US coverage included:</strong> Seamless care when traveling to America</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>South Africa network:</strong> Good coverage in major cities</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Tropical disease:</strong> Full coverage for regional illnesses</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Evacuation:</strong> Transport to US or other destinations</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-600 mt-1">△</span>
          <span><strong>Limited Africa network:</strong> Less extensive than Cigna or Bupa</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Aetna International's Africa presence is more limited than Cigna or Bupa. The network focuses on South Africa's major cities, with limited direct billing elsewhere. For Americans in Africa who value integrated US coverage, Aetna provides a workable solution.
    </p>
    <p class="text-neutral-700">
      The US connection matters for Americans who return frequently. Medical evacuations can route through US hospitals rather than just European or South African facilities. For non-Americans, Cigna or Bupa typically offer better Africa-specific value.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Africa Insurance Quotes"
    description="Compare plans from Cigna, Bupa, and Aetna designed for expats living and working in Africa."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Africa pricing is generally lower than other regions due to lower local healthcare costs in many areas. However, the need for evacuation coverage and access to quality facilities keeps premiums meaningful.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for Africa regional coverage. Including US coverage (for evacuations to US) increases premiums.
    </p>
  </section>

  <!-- Africa Details Section -->
  <section id="africa-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Africa Healthcare Realities</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Healthcare Quality Varies Dramatically</h3>
        <p class="text-neutral-700 mb-3">
          South Africa has world-class private hospitals rivaling anything in Europe or America. Kenya's Nairobi Hospital and Aga Khan facilities are excellent. But move to rural areas or less developed countries, and options diminish quickly—sometimes dramatically.
        </p>
        <p class="text-neutral-700">
          Your insurance must bridge this gap. In cities, use the network for quality care. In remote areas, telemedicine and evacuation become critical. All three insurers understand this reality and structure coverage accordingly.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Tropical Diseases</h3>
        <p class="text-neutral-700 mb-3">
          Malaria, typhoid, dengue fever, and other tropical diseases are real concerns across much of Africa. All three insurers fully cover treatment for these conditions. Prevention (antimalarials, vaccinations) may also be covered—check your specific policy.
        </p>
        <p class="text-neutral-700">
          Having coverage isn't enough—you need access to quality treatment quickly. Malaria can become serious fast. Insurers with strong Africa networks and 24/7 support help ensure you get proper care promptly when tropical illness strikes.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Medical Evacuation</h3>
        <p class="text-neutral-700 mb-3">
          Evacuation is not optional for Africa-based expats—it's essential. When local facilities can't handle your condition, you need air ambulance to South Africa, Europe, or home. All three insurers provide comprehensive medical evacuation.
        </p>
        <p class="text-neutral-700">
          Typical evacuation destinations: Johannesburg or Cape Town for southern/eastern Africa, sometimes Europe for West Africa. US evacuation is possible but expensive and usually reserved for American citizens or when US-specific care is needed.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Security Evacuation</h3>
        <p class="text-neutral-700 mb-3">
          Political instability, civil unrest, or security threats occasionally require evacuation for safety—not medical reasons. This is separate from medical evacuation and typically requires an add-on or separate security coverage.
        </p>
        <p class="text-neutral-700">
          Organizations operating in higher-risk areas (NGOs, mining companies, diplomatic services) often add security evacuation coverage. Check if your employer provides this, or consider personal security coverage if working in volatile regions.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You work across multiple African countries</li>
          <li>• You're outside South Africa regularly</li>
          <li>• Dedicated Africa support matters</li>
          <li>• You want the strongest continent-wide network</li>
          <li>• Telemedicine is important for remote work</li>
          <li>• Comprehensive coverage is priority</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose Bupa If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're primarily based in South Africa</li>
          <li>• Lower premiums are important</li>
          <li>• Occasional continental travel is enough</li>
          <li>• You have health history (moratorium)</li>
          <li>• Value for money matters most</li>
          <li>• Southern Africa is your focus</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Aetna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're an American expat</li>
          <li>• Integrated US coverage matters</li>
          <li>• You travel frequently to the US</li>
          <li>• You're based in South Africa</li>
          <li>• US evacuation option is valued</li>
          <li>• Your employer provides Aetna</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Are vaccinations and antimalarials covered?</h3>
        <p class="text-neutral-700">
          Coverage varies by plan. Some include travel vaccinations and prophylactic antimalarials; others don't. Check your specific policy. Even if not covered, these preventive measures are essential and relatively affordable—don't skip them based on insurance coverage.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I need evacuation from a remote location?</h3>
        <p class="text-neutral-700">
          All three insurers can coordinate evacuations from remote areas, though logistics are more complex. This might involve ground transport to an airstrip, then fixed-wing or helicopter to a major city. The 24/7 assistance line coordinates these situations—they've handled them before.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How does telemedicine work in areas with poor internet?</h3>
        <p class="text-neutral-700">
          Telemedicine requires reasonable connectivity, which can be challenging in remote Africa. Audio-only consultations may work where video doesn't. Insurers also use satellite phones for coordination in truly remote areas. Set realistic expectations about telemedicine availability based on your location.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is HIV treatment covered?</h3>
        <p class="text-neutral-700">
          Yes—HIV treatment is covered as any other medical condition. Pre-existing HIV would be subject to underwriting. Post-exposure prophylaxis (PEP) after potential exposure is typically covered as emergency care. Africa has excellent HIV treatment capabilities, particularly in South Africa.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about coverage in conflict zones?</h3>
        <p class="text-neutral-700">
          Active war zones are typically excluded. Areas with travel advisories may have restrictions. Check your policy's exclusion list and verify coverage for your specific destination. Some organizations provide supplemental coverage for high-risk areas.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I use South African doctors for other African countries?</h3>
        <p class="text-neutral-700">
          South Africa often serves as the regional medical hub. Evacuations frequently go there. For planned specialist care, traveling to South Africa from other African countries is common and covered. Some expats schedule annual checkups in South Africa for convenience.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by specific plan, policy year, and individual circumstances. Healthcare quality and availability varies significantly across Africa. Some areas may have coverage restrictions. Security evacuation is separate from medical evacuation. This comparison reflects general plan features—always verify specific benefits and geographic coverage with insurers before purchasing.
    </p>
  </aside>
</PageShell>
