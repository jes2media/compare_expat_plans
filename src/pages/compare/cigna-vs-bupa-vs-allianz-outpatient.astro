---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'outpatient-details', text: 'Outpatient Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/compare/cigna-vs-bupa-vs-allianz-wellness', text: 'Wellness Coverage' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'GP Visits', cigna: 'Unlimited', bupa: 'Unlimited', allianz: 'Unlimited' },
  { feature: 'Specialist Visits', cigna: 'Unlimited', bupa: 'Unlimited', allianz: 'Subject to limits' },
  { feature: 'Diagnostic Tests', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Good coverage' },
  { feature: 'Physiotherapy', cigna: 'Up to 30 sessions', bupa: 'Up to 25 sessions', allianz: 'Up to 20 sessions' },
  { feature: 'Prescription Drugs', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Copay may apply' },
  { feature: 'Direct Billing', cigna: 'Excellent', bupa: 'Excellent', allianz: 'Good' },
  { feature: 'Outpatient Surgery', cigna: 'Covered', bupa: 'Covered', allianz: 'Covered' },
  { feature: 'Annual Limits', cigna: 'Unlimited', bupa: 'Unlimited', allianz: 'Plan dependent' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Inpatient only (35)', cigna: '$180-250/mo', bupa: '$200-280/mo', allianz: '$150-220/mo' },
  { profile: 'Inpatient + Outpatient (35)', cigna: '$320-420/mo', bupa: '$360-480/mo', allianz: '$280-370/mo' },
  { profile: 'Full coverage family', cigna: '$950-1,250/mo', bupa: '$1,050-1,400/mo', allianz: '$820-1,100/mo' },
  { profile: 'Outpatient add-on cost', cigna: '+$140-170/mo', bupa: '+$160-200/mo', allianz: '+$130-150/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Outpatient Coverage | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for outpatient coverage. Expert analysis of GP visits, specialist access, prescriptions, and physiotherapy."
  headline="Cigna vs Bupa vs Allianz: Best Outpatient Coverage"
  subheadline="Complete comparison of three leading providers for expats prioritizing comprehensive outpatient care including GP visits, specialists, and prescriptions."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Outpatient</p>
        <p class="text-neutral-700 text-sm mb-4">Most comprehensive outpatient coverage with unlimited specialists, best physiotherapy limits, and full prescription coverage.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Direct Billing</p>
        <p class="text-neutral-700 text-sm mb-4">Excellent outpatient network with seamless direct billing at clinics worldwide. Premium service experience.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Good outpatient coverage at the most competitive price. Solid choice for budget-conscious expats.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Specialists</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Full Rx Coverage</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Best Physio Limits</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most comprehensive outpatient coverage in the market. Unlimited GP and specialist visits mean you never worry about hitting caps when managing ongoing health needs. Their prescription drug coverage is full, with no copays on most plans—particularly valuable if you take regular medications.</p>

    <p class="text-neutral-700 mb-4">Physiotherapy limits are the highest at 30 sessions per year, beneficial for expats recovering from injuries or managing chronic pain. Direct billing works at thousands of clinics worldwide, so you rarely pay out of pocket for routine outpatient care.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Outpatient Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Unlimited specialist visits</li>
          <li>• Full prescription drug coverage</li>
          <li>• 30 physio sessions/year</li>
          <li>• Extensive direct billing network</li>
          <li>• No annual outpatient limits</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher premiums than Allianz</li>
          <li>• Outpatient adds significant cost</li>
          <li>• Some regions have limited clinics</li>
          <li>• Prior authorization for some treatments</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Service</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Direct Billing</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Quality Network</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's outpatient coverage emphasizes quality and convenience. Their direct billing network focuses on premium clinics and medical centers, ensuring high standards wherever you seek care. Unlimited GP and specialist visits provide flexibility for ongoing health management.</p>

    <p class="text-neutral-700 mb-4">The Bupa app makes finding outpatient providers simple, with quality ratings and direct booking available. Full prescription coverage with pharmacy finder integration streamlines the medication process. Physiotherapy is covered up to 25 sessions annually.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Outpatient Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Premium clinic network</li>
          <li>• Excellent direct billing</li>
          <li>• App-based provider search</li>
          <li>• Full prescription coverage</li>
          <li>• Quality-focused provider selection</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest outpatient premiums</li>
          <li>• 25 physio sessions (vs Cigna's 30)</li>
          <li>• Some locations limited options</li>
          <li>• Premium pricing for premium service</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Solid Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Plans</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers solid outpatient coverage at the most accessible price point. GP visits are unlimited, though specialist visits may have annual limits depending on your plan level. This makes Allianz attractive for generally healthy expats who primarily need routine care.</p>

    <p class="text-neutral-700 mb-4">Prescription coverage includes modest copays on some plans—typically €5-20 per prescription. Physiotherapy is covered up to 20 sessions, adequate for most needs. Direct billing is available but not as extensive as Cigna or Bupa; expect to pay and claim for some visits.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Outpatient Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable outpatient option</li>
          <li>• Unlimited GP visits</li>
          <li>• Good diagnostic coverage</li>
          <li>• Flexible plan customization</li>
          <li>• Adequate for routine care</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Specialist limits on some plans</li>
          <li>• Prescription copays may apply</li>
          <li>• 20 physio sessions (lowest)</li>
          <li>• Less direct billing coverage</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Outpatient Coverage Quotes"
    description="Get personalized quotes with outpatient benefits from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Outpatient coverage significantly increases premiums—but provides daily-use value:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Adding outpatient coverage typically increases premiums by 60-80%. Consider whether routine care needs justify the cost.</p>
  </section>

  <section id="outpatient-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Outpatient Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">What's Typically Included</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• GP consultations and visits</li>
          <li>• Specialist consultations</li>
          <li>• Diagnostic tests (blood, imaging)</li>
          <li>• Prescription medications</li>
          <li>• Physiotherapy</li>
          <li>• Outpatient surgery</li>
          <li>• Mental health consultations</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Inpatient vs Outpatient</h3>
        <p class="text-neutral-700 text-sm mb-4">Understanding the difference:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Inpatient:</strong> Overnight hospital stays, surgery requiring admission</li>
          <li>• <strong>Outpatient:</strong> Same-day visits, no overnight stay</li>
          <li>• Many plans cover inpatient only—add outpatient for full coverage</li>
          <li>• Outpatient is your "everyday" coverage</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Therapies & Rehabilitation</h3>
      <p class="text-blue-700 mb-4">Sessions included in outpatient coverage:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">30 physio sessions, speech therapy, occupational therapy included. Chiropractic and osteopathy on some plans.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">25 physio sessions, complementary therapies on premium plans. Acupuncture may be covered.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Allianz</h4>
          <p class="text-blue-700 text-sm">20 physio sessions standard. Alternative therapies typically excluded or add-on.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the most comprehensive outpatient coverage</li>
          <li>• Full prescription coverage without copays matters</li>
          <li>• You may need extensive physiotherapy</li>
          <li>• Unlimited specialist visits are important</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Direct billing convenience is a priority</li>
          <li>• You value premium clinic access</li>
          <li>• Quality of providers matters more than quantity</li>
          <li>• You want app-based provider search</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a significant consideration</li>
          <li>• You're generally healthy with routine needs</li>
          <li>• Basic outpatient coverage is sufficient</li>
          <li>• You're comfortable with occasional reimbursement</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need outpatient coverage or just inpatient?</h3>
        <p class="text-neutral-700">It depends on your health needs and risk tolerance. Inpatient-only plans cost 40-50% less but mean you pay cash for GP visits, prescriptions, and routine care. If you're healthy and building savings locally works, inpatient-only may suffice. For comprehensive coverage including everyday healthcare, add outpatient.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does direct billing work for outpatient visits?</h3>
        <p class="text-neutral-700">At network clinics, you show your insurance card and the clinic bills your insurer directly—you pay nothing (or just copays). Not all clinics participate; check your insurer's provider finder before appointments. For non-network providers, you pay upfront and submit claims for reimbursement.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are routine check-ups and preventive care included?</h3>
        <p class="text-neutral-700">Outpatient coverage typically includes diagnostic tests ordered by your doctor. Annual wellness exams and preventive screenings may require a wellness add-on or be included in comprehensive plans. Check your specific policy for preventive care details.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What's the claims process for out-of-network outpatient care?</h3>
        <p class="text-neutral-700">You pay the provider directly, then submit the receipt and diagnosis codes via app or portal. All three insurers have online claims submission. Reimbursement typically takes 5-15 business days. Keep all receipts and request itemized bills for smooth processing.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Outpatient benefits vary by plan level and region. Always verify specific coverage directly with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
