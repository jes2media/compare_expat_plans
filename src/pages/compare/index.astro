---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ContentCards from '../../components/ContentCards.astro';

const comparisons = [
  {
    title: 'Cigna Global vs Allianz Care',
    description: 'Two popular choices compared on coverage, price, and service.',
    href: '/compare/cigna-global-vs-allianz-care',
  },
  {
    title: 'Cigna Global vs Aetna',
    description: 'Which works better for US expats?',
    href: '/compare/cigna-global-vs-aetna',
  },
  {
    title: 'BUPA Global vs Cigna Global',
    description: 'Premium options for comprehensive coverage.',
    href: '/compare/bupa-global-vs-cigna-global',
  },
];
---

<Layout title="Compare Insurance Plans" description="Head-to-head comparisons of international health insurance providers. See how they stack up on coverage, price, and service.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Compare Insurance Providers
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          See how leading international health insurance providers compare on coverage, pricing, and service.
        </p>
        <CTAButton href="/compare/cigna-global-vs-allianz-care" size="lg">
          See Popular Comparison
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={comparisons} title="Popular Comparisons" />
    </div>
  </section>
</Layout>
