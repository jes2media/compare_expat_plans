---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Iceland Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Iceland's Long-Term Visa for Remote Workers. Expert analysis of Cigna Global, SafetyWing, and Allianz Care for nomads in Reykjavik.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "Iceland DNV Acceptance", cigna: "✓ Accepted", safetywing: "✓ Accepted", allianz: "✓ Accepted" },
  { feature: "Iceland Network", cigna: "Landspítali, private clinics", safetywing: "Reimbursement", allianz: "Good coverage" },
  { feature: "Schengen Coverage", cigna: "✓ Worldwide", safetywing: "✓ Outside home country", allianz: "✓ Worldwide" },
  { feature: "Medical Evacuation", cigna: "Unlimited", safetywing: "$100K limit", allianz: "Included" },
  { feature: "Monthly Cost (35yo)", cigna: "$350-520", safetywing: "$69", allianz: "$300-460" },
  { feature: "Annual Maximum", cigna: "Unlimited", safetywing: "$250,000", allianz: "€1-2 million" },
  { feature: "Best For", cigna: "Comprehensive needs", safetywing: "Budget nomads", allianz: "Nordic focus" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "$250K limit", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited (critical in Iceland)", safetywing: "$100K limit", allianz: "Included" },
  { coverage: "Search & Rescue", cigna: "Check policy", safetywing: "Not covered", allianz: "Check policy" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Covered" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "$260-400/month", safetywing: "$69/month", allianz: "$230-350/month" },
  { age: "30-35", cigna: "$330-500/month", safetywing: "$69/month", allianz: "$290-440/month" },
  { age: "40-45", cigna: "$470-720/month", safetywing: "$99/month", allianz: "$420-630/month" },
  { age: "50-55", cigna: "$680-1,040/month", safetywing: "$148/month", allianz: "$600-900/month" },
];

const networkColumns = [
  { key: "location", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { location: "Reykjavik (Landspítali)", cigna: "Direct billing available", safetywing: "Reimbursement", allianz: "Direct billing" },
  { location: "Private Clinics", cigna: "Good coverage", safetywing: "Reimbursement", allianz: "Good coverage" },
  { location: "Regional Iceland", cigna: "Limited facilities", safetywing: "Reimbursement", allianz: "Limited facilities" },
  { location: "Copenhagen (evacuation)", cigna: "Full coverage", safetywing: "Covered", allianz: "Full coverage" },
  { location: "Schengen Zone", cigna: "Worldwide", safetywing: "Covered", allianz: "Worldwide" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Iceland's Long-Term Visa for Remote Workers"
    heroImage="/images/countries/iceland-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Iceland Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Iceland's Long-Term Visa for Remote Workers allows digital nomads to live in this stunning Nordic island for up to 6 months. Known for dramatic landscapes, Northern Lights, and high quality of life, Iceland attracts adventurous remote workers despite its high cost of living.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for visa application</li>
          <li>• Must cover medical treatment in Iceland</li>
          <li>• Minimum coverage: ISK 4,000,000 (~€30,000)</li>
          <li>• Policy must cover entire stay duration</li>
          <li>• International insurance accepted</li>
          <li>• Income requirement: ISK 1,000,000/month (~€7,000)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Iceland has excellent healthcare but is remote. Landspítali (the national university hospital) in Reykjavik is the main facility. For specialized care, evacuation to Copenhagen or other Nordic capitals may be necessary. Medical evacuation coverage is particularly important in Iceland.
      </p>

      <p class="text-neutral-700">
        Iceland's high cost of living extends to healthcare—even minor treatments can be expensive. Comprehensive insurance is strongly recommended. Note the high income requirement (€7,000/month) reflects Iceland's expensive lifestyle.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Iceland DNV</h2>

      <p class="text-neutral-700 mb-6">
        Iceland accepts various international insurers. Given the remote location, evacuation coverage is important:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive coverage with unlimited medical evacuation—critical for Iceland's remote location. Their worldwide coverage works well for nomads who may need to be evacuated to Copenhagen or other cities.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Unlimited medical evacuation</li>
            <li>• Direct billing at Iceland facilities</li>
            <li>• Worldwide coverage including Nordic</li>
            <li>• Pre-existing condition options</li>
            <li>• 24/7 English support</li>
            <li>• Copenhagen/London hospital access</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Higher cost than SafetyWing</li>
            <li>• Limited facilities in Iceland anyway</li>
            <li>• Premium pricing matches Iceland's costs</li>
            <li>• May be more than needed short-term</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive coverage with critical evacuation for Iceland."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing Nomad Insurance</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing offers affordable coverage that meets Iceland's requirements. At $69/month, it's budget-friendly, though the $100K evacuation limit should be considered given Iceland's remote location.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable ($69/month under 40)</li>
            <li>• Exceeds ISK 4,000,000 minimum</li>
            <li>• Accepted for Iceland visa</li>
            <li>• Medical evacuation included ($100K)</li>
            <li>• Month-to-month flexibility</li>
            <li>• Simple claims process</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No direct billing—pay and claim</li>
            <li>• $100K evacuation may be limiting</li>
            <li>• Pre-existing conditions not covered</li>
            <li>• $250 deductible per incident</li>
            <li>• Search & rescue not covered</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget nomad insurance starting at $69/month."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers European-focused coverage with good Nordic networks. Their plans work well for nomads planning to explore Scandinavia and the Nordics from Iceland.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong Nordic/Scandinavian network</li>
            <li>• Direct billing in Europe</li>
            <li>• Medical evacuation included</li>
            <li>• Pre-existing condition options</li>
            <li>• European-based support</li>
            <li>• Good for Nordic exploration</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Similar pricing to Cigna</li>
            <li>• Iceland network limited regardless</li>
            <li>• Claims processing time</li>
            <li>• Plan complexity</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="European coverage with Nordic networks."
        buttonText="Get Quote"
        buttonHref="/go/allianz"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares. Evacuation is particularly important for Iceland:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Medical evacuation coverage is critical in Iceland. The island is remote, and specialized care may require transfer to Copenhagen, London, or other cities. Ensure your policy has adequate evacuation limits.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically cheaper, but consider Iceland's remoteness:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Given Iceland's high cost of living (€7,000/month income requirement), nomads who qualify likely have budget for comprehensive coverage. SafetyWing works for healthy adventurers comfortable with some risk.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Iceland</h2>

      <p class="text-neutral-700 mb-6">
        Iceland's healthcare is concentrated in Reykjavik. Regional options are very limited:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Landspítali in Reykjavik is Iceland's main hospital. Outside the capital, healthcare facilities are basic. For serious conditions, evacuation to Copenhagen (3-hour flight) is common. Ensure your insurance covers this scenario.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Summer Nomad in Reykjavik</h3>
          <p class="text-neutral-600 mb-3">30-year-old software engineer, healthy, 3-month summer stay.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">For a short healthy summer stay in Reykjavik, SafetyWing's $69/month covers basics. You're in the capital with access to Landspítali. The $100K evacuation limit is reasonable for a 3-month stay.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Adventure Activities Planned</h3>
          <p class="text-neutral-600 mb-3">28-year-old planning glacier hiking, ice climbing, exploring highlands.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global + adventure activity coverage</p>
          <p class="text-neutral-600 text-sm">Adventure activities in Iceland carry real risk. Glacier rescue can cost €20,000+. Cigna's unlimited evacuation is valuable. Verify your specific activities are covered—some may require additional adventure sports coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Exploring Beyond Reykjavik</h3>
          <p class="text-neutral-600 mb-3">35-year-old planning road trips around Iceland, staying in rural areas.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Rural Iceland has minimal healthcare. If something happens on the Ring Road, you may need helicopter evacuation to Reykjavik or beyond. Cigna's unlimited evacuation provides security for remote exploration.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Pre-existing Health Condition</h3>
          <p class="text-neutral-600 mb-3">42-year-old with managed chronic condition.</p>
          <p class="text-amber-700 font-medium">Recommendation: Reconsider Iceland or use Cigna Global</p>
          <p class="text-neutral-600 text-sm">Iceland's remoteness makes pre-existing conditions higher risk. If you proceed, Cigna's moratorium option covers after waiting period. Have a plan for managing your condition with limited local specialists.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Nordic Region Exploration</h3>
          <p class="text-neutral-600 mb-3">38-year-old using Iceland as base for Nordic exploration (Norway, Denmark, Sweden).</p>
          <p class="text-green-700 font-medium">Recommendation: Allianz Care</p>
          <p class="text-neutral-600 text-sm">If you're exploring the Nordic region, Allianz's European network shines. Good coverage throughout Scandinavia, direct billing in major Nordic cities, and comprehensive protection for your regional travels.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        Iceland's remoteness makes medical evacuation coverage more important than most destinations. <strong>Cigna Global</strong> is the safest choice with unlimited evacuation. <strong>SafetyWing</strong> works for healthy nomads staying mainly in Reykjavik with limited adventure activities. <strong>Allianz Care</strong> suits those exploring the broader Nordic region.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Planning adventure activities</li>
            <li>• Exploring rural Iceland</li>
            <li>• Want evacuation certainty</li>
            <li>• Have health conditions</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Young and healthy</li>
            <li>• Staying in Reykjavik</li>
            <li>• Short-term stay</li>
            <li>• Budget-conscious</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz Care If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Nordic region exploration</li>
            <li>• Prefer European insurer</li>
            <li>• Want Scandinavian network</li>
            <li>• European-based support</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Why is medical evacuation so important in Iceland?</h3>
          <p class="text-neutral-600">Iceland is a remote island with limited medical facilities. Landspítali is the only major hospital. For specialized care (cardiac surgery, complex trauma, cancer treatment), patients are typically evacuated to Copenhagen or other cities. Without insurance, evacuation costs €30,000-100,000+.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Does insurance cover search and rescue in Iceland?</h3>
          <p class="text-neutral-600">Iceland's search and rescue (ICE-SAR) is volunteer-based and typically free for rescues. However, medical treatment and helicopter transport for injuries are not free. Most travel insurance doesn't cover "search and rescue" as a separate benefit—it covers medical evacuation once you're found. Check your specific policy.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about adventure activities like glacier hiking?</h3>
          <p class="text-neutral-600">Many insurance policies exclude "hazardous activities." Glacier hiking, ice climbing, and similar activities may not be covered under standard policies. Cigna and Allianz offer adventure activity add-ons. SafetyWing covers some activities but has exclusions—check their list. Always verify coverage before activities.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is Iceland in the Schengen zone?</h3>
          <p class="text-neutral-600">Yes, Iceland is in the Schengen area (though not the EU). Your Schengen-compliant insurance covers Iceland plus the 26 other Schengen countries. This is required for the visa anyway—minimum €30,000 coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How expensive is healthcare in Iceland?</h3>
          <p class="text-neutral-600">Very expensive. A GP visit costs ISK 5,000-10,000 (€35-70). Emergency room visits ISK 20,000+ (€140+). Hospital stays are several hundred euros per day. Prescriptions are also expensive. Insurance is essential—even minor issues can cost hundreds of euros.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use Iceland's public healthcare?</h3>
          <p class="text-neutral-600">As a nomad visa holder, you don't automatically qualify for Iceland's public healthcare system. You must maintain private insurance. Emergency care is available but you'll be billed. There are no bilateral healthcare agreements for most nomad source countries.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Iceland visa requirements can change. Verify current requirements with the Icelandic Directorate of Immigration. Confirm policy coverage for adventure activities and evacuation directly with insurers. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
