---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'european-coverage', text: 'European Healthcare Access', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/countries/spain/insurance', text: 'Spain Insurance Guide' },
  { href: '/countries/portugal/insurance', text: 'Portugal Insurance Guide' },
  { href: '/countries/france/insurance', text: 'France Insurance Guide' },
  { href: '/visas/digital-nomad/in/spain', text: 'Spain Digital Nomad Visa' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'European Hospital Network', cigna: '5,000+ hospitals', bupa: '4,500+ hospitals', allianz: '4,200+ hospitals' },
  { feature: 'EU Direct Billing', cigna: 'Excellent', bupa: 'Excellent', allianz: 'Very Good' },
  { feature: 'Schengen Compliance', cigna: 'Yes', bupa: 'Yes', allianz: 'Yes' },
  { feature: 'UK Coverage Post-Brexit', cigna: 'Included', bupa: 'Full coverage', allianz: 'Included' },
  { feature: 'Multi-Country Plans', cigna: 'Worldwide/Regional', bupa: 'Worldwide/Regional', allianz: 'Worldwide/Regional' },
  { feature: 'Local Language Support', cigna: '15+ languages', bupa: '12+ languages', allianz: '20+ languages' },
  { feature: 'Minimum Term', cigna: '12 months', bupa: '12 months', allianz: '12 months' },
  { feature: 'Online Claims', cigna: 'Yes + app', bupa: 'Yes + app', allianz: 'Yes + app' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Individual (35, comprehensive)', cigna: '$280-380/mo', bupa: '$300-420/mo', allianz: '$260-350/mo' },
  { profile: 'Couple (40s)', cigna: '$520-700/mo', bupa: '$570-780/mo', allianz: '$480-650/mo' },
  { profile: 'Family (2 adults + 2 kids)', cigna: '$800-1,100/mo', bupa: '$900-1,250/mo', allianz: '$750-1,000/mo' },
  { profile: 'Senior (60)', cigna: '$550-750/mo', bupa: '$620-850/mo', allianz: '$500-680/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Europe | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for European expats. Expert analysis of hospital networks, Schengen compliance, and EU coverage for 2025."
  headline="Cigna vs Bupa vs Allianz: Best Insurance for European Expats"
  subheadline="Complete comparison of three leading providers for expats living in Europe—from hospital networks to Schengen compliance and multi-country coverage."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Hospital Network</p>
        <p class="text-neutral-700 text-sm mb-4">Largest European hospital network with excellent direct billing across all EU countries and seamless UK coverage.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best for UK Expats</p>
        <p class="text-neutral-700 text-sm mb-4">Strong UK heritage makes Bupa ideal for British expats in Europe or those frequently traveling between UK and EU.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Value + Language Support</p>
        <p class="text-neutral-700 text-sm mb-4">Most competitive pricing and exceptional multilingual support across 20+ European languages.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Largest EU Network</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Excellent Direct Billing</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">24/7 Multilingual Support</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most extensive hospital network in Europe, with over 5,000 partner facilities across all EU member states. Their European team is headquartered in Belgium with regional offices in Spain, UK, and Germany, ensuring local expertise and time-zone appropriate support.</p>

    <p class="text-neutral-700 mb-4">Direct billing works seamlessly at major hospitals in every European country, and their mobile app provides instant access to the nearest network providers wherever you are. The claims process is particularly efficient for European members, typically processing reimbursements within 5-7 business days.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Europe</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Largest hospital network (5,000+)</li>
          <li>• Excellent coverage in Eastern Europe</li>
          <li>• Strong direct billing relationships</li>
          <li>• Seamless UK-EU coverage</li>
          <li>• 24/7 support in 15+ languages</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher premiums than Allianz</li>
          <li>• 12-month minimum commitment</li>
          <li>• Some rural areas limited network</li>
          <li>• Wellness benefits vary by plan</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">UK Heritage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Service</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Strong UK-EU Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's British heritage makes them the natural choice for UK nationals moving to Europe or European expats who frequently travel to the UK. Post-Brexit, Bupa has invested heavily in maintaining seamless coverage across both regions, with dedicated teams handling cross-border claims and coordination.</p>

    <p class="text-neutral-700 mb-4">Their European network includes 4,500+ hospitals with particularly strong relationships in Spain, France, and Portugal—popular destinations for British expats. The Bupa Global app provides real-time access to your policy details, digital ID cards, and one-click direct billing authorization.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Europe</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best for UK-EU coverage</li>
          <li>• Strong network in Western Europe</li>
          <li>• Premium service experience</li>
          <li>• Excellent chronic condition management</li>
          <li>• Dedicated expat support teams</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums of the three</li>
          <li>• Smaller Eastern European network</li>
          <li>• Less competitive for non-UK expats</li>
          <li>• Some plans have UK residency requirements</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">20+ Languages</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">German Engineering</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care combines German engineering precision with the most competitive pricing for European coverage. Their multilingual support spans 20+ European languages—more than any competitor—making them ideal for expats navigating different healthcare systems across multiple countries.</p>

    <p class="text-neutral-700 mb-4">Based in Munich with offices across Europe, Allianz understands the European healthcare landscape intimately. Their network of 4,200+ hospitals covers all major cities and regions, with particularly strong relationships in Germany, Austria, Switzerland, and the Benelux countries.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Europe</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most competitive pricing</li>
          <li>• 20+ language support</li>
          <li>• Strong Central European network</li>
          <li>• Excellent Schengen compliance</li>
          <li>• Flexible plan customization</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Smaller UK network than Bupa</li>
          <li>• Direct billing less comprehensive</li>
          <li>• Claims processing slightly slower</li>
          <li>• Customer service varies by region</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare European Coverage Quotes"
    description="Get personalized quotes from all three providers to find the best coverage for your European lifestyle."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">European coverage pricing varies based on age, country of residence, and plan level. These estimates are for comprehensive coverage with €1,000 deductible:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Prices vary by specific country within Europe. Southern and Eastern European countries typically have lower premiums than Northern Europe.</p>
  </section>

  <section id="european-coverage" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">European Healthcare Access</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Schengen Compliance</h3>
        <p class="text-neutral-700 text-sm mb-4">All three providers offer plans that meet Schengen visa insurance requirements: minimum €30,000 medical coverage, repatriation coverage, and validity across all Schengen states.</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Cigna: Automatic compliance on all plans</li>
          <li>• Bupa: Certificate available on request</li>
          <li>• Allianz: Pre-formatted Schengen certificates</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Post-Brexit UK Coverage</h3>
        <p class="text-neutral-700 text-sm mb-4">Since Brexit, private insurance is essential for expats moving between UK and EU. All three providers have adapted their policies:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Cigna: UK included in worldwide plans</li>
          <li>• Bupa: Seamless UK-EU coverage (best option)</li>
          <li>• Allianz: UK add-on available for EU plans</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Multi-Country European Coverage</h3>
      <p class="text-blue-700 mb-4">For expats living in multiple European countries or frequently relocating within Europe:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">Europe-wide plan with single premium covering all EU/EEA countries. Change country of residence without policy changes.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">Regional Europe plan with UK inclusion. Requires notification of primary residence country for pricing.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Allianz</h4>
          <p class="text-blue-700 text-sm">Flexible area selection—choose specific countries or regions for more accurate pricing.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You need the largest possible hospital network across Europe</li>
          <li>• You'll be living in or traveling to Eastern European countries</li>
          <li>• Seamless direct billing is a priority</li>
          <li>• You want 24/7 support in multiple European languages</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You're a UK national moving to Europe or vice versa</li>
          <li>• You frequently travel between the UK and EU</li>
          <li>• Premium service and chronic condition management are priorities</li>
          <li>• You're settling in Spain, France, or Portugal</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a significant consideration</li>
          <li>• You need support in less common European languages</li>
          <li>• You're based in Central Europe (Germany, Austria, Switzerland)</li>
          <li>• You want flexible plan customization</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my EHIC/GHIC card alongside private insurance?</h3>
        <p class="text-neutral-700">Yes, you can use your European Health Insurance Card for public healthcare access while maintaining private insurance for faster access, private facilities, and comprehensive coverage. Private insurance often reimburses the difference between public and private care.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What happens if I move between European countries?</h3>
        <p class="text-neutral-700">All three providers allow country changes within Europe without losing coverage. Cigna and Allianz typically don't adjust premiums for EU moves, while Bupa may recalculate based on your new residence country. Notify your insurer within 30 days of relocating.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do these plans meet visa requirements for European countries?</h3>
        <p class="text-neutral-700">Yes, comprehensive plans from all three providers meet requirements for Digital Nomad Visas, retirement visas, and long-stay permits across European countries. Request a coverage certificate confirming minimum requirements are met when applying.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does coverage work in Switzerland?</h3>
        <p class="text-neutral-700">Switzerland isn't in the EU but all three providers include it in European plans. Note that Swiss healthcare is expensive—ensure your plan has adequate coverage limits. Cigna and Allianz have strong Swiss networks; Bupa covers Switzerland but with fewer direct billing arrangements.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. The information provided is based on publicly available data and may not reflect current offerings. Always verify details directly with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
