---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "SafetyWing vs Allianz vs IMG: Best International Health Insurance for Sabbatical & Career Breaks";
const description = "Compare SafetyWing, Allianz Care, and IMG Global for professionals on sabbatical, career breaks, and extended travel. Coverage for gap years and round-the-world trips.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Flexibility', safetywing: 'Monthly', allianz: '6-month min', img: 'Flexible' },
  { feature: 'Global Coverage', safetywing: 'Worldwide', allianz: 'Worldwide', img: 'Worldwide' },
  { feature: 'Mental Health', safetywing: 'Limited', allianz: 'Good', img: 'Limited' },
  { feature: 'Adventure Activities', safetywing: 'Many covered', allianz: 'Check policy', img: 'Some covered' },
  { feature: 'Home Country Visits', safetywing: 'Limited', allianz: 'Included', img: 'Varies' },
  { feature: 'Return-to-Work Ready', safetywing: 'Easy cancel', allianz: 'Flexible', img: 'Flexible' },
  { feature: 'Starting Price', safetywing: '$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', safetywing: 'Up to $250K', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', safetywing: 'Emergency only', allianz: 'Comprehensive', img: 'Plan dependent' },
  { coverage: 'Mental Health', safetywing: 'Limited', allianz: 'Annual limits', img: 'Limited' },
  { coverage: 'Adventure Sports', safetywing: 'Many included', allianz: 'Check activities', img: 'Some included' },
  { coverage: 'Medical Evacuation', safetywing: 'Included', allianz: 'Included', img: 'Included' },
  { coverage: 'Pre-existing Conditions', safetywing: 'Excluded', allianz: 'Moratorium', img: 'Excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: '6-month sabbatical, age 32', safetywing: '$280-350', allianz: '$1,400-1,900', img: '$850-1,200' },
  { profile: '12-month career break, age 38', safetywing: '$550-700', allianz: '$2,800-3,800', img: '$1,700-2,400' },
  { profile: '6-month gap year, age 28', safetywing: '$260-330', allianz: '$1,200-1,700', img: '$750-1,050' },
  { profile: 'Couple, 12-month trip, both 35', safetywing: '$1,100-1,400', allianz: '$5,200-7,200', img: '$3,200-4,400' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'sabbatical-considerations', text: 'Sabbatical Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-blue-800 text-sm">You want the most affordable coverage with maximum flexibility, perfect for budget-conscious sabbaticals where you're healthy and don't expect ongoing health needs.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want comprehensive coverage with proper outpatient access, mental health support for career transition stress, and coverage that feels more like "real" insurance.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You want a middle-ground option with flexible terms, decent hospitalization coverage, and moderate pricing for medium-length sabbaticals.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Sabbaticals and career breaks are increasingly common—professionals taking 6-12 months (or longer) for travel, reflection, or personal projects. Insurance needs differ from permanent expat coverage: maximum flexibility, adventure activity coverage, and easy return to normal life when the break ends.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing is the go-to choice for budget sabbaticals, offering maximum flexibility and affordability. Their monthly subscription model perfectly suits the uncertain timelines of career breaks and round-the-world trips.</p>

      <h3>Strengths for Sabbaticals</h3>
      <ul>
        <li>Most affordable option by far</li>
        <li>Monthly subscription—adjust as plans change</li>
        <li>Many adventure activities included</li>
        <li>Global coverage for multi-destination trips</li>
        <li>Easy enrollment and cancellation</li>
        <li>Popular in sabbatical/nomad community</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Emergency-only outpatient—no routine care</li>
        <li>Limited mental health coverage</li>
        <li>$250K limit may concern some</li>
        <li>Limited home country coverage</li>
        <li>Pre-existing conditions excluded</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides comprehensive coverage that feels more like traditional insurance—proper outpatient access, mental health support, and home country coverage. Their 6-month minimum suits longer sabbaticals.</p>

      <h3>Strengths for Sabbaticals</h3>
      <ul>
        <li>Comprehensive outpatient coverage</li>
        <li>Mental health support for career transition</li>
        <li>6-month minimum suits longer breaks</li>
        <li>Home country visits covered</li>
        <li>Feels like "real" insurance</li>
        <li>Good for those with health considerations</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Significantly higher cost than SafetyWing</li>
        <li>6-month minimum may exceed some trips</li>
        <li>Adventure activities need verification</li>
        <li>Mental health has annual session limits</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers a middle ground—more comprehensive than SafetyWing, more affordable than Allianz. Their flexible terms suit sabbaticals of various lengths.</p>

      <h3>Strengths for Sabbaticals</h3>
      <ul>
        <li>Moderate pricing between extremes</li>
        <li>Flexible term options</li>
        <li>Good hospitalization coverage</li>
        <li>Medical evacuation included</li>
        <li>Some adventure activities covered</li>
        <li>Easy enrollment</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Outpatient coverage varies by plan</li>
        <li>Limited mental health</li>
        <li>Pre-existing conditions excluded</li>
        <li>Less known brand than others</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Sabbatical insurance priorities include emergency coverage, adventure activity inclusion, and flexibility. Whether you need comprehensive outpatient care depends on your health situation and risk tolerance.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Sabbatical budgets are often tight—you're not earning full income. SafetyWing's dramatic affordability is compelling. The question is whether budget savings justify coverage limitations for your specific situation.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by age, health history, and coverage options. SafetyWing's monthly model means costs can be adjusted as trip length changes.</p>
    </section>

    <section id="sabbatical-considerations" class="mb-12">
      <h2>Sabbatical Considerations</h2>

      <h3>Flexibility for Changing Plans</h3>
      <p>Sabbatical plans often evolve—you might extend, cut short, or change destinations. SafetyWing's monthly model accommodates this perfectly. IMG offers good flexibility. Allianz's 6-month minimum means committing to longer coverage periods.</p>

      <h3>Adventure Activities</h3>
      <p>Many sabbaticals include adventure—hiking, diving, skiing, surfing. Verify your planned activities are covered. SafetyWing includes many adventures. Allianz and IMG have activity lists requiring verification. Extreme activities may need supplemental adventure insurance.</p>

      <h3>Career Transition Stress</h3>
      <p>Stepping away from careers causes mixed emotions—excitement but also anxiety about return, identity questions, and uncertainty. Mental health support helps navigate this transition. Allianz provides this; SafetyWing and IMG are limited.</p>

      <h3>Home Country Coverage</h3>
      <p>Most sabbaticals include visits home. SafetyWing has limited home country coverage. Allianz includes home visits. IMG varies by plan. If you'll spend significant time home, factor this into your choice.</p>

      <h3>Returning to Work</h3>
      <p>Sabbaticals end. You need coverage that transitions smoothly back to regular life. SafetyWing cancels easily. Allianz and IMG can be ended when employer coverage resumes. Consider transition logistics when planning.</p>

      <h3>Budget Reality</h3>
      <p>Sabbaticals often involve reduced income. SafetyWing's affordability makes comprehensive emergency coverage accessible on tight budgets. The gap to Allianz's comprehensive coverage is significant. Choose based on your actual health needs and risk tolerance.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Budget sabbaticals</li>
            <li>• Healthy young travelers</li>
            <li>• Uncertain trip lengths</li>
            <li>• Adventure-focused trips</li>
            <li>• Round-the-world travel</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Longer sabbaticals (6+ months)</li>
            <li>• Those with health considerations</li>
            <li>• Those wanting mental health support</li>
            <li>• Frequent home visits planned</li>
            <li>• Those preferring comprehensive coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Medium-length breaks</li>
            <li>• Moderate budget sabbaticals</li>
            <li>• Those wanting middle ground</li>
            <li>• Good hospitalization priority</li>
            <li>• Flexible term needs</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I extend coverage if I extend my sabbatical?</h3>
          <p class="text-neutral-700">Yes. SafetyWing automatically renews monthly—coverage continues as long as you pay. Allianz and IMG can be extended by contacting them. Plan for flexibility since sabbaticals often run longer than initially planned.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What happens when I return to work?</h3>
          <p class="text-neutral-700">Cancel your sabbatical insurance when employer coverage resumes. SafetyWing cancels easily anytime. Allianz may have notice requirements. Ensure no gap between sabbatical coverage ending and work coverage starting.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are adventure activities covered?</h3>
          <p class="text-neutral-700">SafetyWing covers many adventure activities by default. Allianz and IMG have activity lists—verify your planned adventures are included. Extreme activities (skydiving, mountaineering, etc.) may need supplemental adventure insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I keep my home country health insurance during sabbatical?</h3>
          <p class="text-neutral-700">It depends on your system. If you have employer coverage, it typically ends when you leave. Private domestic insurance might be pauseable. International sabbatical insurance covers you abroad but may have limited home coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is mental health coverage important for sabbaticals?</h3>
          <p class="text-neutral-700">Consider it. Career breaks involve identity questions, uncertainty about return, and sometimes loneliness or anxiety. If you anticipate needing mental health support, Allianz provides this. SafetyWing and IMG are limited.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What if I get sick abroad—can I see a doctor?</h3>
          <p class="text-neutral-700">SafetyWing covers emergency outpatient only—not routine doctor visits. Allianz provides comprehensive outpatient access. IMG varies by plan. If you expect ongoing health needs, choose comprehensive outpatient coverage.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
