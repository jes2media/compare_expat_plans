---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "AXA vs Bupa vs SafetyWing: Best International Health Insurance for Hospitality & Tourism Professionals";
const description = "Compare AXA Global Healthcare, Bupa Global, and SafetyWing for hospitality workers, hotel managers, and tourism professionals working internationally.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mainComparisonRows = [
  { feature: 'Premium Level', axa: 'Premium', bupa: 'Premium', safetywing: 'Budget' },
  { feature: 'Mental Health', axa: 'Comprehensive', bupa: 'Unlimited', safetywing: 'Limited' },
  { feature: 'Global Coverage', axa: 'Excellent', bupa: 'Excellent', safetywing: 'Good' },
  { feature: 'Physical Injury', axa: 'Full coverage', bupa: 'Full coverage', safetywing: 'Emergency only' },
  { feature: 'Seasonal Flexibility', axa: '12-month min', bupa: 'Annual', safetywing: 'Monthly' },
  { feature: 'Wellness Programs', axa: 'Strong', bupa: 'Comprehensive', safetywing: 'Not included' },
  { feature: 'Starting Price', axa: '$$$', bupa: '$$$', safetywing: '$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const coverageRows = [
  { coverage: 'Inpatient', axa: 'Full coverage', bupa: 'Full coverage', safetywing: 'Up to $250K' },
  { coverage: 'Outpatient', axa: 'Comprehensive', bupa: 'Comprehensive', safetywing: 'Emergency only' },
  { coverage: 'Mental Health', axa: 'Full coverage', bupa: 'Unlimited sessions', safetywing: 'Limited' },
  { coverage: 'Physical Therapy', axa: 'Covered', bupa: 'Covered', safetywing: 'Not included' },
  { coverage: 'Preventive Care', axa: 'Health screenings', bupa: 'Comprehensive', safetywing: 'Not included' },
  { coverage: 'Pre-existing Conditions', axa: 'Underwritten', bupa: 'Underwritten', safetywing: 'Excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const pricingRows = [
  { profile: 'Front desk staff, 25', axa: '$2,800-3,800/yr', bupa: '$3,000-4,100/yr', safetywing: '$500-650/yr' },
  { profile: 'Restaurant manager, 35', axa: '$3,800-5,200/yr', bupa: '$4,100-5,600/yr', safetywing: '$650-850/yr' },
  { profile: 'Hotel GM, 45', axa: '$5,200-7,000/yr', bupa: '$5,600-7,600/yr', safetywing: '$850-1,100/yr' },
  { profile: 'Hospitality exec + family', axa: '$14,000-19,000/yr', bupa: '$15,000-20,500/yr', safetywing: '$2,100-2,700/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'hospitality-considerations', text: 'Hospitality Professional Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Service Workers', href: '/insurance-for/service-workers' },
  { title: 'AXA Global Review', href: '/providers/axa' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-blue-800 text-sm">You want comprehensive coverage with strong wellness programs, good mental health support, and slightly more competitive pricing than Bupa for hospitality management roles.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You want the most premium coverage with unlimited mental health sessions—essential for the high-stress hospitality industry—and comprehensive wellness programs.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-purple-800 text-sm">You're starting in hospitality, working seasonal positions, or need affordable basic coverage while building your international career.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Hospitality and tourism professionals face unique challenges: long hours, physical demands, guest-facing stress, and often seasonal or contract-based work. International hotel and resort positions may include employer benefits, but coverage quality varies. Individual insurance ensures consistent protection.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global offers comprehensive coverage with strong wellness programs suited to the demanding hospitality industry. Their mental health coverage and preventive care help professionals maintain health despite challenging schedules.</p>

      <h3>Strengths for Hospitality Professionals</h3>
      <ul>
        <li>Comprehensive mental health coverage for industry stress</li>
        <li>Strong wellness and preventive care programs</li>
        <li>Physical therapy coverage for job-related strain</li>
        <li>Global network in tourist destinations worldwide</li>
        <li>24/7 support matching hospitality schedules</li>
        <li>Slightly more competitive than Bupa</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>12-month minimum commitment</li>
        <li>Premium pricing—may strain entry-level budgets</li>
        <li>Some conditions may be excluded after underwriting</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global represents the premium tier for hospitality professionals, with unlimited mental health coverage addressing the high-stress nature of the industry and comprehensive wellness programs for maintaining health.</p>

      <h3>Strengths for Hospitality Professionals</h3>
      <ul>
        <li>Unlimited mental health sessions—ideal for demanding industry</li>
        <li>Comprehensive wellness programs</li>
        <li>Full physical therapy coverage</li>
        <li>Premium networks at resort destinations globally</li>
        <li>Second medical opinion services</li>
        <li>Excellent family coverage for relocated managers</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums—may require employer contribution</li>
        <li>Annual commitment required</li>
        <li>May exceed needs for seasonal or entry-level positions</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing offers budget-friendly coverage popular among seasonal hospitality workers and those building international careers. Their monthly flexibility aligns with the often-variable nature of hospitality employment.</p>

      <h3>Strengths for Hospitality Professionals</h3>
      <ul>
        <li>Most affordable option by far</li>
        <li>Monthly subscription—perfect for seasonal work</li>
        <li>Good basic emergency coverage</li>
        <li>Global coverage for resort destinations</li>
        <li>Simple enrollment process</li>
        <li>Can pause between seasonal contracts</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health coverage—significant gap for stressful industry</li>
        <li>No physical therapy—problematic for physical work</li>
        <li>Emergency-only outpatient</li>
        <li>$250K limit may concern some</li>
        <li>No preventive care</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Key coverage for hospitality includes mental health (industry has high burnout rates), physical therapy (long hours on feet cause strain), and comprehensive outpatient care for ongoing health maintenance.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Hospitality salaries vary widely—from modest entry-level wages to substantial executive compensation. Many international hotels provide health benefits; verify your package before purchasing individual coverage.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by location, age, health history, and coverage level. International hotel chains often provide health insurance—verify employer benefits.</p>
    </section>

    <section id="hospitality-considerations" class="mb-12">
      <h2>Hospitality Professional Considerations</h2>

      <h3>Industry Burnout</h3>
      <p>Hospitality has among the highest burnout rates of any industry—long hours, demanding guests, thin profit margins, and constant pressure. Mental health support isn't optional; it's essential. Bupa's unlimited sessions or AXA's comprehensive coverage address this need. SafetyWing's limited coverage is a significant gap.</p>

      <h3>Physical Demands</h3>
      <p>Hospitality work is physical—hours on your feet, repetitive motions, lifting, and constant activity. Musculoskeletal issues, back problems, and repetitive strain are common. Physical therapy coverage matters. AXA and Bupa cover this; SafetyWing doesn't.</p>

      <h3>Irregular Schedules</h3>
      <p>Hospitality schedules are unpredictable—split shifts, nights, weekends, holidays. This affects health access. 24/7 support services help schedule care around work demands. Telemedicine options available with premium insurers provide flexibility.</p>

      <h3>Seasonal Employment</h3>
      <p>Many hospitality positions are seasonal—ski resorts, beach destinations, cruise ships. SafetyWing's monthly model lets you maintain coverage only during employment. For year-round positions, annual plans from AXA or Bupa make more sense.</p>

      <h3>Global Mobility</h3>
      <p>International hospitality careers often involve moves between properties and countries. Insurance should work regardless of location. All three providers offer global coverage, ensuring continuity as you move between assignments.</p>

      <h3>Employer-Provided Benefits</h3>
      <p>Major hotel chains often provide health insurance for management positions. Verify what your employer offers before purchasing individual coverage. Individual plans may supplement employer benefits or provide coverage during transitions.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Hotel general managers</li>
            <li>• Resort directors</li>
            <li>• F&B management</li>
            <li>• Those seeking value premium coverage</li>
            <li>• Hospitality executives</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Senior hospitality executives</li>
            <li>• Those prioritizing mental health</li>
            <li>• Managers with families abroad</li>
            <li>• Premium coverage seekers</li>
            <li>• Those with employer contributions</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Seasonal hospitality workers</li>
            <li>• Entry-level international staff</li>
            <li>• Young professionals abroad</li>
            <li>• Budget-conscious workers</li>
            <li>• Between-position coverage</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do international hotels typically provide health insurance?</h3>
          <p class="text-neutral-700">Major hotel chains usually provide health insurance for management positions. Coverage quality varies significantly. Entry-level and seasonal positions may have limited or no benefits. Verify your specific employment package.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is mental health coverage important in hospitality?</h3>
          <p class="text-neutral-700">Extremely important. Hospitality has high burnout rates due to long hours, guest demands, and high-pressure environments. Access to therapy and mental health support helps maintain wellbeing and career longevity.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage for physical strain injuries?</h3>
          <p class="text-neutral-700">Physical therapy coverage matters for hospitality work. AXA and Bupa include comprehensive rehabilitation. SafetyWing doesn't cover physical therapy—a significant gap for this physically demanding industry.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I pause SafetyWing between seasonal contracts?</h3>
          <p class="text-neutral-700">Yes, SafetyWing's monthly model lets you maintain coverage during employment and pause during off-seasons. This flexibility suits seasonal hospitality work, though be aware coverage gaps affect pre-existing condition rules.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does coverage transfer if I move to a different property abroad?</h3>
          <p class="text-neutral-700">Yes, all three providers offer global coverage that transfers between locations. Hospitality careers often involve international moves—your insurance continues regardless of which country you're assigned to.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I get individual insurance if my employer provides coverage?</h3>
          <p class="text-neutral-700">Review employer coverage carefully. If it's comprehensive, you may not need individual insurance. If it has gaps—limited mental health, no family coverage, or only emergency care—consider supplementing with individual coverage.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
