---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'axa', text: 'AXA Global', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'pricing', text: 'Family Pricing', level: 2 },
  { id: 'family-considerations', text: 'Family Coverage Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Allianz Care Full Review', href: '/providers/allianz-care' },
  { title: 'AXA Global Full Review', href: '/providers/axa-global' },
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'Insurance for Expat Families', href: '/insurance-for/families' },
  { title: 'Best Family Expat Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const mainComparisonRows = [
  { feature: 'Children included free', allianz: 'Up to 2 children', axa: 'Up to 2 children', cigna: 'Up to 2 children' },
  { feature: 'Maternity coverage', allianz: '12-month wait', axa: '10-month wait', cigna: '12-month wait' },
  { feature: 'Newborn coverage', allianz: 'From birth—automatic', axa: 'From birth—30 days to add', cigna: 'From birth—automatic' },
  { feature: 'Pediatric network', allianz: 'Strong globally', axa: 'Good in Europe', cigna: 'Excellent worldwide' },
  { feature: 'Vaccinations', allianz: 'Covered—wellness plans', axa: 'Covered—higher tiers', cigna: 'Covered—most plans' },
  { feature: 'Dental for children', allianz: 'Optional add-on', axa: 'Optional add-on', cigna: 'Optional add-on' },
  { feature: 'Mental health (teens)', allianz: 'Good coverage', axa: 'Standard coverage', cigna: 'Strong coverage' },
  { feature: 'Family deductible cap', allianz: 'Yes—2x individual', axa: 'Yes—2x individual', cigna: 'Yes—family maximum' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Family Scenario' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const pricingRows = [
  { scenario: '2 adults (35), 1 child', allianz: '$6,500-9,000/yr', axa: '$6,000-8,500/yr', cigna: '$7,000-9,500/yr' },
  { scenario: '2 adults (35), 2 children', allianz: '$6,500-9,000/yr', axa: '$6,000-8,500/yr', cigna: '$7,000-9,500/yr' },
  { scenario: '2 adults (40), 3 children', allianz: '$8,500-12,000/yr', axa: '$8,000-11,500/yr', cigna: '$9,000-12,500/yr' },
  { scenario: 'Add maternity rider', allianz: '+$2,000-4,000/yr', axa: '+$1,800-3,500/yr', cigna: '+$2,200-4,500/yr' },
  { scenario: 'Add dental (family)', allianz: '+$1,200-2,000/yr', axa: '+$1,000-1,800/yr', cigna: '+$1,400-2,200/yr' },
];
---

<PageShell
  title="Allianz vs AXA vs Cigna: Best for Expat Families 2025"
  description="Compare Allianz, AXA, and Cigna for expat families. Maternity coverage, children's benefits, pediatric networks, and family pricing compared."
  headline="Allianz vs AXA vs Cigna: Best for Expat Families"
  subheadline="Which insurer offers the best coverage for families living abroad? Children's coverage, maternity, and family-friendly features compared."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Overall for Families</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Excellent pediatric network worldwide. Strong mental health coverage for teens. Automatic newborn coverage from birth.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">AXA Global</p>
      <p class="text-sm text-neutral-600 mb-3">Most affordable family premiums. Shorter maternity waiting period (10 months). Good European pediatric network.</p>
      <a href="/providers/axa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best Wellness Benefits</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Allianz Care</p>
      <p class="text-sm text-neutral-600 mb-3">Comprehensive wellness programs. Strong vaccination coverage. Good preventive care for children.</p>
      <a href="/providers/allianz-care" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="allianz">Allianz Care</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Allianz Care offers comprehensive family coverage with strong wellness benefits. Their preventive care focus makes them attractive for families who want to keep kids healthy rather than just treating illness.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Family Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Up to 2 children covered free on family plans</li>
      <li>Comprehensive wellness and vaccination coverage</li>
      <li>Strong global pediatric network</li>
      <li>Automatic newborn coverage from birth</li>
      <li>Good preventive care benefits</li>
      <li>Family deductible cap (2x individual max)</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>12-month maternity waiting period</li>
      <li>Dental requires separate add-on</li>
      <li>Premium pricing compared to AXA</li>
      <li>Some regions have weaker networks</li>
    </ul>
  </div>

  <h2 id="axa">AXA Global Healthcare</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">AXA Global offers the most affordable family premiums among major international insurers. Their shorter maternity waiting period (10 months vs 12) helps families planning to expand abroad.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Family Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most competitive family pricing</li>
      <li>Shorter maternity waiting period (10 months)</li>
      <li>Up to 2 children covered free</li>
      <li>Strong European pediatric network</li>
      <li>Good family value overall</li>
      <li>Flexible plan options</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Must add newborn within 30 days</li>
      <li>Vaccination coverage varies by plan level</li>
      <li>Mental health coverage less comprehensive</li>
      <li>Network weaker outside Europe</li>
    </ul>
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global offers the strongest worldwide pediatric network and excellent mental health coverage—increasingly important for expat teens. Their comprehensive approach makes them ideal for families prioritizing quality over cost.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Family Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Excellent worldwide pediatric network</li>
      <li>Strong mental health coverage (including teens)</li>
      <li>Automatic newborn coverage from birth</li>
      <li>Comprehensive vaccination coverage</li>
      <li>Up to 2 children covered free</li>
      <li>Family deductible maximum</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Highest premiums of the three</li>
      <li>12-month maternity waiting period</li>
      <li>Dental requires add-on</li>
      <li>Maternity rider costs more</li>
    </ul>
  </div>

  <CTABox
    title="Find the Right Coverage for Your Family"
    description="Compare family-friendly plans with children's coverage, maternity benefits, and pediatric networks worldwide."
    buttonText="Compare Family Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Family Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Annual premiums for typical family configurations. Prices exclude US coverage—add 30-50% for US inclusion.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Prices vary by residence country, citizenship, and plan level. Most insurers include up to 2 children free; additional children add ~$500-1,500/year each.</p>

  <h2 id="family-considerations">Family Coverage Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Maternity Planning</h3>
      <p class="text-neutral-700">All three insurers have maternity waiting periods (10-12 months). If you're planning pregnancy abroad, buy coverage before conception. Maternity riders add $2,000-4,500/year but cover prenatal, delivery, and postnatal care. Without the rider, you'll pay out of pocket—hospital births abroad range from $3,000 (Thailand) to $30,000+ (US, Singapore).</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Newborn Coverage</h3>
      <p class="text-neutral-700">Cigna and Allianz automatically cover newborns from birth if you have maternity coverage. AXA requires adding the baby within 30 days. Newborn complications can be expensive—NICU stays cost $2,000-5,000/day. Ensure your policy covers newborn emergencies from day one.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Children's Mental Health</h3>
      <p class="text-neutral-700">Expat children face unique challenges—frequent moves, cultural adjustment, leaving friends. Teen mental health is increasingly important. Cigna leads here with comprehensive coverage. Allianz offers good coverage. AXA's mental health benefits are more limited. Consider this if you have older children.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Vaccinations and Preventive Care</h3>
      <p class="text-neutral-700">Children need vaccinations on schedule regardless of location. All three cover childhood vaccinations, but coverage levels vary. Allianz includes comprehensive wellness programs. Cigna covers vaccinations on most plans. AXA may require higher-tier plans for full vaccination coverage. Verify your specific plan includes pediatric preventive care.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">School and Activity Requirements</h3>
      <p class="text-neutral-700">International schools often require proof of health insurance. Some activities (sports teams, camps) need specific coverage. All three insurers provide certificates for school enrollment. Ensure your plan covers sports injuries if children participate in athletics—most standard plans do, but verify adventure sports coverage.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose Allianz If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Preventive care is priority</li>
        <li>You want wellness programs</li>
        <li>Children need regular vaccinations</li>
        <li>You value health maintenance</li>
        <li>You're in Europe or Asia</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose AXA If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is primary concern</li>
        <li>You're planning pregnancy soon</li>
        <li>You're based in Europe</li>
        <li>You want value for money</li>
        <li>Basic family coverage suffices</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Worldwide network matters</li>
        <li>You have teenagers</li>
        <li>Mental health coverage important</li>
        <li>Quality over cost is priority</li>
        <li>You move frequently</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How many children can be covered free?</h3>
      <p class="text-neutral-700">All three insurers typically include up to 2 dependent children free on family plans. Additional children add approximately $500-1,500 per year each, depending on age and plan level. Children are usually covered until age 18, or 25 if full-time students.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What if we're already pregnant?</h3>
      <p class="text-neutral-700">Pregnancy is considered a pre-existing condition. If you're already pregnant when applying, maternity won't be covered for that pregnancy. You can still get coverage for everything else, and maternity will be covered for future pregnancies after the waiting period. Plan ahead—buy coverage before conceiving.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Are childhood vaccinations covered?</h3>
      <p class="text-neutral-700">Yes, but coverage varies by plan level. Allianz includes vaccinations in their wellness programs. Cigna covers vaccinations on most plans. AXA may require higher-tier plans. Standard childhood immunization schedules are typically covered—travel vaccines and optional vaccines may have limits or require wellness add-ons.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about dental and vision for kids?</h3>
      <p class="text-neutral-700">Dental and vision are optional add-ons with all three insurers. Dental add-ons cost $300-600 per child annually and typically cover checkups, cleanings, fillings, and orthodontics (with limits). Vision coverage for glasses/contacts is usually included in dental add-ons or available separately. Consider these if your children need braces.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can children see doctors without parents present?</h3>
      <p class="text-neutral-700">Insurance allows it, but medical consent laws vary by country. Teenagers (16+) can often consent to routine care. For younger children, you'll typically need to be present or provide written authorization. All three insurers allow you to designate authorized persons who can accompany children to appointments.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What happens when children turn 18?</h3>
      <p class="text-neutral-700">Children can remain on family plans as dependents until age 18, or 25 if full-time students. After aging out, they need their own policy. All three insurers allow transition to individual plans without new underwriting if done immediately. Plan the transition—don't let coverage lapse.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Family coverage needs vary significantly. Maternity waiting periods, children's coverage limits, and pricing change regularly. Always verify specific benefits with insurers. This comparison provides general guidance—consult insurers directly for your family's specific situation.
    </p>
  </div>
</PageShell>
