---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Allianz vs AXA vs IMG: Best International Health Insurance for Short-Term Expats";
const description = "Compare Allianz Care, AXA Global Healthcare, and IMG Global for short-term assignments abroad. Analysis of coverage flexibility, minimum terms, and value for 3-12 month stays.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Minimum Term', allianz: '6 months', axa: '12 months', img: '5 days' },
  { feature: 'Short-Term Flexibility', allianz: 'Moderate', axa: 'Limited', img: 'Excellent' },
  { feature: 'Monthly Payment', allianz: 'Available', axa: 'Annual preferred', img: 'Available' },
  { feature: 'Early Termination', allianz: 'Pro-rata refund', axa: 'Restricted', img: 'Flexible' },
  { feature: 'Extension Options', allianz: 'Easy renewal', axa: 'Full underwriting', img: 'Simple extension' },
  { feature: 'Coverage Quality', allianz: 'Premium', axa: 'Premium', img: 'Good' },
  { feature: 'Starting Price', allianz: '$$-$$$', axa: '$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', allianz: 'Full coverage', axa: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', allianz: 'Optional/Included', axa: 'Optional/Included', img: 'Plan dependent' },
  { coverage: 'Pre-existing Conditions', allianz: 'Limited for short-term', axa: 'Requires underwriting', img: 'Exclusions apply' },
  { coverage: 'Emergency Evacuation', allianz: 'Included', axa: 'Included', img: 'Included' },
  { coverage: 'Trip Interruption', allianz: 'Limited', axa: 'Not included', img: 'Available' },
  { coverage: 'Maternity', allianz: 'Waiting period issues', axa: '12-month wait', img: 'Limited/None' },
];

const pricingColumns = [
  { key: 'duration', header: 'Assignment Duration' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { duration: '3 months, age 30', allianz: '$800-1,200', axa: 'N/A (12mo min)', img: '$400-700' },
  { duration: '6 months, age 30', allianz: '$1,500-2,200', axa: 'N/A (12mo min)', img: '$750-1,200' },
  { duration: '12 months, age 35', allianz: '$2,800-4,200', axa: '$3,500-5,000', img: '$1,500-2,400' },
  { duration: 'Family, 6 months', allianz: '$4,500-6,500', axa: 'N/A (12mo min)', img: '$2,200-3,500' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'short-term-considerations', text: 'Short-Term Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'AXA Global Review', href: '/providers/axa' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-blue-800 text-sm">You need premium coverage for 6+ months and want a balance between flexibility and comprehensive benefits from a recognized global brand.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-green-800 text-sm">Your assignment is definitely 12+ months and you want top-tier coverage without worrying about policy limitations or network gaps.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You need maximum flexibility for uncertain durations—from a few weeks to a year—at competitive prices with easy extension options.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Short-term expat assignments present unique insurance challenges. You need meaningful coverage without committing to annual contracts or losing money on early termination. These three providers approach short-term coverage very differently.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care offers a middle-ground solution for short-term expats. With a 6-month minimum term, they're more flexible than AXA but provide more comprehensive coverage than typical travel insurance. Their global network and brand recognition make them a solid choice for professional assignments.</p>

      <h3>Strengths for Short-Term Assignments</h3>
      <ul>
        <li>6-month minimum allows coverage of typical project assignments</li>
        <li>Monthly payment options reduce upfront costs</li>
        <li>Pro-rata refunds if you need to end coverage early</li>
        <li>Easy extension without full re-underwriting</li>
        <li>Premium hospital networks in most regions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>6-month minimum may be too long for some assignments</li>
        <li>Pre-existing condition coverage limited on short-term plans</li>
        <li>Higher pricing than IMG for similar durations</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global is designed for longer-term expats, with a 12-month minimum commitment. While this limits flexibility for short-term assignments, their coverage quality is among the best in the industry. Best suited when your "short-term" assignment is definitely a full year.</p>

      <h3>Strengths for Year-Long Assignments</h3>
      <ul>
        <li>Comprehensive coverage rivaling domestic health insurance</li>
        <li>Excellent hospital networks globally</li>
        <li>Strong mental health and wellness benefits</li>
        <li>Seamless claims process with direct billing</li>
        <li>High coverage limits and few exclusions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>12-month minimum eliminates true short-term use</li>
        <li>Restricted early termination and refund policies</li>
        <li>Premium pricing reflects comprehensive coverage</li>
        <li>Not ideal when assignment duration is uncertain</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global specializes in flexible international coverage, making them the standout choice for truly short-term assignments. Their plans can start from just 5 days and extend as needed, with straightforward pricing and easy administration.</p>

      <h3>Strengths for Short-Term Assignments</h3>
      <ul>
        <li>Minimum term as short as 5 days for some plans</li>
        <li>Easy online extensions without new applications</li>
        <li>Competitive pricing for short durations</li>
        <li>No penalty for uncertain end dates</li>
        <li>Trip interruption and travel benefits available</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Coverage may be less comprehensive than Allianz or AXA</li>
        <li>Pre-existing conditions typically excluded</li>
        <li>Smaller direct billing network in some regions</li>
        <li>May need to transition to different plan for long-term</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Short-term plans typically have more restrictions than annual policies. Pre-existing conditions are rarely covered, maternity benefits are usually unavailable due to waiting periods, and some wellness features may be excluded.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Short-term coverage can be expensive on a per-month basis compared to annual plans, but the ability to pay only for the coverage you need often results in overall savings for defined assignments.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by age, health status, destination, and coverage level. AXA requires 12-month commitment, so shorter terms show N/A.</p>
    </section>

    <section id="short-term-considerations" class="mb-12">
      <h2>Short-Term Assignment Considerations</h2>

      <h3>Assignment Extension Risk</h3>
      <p>Many "short-term" assignments get extended. If there's a chance your 3-month project becomes 9 months, choose a provider with easy extension policies. IMG handles this best, followed by Allianz. AXA's annual structure actually works well if you're confident about a full year.</p>

      <h3>Gap Coverage Concerns</h3>
      <p>If you're between employers or waiting for corporate benefits to start, short-term international coverage can bridge the gap. IMG's flexible start dates and durations work well for these scenarios.</p>

      <h3>Pre-existing Conditions</h3>
      <p>Short-term policies rarely cover pre-existing conditions meaningfully. If you have ongoing health needs, you may need to maintain home country coverage or seek policies with moratorium options from Allianz.</p>

      <h3>Multiple Destinations</h3>
      <p>If your assignment involves multiple countries, ensure your chosen plan covers all destinations. All three providers offer regional and worldwide options, but pricing varies significantly by region.</p>

      <h3>Visa Requirements</h3>
      <p>Some visas require specific coverage minimums or policy durations. Verify requirements before purchasing—a policy that's too short or lacks required benefits could jeopardize your visa application.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• 6-12 month project assignments</li>
            <li>• Professionals needing premium networks</li>
            <li>• Those wanting refund flexibility</li>
            <li>• Expats valuing brand recognition</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Confirmed 12-month assignments</li>
            <li>• Those prioritizing coverage depth</li>
            <li>• Corporate secondments</li>
            <li>• Expats with complex health needs</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Assignments under 6 months</li>
            <li>• Uncertain duration projects</li>
            <li>• Budget-conscious expats</li>
            <li>• Gap coverage between jobs</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What's the minimum coverage period for each provider?</h3>
          <p class="text-neutral-700">IMG offers the shortest terms, starting from 5 days. Allianz requires 6 months minimum. AXA requires a full 12-month commitment on their international health plans.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get a refund if my assignment ends early?</h3>
          <p class="text-neutral-700">Allianz offers pro-rata refunds for unused coverage. IMG's flexible terms mean you generally only pay for what you use. AXA has more restrictive refund policies due to their annual structure.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What happens if my short-term assignment gets extended?</h3>
          <p class="text-neutral-700">IMG allows easy online extensions. Allianz permits renewal without full re-underwriting for continuous coverage. AXA extensions depend on your existing policy terms.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are pre-existing conditions covered on short-term plans?</h3>
          <p class="text-neutral-700">Generally, no. Short-term plans typically exclude pre-existing conditions. Allianz offers some moratorium options, but full coverage usually requires longer policy terms.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I choose short-term insurance or travel insurance?</h3>
          <p class="text-neutral-700">For assignments over 30 days, international health insurance typically provides better coverage than travel insurance. IMG bridges both categories well for medium-duration trips.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I switch from short-term to long-term coverage?</h3>
          <p class="text-neutral-700">Yes, but it usually requires a new application and underwriting. Some providers offer conversion programs. It's often easier to start with a provider that offers both short and long-term options.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
