---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for UK Skilled Worker Visa (2025)";
const description = "Compare top health insurance options for UK Skilled Worker visa. Expert analysis of Cigna Global, Bupa Global, and NHS access through the Immigration Health Surcharge.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "bupa-global", title: "Bupa Global" },
  { id: "nhs-ihs", title: "NHS via IHS" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "nhs", header: "NHS (via IHS)" },
];

const comparisonRows = [
  { feature: "Skilled Worker Acceptance", cigna: "✓ Supplement to IHS", bupa: "✓ Supplement to IHS", nhs: "✓ Mandatory (via IHS fee)" },
  { feature: "UK Hospital Network", cigna: "Private hospitals", bupa: "Private hospitals", nhs: "All NHS facilities" },
  { feature: "Wait Times", cigna: "Minimal (private)", bupa: "Minimal (private)", nhs: "Can be lengthy" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", bupa: "Moratorium option", nhs: "✓ Full coverage" },
  { feature: "Dental Coverage", cigna: "Optional", bupa: "Optional", nhs: "Subsidized NHS dental" },
  { feature: "Mental Health", cigna: "Full coverage", bupa: "Full coverage", nhs: "Covered (waitlists)" },
  { feature: "GP Access", cigna: "Private GPs", bupa: "Private GPs", nhs: "Register with NHS GP" },
  { feature: "Best For", cigna: "Premium/fast access", bupa: "Comprehensive private", nhs: "Cost-effective baseline" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "nhs", header: "NHS (via IHS)" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", bupa: "100% covered", nhs: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", bupa: "100% covered", nhs: "100% covered" },
  { coverage: "Emergency Care", cigna: "Full coverage", bupa: "Full coverage", nhs: "Full coverage (A&E)" },
  { coverage: "Prescription Drugs", cigna: "100% covered", bupa: "100% covered", nhs: "£9.90/item (or PPC)" },
  { coverage: "Dental", cigna: "Optional", bupa: "Optional", nhs: "NHS dental (subsidized)" },
  { coverage: "Vision", cigna: "Optional", bupa: "Optional", nhs: "NHS vouchers available" },
  { coverage: "Maternity", cigna: "Optional add-on", bupa: "Optional add-on", nhs: "Full coverage" },
  { coverage: "Specialist Referrals", cigna: "Direct access", bupa: "Direct access", nhs: "GP referral required" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "nhs", header: "NHS (IHS only)" },
];

const pricingRows = [
  { age: "25-30", cigna: "£200-320/month", bupa: "£250-400/month", nhs: "£1,035/year total" },
  { age: "30-35", cigna: "£250-400/month", bupa: "£300-480/month", nhs: "£1,035/year total" },
  { age: "40-45", cigna: "£350-550/month", bupa: "£420-660/month", nhs: "£1,035/year total" },
  { age: "50-55", cigna: "£500-780/month", bupa: "£600-940/month", nhs: "£1,035/year total" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "nhs", header: "NHS" },
];

const networkRows = [
  { region: "London", cigna: "Excellent - 30+ hospitals", bupa: "Excellent - 35+ hospitals", nhs: "All NHS facilities" },
  { region: "Manchester", cigna: "Strong - 10+ hospitals", bupa: "Strong - 12+ hospitals", nhs: "All NHS facilities" },
  { region: "Birmingham", cigna: "Good - 8+ hospitals", bupa: "Good - 10+ hospitals", nhs: "All NHS facilities" },
  { region: "Edinburgh/Scotland", cigna: "Good", bupa: "Strong", nhs: "All NHS Scotland" },
  { region: "Other UK", cigna: "Limited - reimbursement", bupa: "Good network", nhs: "Full UK coverage" },
  { region: "International", cigna: "Worldwide coverage", bupa: "Worldwide coverage", nhs: "Limited abroad" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for UK Skilled Worker visa holders"
    heroImage="/images/countries/uk-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">UK Skilled Worker Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        The UK Skilled Worker visa requires payment of the Immigration Health Surcharge (IHS) as part of the visa application. This fee grants you access to the National Health Service (NHS) on the same basis as UK residents. Private insurance is optional but popular for faster access.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Immigration Health Surcharge (IHS) is mandatory: £1,035/year</li>
          <li>• IHS grants full NHS access from visa start date</li>
          <li>• No waiting period for NHS services after IHS payment</li>
          <li>• Private insurance is optional (supplements NHS)</li>
          <li>• Employer may provide private health benefits</li>
          <li>• NHS doesn't cover dental/optical (separate arrangements)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        The NHS provides comprehensive healthcare free at point of use. However, wait times for non-urgent care can be lengthy. Many professionals add private insurance through their employer or independently for faster specialist access and private hospital care.
      </p>

      <p class="text-neutral-700">
        Unlike other countries, the UK's IHS system means you're covered from day one—there's no gap period requiring bridge insurance. The decision is whether to supplement NHS with private coverage for faster access and additional benefits.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for UK Skilled Worker Visa</h2>

      <p class="text-neutral-700 mb-6">
        Skilled Worker visa holders have NHS access via IHS. The question is whether to add private insurance for enhanced access:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive international coverage that works well for skilled workers who want private healthcare access in the UK plus coverage when traveling internationally.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Direct access to UK private hospitals</li>
            <li>• No GP referral required for specialists</li>
            <li>• Comprehensive mental health coverage</li>
            <li>• Worldwide coverage for travel</li>
            <li>• Modular plans for customization</li>
            <li>• 24/7 multilingual support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Significant cost on top of IHS</li>
            <li>• Redundant for basic care (NHS covers)</li>
            <li>• Annual commitment typical</li>
            <li>• May duplicate employer benefits</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Premium private healthcare in the UK and worldwide."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Bupa Global</h2>

      <p class="text-neutral-700 mb-4">
        Bupa is a British healthcare company with extensive UK networks. They offer both international (Bupa Global) and UK-specific private health insurance, making them ideal for skilled workers wanting premium UK coverage.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Largest UK private hospital network</li>
            <li>• Bupa health centres for routine care</li>
            <li>• Strong brand recognition in UK</li>
            <li>• Comprehensive wellness benefits</li>
            <li>• Can transition to UK-only Bupa product</li>
            <li>• 24/7 UK-based support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Premium pricing</li>
            <li>• Bupa Global more expensive than UK-only</li>
            <li>• May be excessive if employer provides</li>
            <li>• NHS covers same services free</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Bupa Global Quote"
        description="British healthcare expertise with global coverage."
        buttonText="Get Quote"
        buttonHref="/go/bupa"
      />
    </section>

    <section id="nhs-ihs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">NHS via Immigration Health Surcharge</h2>

      <p class="text-neutral-700 mb-4">
        The NHS is one of the world's best-known healthcare systems. Through the mandatory IHS payment, skilled workers get full access to NHS services—from GPs to hospitals to specialist care—on the same basis as British citizens.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Comprehensive coverage for £1,035/year</li>
            <li>• All pre-existing conditions covered</li>
            <li>• Maternity fully covered</li>
            <li>• No coverage limits or exclusions</li>
            <li>• Access from visa start date</li>
            <li>• World-class emergency care (A&E)</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Wait times for non-urgent care</li>
            <li>• GP referral required for specialists</li>
            <li>• Limited choice of consultant/hospital</li>
            <li>• Prescription charges (£9.90/item)</li>
            <li>• NHS dental can be hard to access</li>
            <li>• Limited coverage abroad</li>
          </ul>
        </div>
      </div>

      <div class="bg-neutral-50 p-4 rounded-lg">
        <p class="text-neutral-700 text-sm">
          <strong>IHS Calculator:</strong> £1,035/year for adults, £776/year for students and children. For a 5-year visa, you'll pay £5,175 upfront. IHS is paid during visa application and covers you for your entire visa duration.
        </p>
      </div>
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares. Remember—NHS via IHS is your baseline; private insurance supplements it:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        NHS provides comprehensive medical coverage. Private insurance adds speed (shorter waits), choice (pick your consultant), and comfort (private rooms). For most medical needs, NHS is excellent—private is for convenience.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        IHS is mandatory and fixed. Private insurance varies significantly by age and coverage level:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        NHS via IHS is remarkably cost-effective—£1,035/year regardless of age or health. Private insurance can cost 3-10x more. Many people use NHS for routine care and private for elective procedures where waits are longest.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in the UK</h2>

      <p class="text-neutral-700 mb-6">
        NHS provides universal access; private insurance focuses on private hospital networks:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        London has the most extensive private healthcare options. Outside major cities, NHS may be more practical for routine care, with private insurance reserved for specific procedures.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Tech Professional in London</h3>
          <p class="text-neutral-600 mb-3">32-year-old software engineer, employer provides Bupa UK, healthy, single.</p>
          <p class="text-green-700 font-medium">Recommendation: NHS + employer Bupa (standard approach)</p>
          <p class="text-neutral-600 text-sm">IHS covers NHS baseline. Employer Bupa provides private option for faster specialist access. No need for additional international insurance unless traveling frequently.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Finance Professional, Globally Mobile</h3>
          <p class="text-neutral-600 mb-3">40-year-old banker, travels to US and Europe frequently for work.</p>
          <p class="text-green-700 font-medium">Recommendation: NHS + Cigna Global</p>
          <p class="text-neutral-600 text-sm">NHS for UK base. Cigna Global provides seamless international coverage for frequent travel. Worth the premium for global access and continuity of care across countries.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Family with Children</h3>
          <p class="text-neutral-600 mb-3">35-year-old with spouse and two children, relocating to Manchester.</p>
          <p class="text-green-700 font-medium">Recommendation: NHS + consider private for dental</p>
          <p class="text-neutral-600 text-sm">NHS excellent for family care, especially maternity and pediatrics. NHS dental access can be challenging—consider private dental plan for children's orthodontics.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Professional with Chronic Condition</h3>
          <p class="text-neutral-600 mb-3">45-year-old with managed MS, needs regular specialist care.</p>
          <p class="text-green-700 font-medium">Recommendation: NHS (possibly sufficient alone)</p>
          <p class="text-neutral-600 text-sm">NHS provides excellent chronic condition care with no exclusions. MS services are NHS specialty. Private may add faster initial appointments but NHS handles ongoing management well.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Contractor Without Employer Benefits</h3>
          <p class="text-neutral-600 mb-3">38-year-old contractor, no employer health benefits, values fast access.</p>
          <p class="text-green-700 font-medium">Recommendation: NHS + Bupa UK individual plan</p>
          <p class="text-neutral-600 text-sm">NHS as baseline. Bupa UK (domestic, not Global) offers good value for UK-only private coverage. More affordable than international plans for UK-focused living.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most Skilled Worker visa holders, <strong>NHS via IHS</strong> provides excellent baseline coverage at very low cost. If your employer offers private health insurance (common in professional roles), accept it. <strong>International insurance</strong> primarily makes sense for those who travel frequently or maintain homes in multiple countries.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose NHS Only If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Comfortable with NHS waits</li>
            <li>• Budget is priority</li>
            <li>• Generally healthy</li>
            <li>• No employer benefits</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Add Private UK Insurance If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Employer provides it free</li>
            <li>• Want faster specialist access</li>
            <li>• Value private rooms</li>
            <li>• Need specific procedures</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose International Insurance If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Travel internationally often</li>
            <li>• May relocate from UK</li>
            <li>• Have homes in multiple countries</li>
            <li>• Want worldwide coverage</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Do I have to pay the Immigration Health Surcharge?</h3>
          <p class="text-neutral-600">Yes, IHS is mandatory for most visa applicants staying longer than 6 months. You cannot opt out, even if you have private insurance. The fee is paid as part of your visa application and covers you for your visa duration.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">When does my NHS access start?</h3>
          <p class="text-neutral-600">NHS access begins from your visa start date (not arrival date, not application date). Register with a local GP as soon as possible after arriving—this is your gateway to NHS services.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about NHS dental care?</h3>
          <p class="text-neutral-600">NHS dental is subsidized but not free. Finding an NHS dentist accepting new patients can be challenging in some areas. Many people use private dentists. Costs are regulated on NHS (Band 1-3 charges) or market rate for private.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Are prescriptions free on the NHS?</h3>
          <p class="text-neutral-600">In England, prescriptions cost £9.90/item. A Prescription Prepayment Certificate (PPC) saves money if you need multiple prescriptions (£111.60/year for unlimited prescriptions). Scotland, Wales, and Northern Ireland offer free prescriptions.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use private insurance instead of paying IHS?</h3>
          <p class="text-neutral-600">No. IHS is mandatory regardless of any private insurance you have. Private insurance supplements NHS access—it doesn't replace it or exempt you from IHS. You'll have both NHS access and private coverage if you choose.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What if I have a medical emergency?</h3>
          <p class="text-neutral-600">Go to A&E (Accident & Emergency) at any NHS hospital—it's free for everyone, including before your visa starts. Emergency care is excellent. For non-emergencies, use NHS 111 (phone/online) for guidance.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> NHS services and IHS fees can change. Verify current IHS rates at gov.uk. Confirm policy details with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
