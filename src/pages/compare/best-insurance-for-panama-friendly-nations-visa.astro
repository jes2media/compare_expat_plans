---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Panama Friendly Nations Visa (2025)";
const description = "Compare top health insurance options for Panama's Friendly Nations Visa. Expert analysis of Cigna Global, IMG Global, and local Panama insurers for expats moving to Panama.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "img-global", title: "IMG Global" },
  { id: "bupa-global", title: "Bupa Global" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "img", header: "IMG Global" },
  { key: "bupa", header: "Bupa Global" },
];

const comparisonRows = [
  { feature: "Panama Visa Acceptance", cigna: "✓ Widely accepted", img: "✓ Widely accepted", bupa: "✓ Widely accepted" },
  { feature: "Panama City Network", cigna: "Excellent (direct billing)", img: "Good (reimbursement)", bupa: "Excellent (direct billing)" },
  { feature: "US Coverage", cigna: "✓ Optional add-on", img: "✓ Strong BCBS network", bupa: "✓ Optional add-on" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", img: "Limited coverage", bupa: "Moratorium option" },
  { feature: "Age Limits", cigna: "Up to 74", img: "Up to 80", bupa: "Up to 74" },
  { feature: "Mental Health", cigna: "Full coverage", img: "Limited", bupa: "Full coverage" },
  { feature: "Annual Maximum", cigna: "$1M - Unlimited", img: "$1M - $8M", bupa: "$1M - Unlimited" },
  { feature: "Best For", cigna: "Premium seekers", img: "US coverage focus", bupa: "Premium service" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "img", header: "IMG Global" },
  { key: "bupa", header: "Bupa Global" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", img: "100% covered", bupa: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", img: "80-100% covered", bupa: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", img: "$500,000", bupa: "Unlimited" },
  { coverage: "Prescription Drugs", cigna: "100% covered", img: "Subject to limits", bupa: "100% covered" },
  { coverage: "Dental", cigna: "Optional", img: "Optional", bupa: "Optional" },
  { coverage: "Vision", cigna: "Optional", img: "Optional", bupa: "Optional" },
  { coverage: "Wellness/Preventive", cigna: "Annual checkup", img: "Limited", bupa: "Comprehensive" },
  { coverage: "Chronic Conditions", cigna: "Full management", img: "Maintenance only", bupa: "Full management" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "img", header: "IMG Global" },
  { key: "bupa", header: "Bupa Global" },
];

const pricingRows = [
  { age: "30-35", cigna: "$200-320/month", img: "$120-200/month", bupa: "$230-360/month" },
  { age: "40-45", cigna: "$280-440/month", img: "$180-280/month", bupa: "$320-500/month" },
  { age: "50-55", cigna: "$400-600/month", img: "$280-420/month", bupa: "$460-700/month" },
  { age: "60-65", cigna: "$550-850/month", img: "$400-600/month", bupa: "$640-980/month" },
  { age: "65-70", cigna: "$700-1,050/month", img: "$500-750/month", bupa: "$820-1,250/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "img", header: "IMG Global" },
  { key: "bupa", header: "Bupa Global" },
];

const networkRows = [
  { region: "Panama City", cigna: "Excellent - 10+ hospitals", img: "Good - major hospitals", bupa: "Excellent - 10+ hospitals" },
  { region: "Bocas del Toro", cigna: "Very limited", img: "Very limited", bupa: "Very limited" },
  { region: "Boquete/Chiriquí", cigna: "Limited - regional hospital", img: "Limited", bupa: "Limited" },
  { region: "Coronado/Beach Areas", cigna: "Limited - evacuation to city", img: "Limited", bupa: "Limited" },
  { region: "United States", cigna: "Strong (with US option)", img: "Excellent (BCBS)", bupa: "Strong (with US option)" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Panama's Friendly Nations Visa"
    heroImage="/images/countries/panama-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Panama Friendly Nations Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Panama's Friendly Nations Visa is one of the most accessible residency programs for citizens of about 50 countries, including the US, Canada, UK, and most EU nations. Health insurance isn't strictly required for the visa itself, but it's strongly recommended and increasingly expected by immigration attorneys.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance not mandatory for visa, but strongly recommended</li>
          <li>• Must demonstrate economic tie to Panama (bank account with $5,000+, business, or employment)</li>
          <li>• Panama has no public healthcare system for non-citizens</li>
          <li>• Medical costs are out-of-pocket without insurance</li>
          <li>• Some immigration lawyers include insurance proof in applications</li>
          <li>• Private healthcare is affordable but still requires coverage for major events</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Unlike Costa Rica, Panama doesn't have a universal public healthcare system. The CSS (Caja de Seguro Social) exists but is primarily for Panamanian citizens and formal employees. As a Friendly Nations visa holder, you'll rely on private healthcare—making insurance particularly important.
      </p>

      <p class="text-neutral-700">
        Panama City has excellent private hospitals—Punta Pacífica (affiliated with Johns Hopkins), Hospital Nacional, and Centro Médico Paitilla—with many US-trained doctors. Outside the city, healthcare options are limited.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Top 3 Insurers for Panama Friendly Nations Visa</h2>

      <p class="text-neutral-700 mb-6">
        We've analyzed the best options for Friendly Nations visa holders. All three provide strong Panama City coverage; the choice depends on your budget, US travel frequency, and coverage preferences.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global is a leading choice for expats in Panama who want comprehensive coverage with direct billing at Panama City's best hospitals. Their modular plans allow customization based on your specific needs.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Direct billing at Punta Pacífica and major hospitals</li>
            <li>• Modular plans for customization</li>
            <li>• Comprehensive mental health coverage</li>
            <li>• Excellent chronic condition management</li>
            <li>• US coverage optional but strong</li>
            <li>• 24/7 English-speaking support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Premium pricing tier</li>
            <li>• Age limit of 74 for new enrollees</li>
            <li>• Network limited outside Panama City</li>
            <li>• US coverage adds significant cost</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Premium coverage with Panama's best hospital network."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="img-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">IMG Global</h2>

      <p class="text-neutral-700 mb-4">
        IMG Global offers strong value for Panama expats, particularly those who travel to the US frequently. Their GeoBlue plans provide access to the Blue Cross Blue Shield network—a significant advantage for Americans maintaining US ties.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Excellent US coverage via BCBS network</li>
            <li>• Higher age acceptance (up to 80)</li>
            <li>• More affordable than premium options</li>
            <li>• Good for healthy expats</li>
            <li>• Flexible plan options</li>
            <li>• Straightforward claims process</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Pre-existing condition coverage limited</li>
            <li>• Primarily reimbursement model in Panama</li>
            <li>• Mental health coverage restricted</li>
            <li>• Less comprehensive than Cigna/Bupa</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an IMG Global Quote"
        description="Strong US coverage for Panama expats."
        buttonText="Get Quote"
        buttonHref="/go/img"
      />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Bupa Global</h2>

      <p class="text-neutral-700 mb-4">
        Bupa Global provides premium international health insurance with excellent service. Their concierge approach appeals to executives and high-net-worth individuals who want the best available care access.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Premium concierge medical service</li>
            <li>• Excellent Panama City network</li>
            <li>• Comprehensive wellness benefits</li>
            <li>• Strong chronic condition support</li>
            <li>• Worldwide coverage</li>
            <li>• Direct billing at major facilities</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Highest premium option</li>
            <li>• Age limit of 74 for new enrollees</li>
            <li>• US coverage adds cost</li>
            <li>• May be excessive for basic needs</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Bupa Global Quote"
        description="Premium coverage with concierge service."
        buttonText="Get Quote"
        buttonHref="/go/bupa-global"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        All three insurers provide comprehensive coverage suitable for Panama. Here's how they compare across key categories:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        IMG offers the best US network access at lower cost but with more limited overall coverage. Cigna and Bupa provide more comprehensive plans at higher prices.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Panama-based plans are moderately priced. These ranges represent comprehensive coverage suitable for Friendly Nations visa holders:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        IMG offers the most affordable option, particularly attractive for healthy expats who prioritize US coverage. Cigna and Bupa cost more but provide more comprehensive benefits.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Panama</h2>

      <p class="text-neutral-700 mb-6">
        Panama City has excellent healthcare; rural areas are limited. Here's what to expect:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        If you're settling in Boquete, Bocas del Toro, or beach areas, understand that serious medical care will require travel to Panama City. Evacuation coverage becomes valuable in these locations.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Remote Worker in Panama City</h3>
          <p class="text-neutral-600 mb-3">35-year-old remote worker, healthy, lives in Panama City, occasional US trips.</p>
          <p class="text-green-700 font-medium">Recommendation: IMG Global</p>
          <p class="text-neutral-600 text-sm">Good balance of cost and coverage. BCBS network for US trips. Panama City network is adequate for routine needs.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Retiree in Boquete</h3>
          <p class="text-neutral-600 mb-3">62-year-old retiree settling in Boquete highlands, managed cholesterol, visits US annually.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Evacuation coverage important for Boquete location. Good chronic condition management. Direct billing at David regional hospital and Panama City facilities.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Entrepreneur Starting Business</h3>
          <p class="text-neutral-600 mb-3">40-year-old starting a business in Panama City, healthy, travels frequently to Latin America.</p>
          <p class="text-green-700 font-medium">Recommendation: IMG Global or Cigna Global</p>
          <p class="text-neutral-600 text-sm">IMG for cost-effectiveness if healthy. Cigna if you want more comprehensive coverage and direct billing convenience for busy professionals.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Executive Relocating with Family</h3>
          <p class="text-neutral-600 mb-3">48-year-old executive with spouse and two children, relocating to Panama for regional role.</p>
          <p class="text-green-700 font-medium">Recommendation: Bupa Global</p>
          <p class="text-neutral-600 text-sm">Premium family coverage with concierge service. Excellent pediatric network at Punta Pacífica. Company may cover the premium.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Older Retiree with Health Issues</h3>
          <p class="text-neutral-600 mb-3">72-year-old with diabetes and prior heart surgery, wants access to best Panama care.</p>
          <p class="text-amber-700 font-medium">Recommendation: IMG Global (only option at this age with conditions)</p>
          <p class="text-neutral-600 text-sm">IMG accepts up to 80. Pre-existing coverage will be limited, but provides essential catastrophic coverage. Consider supplementing with cash reserves for predictable chronic care costs.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most Friendly Nations visa holders, <strong>IMG Global</strong> offers the best value with strong US coverage. For those wanting premium service and comprehensive benefits, <strong>Cigna Global</strong> provides excellent coverage with direct billing at Panama's best hospitals. <strong>Bupa Global</strong> is ideal for executives and families wanting concierge-level service.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose IMG Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• US coverage is priority</li>
            <li>• Budget-conscious</li>
            <li>• Generally healthy</li>
            <li>• Over 74 years old</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want premium coverage</li>
            <li>• Have chronic conditions</li>
            <li>• Value direct billing</li>
            <li>• Live outside Panama City</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Bupa If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want concierge service</li>
            <li>• Relocating with family</li>
            <li>• Company provides coverage</li>
            <li>• Premium budget available</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is health insurance required for the Friendly Nations Visa?</h3>
          <p class="text-neutral-600">Not strictly required, but strongly recommended. Some immigration lawyers include insurance documentation to strengthen applications. More importantly, Panama has no public healthcare for foreigners—you need coverage for your own protection.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I access Panama's public healthcare (CSS)?</h3>
          <p class="text-neutral-600">CSS is primarily for Panamanian citizens and formal employees paying into the system. As a Friendly Nations visa holder, you likely won't qualify unless employed by a company that contributes to CSS. Plan on private healthcare and insurance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How good is healthcare in Panama City?</h3>
          <p class="text-neutral-600">Excellent. Hospital Punta Pacífica is affiliated with Johns Hopkins and offers world-class care. Many doctors trained in the US and speak English. Costs are typically 40-60% of US prices. Quality rivals developed countries.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about healthcare in Boquete or Bocas del Toro?</h3>
          <p class="text-neutral-600">Limited. Boquete has basic clinics and a regional hospital in David (45 minutes away). Bocas del Toro has minimal facilities—serious issues require evacuation to Panama City. Include evacuation coverage if living in these areas.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What's the $5,000 bank requirement about?</h3>
          <p class="text-neutral-600">The Friendly Nations Visa requires demonstrating an "economic tie" to Panama. The easiest way is opening a Panama bank account with at least $5,000. Alternatives include employment by a Panama company or starting a business.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Should I get local Panama insurance instead?</h3>
          <p class="text-neutral-600">Local insurers exist (Assa, Mapfre, etc.) and can be cheaper for Panama-only coverage. However, they typically don't cover you internationally and may have more exclusions. For expats who travel—especially to the US—international insurance is usually the better choice.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Insurance requirements and visa rules change. Verify current requirements with a Panama immigration attorney. Confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or legal advice.</p>
    </div>
  </PageShell>
</Layout>
