---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'axa', text: 'AXA Global', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'student-considerations', text: 'Student Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'AXA Global Full Review', href: '/providers/axa-global' },
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Full Review', href: '/providers/bupa-global' },
  { title: 'Insurance for International Students', href: '/insurance-for/students' },
  { title: 'Best Student Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
];

const mainComparisonRows = [
  { feature: 'Student plans', axa: 'Dedicated options', cigna: 'Individual plans', bupa: 'Individual plans' },
  { feature: 'Age limit', axa: 'Up to 65', cigna: 'Up to 74', bupa: 'Up to 85' },
  { feature: 'Visa compliance', axa: 'Strong—Schengen', cigna: 'Strong', bupa: 'Strong' },
  { feature: 'University proximity', axa: 'European focus', cigna: 'Global', bupa: 'Global' },
  { feature: 'Mental health', axa: 'Basic coverage', cigna: 'Good coverage', bupa: 'Excellent' },
  { feature: 'Sports injuries', axa: 'Covered', cigna: 'Covered', bupa: 'Covered' },
  { feature: 'Home visits', axa: '30-90 days/yr', cigna: 'Up to 90 days', bupa: 'Up to 90 days' },
  { feature: 'Budget options', axa: 'Yes—affordable', cigna: 'Higher cost', bupa: 'Premium pricing' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
];

const pricingRows = [
  { scenario: 'Age 20, basic', axa: '$1,200-1,800/yr', cigna: '$1,800-2,500/yr', bupa: '$2,000-2,800/yr' },
  { scenario: 'Age 25, comprehensive', axa: '$1,800-2,600/yr', cigna: '$2,500-3,500/yr', bupa: '$2,800-4,000/yr' },
  { scenario: 'Age 30 (grad student)', axa: '$2,200-3,200/yr', cigna: '$3,000-4,200/yr', bupa: '$3,500-4,800/yr' },
  { scenario: 'With dental add-on', axa: '+$300-500/yr', cigna: '+$400-600/yr', bupa: '+$450-700/yr' },
  { scenario: 'High deductible option', axa: '-20-30%', cigna: '-25-35%', bupa: '-20-30%' },
];
---

<PageShell
  title="AXA vs Cigna vs Bupa: Best for International Students 2025"
  description="Compare AXA, Cigna, and Bupa for international students. Student visa compliance, university requirements, mental health, and affordable coverage."
  headline="AXA vs Cigna vs Bupa: Student Insurance"
  subheadline="Which insurer is best for international students? Visa compliance, university requirements, and coverage that fits a student budget."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">AXA Global</p>
      <p class="text-sm text-neutral-600 mb-3">Most affordable premiums for students. Strong Schengen compliance. Best for European universities and budget-conscious students.</p>
      <a href="/providers/axa-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best Global Coverage</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Strongest worldwide network. Good for students at universities outside Europe. Better mental health coverage than AXA.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best Mental Health</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Industry-leading mental health coverage. Premium service and benefits. Worth the cost for students with mental health needs.</p>
      <a href="/providers/bupa-global" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="axa">AXA Global Healthcare</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">AXA Global offers the most affordable international health insurance for students, with dedicated plans designed for the student budget. Their strong European network and Schengen compliance make them ideal for students at European universities.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Student Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most affordable student premiums</li>
      <li>Schengen visa compliant</li>
      <li>Strong European university coverage</li>
      <li>Sports injuries covered</li>
      <li>Home country visits included</li>
      <li>High deductible options for savings</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Mental health coverage basic</li>
      <li>Network weaker outside Europe</li>
      <li>Less comprehensive than competitors</li>
      <li>Service may feel less premium</li>
    </ul>
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global offers students access to their worldwide network, making them ideal for those studying outside Europe or at globally mobile universities. Their mental health coverage is better than AXA, though premiums are higher.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Student Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Excellent worldwide network</li>
      <li>Good mental health coverage</li>
      <li>Strong visa compliance globally</li>
      <li>Comprehensive coverage options</li>
      <li>Good for US university students</li>
      <li>Sports and activities covered</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Higher premiums than AXA</li>
      <li>No dedicated student plans</li>
      <li>May be overkill for European study</li>
      <li>Complex plan options</li>
    </ul>
  </div>

  <h2 id="bupa">Bupa Global</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Bupa Global offers the most comprehensive coverage including industry-leading mental health benefits. For students with mental health needs or those wanting premium protection, Bupa justifies its higher cost.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Student Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Excellent mental health coverage</li>
      <li>Comprehensive benefits package</li>
      <li>Premium service standards</li>
      <li>Strong global network</li>
      <li>Good UK university coverage</li>
      <li>Chronic condition support</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Highest premiums of the three</li>
      <li>May exceed student budgets</li>
      <li>No dedicated student plans</li>
      <li>Premium pricing for premium service</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage for Your Studies Abroad"
    description="Compare plans designed for international students. Visa compliance, university requirements, and coverage that fits your budget."
    buttonText="Compare Student Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Annual premiums for international students. Young age keeps premiums relatively affordable across all three insurers.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Student insurance is more affordable due to young age. High deductible options can reduce premiums 20-35%. Prices exclude US coverage—add 40-50% for US university study.</p>

  <h2 id="student-considerations">Student Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">University Requirements</h3>
      <p class="text-neutral-700">Many universities require proof of health insurance for enrollment. US universities often mandate specific coverage levels. European universities may accept Schengen-compliant insurance. Verify your university's specific requirements before purchasing—some require policies from approved providers only.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Student Visa Requirements</h3>
      <p class="text-neutral-700">Student visas typically require health insurance. Schengen requires €30,000 minimum coverage. UK requires NHS surcharge payment but allows supplemental private insurance. US J-1 and F-1 visas have specific requirements. All three insurers provide visa documentation—verify your specific visa needs.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Mental Health for Students</h3>
      <p class="text-neutral-700">Student life abroad can be stressful—new environment, academic pressure, isolation. Mental health support matters. Bupa leads with comprehensive coverage. Cigna offers good coverage. AXA's mental health benefits are basic. If mental health support is important, prioritize Bupa or Cigna despite higher costs.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Sports and Activities</h3>
      <p class="text-neutral-700">University sports, intramurals, and recreational activities are covered by all three insurers. Injuries from football, basketball, skiing trips, etc. are included. Adventure sports may have limitations—verify if you plan extreme activities. Club sports and university athletics are generally covered.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Parent-Funded vs Self-Funded</h3>
      <p class="text-neutral-700">Most student insurance is parent-funded. All three insurers allow parents to purchase and manage policies for dependent children. If self-funding, high deductible options reduce costs significantly. Consider your financial situation—affordable monthly payments vs annual lump sum.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose AXA If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is top priority</li>
        <li>You're studying in Europe</li>
        <li>Schengen compliance needed</li>
        <li>Basic coverage suffices</li>
        <li>Mental health less critical</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You're studying outside Europe</li>
        <li>Global network matters</li>
        <li>Better mental health needed</li>
        <li>Comprehensive coverage wanted</li>
        <li>Parents can afford higher cost</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose Bupa If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Mental health is priority</li>
        <li>You have existing conditions</li>
        <li>Premium coverage wanted</li>
        <li>UK university study</li>
        <li>Budget is flexible</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Will my university accept international insurance?</h3>
      <p class="text-neutral-700">Most universities accept international health insurance from major providers like AXA, Cigna, and Bupa. However, some US universities require enrollment in their student health plan regardless of existing coverage. Verify with your specific university's international student office before purchasing.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I stay on my parents' plan while studying abroad?</h3>
      <p class="text-neutral-700">Domestic health insurance (US employer plans, NHS, etc.) typically has limited or no coverage abroad. You need international insurance while studying overseas. If your parents have international expat insurance, you may be able to remain as a dependent—verify coverage extends to your study country.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about coverage during semester breaks at home?</h3>
      <p class="text-neutral-700">All three insurers include home country coverage (typically 30-90 days annually). This covers you during winter and summer breaks when visiting home. Verify your specific limit matches your travel patterns. Extended stays may require adjusting your coverage.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is mental health counseling covered?</h3>
      <p class="text-neutral-700">Coverage varies significantly. Bupa offers comprehensive mental health including therapy sessions. Cigna provides good coverage with some limits. AXA's mental health coverage is basic—may only cover crisis situations. If you anticipate needing regular counseling, choose Bupa or verify Cigna's specific limits.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What happens when I graduate?</h3>
      <p class="text-neutral-700">Student status doesn't affect coverage eligibility—these are standard international health insurance plans. After graduation, if you stay abroad for work, your coverage continues. If returning home, you'd transition to domestic insurance. All three insurers allow seamless continuation without re-underwriting.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I use campus health services with international insurance?</h3>
      <p class="text-neutral-700">Usually yes—you can visit campus health centers and submit claims for reimbursement. Some campus clinics may not accept direct billing from international insurers. For minor issues, campus health is often convenient. For anything serious, use your insurance network hospitals for direct billing and better care.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> University and visa requirements vary significantly. This comparison provides general guidance—verify specific requirements with your university and visa authorities. Student insurance needs are individual. Coverage options and pricing change regularly.
    </p>
  </div>
</PageShell>
