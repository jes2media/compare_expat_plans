---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'vision-details', text: 'Vision Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/compare/cigna-vs-bupa-vs-allianz-dental', text: 'Dental Coverage Comparison' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Annual Vision Limit', cigna: 'Up to $500', bupa: 'Up to $400', allianz: 'Up to $300' },
  { feature: 'Eye Exams', cigna: '1 per year', bupa: '1 per year', allianz: '1 every 2 years' },
  { feature: 'Glasses Allowance', cigna: 'Up to $300', bupa: 'Up to $250', allianz: 'Up to $200' },
  { feature: 'Contact Lenses', cigna: 'Covered in allowance', bupa: 'Covered in allowance', allianz: 'Limited' },
  { feature: 'LASIK/Corrective', cigna: 'Not covered', bupa: 'Optional rider', allianz: 'Not covered' },
  { feature: 'Emergency Eye Care', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Full coverage' },
  { feature: 'Waiting Period', cigna: '3 months', bupa: '6 months', allianz: '6-12 months' },
  { feature: 'Network Opticians', cigna: 'Good', bupa: 'Limited', allianz: 'Limited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Base plan (no vision)', cigna: '$300/mo', bupa: '$350/mo', allianz: '$240/mo' },
  { profile: 'With vision coverage', cigna: '$330-380/mo', bupa: '$385-450/mo', allianz: '$265-320/mo' },
  { profile: 'Vision add-on cost', cigna: '+$30-80/mo', bupa: '+$35-100/mo', allianz: '+$25-80/mo' },
  { profile: 'Family vision add-on', cigna: '+$80-180/mo', bupa: '+$100-220/mo', allianz: '+$70-180/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Vision Coverage | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for vision coverage. Expert analysis of eye exams, glasses, contacts, and LASIK for expats abroad."
  headline="Cigna vs Bupa vs Allianz: Best Vision Coverage"
  subheadline="Complete comparison for expats prioritizing eye care abroad—covering exams, glasses, contacts, and corrective surgery options."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Vision</p>
        <p class="text-neutral-700 text-sm mb-4">Highest allowances ($500 total, $300 glasses), annual exams, and shortest waiting period. Best choice for comprehensive eye care.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">LASIK Option</p>
        <p class="text-neutral-700 text-sm mb-4">Optional LASIK/corrective surgery rider available. Good standard coverage with premium features for those considering eye surgery.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Basic vision coverage at the lowest price. Adequate for occasional glasses needs in low-cost countries.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">$500 Limit</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Annual Exams</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">3-Month Wait</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most generous vision benefits in the international insurance market. The $500 annual limit covers both exams and eyewear, with up to $300 available for glasses or contacts. Annual eye exams are covered, ensuring regular monitoring of eye health.</p>

    <p class="text-neutral-700 mb-4">The 3-month waiting period is the shortest available—you can use vision benefits relatively quickly after enrollment. Network opticians exist in major cities, but reimbursement for any licensed provider works smoothly. For expats who wear glasses or contacts regularly, Cigna's vision coverage provides real value.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Vision Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Highest annual limit ($500)</li>
          <li>• $300 glasses/contacts allowance</li>
          <li>• Annual eye exams covered</li>
          <li>• 3-month waiting period (shortest)</li>
          <li>• Contacts fully included</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• LASIK not covered</li>
          <li>• Higher premium with vision</li>
          <li>• Limited network opticians</li>
          <li>• Cosmetic lenses excluded</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">LASIK Rider</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">$400 Limit</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Annual Exams</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's vision coverage stands out for the optional LASIK/corrective surgery rider. If you're considering laser eye surgery abroad (common in Thailand, Turkey, or Mexico), Bupa can provide partial coverage. The $400 annual limit covers standard vision needs well.</p>

    <p class="text-neutral-700 mb-4">Annual eye exams are included, and the $250 glasses/contacts allowance is adequate for most needs. The 6-month waiting period is standard. For expats planning corrective eye surgery or wanting the option, Bupa's flexibility is valuable despite the premium pricing.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Vision Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• LASIK rider available</li>
          <li>• $400 annual limit</li>
          <li>• Annual eye exams</li>
          <li>• Quality optician referrals</li>
          <li>• Corrective surgery option</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lower standard allowance</li>
          <li>• 6-month waiting period</li>
          <li>• LASIK rider costs extra</li>
          <li>• Highest vision premiums</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Option</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">$300 Limit</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Basic Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care provides basic vision coverage at the most affordable price. The $300 annual limit with $200 for glasses/contacts is adequate for occasional eyewear needs, particularly in countries where glasses are inexpensive (Thailand, Vietnam, Mexico).</p>

    <p class="text-neutral-700 mb-4">Eye exams are covered once every two years—less frequent than competitors but often sufficient for stable prescriptions. The 6-12 month waiting period is longest. Contact lens coverage is limited. Best for expats with stable vision who need occasional glasses replacement.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Vision Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable vision</li>
          <li>• $300 annual coverage</li>
          <li>• Basic exams included</li>
          <li>• Low premium add-on</li>
          <li>• Emergency eye care covered</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lowest limits ($300)</li>
          <li>• Exams every 2 years only</li>
          <li>• Limited contact coverage</li>
          <li>• No LASIK option</li>
          <li>• Long waiting period</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Vision Coverage Quotes"
    description="Get personalized quotes with vision benefits from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Vision adds modestly to premiums—often worthwhile for glasses wearers:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Vision is typically an add-on or included in comprehensive plans. Prices for individual coverage, age 35, Europe-based. Allowances may vary by plan level.</p>
  </section>

  <section id="vision-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Vision Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">What's Typically Covered</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Comprehensive eye exams</li>
          <li>• Prescription glasses (frames + lenses)</li>
          <li>• Contact lenses (up to allowance)</li>
          <li>• Lens coatings (UV, anti-glare)</li>
          <li>• Emergency eye care</li>
          <li>• Medical eye conditions</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Common Exclusions</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• LASIK/PRK (unless rider)</li>
          <li>• Cosmetic lenses</li>
          <li>• Sunglasses (non-prescription)</li>
          <li>• Designer frame premiums (above allowance)</li>
          <li>• Experimental treatments</li>
          <li>• Vision therapy (usually)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Is Vision Coverage Worth It?</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Add Vision If...</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• You wear glasses or contacts</li>
            <li>• Prescription changes regularly</li>
            <li>• You're in a high-cost country</li>
            <li>• Children need vision care</li>
            <li>• Annual exams are important to you</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Skip Vision If...</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• You don't wear corrective lenses</li>
            <li>• Glasses are cheap locally</li>
            <li>• Prescription is stable</li>
            <li>• Budget is very tight</li>
            <li>• You'd pay less out-of-pocket</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the highest vision limits</li>
          <li>• Annual eye exams matter</li>
          <li>• Short waiting period is important</li>
          <li>• You wear contacts regularly</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You're considering LASIK</li>
          <li>• Corrective surgery coverage is valuable</li>
          <li>• You want premium vision options</li>
          <li>• Quality optician referrals matter</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is your main concern</li>
          <li>• Basic vision coverage is enough</li>
          <li>• You're in a low-cost country for glasses</li>
          <li>• Your prescription rarely changes</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I get glasses anywhere or only at network opticians?</h3>
        <p class="text-neutral-700">You can get glasses from any licensed optician—you're not restricted to networks. At network opticians, direct billing may apply. Elsewhere, pay upfront and submit receipts for reimbursement up to your allowance. Many expats use local opticians for better value.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is LASIK covered by international insurance?</h3>
        <p class="text-neutral-700">Typically no—LASIK is considered elective/cosmetic. Bupa Global offers an optional rider with partial coverage. Many expats get LASIK in affordable destinations (Thailand, Turkey, Mexico) paying cash—often $1,000-2,000 for a procedure costing $5,000+ in the US/UK.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my allowance for multiple pairs of glasses?</h3>
        <p class="text-neutral-700">Yes, you can split your allowance however you want—one expensive pair or multiple budget pairs. Some expats get prescription sunglasses and regular glasses. As long as total claims don't exceed your annual allowance, you have flexibility.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about medical eye conditions like glaucoma?</h3>
        <p class="text-neutral-700">Medical eye conditions are covered under your main medical benefits, not vision allowance. Glaucoma, cataracts, retinal issues—these are treated as medical conditions with full coverage (subject to policy limits). Vision coverage is specifically for corrective lenses and routine exams.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Vision coverage limits, waiting periods, and allowances vary by specific plan and may change. Pre-existing vision conditions may be excluded. Always verify current vision benefits directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
