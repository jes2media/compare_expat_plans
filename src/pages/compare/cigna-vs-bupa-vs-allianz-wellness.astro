---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'wellness-benefits', text: 'Wellness Program Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
  { href: '/guides/preventive-care-abroad', text: 'Preventive Care Guide' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Annual Health Check', cigna: 'Comprehensive included', bupa: 'Comprehensive included', allianz: 'Basic included' },
  { feature: 'Wellness Program', cigna: 'Cigna Wellbeing', bupa: 'Bupa Lifeworks', allianz: 'MyHealth app' },
  { feature: 'Vaccinations', cigna: 'Covered', bupa: 'Covered', allianz: 'Covered' },
  { feature: 'Cancer Screenings', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Good coverage' },
  { feature: 'Mental Health Support', cigna: 'Comprehensive + EAP', bupa: 'Excellent + coaching', allianz: 'Good' },
  { feature: 'Fitness Benefits', cigna: 'Gym subsidies', bupa: 'Wellness rewards', allianz: 'Limited' },
  { feature: 'Health Coaching', cigna: 'Included', bupa: 'Premium service', allianz: 'Available' },
  { feature: 'Telehealth Wellness', cigna: '24/7 available', bupa: '24/7 available', allianz: 'Available' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Individual (35, with wellness)', cigna: '$350-480/mo', bupa: '$380-520/mo', allianz: '$300-400/mo' },
  { profile: 'Couple (40s)', cigna: '$650-880/mo', bupa: '$720-980/mo', allianz: '$560-750/mo' },
  { profile: 'Family (2 adults + 2 kids)', cigna: '$1,000-1,350/mo', bupa: '$1,100-1,500/mo', allianz: '$850-1,150/mo' },
  { profile: 'Wellness add-on cost', cigna: 'Often included', bupa: '$50-100/mo extra', allianz: '$30-60/mo extra' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Wellness Coverage | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for wellness and preventive care. Expert analysis of health screenings, wellness programs, and preventive benefits."
  headline="Cigna vs Bupa vs Allianz: Best Wellness & Preventive Coverage"
  subheadline="Complete comparison of three leading providers for expats prioritizing preventive care, health screenings, and wellness programs."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Wellness</p>
        <p class="text-neutral-700 text-sm mb-4">Most comprehensive wellness program with health coaching included. Cigna Wellbeing platform offers personalized health journeys.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Premium Service</p>
        <p class="text-neutral-700 text-sm mb-4">Premium wellness experience with concierge health services, mental health coaching, and exclusive health facilities access.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Good preventive coverage at lower price point. MyHealth app provides solid wellness tracking and telehealth access.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Cigna Wellbeing</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Health Coaching</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive Screenings</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global leads the market in integrated wellness coverage. Their Cigna Wellbeing platform combines health assessments, personalized recommendations, coaching, and rewards into a cohesive experience. The annual health check is comprehensive, including bloodwork, imaging, and specialist consultations.</p>

    <p class="text-neutral-700 mb-4">Health coaching is included with premium plans—not an expensive add-on. You get access to certified coaches who help with weight management, stress reduction, smoking cessation, and chronic condition management. The 24/7 telehealth service includes wellness consultations, not just sick visits.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Wellness Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Comprehensive health check included</li>
          <li>• Health coaching at no extra cost</li>
          <li>• Cigna Wellbeing platform</li>
          <li>• Mental health EAP included</li>
          <li>• Gym/fitness subsidies</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher base premiums</li>
          <li>• Best wellness features on premium plans</li>
          <li>• Some features region-dependent</li>
          <li>• Fitness benefits vary by location</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Bupa Lifeworks</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Concierge Service</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Mental Wellness Focus</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global takes a premium approach to wellness with their Bupa Lifeworks platform. The focus is on personalized, concierge-style health management. You get a dedicated health advisor who coordinates your preventive care, tracks your health goals, and ensures you're getting appropriate screenings.</p>

    <p class="text-neutral-700 mb-4">Mental wellness is particularly strong with Bupa—they offer mental health coaching, stress management programs, and access to Bupa's network of psychologists and counselors. The wellness rewards program incentivizes healthy behaviors with tangible benefits like premium discounts.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Wellness Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Premium concierge service</li>
          <li>• Excellent mental wellness support</li>
          <li>• Wellness rewards program</li>
          <li>• Dedicated health advisor</li>
          <li>• Access to Bupa health centers</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• Wellness features often add-on cost</li>
          <li>• Best features on premium tiers</li>
          <li>• Some benefits UK/Europe focused</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">MyHealth App</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Value Pricing</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Solid Preventive Care</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers solid wellness coverage at a more accessible price point. Their MyHealth app provides health tracking, wellness resources, and telehealth access. While not as feature-rich as Cigna or Bupa's platforms, it covers the essentials for health-conscious expats.</p>

    <p class="text-neutral-700 mb-4">Preventive care coverage includes annual health checks, vaccinations, and cancer screenings. The wellness add-on is affordable compared to competitors, making comprehensive preventive coverage accessible to more budget-conscious expats. Telehealth wellness consultations are available 24/7.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Wellness Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best value for wellness</li>
          <li>• Affordable wellness add-on</li>
          <li>• MyHealth app included</li>
          <li>• Basic health check included</li>
          <li>• 24/7 telehealth wellness</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Less comprehensive than competitors</li>
          <li>• Limited health coaching</li>
          <li>• Fewer fitness benefits</li>
          <li>• Basic mental wellness support</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Wellness Coverage Quotes"
    description="Get personalized quotes with wellness benefits from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Wellness benefits can be included or add-on depending on plan level:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Cigna often includes wellness in base premium; Bupa and Allianz may charge separately for enhanced wellness features.</p>
  </section>

  <section id="wellness-benefits" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Wellness Program Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Annual Health Checks</h3>
        <p class="text-neutral-700 text-sm mb-4">What's included in preventive screenings:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> Full physical, bloodwork, imaging, specialist referrals</li>
          <li>• <strong>Bupa:</strong> Comprehensive exam with executive health options</li>
          <li>• <strong>Allianz:</strong> Basic physical and bloodwork; enhanced options available</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Cancer Screenings</h3>
        <p class="text-neutral-700 text-sm mb-4">Age-appropriate cancer prevention coverage:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> Mammograms, colonoscopies, PSA, skin checks</li>
          <li>• <strong>Bupa:</strong> Full cancer screening panel with genetic testing options</li>
          <li>• <strong>Allianz:</strong> Standard screenings; advanced tests may require approval</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Mental Wellness Programs</h3>
      <p class="text-blue-700 mb-4">Mental health is increasingly part of wellness coverage:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">Employee Assistance Program (EAP) included. Stress management, counseling, work-life balance support. Telehealth therapy available.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">Mental health coaching and counseling. Mindfulness apps included. Resilience training programs. Best overall mental wellness.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Allianz</h4>
          <p class="text-blue-700 text-sm">Basic mental health support through telehealth. Limited coaching. Adequate for general wellness needs.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the most comprehensive wellness program</li>
          <li>• Health coaching included is important to you</li>
          <li>• You value an integrated wellness platform</li>
          <li>• Mental health EAP is valuable for your situation</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Premium, concierge-style service appeals to you</li>
          <li>• Mental wellness is a top priority</li>
          <li>• You want a dedicated health advisor</li>
          <li>• Wellness rewards and incentives motivate you</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is a significant consideration</li>
          <li>• You need solid preventive coverage without extras</li>
          <li>• Basic wellness tracking is sufficient</li>
          <li>• You want good value with essential coverage</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is preventive care worth the extra premium?</h3>
        <p class="text-neutral-700">For most expats, yes. Preventive care catches health issues early when treatment is less expensive and more effective. A single comprehensive health check can pay for itself if it identifies a condition early. Mental wellness support can prevent burnout and related health issues common among expats.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I get health checks done anywhere?</h3>
        <p class="text-neutral-700">Yes, all three providers allow health checks at network facilities worldwide. Cigna and Bupa have dedicated executive health centers in major cities. You can also use any network provider offering comprehensive health assessments. Some providers offer reimbursement for out-of-network preventive care.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What vaccinations are covered?</h3>
        <p class="text-neutral-700">All three cover routine vaccinations (flu, tetanus, hepatitis) and travel-required vaccinations for your destination. COVID-19 vaccines are covered. Some plans include childhood vaccination schedules for dependents. Verify specific vaccines are covered before your appointment.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How do wellness apps and telehealth work abroad?</h3>
        <p class="text-neutral-700">All three providers offer mobile apps and telehealth that work globally with internet access. Cigna Wellbeing, Bupa Lifeworks, and Allianz MyHealth are accessible worldwide. Video consultations can be conducted from anywhere, though time zones may affect availability of live coaching sessions.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Wellness benefits vary by plan level and region. Always verify specific preventive care coverage directly with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
