---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', title: 'Quick Verdict' },
  { id: 'comparison', title: 'Side-by-Side Comparison' },
  { id: 'cigna', title: 'Cigna Global' },
  { id: 'bupa', title: 'Bupa Global' },
  { id: 'allianz', title: 'Allianz Care' },
  { id: 'pricing', title: 'Pricing Comparison' },
  { id: 'wellness-details', title: 'Wellness Coverage Details' },
  { id: 'best-for', title: 'Best For' },
  { id: 'faqs', title: 'FAQs' },
];

const relatedLinks = [
  { href: '/providers/cigna-global', title: 'Cigna Global Full Review' },
  { href: '/providers/bupa-global', title: 'Bupa Global Full Review' },
  { href: '/providers/allianz-care', title: 'Allianz Care Full Review' },
  { href: '/guides/preventive-care-abroad', title: 'Preventive Care Guide' },
  { href: '/guides/health-screenings-abroad', title: 'Health Screenings Abroad' },
];

const mainComparisonColumns = ['Feature', 'Cigna Global', 'Bupa Global', 'Allianz Care'];
const mainComparisonRows = [
  ['Annual Physical', 'Included—comprehensive plans', 'Included—most plans', 'Plan dependent'],
  ['Health Screenings', 'Covered—age-appropriate', 'Covered—age-appropriate', 'Varies by plan'],
  ['Vaccinations', 'Routine + travel vaccines', 'Routine vaccines', 'Plan dependent'],
  ['Cancer Screenings', 'Included—per guidelines', 'Included—per guidelines', 'Most plans'],
  ['Wellness Programs', 'Digital wellness platform', 'Bupa wellness resources', 'Limited'],
  ['Health Coaching', 'Available', 'Available', 'Premium plans only'],
  ['Gym Benefits', 'Not typically included', 'Some plans offer subsidies', 'Not typically included'],
  ['Mental Wellness', 'Apps + counseling', 'Resources available', 'Plan dependent'],
  ['Dental Checkups', 'Preventive dental included', 'Preventive dental included', 'Dental add-on required'],
];

const pricingColumns = ['Plan Level', 'Cigna Global', 'Bupa Global', 'Allianz Care'];
const pricingRows = [
  ['Basic (limited preventive)', '$2,500-3,500/yr', '$2,400-3,300/yr', '$2,200-3,000/yr'],
  ['Comprehensive (full preventive)', '$4,500-6,500/yr', '$4,200-6,000/yr', '$4,000-5,500/yr'],
  ['Premium (wellness extras)', '$6,500-9,000/yr', '$6,000-8,500/yr', '$5,500-7,500/yr'],
  ['Wellness benefit value', 'Up to $1,500/yr', 'Up to $1,200/yr', 'Up to $800/yr'],
  ['Preventive dental value', 'Up to $500/yr', 'Up to $400/yr', 'Add-on required'],
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz: Wellness & Preventive Care Comparison 2025"
  description="Compare wellness and preventive care benefits from Cigna, Bupa, and Allianz. Annual physicals, health screenings, vaccinations, and wellness programs."
  headline="Cigna vs Bupa vs Allianz"
  subheadline="Which Provider is Best for Wellness & Preventive Care?"
  heroImage="/images/compare/wellness-preventive-hero.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Cigna Global</h3>
        <p class="text-neutral-700 mb-4">Best overall wellness coverage with comprehensive preventive benefits, digital wellness platform, and integrated health coaching across all regions.</p>
        <p class="text-sm font-medium text-primary-700">Up to $1,500/yr wellness value</p>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Bupa Global</h3>
        <p class="text-neutral-700 mb-4">Strong preventive benefits with good wellness resources and some plans offering gym subsidies. Solid choice for holistic health focus.</p>
        <p class="text-sm font-medium text-purple-700">Up to $1,200/yr wellness value</p>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Allianz Care</h3>
        <p class="text-neutral-700 mb-4">More limited wellness benefits but competitive pricing. Good option if you primarily need medical coverage with basic preventive care.</p>
        <p class="text-sm font-medium text-green-700">Up to $800/yr wellness value</p>
      </div>
    </div>
  </section>

  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <div class="bg-primary-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-primary-800 mb-4">Cigna Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Cigna Global leads in wellness and preventive care with comprehensive benefits across most plan levels. Their digital wellness platform and integrated approach to health management set them apart.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Wellness Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Annual comprehensive health check included in most plans</li>
        <li>Age-appropriate cancer screenings (mammograms, colonoscopies, etc.)</li>
        <li>Routine and travel vaccinations covered</li>
        <li>Digital wellness platform with health tracking and resources</li>
        <li>Health coaching and chronic disease management programs</li>
        <li>Mental wellness apps and counseling access</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Higher premiums than competitors</li>
        <li>Some wellness benefits require higher-tier plans</li>
        <li>Gym memberships not typically covered</li>
        <li>Alternative therapies limited</li>
      </ul>
    </div>
  </section>

  <section id="bupa" class="mb-12">
    <div class="bg-purple-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-purple-800 mb-4">Bupa Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Bupa Global provides solid preventive care coverage with good wellness resources. Some plans include unique benefits like gym subsidies that appeal to health-conscious expats.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Wellness Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Annual health assessments on most comprehensive plans</li>
        <li>Cancer screening coverage following international guidelines</li>
        <li>Bupa wellness resources and health information</li>
        <li>Some plans include gym or fitness subsidies</li>
        <li>Preventive dental care included in comprehensive plans</li>
        <li>Health coaching available for chronic conditions</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Travel vaccinations may have limitations</li>
        <li>Digital wellness platform less developed than Cigna</li>
        <li>Gym benefits only on select plans</li>
        <li>Lower wellness benefit limits than Cigna</li>
      </ul>
    </div>
  </section>

  <section id="allianz" class="mb-12">
    <div class="bg-green-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-green-800 mb-4">Allianz Care</h2>
      <p class="text-lg text-neutral-700 mb-6">Allianz Care focuses more on medical coverage than wellness, with preventive benefits varying significantly by plan level. Good value if wellness isn't your primary concern.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Wellness Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Basic preventive care on most plans</li>
        <li>Cancer screenings covered on comprehensive plans</li>
        <li>Competitive pricing for medical + basic preventive</li>
        <li>Flexibility to add wellness benefits as needed</li>
        <li>Preventive care for children typically included</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Wellness benefits significantly below competitors</li>
        <li>Preventive dental requires separate add-on</li>
        <li>Limited wellness programs and resources</li>
        <li>Health coaching only on premium plans</li>
        <li>Travel vaccines may not be covered</li>
      </ul>
    </div>
  </section>

  <CTABox
    title="Prioritize Your Preventive Health"
    description="Find a plan that covers annual checkups, screenings, and wellness programs to keep you healthy while living abroad."
    buttonText="Compare Wellness Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing & Wellness Value</h2>
    <p class="text-neutral-600 mb-6">Annual premiums and preventive benefit values for a 40-year-old. Higher plans include more comprehensive wellness benefits.</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">Wellness benefit value includes annual physicals, screenings, vaccinations, and wellness programs. Actual usage may be lower.</p>
  </section>

  <section id="wellness-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Wellness Coverage Details</h2>
    
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Annual Health Checks</h3>
        <p class="text-neutral-700">Comprehensive health checks typically include physical examination, blood work (cholesterol, blood sugar, liver function), blood pressure monitoring, and basic vision/hearing tests. Cigna offers the most comprehensive assessments. Bupa's vary by plan. Allianz includes basic checkups but may limit frequency or scope.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Cancer Screenings</h3>
        <p class="text-neutral-700">All three cover age-appropriate cancer screenings following international guidelines. This includes mammograms (typically starting at 40 or 50), colonoscopies (typically starting at 45-50), cervical smears, and prostate screening discussions. Screening frequency follows medical guidelines, not annual automatic coverage.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Vaccinations</h3>
        <p class="text-neutral-700">Cigna covers both routine vaccinations (flu, tetanus boosters) and travel vaccines (hepatitis, typhoid, yellow fever). Bupa covers routine vaccines with some travel vaccines. Allianz varies—check your specific plan. Routine childhood vaccinations are typically covered on family plans across all providers.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Mental Wellness Programs</h3>
        <p class="text-neutral-700">Cigna offers digital mental wellness tools, apps, and access to counseling as part of their wellness approach. Bupa provides wellness resources and some mental health support. Allianz's mental wellness is limited unless you have comprehensive mental health coverage added. Consider this if stress and mental health are priorities.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Preventive Dental</h3>
        <p class="text-neutral-700">Cigna and Bupa include preventive dental (cleanings, checkups, x-rays) in comprehensive plans. Allianz requires a separate dental add-on. Preventive dental is important—regular cleanings prevent more expensive treatments later. If dental wellness matters, factor this into plan comparison.</p>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Choose Cigna If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Wellness is a high priority for you</li>
          <li>You want comprehensive preventive benefits</li>
          <li>Digital health tools appeal to you</li>
          <li>You value health coaching access</li>
          <li>You want travel vaccines covered</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Choose Bupa If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You want solid preventive benefits</li>
          <li>Gym subsidies interest you</li>
          <li>You prefer European-based wellness approach</li>
          <li>Preventive dental is important</li>
          <li>You want good value for wellness</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Choose Allianz If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Medical coverage is your priority</li>
          <li>Basic preventive care is sufficient</li>
          <li>Budget is a primary concern</li>
          <li>You'll get checkups locally anyway</li>
          <li>You prefer à la carte wellness options</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How often can I get an annual health check?</h3>
        <p class="text-neutral-700">Typically once per policy year, sometimes with minimum intervals (e.g., 12 months between checks). Some plans allow more frequent checks if medically indicated. Check your specific plan terms—comprehensive health assessments are usually annual, but individual tests may be available more frequently.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Are wellness benefits in addition to regular medical coverage?</h3>
        <p class="text-neutral-700">Yes, wellness and preventive benefits have separate limits from your main medical coverage. Using your full wellness benefit doesn't reduce your medical coverage. However, if a preventive test reveals a condition requiring treatment, that treatment uses your medical coverage.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I choose where to get my health check?</h3>
        <p class="text-neutral-700">Generally yes—you can use network providers for direct billing or any licensed provider for reimbursement. Some insurers have preferred wellness centers with streamlined booking. Cigna and Bupa may have specific wellness check facilities in major cities.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Do unused wellness benefits roll over?</h3>
        <p class="text-neutral-700">No, wellness benefits typically reset each policy year. If you don't use your annual health check or vaccination allowance, they don't accumulate. Schedule your preventive care to maximize the benefits you're paying for in your premium.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What screenings are covered at what ages?</h3>
        <p class="text-neutral-700">Providers follow international medical guidelines. Generally: cholesterol screening starts in 20s, diabetes screening for at-risk individuals or from age 45, mammograms from 40-50, colonoscopies from 45-50, prostate discussions from 50. Your doctor can advise based on personal risk factors.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is preventive care worth the higher premium?</h3>
        <p class="text-neutral-700">It depends on how you use healthcare. If you'll actually get annual checkups and screenings, the value can exceed $1,000/year. If you rarely see doctors, basic coverage may suffice. Preventive care can catch issues early, potentially saving significant costs and health impacts later.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 mb-12">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Wellness and preventive benefits vary by specific plan level and region. This comparison provides general guidance only. Verify current coverage details, benefit limits, and terms directly with providers. Medical screening recommendations should be discussed with your healthcare provider based on your individual health profile.
    </p>
  </div>
</PageShell>
