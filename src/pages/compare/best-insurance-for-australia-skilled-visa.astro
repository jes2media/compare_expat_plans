---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Australia Skilled Visa (2025)";
const description = "Compare top health insurance options for Australia's Skilled Independent (189) and Skilled Nominated (190) visas. Expert analysis of Cigna Global, Bupa Global, and Australian private health insurance.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "bupa-global", title: "Bupa Global" },
  { id: "australian-phi", title: "Australian Private Health" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "phi", header: "Australian PHI" },
];

const comparisonRows = [
  { feature: "Skilled Visa Acceptance", cigna: "✓ Accepted", bupa: "✓ Accepted (Bupa AU available)", phi: "✓ Standard for PR holders" },
  { feature: "Australian Network", cigna: "Good (private hospitals)", bupa: "Excellent (Bupa Australia)", phi: "Excellent (all private hospitals)" },
  { feature: "Medicare Access", cigna: "No (separate)", bupa: "No (separate)", phi: "Complements Medicare" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", bupa: "Moratorium option", phi: "12-month wait (by law)" },
  { feature: "International Coverage", cigna: "Worldwide", bupa: "Worldwide", phi: "None" },
  { feature: "MLS Exemption", cigna: "Does not exempt", bupa: "Bupa AU exempts", phi: "✓ Exempts from levy" },
  { feature: "Annual Maximum", cigna: "Unlimited", bupa: "Unlimited", phi: "Varies by procedure" },
  { feature: "Best For", cigna: "Global movers", bupa: "Transitional coverage", phi: "Long-term PR holders" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "phi", header: "Australian PHI" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", bupa: "100% covered", phi: "Private hospital access" },
  { coverage: "Outpatient Care", cigna: "100% covered", bupa: "100% covered", phi: "Extras cover required" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", bupa: "Unlimited", phi: "Not covered" },
  { coverage: "Prescription Drugs", cigna: "100% covered", bupa: "100% covered", phi: "PBS (separate system)" },
  { coverage: "Dental", cigna: "Optional", bupa: "Optional", phi: "Extras cover" },
  { coverage: "Vision", cigna: "Optional", bupa: "Optional", phi: "Extras cover" },
  { coverage: "Mental Health", cigna: "Full coverage", bupa: "Full coverage", phi: "Hospital cover included" },
  { coverage: "Pregnancy/Birth", cigna: "Optional add-on", bupa: "Optional add-on", phi: "12-month wait" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "phi", header: "Australian PHI" },
];

const pricingRows = [
  { age: "25-30", cigna: "A$350-550/month", bupa: "A$400-620/month", phi: "A$100-200/month" },
  { age: "30-35", cigna: "A$420-650/month", bupa: "A$480-740/month", phi: "A$100-200/month" },
  { age: "40-45", cigna: "A$600-920/month", bupa: "A$700-1,050/month", phi: "A$150-300/month" },
  { age: "50-55", cigna: "A$850-1,300/month", bupa: "A$980-1,480/month", phi: "A$200-400/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "phi", header: "Australian PHI" },
];

const networkRows = [
  { region: "Sydney", cigna: "Good - select private hospitals", bupa: "Excellent - Bupa network", phi: "Full private network" },
  { region: "Melbourne", cigna: "Good - select private hospitals", bupa: "Excellent - Bupa network", phi: "Full private network" },
  { region: "Brisbane", cigna: "Good", bupa: "Excellent", phi: "Full private network" },
  { region: "Perth/Adelaide", cigna: "Limited", bupa: "Good", phi: "Full private network" },
  { region: "Regional Australia", cigna: "Reimbursement", bupa: "Limited", phi: "Regional private facilities" },
  { region: "International", cigna: "Worldwide", bupa: "Worldwide", phi: "Not covered" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Australia's Skilled Independent (189) and Skilled Nominated (190) visas"
    heroImage="/images/countries/australia-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Australia Skilled Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Australia's Skilled Independent (189) and Skilled Nominated (190) visas grant permanent residency to skilled professionals. As a permanent resident, you're eligible for Medicare—Australia's public healthcare system. However, private health insurance plays a unique role in the Australian system.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Considerations</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Medicare access granted with PR (after visa approval)</li>
          <li>• Private health insurance is optional but incentivized</li>
          <li>• Medicare Levy Surcharge (MLS): 1-1.5% extra tax without PHI if income &gt;$93,000</li>
          <li>• Lifetime Health Cover (LHC): premiums increase 2%/year if you join PHI after age 31</li>
          <li>• International insurance doesn't exempt you from MLS or LHC penalties</li>
          <li>• Waiting periods apply for pre-existing conditions (12 months by law)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Australia's system is unique: Medicare covers most essential care, but private insurance provides faster access to elective surgery, choice of doctor, and private hospital rooms. The government actively incentivizes private coverage through tax penalties (MLS) and lifetime loading (LHC).
      </p>

      <p class="text-neutral-700">
        For skilled visa holders planning to stay in Australia long-term, Australian private health insurance is typically the best choice for cost and tax efficiency. International insurance makes sense during the transition period or if you'll be moving countries again.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Skilled Visa Holders</h2>

      <p class="text-neutral-700 mb-6">
        Skilled visa holders have three main paths: international coverage, global insurers with Australian products (like Bupa), or local Australian private health insurance:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive international coverage that works well for skilled migrants who may not stay in Australia permanently or who travel internationally frequently.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Worldwide coverage (great for global movers)</li>
            <li>• Access to select Australian private hospitals</li>
            <li>• No waiting periods for most conditions</li>
            <li>• Comprehensive coverage including mental health</li>
            <li>• Portable if you leave Australia</li>
            <li>• 24/7 multilingual support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Does NOT exempt from Medicare Levy Surcharge</li>
            <li>• Does NOT count toward Lifetime Health Cover</li>
            <li>• Much more expensive than Australian PHI</li>
            <li>• Limited Australian network vs. local PHI</li>
            <li>• Not cost-effective for long-term AU residence</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Global coverage for internationally mobile professionals."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Bupa Global / Bupa Australia</h2>

      <p class="text-neutral-700 mb-4">
        Bupa is unique—they offer both international coverage (Bupa Global) and Australian private health insurance (Bupa Australia). This makes them ideal for skilled migrants transitioning from international to local coverage.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Bupa Australia product exempts from MLS</li>
            <li>• Bupa Australia counts for LHC purposes</li>
            <li>• Excellent Australian hospital network</li>
            <li>• Can transition from Global to Australia product</li>
            <li>• Strong brand recognition in Australia</li>
            <li>• Bupa Global offers worldwide coverage</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Bupa Global doesn't exempt from MLS</li>
            <li>• 12-month wait for pre-existing (Bupa AU)</li>
            <li>• Bupa Global is expensive for AU-only living</li>
            <li>• Need to choose correct product for needs</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Bupa Quote"
        description="International coverage with Australian local options."
        buttonText="Get Quote"
        buttonHref="/go/bupa"
      />
    </section>

    <section id="australian-phi" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Australian Private Health Insurance</h2>

      <p class="text-neutral-700 mb-4">
        Australian PHI (from Bupa Australia, Medibank, HCF, NIB, etc.) is the standard choice for permanent residents. It exempts you from tax penalties, provides choice of private hospitals, and integrates with Medicare.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Exempts from Medicare Levy Surcharge</li>
            <li>• Counts toward Lifetime Health Cover</li>
            <li>• Most affordable option for AU residence</li>
            <li>• Full private hospital network access</li>
            <li>• Extras cover for dental, optical, physio</li>
            <li>• Integrates seamlessly with Medicare</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• 12-month waiting period for pre-existing</li>
            <li>• 2-month wait for most services</li>
            <li>• 12-month wait for pregnancy/birth</li>
            <li>• No international coverage at all</li>
            <li>• Gap payments for some procedures</li>
          </ul>
        </div>
      </div>

      <div class="bg-neutral-50 p-4 rounded-lg">
        <p class="text-neutral-700 text-sm">
          <strong>Compare Australian PHI at:</strong> privatehealth.gov.au (government comparison site), iSelect, Compare the Market, or directly with insurers like Bupa Australia, Medibank, HCF, NIB. Premiums are regulated and similar across insurers—differences are in network agreements and extras benefits.
        </p>
      </div>
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares. Remember that skilled visa holders get Medicare—PHI supplements it:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Medicare covers GP visits, public hospital care, and most pathology. PHI adds private hospital choice, shorter waits for elective surgery, and extras (dental, optical). International insurance provides comprehensive standalone coverage without Medicare integration.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Australian PHI is dramatically cheaper than international coverage. These ranges represent hospital + extras cover:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        The cost difference is significant. For a 35-year-old, Australian PHI is roughly 20-30% the cost of international coverage. Factor in MLS savings (1-1.5% of income over $93,000) and the financial case for local PHI is strong.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Australia</h2>

      <p class="text-neutral-700 mb-6">
        Australia has excellent healthcare in major cities. Here's network access comparison:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Australian PHI provides the broadest local network. International insurers have more limited Australian partnerships but offer worldwide coverage. For Australia-only living, local PHI provides better access.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Skilled Professional Settling in Sydney</h3>
          <p class="text-neutral-600 mb-3">32-year-old software engineer with 189 visa, earning $150,000, plans to stay in Australia long-term.</p>
          <p class="text-green-700 font-medium">Recommendation: Australian PHI (Hospital + Extras)</p>
          <p class="text-neutral-600 text-sm">MLS savings alone justify PHI cost. Get hospital cover to avoid MLS, add extras for dental/optical. Start before turning 31 to avoid LHC loading. Most cost-effective long-term.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Globally Mobile Professional</h3>
          <p class="text-neutral-600 mb-3">38-year-old consultant with 190 visa, travels internationally 40% of the year for work.</p>
          <p class="text-amber-700 font-medium">Recommendation: Australian PHI + Travel Insurance OR Cigna Global</p>
          <p class="text-neutral-600 text-sm">Get minimum Australian PHI to avoid MLS/LHC penalties. Add comprehensive travel insurance for international trips. Alternatively, Cigna Global if you might relocate within 2-3 years.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Young Skilled Migrant, Lower Income</h3>
          <p class="text-neutral-600 mb-3">28-year-old nurse with 189 visa, earning $75,000, healthy, no immediate healthcare needs.</p>
          <p class="text-green-700 font-medium">Recommendation: Basic Australian PHI now</p>
          <p class="text-neutral-600 text-sm">Income below MLS threshold ($93,000) but get PHI now to avoid LHC loading after 31. Basic hospital cover is affordable (~$100/month). Can upgrade later when income grows.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Skilled Migrant with Pre-existing Conditions</h3>
          <p class="text-neutral-600 mb-3">45-year-old engineer with 189 visa, has managed diabetes and needs regular care.</p>
          <p class="text-amber-700 font-medium">Recommendation: Australian PHI + Medicare</p>
          <p class="text-neutral-600 text-sm">Medicare covers your diabetes care immediately (no waiting periods for public system). Australian PHI has 12-month pre-existing wait but provides private hospital access after wait period. International insurance offers no waiting but costs 3-4x more.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Couple Planning Family</h3>
          <p class="text-neutral-600 mb-3">30-year-old couple with 189 visas, planning to have children in Australia.</p>
          <p class="text-green-700 font-medium">Recommendation: Australian PHI with pregnancy cover</p>
          <p class="text-neutral-600 text-sm">Get PHI with pregnancy cover immediately—there's a 12-month waiting period before you can claim pregnancy benefits. Medicare covers public birth (excellent), but PHI adds private obstetrician choice and private room.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most skilled visa holders planning to stay in Australia, <strong>Australian Private Health Insurance</strong> is the clear choice—it's more affordable, exempts you from tax penalties, and provides better local network access. <strong>International insurance</strong> only makes sense if you're highly mobile internationally or uncertain about staying in Australia long-term.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Australian PHI If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Planning to stay in Australia</li>
            <li>• Income over $93,000 (MLS)</li>
            <li>• Under 31 (avoid LHC loading)</li>
            <li>• Want best local network</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• May relocate in 2-3 years</li>
            <li>• Travel internationally often</li>
            <li>• Want immediate full coverage</li>
            <li>• MLS is acceptable cost</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Bupa If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want transition flexibility</li>
            <li>• Bupa AU + Global options</li>
            <li>• Prefer single insurer</li>
            <li>• Value brand recognition</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">When do I get Medicare access with a skilled visa?</h3>
          <p class="text-neutral-600">Medicare eligibility starts when your permanent visa is granted (not just applied for). Once you have your 189/190 visa, enroll at a Medicare service center. You can then see any bulk-billing GP for free.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What is the Medicare Levy Surcharge (MLS)?</h3>
          <p class="text-neutral-600">MLS is an extra 1-1.5% tax on top of the standard 2% Medicare Levy if you earn over $93,000 (single) and don't have Australian PHI hospital cover. At $150,000 income, MLS costs ~$1,875/year—often more than PHI premiums.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What is Lifetime Health Cover (LHC) loading?</h3>
          <p class="text-neutral-600">If you don't get Australian PHI hospital cover by July 1 after turning 31, your premiums increase by 2% for each year you delay (up to 70% loading). This loading applies for 10 years. Getting PHI before 31 avoids this entirely.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can international insurance exempt me from MLS?</h3>
          <p class="text-neutral-600">No. Only Australian government-registered private health insurance with hospital cover exempts you from MLS. Cigna Global, SafetyWing, and other international policies don't qualify. You'd pay MLS on top of international premiums.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about the 12-month waiting period for pre-existing conditions?</h3>
          <p class="text-neutral-600">Australian PHI has a legally mandated 12-month waiting period for pre-existing conditions. During this time, Medicare still covers your care in the public system. After 12 months, PHI covers private hospital care for those conditions.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Should I get "Hospital" or "Extras" or both?</h3>
          <p class="text-neutral-600">Hospital cover is what exempts you from MLS and is essential for private hospital access. Extras cover dental, optical, physio, etc. Most people get both. If budget-constrained, prioritize hospital cover (for MLS exemption) and pay for dental/optical out-of-pocket.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Medicare, MLS, and LHC rules change. Verify current requirements with Services Australia and the Australian Taxation Office. Compare Australian PHI at privatehealth.gov.au. Confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance, tax, or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
