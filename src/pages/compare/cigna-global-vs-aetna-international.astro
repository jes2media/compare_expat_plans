];

const coverageColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const coverageRows = [
  { feature: 'Network Size', cigna: '1.5M+ global', aetna: '1.7M+ (incl. US Aetna)' },
  { feature: 'Inpatient Care', cigna: true, aetna: true },
  { feature: 'Outpatient Care', cigna: 'Gold/Platinum', aetna: 'Prime/Platinum' },
  { feature: 'Mental Health', cigna: true, aetna: true },
  { feature: 'Maternity', cigna: 'Optional (10-mo wait)', aetna: 'Optional (12-mo wait)' },
  { feature: 'Dental', cigna: 'Optional', aetna: 'Optional module' },
  { feature: 'Vision', cigna: 'Optional', aetna: 'Optional module' },
  { feature: 'Wellness Programs', cigna: true, aetna: true },
  { feature: 'Medical Evacuation', cigna: 'Included', aetna: 'Up to $1M' },
  { feature: 'US Coverage', cigna: 'Add-on (+40-60%)', aetna: 'Integrated' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Gold' },
  { key: 'aetna', header: 'Aetna Prime' },
];

const pricingRows = [
  { profile: 'Age 30, ex-US', cigna: '$140-200/mo', aetna: '$170-240/mo' },
  { profile: 'Age 40, ex-US', cigna: '$200-280/mo', aetna: '$230-320/mo' },
  { profile: 'Age 50, ex-US', cigna: '$300-400/mo', aetna: '$340-450/mo' },
  { profile: 'Age 30, with US', cigna: '$210-300/mo', aetna: '$170-240/mo' },
  { profile: 'Age 40, with US', cigna: '$300-420/mo', aetna: '$230-320/mo' },
  { profile: 'Family of 4, ex-US', cigna: '$450-600/mo', aetna: '$500-680/mo' },
];

const planTiersColumns = [
  { key: 'tier', header: 'Tier' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const planTiersRows = [
  { tier: 'Entry Level', cigna: 'Silver', aetna: 'Foundation' },
  { tier: 'Mid-Range', cigna: 'Gold', aetna: 'Prime' },
  { tier: 'Premium', cigna: 'Platinum', aetna: 'Platinum' },
  { tier: 'Modular Option', cigna: 'No', aetna: 'Navigator plans' },
  { tier: 'Max Deductible', cigna: '$10,000', aetna: '$5,000' },
