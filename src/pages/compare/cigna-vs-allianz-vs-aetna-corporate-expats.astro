---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'corporate-considerations', text: 'Corporate Expat Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'Allianz Care Full Review', href: '/providers/allianz-care' },
  { title: 'Aetna International Full Review', href: '/providers/aetna-international' },
  { title: 'Insurance for Corporate Expats', href: '/insurance-for/corporate-expats' },
  { title: 'Best Executive Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'Corporate plans', cigna: 'Extensive options', allianz: 'Strong options', aetna: 'Corporate focus' },
  { feature: 'Executive coverage', cigna: 'Premium tiers', allianz: 'Premium tiers', aetna: 'Excellent' },
  { feature: 'Global network', cigna: 'Excellent', allianz: 'Very good', aetna: 'Excellent' },
  { feature: 'US coverage', cigna: 'Full available', allianz: 'Full available', aetna: 'Native US network' },
  { feature: 'Family coverage', cigna: 'Comprehensive', allianz: 'Comprehensive', aetna: 'Comprehensive' },
  { feature: 'Evacuation/repatriation', cigna: 'Included', allianz: 'Included', aetna: 'Included' },
  { feature: 'EAP services', cigna: 'Available', allianz: 'Available', aetna: 'Strong' },
  { feature: 'Assignment support', cigna: 'Good', allianz: 'Good', aetna: 'Excellent' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { scenario: 'Executive, age 40', cigna: '$8,000-12,000/yr', allianz: '$7,500-11,000/yr', aetna: '$9,000-14,000/yr' },
  { scenario: 'Executive + family', cigna: '$18,000-28,000/yr', allianz: '$16,000-25,000/yr', aetna: '$20,000-32,000/yr' },
  { scenario: 'With US coverage', cigna: 'Included in global', allianz: '+30-40%', aetna: 'Included—native' },
  { scenario: 'Premium executive tier', cigna: '$15,000-22,000/yr', allianz: '$14,000-20,000/yr', aetna: '$18,000-26,000/yr' },
  { scenario: 'Dental + vision add-on', cigna: '+$1,500-2,500/yr', allianz: '+$1,200-2,000/yr', aetna: '+$1,800-3,000/yr' },
];
---

<PageShell
  title="Cigna vs Allianz vs Aetna: Best for Corporate Expats 2025"
  description="Compare Cigna, Allianz, and Aetna for corporate expats and executives. Global networks, US coverage, family benefits, and executive-level protection."
  headline="Cigna vs Allianz vs Aetna: Corporate Expat Insurance"
  subheadline="Which insurer is best for corporate assignees and executives? Global coverage, family protection, and benefits that match your position."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Overall</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Strongest global network for mobile executives. Excellent coverage across regions. Best for corporate expats who move frequently.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Allianz Care</p>
      <p class="text-sm text-neutral-600 mb-3">Competitive corporate pricing with comprehensive benefits. Good global network at lower cost than competitors.</p>
      <a href="/providers/allianz-care" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best for US Expats</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Aetna International</p>
      <p class="text-sm text-neutral-600 mb-3">Native US network access. Excellent for American executives abroad. Strong assignment support services.</p>
      <a href="/providers/aetna-international" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global is a leader in corporate expat insurance, serving multinational companies and their assignees worldwide. Their extensive global network and premium executive tiers make them ideal for senior professionals and mobile executives.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Corporate Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Strongest global network for mobile executives</li>
      <li>Premium executive plan tiers</li>
      <li>Comprehensive family coverage</li>
      <li>Full US coverage available</li>
      <li>Medical evacuation and repatriation</li>
      <li>Employee assistance programs</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Premium pricing</li>
      <li>Can feel corporate/bureaucratic</li>
      <li>Complex plan structures</li>
      <li>May be overkill for simple assignments</li>
    </ul>
  </div>

  <h2 id="allianz">Allianz Care</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Allianz Care offers competitive corporate coverage at better prices than Cigna or Aetna. Their global network covers most executive needs while providing better value for companies managing multiple assignees.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Corporate Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most competitive corporate pricing</li>
      <li>Strong global network</li>
      <li>Good executive plan options</li>
      <li>Comprehensive family coverage</li>
      <li>Evacuation and repatriation included</li>
      <li>Employee assistance available</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>US coverage adds significant cost</li>
      <li>Network gaps vs Cigna in some regions</li>
      <li>Less US-specific support than Aetna</li>
      <li>Executive tiers less premium than competitors</li>
    </ul>
  </div>

  <h2 id="aetna">Aetna International</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Aetna International specializes in corporate expat coverage with particular strength for US-headquartered companies. Their native US network access and assignment support services make them ideal for American executives abroad.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Corporate Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Native US network—Aetna domestic access</li>
      <li>Excellent for US-based companies</li>
      <li>Strong assignment support services</li>
      <li>Comprehensive EAP programs</li>
      <li>Family coverage with US school access</li>
      <li>CVS/Caremark pharmacy network</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Highest premiums of the three</li>
      <li>Less competitive outside Americas</li>
      <li>US-centric focus may not suit all</li>
      <li>Complex for non-US companies</li>
    </ul>
  </div>

  <CTABox
    title="Find Executive Coverage for Your Assignment"
    description="Compare plans designed for corporate expats and executives. Global networks, family coverage, and benefits that match your position."
    buttonText="Compare Corporate Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Annual premiums for corporate expats and executives. Prices vary significantly by plan tier and coverage scope.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Corporate plans are typically employer-paid. Prices shown are per-person annual costs. Group rates may be lower. US coverage significantly impacts pricing for non-US insurers.</p>

  <h2 id="corporate-considerations">Corporate Expat Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Employer vs Self-Selected</h3>
      <p class="text-neutral-700">Most corporate expats receive insurance through their employer. However, you may have input into plan selection or negotiate better coverage. Understanding the market helps you advocate for appropriate protection. If your employer's coverage is inadequate, some executives purchase supplemental individual coverage.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Family Coverage</h3>
      <p class="text-neutral-700">Corporate assignments typically include family coverage. Verify spouse and children are fully covered—not all plans are equal. Maternity coverage may have waiting periods even on corporate plans. Children's education-related medical exams, vaccinations, and sports physicals should be covered. Review family benefits carefully.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">US Coverage for American Expats</h3>
      <p class="text-neutral-700">American executives often return to the US for visits, home leave, or medical care. Aetna provides native US network access. Cigna offers full US coverage. Allianz can add US coverage but at significant cost. If US healthcare access matters, prioritize Aetna or Cigna. US coverage can add 30-50% to non-US insurer premiums.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Assignment Transitions</h3>
      <p class="text-neutral-700">Corporate expats move between countries. All three insurers maintain coverage continuity across relocations—no re-underwriting when you move from Singapore to London. This portability is essential. Verify your plan covers the specific countries in your assignment rotation. Network strength varies by region.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Executive Health Services</h3>
      <p class="text-neutral-700">Premium executive plans often include enhanced services—annual executive health checks, second medical opinions, dedicated case managers, and priority access. These services justify higher premiums for senior executives whose time and health are valuable. Compare what's included at different plan tiers.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You move between multiple regions</li>
        <li>Global network strength matters</li>
        <li>You're a mobile senior executive</li>
        <li>Your company rotates assignments</li>
        <li>Comprehensive coverage is priority</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose Allianz If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Cost efficiency matters to employer</li>
        <li>You're based primarily in Europe</li>
        <li>US coverage isn't critical</li>
        <li>Good coverage at better value</li>
        <li>Your company has multiple assignees</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose Aetna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You're an American executive</li>
        <li>US network access is essential</li>
        <li>Your company is US-headquartered</li>
        <li>You return to US frequently</li>
        <li>Assignment support matters</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I influence my employer's choice of insurer?</h3>
      <p class="text-neutral-700">Often yes—especially for senior roles. If your employer is selecting coverage, provide input on your needs (family coverage, specific regions, US access). For executive hires, insurance quality is a negotiable benefit. If current coverage is inadequate, request upgrades or supplemental individual coverage as part of your package.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What happens to my coverage when my assignment ends?</h3>
      <p class="text-neutral-700">Corporate coverage typically ends when employment ends. All three insurers offer conversion to individual plans—you keep your coverage history and avoid re-underwriting. If returning to your home country, you may transition to domestic insurance. Plan ahead—don't have coverage gaps between assignment end and next coverage.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is my spouse's coverage equivalent to mine?</h3>
      <p class="text-neutral-700">Usually yes on corporate plans—dependents receive the same coverage level. However, verify specifics. Some plans have different limits for spouses or children. Maternity coverage should be confirmed if relevant. Mental health, dental, and optical benefits for family members may vary. Review the full family benefits schedule.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about coverage during home leave?</h3>
      <p class="text-neutral-700">All three insurers cover home country visits (typically 30-90 days/year). This is essential for corporate expats returning for holidays, family visits, or business. Verify your specific limit. If you spend extended time in your home country, ensure adequate coverage—some plans have caps that may not match your travel patterns.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Are executive health checks included?</h3>
      <p class="text-neutral-700">Premium executive tiers often include annual comprehensive health checks, second medical opinions, and dedicated case management. Standard corporate plans may not include these extras. If executive health services matter, confirm they're included in your specific plan tier or request them as part of your employment package.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How do claims work with corporate plans?</h3>
      <p class="text-neutral-700">Corporate plans typically work the same as individual plans—direct billing where available, reimbursement otherwise. Your employer's HR or benefits team may provide support. Some corporate plans have dedicated service lines for member companies. Claims processes are generally streamlined for corporate accounts.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Corporate insurance is typically selected and paid by employers. Individual circumstances vary. Coverage details depend on specific corporate contracts. This comparison provides general guidance—verify your specific plan benefits with your employer's HR department and the insurer directly.
    </p>
  </div>
</PageShell>
