---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Non-Lucrative Visa Insurance Requirements', level: 2 },
  { id: 'quick-comparison', text: 'Quick Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'sanitas', text: 'Sanitas (Local Option)', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'pricing', text: 'Pricing for Applicants', level: 2 },
  { id: 'spain-network', text: 'Spain Network Access', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'verdict', text: 'Our Recommendation', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { text: 'Spain Non-Lucrative Visa Guide', href: '/visas/retirement-visa/in/spain' },
  { text: 'Spain Seniors Insurance', href: '/insurance-for/seniors/in/spain' },
  { text: 'Cigna Global Review', href: '/providers/cigna-global' },
  { text: 'Allianz Care Review', href: '/providers/allianz-care' },
];

const quickCompareColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'sanitas', header: 'Sanitas' },
  { key: 'allianz', header: 'Allianz Care' },
];

const quickCompareRows = [
  { feature: 'Visa Accepted', cigna: '✓ Yes', sanitas: '✓ Yes (preferred)', allianz: '✓ Yes' },
  { feature: 'Spain Network', cigna: 'Excellent', sanitas: 'Extensive (own network)', allianz: 'Very Good' },
  { feature: 'Coverage Type', cigna: 'International', sanitas: 'Spain only', allianz: 'International' },
  { feature: 'Max Entry Age', cigna: '74', sanitas: '69-74 (varies)', allianz: '74' },
  { feature: 'Monthly Cost (65yo)', cigna: '€350-450', sanitas: '€180-280', allianz: '€320-400' },
  { feature: 'Copays', cigna: 'None/Low', sanitas: 'Yes (€5-20)', allianz: 'None/Low' },
  { feature: 'Travel Coverage', cigna: 'Worldwide', sanitas: 'Limited', allianz: 'Worldwide' },
  { feature: 'Best For', cigna: 'International flexibility', sanitas: 'Spain-focused, budget', allianz: 'Value + travel' },
];

const coverageColumns = [
  { key: 'benefit', header: 'Benefit' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'sanitas', header: 'Sanitas' },
  { key: 'allianz', header: 'Allianz Care' },
];

const coverageRows = [
  { benefit: 'Hospitalization', cigna: 'Unlimited', sanitas: 'Full coverage', allianz: '€3M' },
  { benefit: 'Outpatient Care', cigna: 'Full coverage', sanitas: 'Full (with copays)', allianz: 'Full coverage' },
  { benefit: 'Emergency', cigna: 'Worldwide', sanitas: 'Spain + EU emergency', allianz: 'Worldwide' },
  { benefit: 'Repatriation', cigna: 'Included', sanitas: 'Limited', allianz: 'Included' },
  { benefit: 'Pre-existing', cigna: 'Underwriting', sanitas: 'Waiting periods', allianz: 'Flexible underwriting' },
  { benefit: 'Mental Health', cigna: 'Standard limits', sanitas: 'Basic', allianz: 'Enhanced' },
  { benefit: 'Dental', cigna: 'Optional add-on', sanitas: 'Often included', allianz: 'Optional add-on' },
  { benefit: 'Home Country', cigna: 'Add-on available', sanitas: 'Not covered', allianz: 'Add-on available' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'sanitas', header: 'Sanitas' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Individual, Age 55', cigna: '€260-330/mo', sanitas: '€140-180/mo', allianz: '€230-290/mo' },
  { profile: 'Individual, Age 65', cigna: '€350-450/mo', sanitas: '€180-280/mo', allianz: '€320-400/mo' },
  { profile: 'Individual, Age 70', cigna: '€450-570/mo', sanitas: '€250-380/mo', allianz: '€400-500/mo' },
  { profile: 'Couple, Age 60', cigna: '€580-740/mo', sanitas: '€300-420/mo', allianz: '€520-660/mo' },
  { profile: 'Couple, Age 65', cigna: '€700-900/mo', sanitas: '€360-560/mo', allianz: '€640-800/mo' },
];
---

<PageShell
  title="Best Health Insurance for Spain Non-Lucrative Visa: Cigna vs Sanitas vs Allianz | 2025"
  description="Compare the best health insurance for Spain non-lucrative visa. Cigna Global vs Sanitas vs Allianz Care - coverage, pricing, Spain networks, and which to choose."
  headline="Best Health Insurance for Spain Non-Lucrative Visa"
  subheadline="Cigna Global vs Sanitas vs Allianz Care: International coverage or Spanish insurer for your retirement visa?"
  heroImage="/images/countries/spain-hero-bg.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <section id="overview" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Non-Lucrative Visa Insurance Requirements</h2>
    <p class="mb-4">
      Spain's non-lucrative visa has some of the strictest insurance requirements in Europe. Spanish consulates explicitly require private health insurance with no copays for essential services—a requirement that eliminates many budget options and even some international policies.
    </p>

    <div class="bg-red-50 border border-red-200 rounded-lg p-6 my-6">
      <h3 class="font-semibold text-red-900 mb-2">Spain's Strict Insurance Requirements</h3>
      <ul class="space-y-2 text-red-800">
        <li><strong>No copays:</strong> Many consulates reject policies with copayments for hospitalization or essential care</li>
        <li><strong>Full coverage:</strong> Must cover all medical contingencies without exclusions</li>
        <li><strong>Spanish provider or equivalent:</strong> Some consulates prefer Spanish insurers (Sanitas, Adeslas, Mapfre)</li>
        <li><strong>Valid for visa duration:</strong> Usually 1 year minimum with renewal guarantee</li>
        <li><strong>No coverage caps:</strong> Unlimited or very high coverage limits required</li>
      </ul>
    </div>

    <p class="mb-4">
      This creates a unique decision: choose a Spanish insurer like Sanitas (lower cost, consulate-preferred, but Spain-only coverage) or an international provider like Cigna or Allianz (higher cost, more flexibility, worldwide coverage). Both approaches work, but they serve different needs.
    </p>
    <p>
      Unlike Portugal's D7 visa where international insurance is standard, Spain's consulates often have strong preferences. Check with your specific consulate before purchasing—requirements can vary between countries and even between consulates in the same country.
    </p>
  </section>

  <section id="quick-comparison" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Comparison</h2>
    <p class="mb-4">
      Here's how Cigna Global, Sanitas, and Allianz Care compare for non-lucrative visa applicants. The key decision: international flexibility vs. Spanish insurer advantages.
    </p>

    <ComparisonTable columns={quickCompareColumns} rows={quickCompareRows} />

    <div class="grid md:grid-cols-3 gap-4 mt-6">
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-center">
        <p class="font-semibold text-blue-900">Best International</p>
        <p class="text-2xl font-bold text-blue-700">Cigna Global</p>
      </div>
      <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 text-center">
        <p class="font-semibold text-orange-900">Best Spanish/Budget</p>
        <p class="text-2xl font-bold text-orange-700">Sanitas</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
        <p class="font-semibold text-green-900">Best Balance</p>
        <p class="text-2xl font-bold text-green-700">Allianz Care</p>
      </div>
    </div>
  </section>

  <CTABox
    title="Get Non-Lucrative Visa Insurance Quotes"
    description="Compare personalized quotes from international and Spanish providers. Takes 5 minutes, no commitment."
    buttonText="Compare Quotes Now"
    buttonHref="/get-quotes"
    variant="highlight"
  />

  <section id="cigna-global" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Cigna Global for Non-Lucrative Visa</h2>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mb-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-neutral-900 mb-2">Strengths</h3>
          <ul class="space-y-1 text-neutral-600">
            <li>✓ Worldwide coverage including home country visits</li>
            <li>✓ No copays on comprehensive plans (visa-compliant)</li>
            <li>✓ Excellent Spain network (Quirónsalud, HM, Vithas)</li>
            <li>✓ 24/7 English support</li>
            <li>✓ Seamless if you move countries later</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-neutral-900 mb-2">Considerations</h3>
          <ul class="space-y-1 text-neutral-600">
            <li>• Higher cost than Spanish insurers</li>
            <li>• Some consulates prefer Spanish providers</li>
            <li>• May need to provide additional documentation</li>
          </ul>
        </div>
      </div>
    </div>

    <p class="mb-4">
      Cigna Global makes sense for non-lucrative visa applicants who want international flexibility. If you plan to travel frequently, maintain ties to your home country, or might relocate within Europe, Cigna's worldwide coverage eliminates the need for separate travel insurance.
    </p>
    <p class="mb-4">
      Their Spain network is excellent—Quirónsalud (Spain's largest private hospital group), HM Hospitales, Vithas, and major facilities in Madrid, Barcelona, Valencia, and the Costa del Sol. Direct billing is available at most major hospitals, minimizing out-of-pocket hassle.
    </p>
    <p>
      <strong>Best for:</strong> Applicants who value international coverage, plan significant travel, are American or maintain US ties, or anticipate potentially moving within Europe.
    </p>

    <div class="mt-4">
      <a href="/go/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-700 transition" style="color: white !important;">Get Cigna Quote →</a>
    </div>
  </section>

  <section id="sanitas" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Sanitas for Non-Lucrative Visa</h2>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mb-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-neutral-900 mb-2">Strengths</h3>
          <ul class="space-y-1 text-neutral-600">
            <li>✓ Preferred by many Spanish consulates</li>
            <li>✓ 40-50% cheaper than international options</li>
            <li>✓ Huge Spain network (own hospitals + partners)</li>
            <li>✓ Dental often included</li>
            <li>✓ Spanish-speaking support (English available)</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-neutral-900 mb-2">Considerations</h3>
          <ul class="space-y-1 text-neutral-600">
            <li>• Spain-only coverage (travel insurance needed separately)</li>
            <li>• Copays on most plans (may not satisfy all consulates)</li>
            <li>• Age limits for new enrollment (typically 69-74)</li>
            <li>• Pre-existing condition waiting periods</li>
            <li>• Less flexibility if you move countries</li>
          </ul>
        </div>
      </div>
    </div>

    <p class="mb-4">
      Sanitas (owned by Bupa) is Spain's largest private health insurer with over 2 million customers. Their "Más Salud" and "Integral" plans are commonly used for non-lucrative visa applications. As a Spanish company, consulates are familiar with their policies and acceptance is straightforward.
    </p>
    <p class="mb-4">
      The cost savings are substantial—often €150-200/month less than international alternatives. For retirees planning to settle permanently in Spain with minimal international travel, Sanitas delivers excellent value. Their network includes their own hospitals plus partnerships with most major Spanish private facilities.
    </p>
    <p class="mb-4">
      <strong>Important:</strong> Sanitas plans include copays (€5-20 for various services). Some consulates accept this; others explicitly require no-copay policies. Verify with your consulate before purchasing. Sanitas offers "sin copago" (no copay) options at higher premiums.
    </p>
    <p>
      <strong>Best for:</strong> Applicants committed to Spain long-term, budget-conscious retirees, those who won't travel extensively, and applicants whose consulate accepts copay policies or Sanitas specifically.
    </p>

    <div class="mt-4">
      <a href="/get-quotes" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-700 transition" style="color: white !important;">Get Sanitas Quote →</a>
    </div>
  </section>

  <section id="allianz-care" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Allianz Care for Non-Lucrative Visa</h2>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mb-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-neutral-900 mb-2">Strengths</h3>
          <ul class="space-y-1 text-neutral-600">
            <li>✓ International coverage at competitive pricing</li>
            <li>✓ Strong European presence (German company)</li>
            <li>✓ Enhanced mental health coverage</li>
            <li>✓ Flexible pre-existing condition handling</li>
            <li>✓ Good Spain network</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-neutral-900 mb-2">Considerations</h3>
          <ul class="space-y-1 text-neutral-600">
            <li>• More expensive than Sanitas (but cheaper than Cigna)</li>
            <li>• Smaller direct billing network than Cigna in Spain</li>
            <li>• Digital tools less polished</li>
          </ul>
        </div>
      </div>
    </div>

    <p class="mb-4">
      Allianz Care offers a middle ground: international coverage and flexibility like Cigna, but at prices 10-15% lower. For non-lucrative applicants who want worldwide coverage without paying top-tier premiums, Allianz hits a sweet spot.
    </p>
    <p class="mb-4">
      Their European heritage means strong understanding of Spanish healthcare and EU regulations. Plans are designed for European living with global flexibility. Mental health coverage is notably better than competitors—valuable for retirees adjusting to life abroad.
    </p>
    <p>
      <strong>Best for:</strong> Applicants wanting international flexibility at better value than Cigna, Europeans familiar with reimbursement models, those prioritizing mental health coverage, and budget-conscious applicants who still need travel coverage.
    </p>

    <div class="mt-4">
      <a href="/go/allianz-care" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-700 transition" style="color: white !important;">Get Allianz Quote →</a>
    </div>
  </section>

  <section id="coverage-comparison" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Coverage Comparison</h2>
    <p class="mb-4">
      Understanding how coverage differs is crucial—especially the gap between Spanish-only and international policies.
    </p>

    <ComparisonTable columns={coverageColumns} rows={coverageRows} />

    <h3 class="text-xl font-semibold text-neutral-800 mt-6 mb-3">Key Coverage Considerations</h3>
    <p class="mb-4">
      <strong>Travel Coverage:</strong> The biggest difference. Sanitas covers you in Spain plus EU emergency care. Cigna and Allianz cover you worldwide. If you plan to visit family, travel Europe, or maintain ties elsewhere, international coverage eliminates the need for separate travel insurance.
    </p>
    <p class="mb-4">
      <strong>Copays:</strong> Standard Sanitas plans include copays (€5-20 per visit/service). International plans typically don't. Some consulates reject copay policies for non-lucrative visas—verify before purchasing.
    </p>
    <p>
      <strong>Repatriation:</strong> Sanitas has limited repatriation coverage. International plans include comprehensive medical evacuation and repatriation—important if a serious illness requires returning home.
    </p>
  </section>

  <section id="pricing" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Pricing for Non-Lucrative Visa Applicants</h2>
    <p class="mb-4">
      The price gap between Spanish and international insurers is significant. Here's what to expect for comprehensive plans meeting visa requirements.
    </p>

    <ComparisonTable columns={pricingColumns} rows={pricingRows} />

    <p class="mt-4 text-sm text-neutral-600">
      *Sanitas prices are for "sin copago" (no copay) plans where required. Standard copay plans are 20-30% cheaper. International prices for Europe-excluding-US coverage with moderate deductibles.
    </p>
  </section>

  <section id="spain-network" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Spain Network Access</h2>

    <div class="space-y-4">
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h3 class="font-semibold text-neutral-900">Madrid</h3>
        <p class="text-neutral-600 text-sm"><strong>Cigna/Allianz:</strong> HM Hospitales, Quirónsalud, Vithas, Hospital La Luz</p>
        <p class="text-neutral-600 text-sm"><strong>Sanitas:</strong> Hospital La Moraleja, Hospital La Zarzuela, plus extensive clinic network</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h3 class="font-semibold text-neutral-900">Barcelona</h3>
        <p class="text-neutral-600 text-sm"><strong>Cigna/Allianz:</strong> Quirónsalud, Hospital de Barcelona, Teknon</p>
        <p class="text-neutral-600 text-sm"><strong>Sanitas:</strong> Hospital CIMA, Centro Médico Teknon (partner), extensive outpatient</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h3 class="font-semibold text-neutral-900">Costa del Sol (Málaga, Marbella)</h3>
        <p class="text-neutral-600 text-sm"><strong>Cigna/Allianz:</strong> Quirónsalud Marbella, Hospital Vithas Xanit, HC Marbella</p>
        <p class="text-neutral-600 text-sm"><strong>Sanitas:</strong> Good coverage in main towns, may need to travel to Málaga for complex care</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-4">
        <h3 class="font-semibold text-neutral-900">Valencia & Alicante</h3>
        <p class="text-neutral-600 text-sm"><strong>Cigna/Allianz:</strong> Quirónsalud, Hospital Vithas, IMED Hospitales</p>
        <p class="text-neutral-600 text-sm"><strong>Sanitas:</strong> Hospital 9 de Octubre (partner), Clínica Sanitas coverage</p>
      </div>
    </div>
  </section>

  <section id="scenarios" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Real-World Scenarios</h2>

    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Scenario 1: Emergency While Visiting UK Family</h3>
        <p class="text-neutral-700 mb-3">You're visiting grandchildren in London when you develop severe chest pain. Need emergency cardiac care.</p>
        <div class="grid md:grid-cols-3 gap-4 text-sm">
          <div class="bg-blue-50 p-3 rounded">
            <p class="font-semibold text-blue-900">Cigna:</p>
            <p class="text-blue-800">Full coverage at UK hospital. Same policy covers Spain and UK seamlessly.</p>
          </div>
          <div class="bg-orange-50 p-3 rounded">
            <p class="font-semibold text-orange-900">Sanitas:</p>
            <p class="text-orange-800">EU emergency-only coverage. Basic stabilization covered, but full treatment may require return to Spain or separate travel insurance claim.</p>
          </div>
          <div class="bg-green-50 p-3 rounded">
            <p class="font-semibold text-green-900">Allianz:</p>
            <p class="text-green-800">Full coverage throughout Europe. UK care fully covered under same policy.</p>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Scenario 2: Hip Replacement in Marbella</h3>
        <p class="text-neutral-700 mb-3">You need an elective hip replacement. Want it done at a quality facility near your Costa del Sol home.</p>
        <div class="grid md:grid-cols-3 gap-4 text-sm">
          <div class="bg-blue-50 p-3 rounded">
            <p class="font-semibold text-blue-900">Cigna:</p>
            <p class="text-blue-800">Quirónsalud Marbella or HC Marbella—direct billing, no upfront cost. €15,000-20,000 procedure fully covered.</p>
          </div>
          <div class="bg-orange-50 p-3 rounded">
            <p class="font-semibold text-orange-900">Sanitas:</p>
            <p class="text-orange-800">May require traveling to Málaga or using partner facility. Copay applies. Still excellent value given lower premiums.</p>
          </div>
          <div class="bg-green-50 p-3 rounded">
            <p class="font-semibold text-green-900">Allianz:</p>
            <p class="text-green-800">Good coverage at Costa del Sol hospitals. May require reimbursement at some facilities.</p>
          </div>
        </div>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-900 mb-2">Scenario 3: Managing Pre-Existing Diabetes</h3>
        <p class="text-neutral-700 mb-3">You have well-controlled Type 2 diabetes needing ongoing management—quarterly visits, medications, annual screenings.</p>
        <div class="grid md:grid-cols-3 gap-4 text-sm">
          <div class="bg-blue-50 p-3 rounded">
            <p class="font-semibold text-blue-900">Cigna:</p>
            <p class="text-blue-800">Underwriting determines coverage—may have waiting period or loading. Once covered, full management included.</p>
          </div>
          <div class="bg-orange-50 p-3 rounded">
            <p class="font-semibold text-orange-900">Sanitas:</p>
            <p class="text-orange-800">6-12 month waiting period typical for pre-existing conditions. After waiting period, covered with standard copays.</p>
          </div>
          <div class="bg-green-50 p-3 rounded">
            <p class="font-semibold text-green-900">Allianz:</p>
            <p class="text-green-800">Often most flexible—may offer coverage with premium loading rather than exclusion.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="verdict" class="mb-12">
    <h2 class="text-2xl font-bold text-neutral-900 mb-4">Our Recommendation</h2>

    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-blue-50 border-2 border-blue-300 rounded-lg p-6">
        <h3 class="text-xl font-bold text-blue-900 mb-2">Choose Cigna Global If:</h3>
        <ul class="space-y-2 text-blue-800">
          <li>• You'll travel frequently outside Spain</li>
          <li>• You're American or need US coverage</li>
          <li>• International flexibility matters</li>
          <li>• Budget is secondary to coverage</li>
        </ul>
        <div class="mt-4">
          <a href="/go/cigna-global" class="inline-block bg-blue-600 text-white px-4 py-2 rounded font-semibold hover:bg-blue-700 transition" style="color: white !important;">Get Cigna Quote</a>
        </div>
      </div>

      <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-6">
        <h3 class="text-xl font-bold text-orange-900 mb-2">Choose Sanitas If:</h3>
        <ul class="space-y-2 text-orange-800">
          <li>• Spain is your permanent home</li>
          <li>• Budget is a priority</li>
          <li>• Your consulate prefers Spanish insurers</li>
          <li>• You won't travel much</li>
        </ul>
        <div class="mt-4">
          <a href="/get-quotes" class="inline-block bg-orange-600 text-white px-4 py-2 rounded font-semibold hover:bg-orange-700 transition" style="color: white !important;">Get Sanitas Quote</a>
        </div>
      </div>

      <div class="bg-green-50 border-2 border-green-300 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-900 mb-2">Choose Allianz Care If:</h3>
        <ul class="space-y-2 text-green-800">
          <li>• You want international coverage at better value</li>
          <li>• Mental health is a priority</li>
          <li>• You're European/comfortable with reimbursement</li>
          <li>• You want balance of price and flexibility</li>
        </ul>
        <div class="mt-4">
          <a href="/go/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded font-semibold hover:bg-green-700 transition" style="color: white !important;">Get Allianz Quote</a>
        </div>
      </div>
    </div>

    <div class="bg-neutral-100 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">The Bottom Line</h3>
      <p class="text-neutral-700">
