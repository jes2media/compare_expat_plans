---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'fundamental-difference', text: 'The Fundamental Difference', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'plan-options', text: 'Plan Options', level: 2 },
  { id: 'pricing', text: 'Pricing Breakdown', level: 2 },
  { id: 'network-access', text: 'Network & Hospital Access', level: 2 },
  { id: 'claims-experience', text: 'Claims Experience', level: 2 },
  { id: 'customer-service', text: 'Customer Service', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'real-world-scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Best Digital Nomad Insurance', href: '/best/digital-nomad-insurance' },
  { title: 'Portugal Insurance Guide', href: '/countries/portugal/insurance' },
  { title: 'Best Budget Insurance', href: '/best/budget-expat-health-insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing Nomad' },
  { key: 'cigna', header: 'Cigna Global' },
];

const coverageRows = [
  { feature: 'Product Type', safetywing: 'Travel Medical Insurance', cigna: 'Health Insurance' },
  { feature: 'Maximum Coverage', safetywing: '$250,000', cigna: 'Unlimited (Platinum)' },
  { feature: 'Contract Length', safetywing: 'None—cancel anytime', cigna: 'Annual' },
  { feature: 'Inpatient (Hospital)', safetywing: '✓ Emergency only', cigna: '✓ All tiers' },
  { feature: 'Outpatient (Doctor visits)', safetywing: '✗ Emergency only', cigna: '✓ Gold/Platinum' },
  { feature: 'Routine Care/Preventive', safetywing: '✗ Not covered', cigna: '✓ Platinum' },
  { feature: 'Mental Health', safetywing: '✗ Not covered', cigna: '✓ Included' },
  { feature: 'Maternity', safetywing: '✗ Not covered', cigna: '✓ Optional add-on' },
  { feature: 'Dental/Vision', safetywing: 'Emergency dental only', cigna: 'Optional add-on' },
  { feature: 'Pre-existing Conditions', safetywing: '✗ Not covered', cigna: 'Underwritten (may cover)' },
  { feature: 'Chronic Conditions', safetywing: '✗ Not covered', cigna: '✓ Covered if declared' },
];

const planTierColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'safetywing', header: 'SafetyWing Options' },
  { key: 'cigna', header: 'Cigna Tiers' },
];

const planTierRows = [
  { aspect: 'Entry Level', safetywing: 'Nomad Insurance ($45/mo)', cigna: 'Silver (~$100-150/mo)' },
  { aspect: 'Mid Tier', safetywing: 'Remote Health (~$100-200/mo)', cigna: 'Gold (~$150-250/mo)' },
  { aspect: 'Top Tier', safetywing: 'Remote Health + add-ons', cigna: 'Platinum (~$250-400/mo)' },
  { aspect: 'Deductible Options', safetywing: '$250 (Nomad) or $0-10K (Remote)', cigna: '$0 to $10,000+' },
  { aspect: 'US Coverage', safetywing: 'Limited (90 days max)', cigna: 'Full (increases cost 40-60%)' },
  { aspect: 'Family Plans', safetywing: 'Add dependents individually', cigna: 'Family discount ~10-15%' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing Nomad' },
  { key: 'remote', header: 'SafetyWing Remote Health' },
  { key: 'cigna', header: 'Cigna Gold (ex-US)' },
];

const pricingRows = [
  { profile: 'Age 25, healthy', safetywing: '~$42/mo', remote: '~$100/mo', cigna: '~$130/mo' },
  { profile: 'Age 35, healthy', safetywing: '~$49/mo', remote: '~$150/mo', cigna: '~$180/mo' },
  { profile: 'Age 45, healthy', safetywing: '~$83/mo', remote: '~$250/mo', cigna: '~$280/mo' },
  { profile: 'Age 55, healthy', safetywing: '~$127/mo', remote: '~$400/mo', cigna: '~$420/mo' },
  { profile: 'Age 65, healthy', safetywing: 'Not available', remote: '~$600/mo', cigna: '~$650/mo' },
  { profile: 'Couple, 35, no kids', safetywing: '~$98/mo', remote: '~$300/mo', cigna: '~$340/mo' },
  { profile: 'Family of 4 (35/35/8/5)', safetywing: '~$165/mo', remote: '~$550/mo', cigna: '~$580/mo' },
];

const networkColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'cigna', header: 'Cigna Global' },
];

const networkRows = [
  { aspect: 'Global Network Size', safetywing: 'Uses partner networks', cigna: '1.5+ million providers' },
  { aspect: 'Direct Billing', safetywing: 'Limited (major emergencies)', cigna: 'Extensive worldwide' },
  { aspect: 'Hospital Access', safetywing: 'Any licensed facility', cigna: 'Network preferred, any accepted' },
  { aspect: 'Provider App/Directory', safetywing: 'Partner lookup', cigna: 'Comprehensive mobile app' },
  { aspect: 'Typical Experience', safetywing: 'Pay, then claim', cigna: 'Show card, walk out' },
  { aspect: 'Pre-authorization', safetywing: 'For planned procedures', cigna: 'For non-emergencies >$1,000' },
];
---

<PageShell
  title="SafetyWing vs Cigna Global: Complete 2025 Comparison"
  description="SafetyWing vs Cigna Global compared in depth. Travel medical insurance vs comprehensive health coverage—understand what you're actually buying before you choose."
  headline="SafetyWing vs Cigna Global"
  subheadline="The startup travel insurance darling versus the global health insurance giant. Different products, different purposes, vastly different prices."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes from Both"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Overview</h2>

  <!-- Quick Decision Guide - CRO: Helps users self-select quickly -->
  <div class="bg-gradient-to-r from-primary-50 to-neutral-50 border border-primary-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">⚡ Quick Decision Guide</h3>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="bg-white rounded p-4 border border-primary-100">
        <p class="font-medium text-primary-900 mb-2">Choose SafetyWing if:</p>
        <ul class="text-sm text-neutral-700 space-y-1">
          <li>• You're under 35 and very healthy</li>
          <li>• You just need emergency coverage</li>
          <li>• Budget under $60/month</li>
          <li>• Testing nomad lifestyle short-term</li>
        </ul>
      </div>
      <div class="bg-white rounded p-4 border border-neutral-200">
        <p class="font-medium text-neutral-900 mb-2">Choose Cigna if:</p>
        <ul class="text-sm text-neutral-700 space-y-1">
          <li>• You need actual health insurance</li>
          <li>• Over 40 or any health conditions</li>
          <li>• Want mental health coverage</li>
          <li>• Direct hospital billing matters</li>
        </ul>
      </div>
    </div>
  </div>

  <p>
    SafetyWing and Cigna Global both serve people living abroad, but they sell fundamentally different products. Understanding this distinction is critical—because choosing the wrong one could leave you with a $200,000 hospital bill or paying for coverage you don't need.
  </p>

  <p>
    <strong>SafetyWing</strong> burst onto the scene in 2017 as a startup built specifically for digital nomads. Their flagship product, Nomad Insurance, is travel medical insurance—not health insurance. It covers emergencies while traveling, with a subscription model that lets you cancel anytime. It's affordable, flexible, and perfectly adequate for healthy young travelers who just want a safety net. They also offer Remote Health, which is actual health insurance, but most people know SafetyWing for Nomad Insurance.
  </p>

  <p>
    <strong>Cigna Global</strong> has been providing international health insurance for decades. They offer comprehensive health insurance plans that cover everything from routine checkups to cancer treatment. With a network of 1.5+ million providers worldwide and unlimited coverage options, they're the premium choice for expats who want complete healthcare coverage. You pay more because you get more.
  </p>

  <p>
    This comparison will help you understand exactly what each product covers, what it costs, and which one matches your actual needs—not which one has better marketing.
  </p>

  <!-- At-a-glance boxes with trust signals - CRO: Builds credibility -->
  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">SafetyWing</h3>
      <ul class="space-y-2 text-neutral-600">
        <li><strong>Type:</strong> Travel Medical Insurance (Nomad) / Health Insurance (Remote Health)</li>
        <li><strong>Founded:</strong> 2017 (San Francisco startup)</li>
        <li><strong>Commitment:</strong> None—cancel anytime</li>
        <li><strong>Coverage Limit:</strong> $250K (Nomad) / $10M (Remote Health)</li>
        <li><strong>Best For:</strong> Digital nomads, young healthy travelers</li>
        <li><strong>Trustpilot:</strong> 4.3/5 (2,000+ reviews)</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Cigna Global</h3>
      <ul class="space-y-2 text-neutral-600">
        <li><strong>Type:</strong> Comprehensive Health Insurance</li>
        <li><strong>Founded:</strong> 1982 (global division)</li>
        <li><strong>Commitment:</strong> Annual</li>
        <li><strong>Coverage Limit:</strong> Up to Unlimited</li>
        <li><strong>Best For:</strong> Families, long-term expats, those over 40</li>
        <li><strong>Network:</strong> 1.5M+ providers with direct billing</li>
      </ul>
    </div>
  </div>

  <h2 id="fundamental-difference">The Fundamental Difference</h2>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">🚨 Critical Distinction</h3>
    <p class="text-amber-800">
      <strong>SafetyWing Nomad Insurance is travel medical insurance.</strong> It covers emergencies while traveling—broken bones, sudden illness, urgent care. It does NOT cover routine healthcare, pre-existing conditions, mental health, or maternity.
    </p>
    <p class="text-amber-800 mt-2">
      <strong>Cigna Global is health insurance.</strong> It covers your complete healthcare needs—doctor visits, prescriptions, preventive care, mental health, chronic conditions, everything. It's what you had through your employer, but worldwide.
    </p>
    <p class="text-amber-800 mt-2 font-medium">
      Comparing SafetyWing Nomad to Cigna is like comparing travel insurance to Blue Cross. They're not the same product.
    </p>
  </div>

  <p>
    This matters because many people choose SafetyWing thinking they're getting health insurance at a great price. They're not. They're getting travel medical insurance—which is a completely valid product, but serves a different purpose.
  </p>

  <h3>What Travel Medical Insurance (SafetyWing Nomad) Actually Covers</h3>
  <ul>
    <li><strong>Emergency room visits</strong> after accidents or sudden illness</li>
    <li><strong>Emergency hospitalization</strong> for acute conditions</li>
    <li><strong>Emergency surgery</strong> (appendicitis, broken bones, etc.)</li>
    <li><strong>Emergency evacuation</strong> to a better hospital</li>
    <li><strong>Acute illness medications</strong> (antibiotics for infection, etc.)</li>
    <li><strong>Emergency dental</strong> for pain relief only</li>
  </ul>

  <h3>What Travel Medical Insurance Does NOT Cover</h3>
  <ul>
    <li><strong>Routine doctor visits</strong> when you're feeling off</li>
    <li><strong>Preventive care</strong> like annual checkups or vaccinations</li>
    <li><strong>Ongoing prescriptions</strong> for blood pressure, thyroid, etc.</li>
    <li><strong>Mental health</strong> of any kind</li>
    <li><strong>Pre-existing conditions</strong> even if they become emergencies</li>
    <li><strong>Chronic disease management</strong> like diabetes care</li>
    <li><strong>Pregnancy and childbirth</strong></li>
    <li><strong>Non-emergency surgery</strong> even if medically necessary</li>
  </ul>

  <p>
    If you have high blood pressure and have a stroke abroad, SafetyWing Nomad may deny the claim as a pre-existing condition. If you develop depression, there's no coverage. If you need a non-emergency MRI to investigate chronic pain, you're paying out of pocket.
  </p>

  <CTABox
    title="Not Sure What You Need?"
    description="Get quotes for both travel medical and health insurance to see the real price difference."
    buttonText="Compare Both Options"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="coverage-comparison">Coverage Comparison</h2>

  <p>
    Here's the detailed coverage breakdown between SafetyWing Nomad Insurance and Cigna Global health plans. Note that SafetyWing's Remote Health product has different coverage—more similar to Cigna.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Coverage Limits Matter</h3>
  <p>
    SafetyWing Nomad has a $250,000 lifetime maximum. That sounds like a lot until you realize:
  </p>
  <ul>
    <li>A week in a US hospital ICU can cost $100,000+</li>
    <li>Cancer treatment often exceeds $300,000</li>
    <li>Major surgery with complications can hit $200,000</li>
    <li>Emergency air evacuation alone can cost $50,000-100,000</li>
  </ul>

  <p>
    Cigna's plans go up to unlimited coverage. For Silver and Gold, you typically get $1-2 million. Platinum offers unlimited. If something catastrophic happens, you're not doing math on whether your coverage is enough.
  </p>

  <h3>The Pre-existing Condition Question</h3>
  <p>
    <strong>SafetyWing Nomad:</strong> Pre-existing conditions are excluded entirely. If you have asthma and have an asthma attack abroad, that's not covered. If you have a heart condition and have a heart attack, not covered. This is standard for travel medical insurance.
  </p>
  <p>
    <strong>Cigna Global:</strong> Uses full medical underwriting. You'll complete a health questionnaire, and Cigna may: cover conditions normally, exclude specific conditions, add a premium loading, or decline coverage. The process is more involved, but conditions you disclose may eventually be covered (often after a waiting period or as part of ongoing care).
  </p>

  <h2 id="plan-options">Plan Options</h2>

  <p>
    Both providers offer multiple tiers, but the structure is completely different.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planTierColumns} rows={planTierRows} />
  </div>

  <h3>SafetyWing Products</h3>
  <p><strong>Nomad Insurance</strong> (~$45/month for age 30):</p>
  <ul>
    <li>Travel medical insurance (emergencies only)</li>
    <li>$250,000 coverage limit</li>
    <li>$250 deductible</li>
    <li>Cancel anytime, 4-week billing cycles</li>
    <li>Up to 90 days US coverage per year</li>
    <li>Best for: Short-term travel, healthy young nomads</li>
  </ul>

  <p><strong>Remote Health</strong> (~$100-600/month depending on age):</p>
  <ul>
    <li>Actual health insurance</li>
    <li>Up to $10 million coverage</li>
    <li>Multiple deductible options ($0 to $10,000)</li>
    <li>Mental health included</li>
    <li>Maternity available (12-month waiting period)</li>
    <li>Pre-existing conditions covered after waiting period</li>
    <li>Best for: Long-term nomads wanting real insurance</li>
  </ul>

  <h3>Cigna Global Tiers</h3>
  <p><strong>Silver</strong> (Inpatient only):</p>
  <ul>
    <li>Hospital stays and surgery</li>
    <li>Day-patient treatment</li>
    <li>Cancer care</li>
    <li>No outpatient coverage</li>
    <li>Lowest premium tier</li>
  </ul>

  <p><strong>Gold</strong> (Most popular):</p>
  <ul>
    <li>Everything in Silver</li>
    <li>Outpatient visits and tests</li>
    <li>Specialist consultations</li>
    <li>Prescriptions</li>
    <li>Physical therapy</li>
  </ul>

  <p><strong>Platinum</strong> (Comprehensive):</p>
  <ul>
    <li>Everything in Gold</li>
    <li>Wellness and preventive care</li>
    <li>Annual checkups</li>
    <li>Vaccinations</li>
    <li>Unlimited coverage</li>
  </ul>

  <h2 id="pricing">Pricing Breakdown</h2>

  <p>
    Price is where SafetyWing shines—if you compare apples to oranges. When you compare apples to apples (SafetyWing Remote Health vs Cigna), the gap narrows significantly.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    *Estimates based on 2026-2025 quotes for individuals excluding US coverage. Actual prices vary based on health history, exact location, and plan customization.
  </p>

  <h3>Why SafetyWing Nomad Is So Cheap</h3>
  <p>
    SafetyWing Nomad Insurance costs 70-80% less than Cigna because it covers 70-80% less. It's travel medical insurance—emergency coverage only. When you need actual healthcare (not just emergency rescue), you pay out of pocket.
  </p>

  <h3>The Fairer Comparison: Remote Health vs Cigna</h3>
  <p>
    SafetyWing Remote Health is actual health insurance, comparable to Cigna Gold. At these tiers:
  </p>
  <ul>
    <li>Remote Health is roughly 10-15% cheaper for young, healthy individuals</li>
    <li>The gap narrows for older individuals (over 50)</li>
    <li>Cigna often wins for families due to better multi-person discounts</li>
    <li>Remote Health's deductible options can reduce costs further</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-2">Ways to Reduce Cigna's Cost</h3>
    <ul class="text-blue-800 space-y-1">
      <li><strong>Exclude US coverage:</strong> Saves 40-60% on premiums</li>
      <li><strong>Higher deductible:</strong> $5,000-$10,000 deductible reduces premiums 25-35%</li>
      <li><strong>Silver tier:</strong> Inpatient-only saves vs Gold (pair with local insurance for outpatient)</li>
      <li><strong>Annual payment:</strong> Small discount for paying yearly</li>
    </ul>
  </div>

  <!-- CTA after pricing - CRO: Capture users ready to compare costs -->
  <CTABox
    title="Get Your Actual Price"
    description="Quotes are personalized. See what you'd actually pay based on your age, health, and location."
    buttonText="Get Free Quotes"
    buttonHref="/go/cigna-global"
  />

  <h2 id="network-access">Network & Hospital Access</h2>

  <p>
    How you actually use your insurance day-to-day differs dramatically between these providers.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={networkColumns} rows={networkRows} />
  </div>

  <h3>Cigna's Network Advantage</h3>
  <p>
    Cigna's 1.5+ million provider network with direct billing is genuinely useful. In practice:
  </p>
  <ul>
    <li>Walk into a network hospital, show your Cigna card</li>
    <li>Get treated, sign paperwork</li>
    <li>Walk out without paying anything (or just your copay)</li>
    <li>Cigna handles the bill directly with the hospital</li>
  </ul>

  <p>
    The mobile app shows nearby network providers, lets you get pre-authorization, and tracks claims in real-time. For non-emergency situations, this convenience is significant.
  </p>

  <h3>SafetyWing's Reimbursement Model</h3>
  <p>
    SafetyWing primarily works on reimbursement:
  </p>
  <ul>
    <li>Find a hospital or clinic</li>
    <li>Pay the bill yourself</li>
    <li>Submit claim with receipts</li>
    <li>Wait 10-30 days for reimbursement</li>
  </ul>

  <p>
    For major emergencies, SafetyWing will coordinate with hospitals for direct billing. But for anything non-emergency, expect to pay upfront and wait for reimbursement.
  </p>

  <h3>What This Means Practically</h3>
  <p>
    With Cigna, you can see a doctor for a cold without thinking about money. With SafetyWing Nomad, there's no coverage for that anyway—but even with Remote Health, you might pay $100-200 out of pocket and wait weeks to get it back. If cash flow matters, Cigna's direct billing has real value.
  </p>

  <h2 id="claims-experience">Claims Experience</h2>

  <h3>SafetyWing Claims</h3>
  <p>
    SafetyWing's claims process is straightforward but basic:
  </p>
  <ul>
    <li><strong>Submit via:</strong> Online portal or app</li>
    <li><strong>Processing time:</strong> 10-30 days typically</li>
    <li><strong>Documentation:</strong> Receipts, medical reports, sometimes additional forms</li>
    <li><strong>Payment:</strong> Direct to bank account</li>
  </ul>

  <p>
    Reviews are mixed. Small claims (few hundred dollars) usually process without issues. Larger claims or anything touching pre-existing condition exclusions can face scrutiny and delays. Some users report having to appeal denials. This is fairly typical for budget travel insurance.
  </p>

  <h3>Cigna Claims</h3>
  <p>
    Cigna's claims process reflects their premium positioning:
  </p>
  <ul>
    <li><strong>Submit via:</strong> App, online portal, email, or even fax</li>
    <li><strong>Processing time:</strong> 5-10 business days typically</li>
    <li><strong>Documentation:</strong> Minimal for small claims; detailed for large ones</li>
    <li><strong>Direct billing:</strong> Most hospital claims never become "claims"—Cigna pays directly</li>
  </ul>

  <p>
    Cigna has more resources and a longer track record. Complex claims get assigned to case managers. Pre-authorization is straightforward through the app. The experience is more consistent than budget insurers.
  </p>

  <h2 id="customer-service">Customer Service</h2>

  <h3>SafetyWing Support</h3>
  <ul>
    <li><strong>Channels:</strong> Email and chat (no phone)</li>
    <li><strong>Hours:</strong> Business hours, not 24/7</li>
    <li><strong>Response time:</strong> Usually same day for chat, 1-2 days for email</li>
    <li><strong>Languages:</strong> English primarily</li>
  </ul>

  <p>
    SafetyWing is a startup. Their support is adequate for basic questions and standard claims, but don't expect white-glove service. For a $45/month product, the support matches the price.
  </p>

  <h3>Cigna Support</h3>
  <ul>
    <li><strong>Channels:</strong> 24/7 phone, email, chat, app</li>
    <li><strong>Response:</strong> Immediate for phone, same day for digital</li>
    <li><strong>Languages:</strong> Multiple languages available</li>
    <li><strong>Special services:</strong> Case managers for complex situations, medical concierge</li>
  </ul>

  <p>
    Cigna's support is genuinely premium. Need help finding a specialist at 2am? Call them. Need documents for a visa application? They'll expedite. Having a medical emergency? They coordinate with hospitals directly. This is part of what you pay for.
  </p>

  <h2 id="who-should-choose">Who Should Choose Which</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">SafetyWing Nomad Is Right If:</h3>
      <ul class="space-y-2 text-neutral-700">
        <li>✓ You're under 35 and genuinely healthy</li>
        <li>✓ You have no pre-existing conditions whatsoever</li>
        <li>✓ You just need emergency coverage, not healthcare</li>
        <li>✓ You're traveling short-term (3-12 months)</li>
        <li>✓ Budget under $60/month is mandatory</li>
        <li>✓ You're comfortable paying out of pocket for non-emergencies</li>
        <li>✓ You want zero commitment—cancel anytime</li>
        <li>✓ You have access to affordable local healthcare</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Cigna Global Is Right If:</h3>
      <ul class="space-y-2 text-neutral-700">
        <li>✓ You need actual health insurance, not just emergency coverage</li>
        <li>✓ You're over 40 or have any health conditions</li>
        <li>✓ Mental health coverage is important to you</li>
        <li>✓ You have pre-existing conditions you want covered</li>
        <li>✓ Direct billing and premium service have value to you</li>
        <li>✓ You're relocating long-term (2+ years)</li>
        <li>✓ You have a family to cover</li>
        <li>✓ Peace of mind matters more than minimal cost</li>
      </ul>
    </div>
  </div>

  <h3>The Middle Ground: SafetyWing Remote Health</h3>
  <p>
    If you want comprehensive health insurance but prefer SafetyWing's digital-first approach, Remote Health is worth considering. It offers:
  </p>
  <ul>
    <li>Actual health insurance (not travel medical)</li>
