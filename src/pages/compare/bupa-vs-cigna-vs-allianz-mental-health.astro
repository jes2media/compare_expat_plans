---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'coverage-details', text: 'Mental Health Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Mental Health Coverage Guide', href: '/guides/mental-health-coverage-abroad' },
  { title: 'Pre-Existing Conditions', href: '/guides/pre-existing-conditions-abroad' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Mental Health Coverage', bupa: 'Comprehensive', cigna: 'Good', allianz: 'Best' },
  { feature: 'Outpatient Therapy', bupa: 'Up to $15K/year', cigna: 'Up to $10K/year', allianz: 'Up to $20K/year' },
  { feature: 'Inpatient Psychiatric', bupa: '60-90 days', cigna: '30-60 days', allianz: '90+ days' },
  { feature: 'Waiting Period', bupa: '12 months', cigna: '24 months', allianz: '12 months' },
  { feature: 'Telehealth Therapy', bupa: 'Yes', cigna: 'Yes', allianz: 'Yes' },
  { feature: 'Prior History Accepted', bupa: 'Sometimes', cigna: 'Rarely', allianz: 'More Often' },
  { feature: 'Crisis Coverage', bupa: 'Full', cigna: 'Full', allianz: 'Full' },
  { feature: 'Best For', bupa: 'Premium service', cigna: 'New diagnoses', allianz: 'Best benefits' },
];

const coverageColumns = [
  { key: 'benefit', header: 'Benefit' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const coverageRows = [
  { benefit: 'Psychiatrist Visits', bupa: 'Covered', cigna: 'Covered', allianz: 'Covered' },
  { benefit: 'Psychologist Sessions', bupa: '30-40/year', cigna: '20-30/year', allianz: '40-50/year' },
  { benefit: 'Group Therapy', bupa: 'Covered', cigna: 'Limited', allianz: 'Covered' },
  { benefit: 'Medication', bupa: 'Covered', cigna: 'Covered', allianz: 'Covered' },
  { benefit: 'Substance Abuse', bupa: '30 days inpatient', cigna: 'Limited', allianz: '60 days inpatient' },
  { benefit: 'Eating Disorders', bupa: 'Covered', cigna: 'Limited', allianz: 'Covered' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Single, Age 35', bupa: '$300-500/mo', cigna: '$280-450/mo', allianz: '$180-280/mo' },
  { profile: 'Single, Age 45', bupa: '$450-650/mo', cigna: '$400-600/mo', allianz: '$250-380/mo' },
  { profile: 'Couple, Age 40', bupa: '$700-1,000/mo', cigna: '$650-950/mo', allianz: '$420-620/mo' },
  { profile: 'Family of 4', bupa: '$950-1,500/mo', cigna: '$900-1,400/mo', allianz: '$600-900/mo' },
];
---

<PageShell
  title="Bupa vs Cigna vs Allianz: Best Mental Health Coverage for Expats 2026"
  description="Compare mental health benefits from Bupa Global, Cigna Global, and Allianz Care. Session limits, waiting periods, and which insurer covers pre-existing mental health conditions."
  headline="Bupa vs Cigna vs Allianz: Mental Health Coverage Compared"
  subheadline="Mental health coverage varies dramatically between insurers. Here's who offers the most generous benefits—and who's most likely to cover prior history."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-green-50 border-2 border-green-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Best Benefits</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Allianz Care</p>
      <p class="text-sm text-neutral-600 mb-3">Most generous limits. Best for prior mental health history. Up to 50 therapy sessions/year.</p>
      <a href="/go/allianz-care" class="inline-block w-full text-center bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Allianz Quote</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Premium Service</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Good coverage with excellent support. Strong substance abuse benefits. Premium pricing.</p>
      <a href="/go/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Bupa Quote</a>
    </div>
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best App</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Good mental health coverage with best digital experience. Strictest on prior history.</p>
      <a href="/go/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Cigna Quote</a>
    </div>
  </div>

  <p>
    If mental health coverage is your priority, Allianz Care offers the most generous benefits and is most likely to cover prior history. Bupa provides solid coverage with premium service. Cigna has good benefits but is strictest on excluding prior conditions.
  </p>

  <h2 id="comparison-table">Side-by-Side Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="bupa-global">Bupa Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Premium Service</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Substance Abuse</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Comprehensive</span>
  </div>

  <p>
    Bupa Global offers comprehensive mental health coverage with excellent customer support. Their substance abuse and addiction treatment benefits are particularly strong. Premium pricing, but you get premium service when you need help navigating mental health care abroad.
  </p>

  <p><strong>Mental health strengths:</strong></p>
  <ul>
    <li>Up to $15K/year outpatient therapy</li>
    <li>60-90 days inpatient psychiatric coverage</li>
    <li>Strong substance abuse benefits (30 days inpatient)</li>
    <li>Good eating disorder coverage</li>
    <li>Dedicated mental health support line</li>
    <li>Telehealth therapy included</li>
  </ul>

  <p><strong>Limitations:</strong></p>
  <ul>
    <li>12-month waiting period for mental health</li>
    <li>Prior history often excluded</li>
    <li>Session limits lower than Allianz</li>
    <li>Most expensive option</li>
  </ul>

  <p><strong>Best for:</strong> Those who need substance abuse coverage. Expats who value premium service and support. Those without prior mental health history.</p>

  <div class="my-6">
    <a href="/go/bupa-global" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Bupa Quote</a>
    <a href="/providers/bupa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="cigna-global">Cigna Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Best App</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Fast Claims</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Strict Underwriting</span>
  </div>

  <p>
    Cigna Global has good mental health benefits with the best digital experience for managing care. However, they're the strictest on prior mental health history—if you have any, expect exclusions. Best for those with no prior history who want excellent service.
  </p>

  <p><strong>Mental health strengths:</strong></p>
  <ul>
    <li>Up to $10K/year outpatient therapy</li>
    <li>30-60 days inpatient psychiatric coverage</li>
    <li>Best app for finding providers</li>
    <li>Telehealth therapy included</li>
    <li>Fast claims processing</li>
    <li>Good network of English-speaking therapists</li>
  </ul>

  <p><strong>Limitations:</strong></p>
  <ul>
    <li>24-month waiting period (longest)</li>
    <li>Prior history usually excluded permanently</li>
    <li>Lower session limits than competitors</li>
    <li>Limited substance abuse coverage</li>
    <li>Eating disorders coverage limited</li>
  </ul>

  <p><strong>Best for:</strong> Expats with no mental health history who value the best digital experience. Those who develop conditions while insured get good coverage.</p>

  <div class="my-6">
    <a href="/go/cigna-global" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Cigna Quote</a>
    <a href="/providers/cigna-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="allianz-care">Allianz Care</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Best Coverage</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Prior History</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Best Value</span>
  </div>

  <p>
    Allianz Care offers the most generous mental health benefits and is the most accommodating of prior history. If mental health coverage is your primary concern, Allianz should be your first call. They also cost significantly less than Bupa and Cigna.
  </p>

  <p><strong>Mental health strengths:</strong></p>
  <ul>
    <li>Up to $20K/year outpatient therapy</li>
    <li>40-50 psychologist sessions per year</li>
    <li>90+ days inpatient psychiatric coverage</li>
    <li>60 days substance abuse treatment</li>
    <li>Comprehensive eating disorder coverage</li>
    <li>More flexible on prior history</li>
    <li>12-month waiting period (shorter than Cigna)</li>
  </ul>

  <p><strong>Limitations:</strong></p>
  <ul>
    <li>App less polished than Cigna</li>
    <li>Network smaller in some regions</li>
    <li>Prior history still needs underwriting</li>
    <li>Claims processing slightly slower</li>
  </ul>

  <p><strong>Best for:</strong> Anyone prioritizing mental health coverage. Those with prior history who need coverage. Value-conscious expats who want comprehensive benefits.</p>

  <div class="my-6">
    <a href="/go/allianz-care" class="inline-block bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Allianz Quote</a>
    <a href="/providers/allianz-care" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <CTABox
    title="Compare Mental Health Coverage"
    description="Get personalized quotes with mental health benefits explained for your specific situation."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
    variant="highlight"
  />

  <h2 id="coverage-details">Mental Health Coverage Details</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>What's Typically Covered</h3>
  <ul>
    <li><strong>Outpatient therapy:</strong> Sessions with psychologists, psychiatrists, licensed counselors</li>
    <li><strong>Inpatient psychiatric:</strong> Hospital stays for severe mental health crises</li>
    <li><strong>Medication:</strong> Psychiatric medications prescribed by a psychiatrist</li>
    <li><strong>Crisis intervention:</strong> Emergency mental health care (all plans cover this)</li>
    <li><strong>Telehealth:</strong> Online therapy sessions with licensed providers</li>
  </ul>

  <h3>What's Often Limited or Excluded</h3>
  <ul>
    <li><strong>Pre-existing conditions:</strong> Prior diagnoses often excluded (Allianz most flexible)</li>
    <li><strong>Long-term therapy:</strong> Session limits apply (Allianz has highest)</li>
    <li><strong>Couples/family therapy:</strong> Often excluded or limited</li>
    <li><strong>Self-help programs:</strong> Apps, courses usually not covered</li>
    <li><strong>Coaching:</strong> Life coaching, wellness coaching excluded</li>
  </ul>

  <h3>Prior Mental Health History</h3>
  <p>
    If you have prior depression, anxiety, or other mental health diagnoses:
  </p>
  <ul>
    <li><strong>Allianz:</strong> Most likely to cover with waiting period or loading</li>
    <li><strong>Bupa:</strong> May cover stable conditions, case-by-case</li>
    <li><strong>Cigna:</strong> Usually permanently excludes prior conditions</li>
  </ul>

  <h2 id="pricing">Pricing Comparison</h2>

  <p>
    Mental health benefits are included in comprehensive plans—you don't pay extra for them. But overall plan pricing varies significantly. Allianz offers the best mental health benefits at the lowest price.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">
    *Estimated ranges for comprehensive plans with mental health coverage. Prices vary based on age, health, and location.
  </p>

  <h2 id="best-for">Which Is Best For You?</h2>

  <div class="space-y-4 my-8">
    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Allianz Care if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the most generous mental health benefits</li>
        <li>Have prior mental health history</li>
        <li>Need substance abuse or eating disorder coverage</li>
        <li>Want good coverage at lower prices</li>
        <li>Prefer more therapy sessions per year</li>
        <li>Are comfortable with occasional reimbursement claims</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Bupa Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Need strong substance abuse coverage</li>
        <li>Value premium customer service</li>
        <li>Have no prior mental health history</li>
        <li>Want dedicated mental health support line</li>
        <li>Can afford premium pricing</li>
        <li>Prefer established insurer reputation</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Cigna Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Have no prior mental health history</li>
        <li>Want the best app and digital experience</li>
        <li>Prefer largest provider network</li>
        <li>Value fast claims processing</li>
        <li>Are okay with lower mental health limits</li>
        <li>Prioritize overall service over mental health specifically</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Will my prior anxiety/depression be covered?</h3>
  <p>
    With Cigna: almost certainly not. With Bupa: sometimes, if stable and well-managed. With Allianz: best chance—they may cover with a waiting period or premium loading. Always disclose fully and get coverage terms in writing before purchasing.
  </p>

  <h3>What's the waiting period before mental health is covered?</h3>
  <p>
    Allianz and Bupa: typically 12 months. Cigna: typically 24 months. This means new mental health conditions that develop won't be covered until the waiting period passes. Crisis care is usually covered immediately.
  </p>

  <h3>Can I see any therapist I want?</h3>
  <p>
    All three allow you to see licensed mental health providers. Some have preferred networks with direct billing; others may require reimbursement. Telehealth options often have more flexibility in provider choice.
  </p>

  <h3>Is therapy abroad as good as at home?</h3>
  <p>
    Quality varies by location. Major cities worldwide have excellent English-speaking therapists. All three insurers can help you find appropriate providers. Telehealth lets you continue with providers from home if needed.
  </p>

  <h3>What if I need psychiatric hospitalization abroad?</h3>
  <p>
    All three cover inpatient psychiatric care, though duration limits vary. In an emergency, you'll be admitted to an appropriate facility. The insurer's assistance team helps coordinate care and may arrange medical evacuation if needed.
  </p>

  <h3>Does medication require prior authorization?</h3>
  <p>
    Most psychiatric medications don't require prior authorization. However, some newer or expensive medications may need approval. Your prescribing psychiatrist's records help expedite approvals.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This comparison is for informational purposes only. Mental health coverage terms vary by plan and individual circumstances. We are not insurance brokers. Verify specific mental health benefits directly with each insurer before purchasing.
    </p>
  </div>
</PageShell>
