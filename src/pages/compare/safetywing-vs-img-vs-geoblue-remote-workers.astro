---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'geoblue', text: 'GeoBlue', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'remote-worker-needs', text: 'Remote Worker Considerations', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/remote-workers', text: 'Remote Worker Insurance Guide' },
  { href: '/insurance-for/digital-nomads', text: 'Digital Nomad Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/providers/geoblue', text: 'GeoBlue Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'geoblue', header: 'GeoBlue' },
];

const mainComparisonRows = [
  { feature: 'Monthly Cost (30)', safetywing: '$45', img: '$150-250', geoblue: '$200-350' },
  { feature: 'Coverage Limit', safetywing: '$250,000', img: '$1M-5M', geoblue: '$1M-5M' },
  { feature: 'US Coverage', safetywing: '30 days/90', img: 'Optional full', geoblue: 'Excellent' },
  { feature: 'Telemedicine', safetywing: 'Included', img: 'Included', geoblue: 'Excellent' },
  { feature: 'Routine Care', safetywing: 'Not covered', img: 'Optional', geoblue: 'Optional' },
  { feature: 'Mental Health', safetywing: 'Crisis only', img: 'Limited', geoblue: 'Good' },
  { feature: 'Flexibility', safetywing: 'Monthly', img: 'Annual', geoblue: 'Annual' },
  { feature: 'Target Market', safetywing: 'Nomads', img: 'All expats', geoblue: 'US expats' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'geoblue', header: 'GeoBlue' },
];

const pricingRows = [
  { profile: 'Remote worker (28)', safetywing: '$42/mo', img: '$130-180/mo', geoblue: '$180-280/mo' },
  { profile: 'Remote worker (38)', safetywing: '$56/mo', img: '$180-280/mo', geoblue: '$250-400/mo' },
  { profile: 'Couple (30s)', safetywing: '$90/mo', img: '$300-450/mo', geoblue: '$400-600/mo' },
  { profile: 'Annual cost difference', safetywing: '$540/yr', img: '$1,800-2,500/yr', geoblue: '$2,400-3,600/yr' },
];
---

<PageShell
  title="SafetyWing vs IMG vs GeoBlue for Remote Workers | 2025 Comparison"
  description="Compare health insurance for remote workers: SafetyWing's budget nomad insurance, IMG's comprehensive coverage, and GeoBlue's US expat focus. Expert analysis for location-independent professionals."
  headline="SafetyWing vs IMG vs GeoBlue: Insurance for Remote Workers"
  subheadline="From budget-conscious nomads to established remote professionals—find the right coverage for your location-independent career."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">$45/month with month-to-month flexibility. Perfect for nomadic remote workers who change locations frequently and want affordable basic coverage.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 mb-3">Best Comprehensive</p>
        <p class="text-neutral-700 text-sm mb-4">Full expat-level coverage with customizable options. Best for established remote workers who want real health insurance, not just travel coverage.</p>
        <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">GeoBlue</h3>
        <p class="text-green-700 mb-3">Best for Americans</p>
        <p class="text-neutral-700 text-sm mb-4">Blue Cross network access and excellent US coverage. Ideal for American remote workers who travel home frequently or need US healthcare access.</p>
        <a href="/providers/geoblue" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">$45/Month</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Monthly Billing</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Nomad-Built</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing was built specifically for remote workers and digital nomads. The Nomad Insurance product costs just $45/month, auto-renews monthly, and lets you cancel anytime. This flexibility matches the unpredictable nature of remote work—if you take a full-time job with benefits, just stop your subscription.</p>

    <p class="text-neutral-700 mb-4">Coverage includes 30 days per 90-day period in your home country, telemedicine access, and emergency medical up to $250,000. It's not comprehensive health insurance—routine care, prescriptions, and pre-existing conditions aren't covered—but for healthy young remote workers, it provides essential protection at minimal cost.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Remote Worker Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest cost ($45/mo)</li>
          <li>• Month-to-month flexibility</li>
          <li>• Works in 180+ countries</li>
          <li>• Telemedicine included</li>
          <li>• Simple signup (5 minutes)</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Limitations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• $250K limit (lower)</li>
          <li>• No routine care</li>
          <li>• Pre-existing excluded</li>
          <li>• Limited US coverage</li>
          <li>• Crisis-only mental health</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Full Coverage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Customizable</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Real Insurance</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global provides actual health insurance, not just travel coverage. Their Global Medical Insurance offers $1M-5M in coverage with optional outpatient care, routine visits, and prescription benefits. For established remote workers earning good income, this is the upgrade from SafetyWing.</p>

    <p class="text-neutral-700 mb-4">Coverage is highly customizable—add or remove outpatient, adjust deductibles, include US coverage. The annual commitment means less flexibility, but you get comprehensive protection that rivals traditional employment-based insurance. Telemedicine is included, and pre-existing conditions may be covered after waiting periods.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Remote Worker Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• $1M-5M coverage limits</li>
          <li>• Optional routine care</li>
          <li>• Customizable plans</li>
          <li>• US coverage available</li>
          <li>• Telemedicine included</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Annual commitment</li>
          <li>• Higher premiums</li>
          <li>• Complex options</li>
          <li>• Pre-existing limitations</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="geoblue" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">GeoBlue</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Blue Cross Network</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">US Focused</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Telemedicine+</span>
    </div>

    <p class="text-neutral-700 mb-4">GeoBlue is the international arm of Blue Cross Blue Shield, making it ideal for American remote workers. If you need seamless US healthcare access—whether for home visits, specialists, or prescription continuity—GeoBlue provides that connection while covering you globally.</p>

    <p class="text-neutral-700 mb-4">Their telemedicine platform is particularly strong, with 24/7 access to US-licensed doctors. Mental health coverage is better than competitors. The premium pricing reflects premium features—this is for established remote workers who value quality over cost and frequently travel to the US.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Remote Worker Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Blue Cross network access</li>
          <li>• Excellent US coverage</li>
          <li>• Superior telemedicine</li>
          <li>• Good mental health coverage</li>
          <li>• Familiar US brand</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• US-centric design</li>
          <li>• Annual commitment</li>
          <li>• Less value outside US context</li>
        </ul>
      </div>
    </div>

    <a href="/providers/geoblue" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get GeoBlue Quote</a>
  </section>

  <CTABox
    title="Compare Remote Worker Coverage"
    description="Get quotes tailored to your remote work lifestyle and destinations."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Annual cost differences are significant—choose based on needs:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*SafetyWing is month-to-month; IMG and GeoBlue are annual. IMG/GeoBlue prices for comprehensive coverage including outpatient.</p>
  </section>

  <section id="remote-worker-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Remote Worker Considerations</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Location Patterns</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>True nomads (5+ countries/year):</strong> SafetyWing flexibility wins</li>
          <li>• <strong>Slow travelers (2-3 bases/year):</strong> Any option works</li>
          <li>• <strong>Remote + US returns:</strong> GeoBlue or IMG with US</li>
          <li>• <strong>Single base abroad:</strong> Consider local + travel backup</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Income Considerations</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Under $3K/mo:</strong> SafetyWing is practical</li>
          <li>• <strong>$3-6K/mo:</strong> IMG provides better value</li>
          <li>• <strong>$6K+/mo:</strong> GeoBlue or Cigna-level coverage</li>
          <li>• <strong>Company policy:</strong> Consider employer-provided</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Remote Work Insurance Strategy</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Freelancer/Contractor</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Insurance is your responsibility</li>
            <li>• Consider it a business expense</li>
            <li>• Budget 3-5% of income</li>
            <li>• Upgrade as income grows</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Remote Employee</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Check employer coverage abroad</li>
            <li>• May need supplemental policy</li>
            <li>• Ask HR about international options</li>
            <li>• SafetyWing as backup/supplement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Budget is under $100/month</li>
          <li>• You move frequently (true nomad)</li>
          <li>• You're young and healthy</li>
          <li>• Flexibility matters over comprehensiveness</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You want real health insurance</li>
          <li>• Routine care coverage matters</li>
          <li>• You have a stable income</li>
          <li>• Annual commitment is acceptable</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose GeoBlue if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• You're American and value US access</li>
          <li>• Blue Cross network matters</li>
          <li>• You travel home frequently</li>
          <li>• Quality telemedicine is important</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need insurance if I work for a US company remotely?</h3>
        <p class="text-neutral-700">It depends on your employment arrangement. W-2 employees may have international coverage extensions; ask HR. Contractors are responsible for their own insurance. Many US health plans don't cover care abroad except emergencies—supplement with travel or expat insurance.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use these plans for visa requirements?</h3>
        <p class="text-neutral-700">Yes, all three can provide visa compliance letters for most countries. However, some destinations (like Germany or Czech Republic) have specific requirements SafetyWing may not meet. Verify your visa country's specific insurance requirements before purchasing.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about prescriptions I take regularly?</h3>
        <p class="text-neutral-700">SafetyWing doesn't cover ongoing prescriptions. IMG and GeoBlue can include prescription coverage with outpatient plans. For specific medications, verify formulary coverage before enrolling. Many remote workers source medications locally (often cheaper) and use insurance for major medical only.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Should I keep US health insurance while working remotely?</h3>
        <p class="text-neutral-700">If you're living abroad, US insurance usually isn't cost-effective—you're paying for a network you can't use. However, maintaining short-term coverage or COBRA during transitions can provide continuity. Once established abroad, international insurance typically makes more sense.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing, coverage options, and visa compliance vary by specific plan and destination. Remote work arrangements and coverage needs differ significantly. Always verify current coverage directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
