---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'company-background', text: 'Company Background', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'plan-options', text: 'Plan Tiers & Options', level: 2 },
  { id: 'pricing', text: 'Pricing Breakdown', level: 2 },
  { id: 'deductible-advantage', text: 'The Deductible Advantage', level: 2 },
  { id: 'networks', text: 'Provider Networks', level: 2 },
  { id: 'claims-service', text: 'Claims & Customer Service', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'real-world-scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Best Budget Insurance', href: '/best/budget-expat-health-insurance' },
  { title: 'Mexico Insurance Guide', href: '/countries/mexico/insurance' },
  { title: 'Thailand Insurance Guide', href: '/countries/thailand/insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const coverageRows = [
  { feature: 'Maximum Coverage', img: 'Up to $8M', cigna: 'Up to Unlimited' },
  { feature: 'Inpatient Hospital', img: '✓ All plans', cigna: '✓ All plans' },
  { feature: 'Outpatient Care', img: '✓ All plans', cigna: '✓ Gold/Platinum' },
  { feature: 'Mental Health', img: 'Limited ($50K-$100K)', cigna: '✓ Included (higher limits)' },
  { feature: 'Maternity', img: 'Optional (10 mo wait)', cigna: 'Optional (12 mo wait)' },
  { feature: 'Preventive Care', img: '✓ Higher tiers', cigna: '✓ Platinum' },
  { feature: 'Dental/Vision', img: 'Optional add-on', cigna: 'Optional add-on' },
  { feature: 'Medical Evacuation', img: '✓ Up to $1M', cigna: '✓ Included' },
  { feature: 'Pre-existing Conditions', img: 'Full underwriting', cigna: 'Full underwriting' },
  { feature: 'US Coverage', img: 'Optional add-on', cigna: 'Optional add-on' },
  { feature: '50% Deductible Waiver (outside US)', img: '✓ Unique feature', cigna: '✗ Not offered' },
];

const planColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const planRows = [
  { aspect: 'Plan Structure', img: 'Tiered (Global Medical Insurance)', cigna: 'Tiered (Silver/Gold/Platinum)' },
  { aspect: 'Entry Level', img: 'Silver (~$100-140/mo)', cigna: 'Silver (~$120-160/mo)' },
  { aspect: 'Mid Tier', img: 'Gold (~$140-200/mo)', cigna: 'Gold (~$160-220/mo)' },
  { aspect: 'Top Tier', img: 'Platinum (~$200-300/mo)', cigna: 'Platinum (~$220-320/mo)' },
  { aspect: 'Deductible Options', img: '7 choices ($250-$10,000)', cigna: '4 choices ($0-$10,000)' },
  { aspect: 'Area of Coverage', img: 'Worldwide or excluding US', cigna: 'Regional or worldwide' },
  { aspect: 'Deductible Waiver', img: '50% waived outside US', cigna: 'No waiver' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'img', header: 'IMG Global (excl. US)' },
  { key: 'cigna', header: 'Cigna Global (excl. US)' },
  { key: 'savings', header: 'Annual Savings with IMG' },
];

const pricingRows = [
  { profile: 'Age 30, healthy', img: '~$100-140/mo', cigna: '~$140-180/mo', savings: '~$480-720' },
  { profile: 'Age 40, healthy', img: '~$150-200/mo', cigna: '~$190-250/mo', savings: '~$480-600' },
  { profile: 'Age 50, healthy', img: '~$220-300/mo', cigna: '~$280-370/mo', savings: '~$720-840' },
  { profile: 'Age 60, healthy', img: '~$320-420/mo', cigna: '~$400-550/mo', savings: '~$960-1,560' },
  { profile: 'Couple, 40s', img: '~$290-390/mo', cigna: '~$370-490/mo', savings: '~$960-1,200' },
  { profile: 'Family of 4', img: '~$420-580/mo', cigna: '~$550-750/mo', savings: '~$1,560-2,040' },
];

const deductibleColumns = [
  { key: 'deductible', header: 'Deductible' },
  { key: 'premium_impact', header: 'Approx. Premium Impact' },
  { key: 'outside_us', header: 'Effective Deductible Outside US (IMG)' },
  { key: 'best_for', header: 'Best For' },
];

const deductibleRows = [
  { deductible: '$250', premium_impact: 'Highest premiums', outside_us: '$125', best_for: 'Frequent healthcare users' },
  { deductible: '$500', premium_impact: '-5% vs $250', outside_us: '$250', best_for: 'Moderate healthcare needs' },
  { deductible: '$1,000', premium_impact: '-10% vs $250', outside_us: '$500', best_for: 'Occasional doctor visits' },
  { deductible: '$2,500', premium_impact: '-20% vs $250', outside_us: '$1,250', best_for: 'Healthy, cost-conscious' },
  { deductible: '$5,000', premium_impact: '-30% vs $250', outside_us: '$2,500', best_for: 'Major events only' },
  { deductible: '$10,000', premium_impact: '-40% vs $250', outside_us: '$5,000', best_for: 'Catastrophic coverage only' },
];

const networkColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const networkRows = [
  { aspect: 'Global Provider Count', img: 'Smaller network', cigna: '1.5M+ providers' },
  { aspect: 'Direct Billing', img: 'Limited (major hospitals)', cigna: 'Extensive worldwide' },
  { aspect: 'Payment Model', img: 'Often pay-then-claim', cigna: 'Often direct billing' },
  { aspect: 'Provider Finder', img: 'Basic online directory', cigna: 'Mobile app + web portal' },
  { aspect: 'Hospital Quality', img: 'Major hospitals covered', cigna: 'Wide range of facilities' },
  { aspect: 'Pre-authorization', img: 'Required for planned care', cigna: 'Required >$1,000 non-emergency' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const claimsRows = [
  { aspect: 'Claims Submission', img: 'Online portal, app, email', cigna: 'Mobile app, portal, email' },
  { aspect: 'Processing Time', img: '10-30 days (sometimes longer)', cigna: '5-10 business days' },
  { aspect: 'Complex Claims', img: 'Can take weeks to months', cigna: 'Generally faster resolution' },
  { aspect: 'Customer Service', img: '24/7 in 18 languages', cigna: '24/7 multilingual (highly rated)' },
  { aspect: 'Trustpilot Rating', img: '4.6/5 (19,000+ reviews)', cigna: '4.0/5 (1,000+ reviews)' },
  { aspect: 'Service Reputation', img: 'Good but variable', cigna: 'Consistently strong' },
];
---

<PageShell
  title="IMG Global vs Cigna Global: Complete 2025 Comparison"
  description="IMG Global vs Cigna Global compared in depth. Budget-friendly insurance vs premium coverage—see where to save money and when to pay more."
  headline="IMG Global vs Cigna Global"
  subheadline="The budget contender vs the premium standard. Save 20-30% with IMG or invest in Cigna's superior network and service—here's how to decide."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes from Both"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Overview</h2>

  <!-- Quick Decision Guide - CRO: Helps users self-select quickly -->
  <div class="bg-gradient-to-r from-primary-50 to-neutral-50 border border-primary-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">⚡ Quick Decision Guide</h3>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="bg-white rounded p-4 border border-primary-100">
        <p class="font-medium text-primary-900 mb-2">Choose IMG if:</p>
        <ul class="text-sm text-neutral-700 space-y-1">
          <li>• Budget is your top priority (save 20-30%)</li>
          <li>• You're healthy and rarely need care</li>
          <li>• You'll mostly be outside the US</li>
          <li>• You can handle pay-then-claim</li>
        </ul>
      </div>
      <div class="bg-white rounded p-4 border border-neutral-200">
        <p class="font-medium text-neutral-900 mb-2">Choose Cigna if:</p>
        <ul class="text-sm text-neutral-700 space-y-1">
          <li>• Direct billing matters to you</li>
          <li>• You have ongoing health needs</li>
          <li>• Mental health coverage is important</li>
          <li>• You value premium customer service</li>
        </ul>
      </div>
    </div>
  </div>

  <p>
    IMG Global and Cigna Global represent two different approaches to international health insurance. IMG is the value leader—solid coverage at budget-friendly prices. Cigna is the premium standard—larger network, better service, higher cost. This comparison will help you decide whether the savings with IMG are worth the trade-offs.
  </p>

  <p>
    <strong>IMG Global</strong> (International Medical Group) has been providing international insurance for over 30 years. They've built a reputation for affordable coverage with flexible options. Their unique 50% deductible waiver for care outside the US is a genuine money-saver. With a 4.6/5 Trustpilot rating from 19,000+ reviews, customer satisfaction is strong—though reviews note that claims processing can be slow.
  </p>

  <p>
    <strong>Cigna Global</strong> is often considered the benchmark in international health insurance. With 1.5 million+ providers worldwide and a reputation for excellent customer service, they're the premium choice. You pay more for Cigna—typically 20-30% more than IMG—but you get a larger network, faster claims, and more comprehensive coverage for things like mental health.
  </p>

  <p>
    The core question: Is Cigna's premium experience worth 20-30% more per year? For some expats, definitely. For others, IMG's savings make more sense.
  </p>

  <!-- At-a-glance boxes with trust signals - CRO: Builds credibility -->
  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">IMG Global</h3>
      <ul class="space-y-2 text-neutral-600">
        <li><strong>Founded:</strong> 1990 (Indianapolis, USA)</li>
        <li><strong>Trustpilot:</strong> 4.6/5 (19,000+ reviews)</li>
        <li><strong>Coverage Limit:</strong> Up to $8M</li>
        <li><strong>Best For:</strong> Budget-conscious, healthy expats</li>
        <li><strong>Unique Feature:</strong> 50% deductible waiver outside US</li>
        <li><strong>Positioning:</strong> Value leader</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Cigna Global</h3>
      <ul class="space-y-2 text-neutral-600">
        <li><strong>Parent Company:</strong> Cigna Corporation (US)</li>
        <li><strong>Network:</strong> 1.5M+ providers worldwide</li>
        <li><strong>Coverage Limit:</strong> Up to Unlimited</li>
        <li><strong>Best For:</strong> Service-focused, ongoing health needs</li>
        <li><strong>Strength:</strong> Direct billing and customer service</li>
        <li><strong>Positioning:</strong> Premium standard</li>
      </ul>
    </div>
  </div>

  <h2 id="company-background">Company Background</h2>

  <h3>IMG Global: The Value Specialist</h3>
  <p>
    International Medical Group (IMG) was founded in 1990 in Indianapolis, Indiana. They've carved out a niche as the budget-friendly option in international health insurance:
  </p>
  <ul>
    <li>Over 30 years serving expats, missionaries, students, and travelers</li>
    <li>Known for competitive pricing and flexible deductible options</li>
    <li>Strong customer reviews (4.6/5 on Trustpilot with 19,000+ ratings)</li>
    <li>Unique features like the 50% deductible waiver and Travel Intelligence alerts</li>
  </ul>
  <p>
    IMG isn't trying to be Cigna. They're intentionally positioned as the value option—solid coverage at lower prices, with trade-offs in network size and claims speed.
  </p>

  <h3>Cigna Global: The Premium Standard</h3>
  <p>
    Cigna's global health division is part of Cigna Corporation, one of America's largest health services companies. Their international operations are headquartered in Belgium:
  </p>
  <ul>
    <li>1.5 million+ providers in 200+ countries</li>
    <li>Consistently rated for excellent customer service</li>
    <li>Strong direct billing network worldwide</li>
    <li>Comprehensive coverage including robust mental health benefits</li>
  </ul>
  <p>
    Cigna is often the default recommendation for expats who want the "best" insurance. Whether that premium experience is worth the cost depends on your priorities.
  </p>

  <CTABox
    title="Compare Both Providers"
    description="Get personalized quotes from IMG Global and Cigna Global to see actual pricing."
    buttonText="Get Free Quotes"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="coverage-comparison">Coverage Comparison</h2>

  <p>
    Both providers offer comprehensive international coverage. The differences are in limits, mental health, and unique features.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Key Coverage Differences</h3>

  <p><strong>Coverage Limits:</strong></p>
  <ul>
    <li><strong>IMG:</strong> Up to $8 million maximum coverage</li>
    <li><strong>Cigna:</strong> Up to unlimited on Platinum plans</li>
  </ul>
  <p>
    $8 million is extremely high for most situations—it would cover virtually any medical scenario. But if unlimited coverage provides peace of mind, Cigna offers it.
  </p>

  <p><strong>Mental Health (Significant Difference):</strong></p>
  <ul>
    <li><strong>IMG:</strong> Limited mental health coverage ($50,000-$100,000 depending on plan)</li>
    <li><strong>Cigna:</strong> More comprehensive mental health benefits, higher limits</li>
  </ul>
  <p>
    If mental health coverage is important to you, Cigna is meaningfully better. IMG's limits may be insufficient for ongoing therapy or psychiatric care.
  </p>

  <p><strong>50% Deductible Waiver (IMG Exclusive):</strong></p>
  <ul>
    <li><strong>IMG:</strong> 50% of your deductible is waived for care received outside the US</li>
    <li><strong>Cigna:</strong> No equivalent feature</li>
  </ul>
  <p>
    This unique IMG feature means a $2,500 deductible becomes effectively $1,250 for care in Mexico, Portugal, Thailand, or anywhere outside the US. For expats who rarely visit America, this is a meaningful benefit.
  </p>

  <p><strong>Travel Intelligence (IMG Exclusive):</strong></p>
  <p>
    IMG includes Travel Intelligence—location-specific safety alerts, travel advisories, and security information. A nice bonus for expats who travel frequently.
  </p>

  <h2 id="plan-options">Plan Tiers & Options</h2>

  <p>
    Both providers use tiered plans, but IMG offers significantly more deductible flexibility.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>IMG Global Plans</h3>
  <p><strong>Global Medical Insurance (GMI):</strong></p>
  <ul>
    <li><strong>Silver:</strong> Comprehensive coverage, lower limits on some benefits</li>
    <li><strong>Gold:</strong> Enhanced limits, better wellness coverage</li>
    <li><strong>Platinum:</strong> Highest limits, most comprehensive</li>
  </ul>

  <p><strong>Deductible Options (7 choices):</strong></p>
  <ul>
    <li>$250, $500, $1,000, $2,500, $5,000, $7,500, $10,000</li>
  </ul>
  <p>
    This range lets you fine-tune your premium vs out-of-pocket balance. High deductibles ($5,000+) dramatically reduce premiums for those who rarely need care.
  </p>

  <h3>Cigna Global Plans</h3>
  <p><strong>International Health Insurance:</strong></p>
  <ul>
    <li><strong>Silver:</strong> Inpatient only—hospital, surgery, emergencies</li>
    <li><strong>Gold:</strong> Adds outpatient—doctor visits, prescriptions, therapy</li>
    <li><strong>Platinum:</strong> Comprehensive—wellness, preventive, enhanced limits</li>
  </ul>

  <p><strong>Deductible Options (4 choices):</strong></p>
  <ul>
    <li>$0, $2,500, $5,000, $10,000</li>
  </ul>
  <p>
    Fewer options than IMG, but covers the main scenarios. Note: Cigna Silver is inpatient-only, while IMG Silver includes outpatient.
  </p>

  <h2 id="pricing">Pricing Breakdown</h2>

  <p>
    IMG is typically 20-30% cheaper than Cigna for comparable coverage. The savings are real and significant.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-600 italic">
    *Estimates based on 2026-2025 quotes for mid-tier plans excluding US coverage. Actual prices vary based on health history, exact location, and plan details.
  </p>

  <h3>What the Savings Mean</h3>
  <p>
    For a family of four, choosing IMG over Cigna saves roughly $1,500-2,000 per year. Over five years abroad, that's $7,500-10,000 in premium savings. Whether that's worth the trade-offs depends on your situation.
  </p>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-2">When IMG's Savings Matter Most</h3>
    <ul class="text-blue-800 space-y-1">
      <li><strong>Young and healthy:</strong> Lower chance of needing Cigna's better claims service</li>
      <li><strong>Living outside the US:</strong> Benefit from 50% deductible waiver</li>
      <li><strong>Budget-constrained:</strong> Premium savings can be significant over years</li>
      <li><strong>Comfortable with reimbursement:</strong> Can handle paying upfront occasionally</li>
    </ul>
  </div>

  <!-- CTA after pricing - CRO: Capture users comparing costs -->
  <CTABox
    title="Get Your Actual Price"
    description="Pricing varies by individual. See exact quotes for your age and coverage needs."
    buttonText="Get Free Quotes"
    buttonHref="/go/cigna-global"
  />

  <h2 id="deductible-advantage">The Deductible Advantage</h2>

  <p>
    IMG's deductible flexibility and 50% waiver for non-US care are genuine differentiators worth understanding in depth.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={deductibleColumns} rows={deductibleRows} />
  </div>

  <h3>How the 50% Waiver Works</h3>
  <p>
    If you choose a $5,000 deductible and receive care in Portugal:
  </p>
  <ul>
    <li>Your effective deductible is $2,500 (50% waived)</li>
    <li>After paying $2,500 out-of-pocket, IMG covers the rest</li>
    <li>The same care in the US would require the full $5,000 deductible</li>
  </ul>

  <p>
    For expats living outside the US who rarely visit America, this makes high-deductible plans even more attractive. A $10,000 deductible becomes $5,000 effective—affordable catastrophic coverage at minimal premium cost.
  </p>

  <h3>Optimizing Your Deductible Choice</h3>
  <p>
    <strong>High deductible ($5,000-$10,000):</strong> Best for healthy expats who want low premiums and catastrophic protection. With IMG's 50% waiver, your effective deductible is manageable.
  </p>
  <p>
    <strong>Medium deductible ($1,000-$2,500):</strong> Balances premium cost with reasonable out-of-pocket exposure. Good for most people.
  </p>
  <p>
    <strong>Low deductible ($250-$500):</strong> Best if you expect to use healthcare frequently. Premium is higher, but out-of-pocket is predictable.
  </p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-2">Cigna Doesn't Offer This</h3>
    <p class="text-amber-800">
      Cigna has no equivalent to IMG's 50% deductible waiver. With Cigna, a $5,000 deductible is $5,000 whether you're in Thailand or Texas. For expats who'll primarily receive care outside the US, IMG's waiver creates real value.
    </p>
  </div>

  <h2 id="networks">Provider Networks</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={networkColumns} rows={networkRows} />
  </div>

  <h3>Cigna's Network Advantage</h3>
  <p>
    Cigna's 1.5 million+ provider network is genuinely industry-leading:
  </p>
  <ul>
    <li>Direct billing at hospitals worldwide—show your card, don't pay upfront</li>
    <li>Mobile app to find nearby providers</li>
    <li>Pre-authorization handled electronically</li>
    <li>Consistent experience across countries</li>
  </ul>
  <p>
    For someone with ongoing health needs who visits doctors frequently, Cigna's network makes life easier. Less paperwork, less out-of-pocket, less hassle.
  </p>

  <h3>IMG's Network Reality</h3>
  <p>
    IMG's network is smaller but functional:
  </p>
  <ul>
    <li>Major hospitals in most countries are covered</li>
    <li>Direct billing available at some facilities (not as extensive)</li>
    <li>Often need to pay and file for reimbursement</li>
    <li>Claims processing can take weeks</li>
  </ul>
  <p>
    For healthy expats who rarely need care, IMG's network is adequate. When you do need major care, they'll cover it—you just might pay upfront and wait for reimbursement.
  </p>

  <h3>The Practical Difference</h3>
  <p>
    With Cigna, routine healthcare is seamless—walk in, get treated, walk out. With IMG, you might pay $200 for a doctor visit and wait 2-4 weeks for reimbursement. For some people, that's a minor inconvenience. For others (especially those with limited cash flow), it's a real problem.
  </p>

  <h2 id="claims-service">Claims & Customer Service</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={claimsColumns} rows={claimsRows} />
  </div>

  <h3>IMG's Claims Experience</h3>
  <p>
    IMG's Trustpilot rating (4.6/5) is actually higher than Cigna's, but the reviews reveal nuance:
  </p>
  <ul>
    <li><strong>Positives:</strong> Generally cover what they say they'll cover, good value</li>
    <li><strong>Negatives:</strong> Claims processing can be slow (weeks to months for complex cases)</li>
    <li><strong>Mixed:</strong> Customer service quality varies by representative</li>
  </ul>
  <p>
    If you file a straightforward claim, IMG processes it fine. Complex claims or disputes can drag on longer than with Cigna.
  </p>

  <h3>Cigna's Claims Experience</h3>
  <p>
    Cigna's service reputation is consistently strong:
  </p>
  <ul>
    <li>Claims typically processed in 5-10 business days</li>
    <li>Direct billing reduces the need to file claims</li>
    <li>24/7 support with knowledgeable staff</li>
    <li>Proactive communication during claims</li>
  </ul>
  <p>
    When things go wrong medically, Cigna's support can make a real difference. This is part of what you pay for with their premium pricing.
  </p>

  <h2 id="who-should-choose">Who Should Choose Which</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose IMG Global If:</h3>
      <ul class="space-y-2 text-neutral-700">
        <li>✓ Budget is your top priority</li>
        <li>✓ You're young and healthy</li>
        <li>✓ You'll primarily be outside the US</li>
        <li>✓ You can handle pay-then-claim model</li>
        <li>✓ You want maximum deductible flexibility</li>
        <li>✓ The 50% deductible waiver benefits you</li>
        <li>✓ Mental health coverage isn't critical</li>
        <li>✓ You can wait for slower claims processing</li>
      </ul>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose Cigna Global If:</h3>
      <ul class="space-y-2 text-neutral-700">
        <li>✓ Direct billing is important to you</li>
        <li>✓ You have ongoing healthcare needs</li>
        <li>✓ Mental health coverage matters</li>
        <li>✓ You want the largest provider network</li>
