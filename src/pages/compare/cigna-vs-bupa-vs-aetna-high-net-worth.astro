---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'hnw-features', text: 'High-Net-Worth Features', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/high-net-worth', text: 'HNW Insurance Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/aetna-international', text: 'Aetna International Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'Premium Tier Plan', cigna: 'Cigna Global Platinum', bupa: 'Bupa Lifetime', aetna: 'Aetna Pioneer' },
  { feature: 'Annual Maximum', cigna: 'Unlimited', bupa: 'Unlimited', aetna: '$8M' },
  { feature: 'Private Room Standard', cigna: 'Yes', bupa: 'Yes', aetna: 'Yes' },
  { feature: 'Concierge Service', cigna: 'Yes (dedicated)', bupa: 'Yes (dedicated)', aetna: 'Yes' },
  { feature: 'Direct Billing Network', cigna: 'Extensive global', bupa: 'Extensive global', aetna: 'Strong US/global' },
  { feature: 'US Coverage Quality', cigna: 'Excellent', bupa: 'Good', aetna: 'Excellent' },
  { feature: 'Executive Health Checks', cigna: 'Included', bupa: 'Included', aetna: 'Available' },
  { feature: 'Second Opinion Service', cigna: 'Yes', bupa: 'Yes', aetna: 'Yes' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Platinum' },
  { key: 'bupa', header: 'Bupa Lifetime' },
  { key: 'aetna', header: 'Aetna Pioneer' },
];

const pricingRows = [
  { profile: 'Individual (45)', cigna: '$1,800-2,400/mo', bupa: '$2,000-2,600/mo', aetna: '$1,600-2,200/mo' },
  { profile: 'Couple (45+45)', cigna: '$3,400-4,600/mo', bupa: '$3,800-5,000/mo', aetna: '$3,000-4,200/mo' },
  { profile: 'Family (45+42+2 kids)', cigna: '$4,200-5,400/mo', bupa: '$4,600-6,000/mo', aetna: '$3,800-5,000/mo' },
  { profile: 'With $5K deductible', cigna: '$1,200-1,600/mo', bupa: '$1,400-1,800/mo', aetna: '$1,100-1,500/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna for High-Net-Worth Expats | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Aetna International for high-net-worth individuals. Expert analysis of premium tiers, concierge services, and exclusive benefits."
  headline="Cigna vs Bupa vs Aetna: High-Net-Worth Coverage"
  subheadline="Complete comparison of premium international health plans—covering concierge services, exclusive networks, and benefits befitting your lifestyle."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall</p>
        <p class="text-neutral-700 text-sm mb-4">Platinum tier offers unlimited coverage, dedicated concierge, and the most extensive global network. Best balance of premium features and service quality.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Most Exclusive</p>
        <p class="text-neutral-700 text-sm mb-4">Lifetime tier designed specifically for UHNW clients. Exceptional concierge service and access to the world's leading medical facilities.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 mb-3">Best US Network</p>
        <p class="text-neutral-700 text-sm mb-4">Pioneer plan offers excellent US coverage and competitive pricing. Ideal for HNW individuals splitting time between US and abroad.</p>
        <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Platinum Tier</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Coverage</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Dedicated Concierge</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global's Platinum plan delivers the comprehensive coverage high-net-worth individuals expect. Unlimited annual maximum, private room as standard, and a dedicated concierge team that handles everything from appointment scheduling to complex medical coordination. The network spans 200+ countries with direct billing at major facilities worldwide.</p>

    <p class="text-neutral-700 mb-4">Executive health screenings are included annually at world-class facilities. Medical second opinion services connect you with leading specialists when facing significant health decisions. The claims process is designed around HNW expectations—fast, frictionless, and with personal support throughout.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">HNW Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Unlimited coverage with no caps</li>
          <li>• Dedicated concierge team</li>
          <li>• Best overall global network</li>
          <li>• Executive health checks included</li>
          <li>• Medical second opinions</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Premium pricing (mid-range for HNW)</li>
          <li>• Some exclusive facilities prefer Bupa</li>
          <li>• Wellness coverage could be broader</li>
          <li>• No home healthcare standard</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Platinum Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Lifetime Tier</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">UHNW Focus</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">White Glove Service</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's Lifetime tier is explicitly designed for ultra-high-net-worth clients. Beyond unlimited coverage, it offers a level of personalized service that matches private banking—a named relationship manager who knows your family's health history, preferences, and coordinates all aspects of your care globally.</p>

    <p class="text-neutral-700 mb-4">Access to elite medical facilities is exceptional. Bupa's network includes partnerships with Mayo Clinic, Cleveland Clinic, and exclusive European facilities that don't accept other insurers. Home healthcare, private nursing, and recovery in luxury settings are standard. The pricing reflects this exclusivity—Bupa Lifetime is the most expensive option but offers services others cannot match.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">HNW Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Named relationship manager</li>
          <li>• Access to exclusive facilities</li>
          <li>• Home healthcare included</li>
          <li>• Private nursing/recovery</li>
          <li>• Family-wide coordination</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premium cost</li>
          <li>• US network slightly smaller</li>
          <li>• May be excessive for lower HNW</li>
          <li>• Long application process</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Lifetime Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Pioneer Plan</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">US Network Leader</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Value Premium</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International's Pioneer plan offers HNW-level coverage at more competitive pricing. The $8M annual maximum covers virtually any medical scenario, and Aetna's US roots mean unmatched domestic network access—essential for Americans abroad or those seeking US medical care for serious conditions.</p>

    <p class="text-neutral-700 mb-4">The Pioneer tier includes concierge services, executive health checks at US facilities, and strong global coverage. While slightly less white-glove than Bupa Lifetime, the service quality meets HNW expectations. Aetna is particularly strong for those who want premium coverage but don't need ultra-exclusive services.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">HNW Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Best US network access</li>
          <li>• Competitive HNW pricing</li>
          <li>• Strong concierge service</li>
          <li>• US executive health checks</li>
          <li>• CVS Health integration</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• $8M cap (vs unlimited)</li>
          <li>• Less exclusive than Bupa</li>
          <li>• Global network smaller outside US</li>
          <li>• Fewer luxury facility partnerships</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Aetna Pioneer Quote</a>
  </section>

  <CTABox
    title="Get Premium Plan Quotes"
    description="Connect with specialists who understand high-net-worth coverage requirements and can match you with the right premium plan."
    buttonText="Get HNW Consultation"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Premium tier pricing for comprehensive global coverage:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative for premium tiers with comprehensive coverage. Actual premiums depend on age, health history, coverage area, and specific plan options. HNW clients often choose higher deductibles to reduce premiums while maintaining comprehensive benefits.</p>
  </section>

  <section id="hnw-features" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">High-Net-Worth Features</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Concierge Services</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Dedicated relationship manager (Bupa)</li>
          <li>• 24/7 medical coordination</li>
          <li>• Appointment scheduling worldwide</li>
          <li>• Medical record management</li>
          <li>• Family health coordination</li>
          <li>• Travel health planning</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Executive Health</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Annual comprehensive screenings</li>
          <li>• World-class facility access</li>
          <li>• Preventive care programs</li>
          <li>• Medical second opinions</li>
          <li>• Specialist referrals</li>
          <li>• Longevity/wellness programs</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Premium Network Access</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">United States</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Mayo Clinic</li>
            <li>• Cleveland Clinic</li>
            <li>• Johns Hopkins</li>
            <li>• Memorial Sloan Kettering</li>
            <li>• Stanford Health Care</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Europe</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Harley Street Clinics</li>
            <li>• London Bridge Hospital</li>
            <li>• American Hospital Paris</li>
            <li>• Charité Berlin</li>
            <li>• Hirslanden Switzerland</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Asia/Middle East</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Bumrungrad Bangkok</li>
            <li>• Mount Elizabeth Singapore</li>
            <li>• Raffles Medical</li>
            <li>• Cleveland Clinic Abu Dhabi</li>
            <li>• Tokyo Medical Center</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global Platinum if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want excellent coverage without excessive exclusivity</li>
          <li>• Best overall global network matters</li>
          <li>• You prefer balanced premium vs features</li>
          <li>• Executive health and second opinions are important</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global Lifetime if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Ultra-high-net-worth with matching expectations</li>
          <li>• Named relationship manager is valuable</li>
          <li>• Access to most exclusive facilities matters</li>
          <li>• Home healthcare and private nursing are priorities</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Aetna Pioneer if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• US coverage is a priority</li>
          <li>• You want HNW coverage at competitive pricing</li>
          <li>• US executive health screenings appeal</li>
          <li>• $8M cap is sufficient for your needs</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is unlimited coverage really necessary?</h3>
        <p class="text-neutral-700">For most scenarios, $5-8M covers any medical situation. Unlimited coverage provides peace of mind for catastrophic scenarios—complex cancers, long-term ICU stays, or multiple organ transplants. HNW clients often prefer unlimited to avoid any coverage discussions during medical emergencies.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What does a dedicated concierge actually do?</h3>
        <p class="text-neutral-700">Beyond appointment scheduling, dedicated concierges coordinate complex care across countries, manage medical records, arrange air ambulances, secure hospital accommodations for family members, and serve as your advocate when navigating healthcare systems. For serious conditions, this coordination is invaluable.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use a high deductible to reduce premiums?</h3>
        <p class="text-neutral-700">Yes, and many HNW clients do. A $5,000-10,000 deductible can reduce premiums by 30-40% while maintaining all premium benefits for significant medical events. You self-insure routine care while ensuring world-class coverage when it matters most.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How do these plans handle family coverage?</h3>
        <p class="text-neutral-700">All three offer family plans with the same premium tier benefits for spouse and children. Bupa Lifetime extends relationship manager coordination to the entire family. Children typically stay on family plans until 18-26 depending on education status. Multi-generational family coverage is available.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Premium tier pricing and benefits vary by individual circumstances and change periodically. This comparison represents typical HNW tier offerings—actual coverage, pricing, and available features depend on your specific situation, location, and underwriting. Consult with HNW insurance specialists for personalized guidance.</p>
  </div>
</PageShell>
