---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'dental-details', text: 'Dental Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/guides/dental-care-abroad', text: 'Dental Care Abroad Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Annual Dental Limit', cigna: 'Up to $3,000', bupa: 'Up to $2,500', allianz: 'Up to $1,500' },
  { feature: 'Routine Cleanings', cigna: '2 per year', bupa: '2 per year', allianz: '1-2 per year' },
  { feature: 'X-rays', cigna: 'Full coverage', bupa: 'Full coverage', allianz: '1 set/year' },
  { feature: 'Fillings/Restorations', cigna: '80% covered', bupa: '75-80% covered', allianz: '70% covered' },
  { feature: 'Crowns/Bridges', cigna: '70% covered', bupa: '60-70% covered', allianz: '50% covered' },
  { feature: 'Root Canals', cigna: '80% covered', bupa: '75% covered', allianz: '70% covered' },
  { feature: 'Waiting Period', cigna: '6 months', bupa: '6-12 months', allianz: '12 months' },
  { feature: 'Orthodontics', cigna: 'Limited (50%)', bupa: 'Optional rider', allianz: 'Usually excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Base plan (no dental)', cigna: '$300/mo', bupa: '$350/mo', allianz: '$240/mo' },
  { profile: 'With dental coverage', cigna: '$380-450/mo', bupa: '$430-520/mo', allianz: '$300-370/mo' },
  { profile: 'Dental add-on cost', cigna: '+$80-150/mo', bupa: '+$80-170/mo', allianz: '+$60-130/mo' },
  { profile: 'Family dental add-on', cigna: '+$200-350/mo', bupa: '+$220-400/mo', allianz: '+$150-300/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Dental Coverage | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for dental coverage. Expert analysis of cleanings, fillings, crowns, orthodontics, and dental limits for expats."
  headline="Cigna vs Bupa vs Allianz: Best Dental Coverage"
  subheadline="Complete comparison for expats prioritizing dental care abroad—covering cleanings, restorations, major work, and orthodontics."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Dental</p>
        <p class="text-neutral-700 text-sm mb-4">Highest annual limits ($3,000), best coverage percentages, and includes limited orthodontics. Best choice for comprehensive dental needs.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Provider Network</p>
        <p class="text-neutral-700 text-sm mb-4">Strong dental network worldwide with direct billing at quality dentists. Good limits with orthodontic rider available.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Basic dental coverage at the lowest price. Good for routine care in countries where dental costs are low.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">$3,000 Limit</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Best Coverage %</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">6-Month Wait</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most comprehensive dental coverage among international insurers. The $3,000 annual limit is the highest, covering even expensive procedures in high-cost countries. Coverage percentages are generous: 100% preventive, 80% basic restorations, 70% major work.</p>

    <p class="text-neutral-700 mb-4">The 6-month waiting period for major dental work is the shortest option. Limited orthodontic coverage (50% up to a sub-limit) is included in comprehensive plans—useful for children or adults needing braces. Routine cleanings twice yearly help maintain oral health without out-of-pocket costs.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Dental Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Highest annual limit ($3,000)</li>
          <li>• Best coverage percentages</li>
          <li>• 6-month waiting period (shortest)</li>
          <li>• Limited orthodontics included</li>
          <li>• 2 cleanings per year</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher premium for dental</li>
          <li>• Pre-existing dental excluded</li>
          <li>• Cosmetic procedures excluded</li>
          <li>• Orthodontic limit low</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Dental Network</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Direct Billing</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Ortho Rider</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's dental coverage stands out for network access. Their dental provider network includes quality dentists worldwide with direct billing—no upfront payment for covered services. This convenience matters when seeking dental care in unfamiliar locations.</p>

    <p class="text-neutral-700 mb-4">The $2,500 annual limit covers most routine and moderate needs. An optional orthodontic rider is available for families with children needing braces. Waiting periods are 6-12 months depending on procedure type, with major work requiring the longest waits.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Dental Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Strong dental network</li>
          <li>• Direct billing at dentists</li>
          <li>• Optional orthodontic rider</li>
          <li>• Quality provider vetting</li>
          <li>• 2 cleanings per year</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lower limit than Cigna ($2,500)</li>
          <li>• Variable waiting periods</li>
          <li>• Orthodontics costs extra</li>
          <li>• Highest dental premiums</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Option</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Basic Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Low Premium</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care provides basic dental coverage at the most affordable price. The $1,500 annual limit is suitable for routine care and occasional fillings in countries where dental costs are low. For expats in Thailand, Mexico, or Eastern Europe, this limit often suffices.</p>

    <p class="text-neutral-700 mb-4">Coverage percentages are lower (70% for basic, 50% for major), so expect more out-of-pocket for significant work. The 12-month waiting period for major procedures is longest. Orthodontics are usually excluded. Best for those with good dental health seeking a safety net.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Dental Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable dental</li>
          <li>• Adequate for routine care</li>
          <li>• 1-2 cleanings covered</li>
          <li>• Basic fillings included</li>
          <li>• Low premium add-on</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lowest limit ($1,500)</li>
          <li>• Lower coverage percentages</li>
          <li>• 12-month waiting period</li>
          <li>• No orthodontics</li>
          <li>• Limited for major work</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Dental Coverage Quotes"
    description="Get personalized quotes with dental benefits from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Dental adds to premiums—here's the cost impact:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Dental is typically an add-on or included in comprehensive plans. Prices for individual coverage, age 35, Europe-based. Family dental premiums vary by number of children.</p>
  </section>

  <section id="dental-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Dental Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">What's Typically Covered</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Preventive (cleanings, exams)</li>
          <li>• Diagnostic (X-rays, evaluations)</li>
          <li>• Basic restorative (fillings)</li>
          <li>• Major restorative (crowns, bridges)</li>
          <li>• Endodontics (root canals)</li>
          <li>• Periodontics (gum treatment)</li>
          <li>• Emergency dental care</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Common Exclusions</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Cosmetic procedures (whitening)</li>
          <li>• Orthodontics (often excluded or limited)</li>
          <li>• Implants (varies by plan)</li>
          <li>• Pre-existing dental conditions</li>
          <li>• Procedures during waiting period</li>
          <li>• Non-dentist performed procedures</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Coverage Percentage Tiers</h3>
      <p class="text-blue-700 mb-4">Dental insurance typically uses tiered coverage levels:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Preventive (100%)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Cleanings</li>
            <li>• Exams</li>
            <li>• Routine X-rays</li>
            <li>• Fluoride treatment</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Basic (70-80%)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Fillings</li>
            <li>• Root canals</li>
            <li>• Extractions</li>
            <li>• Gum treatment</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Major (50-70%)</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Crowns</li>
            <li>• Bridges</li>
            <li>• Dentures</li>
            <li>• Implants (if covered)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the highest dental limits</li>
          <li>• Major dental work is likely</li>
          <li>• Orthodontics may be needed</li>
          <li>• Shorter waiting period matters</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Direct billing at dentists is valuable</li>
          <li>• You want a vetted provider network</li>
          <li>• Orthodontic rider appeals</li>
          <li>• Quality dental care matters most</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is your primary concern</li>
          <li>• You have good dental health</li>
          <li>• You're in a low-cost dental country</li>
          <li>• Basic coverage as a safety net is enough</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are dental implants covered?</h3>
        <p class="text-neutral-700">Coverage varies significantly. Cigna may cover implants at 50-70% within your annual limit. Bupa offers implant coverage on some plans. Allianz typically excludes implants. Given implant costs ($3,000-6,000 each), limits are often insufficient—many expats use dental tourism regardless of insurance.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about pre-existing dental conditions?</h3>
        <p class="text-neutral-700">Pre-existing dental conditions are almost always excluded initially. This includes fillings that will need replacement, known crowns needed, or ongoing periodontal disease. Waiting periods apply to new work only. Be honest on applications—undisclosed conditions can void coverage.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is it worth adding dental coverage?</h3>
        <p class="text-neutral-700">It depends on your location and dental health. In high-cost countries (US, UK, Switzerland), dental coverage provides real value. In low-cost countries (Mexico, Thailand, Hungary), paying cash may be cheaper than premiums. Calculate: if premiums exceed likely dental costs, consider self-insuring for dental.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How do dental emergencies work abroad?</h3>
        <p class="text-neutral-700">Dental emergencies (acute pain, broken teeth, infections) are typically covered immediately without waiting periods. Find a dentist, get treated, and submit the claim. For non-emergencies, waiting periods apply. All three insurers have 24/7 assistance lines to help locate emergency dental care.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Dental coverage limits, waiting periods, and percentages vary by specific plan and may change. Pre-existing dental conditions are typically excluded. Always verify current dental benefits directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
