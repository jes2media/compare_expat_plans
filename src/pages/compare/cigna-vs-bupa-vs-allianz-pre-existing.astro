---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'pre-existing-details', text: 'Pre-existing Condition Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/guides/pre-existing-conditions-abroad', text: 'Pre-existing Conditions Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Moratorium Option', cigna: 'Yes (2 years)', bupa: 'Yes (2 years)', allianz: 'Limited' },
  { feature: 'Medical Underwriting', cigna: 'Full assessment', bupa: 'Full assessment', allianz: 'Full assessment' },
  { feature: 'Full Cover Option', cigna: 'Yes (with loading)', bupa: 'Yes (with loading)', allianz: 'Rarely' },
  { feature: 'Waiting Period', cigna: '12-24 months', bupa: '12-24 months', allianz: '24 months+' },
  { feature: 'Chronic Conditions', cigna: 'Can be covered', bupa: 'Can be covered', allianz: 'Often excluded' },
  { feature: 'Mental Health History', cigna: 'Moratorium available', bupa: 'Moratorium available', allianz: 'Usually excluded' },
  { feature: 'Underwriting Flexibility', cigna: 'Good', bupa: 'Good', allianz: 'Limited' },
  { feature: 'Premium Loading', cigna: '15-100%+', bupa: '20-100%+', allianz: '10-50%' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { scenario: 'Healthy applicant (35)', cigna: '$350/mo', bupa: '$400/mo', allianz: '$280/mo' },
  { scenario: 'Diabetes (controlled)', cigna: '$420-520/mo', bupa: '$480-600/mo', allianz: 'Excluded' },
  { scenario: 'Heart condition history', cigna: '$490-700/mo', bupa: '$560-800/mo', allianz: 'Excluded' },
  { scenario: 'Mental health history', cigna: '$400-500/mo', bupa: '$450-550/mo', allianz: 'Excluded' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Pre-existing Conditions | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for pre-existing conditions. Expert analysis of moratorium options, underwriting, chronic conditions, and premium loading."
  headline="Cigna vs Bupa vs Allianz: Pre-existing Conditions"
  subheadline="Complete comparison for expats with health conditions—covering moratorium options, underwriting approaches, and paths to full coverage."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall</p>
        <p class="text-neutral-700 text-sm mb-4">Most flexible underwriting with both moratorium and full-cover options. Best path to eventually covering pre-existing conditions.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Strong Moratorium</p>
        <p class="text-neutral-700 text-sm mb-4">Excellent moratorium option where conditions become covered after 2 years symptom-free. Good for manageable conditions.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Strictest Approach</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable for healthy applicants but typically excludes pre-existing conditions. Best if conditions are mild or you're healthy.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Underwriting</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Moratorium Option</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Full Cover Possible</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most flexible approach to pre-existing conditions. You can choose moratorium underwriting (conditions excluded for 2 years, then automatically covered if symptom-free) or full medical underwriting (condition-specific exclusions or premium loading, but immediate coverage for everything else).</p>

    <p class="text-neutral-700 mb-4">For applicants willing to pay premium loading (15-100%+ depending on severity), Cigna can often provide full coverage including pre-existing conditions from day one. This is valuable for conditions requiring ongoing treatment. The underwriting team considers each case individually rather than blanket exclusions.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Pre-existing Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Moratorium and full-cover options</li>
          <li>• Case-by-case underwriting</li>
          <li>• Full coverage possible with loading</li>
          <li>• Chronic conditions can be covered</li>
          <li>• Mental health moratorium available</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Loading can be substantial</li>
          <li>• 2-year moratorium period</li>
          <li>• Severe conditions may be declined</li>
          <li>• Detailed medical disclosure required</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Strong Moratorium</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">2-Year Path</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Chronic Care</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's moratorium approach is straightforward: pre-existing conditions are excluded for 2 years, then automatically become covered if you haven't received treatment for them during that period. This works well for conditions that are managed and stable—after 2 symptom-free years, full coverage kicks in.</p>

    <p class="text-neutral-700 mb-4">Full medical underwriting is also available with condition-specific exclusions or premium loading. Bupa's underwriting tends toward slightly higher loadings than Cigna but similar flexibility. Their chronic condition management programs are strong once conditions are covered, making them good for long-term care needs.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Pre-existing Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Clear moratorium process</li>
          <li>• Automatic coverage after 2 years</li>
          <li>• Strong chronic care once covered</li>
          <li>• Mental health moratorium</li>
          <li>• Case-by-case review</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Slightly higher loadings</li>
          <li>• Strict 2-year symptom-free requirement</li>
          <li>• Premium pricing even without conditions</li>
          <li>• Detailed medical history needed</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Strict Underwriting</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Option</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Healthy Applicants</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care takes the strictest approach to pre-existing conditions. Most significant conditions are permanently excluded, with limited moratorium options. If you have diabetes, heart conditions, cancer history, or mental health treatment history, expect exclusions rather than coverage paths.</p>

    <p class="text-neutral-700 mb-4">This strict approach results in lower premiums for healthy applicants—Allianz is often 20-30% cheaper than Cigna or Bupa. For those with minor conditions or no health history, Allianz offers excellent value. But for meaningful pre-existing conditions, look to Cigna or Bupa instead.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Pre-existing Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable for healthy</li>
          <li>• Quick underwriting decisions</li>
          <li>• Clear exclusion terms</li>
          <li>• Minor conditions may be accepted</li>
          <li>• Lower premium loading</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Most conditions excluded</li>
          <li>• Limited moratorium options</li>
          <li>• Mental health usually excluded</li>
          <li>• Full cover rarely available</li>
          <li>• Not ideal for chronic conditions</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Get Quotes with Your Health History"
    description="Speak with specialists who understand pre-existing conditions and can find coverage options."
    buttonText="Get Free Consultation"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">How pre-existing conditions affect pricing:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative only—actual premiums depend on specific conditions, severity, treatment history, and underwriting assessment. Loading can vary dramatically.</p>
  </section>

  <section id="pre-existing-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pre-existing Condition Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Moratorium Underwriting</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Pre-existing conditions excluded initially</li>
          <li>• Typically 2-year symptom-free period</li>
          <li>• Conditions auto-covered after period</li>
          <li>• Any treatment restarts the clock</li>
          <li>• No medical questions required</li>
          <li>• Good for stable, managed conditions</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Full Medical Underwriting</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Complete medical history required</li>
          <li>• Condition-specific exclusions possible</li>
          <li>• Premium loading for higher risk</li>
          <li>• Full cover option available</li>
          <li>• May require medical exams</li>
          <li>• Case-by-case assessment</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Common Conditions & Coverage Likelihood</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Often Coverable</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Controlled hypertension</li>
            <li>• Thyroid conditions</li>
            <li>• Allergies/asthma (mild)</li>
            <li>• Previous surgeries (healed)</li>
            <li>• Minor skin conditions</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">With Loading/Moratorium</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Type 2 diabetes (controlled)</li>
            <li>• Anxiety/depression (stable)</li>
            <li>• Heart conditions (managed)</li>
            <li>• Autoimmune conditions</li>
            <li>• Back/spine conditions</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Difficult to Cover</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Recent cancer</li>
            <li>• Organ transplants</li>
            <li>• Severe mental illness</li>
            <li>• HIV/AIDS</li>
            <li>• Multiple chronic conditions</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want maximum flexibility</li>
          <li>• Full coverage with loading is acceptable</li>
          <li>• You have chronic conditions needing ongoing care</li>
          <li>• Mental health coverage is important</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Moratorium approach suits your situation</li>
          <li>• Your conditions are stable/managed</li>
          <li>• You can wait 2 years for full coverage</li>
          <li>• Long-term chronic care matters</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• You're generally healthy</li>
          <li>• Conditions are minor or fully resolved</li>
          <li>• Budget is the priority</li>
          <li>• You're comfortable with exclusions</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What happens if I don't disclose a pre-existing condition?</h3>
        <p class="text-neutral-700">Non-disclosure can void your entire policy. If you claim for an undisclosed condition—or even an unrelated condition where your undisclosed history is discovered—your claim may be denied and policy canceled. Always disclose everything; insurers may still offer coverage with exclusions or loading.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I get coverage for diabetes abroad?</h3>
        <p class="text-neutral-700">Yes, particularly with Cigna or Bupa. Well-controlled Type 2 diabetes is commonly covered with premium loading (20-50%). The moratorium option works if you can manage without treatment for 2 years. Insulin-dependent diabetes is more challenging but not impossible—expect higher loading.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does the moratorium actually work?</h3>
        <p class="text-neutral-700">Under moratorium, any condition you've had treatment, advice, or symptoms for in the past 5 years is excluded. If that condition remains symptom-free and untreated for 2 continuous years while insured, it becomes covered. Any treatment during the 2 years restarts the clock.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Will my premiums increase because of my conditions?</h3>
        <p class="text-neutral-700">With full medical underwriting, yes—expect "loading" of 15-100%+ depending on condition severity. Moratorium underwriting may have no loading since conditions are initially excluded. Standard age-related increases apply regardless of underwriting method.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Underwriting approaches, loading percentages, and coverage options vary by individual circumstance and change over time. This is general guidance—actual coverage depends on your specific health history and underwriting assessment. Always disclose all conditions and consult with insurance specialists for advice specific to your situation.</p>
  </div>
</PageShell>
