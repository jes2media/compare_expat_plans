  { profile: 'Single, Age 40', allianz: '$180-250/mo', bupa: '$300-400/mo' },
  { profile: 'Single, Age 50', allianz: '$260-350/mo', bupa: '$420-550/mo' },
  { profile: 'Couple, Age 35', allianz: '$260-360/mo', bupa: '$400-550/mo' },
  { profile: 'Family of 4', allianz: '$400-600/mo', bupa: '$700-950/mo' },
];

const planTierColumns = [
  { key: 'tier', header: 'Plan Tier' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'bupa', header: 'BUPA Global' },
];

const planTierRows = [
  { tier: 'Entry Level', allianz: 'Essential', bupa: 'Silver' },
  { tier: 'Mid-Range', allianz: 'Classic', bupa: 'Gold' },
  { tier: 'Comprehensive', allianz: 'Premium', bupa: 'Premier' },
  { tier: 'Ultra-Premium', allianz: 'Platinum', bupa: 'Elite / Lifeline' },
  { tier: 'Deductible Options', allianz: '€0-€10,000', bupa: '$0-$5,000' },
  { tier: 'Outpatient Included', allianz: 'Classic tier+', bupa: 'Gold tier+' },
