  { feature: 'No-Claims Discount', allianz: 'No', bupa: 'Yes (up to 50%)' },
  { feature: 'Annual Maximum', allianz: '€1M-Unlimited', bupa: '$2M-Unlimited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'bupa', header: 'BUPA Global' },
];

const pricingRows = [
