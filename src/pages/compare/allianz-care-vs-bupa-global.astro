const mentalHealthColumns = [
  { key: 'aspect', header: 'Mental Health Aspect' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'bupa', header: 'BUPA Global' },
];

const mentalHealthRows = [
  { aspect: 'Parity with Physical Health', allianz: 'No', bupa: 'Yes' },
  { aspect: 'Outpatient Therapy Sessions', allianz: '20-30/year', bupa: 'Unlimited*' },
  { aspect: 'Inpatient Mental Health', allianz: '30-60 days', bupa: 'Same as physical' },
  { aspect: 'Pre-existing Mental Health', allianz: 'Usually excluded', bupa: 'Often covered' },
  { aspect: 'Psychiatrist Visits', allianz: 'Included in cap', bupa: 'Comprehensive' },
  { aspect: 'Substance Abuse Treatment', allianz: 'Limited', bupa: 'Comprehensive' },
