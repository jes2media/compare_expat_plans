---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-decision', text: 'Quick Decision Guide', level: 2 },
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'us-coverage', text: 'US Coverage Comparison', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'deductible-strategy', text: 'The 50% Deductible Trick', level: 2 },
  { id: 'pricing', text: 'Pricing Analysis', level: 2 },
  { id: 'network-comparison', text: 'Provider Networks', level: 2 },
  { id: 'claims-process', text: 'Claims Experience', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
];

const relatedLinks = [
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'Best US Expat Insurance', href: '/best/us-expat-insurance' },
  { title: 'Best Budget Expat Insurance', href: '/best/budget-expat-insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { feature: 'Inpatient Care', aetna: 'Full coverage', img: 'Full coverage' },
  { feature: 'Outpatient Care', aetna: 'Full coverage', img: 'Full coverage' },
  { feature: 'Mental Health', aetna: 'Comprehensive', img: 'Limited (varies)' },
  { feature: 'Maternity', aetna: 'Optional add-on', img: 'Optional (12mo wait)' },
  { feature: 'Dental', aetna: 'Optional add-on', img: 'Optional add-on' },
  { feature: 'Vision', aetna: 'Optional', img: 'Optional' },
  { feature: 'Telemedicine', aetna: 'Included (vHealth)', img: 'Included' },
  { feature: 'Medical Evacuation', aetna: 'Included', img: '$500K-$1M' },
  { feature: 'US Coverage', aetna: 'Integrated (Aetna network)', img: 'Included (limited network)' },
  { feature: 'Pre-existing Conditions', aetna: 'Both options', img: 'Moratorium' },
];

const usNetworkColumns = [
  { key: 'aspect', header: 'US Network Aspect' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'img', header: 'IMG Global' },
];

const usNetworkRows = [
  { aspect: 'Network Type', aetna: 'Aetna domestic network', img: 'Various PPO networks' },
  { aspect: 'US Providers', aetna: '1.7 million+', img: 'Thousands (varies)' },
  { aspect: 'CVS Integration', aetna: 'Full access', img: 'None' },
  { aspect: 'Direct Billing (US)', aetna: 'Seamless', img: 'Limited' },
  { aspect: 'Negotiated Rates', aetna: 'Aetna rates', img: 'Network-dependent' },
  { aspect: 'Balance Billing Risk', aetna: 'Minimal', img: 'Possible' },
];

const deductibleColumns = [
  { key: 'deductible', header: 'Deductible Level' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'img_us', header: 'IMG (in US)' },
  { key: 'img_intl', header: 'IMG (outside US)' },
];

const deductibleRows = [
  { deductible: '$2,500', aetna: '$2,500 everywhere', img_us: '$2,500', img_intl: '$1,250 (50% waived)' },
  { deductible: '$5,000', aetna: '$5,000 everywhere', img_us: '$5,000', img_intl: '$2,500 (50% waived)' },
  { deductible: '$10,000', aetna: 'Not available', img_us: '$10,000', img_intl: '$5,000 (50% waived)' },
  { deductible: '$25,000', aetna: 'Not available', img_us: '$25,000', img_intl: '$12,500 (50% waived)' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'aetna', header: 'Aetna ($2.5K ded)' },
  { key: 'img_standard', header: 'IMG ($2.5K ded)' },
  { key: 'img_high', header: 'IMG ($10K ded)' },
];

const pricingRows = [
  { profile: '30-year-old', aetna: '$200-280/mo', img_standard: '$140-180/mo', img_high: '$95-130/mo' },
  { profile: '40-year-old', aetna: '$280-380/mo', img_standard: '$190-250/mo', img_high: '$130-170/mo' },
  { profile: '50-year-old', aetna: '$380-520/mo', img_standard: '$260-340/mo', img_high: '$180-230/mo' },
  { profile: 'Couple (35, 35)', aetna: '$420-560/mo', img_standard: '$300-400/mo', img_high: '$210-280/mo' },
  { profile: 'Family of 4', aetna: '$680-920/mo', img_standard: '$480-620/mo', img_high: '$340-440/mo' },
];

const networkColumns = [
  { key: 'region', header: 'Region' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'img', header: 'IMG Global' },
];

const networkRows = [
  { region: 'United States', aetna: 'Excellent (1.7M+ providers)', img: 'Good (PPO networks)' },
  { region: 'Europe', aetna: 'Good coverage', img: 'Partner networks' },
  { region: 'Asia Pacific', aetna: 'Strong presence', img: 'Good coverage' },
  { region: 'Latin America', aetna: 'Good coverage', img: 'Strong presence' },
  { region: 'Middle East', aetna: 'Moderate', img: 'Adequate' },
  { region: 'Direct Billing', aetna: 'Widely available', img: 'Limited availability' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'img', header: 'IMG Global' },
];

const claimsRows = [
  { aspect: 'Submission Methods', aetna: 'App, online, email', img: 'App, online, fax' },
  { aspect: 'Processing Time', aetna: '5-10 business days', img: '7-14 business days' },
  { aspect: 'US Claims', aetna: 'Automatic at Aetna network', img: 'Often requires reimbursement' },
  { aspect: 'International Claims', aetna: 'Direct billing common', img: 'Reimbursement common' },
  { aspect: 'Customer Service', aetna: '24/7, multilingual', img: 'US business hours' },
  { aspect: 'CVS Benefits', aetna: 'MinuteClinic, pharmacy', img: 'None' },
];
---

<PageShell
  title="Aetna International vs IMG Global: Premium Integration vs Budget Flexibility"
  description="Compare Aetna International and IMG Global for US expats. CVS-backed premium coverage vs high-deductible budget options with 50% international deductible waiver."
  headline="Aetna International vs IMG Global"
  subheadline="CVS-backed premium coverage vs budget flexibility. Two US-focused options at very different price points."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Aetna Quote"
  ctaButtonHref="/go/aetna-international"
>

  <h2 id="quick-decision">Quick Decision Guide</h2>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-4">Make Your Choice in 60 Seconds</h3>

    <p class="mb-4"><strong>Question 1: How often will you use US healthcare?</strong></p>
    <ul class="mb-4">
      <li><strong>Frequently (3+ times/year) →</strong> Aetna's network is worth it. <strong>Lean Aetna</strong></li>
      <li><strong>Rarely or never →</strong> IMG's 50% deductible waiver saves money abroad. Continue to Question 2</li>
    </ul>

    <p class="mb-4"><strong>Question 2: Is mental health coverage important?</strong></p>
    <ul class="mb-4">
      <li><strong>Yes →</strong> Aetna has better mental health coverage. <strong>Lean Aetna</strong></li>
      <li><strong>No →</strong> IMG is adequate. Continue to Question 3</li>
    </ul>

    <p class="mb-4"><strong>Question 3: Is budget your primary concern?</strong></p>
    <ul>
      <li><strong>Yes →</strong> IMG with high deductible saves 50%+. <strong>Choose IMG</strong></li>
      <li><strong>No, coverage quality matters more →</strong> Aetna provides premium experience</li>
    </ul>
    <div class="flex flex-wrap gap-3 mt-6">
      <a href="/go/aetna-international" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Aetna Quote</a>
      <a href="/go/img-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get IMG Quote</a>
    </div>
  </div>

  <p>
    <strong>The short version:</strong> Aetna International is the premium choice for US expats who want integrated coverage with CVS benefits and excellent US network access. IMG Global is the budget choice for expats who rarely use US healthcare and want to minimize premiums through high deductibles and the 50% international deductible waiver.
  </p>

  <h2 id="overview">Overview</h2>

  <p>
    Aetna International and IMG Global are both US-based options for American expats, but they serve different segments of the market. Aetna is the premium, integrated option. IMG is the flexible, budget option.
  </p>

  <p>
    <strong>Aetna International</strong> is backed by CVS Health, one of America's largest healthcare companies. This connection provides unique advantages: seamless integration with Aetna's domestic network (1.7M+ providers), CVS MinuteClinic access, and pharmacy benefits. They're designed for expats who want their international insurance to work like domestic insurance when they're home.
  </p>

  <p>
    <strong>IMG Global</strong> has served expats since 1990, specializing in flexible, customizable coverage. Their standout features are ultra-high deductible options (up to $25,000) and a 50% deductible waiver for care outside the US—making them attractive for budget-conscious expats who primarily live abroad.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Aetna International at a Glance</h3>
      <ul class="space-y-2 text-neutral-700">
        <li><strong>Parent:</strong> CVS Health</li>
        <li><strong>Key Strength:</strong> US network integration</li>
        <li><strong>CVS Benefits:</strong> MinuteClinic, pharmacy</li>
        <li><strong>US Providers:</strong> 1.7 million+</li>
        <li><strong>Max Deductible:</strong> $5,000</li>
        <li><strong>Best For:</strong> Frequent US healthcare users</li>
      </ul>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">IMG Global at a Glance</h3>
      <ul class="space-y-2 text-neutral-700">
        <li><strong>Founded:</strong> 1990</li>
        <li><strong>Key Strength:</strong> High-deductible flexibility</li>
        <li><strong>50% Deductible Waiver:</strong> Outside US</li>
        <li><strong>Max Deductible:</strong> $25,000</li>
        <li><strong>US Network:</strong> Various PPOs</li>
        <li><strong>Best For:</strong> Budget-conscious expats abroad</li>
      </ul>
    </div>
  </div>

  <h2 id="us-coverage">US Coverage Comparison</h2>

  <p>
    Both include US coverage, but the quality and integration differ significantly.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={usNetworkColumns} rows={usNetworkRows} />
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Aetna's CVS Integration Advantage</h3>
    <p class="mb-4">
      The CVS Health connection provides tangible benefits:
    </p>
    <ul class="space-y-2 text-neutral-700">
      <li><strong>1.7M+ US providers:</strong> Same network as Aetna domestic plans</li>
      <li><strong>CVS MinuteClinic:</strong> Walk-in clinics at CVS stores nationwide</li>
      <li><strong>CVS Pharmacy:</strong> Integrated prescription benefits</li>
      <li><strong>Direct billing:</strong> Seamless claims at network providers</li>
      <li><strong>vHealth telemedicine:</strong> 24/7 virtual care access</li>
    </ul>
    <p class="mt-4 text-sm">
      For expats who return to the US frequently, this integration means healthcare works exactly like it would with domestic insurance.
    </p>
  </div>

  <h3>IMG's US Coverage</h3>
  <p>
    IMG includes US coverage, but it works differently:
  </p>
  <ul>
    <li><strong>Network:</strong> Various PPO arrangements—less comprehensive than Aetna's</li>
    <li><strong>Process:</strong> More likely to require upfront payment and reimbursement</li>
    <li><strong>Integration:</strong> No pharmacy or clinic benefits included</li>
    <li><strong>Balance billing:</strong> More risk with out-of-network providers</li>
  </ul>

  <p>
    <strong>The bottom line:</strong> If you use US healthcare regularly, Aetna's network justifies the premium. If you rarely return to the US, IMG's adequate US coverage is sufficient.
  </p>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Compare Both Options</h3>
    <p class="text-neutral-600 mb-4">Get personalized quotes based on your US usage and budget.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/aetna-international" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Aetna Quote</a>
      <a href="/go/img-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get IMG Quote</a>
    </div>
  </div>

  <h2 id="coverage-comparison">Coverage Comparison</h2>

  <p>
    Beyond US networks, here's how their coverage compares:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Mental Health Coverage</h3>
  <p>
    Aetna has a clear advantage here. Their comprehensive mental health coverage includes therapy, psychiatric care, and inpatient treatment. IMG's mental health coverage is limited and varies by plan—often with caps or exclusions. If mental health coverage matters, Aetna is the better choice.
  </p>

  <h3>Pre-existing Conditions</h3>
  <p>
    Aetna offers both moratorium and full medical underwriting options, giving you flexibility in how pre-existing conditions are handled. IMG uses a moratorium approach: conditions aren't covered initially but can become covered after a treatment-free period (typically 2 years).
  </p>

  <h3>Telemedicine</h3>
  <p>
    Both include telemedicine. Aetna's vHealth service is more robust with 24/7 availability and integration with their broader care system. IMG's telemedicine is adequate but more basic.
  </p>

  <h2 id="deductible-strategy">The 50% Deductible Trick</h2>

  <p>
    IMG's most unique feature is the 50% deductible waiver for care outside the US. This can be a significant advantage for expats who primarily live and receive care abroad.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={deductibleColumns} rows={deductibleRows} />
  </div>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">How the 50% Waiver Works</h3>
    <p class="mb-4">
      If you choose IMG with a $10,000 deductible:
    </p>
    <ul class="space-y-2 text-neutral-700">
      <li><strong>Care in the US:</strong> You pay the full $10,000 deductible</li>
      <li><strong>Care outside the US:</strong> You only pay $5,000 deductible (50% waived)</li>
      <li><strong>The math:</strong> If you primarily receive care abroad, your effective deductible is half what it appears</li>
    </ul>
    <p class="mt-4">
      <strong>Example:</strong> An expat in Mexico with a $10,000 deductible effectively has a $5,000 deductible for local care. Combined with Mexico's lower healthcare costs, this makes high-deductible plans much more practical.
    </p>
  </div>

  <h3>Why This Matters</h3>
  <p>
    The 50% waiver changes the math for high-deductible strategies:
  </p>
  <ul>
    <li>A $25,000 deductible becomes $12,500 for international care</li>
    <li>Premium savings of 50-60% become more palatable</li>
    <li>Works well in countries with affordable healthcare</li>
    <li>Makes catastrophic-only coverage more practical</li>
  </ul>

  <h2 id="pricing">Pricing Analysis</h2>

  <p>
    IMG is significantly cheaper—40-50% less at similar deductibles, and 60%+ less with high-deductible strategies.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <h3>Understanding the Price Gap</h3>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-8">
    <h4 class="font-semibold mb-3">What You're Paying For</h4>
    <ul class="space-y-2">
      <li><strong>Aetna's premium:</strong> CVS integration, 1.7M+ US network, comprehensive mental health, premium service</li>
      <li><strong>IMG at same deductible:</strong> 30-40% cheaper, but without CVS benefits and smaller US network</li>
      <li><strong>IMG with high deductible:</strong> 60%+ cheaper, plus 50% international waiver makes it more practical</li>
      <li><strong>Annual savings:</strong> $1,500-4,000+ depending on profile and deductible choice</li>
    </ul>
  </div>

  <h3>When Aetna's Premium is Worth It</h3>
  <ul>
    <li>You use US healthcare regularly (3+ times/year)</li>
    <li>You want CVS MinuteClinic and pharmacy access</li>
    <li>Mental health coverage is a priority</li>
    <li>You prefer seamless direct billing</li>
    <li>Budget isn't the primary concern</li>
  </ul>

  <h3>When IMG's Savings Make Sense</h3>
  <ul>
    <li>You rarely return to the US for healthcare</li>
    <li>You're healthy and want catastrophic coverage</li>
    <li>You live in a country with affordable healthcare</li>
    <li>You're comfortable with higher deductibles</li>
    <li>Budget is a primary consideration</li>
  </ul>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Calculate Your Actual Savings</h3>
    <p class="text-neutral-600 mb-4">Premiums vary significantly. Get personalized quotes.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/aetna-international" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get Aetna Quote</a>
      <a href="/go/img-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get IMG Quote</a>
    </div>
  </div>

  <h2 id="network-comparison">Provider Networks</h2>

  <p>
    Here's how their networks compare across regions:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={networkColumns} rows={networkRows} />
  </div>

  <h3>Regional Analysis</h3>

  <p>
    <strong>United States:</strong> Aetna wins decisively. The CVS Health integration means 1.7M+ providers, seamless direct billing, and pharmacy benefits. IMG's US coverage works but requires more navigation.
  </p>

  <p>
    <strong>Latin America:</strong> IMG has strong presence here—it's a popular market for their products. Many US expats in Mexico and Central America use IMG successfully. Aetna is adequate but not as focused on this region.
  </p>

  <p>
    <strong>Asia Pacific:</strong> Aetna has stronger presence, particularly in major expat hubs like Hong Kong and Singapore. IMG's coverage is adequate through partner networks.
  </p>

  <p>
    <strong>Europe:</strong> Both have good coverage. Aetna may have slightly better direct billing arrangements. IMG works well but is more reimbursement-based.
  </p>

  <h2 id="claims-process">Claims Experience</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={claimsColumns} rows={claimsRows} />
  </div>

  <h3>Real-World Claims Differences</h3>

  <p>
    <strong>Aetna in the US:</strong> Walk into any Aetna network provider, show your card, receive care. Claims process automatically. CVS MinuteClinics work the same way. It's identical to domestic insurance.
  </p>

  <p>
    <strong>IMG in the US:</strong> Check if the provider is in-network. If yes, may be able to direct bill (verify first). If not, pay upfront and file for reimbursement. More variable experience than Aetna.
  </p>

  <p>
    <strong>International:</strong> Aetna has better direct billing relationships globally. IMG works more on a reimbursement model—pay upfront, submit claims, get reimbursed in 7-14 days.
  </p>

  <h3>Customer Service</h3>
  <p>
    Aetna offers 24/7 multilingual support with the resources of CVS Health behind it. IMG provides solid US-based support during business hours but with fewer resources. For complex situations, Aetna's support infrastructure is stronger.
  </p>

  <h2 id="scenarios">Real-World Scenarios</h2>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Scenario 1: Executive with US Travel</h3>
      <p class="text-neutral-600 mb-3">Michael, 45, works for a US company based in Singapore. He travels to the US quarterly for meetings and sees his US doctor during visits. Mental health coverage matters.</p>
      <p class="text-neutral-700"><strong>Best choice: Aetna International</strong> — Frequent US travel makes the Aetna network valuable. CVS MinuteClinic access during business trips is convenient. Mental health coverage is comprehensive. The premium is justified by his usage pattern.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Scenario 2: Retiree in Mexico</h3>
      <p class="text-neutral-600 mb-3">Patricia, 60, retired to Lake Chapala. She's healthy, visits the US once a year for family, and uses local Mexican healthcare for most needs. Fixed income means budget matters.</p>
      <p class="text-neutral-700"><strong>Best choice: IMG Global ($5K deductible)</strong> — The 50% deductible waiver means her effective deductible for Mexican care is $2,500. Healthcare in Mexico is affordable. She saves $150+/month versus Aetna. Rare US visits don't require premium network access.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Scenario 3: Young Professional in Germany</h3>
      <p class="text-neutral-600 mb-3">David, 32, works for a German company. He's extremely healthy, visits the US once a year for holidays, and wants to minimize costs while having solid coverage.</p>
      <p class="text-neutral-700"><strong>Best choice: IMG Global ($10K deductible)</strong> — Young and healthy with rare US visits. The $10K deductible becomes $5K in Germany. He saves $100+/month versus Aetna. German healthcare is affordable, making the high deductible practical.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Scenario 4: Family Splitting Time</h3>
      <p class="text-neutral-600 mb-3">The Johnsons (parents 40, kids 10 and 12) live in Portugal but spend summers in the US with grandparents. Kids need predictable coverage.</p>
      <p class="text-neutral-700"><strong>Best choice: Aetna International</strong> — Significant US time (3 months/year) makes the Aetna network valuable. Kids' healthcare needs are unpredictable—having seamless US coverage during summers provides peace of mind. The premium is worth it for family coverage.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Scenario 5: Digital Nomad in Southeast Asia</h3>
      <p class="text-neutral-600 mb-3">Jessica, 29, works remotely from Thailand and Bali. She's healthy, rarely visits the US, and healthcare in SEA is very affordable. Budget is tight.</p>
      <p class="text-neutral-700"><strong>Best choice: IMG Global ($10K-$25K deductible)</strong> — The ultra-high deductible cuts her premium dramatically. The 50% waiver means $5K-$12.5K effective deductible in Asia. SEA healthcare is so cheap she can self-insure routine care. The savings fund more travel.</p>
    </div>
  </div>

  <h2 id="who-should-choose">Who Should Choose Which</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose Aetna International If:</h3>
      <ul class="space-y-2 text-neutral-700">
        <li>✓ You use US healthcare regularly (3+ times/year)</li>
