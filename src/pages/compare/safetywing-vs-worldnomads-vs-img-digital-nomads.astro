---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'worldnomads', text: 'World Nomads', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'nomad-considerations', text: 'Digital Nomad Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'SafetyWing Full Review', href: '/providers/safetywing' },
  { title: 'World Nomads Full Review', href: '/providers/world-nomads' },
  { title: 'IMG Global Full Review', href: '/providers/img-global' },
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
  { title: 'Best Nomad Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'worldnomads', header: 'World Nomads' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Built for nomads', safetywing: 'Yes—core focus', worldnomads: 'Travelers focus', img: 'Expats focus' },
  { feature: 'Monthly subscription', safetywing: 'Yes—$45+/mo', worldnomads: 'No—trip-based', img: 'No—term-based' },
  { feature: 'Cancel anytime', safetywing: 'Yes', worldnomads: 'Limited', img: 'Limited' },
  { feature: 'Continuous travel', safetywing: 'Designed for it', worldnomads: 'Trip limits apply', img: 'Good for long stays' },
  { feature: 'Remote work covered', safetywing: 'Yes—explicitly', worldnomads: 'Not addressed', img: 'Yes' },
  { feature: 'Coworking injuries', safetywing: 'Covered', worldnomads: 'Unclear', img: 'Covered' },
  { feature: 'Laptop theft', safetywing: 'No', worldnomads: 'Yes—gear coverage', img: 'Add-on available' },
  { feature: 'Visa compliance', safetywing: 'Most countries', worldnomads: 'Most countries', img: 'Strong compliance' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'worldnomads', header: 'World Nomads' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { scenario: 'Age 25, monthly', safetywing: '$45/mo', worldnomads: '~$100/mo equiv', img: '$80-120/mo' },
  { scenario: 'Age 35, monthly', safetywing: '$52/mo', worldnomads: '~$120/mo equiv', img: '$100-150/mo' },
  { scenario: 'Age 45, monthly', safetywing: '$75/mo', worldnomads: '~$160/mo equiv', img: '$140-200/mo' },
  { scenario: '6-month trip', safetywing: '$270-450', worldnomads: '$600-900', img: '$500-800' },
  { scenario: '12-month continuous', safetywing: '$540-900', worldnomads: '$1,200-1,800', img: '$1,000-1,500' },
];
---

<PageShell
  title="SafetyWing vs World Nomads vs IMG: Best for Digital Nomads 2025"
  description="Compare SafetyWing, World Nomads, and IMG for digital nomads. Monthly subscriptions, continuous travel coverage, remote work protection, and nomad-specific features."
  headline="SafetyWing vs World Nomads vs IMG: Digital Nomad Insurance"
  subheadline="Which insurer understands the nomad lifestyle? Subscription plans, continuous travel, and coverage designed for location-independent workers."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best for Nomads</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">SafetyWing</p>
      <p class="text-sm text-neutral-600 mb-3">Built specifically for digital nomads. Monthly subscription, cancel anytime. Most affordable for continuous travelers.</p>
      <a href="/providers/safetywing" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best for Adventurers</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">World Nomads</p>
      <p class="text-sm text-neutral-600 mb-3">Adventure activities included. Gear and laptop coverage. Best for nomads who prioritize experiences over cost.</p>
      <a href="/providers/world-nomads" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best for Long Stays</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">IMG Global</p>
      <p class="text-sm text-neutral-600 mb-3">Higher coverage limits. Better for settling in one place. Good for nomads transitioning to expat life.</p>
      <a href="/providers/img-global" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="safetywing">SafetyWing Nomad Insurance</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">SafetyWing was founded by digital nomads for digital nomads. Their subscription model mirrors how nomads live—pay monthly, no fixed end date, pause or cancel when you want. It's become the default choice for the nomad community.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Digital Nomad Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Monthly subscription—no commitment</li>
      <li>Designed for indefinite travel</li>
      <li>Remote work explicitly covered</li>
      <li>Coworking space injuries covered</li>
      <li>Most affordable option ($45/mo starting)</li>
      <li>Simple signup—covered in minutes</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Lower coverage limit ($250,000)</li>
      <li>Limited US coverage (30 days/90)</li>
      <li>No gear or laptop coverage</li>
      <li>$250 deductible per incident</li>
      <li>Not accepted for some visa applications</li>
    </ul>
  </div>

  <h2 id="worldnomads">World Nomads</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">World Nomads targets adventure travelers with comprehensive activity coverage and gear protection. While not specifically designed for digital nomads, their coverage appeals to nomads who prioritize experiences and want their equipment protected.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Digital Nomad Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>150+ adventure activities covered</li>
      <li>Gear and electronics coverage</li>
      <li>Laptop theft/damage covered</li>
      <li>Trip cancellation included</li>
      <li>Can purchase while traveling</li>
      <li>Good for shorter trips/hops</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Trip-based, not subscription</li>
      <li>Maximum trip length limits</li>
      <li>Higher cost than SafetyWing</li>
      <li>Not designed for continuous travel</li>
      <li>Remote work coverage unclear</li>
    </ul>
  </div>

  <h2 id="img">IMG Global</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">IMG Global bridges the gap between travel insurance and full expat coverage. Their higher limits and more comprehensive benefits suit nomads who stay longer in each location or are transitioning toward a more settled expat life.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Digital Nomad Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Higher coverage limits ($500K-$2M)</li>
      <li>Full US coverage available</li>
      <li>Remote work covered</li>
      <li>Strong visa compliance</li>
      <li>Good for 6-12+ month stays</li>
      <li>Flexible deductible options</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>More expensive than SafetyWing</li>
      <li>Term-based, not monthly subscription</li>
      <li>Less flexible for short hops</li>
      <li>More complex to understand</li>
      <li>Feels more "insurance" than "nomad"</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage for Your Nomad Lifestyle"
    description="Compare plans designed for location-independent workers. Monthly subscriptions, continuous travel coverage, and protection wherever you work."
    buttonText="Compare Nomad Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Monthly and trip-based costs for digital nomads. SafetyWing's subscription model vs traditional term pricing.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">SafetyWing charges monthly; World Nomads prices per trip; IMG charges per term. For continuous travel, SafetyWing is most affordable. For specific trips with gear coverage, World Nomads may justify its premium.</p>

  <h2 id="nomad-considerations">Digital Nomad Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">The Nomad Lifestyle Reality</h3>
      <p class="text-neutral-700">Traditional insurance assumes you have a home country and take "trips." Nomads live differently—continuous movement, no fixed end date, working from anywhere. SafetyWing was built for this reality. World Nomads and IMG can work but require more planning around trip dates and renewals.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Remote Work Coverage</h3>
      <p class="text-neutral-700">Working while traveling raises insurance questions. SafetyWing explicitly covers remote work—injuries at coworking spaces, work-related RSI, etc. World Nomads is designed for "travelers" and may not cover work-related incidents. IMG covers work but is designed for traditional expats. If work is core to your nomad life, verify coverage.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Visa Requirements</h3>
      <p class="text-neutral-700">Digital nomad visas often require health insurance. SafetyWing works for most but is rejected by some countries (Czech Republic requires specific insurers). IMG has stronger visa compliance. World Nomads is accepted for most travel visas. Verify your specific visa requirements—the cheapest plan that doesn't meet requirements is worthless.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Equipment and Gear</h3>
      <p class="text-neutral-700">Your laptop is your livelihood. SafetyWing doesn't cover gear—you'd need separate electronics insurance. World Nomads includes gear coverage (cameras, laptops, phones). IMG offers gear add-ons. If protecting your work equipment matters, factor this into your decision—or get separate gadget insurance.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">US Coverage Matters</h3>
      <p class="text-neutral-700">American nomads face a dilemma—US healthcare is expensive. SafetyWing limits US coverage to 30 days per 90-day period. IMG and World Nomads offer full US coverage at higher cost. If you visit the US or might need emergency care there, weigh this carefully. One US ER visit without coverage can exceed years of premium savings.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose SafetyWing If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You're a "true" digital nomad</li>
        <li>Budget is top priority</li>
        <li>You want monthly flexibility</li>
        <li>You don't need gear coverage</li>
        <li>Limited US time is fine</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose World Nomads If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Adventure activities are priority</li>
        <li>You need gear coverage</li>
        <li>You take distinct trips</li>
        <li>Trip cancellation matters</li>
        <li>Cost is secondary</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose IMG If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You stay longer in places</li>
        <li>Higher coverage limits matter</li>
        <li>You need full US coverage</li>
        <li>Visa compliance is critical</li>
        <li>You're becoming more "expat"</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I start coverage while already abroad?</h3>
      <p class="text-neutral-700">Yes—all three allow you to purchase while traveling. SafetyWing starts immediately. World Nomads has a short waiting period for some benefits. IMG can start within days. This flexibility is essential for nomads who don't plan trips months in advance. You don't need to be in your home country to get covered.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What if I stay in one country for 6+ months?</h3>
      <p class="text-neutral-700">SafetyWing works for extended stays but was designed for movement. IMG is better suited for longer single-country stays. World Nomads has trip length limits that may not work. If you're becoming a slow nomad or settling somewhere, IMG or even traditional expat insurance might serve you better than travel-focused options.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is my coworking space accident covered?</h3>
      <p class="text-neutral-700">SafetyWing explicitly covers accidents at coworking spaces. IMG covers work-related injuries. World Nomads is unclear—their coverage is designed for travelers, not workers. If coworking is part of your routine, verify coverage. Slipping on a wet floor or ergonomic injuries from bad chairs are real risks.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about mental health coverage?</h3>
      <p class="text-neutral-700">Mental health coverage is limited across all three. SafetyWing doesn't cover mental health. World Nomads may cover crisis intervention. IMG offers some mental health coverage on higher plans. Nomad life can be isolating—if mental health coverage is important, you may need supplemental coverage or choose a traditional expat plan.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I get a visa with SafetyWing?</h3>
      <p class="text-neutral-700">SafetyWing works for most visas including Schengen and many digital nomad visas. However, some countries (Czech Republic, notably) require specific insurers and don't accept SafetyWing. Always verify your specific visa requirements before purchasing. IMG has stronger compliance documentation if visas are your priority.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How do claims work when I'm constantly moving?</h3>
      <p class="text-neutral-700">All three have online claims processes—essential for nomads. SafetyWing's claims are handled through their app and portal. World Nomads and IMG have online claims with documentation upload. Keep receipts and records digitally. Claims typically reimburse within 2-4 weeks. Direct billing is limited—expect to pay and claim back for most care.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Digital nomad insurance needs vary by travel style, destinations, and risk tolerance. Coverage limits, exclusions, and pricing change regularly. Visa requirements should be verified independently. This comparison provides general guidance—read policy documents carefully before purchasing.
    </p>
  </div>
</PageShell>
