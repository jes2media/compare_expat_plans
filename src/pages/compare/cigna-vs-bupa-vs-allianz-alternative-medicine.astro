---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'alt-med-details', text: 'Alternative Medicine Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/guides/alternative-medicine-abroad', text: 'Alternative Medicine Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Acupuncture', cigna: 'Covered (limits apply)', bupa: 'Covered (limits apply)', allianz: 'Limited' },
  { feature: 'Chiropractic', cigna: 'Covered (limits apply)', bupa: 'Covered (limits apply)', allianz: 'Limited' },
  { feature: 'Osteopathy', cigna: 'Covered', bupa: 'Covered', allianz: 'Some plans' },
  { feature: 'Physiotherapy', cigna: 'Covered', bupa: 'Covered', allianz: 'Covered' },
  { feature: 'Homeopathy', cigna: 'Limited', bupa: 'Some plans', allianz: 'Not covered' },
  { feature: 'Naturopathy', cigna: 'Limited', bupa: 'Limited', allianz: 'Not covered' },
  { feature: 'Traditional Chinese Medicine', cigna: 'Covered (Asia)', bupa: 'Covered (limits)', allianz: 'Limited' },
  { feature: 'Annual Alternative Limit', cigna: '$1,500-3,000', bupa: '$1,000-2,500', allianz: '$500-1,000' },
];

const pricingColumns = [
  { key: 'coverage', header: 'Coverage Level' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { coverage: 'Basic (no alt med)', cigna: '$280/mo', bupa: '$320/mo', allianz: '$220/mo' },
  { coverage: 'With alt med module', cigna: '$350/mo', bupa: '$380/mo', allianz: '$250/mo' },
  { coverage: 'Comprehensive', cigna: '$420/mo', bupa: '$450/mo', allianz: '$300/mo' },
  { coverage: 'Alt med annual limit', cigna: '$2,000-3,000', bupa: '$1,500-2,500', allianz: '$500-1,000' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Alternative Medicine | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for alternative medicine coverage. Expert analysis of acupuncture, chiropractic, osteopathy, and complementary therapies."
  headline="Cigna vs Bupa vs Allianz: Alternative Medicine"
  subheadline="Complete comparison of complementary therapy coverage—including acupuncture, chiropractic, osteopathy, and traditional medicine practices worldwide."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall</p>
        <p class="text-neutral-700 text-sm mb-4">Highest annual limits for alternative therapies and broadest coverage of complementary treatments. Best for regular users of alternative medicine.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Good Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Solid alternative medicine benefits with good practitioner networks. Strong in Europe and Asia for traditional therapies.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Basic Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Limited alternative medicine coverage at lower premiums. Best if alternative therapies are occasional, not regular.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Highest Limits</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Broad Coverage</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">TCM Included</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most comprehensive alternative medicine coverage among major international insurers. Annual limits of $2,000-3,000 for complementary therapies mean regular users can access acupuncture, chiropractic, and osteopathy without quickly exhausting benefits. Coverage extends to qualified practitioners worldwide.</p>

    <p class="text-neutral-700 mb-4">Traditional Chinese Medicine (TCM) coverage is particularly strong for expats in Asia—acupuncture, herbal medicine consultations, and related treatments are covered at licensed practitioners. In Western countries, chiropractors, osteopaths, and physiotherapists are all within network. Some plans include naturopathy and homeopathy, though with lower sub-limits.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Alt Med Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Highest annual limits ($3K+)</li>
          <li>• Broadest therapy coverage</li>
          <li>• Strong TCM coverage in Asia</li>
          <li>• Good practitioner networks</li>
          <li>• Some naturopathy included</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Requires outpatient plan</li>
          <li>• Session limits may apply</li>
          <li>• Referral needed for some treatments</li>
          <li>• Higher premium tier</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Good Coverage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">European Network</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Asia Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global provides solid alternative medicine coverage with annual limits typically between $1,500-2,500. Acupuncture, chiropractic, and osteopathy are covered on comprehensive outpatient plans. Their practitioner network in Europe is particularly strong, with direct billing available at many complementary therapy clinics.</p>

    <p class="text-neutral-700 mb-4">In Asia, Bupa covers Traditional Chinese Medicine including acupuncture and herbal consultations. Physiotherapy is covered generously as it's considered mainstream medicine. Homeopathy coverage varies by plan and location—more commonly available in Europe where it's practiced widely. Session limits (typically 15-20 per year per therapy type) help manage costs while providing meaningful coverage.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Alt Med Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Solid annual limits</li>
          <li>• Strong European network</li>
          <li>• TCM in Asia covered</li>
          <li>• Direct billing available</li>
          <li>• Good physiotherapy</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Session limits per therapy</li>
          <li>• Lower limits than Cigna</li>
          <li>• Naturopathy limited</li>
          <li>• Premium pricing</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Basic Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Lower Premiums</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers more limited alternative medicine coverage, reflected in lower premiums. Basic physiotherapy is covered well, but acupuncture and chiropractic coverage is more restricted—lower annual limits ($500-1,000) and fewer covered sessions. Homeopathy and naturopathy are typically not covered.</p>

    <p class="text-neutral-700 mb-4">For expats who use alternative therapies occasionally rather than regularly, Allianz may suffice. The lower limits cover a few sessions per year for acute issues. If you rely on regular chiropractic adjustments, ongoing acupuncture, or frequent complementary therapy visits, the limits will likely be exhausted quickly. Consider Cigna or Bupa for heavier use.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Alt Med Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lower premium costs</li>
          <li>• Good physiotherapy</li>
          <li>• Basic acupuncture/chiro</li>
          <li>• Adequate for light users</li>
          <li>• Simple structure</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Low annual limits ($500-1K)</li>
          <li>• Limited session coverage</li>
          <li>• No homeopathy/naturopathy</li>
          <li>• TCM limited</li>
          <li>• Not for regular users</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Get Alternative Medicine Coverage Quotes"
    description="Compare complementary therapy benefits and find coverage that matches your wellness approach."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">How alternative medicine coverage affects premiums (individual, 40):</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative for comprehensive outpatient coverage. Alternative medicine benefits are typically included in outpatient modules, not separate add-ons. Actual limits and coverage depend on specific plan tier selected.</p>
  </section>

  <section id="alt-med-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Alternative Medicine Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Commonly Covered Therapies</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Acupuncture (licensed practitioners)</li>
          <li>• Chiropractic care</li>
          <li>• Osteopathy</li>
          <li>• Physiotherapy</li>
          <li>• Traditional Chinese Medicine</li>
          <li>• Therapeutic massage (with referral)</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Limited or Excluded</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Homeopathy (plan-dependent)</li>
          <li>• Naturopathy (limited)</li>
          <li>• Ayurvedic medicine</li>
          <li>• Energy healing (Reiki, etc.)</li>
          <li>• Unlicensed practitioners</li>
          <li>• Experimental treatments</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Regional Availability</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Asia</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• TCM widely covered</li>
            <li>• Acupuncture mainstream</li>
            <li>• Herbal consultations</li>
            <li>• Good practitioner networks</li>
            <li>• Direct billing common</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Europe</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Osteopathy popular</li>
            <li>• Chiropractic covered</li>
            <li>• Homeopathy (varies)</li>
            <li>• Strong networks</li>
            <li>• Regulated practitioners</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Americas</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Chiropractic common</li>
            <li>• Acupuncture growing</li>
            <li>• Naturopathy limited</li>
            <li>• Licensing varies by state</li>
            <li>• Check local networks</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Alternative medicine is central to your healthcare</li>
          <li>• You need higher annual limits</li>
          <li>• TCM in Asia is important</li>
          <li>• You want broadest therapy coverage</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You use alternative therapies regularly but moderately</li>
          <li>• European practitioner networks matter</li>
          <li>• Physiotherapy is your main need</li>
          <li>• Balance of coverage and cost works</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Alternative therapies are occasional</li>
          <li>• Budget is the priority</li>
          <li>• Basic physiotherapy suffices</li>
          <li>• You'll pay out-of-pocket for extras</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need a referral for alternative medicine?</h3>
        <p class="text-neutral-700">It depends on the therapy and insurer. Physiotherapy usually requires a doctor's referral. Chiropractic and osteopathy often allow direct access. Acupuncture policies vary—some require referral, others don't. Check your specific plan terms to understand referral requirements.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are herbal medicines and supplements covered?</h3>
        <p class="text-neutral-700">Generally no. Even with TCM coverage, herbal medicines prescribed during consultations are typically excluded or have very low limits. Consultations are covered; the herbs themselves usually aren't. Supplements and vitamins are almost never covered by international health insurance.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What qualifications do practitioners need?</h3>
        <p class="text-neutral-700">Insurers require licensed or registered practitioners in their field. This means different things in different countries—acupuncturists may need medical degrees in some places, specific certifications in others. Using unlicensed practitioners risks claim denial. When in doubt, check with your insurer before treatment.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use alternative medicine for chronic conditions?</h3>
        <p class="text-neutral-700">Yes, within annual limits. Many expats use acupuncture for chronic pain, chiropractic for ongoing back issues, or TCM for various conditions. The key is that annual limits may be reached quickly with regular treatment. Consider whether your typical usage fits within coverage limits before choosing a plan.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Alternative medicine coverage, annual limits, and covered therapies vary by specific plan and change over time. This comparison represents typical offerings—actual coverage depends on your plan tier and location. Always verify that specific therapies and practitioners are covered before seeking treatment.</p>
  </div>
</PageShell>
