---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Estonia Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Estonia's Digital Nomad Visa. Expert analysis of Cigna Global, SafetyWing, and Allianz Care for remote workers moving to Estonia.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz-care", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "Estonia Visa Acceptance", cigna: "✓ Widely accepted", safetywing: "✓ Accepted for DN visa", allianz: "✓ Widely accepted" },
  { feature: "Estonian Network", cigna: "Limited (reimbursement)", safetywing: "Reimbursement model", allianz: "Limited (reimbursement)" },
  { feature: "Schengen Coverage", cigna: "✓ Full Europe", safetywing: "✓ Worldwide", allianz: "✓ Full Europe" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Acute onset only", allianz: "Moratorium option" },
  { feature: "E-Residency Compatible", cigna: "✓ Yes", safetywing: "✓ Yes", allianz: "✓ Yes" },
  { feature: "Monthly Flexibility", cigna: "Annual commitment", safetywing: "✓ Month-to-month", allianz: "Annual commitment" },
  { feature: "Annual Maximum", cigna: "€1M - Unlimited", safetywing: "$250,000", allianz: "€1M - Unlimited" },
  { feature: "Best For", cigna: "Long-term settlers", safetywing: "Budget nomads", allianz: "Comprehensive needs" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "100% covered", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited visits", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100,000", allianz: "Unlimited" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Emergency only", allianz: "100% covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", allianz: "Optional" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Full coverage" },
  { coverage: "COVID-19", cigna: "Full coverage", safetywing: "Full coverage", allianz: "Full coverage" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "€140-220/month", safetywing: "$45-56/month", allianz: "€130-200/month" },
  { age: "30-35", cigna: "€170-260/month", safetywing: "$68-84/month", allianz: "€160-240/month" },
  { age: "35-40", cigna: "€210-320/month", safetywing: "$99-123/month", allianz: "€200-300/month" },
  { age: "40-45", cigna: "€260-400/month", safetywing: "$135-168/month", allianz: "€250-380/month" },
];

const networkColumns = [
  { key: "region", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { region: "Tallinn", cigna: "Reimbursement model", safetywing: "Reimbursement model", allianz: "Reimbursement model" },
  { region: "Tartu", cigna: "Reimbursement model", safetywing: "Reimbursement model", allianz: "Reimbursement model" },
  { region: "Other Estonia", cigna: "Reimbursement model", safetywing: "Reimbursement model", allianz: "Reimbursement model" },
  { region: "Helsinki (nearby)", cigna: "Strong network", safetywing: "Reimbursement", allianz: "Strong network" },
  { region: "Schengen/EU", cigna: "Full coverage", safetywing: "Full coverage", allianz: "Full coverage" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Estonia's Digital Nomad Visa"
    heroImage="/images/countries/estonia-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Estonia Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Estonia was one of the first countries to launch a Digital Nomad Visa in 2020, building on its reputation as a digital-first nation (home of e-Residency). The visa allows remote workers to live in Estonia while working for employers or clients outside the country.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Valid health insurance covering your entire stay in Estonia</li>
          <li>• Minimum coverage of €30,000 (Schengen standard)</li>
          <li>• Must cover hospitalization, emergency care, and repatriation</li>
          <li>• Insurance from a recognized EU or international provider</li>
          <li>• Coverage valid from visa start date</li>
          <li>• Two visa types: short-stay (up to 1 year) and long-stay (up to 1 year, extendable)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Estonia has a well-developed healthcare system. As a DN visa holder, you're not automatically covered by Estonian public health insurance (Haigekassa), so private insurance is essential. Healthcare quality is good, particularly in Tallinn, though options are more limited than in larger EU countries.
      </p>

      <p class="text-neutral-700">
        Estonia's appeal for digital nomads includes: one of Europe's most digital governments, a vibrant startup ecosystem, lower cost of living than Western Europe, and fast internet. Many combine the DN visa with e-Residency for running an EU-based business.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Top 3 Insurers for Estonia DN Visa</h2>

      <p class="text-neutral-700 mb-6">
        We've analyzed options from budget-friendly nomad insurance to comprehensive international coverage. All meet Estonia's visa requirements:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive international coverage suitable for digital nomads planning longer stays in Estonia. Their European coverage is excellent, though direct billing networks in Estonia specifically are limited.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Full Schengen/EU coverage for travel</li>
            <li>• Comprehensive mental health benefits</li>
            <li>• Good for e-Residency entrepreneurs</li>
            <li>• Modular plans for customization</li>
            <li>• Strong network in Helsinki (2hr ferry)</li>
            <li>• 24/7 multilingual support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Annual commitment required</li>
            <li>• Higher cost than nomad insurance</li>
            <li>• Limited direct billing in Estonia</li>
            <li>• May be overkill for short stays</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive coverage for European digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing is designed specifically for digital nomads, with flexible monthly subscriptions. Their Nomad Insurance is accepted for Estonia's DN visa and popular in the nomad community.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable (starts under $50/month)</li>
            <li>• Month-to-month flexibility</li>
            <li>• Designed for nomad lifestyle</li>
            <li>• Worldwide coverage</li>
            <li>• Easy online management</li>
            <li>• Meets Estonia visa requirements</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Lower coverage limits ($250K max)</li>
            <li>• Pre-existing: acute onset only</li>
            <li>• No routine/preventive care</li>
            <li>• Reimbursement model everywhere</li>
            <li>• Limited mental health coverage</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget-friendly insurance for digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers flexible international coverage with strong European networks. Their brand recognition across the EU can smooth administrative processes.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong European coverage</li>
            <li>• Brand recognition in EU</li>
            <li>• Flexible plan options</li>
            <li>• Good wellness benefits</li>
            <li>• Multiple deductible choices</li>
            <li>• Comprehensive chronic care</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Annual commitment</li>
            <li>• Estonian network limited</li>
            <li>• Claims can take time</li>
            <li>• Similar pricing to Cigna</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="Trusted European coverage for digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/allianz"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        All three meet Estonia's €30,000 minimum requirement. Here's detailed coverage comparison:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing covers emergencies and hospital stays but lacks routine care. For nomads with ongoing health needs, Cigna or Allianz provide more comprehensive coverage.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically cheaper but with corresponding coverage limitations:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing's low cost makes it ideal for testing Estonia. For longer commitments, comprehensive plans may be worth the investment.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Estonia</h2>

      <p class="text-neutral-700 mb-6">
        Estonia is small; all insurers primarily use reimbursement models here:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        No insurer has extensive direct billing networks in Estonia. You'll typically pay upfront and submit claims. Helsinki (2-hour ferry) offers more options with some insurers.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Testing Estonia for Summer</h3>
          <p class="text-neutral-600 mb-3">27-year-old developer trying Tallinn for 3 months, healthy, exploring e-Residency.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">Perfect for testing. Month-to-month flexibility, meets visa requirements. Upgrade if you decide to stay longer.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: E-Residency Entrepreneur</h3>
          <p class="text-neutral-600 mb-3">34-year-old running EU company via e-Residency, living in Tallinn full year.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Allianz Care</p>
          <p class="text-neutral-600 text-sm">Full-year commitment justifies comprehensive coverage. EU-wide coverage important for business travel. Good for long-term stability.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Nomad with Mental Health Needs</h3>
          <p class="text-neutral-600 mb-3">31-year-old who sees a therapist regularly, planning 6 months in Estonia.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Best mental health coverage. Can continue therapy via telehealth. SafetyWing's limited mental health makes it unsuitable.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Budget-Conscious Full Year</h3>
          <p class="text-neutral-600 mb-3">25-year-old, very healthy, wants to minimize costs during 12-month visa.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">Meets requirements at lowest cost. Estonian private care is affordable for routine needs. SafetyWing covers the expensive stuff (hospitalization).</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Couple Relocating to Tallinn</h3>
          <p class="text-neutral-600 mb-3">38-year-old couple, both remote workers, planning to stay 2+ years.</p>
          <p class="text-green-700 font-medium">Recommendation: Allianz Care couple plan</p>
          <p class="text-neutral-600 text-sm">Long-term commitment makes comprehensive coverage worthwhile. Allianz family/couple plans offer good value. Consider applying for Estonian residence after DN visa.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For budget-conscious nomads testing Estonia, <strong>SafetyWing</strong> offers excellent value with month-to-month flexibility. For those committing to a full year or longer, <strong>Cigna Global</strong> or <strong>Allianz Care</strong> provide more comprehensive coverage worth the investment. Estonia's small size means all insurers use similar reimbursement models locally.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Budget is priority</li>
            <li>• Very healthy</li>
            <li>• Want flexibility</li>
            <li>• Testing Estonia short-term</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Need mental health coverage</li>
            <li>• Planning 1+ year stay</li>
            <li>• Want comprehensive benefits</li>
            <li>• Travel across EU often</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Prefer EU brand</li>
            <li>• Want flexible deductibles</li>
            <li>• Have chronic conditions</li>
            <li>• Value wellness benefits</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I access Estonian public healthcare with the DN visa?</h3>
          <p class="text-neutral-600">No. DN visa holders aren't covered by Haigekassa (Estonian public health insurance). You'll need private insurance and pay for healthcare out-of-pocket or through your insurance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What's the income requirement for Estonia's DN visa?</h3>
          <p class="text-neutral-600">You must prove income of at least €4,500/month (before tax) from remote work for clients/employers outside Estonia. This is among the higher requirements for DN visas.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How is healthcare quality in Estonia?</h3>
          <p class="text-neutral-600">Good, especially in Tallinn. Private clinics offer modern care with reasonable wait times. English is widely spoken in healthcare settings. For complex procedures, Helsinki (2-hour ferry) is easily accessible.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about e-Residency—do I need it with the DN visa?</h3>
          <p class="text-neutral-600">E-Residency and DN visa are separate. E-Residency is a digital identity for running an EU company; it doesn't grant physical residence. Many combine both: DN visa to live in Estonia, e-Residency to run a company.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I travel in the Schengen Area with Estonia's DN visa?</h3>
          <p class="text-neutral-600">Yes. Estonia is in Schengen, so you can travel freely within the 27 Schengen countries. All three insurance options provide full Schengen coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What happens after the DN visa expires?</h3>
          <p class="text-neutral-600">The DN visa is for up to 1 year, renewable once (2 years total). After that, you'd need to apply for a different residence permit (D-visa/TRP) or leave. If you want to stay longer, consider applying for temporary residence based on your business/employment.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Visa requirements and insurance regulations can change. Verify current requirements with the Estonian Police and Border Guard Board. Confirm policy details with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
