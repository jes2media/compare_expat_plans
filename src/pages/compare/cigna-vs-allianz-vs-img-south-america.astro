---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Allianz vs IMG: Best International Health Insurance for South America";
const description = "Compare Cigna Global, Allianz Care, and IMG Global for expats in South America. Coverage analysis for Brazil, Argentina, Chile, Colombia, Peru, and Ecuador.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'South America Network', cigna: 'Excellent', allianz: 'Strong', img: 'Good' },
  { feature: 'Brazil Coverage', cigna: 'Comprehensive', allianz: 'Strong', img: 'Good' },
  { feature: 'Mental Health', cigna: 'Excellent', allianz: 'Good', img: 'Limited' },
  { feature: 'Tropical Disease', cigna: 'Full coverage', allianz: 'Full coverage', img: 'Covered' },
  { feature: 'Medical Evacuation', cigna: 'Worldwide', allianz: 'Included', img: 'Included' },
  { feature: 'Contract Flexibility', cigna: 'Annual', allianz: '6-month min', img: 'Flexible' },
  { feature: 'Starting Price', cigna: '$$$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Unlimited options', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', allianz: 'Comprehensive', img: 'Plan dependent' },
  { coverage: 'Mental Health', cigna: 'Full coverage', allianz: 'Annual limits', img: 'Limited' },
  { coverage: 'Tropical Disease', cigna: 'Full coverage', allianz: 'Full coverage', img: 'Covered' },
  { coverage: 'Preventive Care', cigna: 'Included', allianz: 'Available', img: 'Basic' },
  { coverage: 'US/Canada Treatment', cigna: 'Optional', allianz: 'Optional', img: 'Optional' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Individual, 35, Brazil', cigna: '$3,200-4,400/yr', allianz: '$2,600-3,600/yr', img: '$1,500-2,100/yr' },
  { profile: 'Individual, 45, Argentina', cigna: '$4,500-6,200/yr', allianz: '$3,600-5,000/yr', img: '$2,200-3,000/yr' },
  { profile: 'Individual, 55, Chile', cigna: '$6,500-8,800/yr', allianz: '$5,200-7,200/yr', img: '$3,200-4,400/yr' },
  { profile: 'Family of 4, Colombia', cigna: '$11,000-15,000/yr', allianz: '$9,000-12,000/yr', img: '$5,500-7,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'south-america-considerations', text: 'South America Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Latin America', href: '/insurance-for/latin-america' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most comprehensive coverage with excellent hospital networks in major South American cities, strong mental health support, and premium care access.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at more competitive pricing, with flexibility that works well for those exploring multiple South American countries.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're a digital nomad or budget-conscious expat who needs affordable coverage while living in South America's lower-cost destinations.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>South America offers diverse expat experiences—from Brazil's business hubs to Ecuador's retiree havens to Chile's stability. Healthcare quality varies significantly between countries and between public/private systems. Private international insurance provides consistent access to quality care across this varied continent.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers the most comprehensive coverage for South America with excellent networks in Brazil, Argentina, Chile, and Colombia. Their presence in the region's premium hospitals and strong support services provide security for expats in diverse locations.</p>

      <h3>Strengths for South America Expats</h3>
      <ul>
        <li>Excellent networks in São Paulo, Buenos Aires, Santiago, Bogotá</li>
        <li>Comprehensive mental health coverage</li>
        <li>Full tropical disease coverage</li>
        <li>24/7 multilingual support including Spanish and Portuguese</li>
        <li>Medical evacuation to US/Europe if needed</li>
        <li>Direct billing at major private hospitals</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>Annual commitment required</li>
        <li>May exceed needs in lower-cost countries like Ecuador or Bolivia</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid comprehensive coverage at more competitive pricing, with good networks across South America. Their flexibility suits expats exploring multiple countries or those on extended stays.</p>

      <h3>Strengths for South America Expats</h3>
      <ul>
        <li>Competitive pricing for the region</li>
        <li>Good networks in major South American cities</li>
        <li>6-month minimum provides flexibility</li>
        <li>Mental health coverage with annual limits</li>
        <li>Medical evacuation included</li>
        <li>Monthly payment options</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions may have annual limits</li>
        <li>Network may be smaller in some countries</li>
        <li>Some rural areas may require reimbursement claims</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers affordable international coverage suitable for budget-conscious expats and digital nomads in South America. Their flexible terms and moderate pricing align with the continent's generally lower cost of living.</p>

      <h3>Strengths for South America Expats</h3>
      <ul>
        <li>Most affordable option for the region</li>
        <li>Flexible terms for nomadic lifestyles</li>
        <li>Good hospitalization coverage</li>
        <li>Medical evacuation included</li>
        <li>Easy enrollment process</li>
        <li>Suitable for lower-cost South American destinations</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health coverage</li>
        <li>Outpatient coverage varies by plan</li>
        <li>Smaller provider network—more reimbursement claims</li>
        <li>Pre-existing conditions excluded</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Key considerations for South America include tropical disease coverage, medical evacuation capability (healthcare quality varies), and access to private hospitals that bypass public system limitations.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>South America generally offers lower healthcare costs than North America or Europe. However, quality varies significantly—premium private hospitals in São Paulo or Santiago provide world-class care, while rural areas may have limited facilities.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates excluding US/Canada coverage and vary by specific country, age, health history, and coverage level. Adding US coverage significantly increases premiums.</p>
    </section>

    <section id="south-america-considerations" class="mb-12">
      <h2>South America Considerations</h2>

      <h3>Healthcare Quality Variation</h3>
      <p>Healthcare quality varies dramatically across South America. Brazil's private hospitals in São Paulo rival anywhere globally; rural Bolivia has minimal facilities. Chile and Argentina have excellent private healthcare; Ecuador and Peru are more variable. Choose insurance that provides access to the best care in your location.</p>

      <h3>Medical Evacuation</h3>
      <p>Given healthcare variation, medical evacuation coverage is important. Serious conditions may require evacuation to better-equipped cities or even to the US or Europe. All three providers include evacuation, but premium providers may have stronger logistics.</p>

      <h3>Tropical Diseases</h3>
      <p>Dengue fever, Zika, malaria (in some regions), and other tropical diseases are present in South America. All three providers cover tropical disease treatment. Consider preventive measures and verify coverage includes these regional health risks.</p>

      <h3>Country-Specific Considerations</h3>
      <p>Brazil has excellent private healthcare but can be expensive. Argentina faces economic volatility affecting healthcare access. Chile has the most developed system. Colombia is improving rapidly. Ecuador and Peru are popular with retirees due to lower costs. Research your specific country's healthcare landscape.</p>

      <h3>Language Barriers</h3>
      <p>Spanish dominates most of South America; Brazil speaks Portuguese. Navigating healthcare in another language adds complexity. Premium insurers offer Spanish/Portuguese support and can help arrange English-speaking providers in major cities.</p>

      <h3>Altitude Considerations</h3>
      <p>Many South American destinations—Bogotá, Quito, La Paz, Cusco—are at high altitude. Altitude sickness and related conditions may affect newcomers. Insurance should cover these health issues common to the region.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Executives in São Paulo or Santiago</li>
            <li>• Those prioritizing premium care</li>
            <li>• Expat families in major cities</li>
            <li>• Those needing mental health support</li>
            <li>• Long-term South America residents</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-career professionals abroad</li>
            <li>• Expats exploring multiple countries</li>
            <li>• Retirees in Ecuador or Colombia</li>
            <li>• Value-conscious expats</li>
            <li>• Those needing flexibility</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Digital nomads in South America</li>
            <li>• Budget-conscious travelers</li>
            <li>• Young expats building experience</li>
            <li>• Short-term stays</li>
            <li>• Lower-cost destinations</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is private healthcare in South America expensive?</h3>
          <p class="text-neutral-700">It varies by country. Brazil's top hospitals can be expensive. Chile and Argentina have moderate costs. Ecuador, Colombia, and Peru offer good private care at relatively low costs. International insurance provides predictable access regardless of local pricing.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do I need evacuation coverage in South America?</h3>
          <p class="text-neutral-700">Strongly recommended. While major cities have good hospitals, serious conditions may require evacuation to better-equipped facilities. Some rural areas have very limited healthcare. All three providers include evacuation coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I add US coverage to my South American plan?</h3>
          <p class="text-neutral-700">Only if you'll visit the US regularly. US coverage significantly increases premiums. Many South American expats exclude US coverage and purchase separate travel insurance for occasional US visits.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage in multiple South American countries?</h3>
          <p class="text-neutral-700">All three providers offer regional or worldwide coverage. If you're traveling between multiple South American countries, verify your coverage includes all your destinations. Regional plans typically cover the entire continent.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is tropical disease coverage included?</h3>
          <p class="text-neutral-700">Yes, all three providers cover treatment for tropical diseases including dengue fever, Zika, and malaria. Prevention (vaccines, prophylaxis) may have different coverage depending on your plan level.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How do I find English-speaking doctors in South America?</h3>
          <p class="text-neutral-700">Premium insurers can help arrange English-speaking providers. Major cities have international hospitals with multilingual staff. In smaller cities, you may need translation assistance—24/7 support lines can help navigate this.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
