---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Greece Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Greece's Digital Nomad Visa. Expert analysis of Cigna Global, SafetyWing, and Allianz Care for remote workers moving to Greece.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz-care", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "Greece Visa Acceptance", cigna: "✓ Widely accepted", safetywing: "✓ Accepted for DN visa", allianz: "✓ Widely accepted" },
  { feature: "Greek Hospital Network", cigna: "Good (direct billing)", safetywing: "Reimbursement model", allianz: "Good (direct billing)" },
  { feature: "Remote Work Flexibility", cigna: "Full global coverage", safetywing: "Built for nomads", allianz: "Full global coverage" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Acute onset only", allianz: "Moratorium option" },
  { feature: "Monthly Subscription", cigna: "Annual commitment", safetywing: "✓ Month-to-month", allianz: "Annual commitment" },
  { feature: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Full coverage" },
  { feature: "Annual Maximum", cigna: "€1M - Unlimited", safetywing: "$250,000", allianz: "€1M - Unlimited" },
  { feature: "Best For", cigna: "Premium nomads", safetywing: "Budget nomads", allianz: "Long-term settlers" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "100% covered", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited visits", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100,000", allianz: "Unlimited" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Emergency only", allianz: "100% covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", allianz: "Optional" },
  { coverage: "Wellness/Preventive", cigna: "Annual checkup", safetywing: "Not covered", allianz: "Annual checkup" },
  { coverage: "COVID-19", cigna: "Full coverage", safetywing: "Full coverage", allianz: "Full coverage" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "€150-240/month", safetywing: "$45-56/month", allianz: "€140-220/month" },
  { age: "30-35", cigna: "€180-280/month", safetywing: "$68-84/month", allianz: "€170-260/month" },
  { age: "35-40", cigna: "€220-340/month", safetywing: "$99-123/month", allianz: "€210-320/month" },
  { age: "40-45", cigna: "€280-420/month", safetywing: "$135-168/month", allianz: "€270-400/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { region: "Athens/Attica", cigna: "Strong - 15+ hospitals", safetywing: "Reimbursement model", allianz: "Strong - 15+ hospitals" },
  { region: "Thessaloniki", cigna: "Good - 8+ hospitals", safetywing: "Reimbursement model", allianz: "Good - 8+ hospitals" },
  { region: "Crete (Heraklion)", cigna: "Limited - 3+ facilities", safetywing: "Reimbursement model", allianz: "Limited - 3+ facilities" },
  { region: "Greek Islands", cigna: "Limited - evacuation may apply", safetywing: "Reimbursement + evacuation", allianz: "Limited - evacuation may apply" },
  { region: "Other Mainland", cigna: "Reimbursement available", safetywing: "Reimbursement model", allianz: "Reimbursement available" },
  { region: "Outside Greece", cigna: "Worldwide coverage", safetywing: "Worldwide coverage", allianz: "Worldwide coverage" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Greece's Digital Nomad Visa"
    heroImage="/images/countries/greece-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Greece Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Greece launched its Digital Nomad Visa in 2021, targeting remote workers who want to live in Greece while working for employers or clients outside the country. Health insurance is a mandatory requirement for visa approval.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Valid health insurance covering your entire stay in Greece</li>
          <li>• Coverage must include hospitalization and medical emergencies</li>
          <li>• Insurance from a recognized provider (EU or international)</li>
          <li>• Minimum coverage typically €30,000 (similar to Schengen requirements)</li>
          <li>• Must be valid from the visa start date</li>
          <li>• Travel insurance may be accepted for initial application</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Greece is more flexible than some EU countries regarding insurance requirements. While they require proof of coverage, they generally accept both travel insurance (for the initial visa) and comprehensive international health insurance. For renewals and longer stays, more comprehensive coverage is recommended.
      </p>

      <p class="text-neutral-700">
        The visa is issued for 12 months initially and can be renewed for up to 2 years. If you plan to stay long-term, transitioning from travel insurance to comprehensive coverage makes sense both for visa renewals and for your own protection.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Top 3 Insurers for Greece Digital Nomad Visa</h2>

      <p class="text-neutral-700 mb-6">
        We've analyzed options ranging from budget-friendly nomad insurance to premium international coverage. SafetyWing is designed specifically for digital nomads, while Cigna and Allianz offer more comprehensive long-term coverage.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides premium international health insurance with strong coverage in Greece and worldwide. Their modular plans work well for digital nomads who want comprehensive coverage and may travel frequently.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong network in Athens and major cities</li>
            <li>• Comprehensive coverage including mental health</li>
            <li>• Excellent worldwide coverage for travel</li>
            <li>• Modular plans—pay for what you need</li>
            <li>• Good pre-existing condition options</li>
            <li>• 24/7 multilingual support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Higher cost than nomad-specific options</li>
            <li>• Annual commitment required</li>
            <li>• Network limited on smaller islands</li>
            <li>• May be overkill for short-term stays</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Premium coverage for serious digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing is built specifically for digital nomads, with flexible monthly subscriptions and pricing that appeals to location-independent workers. Their Nomad Insurance product is popular with the remote work community.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable—starts under $50/month</li>
            <li>• Month-to-month subscription (no annual lock-in)</li>
            <li>• Designed for nomad lifestyle</li>
            <li>• Covers multiple countries including home visits</li>
            <li>• Easy online purchase and management</li>
            <li>• Accepted for Greece DN visa</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Lower coverage limits ($250K maximum)</li>
            <li>• Pre-existing conditions: acute onset only</li>
            <li>• No routine/preventive care</li>
            <li>• Mental health coverage limited</li>
            <li>• Reimbursement model (pay first)</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget-friendly insurance built for nomads."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers flexible international health insurance suitable for digital nomads planning longer stays in Greece. Their range of plan options balances comprehensive coverage with cost considerations.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Good Greek hospital network</li>
            <li>• Flexible plan tiers and deductibles</li>
            <li>• Strong wellness and preventive care</li>
            <li>• Chronic condition coverage</li>
            <li>• Brand recognition in Greece</li>
            <li>• Multiple deductible options</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Annual commitment required</li>
            <li>• Similar pricing to Cigna</li>
            <li>• Network limited on islands</li>
            <li>• Claims can take time to process</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="Flexible coverage for longer Greece stays."
        buttonText="Get Quote"
        buttonHref="/go/allianz-care"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        All three options meet Greece's Digital Nomad Visa requirements. Here's how their coverage compares:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing is designed for emergencies and basic care, not comprehensive health management. If you have ongoing health needs or want preventive care, Cigna or Allianz provide better coverage.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing's pricing is dramatically lower, but so is the coverage depth. These ranges represent typical costs:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing's low cost makes it attractive for healthy nomads on a budget. For those with health needs or wanting comprehensive coverage, the premium options justify their cost.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Greece</h2>

      <p class="text-neutral-700 mb-6">
        Greece has good healthcare in major cities but limited options on smaller islands. Here's what to expect:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        If you're island-hopping or settling on smaller islands, be prepared for reimbursement-based care and potential evacuation to Athens for serious issues. This applies regardless of insurer.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Developer Testing Greece</h3>
          <p class="text-neutral-600 mb-3">28-year-old developer, healthy, trying Greece for 3-6 months before deciding on longer stay.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">Best for testing the waters. Month-to-month flexibility, low cost. Upgrade to comprehensive coverage if you decide to stay longer.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Designer with Ongoing Therapy</h3>
          <p class="text-neutral-600 mb-3">32-year-old designer who sees a therapist regularly, planning 12+ months in Athens.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Best mental health coverage. Can continue therapy with network providers or via telehealth. Worth the premium for ongoing care needs.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Couple Moving to Crete</h3>
          <p class="text-neutral-600 mb-3">35-year-old couple, both work remotely, planning to settle in Chania for 2+ years.</p>
          <p class="text-amber-700 font-medium">Recommendation: Allianz Care</p>
          <p class="text-neutral-600 text-sm">Good balance of coverage and cost for a couple. Note that network is limited on Crete—may need to travel to Heraklion or Athens for specialists.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Budget-Conscious Nomad</h3>
          <p class="text-neutral-600 mb-3">26-year-old content creator, minimal income, island-hopping around Greece.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">Most affordable option that meets visa requirements. Covers emergencies and hospital stays—the critical risks for island life.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Established Professional in Athens</h3>
          <p class="text-neutral-600 mb-3">40-year-old consultant with managed high cholesterol, based in Athens with occasional EU travel.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Best chronic condition coverage. Strong Athens network. Good option for locking in coverage long-term as health needs may increase.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For budget-conscious nomads testing Greece short-term, <strong>SafetyWing</strong> offers unbeatable value with month-to-month flexibility. For those planning longer stays or with health needs, <strong>Cigna Global</strong> provides the most comprehensive coverage. <strong>Allianz Care</strong> is a solid middle ground for cost-conscious long-term settlers.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Budget is primary concern</li>
            <li>• Healthy, no ongoing care needs</li>
            <li>• Want month-to-month flexibility</li>
            <li>• Testing Greece short-term</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Need mental health coverage</li>
            <li>• Have chronic conditions</li>
            <li>• Want premium service</li>
            <li>• Planning long-term stay</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want comprehensive at good value</li>
            <li>• Planning 1-2 year stay</li>
            <li>• Prefer flexible deductibles</li>
            <li>• Like wellness benefits</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use SafetyWing for the Greece Digital Nomad Visa?</h3>
          <p class="text-neutral-600">Yes. SafetyWing is accepted for the Greece DN visa application. However, for renewals and longer stays, Greek authorities may prefer seeing more comprehensive coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What income do I need for the Greece Digital Nomad Visa?</h3>
          <p class="text-neutral-600">You need to demonstrate monthly income of at least €3,500 from remote work for clients/employers outside Greece. This increases by 20% for a spouse and 15% per child.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about healthcare on Greek islands?</h3>
          <p class="text-neutral-600">Smaller islands have limited healthcare—often just a health center (Kentro Ygeias) for basic care. Serious issues require evacuation to larger islands or Athens. All insurers cover evacuation, but understand the logistics before settling on a remote island.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I access Greek public healthcare?</h3>
          <p class="text-neutral-600">Digital Nomad Visa holders don't have access to Greek public healthcare (ESY). Private insurance is your only option. However, private care in Greece is affordable by Western European standards.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Should I start with SafetyWing and upgrade later?</h3>
          <p class="text-neutral-600">This is a common approach. Start with SafetyWing for flexibility, then upgrade to Cigna or Allianz after 6-12 months if you decide Greece is your long-term base. Just note that comprehensive insurers require medical underwriting—apply while healthy.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What if I travel outside Greece frequently?</h3>
          <p class="text-neutral-600">All three options provide worldwide coverage (SafetyWing includes limited US; Cigna/Allianz can include US at extra cost). Your coverage travels with you regardless of where you're working that week.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Insurance requirements and coverage details change regularly. Verify current requirements with the Greek consulate and confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance advice.</p>
    </div>
  </PageShell>
</Layout>
