---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs AXA vs Allianz: Best International Health Insurance for Southeast Asia";
const description = "Compare Cigna Global, AXA Global Healthcare, and Allianz Care for expats in Southeast Asia. Coverage analysis for Thailand, Vietnam, Singapore, Indonesia, Malaysia, and the Philippines.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Southeast Asia Network', cigna: 'Excellent', axa: 'Excellent', allianz: 'Strong' },
  { feature: 'Singapore Coverage', cigna: 'Premium access', axa: 'Premium access', allianz: 'Good coverage' },
  { feature: 'Thailand Network', cigna: 'Extensive', axa: 'Extensive', allianz: 'Extensive' },
  { feature: 'Direct Billing', cigna: 'Widely available', axa: 'Widely available', allianz: 'Major hospitals' },
  { feature: 'Tropical Disease Coverage', cigna: 'Comprehensive', axa: 'Comprehensive', allianz: 'Comprehensive' },
  { feature: 'Regional Evacuation', cigna: 'To Singapore/Bangkok', axa: 'To Singapore/Bangkok', allianz: 'Included' },
  { feature: 'Starting Price', cigna: '$$$', axa: '$$$', allianz: '$$-$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Full coverage', axa: 'Full coverage', allianz: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', axa: 'Comprehensive', allianz: 'Optional/Included' },
  { coverage: 'Dengue/Tropical Diseases', cigna: 'Fully covered', axa: 'Fully covered', allianz: 'Fully covered' },
  { coverage: 'Mental Health', cigna: 'Comprehensive', axa: 'Good coverage', allianz: 'Good coverage' },
  { coverage: 'Maternity', cigna: '12-month wait', axa: '12-month wait', allianz: '12-month wait' },
  { coverage: 'Traditional Medicine', cigna: 'Limited', axa: 'Some coverage', allianz: 'Limited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Single, 35, Thailand', cigna: '$3,500-4,800/yr', axa: '$3,800-5,200/yr', allianz: '$3,000-4,200/yr' },
  { profile: 'Single, 35, Singapore', cigna: '$5,500-7,500/yr', axa: '$6,000-8,000/yr', allianz: '$5,000-6,800/yr' },
  { profile: 'Couple, 45, Vietnam', cigna: '$6,200-8,400/yr', axa: '$6,800-9,000/yr', allianz: '$5,600-7,600/yr' },
  { profile: 'Family of 4, Malaysia', cigna: '$12,000-16,000/yr', axa: '$13,000-17,000/yr', allianz: '$10,500-14,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'southeast-asia', text: 'Southeast Asia Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Thailand Insurance Guide', href: '/countries/thailand/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'AXA Global Review', href: '/providers/axa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most extensive hospital network across all Southeast Asian countries with excellent customer service and seamless direct billing at premium facilities.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-green-800 text-sm">You're based in Singapore or frequently travel there, and want premium coverage with strong wellness benefits and comprehensive outpatient care.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-purple-800 text-sm">You want solid coverage at a more competitive price point, especially if you're based in Thailand, Vietnam, or other lower-cost countries in the region.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Southeast Asia attracts expats with its affordability, lifestyle, and business opportunities. Healthcare quality varies dramatically—from world-class facilities in Singapore and Bangkok to basic care in rural areas. All three providers have strong regional presence, but their strengths differ by country.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global has one of the strongest networks in Southeast Asia, with deep relationships across the region's best hospitals. Their 24/7 customer service includes support in multiple Asian languages, and their claims process is well-established in the region.</p>

      <h3>Strengths for Southeast Asia</h3>
      <ul>
        <li>Extensive direct billing network across Thailand, Singapore, Malaysia, and Vietnam</li>
        <li>Strong relationships with Bumrungrad, Mount Elizabeth, and other premier hospitals</li>
        <li>24/7 customer service with regional language support</li>
        <li>Comprehensive tropical disease coverage including dengue, malaria, and more</li>
        <li>Seamless evacuation to Singapore or Bangkok when needed</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing, especially for Singapore-based coverage</li>
        <li>May be more than needed if you're in a lower-cost country</li>
        <li>Traditional/alternative medicine coverage is limited</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global has a particularly strong presence in Singapore and Hong Kong, with excellent coverage throughout Southeast Asia. Their wellness-focused approach and comprehensive outpatient coverage make them attractive for health-conscious expats.</p>

      <h3>Strengths for Southeast Asia</h3>
      <ul>
        <li>Exceptional coverage in Singapore with access to all major hospitals</li>
        <li>Strong wellness and preventive care benefits</li>
        <li>Comprehensive mental health coverage important for expat adjustment</li>
        <li>Good coverage for health screenings and check-ups</li>
        <li>Established regional offices for local support</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums among the three providers</li>
        <li>12-month minimum commitment</li>
        <li>Network depth varies in less developed countries</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care offers competitive pricing for Southeast Asia without significantly compromising coverage quality. Their strong presence in Thailand makes them particularly attractive for expats in Bangkok, Chiang Mai, or the islands.</p>

      <h3>Strengths for Southeast Asia</h3>
      <ul>
        <li>Most competitive pricing among the three providers</li>
        <li>Excellent network in Thailand and popular expat destinations</li>
        <li>Flexible plan options for different budget levels</li>
        <li>Good coverage for tropical diseases and regional health concerns</li>
        <li>Monthly payment options available</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Network may be smaller in Singapore compared to Cigna and AXA</li>
        <li>Direct billing less extensive in Indonesia and Philippines</li>
        <li>Some premium hospital partnerships may be limited</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>All three providers offer comprehensive coverage for Southeast Asia's unique health risks, including tropical diseases. Key differences emerge in mental health coverage, wellness benefits, and traditional medicine options.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Pricing varies significantly based on country of residence. Singapore is the most expensive market due to high local healthcare costs, while Thailand, Vietnam, and Indonesia are more affordable. All three providers offer deductible options to reduce premiums.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by exact coverage level, health history, and specific city of residence. Singapore premiums reflect the high cost of local healthcare.</p>
    </section>

    <section id="southeast-asia" class="mb-12">
      <h2>Southeast Asia Insurance Considerations</h2>

      <h3>Healthcare Quality Variation</h3>
      <p>Singapore has world-class healthcare rivaling any Western country, but at corresponding prices. Thailand offers excellent private hospitals at lower costs. Vietnam, Indonesia, and the Philippines have quality private facilities in major cities, but care quality drops significantly in rural areas. Ensure your insurance includes evacuation coverage.</p>

      <h3>Tropical Disease Exposure</h3>
      <p>Dengue fever, malaria (in some areas), typhoid, and other tropical diseases are real risks in Southeast Asia. All three providers cover these conditions fully, but verify coverage for any travel to higher-risk areas within the region.</p>

      <h3>Air Quality Concerns</h3>
      <p>Air pollution in cities like Bangkok, Jakarta, and Hanoi can cause or exacerbate respiratory conditions. Comprehensive outpatient coverage ensures access to specialists for pollution-related health issues.</p>

      <h3>Traditional Medicine</h3>
      <p>Traditional Chinese medicine, Ayurveda, and local healing practices are popular throughout Southeast Asia. Coverage for alternative treatments is limited across all three providers—expect to pay out of pocket for these services.</p>

      <h3>Visa and Immigration Requirements</h3>
      <p>Thailand's retirement visa, Malaysia's MM2H, and similar programs may have specific insurance requirements. All three providers typically meet or exceed these minimums, but verify with immigration authorities before applying.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Expats traveling across multiple SEA countries</li>
            <li>• Those prioritizing hospital network breadth</li>
            <li>• Business travelers needing seamless claims</li>
            <li>• Families wanting comprehensive coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Singapore-based expats</li>
            <li>• Health-conscious individuals wanting wellness</li>
            <li>• Those prioritizing mental health support</li>
            <li>• Corporate executives and families</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Thailand-based retirees and expats</li>
            <li>• Budget-conscious professionals</li>
            <li>• Digital nomads in lower-cost countries</li>
            <li>• Those wanting flexible payment options</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Which provider has the best hospital network in Thailand?</h3>
          <p class="text-neutral-700">All three have excellent networks in Thailand, with direct billing at major hospitals like Bumrungrad, Bangkok Hospital, and Samitivej. Cigna and Allianz have particularly strong Thai networks, while AXA's network is also comprehensive.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is dengue fever covered by these insurance plans?</h3>
          <p class="text-neutral-700">Yes, all three providers cover dengue fever and other tropical diseases as standard. Treatment, hospitalization, and follow-up care are all included in comprehensive plans.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get coverage if I split time between Singapore and Thailand?</h3>
          <p class="text-neutral-700">Yes, but premiums will be rated based on your primary country of residence. If Singapore is your main base, expect higher premiums. All three providers allow travel and temporary stays in other countries within your region.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do these plans cover evacuation to Singapore for major treatment?</h3>
          <p class="text-neutral-700">Yes, all three include medical evacuation. If appropriate care isn't available locally, you can be evacuated to Singapore's world-class hospitals. This is particularly valuable if you're based in less developed areas.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is traditional Chinese medicine or Thai massage covered?</h3>
          <p class="text-neutral-700">Coverage for traditional and alternative medicine is limited across all providers. Some plans may cover acupuncture or chiropractic care, but Thai massage and TCM are typically out of pocket unless prescribed for a specific medical condition.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Which is best for the Thailand retirement visa?</h3>
          <p class="text-neutral-700">All three meet Thailand's retirement visa insurance requirements. Allianz often offers the best value for Thailand-based retirees, while Cigna and AXA provide more extensive networks if you travel frequently.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
