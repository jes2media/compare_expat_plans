---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "cigna", title: "Cigna Global" },
  { id: "bupa", title: "Bupa Global" },
  { id: "allianz", title: "Allianz Partners" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "chronic-details", title: "Chronic Condition Coverage" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/providers/bupa-global", title: "Bupa Global Review" },
  { href: "/providers/allianz-partners", title: "Allianz Partners Review" },
  { href: "/guides/chronic-conditions-abroad", title: "Chronic Conditions Abroad" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "allianz", header: "Allianz Partners" },
];

const mainComparisonRows = [
  { feature: "Pre-existing Coverage", cigna: "Case-by-case", bupa: "Moratorium option", allianz: "Full underwriting" },
  { feature: "Diabetes Management", cigna: "Comprehensive", bupa: "Comprehensive", allianz: "Standard" },
  { feature: "Cardiac Conditions", cigna: "Full coverage", bupa: "Full coverage", allianz: "Full coverage" },
  { feature: "Ongoing Medications", cigna: "Unlimited", bupa: "Included", allianz: "Annual limits" },
  { feature: "Specialist Access", cigna: "Direct referral", bupa: "Direct referral", allianz: "GP referral needed" },
  { feature: "Disease Management Programs", cigna: "Included", bupa: "Available", allianz: "Limited" },
  { feature: "Telehealth Monitoring", cigna: "Advanced", bupa: "Available", allianz: "Basic" },
  { feature: "Home Healthcare", cigna: "Covered", bupa: "Covered", allianz: "Limited" },
  { feature: "Condition Exclusions", cigna: "Rare", bupa: "Temporary possible", allianz: "More common" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "allianz", header: "Allianz Partners" },
];

const pricingRows = [
  { profile: "40yo, managed diabetes", cigna: "$7,200–9,600/yr", bupa: "$6,400–8,400/yr", allianz: "May exclude condition" },
  { profile: "50yo, cardiac history", cigna: "$9,800–13,200/yr", bupa: "$8,600–11,400/yr", allianz: "May exclude condition" },
  { profile: "45yo, autoimmune condition", cigna: "$8,400–11,200/yr", bupa: "$7,400–9,800/yr", allianz: "Case-by-case" },
  { profile: "55yo, multiple conditions", cigna: "$12,600–16,800/yr", bupa: "$11,200–14,800/yr", allianz: "Often declined" },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz: Chronic Disease Coverage for Expats (2025)"
  description="Compare chronic disease management coverage from Cigna Global, Bupa Global, and Allianz Partners. Analysis of diabetes, cardiac, autoimmune, and ongoing condition coverage."
  headline="Cigna vs Bupa vs Allianz: Chronic Disease Coverage Compared"
  intro="Managing chronic conditions abroad requires insurance that covers ongoing treatment, medications, and specialist care—not just emergencies. Finding coverage with pre-existing conditions is challenging but not impossible. Here's how Cigna Global, Bupa Global, and Allianz Partners compare for expats with chronic health needs."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 font-semibold mb-2">Best for Chronic Conditions</p>
        <p class="text-neutral-700 text-sm">Most flexible underwriting for pre-existing conditions. Comprehensive disease management programs. Best option for complex health situations.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best Moratorium Option</p>
        <p class="text-neutral-700 text-sm">Moratorium underwriting provides pathway to coverage. Temporary exclusion becomes full coverage after 2 years. Good for manageable conditions.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Partners</h3>
        <p class="text-green-700 font-semibold mb-2">More Restrictive</p>
        <p class="text-neutral-700 text-sm">Stricter underwriting for chronic conditions. May exclude or decline coverage. Best for those with well-controlled, minor conditions only.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Chronic Condition Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Case-by-case review:</strong> Individual assessment rather than blanket exclusions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Disease management:</strong> Structured programs for diabetes, cardiac, and other conditions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Unlimited medications:</strong> No annual caps on prescription costs</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Specialist access:</strong> Direct referral to specialists without GP gatekeeping</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Telehealth monitoring:</strong> Remote monitoring options for chronic conditions</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global takes the most accommodating approach to chronic conditions. Rather than automatic exclusions or declines, they evaluate each application individually. Many people with well-managed diabetes, controlled hypertension, or stable cardiac conditions get full coverage.
    </p>
    <p class="text-neutral-700">
      Their disease management programs add real value. For diabetics, this means coordinated care, monitoring support, and specialist access. The programs help maintain health—reducing complications that cost everyone more in the long run.
    </p>
  </section>

  <!-- Bupa Global Section -->
  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Chronic Condition Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Moratorium underwriting:</strong> Excludes pre-existing for 2 years, then reviews</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Pathway to coverage:</strong> Conditions can become covered after exclusion period</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Comprehensive care:</strong> Full coverage once conditions are included</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Medication coverage:</strong> Ongoing prescriptions included</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Lower premiums:</strong> Often less expensive than Cigna</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Bupa Global's moratorium underwriting offers a practical pathway for people with chronic conditions. Instead of declining you, they exclude the specific condition for 2 years. If you don't need treatment during that period, the condition becomes covered—no questions asked.
    </p>
    <p class="text-neutral-700">
      This works well for stable, well-managed conditions. If your diabetes or hypertension hasn't required significant treatment changes in years, the 2-year moratorium is manageable. You're covered for everything else immediately, and the chronic condition eventually.
    </p>
  </section>

  <!-- Allianz Partners Section -->
  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Partners</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Chronic Condition Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Lower premiums:</strong> Most affordable option when accepted</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Minor conditions:</strong> May cover well-controlled, minor chronic issues</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Full coverage if accepted:</strong> Comprehensive once underwritten</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-600 mt-1">△</span>
          <span><strong>Stricter underwriting:</strong> More likely to exclude or decline</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-600 mt-1">△</span>
          <span><strong>Permanent exclusions:</strong> Excluded conditions may stay excluded</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Allianz Partners takes a more traditional underwriting approach. Significant chronic conditions often result in permanent exclusions or outright declines. They're looking for healthy applicants or those with minor, well-controlled issues.
    </p>
    <p class="text-neutral-700">
      If you have well-controlled hypertension managed with basic medication and no complications, Allianz might work. But moderate diabetes, cardiac history, or autoimmune conditions often face exclusions. Compare your specific situation with Cigna or Bupa's more flexible approaches.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Chronic Condition Coverage Quotes"
    description="Compare plans from Cigna, Bupa, and Allianz that may cover your chronic conditions."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Premiums for applicants with chronic conditions are higher than standard rates. These examples show typical pricing scenarios—your actual quote depends on specific conditions, medications, and health history.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Allianz may exclude conditions rather than cover at higher premium. Individual underwriting determines actual terms.
    </p>
  </section>

  <!-- Chronic Details Section -->
  <section id="chronic-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Understanding Chronic Condition Coverage</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Pre-existing vs New Conditions</h3>
        <p class="text-neutral-700 mb-3">
          Pre-existing conditions are those you have when applying for coverage. They require disclosure and underwriting. New conditions that develop after enrollment are covered like any other illness—no special underwriting applies.
        </p>
        <p class="text-neutral-700">
          This distinction matters: if you develop diabetes after being insured, it's fully covered regardless of which insurer you have. The challenge is getting coverage when you already have diabetes before applying.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Underwriting Approaches</h3>
        <p class="text-neutral-700 mb-3">
          Cigna's case-by-case review considers your overall health picture. Well-managed conditions with stable medications often get covered, sometimes with a loading (higher premium). They want to understand your condition, not just exclude it.
        </p>
        <p class="text-neutral-700">
          Bupa's moratorium option skips detailed medical questions. They accept you but exclude pre-existing conditions for 2 years. If you don't claim for those conditions during the moratorium, they become covered. This avoids permanent exclusions.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Common Chronic Conditions</h3>
        <p class="text-neutral-700 mb-3">
          Diabetes, hypertension, high cholesterol, asthma, and hypothyroidism are among the most common chronic conditions. All three insurers can often accommodate these when well-controlled. Cardiac history, autoimmune diseases, and cancer history face more scrutiny.
        </p>
        <p class="text-neutral-700">
          The key factor is "well-controlled." Stable medications, no recent hospitalizations, and regular monitoring indicate lower risk. Insurers are more willing to cover conditions that are managed effectively.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Medication Continuity</h3>
        <p class="text-neutral-700 mb-3">
          Chronic conditions require ongoing medications. Cigna's unlimited medication coverage means you don't worry about hitting caps. Bupa covers medications comprehensively. Allianz may have annual limits that could affect expensive specialty medications.
        </p>
        <p class="text-neutral-700">
          Medication availability varies by country. Your insurer can help source medications or find equivalents. For rare medications, mail-order from home country or medical hubs like Singapore may be necessary.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You have significant chronic conditions</li>
          <li>• You want conditions potentially covered immediately</li>
          <li>• Disease management programs matter</li>
          <li>• Multiple conditions need coverage</li>
          <li>• You have complex health needs</li>
          <li>• Unlimited medications is important</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose Bupa If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• Your condition is stable and well-managed</li>
          <li>• You can wait 2 years for full coverage</li>
          <li>• Lower premiums are important</li>
          <li>• You want guaranteed acceptance</li>
          <li>• Condition hasn't required recent treatment</li>
          <li>• Moratorium pathway appeals to you</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Allianz If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You have minor, well-controlled conditions</li>
          <li>• Budget is the primary concern</li>
          <li>• You accept possible exclusions</li>
          <li>• Conditions are truly minor</li>
          <li>• You're healthy overall</li>
          <li>• Lower cost outweighs coverage limits</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What happens if I don't disclose a pre-existing condition?</h3>
        <p class="text-neutral-700">
          Non-disclosure is a serious issue. If discovered, the insurer can void your policy or deny claims—even for unrelated conditions. Always disclose everything honestly. Better to face potential exclusions than risk having claims denied later.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How does the moratorium option actually work?</h3>
        <p class="text-neutral-700">
          With Bupa's moratorium, you're accepted without medical questions. Pre-existing conditions are excluded for 2 years. If you don't receive treatment, advice, or medication for that condition during the 2 years, it becomes covered. If you do need treatment, the exclusion continues.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can excluded conditions ever become covered?</h3>
        <p class="text-neutral-700">
          With Bupa's moratorium, yes—after 2 years without treatment. With Cigna, you can request review of exclusions after a period of stability. Allianz exclusions tend to be permanent. Each renewal is an opportunity to discuss changes in your health status.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if my condition worsens after enrollment?</h3>
        <p class="text-neutral-700">
          Once covered, worsening is covered. If you're covered for diabetes and develop diabetic complications, those complications are covered. The pre-existing rules apply at enrollment—not to the natural progression of covered conditions.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I find specialists for my condition abroad?</h3>
        <p class="text-neutral-700">
          Your insurer's provider directory lists specialists by condition and location. Major cities worldwide have specialists for common chronic conditions. For rare conditions, Singapore, Bangkok, or European hubs often have expertise. Telehealth can supplement local care.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Will my premiums increase if I use the coverage heavily?</h3>
        <p class="text-neutral-700">
          International insurers don't typically raise individual premiums based on claims. Premiums increase with age and general market adjustments, but not because you personally used the coverage. This differs from some local insurance markets.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage for pre-existing conditions depends on individual underwriting decisions. This comparison reflects general approaches—your specific situation may differ. Always disclose all health conditions accurately. Medication availability varies by country. This comparison reflects general plan features as of the publication date.
    </p>
  </aside>
</PageShell>
