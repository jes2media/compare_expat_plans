---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'msh', text: 'MSH International', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'humanitarian-needs', text: 'Humanitarian Work Needs', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/guides/international-health-insurance-101', text: 'Insurance 101' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/compare/cigna-vs-aetna-vs-allianz-diplomats', text: 'Diplomat Insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'msh', header: 'MSH International' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'NGO/Humanitarian Focus', cigna: 'General expat', msh: 'Specialized', img: 'Moderate' },
  { feature: 'High-Risk Country Coverage', cigna: 'Most countries', msh: 'Excellent', img: 'Good' },
  { feature: 'War Zone Coverage', cigna: 'Limited', msh: 'Available', img: 'Limited' },
  { feature: 'Emergency Evacuation', cigna: 'Unlimited', msh: 'Unlimited', img: 'Up to $500K' },
  { feature: 'Security Evacuation', cigna: 'Up to $100K', msh: 'Up to $200K', img: 'Up to $100K' },
  { feature: 'Mental Health Coverage', cigna: 'Comprehensive', msh: 'Good', img: 'Basic to Good' },
  { feature: 'Short-Term Missions', cigna: '12-month min', msh: '1-month min', img: '5-day min' },
  { feature: 'Group Plans Available', cigna: 'Yes', msh: 'Yes (NGO focused)', img: 'Yes' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'msh', header: 'MSH International' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Individual (30, field worker)', cigna: '$280-400/mo', msh: '$220-320/mo', img: '$180-280/mo' },
  { profile: 'Short-term mission (3 mo)', cigna: 'N/A (12-mo min)', msh: '$250-350/mo', img: '$200-300/mo' },
  { profile: 'Family (2 adults + 1 child)', cigna: '$750-1,000/mo', msh: '$580-800/mo', img: '$480-680/mo' },
  { profile: 'NGO group rate (per person)', cigna: '$200-300/mo', msh: '$150-220/mo', img: '$140-200/mo' },
];
---

<PageShell
  title="Cigna vs MSH vs IMG for Humanitarian Workers | 2025 Comparison"
  description="Compare Cigna Global, MSH International, and IMG Global for NGO and humanitarian workers. Expert analysis of high-risk coverage, evacuation benefits, and field work needs."
  headline="Cigna vs MSH vs IMG: Best Insurance for Humanitarian Workers"
  subheadline="Complete comparison of three leading providers for NGO staff, aid workers, and humanitarian professionals in challenging environments."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Largest network and most comprehensive coverage for established NGO staff. Best mental health support and long-term career coverage.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">MSH International</h3>
        <p class="text-purple-700 mb-3">Best for Humanitarian Sector</p>
        <p class="text-neutral-700 text-sm mb-4">Purpose-built for NGOs with best high-risk country coverage, war zone options, and flexible short-term missions.</p>
        <a href="/get-quotes" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Get Quote</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">IMG Global</h3>
        <p class="text-green-700 mb-3">Best Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable option with flexible short-term coverage. Good for volunteers and mission trips.</p>
        <a href="/providers/img-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Largest Network</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Mental Health Focus</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Career Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most comprehensive long-term coverage for humanitarian professionals building careers in international development. With 1.5 million+ providers worldwide, you'll find quality care whether you're based in a major city or returning from a field assignment.</p>

    <p class="text-neutral-700 mb-4">Their mental health coverage is particularly valuable for aid workers facing trauma exposure, burnout, and the psychological demands of humanitarian work. Cigna includes telehealth mental health services accessible from anywhere with internet connectivity.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Humanitarian Workers</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Largest global provider network</li>
          <li>• Excellent mental health coverage</li>
          <li>• Comprehensive wellness programs</li>
          <li>• Strong chronic condition management</li>
          <li>• Reliable claims processing</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• 12-month minimum commitment</li>
          <li>• Higher premiums than MSH/IMG</li>
          <li>• Limited war zone coverage</li>
          <li>• Not designed for short missions</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="msh" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">MSH International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">NGO Specialist</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">High-Risk Expert</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Terms</span>
    </div>

    <p class="text-neutral-700 mb-4">MSH International (now part of Cigna but operating independently) was built specifically for the international development and humanitarian sector. They understand the unique needs of NGOs—from coverage in active conflict zones to flexible short-term mission insurance.</p>

    <p class="text-neutral-700 mb-4">Their group plans are designed for organizations of all sizes, from small grassroots NGOs to major international organizations. MSH offers specialized add-ons including war risk coverage, kidnap and ransom support, and security evacuation with higher limits than most competitors.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Humanitarian Workers</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Purpose-built for NGO sector</li>
          <li>• Best high-risk country coverage</li>
          <li>• War zone coverage available</li>
          <li>• Flexible short-term options (1+ months)</li>
          <li>• Excellent group plan pricing</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Smaller provider network than Cigna</li>
          <li>• Mental health coverage less comprehensive</li>
          <li>• Claims processing can be slower</li>
          <li>• Less brand recognition for individual plans</li>
        </ul>
      </div>
    </div>

    <a href="/get-quotes" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get MSH Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Short-Term Flexible</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Mission Trips</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers the most affordable option for humanitarian workers, particularly those on short-term missions or volunteers. Their plans start from just 5 days, making them ideal for mission trips, disaster response deployments, and project-based work.</p>

    <p class="text-neutral-700 mb-4">While not as specialized as MSH for high-risk environments, IMG provides solid coverage for most humanitarian contexts. Their online platform makes it easy to quickly purchase coverage before deploying, with digital ID cards available immediately.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for Humanitarian Workers</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable premiums</li>
          <li>• Ultra-flexible terms (5 days+)</li>
          <li>• Quick online enrollment</li>
          <li>• Good for volunteers and short missions</li>
          <li>• Solid evacuation coverage ($500K)</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited war zone coverage</li>
          <li>• Basic mental health benefits</li>
          <li>• Smaller direct billing network</li>
          <li>• Less suitable for long-term careers</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <CTABox
    title="Compare Humanitarian Coverage Quotes"
    description="Get personalized quotes from providers experienced in humanitarian and NGO coverage."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Humanitarian coverage pricing varies based on deployment location, duration, and risk level. These estimates are for comprehensive coverage:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*NGO group rates typically require minimum 3-5 enrolled members. High-risk country surcharges may apply.</p>
  </section>

  <section id="humanitarian-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Humanitarian Work Needs</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">High-Risk Location Coverage</h3>
        <p class="text-neutral-700 text-sm mb-4">Humanitarian work often requires deployment to challenging environments:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> Covers most countries, excludes active war zones</li>
          <li>• <strong>MSH:</strong> Best coverage including conflict areas with add-on</li>
          <li>• <strong>IMG:</strong> Good coverage, some high-risk exclusions</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Security & Evacuation</h3>
        <p class="text-neutral-700 text-sm mb-4">Essential protection when situations deteriorate:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> Medical evac unlimited, security $100K</li>
          <li>• <strong>MSH:</strong> Medical evac unlimited, security $200K</li>
          <li>• <strong>IMG:</strong> Combined evacuation up to $500K</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Mental Health Support</h3>
      <p class="text-blue-700 mb-4">Critical for workers facing trauma, burnout, and psychological stress:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">Comprehensive mental health with telehealth access. Includes PTSD treatment and critical incident debriefing.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">MSH</h4>
          <p class="text-blue-700 text-sm">Good mental health coverage with some telehealth options. Post-deployment counseling included.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">IMG</h4>
          <p class="text-blue-700 text-sm">Basic mental health benefits. Limited session counts on standard plans; upgrades available.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You're building a long-term career in international development</li>
          <li>• Mental health coverage and wellness support are priorities</li>
          <li>• You need the largest possible provider network</li>
          <li>• Your organization provides individual rather than group coverage</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose MSH International if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You work in high-risk or conflict-affected areas</li>
          <li>• Your NGO needs group coverage designed for the sector</li>
          <li>• You need flexible short-term mission coverage</li>
          <li>• War zone or security evacuation coverage is essential</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is your primary concern</li>
          <li>• You're volunteering or on a short-term mission</li>
          <li>• You need coverage starting from just 5 days</li>
          <li>• Quick online enrollment is important</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Does NGO insurance cover me as a volunteer?</h3>
        <p class="text-neutral-700">Yes, all three providers offer coverage for volunteers. IMG is particularly well-suited for volunteers with its flexible short-term plans. If you're volunteering with an established NGO, check if they provide group coverage first—this is often more comprehensive than individual volunteer insurance.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about coverage in active conflict zones?</h3>
        <p class="text-neutral-700">MSH is the best option for conflict zone coverage, offering war risk add-ons for an additional premium. Cigna and IMG typically exclude coverage for injuries resulting from war, civil unrest, or terrorism in designated conflict zones. Always verify specific country coverage before deploying.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does emergency evacuation work in remote areas?</h3>
        <p class="text-neutral-700">All three providers coordinate evacuations through specialized assistance companies. They'll arrange transport from remote locations to the nearest appropriate medical facility, potentially across borders if necessary. MSH and Cigna have the most experience with complex evacuations from challenging environments.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I switch between individual and group coverage?</h3>
        <p class="text-neutral-700">Yes, but timing matters. If your organization provides group coverage, you can maintain individual coverage as supplemental or transition fully. When leaving an NGO, you can often convert group coverage to individual plans without new underwriting if done within 30-60 days.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. High-risk location coverage and war zone exclusions vary significantly by provider and policy. Always verify specific country and situation coverage directly with providers before deploying. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
