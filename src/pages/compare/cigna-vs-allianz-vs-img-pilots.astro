---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Allianz vs IMG: Best International Health Insurance for Pilots & Aviation Professionals";
const description = "Compare Cigna Global, Allianz Care, and IMG Global for airline pilots, cabin crew, and aviation professionals. Coverage analysis for flight crew health needs and licensing requirements.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Global Coverage', cigna: 'Worldwide', allianz: 'Worldwide', img: 'Worldwide' },
  { feature: 'Cardiac Screening', cigna: 'Available', allianz: 'Available', img: 'Basic' },
  { feature: 'Mental Health', cigna: 'Excellent', allianz: 'Good', img: 'Limited' },
  { feature: 'Vision/Hearing', cigna: 'Optional add-on', allianz: 'Optional add-on', img: 'Emergency only' },
  { feature: 'Medical Certificate Support', cigna: 'Comprehensive', allianz: 'Good', img: 'Basic' },
  { feature: 'Jet Lag/Fatigue Issues', cigna: 'Covered', allianz: 'Covered', img: 'Limited' },
  { feature: 'Starting Price', cigna: '$$$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', allianz: 'Comprehensive', img: 'Plan dependent' },
  { coverage: 'Mental Health', cigna: 'Excellent', allianz: 'Annual limits', img: 'Limited' },
  { coverage: 'Cardiac Care', cigna: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Vision Care', cigna: 'Optional', allianz: 'Optional', img: 'Emergency only' },
  { coverage: 'Hearing Care', cigna: 'Optional', allianz: 'Optional', img: 'Emergency only' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'First Officer, 32', cigna: '$3,800-5,200/yr', allianz: '$3,000-4,200/yr', img: '$1,800-2,500/yr' },
  { profile: 'Captain, 45', cigna: '$5,500-7,500/yr', allianz: '$4,500-6,000/yr', img: '$2,600-3,600/yr' },
  { profile: 'Senior Captain, 55', cigna: '$7,500-10,000/yr', allianz: '$6,000-8,200/yr', img: '$3,800-5,200/yr' },
  { profile: 'Pilot + family of 4', cigna: '$15,000-20,000/yr', allianz: '$12,000-16,000/yr', img: '$7,500-10,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'pilot-considerations', text: 'Aviation Professional Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Transportation Workers', href: '/insurance-for/transportation-workers' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want comprehensive coverage with excellent mental health support, cardiac screening, and the peace of mind that supports maintaining your medical certificate.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at more moderate pricing, with good cardiac and preventive care that helps maintain your flying fitness.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're a younger pilot building flight hours who needs basic international coverage at affordable pricing while establishing your aviation career.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Aviation professionals have unique health requirements: maintaining medical certificates demands excellent cardiac and overall health, irregular schedules affect wellbeing, and mental health is increasingly scrutinized. Insurance should support these professional health needs.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers comprehensive coverage well-suited to aviation professionals, with excellent mental health benefits and cardiac care that support maintaining the health standards required for medical certification.</p>

      <h3>Strengths for Aviation Professionals</h3>
      <ul>
        <li>Excellent mental health coverage—important given industry scrutiny</li>
        <li>Comprehensive cardiac screening and care</li>
        <li>Vision and hearing care available as add-ons</li>
        <li>Global network supporting crew based anywhere</li>
        <li>24/7 support matching irregular flight schedules</li>
        <li>Preventive care helping maintain medical certificate fitness</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>Annual commitment required</li>
        <li>Vision/hearing require add-on purchase</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid comprehensive coverage at more competitive pricing, offering good cardiac and preventive care that supports pilot fitness requirements without premium costs.</p>

      <h3>Strengths for Aviation Professionals</h3>
      <ul>
        <li>Competitive pricing compared to Cigna</li>
        <li>Good cardiac screening and care coverage</li>
        <li>Mental health coverage with annual session limits</li>
        <li>Vision and hearing available as add-ons</li>
        <li>Worldwide coverage for globally-based crew</li>
        <li>Flexible 6-month minimum for contract pilots</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions may have annual limits</li>
        <li>Some premium screenings may require pre-authorization</li>
        <li>Less comprehensive than Cigna's top-tier plans</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers affordable international coverage suitable for younger pilots building experience or cabin crew seeking basic protection. While coverage is less comprehensive, it provides essential protection at accessible pricing.</p>

      <h3>Strengths for Aviation Professionals</h3>
      <ul>
        <li>Most affordable option for aviation professionals</li>
        <li>Flexible terms for contract-based flying</li>
        <li>Good basic hospitalization coverage</li>
        <li>Worldwide coverage for global operations</li>
        <li>Easy enrollment without extensive underwriting</li>
        <li>Suitable for building flight hours phase</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health coverage—significant concern</li>
        <li>Vision and hearing emergency-only</li>
        <li>No cardiac screening programs</li>
        <li>Pre-existing conditions excluded</li>
        <li>May not adequately support medical certificate maintenance</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Key coverage areas for aviation professionals include cardiac care, mental health, and vision/hearing—all critical for maintaining medical certification and professional fitness to fly.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Pilot salaries vary dramatically—from modest regional airline pay to substantial major carrier compensation. Insurance investment should align with career stage and compensation level.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by age, health history, and coverage level. Many airlines provide health insurance—verify before purchasing individual coverage.</p>
    </section>

    <section id="pilot-considerations" class="mb-12">
      <h2>Aviation Professional Considerations</h2>

      <h3>Medical Certificate Requirements</h3>
      <p>Pilots must maintain medical certificates (Class 1/2/3) with regular examinations. Health conditions can affect certification. Good insurance ensures access to preventive care and treatment that maintains flying fitness. Cardiac health, mental health, and vision/hearing are particularly scrutinized.</p>

      <h3>Mental Health Sensitivity</h3>
      <p>Aviation's approach to mental health has evolved, but stigma remains. Pilots may hesitate to seek help fearing career implications. Confidential mental health coverage is valuable. Cigna's excellent coverage and Allianz's solid support provide access to care. IMG's limited coverage may be inadequate.</p>

      <h3>Cardiac Health</h3>
      <p>Cardiac events are career-ending for pilots. Regular screening catches issues early. ECGs, stress tests, and comprehensive cardiac care are important. Cigna and Allianz offer good cardiac coverage; IMG covers treatment but lacks screening programs.</p>

      <h3>Vision and Hearing</h3>
      <p>Pilots need excellent vision and hearing. Regular testing is required for medical certificates. Insurance covering routine vision/hearing care (add-ons for Cigna/Allianz) helps maintain these critical senses. IMG's emergency-only coverage doesn't address routine needs.</p>

      <h3>Jet Lag and Fatigue</h3>
      <p>Long-haul flying disrupts circadian rhythms and causes fatigue-related health issues. Sleep disorders, chronic fatigue, and related conditions need treatment. Comprehensive outpatient coverage addresses these occupational health concerns.</p>

      <h3>Airline-Provided Coverage</h3>
      <p>Many airlines provide health insurance, but coverage quality varies. Verify what your airline offers before purchasing individual coverage. Individual policies may supplement airline benefits or provide coverage during transitions between airlines.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Senior captains</li>
            <li>• Pilots prioritizing mental health</li>
            <li>• Those wanting cardiac screening</li>
            <li>• Pilot families</li>
            <li>• Long-haul international crew</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-career pilots</li>
            <li>• First officers</li>
            <li>• Contract pilots</li>
            <li>• Those seeking value coverage</li>
            <li>• Cabin crew</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Pilots building hours</li>
            <li>• Young flight crew</li>
            <li>• Regional airline crew</li>
            <li>• Budget-conscious aviators</li>
            <li>• Short-term contract flying</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do airlines typically provide health insurance for pilots?</h3>
          <p class="text-neutral-700">Major airlines usually provide health insurance, but coverage quality varies. Regional carriers and contract positions may offer less comprehensive benefits. Verify your airline's coverage before purchasing individual insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Will seeking mental health treatment affect my medical certificate?</h3>
          <p class="text-neutral-700">Aviation authorities are increasingly accepting of pilots seeking mental health support. Treatment for common conditions like mild anxiety or depression may be compatible with flying. Consult an aviation medical examiner about your specific situation.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is cardiac screening particularly important for pilots?</h3>
          <p class="text-neutral-700">Yes. Cardiac events are disqualifying for pilot medical certificates. Regular screening catches issues early when they may be treatable while maintaining certification. Cigna and Allianz offer cardiac screening; consider this investment seriously.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I add vision and hearing coverage?</h3>
          <p class="text-neutral-700">Strongly consider it. Vision and hearing are essential for flying and medical certification. Routine care helps maintain these senses. Add-on coverage from Cigna or Allianz is worthwhile for aviation professionals.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does insurance cover treatment for jet lag and fatigue issues?</h3>
          <p class="text-neutral-700">Comprehensive outpatient coverage (Cigna, Allianz) covers treatment for sleep disorders and fatigue-related conditions common among long-haul crew. IMG's limited outpatient coverage may not adequately address these occupational health issues.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage between airline jobs?</h3>
          <p class="text-neutral-700">Individual insurance provides continuity during career transitions. Allianz's 6-month minimum and IMG's flexible terms work well for contract pilots or those between positions. Coverage continues regardless of employment status.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
