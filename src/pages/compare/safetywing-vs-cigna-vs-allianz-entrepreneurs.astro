---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'entrepreneur-considerations', text: 'Entrepreneur Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'SafetyWing Full Review', href: '/providers/safetywing' },
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'Allianz Care Full Review', href: '/providers/allianz-care' },
  { title: 'Insurance for Entrepreneurs', href: '/insurance-for/entrepreneurs' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Startup-friendly', safetywing: 'Built for startups', cigna: 'Enterprise focus', allianz: 'Individual plans' },
  { feature: 'Monthly payments', safetywing: 'Yes—subscription', cigna: 'Monthly option', allianz: 'Monthly option' },
  { feature: 'Cash flow friendly', safetywing: 'Very—no annual commit', cigna: 'Less flexible', allianz: 'Moderate' },
  { feature: 'Team coverage', safetywing: 'Remote Health (teams)', cigna: 'Corporate plans', allianz: 'Group plans' },
  { feature: 'Visa compliance', safetywing: 'Most countries', cigna: 'Strong', allianz: 'Strong' },
  { feature: 'Coverage limits', safetywing: '$250,000', cigna: '$1M+', allianz: '$1M+' },
  { feature: 'Mental health', safetywing: 'Limited', cigna: 'Good', allianz: 'Good' },
  { feature: 'Maternity', safetywing: 'Limited', cigna: 'Full (waiting period)', allianz: 'Full (waiting period)' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { scenario: 'Founder, age 30', safetywing: '$50/mo ($600/yr)', cigna: '$250/mo ($3,000/yr)', allianz: '$220/mo ($2,640/yr)' },
  { scenario: 'Founder, age 40', safetywing: '$75/mo ($900/yr)', cigna: '$380/mo ($4,560/yr)', allianz: '$320/mo ($3,840/yr)' },
  { scenario: 'Team of 5 (avg age 32)', safetywing: '$250/mo ($3,000/yr)', cigna: 'Quote required', allianz: 'Quote required' },
  { scenario: 'With US coverage', safetywing: 'Limited (30 days/90)', cigna: '+40-50%', allianz: '+40-50%' },
  { scenario: 'Maternity add-on', safetywing: 'Not available', cigna: '+$2,000-4,000/yr', allianz: '+$1,800-3,500/yr' },
];
---

<PageShell
  title="SafetyWing vs Cigna vs Allianz: Best for Entrepreneurs 2025"
  description="Compare SafetyWing, Cigna, and Allianz for entrepreneurs abroad. Startup-friendly pricing, team coverage, cash flow flexibility, and founder protection."
  headline="SafetyWing vs Cigna vs Allianz: Entrepreneur Insurance"
  subheadline="Which insurer is best for founders and entrepreneurs abroad? Startup budgets, team coverage, and protection that scales with your business."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best for Early Stage</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">SafetyWing</p>
      <p class="text-sm text-neutral-600 mb-3">Built for startups with monthly subscription. Most affordable option. Cancel anytime—perfect for uncertain runway.</p>
      <a href="/providers/safetywing" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best for Funded Startups</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Comprehensive coverage for founders who can afford it. Best for post-funding entrepreneurs with families.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best Balance</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Allianz Care</p>
      <p class="text-sm text-neutral-600 mb-3">Good coverage at mid-range pricing. Strong visa compliance. Solid choice for established entrepreneurs.</p>
      <a href="/providers/allianz-care" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="safetywing">SafetyWing</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">SafetyWing was founded by entrepreneurs for entrepreneurs. Their subscription model with no annual commitment is perfect for founders managing uncertain cash flow. They also offer Remote Health for covering distributed teams.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Entrepreneur Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Monthly subscription—no annual commitment</li>
      <li>Most affordable option ($45-85/month)</li>
      <li>Cancel anytime—essential for uncertain runway</li>
      <li>Remote Health product for teams</li>
      <li>Founded by startup founders</li>
      <li>Simple, fast signup</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Lower coverage limit ($250,000)</li>
      <li>Limited US coverage (30 days/90)</li>
      <li>No maternity coverage</li>
      <li>Mental health very limited</li>
      <li>Not accepted for some visa types</li>
    </ul>
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global offers comprehensive coverage for entrepreneurs who've raised funding or have stable revenue. Their higher coverage limits and maternity options suit founders planning families or needing premium protection.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Entrepreneur Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Comprehensive coverage ($1M+ limits)</li>
      <li>Full maternity coverage available</li>
      <li>Good mental health benefits</li>
      <li>Corporate plans for growing teams</li>
      <li>Strong visa compliance</li>
      <li>Global network for mobile founders</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Expensive—5-6x SafetyWing cost</li>
      <li>Annual commitment typically required</li>
      <li>Corporate feel—not startup-focused</li>
      <li>Complex plan structures</li>
    </ul>
  </div>

  <h2 id="allianz">Allianz Care</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Allianz Care offers a middle ground for entrepreneurs—better coverage than SafetyWing at lower cost than Cigna. Good for established entrepreneurs who want comprehensive protection without enterprise pricing.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Entrepreneur Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Mid-range pricing with good coverage</li>
      <li>Monthly payment options available</li>
      <li>Maternity coverage with waiting period</li>
      <li>Good mental health coverage</li>
      <li>Strong visa compliance</li>
      <li>Group plans for small teams</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Not as startup-focused as SafetyWing</li>
      <li>Annual terms more common</li>
      <li>Less flexible than subscription model</li>
      <li>Network weaker outside Europe</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage for Your Entrepreneurial Journey"
    description="Compare plans that fit founder budgets. From bootstrapped to funded—insurance that scales with your business."
    buttonText="Compare Entrepreneur Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Monthly and annual costs for entrepreneurs. SafetyWing's subscription model offers dramatically lower upfront costs.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">SafetyWing is 3-5x cheaper than traditional insurers. The trade-off is lower coverage limits and fewer benefits. As your business grows, you may want to upgrade to more comprehensive coverage.</p>

  <h2 id="entrepreneur-considerations">Entrepreneur Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Cash Flow Management</h3>
      <p class="text-neutral-700">Startup cash flow is unpredictable. SafetyWing's monthly subscription with no annual commitment preserves cash. Cigna and Allianz typically require annual commitments or charge premiums for monthly payment. When runway is uncertain, flexibility matters more than comprehensive coverage.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Coverage as You Scale</h3>
      <p class="text-neutral-700">Many founders start with SafetyWing and upgrade as their business grows. Post-Series A, comprehensive coverage becomes affordable and worthwhile. Cigna and Allianz offer corporate plans for growing teams. Your insurance needs evolve with your company—don't overcommit early, but don't stay underinsured as you scale.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Team Coverage</h3>
      <p class="text-neutral-700">Building a remote team? SafetyWing's Remote Health covers distributed teams affordably. Cigna and Allianz offer group plans but at higher cost. Team coverage can be a recruiting advantage—especially for competitive talent markets. Consider insurance as part of your compensation package.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Visa and Residency Requirements</h3>
      <p class="text-neutral-700">Entrepreneur visas often require health insurance. Portugal's D2, Spain's entrepreneur visa, Germany's self-employment visa—all have requirements. Cigna and Allianz have strong visa compliance. SafetyWing works for most but may not be accepted everywhere. Verify requirements before choosing.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Founder Family Planning</h3>
      <p class="text-neutral-700">Planning to start a family while building your company? SafetyWing doesn't offer maternity. Cigna and Allianz have maternity coverage with waiting periods (10-12 months). If family planning is on your horizon, factor this into your choice—or plan to upgrade before conception.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose SafetyWing If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You're bootstrapped or early-stage</li>
        <li>Cash flow flexibility is essential</li>
        <li>You're young and healthy</li>
        <li>No US coverage needed</li>
        <li>No near-term family plans</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You've raised funding</li>
        <li>Comprehensive coverage matters</li>
        <li>You're planning a family</li>
        <li>Mental health support needed</li>
        <li>You have a growing team</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose Allianz If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You want balanced value</li>
        <li>European base</li>
        <li>Revenue stable but not huge</li>
        <li>Good coverage without premium cost</li>
        <li>Strong visa compliance needed</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Should I use personal or business funds for insurance?</h3>
      <p class="text-neutral-700">Most founders pay personally, especially early-stage. As your company formalizes, health insurance can become a company expense—often tax-advantaged. Consult your accountant about the best structure. Corporate-paid insurance may be taxable income in some jurisdictions.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I get an entrepreneur visa with SafetyWing?</h3>
      <p class="text-neutral-700">SafetyWing works for many entrepreneur visas but not all. Some countries require minimum coverage levels or specific documentation SafetyWing can't provide. Cigna and Allianz have stronger visa compliance. Verify your specific visa requirements—the wrong insurance can delay or derail your application.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What if my startup fails—can I cancel insurance easily?</h3>
      <p class="text-neutral-700">SafetyWing allows cancellation anytime—month-to-month flexibility. Cigna and Allianz typically have annual terms, though you can sometimes exit with penalties. If startup failure is a real risk (it always is), SafetyWing's flexibility provides valuable optionality.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Should I insure my co-founders and early team?</h3>
      <p class="text-neutral-700">Insurance can be a recruiting and retention tool. SafetyWing's Remote Health makes team coverage affordable. As you grow, comprehensive corporate coverage becomes expected. Early-stage, it's often a founder decision whether to provide coverage or let team members self-insure.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">When should I upgrade from SafetyWing to comprehensive coverage?</h3>
      <p class="text-neutral-700">Common triggers: raising significant funding, starting a family, developing health conditions that make $250K limits inadequate, or needing visa-compliant coverage SafetyWing can't provide. Many founders upgrade post-Series A when comprehensive coverage becomes affordable relative to company resources.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is founder burnout and mental health covered?</h3>
      <p class="text-neutral-700">SafetyWing has very limited mental health coverage. Cigna and Allianz offer good coverage including therapy sessions. Founder mental health is real—building companies is stressful. If you anticipate needing mental health support, choose Cigna or Allianz despite higher costs.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Entrepreneur insurance needs vary by business stage, location, and personal circumstances. Tax treatment of insurance premiums depends on business structure and jurisdiction. Visa requirements should be verified independently. Coverage options and pricing change regularly.
    </p>
  </div>
</PageShell>
