---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Allianz vs Cigna vs World Nomads: Best International Health Insurance for Adventure Travelers";
const description = "Compare Allianz Care, Cigna Global, and World Nomads for adventure travelers and outdoor enthusiasts. Coverage analysis for hiking, climbing, diving, extreme sports, and active expat lifestyles.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const mainComparisonRows = [
  { feature: 'Adventure Sports Coverage', allianz: 'Standard activities', cigna: 'Standard activities', worldnomads: 'Extensive list' },
  { feature: 'Extreme Sports', allianz: 'Requires verification', cigna: 'Requires verification', worldnomads: 'Many included' },
  { feature: 'Search & Rescue', allianz: 'Included', cigna: 'Included', worldnomads: 'Included' },
  { feature: 'Mountain Evacuation', allianz: 'Included', cigna: 'Included', worldnomads: 'Included' },
  { feature: 'Long-term Coverage', allianz: 'Yes, annual plans', cigna: 'Yes, annual plans', worldnomads: 'Trip-based' },
  { feature: 'Comprehensive Health', allianz: 'Full coverage', cigna: 'Full coverage', worldnomads: 'Travel-focused' },
  { feature: 'Starting Price', allianz: '$$-$$$', cigna: '$$$', worldnomads: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const coverageRows = [
  { coverage: 'Inpatient', allianz: 'Full coverage', cigna: 'Unlimited options', worldnomads: 'Up to policy limit' },
  { coverage: 'Outpatient', allianz: 'Comprehensive', cigna: 'Comprehensive', worldnomads: 'Emergency focused' },
  { coverage: 'Search & Rescue', allianz: 'Up to $25K+', cigna: 'Included', worldnomads: 'Up to $25K' },
  { coverage: 'Helicopter Evacuation', allianz: 'Included', cigna: 'Included', worldnomads: 'Included' },
  { coverage: 'Equipment Coverage', allianz: 'Not included', cigna: 'Not included', worldnomads: 'Optional' },
  { coverage: 'Trip Cancellation', allianz: 'Not standard', cigna: 'Not standard', worldnomads: 'Included' },
];

const activitiesColumns = [
  { key: 'activity', header: 'Activity' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const activitiesRows = [
  { activity: 'Hiking/Trekking', allianz: 'Covered', cigna: 'Covered', worldnomads: 'Covered' },
  { activity: 'Scuba Diving (certified)', allianz: 'Covered', cigna: 'Covered', worldnomads: 'Covered' },
  { activity: 'Rock Climbing', allianz: 'Check limits', cigna: 'Check limits', worldnomads: 'Covered' },
  { activity: 'Skydiving', allianz: 'May exclude', cigna: 'May exclude', worldnomads: 'Explorer plan' },
  { activity: 'Mountaineering (high altitude)', allianz: 'Verify limits', cigna: 'Verify limits', worldnomads: 'Some limitations' },
  { activity: 'Surfing', allianz: 'Covered', cigna: 'Covered', worldnomads: 'Covered' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const pricingRows = [
  { profile: 'Adventurer, 30, annual', allianz: '$2,800-4,000/yr', cigna: '$3,500-5,000/yr', worldnomads: 'Trip-based pricing' },
  { profile: '6-month trip, age 30', allianz: '$1,400-2,000', cigna: '$1,750-2,500', worldnomads: '$600-1,000' },
  { profile: '12-month trip, age 35', allianz: '$3,200-4,500/yr', cigna: '$4,000-5,500/yr', worldnomads: '$1,000-1,800' },
  { profile: 'Couple, adventure lifestyle', allianz: '$5,500-7,500/yr', cigna: '$7,000-9,500/yr', worldnomads: 'Per-trip pricing' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'world-nomads', text: 'World Nomads', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'activities', text: 'Activity Coverage', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'adventure-considerations', text: 'Adventure Travel Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Outdoor Enthusiasts', href: '/insurance-for/outdoor-enthusiasts' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'World Nomads Review', href: '/providers/worldnomads' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-blue-800 text-sm">You're an active expat who wants comprehensive annual health coverage with adventure activity protection, not just trip-based travel insurance.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-green-800 text-sm">You want premium comprehensive health insurance with strong adventure coverage, and prioritize seamless global access and extensive hospital networks.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose World Nomads If...</h3>
          <p class="text-purple-800 text-sm">You're taking adventure trips rather than living abroad, want the widest range of extreme sports covered, and need trip-based rather than annual coverage.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Adventure travelers need insurance that covers both their activities and their health. The key distinction: World Nomads is travel insurance designed for adventure trips, while Allianz and Cigna are comprehensive health insurance that happens to cover adventure activities. The right choice depends on whether you're taking trips or living an active lifestyle abroad.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides comprehensive international health insurance suitable for expats with active lifestyles. Their coverage includes standard adventure activities, search and rescue, and emergency evacuation—combined with full health coverage beyond just travel emergencies.</p>

      <h3>Strengths for Adventure Travelers</h3>
      <ul>
        <li>Comprehensive health coverage beyond just travel emergencies</li>
        <li>Standard adventure activities covered without surcharge</li>
        <li>Search and rescue coverage included</li>
        <li>Helicopter evacuation from remote locations</li>
        <li>Annual coverage for active expat lifestyles</li>
        <li>Competitive pricing compared to Cigna</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Extreme sports may require verification or exclusion</li>
        <li>No equipment coverage (adventure gear)</li>
        <li>Not designed specifically for adventure travel</li>
        <li>May need to confirm specific activities in advance</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers premium comprehensive health insurance with solid adventure activity coverage. Their extensive global network and high coverage limits provide peace of mind for active expats who want the best healthcare access alongside adventure protection.</p>

      <h3>Strengths for Adventure Travelers</h3>
      <ul>
        <li>Premium comprehensive health coverage worldwide</li>
        <li>Strong emergency evacuation including mountain rescue</li>
        <li>Excellent hospital networks for post-adventure treatment</li>
        <li>24/7 support for emergencies anywhere</li>
        <li>High coverage limits for serious injuries</li>
        <li>Annual coverage for permanent active lifestyle</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums among the three options</li>
        <li>Extreme sports coverage requires verification</li>
        <li>May be more than needed for occasional adventurers</li>
        <li>No adventure-specific benefits like gear coverage</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="world-nomads" class="mb-12">
      <h2>World Nomads</h2>
      <p>World Nomads is travel insurance specifically designed for adventure travelers. They cover the widest range of adventure activities and extreme sports, making them the go-to choice for dedicated adventurers. However, it's travel insurance, not comprehensive health coverage.</p>

      <h3>Strengths for Adventure Travelers</h3>
      <ul>
        <li>Most extensive adventure activity coverage available</li>
        <li>Extreme sports included on Explorer plan</li>
        <li>Optional adventure gear/equipment coverage</li>
        <li>Trip cancellation and interruption included</li>
        <li>Flexible trip-based pricing</li>
        <li>Popular among adventure travel community</li>
        <li>Can extend coverage while traveling</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Travel insurance, not comprehensive health insurance</li>
        <li>Not suitable for long-term expat living</li>
        <li>Emergency-focused, not routine care</li>
        <li>Pre-existing conditions excluded</li>
        <li>Coverage limits lower than comprehensive plans</li>
        <li>Trip-based—not annual coverage</li>
      </ul>

      <CTAButton href="/providers/worldnomads" variant="highlight" style="color: white !important;">Get World Nomads Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>The fundamental difference: Allianz and Cigna are comprehensive health insurance suitable for expat living. World Nomads is travel insurance for trips. Choose based on whether you're living abroad or taking adventure trips.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="activities" class="mb-12">
      <h2>Activity Coverage</h2>
      <p>Specific activity coverage varies by plan and sometimes by altitude, depth, or certification level. Always verify your intended activities before purchasing.</p>
      <ComparisonTable columns={activitiesColumns} rows={activitiesRows} />
      <p class="text-sm text-neutral-600 mt-4">Activity coverage may have specific conditions—altitude limits, certification requirements, or supervision requirements. Verify details for your planned activities.</p>
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>World Nomads appears cheaper because it's trip-based travel insurance rather than comprehensive annual health coverage. Compare appropriately—travel insurance for trips, health insurance for expat living.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">World Nomads pricing is per-trip and varies by destination and duration. Allianz and Cigna are annual comprehensive health insurance prices.</p>
    </section>

    <section id="adventure-considerations" class="mb-12">
      <h2>Adventure Travel Considerations</h2>

      <h3>Travel Insurance vs Health Insurance</h3>
      <p>This is the key distinction. World Nomads is travel insurance—great for trips, covers adventure activities extensively, but emergency-focused and trip-based. Allianz and Cigna are comprehensive health insurance—covers ongoing health needs, routine care, and happens to include adventure activities. If you're living abroad as an active expat, you need health insurance. If you're taking adventure trips, travel insurance may suffice.</p>

      <h3>Activity Verification</h3>
      <p>For extreme sports with Allianz and Cigna, verify coverage before participating. Some activities may be excluded, require professional guide supervision, or have altitude/depth limits. World Nomads lists covered activities explicitly—check their activity list.</p>

      <h3>Search and Rescue</h3>
      <p>Mountain rescue, wilderness search, and remote evacuation can cost tens of thousands of dollars. All three providers include search and rescue coverage, but limits vary. Verify coverage amounts for your intended activities and locations.</p>

      <h3>Altitude and Depth Limits</h3>
      <p>Mountaineering and diving often have coverage limits. Standard policies may cover trekking up to 4,000-5,000m but exclude technical mountaineering at extreme altitude. Scuba diving typically requires certification and may have depth limits. Verify specific limits.</p>

      <h3>Equipment Coverage</h3>
      <p>Adventure gear is expensive. World Nomads offers optional equipment coverage. Allianz and Cigna are health insurance and don't cover gear. Consider separate equipment insurance if you're carrying expensive adventure equipment.</p>

      <h3>Remote Location Access</h3>
      <p>Adventure often happens in remote locations. Ensure your insurer can coordinate evacuation from your intended destinations. All three providers have global assistance networks, but some locations are more challenging than others.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Active expats living abroad</li>
            <li>• Those wanting value for comprehensive coverage</li>
            <li>• Standard adventure activities (hiking, diving)</li>
            <li>• Long-term active lifestyle coverage</li>
            <li>• Families with outdoor interests</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Premium coverage seekers</li>
            <li>• Those wanting best hospital networks</li>
            <li>• Active professionals abroad</li>
            <li>• Adventure enthusiasts with families</li>
            <li>• Those prioritizing service quality</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">World Nomads Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Dedicated adventure travelers</li>
            <li>• Extreme sports enthusiasts</li>
            <li>• Trip-based travel needs</li>
            <li>• Those needing equipment coverage</li>
            <li>• Budget adventure trips</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What's the difference between travel insurance and health insurance for adventurers?</h3>
          <p class="text-neutral-700">Travel insurance (World Nomads) is trip-based, emergency-focused, and designed for travelers. Health insurance (Allianz, Cigna) is annual, comprehensive, and covers ongoing health needs. If you're living abroad, get health insurance. For trips, travel insurance may suffice.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does insurance cover mountain rescue and helicopter evacuation?</h3>
          <p class="text-neutral-700">Yes, all three providers include search and rescue and helicopter evacuation. Coverage limits vary—typically $25,000 or more. Mountain rescue costs can reach $50,000+, so verify your limits for high-risk activities.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are extreme sports like skydiving and bungee jumping covered?</h3>
          <p class="text-neutral-700">World Nomads covers many extreme sports on their Explorer plan—check their activity list. Allianz and Cigna may exclude extreme sports or require verification. Always confirm specific activities before relying on coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about scuba diving coverage?</h3>
          <p class="text-neutral-700">All three cover certified recreational scuba diving. Limits may apply—typically 30-40m depth for recreational diving. Technical diving, cave diving, or deep diving may be excluded or require additional coverage. Verify depth limits for your plans.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get coverage for mountaineering at high altitude?</h3>
          <p class="text-neutral-700">Standard policies typically cover trekking up to 4,000-5,000m. Technical mountaineering, extreme altitude (6,000m+), and expeditions may be excluded or require special coverage. Verify altitude limits and activity definitions for your plans.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should adventure expats get travel insurance or health insurance?</h3>
          <p class="text-neutral-700">If you're living abroad with an active lifestyle, get comprehensive health insurance (Allianz or Cigna) that covers adventure activities. Use travel insurance (World Nomads) for specific adventure trips if you have gaps or want extra extreme sports coverage.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
