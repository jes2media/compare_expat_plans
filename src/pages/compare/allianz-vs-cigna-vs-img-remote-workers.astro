---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'remote-considerations', text: 'Remote Worker Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Allianz Care Full Review', href: '/providers/allianz-care' },
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'IMG Global Full Review', href: '/providers/img-global' },
  { title: 'Insurance for Remote Workers', href: '/insurance-for/remote-workers' },
  { title: 'Best Remote Worker Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Remote work covered', allianz: 'Yes—standard', cigna: 'Yes—standard', img: 'Yes—standard' },
  { feature: 'Work injuries', allianz: 'Covered', cigna: 'Covered', img: 'Covered' },
  { feature: 'Coworking accidents', allianz: 'Covered', cigna: 'Covered', img: 'Covered' },
  { feature: 'RSI/ergonomic issues', allianz: 'Covered', cigna: 'Covered', img: 'Covered' },
  { feature: 'Mental health', allianz: 'Good', cigna: 'Good', img: 'Basic' },
  { feature: 'Visa compliance', allianz: 'Strong', cigna: 'Strong', img: 'Strong' },
  { feature: 'Location flexibility', allianz: 'Global', cigna: 'Global', img: 'Global' },
  { feature: 'US coverage', allianz: 'Add-on', cigna: 'Available', img: 'Full available' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { scenario: 'Age 30, excl. US', allianz: '$2,400-3,500/yr', cigna: '$2,800-4,000/yr', img: '$1,800-2,800/yr' },
  { scenario: 'Age 35, excl. US', allianz: '$3,000-4,200/yr', cigna: '$3,500-5,000/yr', img: '$2,200-3,500/yr' },
  { scenario: 'Age 40, excl. US', allianz: '$3,800-5,500/yr', cigna: '$4,500-6,500/yr', img: '$3,000-4,500/yr' },
  { scenario: 'With US coverage', allianz: '+40-50%', cigna: '+35-45%', img: '+30-40%' },
  { scenario: 'High deductible option', allianz: '-25-35%', cigna: '-25-35%', img: '-30-40%' },
];
---

<PageShell
  title="Allianz vs Cigna vs IMG: Best for Remote Workers 2025"
  description="Compare Allianz, Cigna, and IMG for remote workers abroad. Work injury coverage, coworking accidents, mental health, and location-flexible insurance."
  headline="Allianz vs Cigna vs IMG: Remote Worker Insurance"
  subheadline="Which insurer is best for remote workers abroad? Work injury coverage, mental health support, and insurance that works wherever you work."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Overall</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Strongest global network for mobile remote workers. Good mental health coverage. Best for those who move frequently.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">IMG Global</p>
      <p class="text-sm text-neutral-600 mb-3">Most affordable option for remote workers. Good coverage at lower cost. Best for budget-conscious professionals.</p>
      <a href="/providers/img-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best for Europe</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Allianz Care</p>
      <p class="text-sm text-neutral-600 mb-3">Strong European network. Good mental health coverage. Best for remote workers based primarily in Europe.</p>
      <a href="/providers/allianz-care" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="allianz">Allianz Care</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Allianz Care offers comprehensive coverage for remote workers with particularly strong European networks. Their good mental health coverage and visa compliance make them solid choice for remote professionals based in Europe.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Remote Worker Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Work-related injuries fully covered</li>
      <li>Coworking space accidents covered</li>
      <li>RSI and ergonomic injuries included</li>
      <li>Good mental health coverage</li>
      <li>Strong European network</li>
      <li>Digital nomad visa compliant</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Mid-range pricing</li>
      <li>US coverage costs extra</li>
      <li>Network weaker outside Europe</li>
      <li>Less competitive globally than Cigna</li>
    </ul>
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global offers the strongest worldwide network for remote workers who move frequently between countries. Their global coverage and good mental health benefits make them ideal for truly location-independent professionals.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Remote Worker Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Strongest global network</li>
      <li>Work injuries covered worldwide</li>
      <li>Good mental health coverage</li>
      <li>Seamless when changing countries</li>
      <li>Strong visa compliance globally</li>
      <li>US coverage available</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Higher premiums than IMG</li>
      <li>May be overkill for single-country workers</li>
      <li>Complex plan options</li>
      <li>Corporate feel</li>
    </ul>
  </div>

  <h2 id="img">IMG Global</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">IMG Global offers the most affordable coverage for remote workers without sacrificing essential protections. Their flexible plans and full US coverage options make them attractive for budget-conscious professionals, including American remote workers.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Remote Worker Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most affordable premiums</li>
      <li>Work injuries covered</li>
      <li>Full US coverage available</li>
      <li>Flexible deductible options</li>
      <li>Good visa compliance</li>
      <li>High deductible savings significant</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Mental health coverage basic</li>
      <li>Smaller global network</li>
      <li>Less premium service</li>
      <li>Direct billing more limited</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage for Your Remote Work Lifestyle"
    description="Compare plans designed for remote workers. Work injury protection, location flexibility, and coverage that travels with you."
    buttonText="Compare Remote Worker Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Annual premiums for remote workers. IMG offers the most affordable options; Cigna costs more but has the strongest network.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Remote worker premiums are standard international health insurance rates. US coverage adds significantly to all three. High deductibles can reduce premiums 25-40%.</p>

  <h2 id="remote-considerations">Remote Worker Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Work-Related Injuries</h3>
      <p class="text-neutral-700">Unlike some domestic policies, international health insurance covers injuries regardless of whether they're work-related. Slip at your home office? Covered. Injury at a coworking space? Covered. RSI from typing? Covered. You don't need separate workers' compensation as a remote worker—your health insurance handles everything.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Mental Health for Remote Workers</h3>
      <p class="text-neutral-700">Remote work can be isolating. Mental health support matters. Cigna and Allianz offer good mental health coverage including therapy sessions. IMG's mental health coverage is more basic. If you anticipate needing mental health support, prioritize Cigna or Allianz despite higher costs.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Digital Nomad Visa Compliance</h3>
      <p class="text-neutral-700">Portugal, Spain, Germany, Croatia, and many other countries offer digital nomad visas requiring health insurance. All three insurers meet requirements for most DNV applications. Verify specific minimum coverage amounts for your target country. Request official documentation for visa applications.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Location Independence</h3>
      <p class="text-neutral-700">Remote workers move. All three insurers provide coverage that travels with you—change countries without changing insurers. Cigna has the strongest global network for those who relocate frequently. Allianz excels in Europe. IMG offers good global coverage at lower cost. Consider your mobility patterns when choosing.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">US Remote Workers Abroad</h3>
      <p class="text-neutral-700">American remote workers face unique challenges—US healthcare is expensive, and you may visit home frequently. IMG offers the most affordable US coverage. Cigna provides full US options. Allianz can add US coverage but at significant cost. Factor US coverage needs into your decision.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose Allianz If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You're based in Europe</li>
        <li>Mental health coverage matters</li>
        <li>You want good balance</li>
        <li>European network is priority</li>
        <li>DNV in Europe planned</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You move frequently</li>
        <li>Global network matters</li>
        <li>Mental health is priority</li>
        <li>You work across regions</li>
        <li>Comprehensive coverage wanted</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose IMG If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is top priority</li>
        <li>You need US coverage</li>
        <li>Basic mental health is OK</li>
        <li>You're American abroad</li>
        <li>Value over premium service</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Do I need separate workers' compensation insurance?</h3>
      <p class="text-neutral-700">No—international health insurance covers all injuries, whether work-related or not. Unlike US domestic policies that distinguish between personal health insurance and workers' comp, international plans cover everything. RSI from typing, back pain from your home office setup, injuries at coworking spaces—all covered.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What if my employer offers insurance but I work remotely abroad?</h3>
      <p class="text-neutral-700">Many employer plans don't cover employees living abroad long-term. Verify with your HR department. If your employer plan doesn't cover international residence, you need personal international health insurance. Some employers will contribute to individual international coverage for remote workers.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I get a digital nomad visa with these plans?</h3>
      <p class="text-neutral-700">Yes—all three insurers provide documentation for digital nomad visa applications. Most DNVs require health insurance with minimum coverage amounts (often €30,000-50,000). Verify your target country's specific requirements. Request official insurance certificates in advance of visa applications.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about coverage when working from different countries?</h3>
      <p class="text-neutral-700">International health insurance covers you globally—you can work from Portugal one month and Thailand the next without changing your coverage. Your residence country determines your premium, but coverage extends worldwide. Notify your insurer when you change primary residence countries.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is ergonomic treatment for desk work covered?</h3>
      <p class="text-neutral-700">Yes—treatment for RSI, carpal tunnel, back pain, and other ergonomic issues is covered by all three insurers. This includes doctor visits, physical therapy, and related treatments. Preventive ergonomic consultations may not be covered unless you have a wellness plan add-on.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How do I handle healthcare taxes as a remote worker?</h3>
      <p class="text-neutral-700">Health insurance premiums may be tax-deductible depending on your tax residence and structure. US citizens abroad can often deduct premiums. European countries vary. If you're self-employed, premiums are typically a business expense. Consult a tax professional familiar with remote worker situations.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Remote worker insurance needs vary by employment status, locations, and tax situation. Visa requirements differ by country. This comparison provides general guidance—verify specific requirements for your circumstances. Coverage options and pricing change regularly.
    </p>
  </div>
</PageShell>
