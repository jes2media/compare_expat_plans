---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Allianz vs SafetyWing: Best International Health Insurance for Central America";
const description = "Compare Cigna Global, Allianz Care, and SafetyWing for expats in Central America. Coverage analysis for Costa Rica, Panama, Guatemala, Belize, Nicaragua, and Honduras.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mainComparisonRows = [
  { feature: 'Central America Network', cigna: 'Strong', allianz: 'Good', safetywing: 'Limited' },
  { feature: 'Costa Rica Coverage', cigna: 'Excellent', allianz: 'Strong', safetywing: 'Basic' },
  { feature: 'Panama Coverage', cigna: 'Excellent', allianz: 'Strong', safetywing: 'Basic' },
  { feature: 'US Evacuation', cigna: 'Included', allianz: 'Included', safetywing: 'Included' },
  { feature: 'Tropical Disease', cigna: 'Comprehensive', allianz: 'Comprehensive', safetywing: 'Covered' },
  { feature: 'Monthly Flexibility', cigna: 'Annual plans', allianz: '6-month min', safetywing: 'Monthly' },
  { feature: 'Starting Price', cigna: '$$$', allianz: '$$-$$$', safetywing: '$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Full coverage', allianz: 'Full coverage', safetywing: 'Up to $250K' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', allianz: 'Optional/Included', safetywing: 'Emergency only' },
  { coverage: 'Emergency Evacuation', cigna: 'To US/home country', allianz: 'Included', safetywing: 'Included' },
  { coverage: 'Mental Health', cigna: 'Comprehensive', allianz: 'Good coverage', safetywing: 'Limited' },
  { coverage: 'Maternity', cigna: '12-month wait', allianz: '12-month wait', safetywing: 'Limited' },
  { coverage: 'Adventure Activities', cigna: 'Standard covered', allianz: 'Standard covered', safetywing: 'Many included' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const pricingRows = [
  { profile: 'Single, 35, Costa Rica', cigna: '$3,200-4,400/yr', allianz: '$2,600-3,600/yr', safetywing: '$550-700/yr' },
  { profile: 'Single, 35, Panama', cigna: '$3,400-4,600/yr', allianz: '$2,800-3,800/yr', safetywing: '$550-700/yr' },
  { profile: 'Couple, 50, Guatemala', cigna: '$7,500-10,000/yr', allianz: '$6,200-8,400/yr', safetywing: '$1,400-1,800/yr' },
  { profile: 'Retiree, 65, Costa Rica', cigna: '$8,500-11,500/yr', allianz: '$7,200-9,800/yr', safetywing: 'Age limit applies' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'central-america', text: 'Central America Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Costa Rica Insurance Guide', href: '/countries/costa-rica/insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most comprehensive coverage with excellent hospital networks in Costa Rica and Panama, and you prioritize seamless access to quality care throughout the region.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at a more moderate price point, with good flexibility for the expat lifestyle common in Central America.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-purple-800 text-sm">You're a young digital nomad or budget-conscious expat who wants basic coverage with monthly flexibility while exploring the region.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Central America attracts diverse expats: retirees in Costa Rica and Panama, digital nomads throughout the region, and adventurers exploring Guatemala, Belize, and beyond. Healthcare quality varies dramatically—from excellent private hospitals in San José and Panama City to basic facilities in rural areas.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers the strongest coverage for Central America, with established networks in Costa Rica and Panama's best private hospitals. Their comprehensive benefits and US evacuation options provide peace of mind in a region where advanced care may require travel.</p>

      <h3>Strengths for Central America</h3>
      <ul>
        <li>Excellent networks at CIMA, Clínica Bíblica, and other premier hospitals</li>
        <li>Direct billing at major Costa Rica and Panama facilities</li>
        <li>Seamless US evacuation to Miami for complex cases</li>
        <li>Comprehensive tropical disease coverage</li>
        <li>24/7 multilingual support including Spanish</li>
        <li>Strong mental health coverage for expat adjustment</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>Annual commitment required</li>
        <li>May be more coverage than younger expats need</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid coverage at more moderate pricing, making them attractive for Central American expats who want comprehensive protection without Cigna's premium costs. Their flexibility works well for the region's diverse expat population.</p>

      <h3>Strengths for Central America</h3>
      <ul>
        <li>Competitive pricing compared to Cigna</li>
        <li>Good networks in Costa Rica and Panama</li>
        <li>6-month minimum allows seasonal flexibility</li>
        <li>Comprehensive tropical disease coverage</li>
        <li>Monthly payment options available</li>
        <li>Evacuation to US included for serious conditions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Network smaller than Cigna in some countries</li>
        <li>Direct billing less extensive in Guatemala, Honduras</li>
        <li>Mental health coverage may have session limits</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing has become popular among Central America's digital nomad community for its affordability and flexibility. Their subscription model works well for nomads moving between countries, though coverage is more limited than comprehensive alternatives.</p>

      <h3>Strengths for Central America</h3>
      <ul>
        <li>Most affordable option by far</li>
        <li>Monthly subscription—perfect for nomads</li>
        <li>No commitment—cancel or pause anytime</li>
        <li>Good adventure activity coverage</li>
        <li>Emergency evacuation included</li>
        <li>Popular in expat/nomad communities</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>$250K annual limit—concerning for serious illness</li>
        <li>Limited outpatient and mental health coverage</li>
        <li>No direct billing network—claims process required</li>
        <li>Age limits may exclude older retirees</li>
        <li>Pre-existing conditions excluded</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>The coverage gap between SafetyWing and comprehensive providers is significant. For emergency hospitalization and evacuation, all three work. For ongoing care, mental health, and outpatient services, Cigna and Allianz offer much more.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Central America is generally affordable for international insurers, though Costa Rica and Panama command slightly higher premiums due to better healthcare infrastructure. SafetyWing's pricing is dramatically lower but reflects limited coverage.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific country, age, health history, and coverage level. Retirees should note SafetyWing's age restrictions.</p>
    </section>

    <section id="central-america" class="mb-12">
      <h2>Central America Insurance Considerations</h2>

      <h3>Healthcare Quality Variation</h3>
      <p>Costa Rica and Panama have excellent private hospitals rivaling US facilities. Guatemala City and other capitals have good private care. Rural areas throughout the region have basic facilities only. Evacuation coverage is essential—all three providers include it.</p>

      <h3>Popular Retirement Destinations</h3>
      <p>Costa Rica and Panama are top retirement destinations. Retirees should prioritize comprehensive coverage from Cigna or Allianz. SafetyWing's age limits and coverage gaps make it unsuitable for most retirees.</p>

      <h3>Digital Nomad Hotspots</h3>
      <p>Guatemala (Antigua, Lake Atitlán), Costa Rica (various beach towns), and Panama (Panama City, Bocas del Toro) attract digital nomads. SafetyWing is popular in these communities, though those with health concerns should consider upgrading.</p>

      <h3>Adventure Activities</h3>
      <p>Central America offers surfing, hiking, zip-lining, and other adventure activities. SafetyWing covers many adventure sports by default. Cigna and Allianz cover standard activities but may require verification for extreme sports.</p>

      <h3>Tropical Health Risks</h3>
      <p>Dengue, Zika, chikungunya, and other mosquito-borne diseases exist throughout Central America. All three providers cover these conditions. Some rural areas have malaria risk—verify coverage if you'll be in those regions.</p>

      <h3>Visa and Residency</h3>
      <p>Costa Rica's pensionado visa and Panama's various residency programs may have insurance requirements. Cigna and Allianz typically meet these requirements easily. SafetyWing may require supplemental documentation.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Retirees in Costa Rica or Panama</li>
            <li>• Those with complex health needs</li>
            <li>• Expats wanting premium networks</li>
            <li>• Families relocating to the region</li>
            <li>• Those prioritizing mental health</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-budget expats seeking value</li>
            <li>• Working professionals abroad</li>
            <li>• Those wanting flexible terms</li>
            <li>• Couples without premium needs</li>
            <li>• Expats supplementing local options</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Young digital nomads</li>
            <li>• Budget-conscious travelers</li>
            <li>• Those moving frequently</li>
            <li>• Healthy adventurers</li>
            <li>• Short-term Central America stays</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Which provider is best for Costa Rica retirees?</h3>
          <p class="text-neutral-700">Cigna Global offers the best coverage for Costa Rica retirees, with excellent networks at CIMA, Clínica Bíblica, and Hospital Metropolitano. Allianz is a good alternative at lower cost. SafetyWing's age limits and coverage gaps make it unsuitable for most retirees.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get direct billing at Central American hospitals?</h3>
          <p class="text-neutral-700">Cigna and Allianz offer direct billing at major private hospitals in Costa Rica and Panama. Smaller countries and rural areas typically require upfront payment and claims. SafetyWing doesn't have a direct billing network—you'll always pay and claim.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does coverage include medical evacuation to the US?</h3>
          <p class="text-neutral-700">Yes, all three providers include evacuation to the US (typically Miami) when local care is insufficient. This is essential coverage for Central America given variable healthcare quality outside major cities.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is SafetyWing adequate for surfing and adventure sports?</h3>
          <p class="text-neutral-700">SafetyWing covers many adventure activities including surfing, hiking, and zip-lining. However, their limited outpatient coverage means ongoing treatment for injuries (physiotherapy, etc.) may not be covered. Verify specific activities before relying on coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Will my insurance meet Costa Rica visa requirements?</h3>
          <p class="text-neutral-700">Costa Rica's pensionado and rentista visas require health insurance. Cigna and Allianz policies typically meet requirements easily. SafetyWing may require additional documentation or not meet all visa requirements—verify with immigration before applying.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage for dengue and tropical diseases?</h3>
          <p class="text-neutral-700">All three providers fully cover tropical diseases including dengue, Zika, and chikungunya. Treatment, hospitalization, and follow-up care are included. This is standard coverage for international health insurance in tropical regions.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
