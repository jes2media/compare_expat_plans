---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'deductible-options', text: 'Deductible Options Compared', level: 2 },
  { id: 'savings', text: 'How Much Can You Save?', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'AXA Global Review', href: '/providers/axa-global' },
  { title: 'Premium Reduction Tips', href: '/guides/premium-reduction-tips' },
  { title: 'Deductible Guide', href: '/guides/deductibles-explained' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const mainComparisonRows = [
  { feature: 'Max Deductible', cigna: '$10,000', bupa: '$15,000', axa: '$10,000' },
  { feature: 'Deductible Options', cigna: '6 levels', bupa: '5 levels', axa: '4 levels' },
  { feature: 'Premium Savings', cigna: 'Up to 50%', bupa: 'Up to 55%', axa: 'Up to 45%' },
  { feature: 'Coverage After Deductible', cigna: 'Full', bupa: 'Full', axa: 'Full' },
  { feature: 'Deductible Applies To', cigna: 'Per year', bupa: 'Per year', axa: 'Per year' },
  { feature: 'Zero Deductible Option', cigna: 'Yes', bupa: 'Yes', axa: 'Yes' },
  { feature: 'Network Quality', cigna: 'Best', bupa: 'Excellent', axa: 'Good' },
  { feature: 'Best For', cigna: 'Best flexibility', bupa: 'Highest savings', axa: 'Value choice' },
];

const deductibleColumns = [
  { key: 'deductible', header: 'Deductible' },
  { key: 'cigna', header: 'Cigna Savings' },
  { key: 'bupa', header: 'Bupa Savings' },
  { key: 'axa', header: 'AXA Savings' },
];

const deductibleRows = [
  { deductible: '$0', cigna: 'Baseline', bupa: 'Baseline', axa: 'Baseline' },
  { deductible: '$500', cigna: '~10%', bupa: '~10%', axa: '~8%' },
  { deductible: '$1,000', cigna: '~15%', bupa: '~18%', axa: '~12%' },
  { deductible: '$2,500', cigna: '~25%', bupa: '~30%', axa: '~22%' },
  { deductible: '$5,000', cigna: '~35%', bupa: '~42%', axa: '~32%' },
  { deductible: '$10,000', cigna: '~50%', bupa: '~55%', axa: '~45%' },
];

const savingsColumns = [
  { key: 'profile', header: 'Profile (Age 40)' },
  { key: 'zero', header: '$0 Deductible' },
  { key: 'five', header: '$5,000 Deductible' },
  { key: 'savings', header: 'Annual Savings' },
];

const savingsRows = [
  { profile: 'Cigna Global', zero: '$6,000/yr', five: '$3,900/yr', savings: '$2,100' },
  { profile: 'Bupa Global', zero: '$6,500/yr', five: '$3,770/yr', savings: '$2,730' },
  { profile: 'AXA Global', zero: '$4,800/yr', five: '$3,260/yr', savings: '$1,540' },
];
---

<PageShell
  title="Cigna vs Bupa vs AXA: High Deductible Expat Insurance Compared 2026"
  description="Compare high-deductible options from Cigna, Bupa, and AXA. Save 35-55% on premiums with higher deductibles. Understand the trade-offs and find the right balance."
  headline="Cigna vs Bupa vs AXA: High Deductible Plans Compared"
  subheadline="Save thousands per year with higher deductibles. Here's how the three major insurers' high-deductible options compare—and when they make sense."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Most Flexible</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">6 deductible levels. Save up to 50%. Best network and app. Most options to customize.</p>
      <a href="/go/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Cigna Quote</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Highest Savings</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Up to $15K deductible. Save up to 55%. Biggest discount for taking more risk.</p>
      <a href="/go/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Bupa Quote</a>
    </div>
    <div class="bg-green-50 border-2 border-green-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Value Base</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">AXA Global</p>
      <p class="text-sm text-neutral-600 mb-3">Already cheaper baseline. High deductible adds more savings. Best total value.</p>
      <a href="/go/axa-global" class="inline-block w-full text-center bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get AXA Quote</a>
    </div>
  </div>

  <p>
    High deductible plans trade lower premiums for more out-of-pocket risk. All three insurers offer significant savings—35-55% off premiums—if you're willing to cover the first $5,000-10,000 of claims yourself. Smart for healthy people with emergency funds.
  </p>

  <h2 id="comparison-table">Side-by-Side Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="cigna-global">Cigna Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Most Options</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Best Network</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Up to 50% Savings</span>
  </div>

  <p>
    Cigna Global offers the most deductible options—6 levels from $0 to $10,000. This flexibility lets you fine-tune your premium vs. out-of-pocket balance. Combined with their best-in-class network, you get premium coverage with premium savings.
  </p>

  <p><strong>Deductible options:</strong> $0, $500, $1,000, $2,500, $5,000, $10,000</p>

  <p><strong>Strengths:</strong></p>
  <ul>
    <li>Most deductible options (6 levels)</li>
    <li>Save up to 50% with $10K deductible</li>
    <li>Best provider network worldwide</li>
    <li>Excellent app for tracking expenses toward deductible</li>
    <li>Unlimited coverage after deductible</li>
    <li>Per-year deductible (resets annually)</li>
  </ul>

  <p><strong>Weaknesses:</strong></p>
  <ul>
    <li>Higher base price than AXA</li>
    <li>Max deductible only $10K (Bupa goes to $15K)</li>
    <li>Still expensive even with high deductible</li>
  </ul>

  <p><strong>Best for:</strong> Those who want premium coverage with maximum flexibility. Healthy expats with emergency funds who want the best network but don't expect to use it often.</p>

  <div class="my-6">
    <a href="/go/cigna-global" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Cigna Quote</a>
    <a href="/providers/cigna-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="bupa-global">Bupa Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Highest Deductible</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">55% Savings</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Premium Service</span>
  </div>

  <p>
    Bupa Global offers the highest deductible option ($15,000) and the biggest potential savings (up to 55%). If you're confident in your health and have substantial emergency reserves, Bupa lets you take maximum risk for maximum premium savings.
  </p>

  <p><strong>Deductible options:</strong> $0, $1,000, $2,500, $5,000, $10,000, $15,000</p>

  <p><strong>Strengths:</strong></p>
  <ul>
    <li>Highest deductible available ($15K)</li>
    <li>Biggest savings potential (up to 55%)</li>
    <li>Excellent customer service</li>
    <li>Lifetime renewal guarantee</li>
    <li>Strong network globally</li>
    <li>Good for catastrophic coverage strategy</li>
  </ul>

  <p><strong>Weaknesses:</strong></p>
  <ul>
    <li>Highest base price</li>
    <li>Fewer mid-range deductible options</li>
    <li>$15K is a lot of risk to take on</li>
  </ul>

  <p><strong>Best for:</strong> High-net-worth expats who want catastrophic coverage only. Those with significant emergency funds who rarely use healthcare. Maximum premium savings seekers.</p>

  <div class="my-6">
    <a href="/go/bupa-global" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Bupa Quote</a>
    <a href="/providers/bupa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="axa-global">AXA Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Best Total Value</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Lower Base</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Solid Options</span>
  </div>

  <p>
    AXA Global starts with a lower base price than Cigna and Bupa. Adding a high deductible on top makes it the cheapest comprehensive option overall. Fewer deductible levels, but combined with their lower baseline, excellent total value.
  </p>

  <p><strong>Deductible options:</strong> $0, $1,000, $2,500, $5,000, $10,000</p>

  <p><strong>Strengths:</strong></p>
  <ul>
    <li>Lowest base price to start</li>
    <li>High deductible = cheapest total cost</li>
    <li>Good coverage quality</li>
    <li>Strong mental health benefits</li>
    <li>Save 45% with $10K deductible</li>
    <li>Best overall value for money</li>
  </ul>

  <p><strong>Weaknesses:</strong></p>
  <ul>
    <li>Fewer deductible options (4 levels)</li>
    <li>€3M coverage limit (vs unlimited)</li>
    <li>Smaller direct billing network</li>
    <li>Max deductible only $10K</li>
  </ul>

  <p><strong>Best for:</strong> Value-focused expats who want the lowest total cost. Those who don't need the absolute largest network. Budget-conscious with good emergency reserves.</p>

  <div class="my-6">
    <a href="/go/axa-global" class="inline-block bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get AXA Quote</a>
    <a href="/providers/axa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <CTABox
    title="Compare High Deductible Options"
    description="Get quotes at different deductible levels to see your potential savings."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
    variant="highlight"
  />

  <h2 id="deductible-options">Deductible Options Compared</h2>

  <p>
    Higher deductible = bigger premium discount. But the relationship isn't linear—the savings percentage varies by insurer.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={deductibleColumns} rows={deductibleRows} />
  </div>

  <p class="text-sm text-neutral-500">
    *Approximate savings percentages vs. zero deductible. Actual savings vary by age, location, and plan details.
  </p>

  <h2 id="savings">How Much Can You Actually Save?</h2>

  <p>
    Real numbers for a 40-year-old expat comparing $0 vs. $5,000 deductible:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={savingsColumns} rows={savingsRows} />
  </div>

  <h3>The Math: When High Deductibles Make Sense</h3>

  <p>Consider a $5,000 deductible that saves you $2,000/year in premiums:</p>

  <ul>
    <li><strong>If you have 0 claims:</strong> You save $2,000</li>
    <li><strong>If you have $2,500 in claims:</strong> You pay $2,500, but saved $2,000 → net cost $500</li>
    <li><strong>If you have $5,000+ in claims:</strong> You pay $5,000 max, but saved $2,000 → net cost $3,000</li>
    <li><strong>Break-even point:</strong> You need $2,000+ in claims to "lose" money vs. zero deductible</li>
  </ul>

  <p>
    If you go 2-3 years without significant claims, the premium savings easily cover one "bad year" where you hit your deductible.
  </p>

  <h3>Who Should Consider High Deductibles?</h3>

  <div class="bg-green-50 border border-green-200 rounded-lg p-5 my-4">
    <p class="font-semibold text-green-800 mb-2">Good candidates:</p>
    <ul class="text-green-700 space-y-1">
      <li>Young and healthy (low expected claims)</li>
      <li>Have $5-10K emergency fund available</li>
      <li>Comfortable with routine care out-of-pocket</li>
      <li>Want catastrophic coverage primarily</li>
      <li>Living in low-cost healthcare regions</li>
    </ul>
  </div>

  <div class="bg-red-50 border border-red-200 rounded-lg p-5 my-4">
    <p class="font-semibold text-red-800 mb-2">Not recommended for:</p>
    <ul class="text-red-700 space-y-1">
      <li>Chronic conditions requiring regular care</li>
      <li>Planning pregnancy (high expected costs)</li>
      <li>Limited emergency savings</li>
      <li>Living in expensive healthcare markets</li>
      <li>Older adults with higher healthcare utilization</li>
    </ul>
  </div>

  <h2 id="best-for">Which Is Best For You?</h2>

  <div class="space-y-4 my-8">
    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Cigna Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the most deductible options</li>
        <li>Value the best provider network</li>
        <li>Want flexibility to adjust deductible over time</li>
        <li>Prefer the best digital experience</li>
        <li>Can afford slightly higher premiums for better service</li>
        <li>Travel frequently and need global access</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Bupa Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want maximum deductible option ($15K)</li>
        <li>Are seeking the biggest premium savings</li>
        <li>Have substantial emergency reserves</li>
        <li>Want catastrophic-only coverage</li>
        <li>Value lifetime renewal guarantee</li>
        <li>Are a high-earner who rarely uses healthcare</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose AXA Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the lowest total cost</li>
        <li>Are value-focused</li>
        <li>Don't need unlimited coverage</li>
        <li>Can manage with a smaller network</li>
        <li>Want good mental health benefits</li>
        <li>Have moderate emergency reserves</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Does the deductible reset each year?</h3>
  <p>
    Yes. All three insurers use annual deductibles. If you have a $5,000 deductible and pay $3,000 toward it in Year 1, it resets to $5,000 in Year 2. You start fresh each policy year.
  </p>

  <h3>Can I change my deductible later?</h3>
  <p>
    Generally yes, at renewal. You can usually increase your deductible anytime. Decreasing it may require underwriting review. Check with your insurer about their specific rules.
  </p>

  <h3>Does the deductible apply to emergencies?</h3>
  <p>
    Yes. Your deductible applies to all covered claims, including emergencies. However, after you meet your deductible, the insurer covers everything—so a major emergency is still protected.
  </p>

  <h3>What about preventive care?</h3>
  <p>
    Typically counts toward your deductible. However, some plans offer certain preventive services before deductible. Check your specific plan's benefits summary.
  </p>

  <h3>Is high deductible the same as "catastrophic coverage"?</h3>
  <p>
    Similar concept. High deductible plans are sometimes called "catastrophic" because they primarily protect against major, expensive events rather than routine care. You're self-insuring for smaller claims.
  </p>

  <h3>Should I put my deductible savings into an emergency fund?</h3>
  <p>
    Yes. If you save $2,000/year with a $5,000 deductible, set that money aside. After 2-3 years, you'll have enough to cover your deductible comfortably if needed.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This comparison is for informational purposes only. Deductible options and savings vary by plan, age, and location. Get actual quotes to see your specific savings. We are not insurance brokers.
    </p>
  </div>
</PageShell>
