---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Allianz vs Cigna vs Bupa: Best International Health Insurance for Couples";
const description = "Compare Allianz Care, Cigna Global, and Bupa Global for expat couples without children. Coverage analysis for two-person policies, maternity planning, and couple-specific health needs.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
];

const mainComparisonRows = [
  { feature: 'Couples Pricing', allianz: 'Good value', cigna: 'Competitive', bupa: 'Premium' },
  { feature: 'Maternity Coverage', allianz: '12-month wait', cigna: '12-month wait', bupa: '12-month wait' },
  { feature: 'Mental Health', allianz: 'Good', cigna: 'Excellent', bupa: 'Unlimited' },
  { feature: 'Wellness Programs', allianz: 'Available', cigna: 'Good', bupa: 'Comprehensive' },
  { feature: 'Fertility Support', allianz: 'Limited', cigna: 'Available', bupa: 'Available' },
  { feature: 'Flexibility', allianz: '6-month min', cigna: 'Annual', bupa: 'Annual' },
  { feature: 'Starting Price', allianz: '$$', cigna: '$$$', bupa: '$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', allianz: 'Full coverage', cigna: 'Unlimited options', bupa: 'Full coverage' },
  { coverage: 'Outpatient', allianz: 'Comprehensive', cigna: 'Comprehensive', bupa: 'Comprehensive' },
  { coverage: 'Mental Health', allianz: 'Annual limits', cigna: 'Full coverage', bupa: 'Unlimited' },
  { coverage: 'Maternity', allianz: 'After 12 months', cigna: 'After 12 months', bupa: 'After 12 months' },
  { coverage: 'Preventive Care', allianz: 'Available', cigna: 'Included', bupa: 'Comprehensive' },
  { coverage: 'Fertility', allianz: 'Limited/None', cigna: 'Some coverage', bupa: 'Available' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
];

const pricingRows = [
  { profile: 'Couple, both 30, Europe', allianz: '$4,800-6,500/yr', cigna: '$6,500-8,800/yr', bupa: '$7,000-9,500/yr' },
  { profile: 'Couple, both 40, Asia', allianz: '$6,500-8,800/yr', cigna: '$8,500-11,500/yr', bupa: '$9,500-13,000/yr' },
  { profile: 'Couple, both 50, Americas', allianz: '$9,000-12,000/yr', cigna: '$12,000-16,000/yr', bupa: '$13,500-18,000/yr' },
  { profile: 'With maternity coverage', allianz: '+$2,000-4,000/yr', cigna: '+$2,500-5,000/yr', bupa: '+$3,000-5,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'couples-considerations', text: 'Couples Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Families', href: '/insurance-for/families' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-blue-800 text-sm">You want solid comprehensive coverage for both partners at the most competitive pricing, with flexibility that works for couples with varying work situations.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-green-800 text-sm">You want excellent comprehensive coverage with strong mental health support for both partners and good maternity/fertility options if planning a family.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-purple-800 text-sm">You want the most premium coverage with unlimited mental health, comprehensive wellness, and the best maternity/fertility support for family planning.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Couples without children have distinct insurance needs: efficient two-person policies, potential maternity planning, and coverage that works for both partners' health profiles. The right choice depends on your current needs and future plans, including family expansion.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care offers the best value for couples seeking solid comprehensive coverage without premium pricing. Their flexible terms work well for couples where one partner may have different employment arrangements.</p>

      <h3>Strengths for Couples</h3>
      <ul>
        <li>Most competitive pricing for couple coverage</li>
        <li>Good comprehensive coverage for both partners</li>
        <li>6-month minimum allows flexibility</li>
        <li>Monthly payment options for budgeting</li>
        <li>Maternity coverage available (12-month wait)</li>
        <li>Moratorium option for pre-existing conditions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions may have annual limits</li>
        <li>Fertility coverage limited or not included</li>
        <li>Wellness programs less comprehensive</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global provides excellent comprehensive coverage for couples with strong mental health benefits and good maternity/fertility options. Their global network serves couples living and working internationally.</p>

      <h3>Strengths for Couples</h3>
      <ul>
        <li>Excellent mental health coverage for both partners</li>
        <li>Good maternity coverage after 12-month wait</li>
        <li>Some fertility support available</li>
        <li>Strong global network</li>
        <li>Comprehensive preventive care</li>
        <li>24/7 support for both partners</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Higher pricing than Allianz</li>
        <li>Annual commitment required</li>
        <li>Fertility coverage may have limits</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global represents the premium tier for couples, with unlimited mental health coverage, comprehensive wellness programs, and the best maternity/fertility support. Ideal for couples prioritizing health and family planning.</p>

      <h3>Strengths for Couples</h3>
      <ul>
        <li>Unlimited mental health sessions for both partners</li>
        <li>Comprehensive wellness and preventive care</li>
        <li>Best maternity coverage options</li>
        <li>Fertility support available on premium plans</li>
        <li>Premium hospital networks globally</li>
        <li>Health screening programs for both partners</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums among the three</li>
        <li>Annual commitment required</li>
        <li>Premium positioning may exceed some couples' needs</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Key considerations for couples include maternity planning (all have 12-month waits), mental health support for both partners, and potential fertility coverage if planning a family.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Couple policies typically offer better value than two individual policies. Pricing varies by age, location, and coverage level. Maternity coverage adds significant cost but is essential if family planning.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates for two-person policies and vary by location, ages, health history, and coverage level. Maternity coverage requires 12-month waiting period across all providers.</p>
    </section>

    <section id="couples-considerations" class="mb-12">
      <h2>Couples Considerations</h2>

      <h3>Joint vs Individual Policies</h3>
      <p>Couple policies typically cost less than two individual policies and are easier to manage. If partners have very different health profiles or coverage needs, separate policies might sometimes make sense, but joint coverage usually offers better value.</p>

      <h3>Maternity Planning</h3>
      <p>All three providers have 12-month waiting periods for maternity coverage. If you're planning to start a family, add maternity coverage at least a year before trying to conceive. Waiting until pregnancy means no coverage for that pregnancy.</p>

      <h3>Fertility Support</h3>
      <p>If fertility treatment may be needed, Bupa offers the most comprehensive support, Cigna has some coverage, and Allianz is more limited. Fertility coverage typically has caps and specific conditions. Verify details if this matters to you.</p>

      <h3>Different Health Needs</h3>
      <p>Partners often have different health profiles and needs. Couple policies cover both partners equally. If one partner has pre-existing conditions, moratorium options (Allianz, Cigna) or underwriting (Bupa) apply to that partner's conditions.</p>

      <h3>Mental Health for Both</h3>
      <p>Relocation stress affects both partners. Access to mental health support for each person matters. Bupa's unlimited sessions mean both can access therapy freely. Cigna's excellent coverage also works well. Allianz's session limits are per person.</p>

      <h3>Career Flexibility</h3>
      <p>Couples often have different work arrangements—one employed, one freelance, or both in different situations. The policy needs to work regardless of employment status. All three providers offer individual and family plans that accommodate various arrangements.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Value-conscious couples</li>
            <li>• Couples with flexible arrangements</li>
            <li>• Those not planning pregnancy soon</li>
            <li>• Younger couples abroad</li>
            <li>• Couples supplementing other coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Couples planning families</li>
            <li>• Those prioritizing mental health</li>
            <li>• Professional couples abroad</li>
            <li>• Those wanting balanced coverage</li>
            <li>• Globally mobile couples</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Couples prioritizing wellness</li>
            <li>• Those needing fertility support</li>
            <li>• Premium coverage seekers</li>
            <li>• Couples with complex health needs</li>
            <li>• Executive couples abroad</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is a couple policy better than two individual policies?</h3>
          <p class="text-neutral-700">Usually yes. Couple policies typically cost less than two individual policies and are easier to manage. The exception might be if partners have very different coverage needs or one qualifies for employer coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">When should we add maternity coverage?</h3>
          <p class="text-neutral-700">At least 12 months before planning to conceive. All providers have 12-month waiting periods for maternity. Adding coverage after pregnancy means no coverage for that pregnancy. Plan ahead if family is in your future.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What if one partner has pre-existing conditions?</h3>
          <p class="text-neutral-700">Pre-existing conditions affect that partner's coverage. Allianz and Cigna offer moratorium options (conditions excluded initially, potentially covered after claim-free period). Bupa underwrites—conditions may be excluded or covered with terms.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is fertility treatment covered?</h3>
          <p class="text-neutral-700">Bupa offers the most comprehensive fertility support on premium plans. Cigna has some coverage available. Allianz is more limited. Fertility coverage typically has caps and specific conditions—verify details if this matters to you.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can we have different coverage levels for each partner?</h3>
          <p class="text-neutral-700">Standard couple policies provide the same coverage for both partners. If you need different coverage levels, you'd need separate individual policies, which usually costs more overall.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What happens if we have a child—does our policy convert?</h3>
          <p class="text-neutral-700">You can add children to couple policies, converting to a family plan. Newborns are typically covered from birth if added within 30-60 days. Contact your insurer when planning to expand your family.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
