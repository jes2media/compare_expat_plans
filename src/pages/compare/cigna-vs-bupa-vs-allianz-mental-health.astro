---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'mental-health-details', text: 'Mental Health Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/guides/mental-health-abroad', text: 'Mental Health Abroad Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Outpatient Therapy', cigna: 'Up to 30 sessions', bupa: 'Up to 25 sessions', allianz: 'Up to 20 sessions' },
  { feature: 'Inpatient Psychiatric', cigna: '60 days/year', bupa: '45 days/year', allianz: '30 days/year' },
  { feature: 'Psychologist Coverage', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Limited coverage' },
  { feature: 'Psychiatrist Coverage', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Full coverage' },
  { feature: 'Teletherapy', cigna: 'Included', bupa: 'Included', allianz: 'Included' },
  { feature: 'Waiting Period', cigna: '12 months', bupa: '12 months', allianz: '12-24 months' },
  { feature: 'Pre-existing Exclusion', cigna: '2 years symptom-free', bupa: '2 years moratorium', allianz: 'Often permanent' },
  { feature: 'Crisis Coverage', cigna: 'Immediate', bupa: 'Immediate', allianz: 'Immediate' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Base plan (no mental health)', cigna: '$280/mo', bupa: '$320/mo', allianz: '$220/mo' },
  { profile: 'With mental health coverage', cigna: '$350-420/mo', bupa: '$400-500/mo', allianz: '$280-350/mo' },
  { profile: 'Mental health add-on cost', cigna: '+$70-140/mo', bupa: '+$80-180/mo', allianz: '+$60-130/mo' },
  { profile: 'Individual session copay', cigna: '$0-50', bupa: '$0-50', allianz: '$20-60' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Mental Health Coverage | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for mental health coverage. Expert analysis of therapy sessions, psychiatric care, teletherapy, and crisis support for expats."
  headline="Cigna vs Bupa vs Allianz: Best Mental Health Coverage"
  subheadline="Complete comparison for expats prioritizing mental health support—covering therapy, psychiatry, teletherapy, and crisis care abroad."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Mental Health Overall</p>
        <p class="text-neutral-700 text-sm mb-4">Highest therapy limits (30 sessions), best inpatient days (60), and pathway to cover pre-existing conditions. Industry leader for mental health.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Provider Network</p>
        <p class="text-neutral-700 text-sm mb-4">Excellent therapist network and digital mental health tools. Strong support infrastructure with care coordination.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Basic mental health coverage at the lowest price. Adequate for those wanting some coverage without premium costs.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">30 Sessions</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">60 Inpatient Days</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Pre-existing Path</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most comprehensive mental health coverage in the international insurance market. Their 30 outpatient therapy sessions per year exceed competitors significantly—enough for weekly therapy for over half the year. For those managing anxiety, depression, or ongoing mental health needs, this matters.</p>

    <p class="text-neutral-700 mb-4">Inpatient psychiatric coverage at 60 days is industry-leading, important for severe depression, bipolar episodes, or crisis situations. Perhaps most importantly, Cigna has a pathway to eventually cover pre-existing mental health conditions: after 2 years symptom-free (no treatment), conditions can become covered.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Mental Health Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 30 outpatient therapy sessions</li>
          <li>• 60 days inpatient psychiatric</li>
          <li>• Pre-existing can become covered</li>
          <li>• Teletherapy fully supported</li>
          <li>• No separate mental health limit</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• 12-month waiting period</li>
          <li>• Higher premiums for coverage</li>
          <li>• Some regions limited providers</li>
          <li>• Prior auth may be needed</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Provider Network</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Digital Tools</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Care Coordination</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's mental health coverage stands out for its support infrastructure. Their therapist network is carefully vetted, and the Bupa app includes digital mental health tools—guided meditation, CBT resources, and mental wellness assessments. This ecosystem approach goes beyond just paying for sessions.</p>

    <p class="text-neutral-700 mb-4">Coverage includes 25 outpatient sessions and 45 inpatient days—solid limits for most needs. The moratorium approach to pre-existing conditions means after 2 years without treatment, conditions automatically become covered. Care coordinators help navigate mental health resources in unfamiliar countries.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Mental Health Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Vetted therapist network</li>
          <li>• Digital mental health tools</li>
          <li>• Care coordination support</li>
          <li>• 25 outpatient sessions</li>
          <li>• Moratorium for pre-existing</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Fewer sessions than Cigna</li>
          <li>• 45 days inpatient (vs 60)</li>
          <li>• Highest premiums</li>
          <li>• 12-month waiting period</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Option</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Basic Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Crisis Support</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers mental health coverage at the most affordable price point, but with meaningful limitations. Coverage includes 20 outpatient sessions and 30 inpatient days—adequate for minor issues or crisis support, but limiting for ongoing therapy needs.</p>

    <p class="text-neutral-700 mb-4">Pre-existing mental health conditions are often permanently excluded, making Allianz less suitable if you have a history of depression, anxiety, or other conditions. However, for those without prior mental health treatment who want basic coverage as a safety net, Allianz provides value.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Mental Health Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable option</li>
          <li>• 20 sessions often sufficient</li>
          <li>• Crisis coverage included</li>
          <li>• Teletherapy supported</li>
          <li>• Psychiatry fully covered</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lowest session limits (20)</li>
          <li>• 30 days inpatient only</li>
          <li>• Pre-existing often excluded</li>
          <li>• Longer waiting period (12-24 mo)</li>
          <li>• Session copays likely</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Mental Health Coverage Quotes"
    description="Get personalized quotes with mental health benefits from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Mental health coverage adds to premiums—here's what to expect:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Mental health may be included in comprehensive plans or offered as an add-on. Prices for individual coverage, age 35, Europe-based.</p>
  </section>

  <section id="mental-health-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Mental Health Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">What's Typically Covered</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Psychotherapy sessions</li>
          <li>• Psychiatrist consultations</li>
          <li>• Psychiatric medications</li>
          <li>• Inpatient psychiatric care</li>
          <li>• Crisis intervention</li>
          <li>• Teletherapy sessions</li>
          <li>• Psychological assessments</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Common Exclusions</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Pre-existing conditions (varies)</li>
          <li>• Substance abuse treatment</li>
          <li>• Couples/family therapy (usually)</li>
          <li>• Learning disabilities</li>
          <li>• Developmental disorders (often)</li>
          <li>• Non-evidence-based therapies</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Pre-existing Mental Health Conditions</h3>
      <p class="text-blue-700 mb-4">This is the crucial consideration—each insurer handles history differently:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">2-year moratorium: conditions become covered after 2 years symptom-free. Can also apply for underwritten coverage with potential exclusions or loadings.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">2-year moratorium standard. After 2 years without treatment, conditions automatically covered. Medical underwriting also available.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Allianz</h4>
          <p class="text-blue-700 text-sm">Often permanently excluded. Stricter approach to pre-existing mental health. Best for those without history seeking basic coverage.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Mental health coverage is a priority</li>
          <li>• You want the highest session limits</li>
          <li>• You have pre-existing conditions to eventually cover</li>
          <li>• Inpatient psychiatric coverage may be needed</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Provider network quality matters</li>
          <li>• You want digital mental health tools</li>
          <li>• Care coordination support is valuable</li>
          <li>• You prefer an integrated wellness approach</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is your main concern</li>
          <li>• No prior mental health history</li>
          <li>• Basic safety net coverage is sufficient</li>
          <li>• You're primarily seeking crisis coverage</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need to disclose my mental health history?</h3>
        <p class="text-neutral-700">Yes, absolutely. Failing to disclose treatment history can void your entire policy if discovered. Be honest on applications—insurers may offer coverage with exclusions or moratoriums, but undisclosed conditions mean no coverage when you need it most.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my home country therapist via teletherapy?</h3>
        <p class="text-neutral-700">Generally yes, if your plan covers teletherapy and the therapist is licensed. Some insurers require providers to be in their network; others reimburse any licensed professional. Confirm with your insurer, especially regarding cross-border licensing and reimbursement rates.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What counts as a "session" for coverage limits?</h3>
        <p class="text-neutral-700">Typically a 45-60 minute session with a licensed psychologist, psychiatrist, or in some cases clinical social worker. Some plans count psychiatric medication management visits as sessions; others don't. Check your policy for specific definitions.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is medication covered under mental health benefits?</h3>
        <p class="text-neutral-700">Psychiatric medications prescribed by a covered psychiatrist are typically included under your prescription drug benefits, not mental health limits. This means your therapy sessions and medications usually have separate limits—check your specific plan for details.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Mental health coverage varies significantly by plan level, region, and individual circumstances. Pre-existing condition policies are strictly enforced. Always verify current coverage, session limits, and exclusions directly with providers before purchasing. This comparison is for informational purposes only and does not constitute medical or insurance advice.</p>
  </div>
</PageShell>
