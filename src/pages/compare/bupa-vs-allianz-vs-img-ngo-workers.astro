---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Bupa vs Allianz vs IMG: Best International Health Insurance for NGO & Humanitarian Workers";
const description = "Compare Bupa Global, Allianz Care, and IMG Global for NGO staff, humanitarian workers, and development professionals. Coverage for remote postings, conflict-adjacent regions, and challenging environments.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Remote Location Coverage', bupa: 'Excellent', allianz: 'Good', img: 'Good' },
  { feature: 'Medical Evacuation', bupa: 'Comprehensive', allianz: 'Included', img: 'Included' },
  { feature: 'Mental Health Support', bupa: 'Excellent', allianz: 'Good', img: 'Limited' },
  { feature: 'Tropical Disease', bupa: 'Comprehensive', allianz: 'Comprehensive', img: 'Covered' },
  { feature: 'Security Evacuation', bupa: 'Not standard', allianz: 'Not standard', img: 'Not standard' },
  { feature: 'Contract Flexibility', bupa: 'Annual', allianz: '6-month min', img: 'Flexible' },
  { feature: 'Starting Price', bupa: '$$$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', bupa: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', bupa: 'Comprehensive', allianz: 'Comprehensive', img: 'Plan dependent' },
  { coverage: 'Mental Health', bupa: 'Unlimited sessions', allianz: 'Annual limits', img: 'Limited' },
  { coverage: 'Tropical/Endemic Disease', bupa: 'Full coverage', allianz: 'Full coverage', img: 'Covered' },
  { coverage: 'Preventive Care', bupa: 'Vaccinations included', allianz: 'Available', img: 'Basic' },
  { coverage: 'PTSD/Trauma Support', bupa: 'Covered', allianz: 'Covered', img: 'Limited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Aid worker, 30, Africa', bupa: '$3,500-4,800/yr', allianz: '$2,800-3,800/yr', img: '$1,600-2,200/yr' },
  { profile: 'Program manager, 38, Asia', bupa: '$4,500-6,000/yr', allianz: '$3,500-4,800/yr', img: '$2,000-2,800/yr' },
  { profile: 'Country director, 45', bupa: '$5,500-7,500/yr', allianz: '$4,500-6,000/yr', img: '$2,600-3,600/yr' },
  { profile: 'Family posting, hardship', bupa: '$14,000-19,000/yr', allianz: '$11,000-15,000/yr', img: '$6,500-9,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'ngo-considerations', text: 'NGO Worker Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Development Workers', href: '/insurance-for/development-workers' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most comprehensive coverage with excellent mental health support for trauma and stress, plus reliable evacuation from challenging locations.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at moderate cost, with good evacuation options and flexibility that works for contract-based humanitarian assignments.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're on a tight organizational budget or working with a smaller NGO that can't afford premium coverage, and need basic international protection.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>NGO and humanitarian workers face unique health challenges: remote postings with limited facilities, exposure to tropical diseases, high stress and potential trauma, and sometimes conflict-adjacent environments. Health insurance must address these realities while working within often-limited organizational budgets.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global offers the most comprehensive coverage for humanitarian workers, with excellent mental health benefits particularly valuable for trauma-exposed staff. Their global reach and evacuation capabilities serve well in challenging environments.</p>

      <h3>Strengths for NGO Workers</h3>
      <ul>
        <li>Unlimited mental health sessions—critical for trauma and stress</li>
        <li>Comprehensive medical evacuation from remote locations</li>
        <li>Full coverage for tropical and endemic diseases</li>
        <li>Preventive care including travel vaccinations</li>
        <li>24/7 support regardless of time zone or location</li>
        <li>PTSD and trauma counseling covered</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums—may strain NGO budgets</li>
        <li>Annual commitment less flexible for short-term missions</li>
        <li>Security evacuation not included (separate coverage needed)</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid comprehensive coverage at more moderate pricing, making them accessible for a wider range of NGOs. Their 6-month minimum allows flexibility for contract-based assignments common in humanitarian work.</p>

      <h3>Strengths for NGO Workers</h3>
      <ul>
        <li>More affordable than Bupa for budget-constrained organizations</li>
        <li>Good mental health coverage with annual session limits</li>
        <li>Reliable medical evacuation from remote postings</li>
        <li>Comprehensive tropical disease coverage</li>
        <li>6-month minimum allows assignment flexibility</li>
        <li>Monthly payment options help cash flow</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions may have annual limits</li>
        <li>May not match Bupa's evacuation capabilities in extreme locations</li>
        <li>Some premium hospital access requires pre-authorization</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers affordable international coverage suitable for smaller NGOs or volunteers with limited budgets. While coverage is less comprehensive, it provides essential protection for humanitarian workers in the field.</p>

      <h3>Strengths for NGO Workers</h3>
      <ul>
        <li>Most affordable option for budget-constrained organizations</li>
        <li>Flexible terms matching mission durations</li>
        <li>Medical evacuation included</li>
        <li>Tropical disease coverage</li>
        <li>Easy enrollment for rapid deployment</li>
        <li>Good basic hospitalization coverage</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health coverage—significant gap for trauma exposure</li>
        <li>Outpatient coverage may have restrictions</li>
        <li>Pre-existing conditions excluded</li>
        <li>Evacuation capabilities may be more limited</li>
        <li>May need supplementation for high-risk postings</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Mental health coverage is particularly important for humanitarian workers given exposure to trauma, stress, and challenging conditions. Bupa's unlimited sessions are ideal; IMG's limited coverage may require supplementation.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>NGO budgets often constrain insurance choices. Bupa offers the best coverage but at premium prices. Allianz provides good value. IMG works for organizations with limited resources, though coverage gaps should be considered.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by posting location, age, health history, and coverage level. Hardship postings may have different risk ratings.</p>
    </section>

    <section id="ngo-considerations" class="mb-12">
      <h2>NGO Worker-Specific Considerations</h2>

      <h3>Mental Health and Trauma</h3>
      <p>Humanitarian work involves exposure to suffering, crisis, and sometimes direct trauma. Depression, anxiety, burnout, and PTSD are occupational hazards. Bupa's unlimited mental health coverage is ideal. If using Allianz or IMG, consider whether session limits will be adequate for your potential needs.</p>

      <h3>Medical Evacuation</h3>
      <p>Many humanitarian postings have limited medical facilities. Evacuation to regional medical centers (Nairobi, Johannesburg, Dubai, Bangkok) is often necessary for serious conditions. All three providers include medical evacuation, but capabilities vary in extreme locations.</p>

      <h3>Security Evacuation</h3>
      <p>Important distinction: Health insurance covers medical evacuation, not security evacuation. If your posting has security risks, your organization needs separate security/crisis evacuation coverage. None of these health insurers cover extraction due to conflict or security threats.</p>

      <h3>Tropical and Endemic Diseases</h3>
      <p>Malaria, typhoid, dengue, cholera, and other diseases are occupational hazards in many humanitarian contexts. All three providers cover these conditions fully. Preventive measures like antimalarials may be covered under wellness benefits (Bupa) or require separate provision.</p>

      <h3>Organizational vs Individual Coverage</h3>
      <p>Many NGOs provide group health coverage for staff. Understand what your organization offers before purchasing individual coverage. Individual policies may supplement organizational coverage for gaps or provide coverage during transitions between assignments.</p>

      <h3>Volunteer Considerations</h3>
      <p>Volunteers may not receive organizational health coverage. IMG's affordable pricing makes it accessible for self-funded volunteers. However, volunteers in high-risk environments should seriously consider more comprehensive coverage if resources allow.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Senior humanitarian professionals</li>
            <li>• Those in trauma-exposed roles</li>
            <li>• Workers in remote hardship postings</li>
            <li>• Organizations prioritizing staff welfare</li>
            <li>• Long-term humanitarian careers</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-level NGO professionals</li>
            <li>• Contract-based assignments</li>
            <li>• Organizations seeking value</li>
            <li>• Development workers</li>
            <li>• Those supplementing org coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Volunteers with limited budgets</li>
            <li>• Small NGO staff</li>
            <li>• Short-term missions</li>
            <li>• Entry-level aid workers</li>
            <li>• Basic coverage needs</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does health insurance cover security evacuation from conflict zones?</h3>
          <p class="text-neutral-700">No. Health insurance covers medical evacuation only. Security/crisis evacuation due to conflict, civil unrest, or political instability requires separate coverage, typically provided through organizational security policies or specialized crisis response providers.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is PTSD and trauma counseling covered?</h3>
          <p class="text-neutral-700">Bupa covers PTSD and trauma counseling under their unlimited mental health benefit. Allianz covers it within annual session limits. IMG's limited mental health coverage may not adequately address trauma needs—consider supplemental coverage if trauma exposure is likely.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do NGOs usually provide health insurance for staff?</h3>
          <p class="text-neutral-700">Major international NGOs (UN agencies, large INGOs) typically provide comprehensive coverage. Smaller organizations may provide basic coverage or none. Volunteers often need to arrange their own insurance. Verify organizational coverage before purchasing individual policies.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are travel vaccinations covered?</h3>
          <p class="text-neutral-700">Bupa includes vaccinations under preventive care benefits. Allianz and IMG may cover some vaccinations depending on plan level. Required work vaccinations are often provided by employers regardless of insurance coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage in conflict-adjacent regions?</h3>
          <p class="text-neutral-700">Medical coverage typically continues in conflict-adjacent areas, but some policies exclude active conflict zones. Verify coverage for your specific posting. Medical evacuation remains covered, but extraction capabilities may be limited in unstable areas.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I maintain coverage between humanitarian assignments?</h3>
          <p class="text-neutral-700">Yes, individual policies continue regardless of employment status. This provides continuity between assignments. Allianz's 6-month minimum and IMG's flexibility help bridge gaps between contracts.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
