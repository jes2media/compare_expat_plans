---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Bupa vs Allianz: Best International Health Insurance for Healthcare Workers";
const description = "Compare Cigna Global, Bupa Global, and Allianz Care for doctors, nurses, and medical professionals working abroad. Coverage analysis for occupational risks, liability, and healthcare worker needs.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Occupational Coverage', cigna: 'Comprehensive', bupa: 'Comprehensive', allianz: 'Good coverage' },
  { feature: 'Needlestick/Exposure', cigna: 'Covered', bupa: 'Covered', allianz: 'Covered' },
  { feature: 'Mental Health', cigna: 'Excellent', bupa: 'Excellent', allianz: 'Good' },
  { feature: 'Global Hospital Network', cigna: 'Extensive', bupa: 'Extensive', allianz: 'Strong' },
  { feature: 'Shift Work Support', cigna: '24/7 access', bupa: '24/7 access', allianz: '24/7 access' },
  { feature: 'Family Coverage', cigna: 'Comprehensive', bupa: 'Comprehensive', allianz: 'Comprehensive' },
  { feature: 'Starting Price', cigna: '$$$', bupa: '$$$', allianz: '$$-$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', bupa: 'Comprehensive', allianz: 'Optional/Included' },
  { coverage: 'Mental Health', cigna: 'Unlimited sessions', bupa: 'Comprehensive', allianz: 'Annual limits' },
  { coverage: 'Infectious Disease', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Full coverage' },
  { coverage: 'Preventive Care', cigna: 'Health screenings', bupa: 'Included', allianz: 'Available' },
  { coverage: 'Chronic Conditions', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Coverage varies' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Nurse, 30, Middle East', cigna: '$3,800-5,200/yr', bupa: '$4,000-5,500/yr', allianz: '$3,200-4,400/yr' },
  { profile: 'Doctor, 40, Asia', cigna: '$5,200-7,000/yr', bupa: '$5,500-7,500/yr', allianz: '$4,500-6,000/yr' },
  { profile: 'Surgeon, 45, Europe', cigna: '$6,000-8,200/yr', bupa: '$6,500-8,800/yr', allianz: '$5,200-7,000/yr' },
  { profile: 'Medical family of 4', cigna: '$14,000-19,000/yr', bupa: '$15,000-20,000/yr', allianz: '$12,000-16,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'healthcare-worker-considerations', text: 'Healthcare Worker Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Medical Professionals', href: '/insurance-for/medical-professionals' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the best mental health support for high-stress medical work, need extensive global coverage, and value seamless access to healthcare facilities worldwide.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You're working at a prestigious international hospital, want premium wellness benefits, and appreciate Bupa's healthcare industry expertise and reputation.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-purple-800 text-sm">You want solid comprehensive coverage at a more competitive price, especially if your employer provides partial insurance benefits you need to supplement.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Healthcare workers face unique risks: occupational exposure to infectious diseases, demanding shift schedules, high stress levels, and the irony of caring for others while potentially neglecting their own health. All three providers understand healthcare professional needs, but differ in coverage depth and pricing.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global has deep roots in healthcare, making them particularly attuned to medical professionals' needs. Their extensive network, excellent mental health coverage, and understanding of occupational health risks make them a strong choice for doctors, nurses, and allied health professionals.</p>

      <h3>Strengths for Healthcare Workers</h3>
      <ul>
        <li>Excellent mental health coverage—critical for burnout and compassion fatigue</li>
        <li>Comprehensive occupational exposure coverage including post-exposure prophylaxis</li>
        <li>24/7 support aligned with irregular shift schedules</li>
        <li>Direct billing at major hospitals where you may also work</li>
        <li>Health screenings and preventive care included</li>
        <li>Strong chronic disease management for conditions that may develop</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing at the higher end of the market</li>
        <li>May overlap with employer-provided coverage</li>
        <li>Annual commitment required</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa's origins as a healthcare provider give them unique insight into medical professionals' needs. Their premium coverage, wellness focus, and global hospital partnerships make them popular among physicians and senior healthcare staff.</p>

      <h3>Strengths for Healthcare Workers</h3>
      <ul>
        <li>Healthcare industry expertise built into their DNA</li>
        <li>Comprehensive wellness programs for preventive health</li>
        <li>Strong mental health support including therapy and counseling</li>
        <li>Premium hospital networks globally—often the same facilities you work at</li>
        <li>Second medical opinion services for complex conditions</li>
        <li>Excellent reputation recognized by healthcare employers</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums among the three providers</li>
        <li>Annual commitment with limited flexibility</li>
        <li>Premium positioning may be excessive for some needs</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care offers comprehensive coverage at more competitive pricing, making them attractive for healthcare workers who want solid protection without premium costs—especially those supplementing employer coverage or early in their careers.</p>

      <h3>Strengths for Healthcare Workers</h3>
      <ul>
        <li>Most competitive pricing among the three providers</li>
        <li>Solid occupational health coverage including exposures</li>
        <li>Good mental health coverage with therapy sessions</li>
        <li>Flexible payment options including monthly billing</li>
        <li>Strong global network covering major medical centers</li>
        <li>6-month minimum allows contract alignment</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health coverage may have session limits</li>
        <li>Some premium hospital partnerships less extensive</li>
        <li>Wellness benefits less comprehensive than Bupa</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Healthcare workers need coverage that addresses their unique occupational risks and the stress of medical work. Mental health support is particularly important given high rates of burnout in the profession.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Healthcare workers often receive employer insurance benefits, but these may be insufficient or have gaps. Individual coverage can supplement or replace employer plans, especially for those on contract or working independently.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specialty, age, location, and coverage level. Healthcare workers are generally standard risk and not surcharged for their profession.</p>
    </section>

    <section id="healthcare-worker-considerations" class="mb-12">
      <h2>Healthcare Worker-Specific Considerations</h2>

      <h3>Occupational Exposure</h3>
      <p>Needlestick injuries, bloodborne pathogen exposure, and infectious disease risks are occupational realities. All three providers cover post-exposure prophylaxis and follow-up treatment. Verify your plan includes HIV PEP coverage and related testing.</p>

      <h3>Mental Health and Burnout</h3>
      <p>Healthcare workers experience high rates of burnout, depression, and anxiety. Cigna and Bupa offer excellent mental health coverage without session limits. Allianz provides good coverage but may cap annual therapy sessions. Prioritize mental health benefits.</p>

      <h3>Shift Work Challenges</h3>
      <p>Irregular hours require 24/7 access to support services. All three providers offer round-the-clock customer service and telehealth. Consider how easy it is to access care during your off-hours, which may be others' busy times.</p>

      <h3>Professional Colleague Networks</h3>
      <p>Working in healthcare means you know good doctors. Your insurance should provide access to specialists you'd choose yourself. Cigna and Bupa's extensive networks typically include premier facilities. Verify your preferred hospitals are covered.</p>

      <h3>Employer Coverage Gaps</h3>
      <p>Many healthcare employers provide basic coverage that may lack adequate mental health benefits, comprehensive outpatient care, or coverage for family members. Individual policies can fill these gaps or provide primary coverage for dependents.</p>

      <h3>International Licensing and Practice</h3>
      <p>If you practice medicine abroad, ensure you have appropriate malpractice/professional liability coverage separately. Health insurance covers your personal health, not professional liability—different policies serve different purposes.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Doctors prioritizing mental health support</li>
            <li>• Healthcare workers in high-stress specialties</li>
            <li>• Those needing extensive global coverage</li>
            <li>• Medical professionals with families</li>
            <li>• ICU, ER, and critical care staff</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Senior physicians and surgeons</li>
            <li>• Those at prestigious international hospitals</li>
            <li>• Healthcare executives and administrators</li>
            <li>• Professionals valuing wellness programs</li>
            <li>• Those with employer insurance contributions</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Nurses and allied health professionals</li>
            <li>• Early-career healthcare workers</li>
            <li>• Those supplementing employer coverage</li>
            <li>• Budget-conscious medical professionals</li>
            <li>• Contract-based healthcare workers</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does health insurance cover occupational exposures like needlesticks?</h3>
          <p class="text-neutral-700">Yes, all three providers cover treatment for occupational exposures including post-exposure prophylaxis for HIV and hepatitis, testing, and follow-up care. This is separate from any workers' compensation your employer may provide.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are healthcare workers charged higher premiums?</h3>
          <p class="text-neutral-700">No, healthcare workers are not typically surcharged for their profession. Standard underwriting based on age and health history applies. Your medical knowledge may actually help you manage your health better.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I use my insurance at the hospital where I work?</h3>
          <p class="text-neutral-700">Usually yes, if your hospital is in the insurer's network. Many healthcare workers prefer being treated elsewhere for privacy, and all three providers have extensive networks offering alternatives.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How important is mental health coverage for medical professionals?</h3>
          <p class="text-neutral-700">Critically important. Healthcare worker burnout rates exceed 50% in many specialties. Comprehensive mental health coverage from Cigna or Bupa ensures access to therapy without worrying about session limits or costs.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does this cover malpractice or professional liability?</h3>
          <p class="text-neutral-700">No, health insurance covers your personal medical needs. Professional liability/malpractice insurance is separate and typically provided by your employer or purchased independently through specialized insurers.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What if my employer provides basic coverage?</h3>
          <p class="text-neutral-700">You can supplement employer coverage with an individual policy to fill gaps—especially for mental health, family coverage, or higher limits. Alternatively, maintain individual coverage for continuity between contracts.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
