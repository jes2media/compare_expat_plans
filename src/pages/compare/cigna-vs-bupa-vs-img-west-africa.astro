---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Bupa vs IMG: Best International Health Insurance for West Africa";
const description = "Compare Cigna Global, Bupa Global, and IMG Global for expats in West Africa. Coverage analysis for Nigeria, Ghana, Senegal, Côte d'Ivoire, and the West African region.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'West Africa Network', cigna: 'Strong', bupa: 'Good', img: 'Limited' },
  { feature: 'Medical Evacuation', cigna: 'Comprehensive', bupa: 'Comprehensive', img: 'Included' },
  { feature: 'Tropical Disease', cigna: 'Full coverage', bupa: 'Full coverage', img: 'Covered' },
  { feature: 'Mental Health', cigna: 'Excellent', bupa: 'Unlimited', img: 'Limited' },
  { feature: 'Security Evacuation', cigna: 'Optional add-on', bupa: 'Optional add-on', img: 'Not included' },
  { feature: 'Regional Hospitals', cigna: 'Direct billing', bupa: 'Direct billing', img: 'Reimbursement' },
  { feature: 'Starting Price', cigna: '$$$', bupa: '$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Unlimited options', bupa: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', bupa: 'Comprehensive', img: 'Plan dependent' },
  { coverage: 'Medical Evacuation', cigna: 'Worldwide', bupa: 'Worldwide', img: 'Regional' },
  { coverage: 'Tropical Disease', cigna: 'Full coverage', bupa: 'Full coverage', img: 'Covered' },
  { coverage: 'Malaria Treatment', cigna: 'Full coverage', bupa: 'Full coverage', img: 'Covered' },
  { coverage: 'Vaccinations', cigna: 'Included', bupa: 'Comprehensive', img: 'Limited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Individual, 35, Nigeria', cigna: '$4,500-6,200/yr', bupa: '$4,800-6,500/yr', img: '$2,200-3,000/yr' },
  { profile: 'Individual, 45, Ghana', cigna: '$6,000-8,200/yr', bupa: '$6,500-8,800/yr', img: '$3,000-4,200/yr' },
  { profile: 'Individual, 55, Senegal', cigna: '$8,500-11,500/yr', bupa: '$9,000-12,500/yr', img: '$4,200-5,800/yr' },
  { profile: 'Family of 4, Lagos', cigna: '$16,000-22,000/yr', bupa: '$17,000-23,500/yr', img: '$8,500-11,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'west-africa-considerations', text: 'West Africa Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Africa', href: '/insurance-for/africa' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the strongest West African hospital networks with direct billing, comprehensive evacuation coverage, and excellent support for challenging healthcare environments.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You want premium coverage with unlimited mental health support, comprehensive evacuation, and the prestige of a globally recognized healthcare brand.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're on a shorter-term assignment, need budget-friendly coverage with essential evacuation, and are comfortable with reimbursement-based claims.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>West Africa presents unique challenges for expats: variable healthcare quality, tropical disease risk, and limited specialist facilities outside major cities. Medical evacuation capability is essential—serious conditions often require treatment in South Africa, Europe, or the Middle East. Premium insurance is strongly recommended.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers the strongest presence in West Africa with established hospital networks, direct billing relationships, and comprehensive evacuation capabilities. Their experience in challenging healthcare environments provides reassurance for West African assignments.</p>

      <h3>Strengths for West Africa Expats</h3>
      <ul>
        <li>Strong hospital networks in Lagos, Accra, Dakar</li>
        <li>Direct billing at major facilities</li>
        <li>Comprehensive medical evacuation worldwide</li>
        <li>Full tropical disease and malaria coverage</li>
        <li>24/7 multilingual support</li>
        <li>Excellent mental health coverage</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing for the region</li>
        <li>Annual commitment required</li>
        <li>Security evacuation requires separate coverage</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global provides premium coverage with unlimited mental health support—valuable in challenging postings. Their global brand and comprehensive evacuation ensure access to quality care regardless of local limitations.</p>

      <h3>Strengths for West Africa Expats</h3>
      <ul>
        <li>Unlimited mental health sessions for posting stress</li>
        <li>Comprehensive medical evacuation</li>
        <li>Full tropical disease coverage</li>
        <li>Premium global brand recognition</li>
        <li>Extensive vaccination coverage</li>
        <li>Strong wellness programs</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums</li>
        <li>Network may be smaller than Cigna in some areas</li>
        <li>Annual commitment required</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers more affordable coverage suitable for shorter assignments or budget-conscious expats. While networks are limited, essential evacuation coverage and basic hospitalization provide necessary protection.</p>

      <h3>Strengths for West Africa Expats</h3>
      <ul>
        <li>Most affordable option for the region</li>
        <li>Medical evacuation included</li>
        <li>Flexible terms for project-based work</li>
        <li>Tropical disease coverage</li>
        <li>Malaria treatment covered</li>
        <li>Good basic hospitalization</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited direct billing—mostly reimbursement</li>
        <li>Smaller provider network</li>
        <li>Limited mental health coverage</li>
        <li>Outpatient coverage varies by plan</li>
        <li>Pre-existing conditions excluded</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Key coverage priorities for West Africa include medical evacuation (essential given limited facilities), tropical disease treatment (malaria, yellow fever, typhoid), and access to quality facilities for serious conditions.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>West Africa premiums reflect challenging healthcare environments and evacuation risks. Many employers in the region provide comprehensive health insurance—verify your package before purchasing individual coverage.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific country, age, health history, and coverage level. Corporate postings typically include employer-provided coverage.</p>
    </section>

    <section id="west-africa-considerations" class="mb-12">
      <h2>West Africa Considerations</h2>

      <h3>Medical Evacuation is Essential</h3>
      <p>Quality healthcare in West Africa is limited outside major cities. Serious conditions—cardiac events, complex surgeries, cancer treatment—often require evacuation to South Africa, Europe, or the UAE. Comprehensive evacuation coverage isn't optional; it's essential for safe West African assignments.</p>

      <h3>Tropical Disease Risk</h3>
      <p>Malaria, yellow fever, typhoid, dengue, and other tropical diseases are present throughout West Africa. All three providers cover treatment. Prevention matters too—verify vaccination coverage and take appropriate prophylaxis. Even with precautions, tropical disease treatment access is important.</p>

      <h3>Healthcare Quality Variation</h3>
      <p>Lagos and Accra have quality private hospitals; smaller cities and rural areas have very limited facilities. Premium insurers with direct billing at major hospitals simplify care access. In remote areas, evacuation to regional hubs may be necessary even for moderate conditions.</p>

      <h3>Mental Health in Challenging Postings</h3>
      <p>West African assignments can be challenging—isolation, security concerns, difficult conditions, and distance from family. Mental health support matters significantly. Bupa's unlimited sessions or Cigna's excellent coverage address these needs. IMG's limited coverage may be inadequate.</p>

      <h3>Security Considerations</h3>
      <p>Some West African regions have security concerns. Medical insurance covers health evacuation only—security evacuation requires separate coverage. Many corporate assignments include security evacuation through employers or specialized providers.</p>

      <h3>Employer-Provided Coverage</h3>
      <p>Corporate expats in West Africa typically receive comprehensive health insurance as part of assignment packages. Oil and gas, mining, and international development positions usually include premium coverage. Verify your employer's provision before purchasing individual insurance.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Long-term West Africa expats</li>
            <li>• Those wanting direct billing</li>
            <li>• Corporate professionals in Lagos</li>
            <li>• Families in the region</li>
            <li>• Those prioritizing local networks</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Those prioritizing mental health</li>
            <li>• Premium coverage seekers</li>
            <li>• Senior executives in the region</li>
            <li>• Those in challenging postings</li>
            <li>• Diplomatic and NGO staff</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Short-term assignments</li>
            <li>• Budget-conscious expats</li>
            <li>• Project-based workers</li>
            <li>• Young professionals building experience</li>
            <li>• Those supplementing employer coverage</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is medical evacuation really necessary for West Africa?</h3>
          <p class="text-neutral-700">Yes, strongly recommended. Quality healthcare is limited outside major cities. Serious conditions often require treatment in South Africa, Europe, or the Middle East. Evacuation can cost $50,000-$200,000+ without insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about malaria coverage?</h3>
          <p class="text-neutral-700">All three providers cover malaria treatment. Prevention is equally important—take prophylaxis, use mosquito nets, and avoid exposure. Even with precautions, malaria risk is significant throughout West Africa.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do employers in West Africa provide health insurance?</h3>
          <p class="text-neutral-700">Most international employers (oil/gas, mining, NGOs, multinationals) provide comprehensive coverage including evacuation. This is standard for hardship postings. Verify your specific package before purchasing individual insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does health insurance cover security evacuation?</h3>
          <p class="text-neutral-700">No. Health insurance covers medical evacuation only. Security evacuation (due to conflict, civil unrest, etc.) requires separate coverage, typically provided by employers or specialized security insurers for West African assignments.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are there quality hospitals in West Africa?</h3>
          <p class="text-neutral-700">Lagos (Nigeria) and Accra (Ghana) have quality private hospitals with international standards. Smaller cities have limited facilities. For complex care, evacuation to South Africa, Europe, or UAE is often necessary.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I prioritize direct billing in West Africa?</h3>
          <p class="text-neutral-700">Yes, if possible. Direct billing at major hospitals avoids out-of-pocket expenses. Cigna has the strongest direct billing relationships in the region. IMG mostly requires paying and claiming reimbursement.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
