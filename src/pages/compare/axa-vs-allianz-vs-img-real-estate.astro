---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "AXA vs Allianz vs IMG: Best International Health Insurance for Real Estate Professionals";
const description = "Compare AXA Global Healthcare, Allianz Care, and IMG Global for real estate developers, property investors, and international real estate professionals working across borders.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Premium Level', axa: 'Premium', allianz: 'Mid-Premium', img: 'Budget-Mid' },
  { feature: 'Multi-Country Coverage', axa: 'Excellent', allianz: 'Strong', img: 'Good' },
  { feature: 'Mental Health', axa: 'Comprehensive', allianz: 'Good', img: 'Limited' },
  { feature: 'Executive Health', axa: 'Available', allianz: 'Available', img: 'Not included' },
  { feature: 'Travel Flexibility', axa: 'Seamless', allianz: 'Good', img: 'Good' },
  { feature: 'Contract Terms', axa: '12-month min', allianz: '6-month min', img: 'Flexible' },
  { feature: 'Starting Price', axa: '$$$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', axa: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', axa: 'Comprehensive', allianz: 'Comprehensive', img: 'Plan dependent' },
  { coverage: 'Mental Health', axa: 'Full coverage', allianz: 'Annual limits', img: 'Limited' },
  { coverage: 'Preventive Care', axa: 'Health screenings', allianz: 'Available', img: 'Basic' },
  { coverage: 'Business Travel', axa: 'Worldwide', allianz: 'Worldwide', img: 'Worldwide' },
  { coverage: 'Pre-existing Conditions', axa: 'Underwritten', allianz: 'Moratorium option', img: 'Excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'Agent/broker, 35', axa: '$4,000-5,500/yr', allianz: '$3,200-4,400/yr', img: '$1,800-2,500/yr' },
  { profile: 'Developer, 45', axa: '$5,500-7,500/yr', allianz: '$4,500-6,000/yr', img: '$2,600-3,600/yr' },
  { profile: 'Investor, 55', axa: '$7,500-10,000/yr', allianz: '$6,000-8,200/yr', img: '$3,800-5,200/yr' },
  { profile: 'RE executive + family', axa: '$16,000-22,000/yr', allianz: '$12,000-16,500/yr', img: '$7,500-10,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'real-estate-considerations', text: 'Real Estate Professional Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Business Professionals', href: '/insurance-for/business-professionals' },
  { title: 'AXA Global Review', href: '/providers/axa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-blue-800 text-sm">You're a senior real estate developer or investor who travels extensively, wants premium coverage with executive health benefits, and values comprehensive care in global property markets.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at moderate pricing, with flexibility that works for real estate professionals managing properties across multiple markets.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're building your international real estate career, need flexible terms matching deal cycles, and want affordable coverage while establishing yourself.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>International real estate professionals—developers, investors, brokers, and property managers—often work across multiple countries, requiring insurance that seamlessly covers travel between markets. Variable income from deal cycles may also influence coverage choices.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global offers premium coverage suited to successful real estate professionals with significant deal flow. Their comprehensive benefits, executive health programs, and seamless multi-country coverage align with the demands of international property business.</p>

      <h3>Strengths for Real Estate Professionals</h3>
      <ul>
        <li>Seamless coverage across international property markets</li>
        <li>Executive health screenings for busy professionals</li>
        <li>Comprehensive mental health coverage for deal stress</li>
        <li>Premium hospital networks in major global cities</li>
        <li>Wellness programs for maintaining health during travel</li>
        <li>24/7 support regardless of time zone</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>12-month commitment may not suit all deal cycles</li>
        <li>May exceed needs for smaller-scale operators</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid comprehensive coverage at more moderate pricing, with flexibility that works well for real estate professionals managing properties and deals across multiple markets.</p>

      <h3>Strengths for Real Estate Professionals</h3>
      <ul>
        <li>Competitive pricing for comprehensive coverage</li>
        <li>6-month minimum provides flexibility</li>
        <li>Good global network in major property markets</li>
        <li>Mental health coverage with annual session limits</li>
        <li>Monthly payment options for cash flow management</li>
        <li>Worldwide coverage for frequent travel</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions may have annual limits</li>
        <li>Executive health programs less comprehensive than AXA</li>
        <li>May lack some premium hospital partnerships</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global offers affordable international coverage suitable for real estate professionals building their international portfolios. Their flexible terms and moderate pricing work well with the variable income cycles of real estate careers.</p>

      <h3>Strengths for Real Estate Professionals</h3>
      <ul>
        <li>Most affordable option for building professionals</li>
        <li>Flexible terms matching deal cycle variability</li>
        <li>Good basic coverage for international travel</li>
        <li>Worldwide coverage for property market visits</li>
        <li>Easy enrollment without extensive underwriting</li>
        <li>Option to upgrade as business grows</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health coverage</li>
        <li>No executive health screening programs</li>
        <li>Outpatient coverage may have restrictions</li>
        <li>Pre-existing conditions excluded</li>
        <li>May not project premium professional image</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Key coverage areas for real estate professionals include worldwide travel coverage, mental health support for high-pressure deals, and preventive care for maintaining health during busy periods.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Real estate income can be variable—large commissions during closings, slower periods between deals. AXA and Allianz's fixed annual costs require planning; IMG's flexibility may better suit variable income.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by primary residence, age, health history, and coverage level. Consider insurance as a business expense and factor into deal budgeting.</p>
    </section>

    <section id="real-estate-considerations" class="mb-12">
      <h2>Real Estate Professional Considerations</h2>

      <h3>Multi-Country Operations</h3>
      <p>International real estate often involves managing properties or deals across multiple countries. Ensure your coverage works in all your active markets. All three providers offer worldwide coverage, but verify specific country inclusions for emerging markets.</p>

      <h3>Deal Stress and Mental Health</h3>
      <p>Large real estate transactions involve significant stress—financing uncertainties, regulatory challenges, and high stakes. AXA's comprehensive mental health coverage addresses this well. Allianz provides good support with limits. IMG's coverage may be insufficient for high-stress periods.</p>

      <h3>Variable Income Cycles</h3>
      <p>Real estate income often comes in large amounts at deal closings with slower periods between. IMG's flexible terms accommodate this variability. AXA and Allianz's fixed annual commitments require budgeting during slower periods.</p>

      <h3>Site Visit Travel</h3>
      <p>Property inspection, due diligence, and deal meetings require frequent travel. All three providers cover business travel globally. Consider how easy it is to access care in your frequent destinations.</p>

      <h3>Cardiovascular Health</h3>
      <p>The stress and lifestyle of real estate—client entertainment, irregular schedules, travel—affects cardiovascular health. AXA's executive health screenings help catch issues early. Regular check-ups are particularly important for this profession.</p>

      <h3>Tax Considerations</h3>
      <p>Health insurance premiums are typically deductible business expenses for self-employed real estate professionals. This effectively reduces the net cost of premium coverage. Consult your tax advisor for proper treatment.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Senior real estate developers</li>
            <li>• High-volume property investors</li>
            <li>• Real estate firm principals</li>
            <li>• Those prioritizing executive health</li>
            <li>• Multi-market operators</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-career real estate professionals</li>
            <li>• Property managers abroad</li>
            <li>• International brokers</li>
            <li>• Those seeking value coverage</li>
            <li>• Real estate consultants</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Early-career international agents</li>
            <li>• Those building international portfolios</li>
            <li>• Budget-conscious professionals</li>
            <li>• Variable income operators</li>
            <li>• Short-term international projects</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does insurance cover me while visiting properties in different countries?</h3>
          <p class="text-neutral-700">Yes, all three providers offer worldwide coverage including business travel. You're covered while inspecting properties, meeting clients, or conducting due diligence anywhere in your coverage region.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How do I handle insurance during slow deal periods?</h3>
          <p class="text-neutral-700">IMG's flexible terms let you adjust during slow periods. For AXA and Allianz's annual commitments, budget throughout the year—treat insurance as a fixed business cost regardless of deal flow.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is health insurance tax deductible for real estate professionals?</h3>
          <p class="text-neutral-700">Generally yes, for self-employed professionals. Health insurance premiums are typically deductible business expenses. This reduces the effective cost of premium coverage. Consult your tax advisor for specific treatment.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage in emerging real estate markets?</h3>
          <p class="text-neutral-700">All three providers offer worldwide coverage, but network depth varies in emerging markets. Direct billing may be limited in developing countries. Verify coverage for your specific target markets before purchasing.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I prioritize mental health coverage in real estate?</h3>
          <p class="text-neutral-700">Yes. Large real estate transactions involve significant stress and high stakes. Deal failures, financing challenges, and client pressure affect mental health. AXA's comprehensive coverage or Allianz's good support is worth prioritizing.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does this cover accidents on construction sites?</h3>
          <p class="text-neutral-700">Health insurance covers medical treatment for any injury, including construction site accidents. However, if you're regularly on construction sites, verify whether your policy has any occupational exclusions and ensure you have appropriate site safety protocols.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
