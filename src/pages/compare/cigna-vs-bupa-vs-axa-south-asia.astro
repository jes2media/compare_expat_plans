---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Bupa vs AXA: Best International Health Insurance for South Asia";
const description = "Compare Cigna Global, Bupa Global, and AXA Global Healthcare for expats in South Asia. Coverage analysis for India, Sri Lanka, Bangladesh, Nepal, and Pakistan.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const mainComparisonRows = [
  { feature: 'India Network', cigna: 'Excellent', bupa: 'Excellent', axa: 'Strong' },
  { feature: 'Sri Lanka Coverage', cigna: 'Good', bupa: 'Good', axa: 'Good' },
  { feature: 'Direct Billing', cigna: 'Extensive in India', bupa: 'Major hospitals', axa: 'Major hospitals' },
  { feature: 'Tropical Disease', cigna: 'Comprehensive', bupa: 'Comprehensive', axa: 'Comprehensive' },
  { feature: 'Air Quality Issues', cigna: 'Covered', bupa: 'Covered', axa: 'Covered' },
  { feature: 'Regional Evacuation', cigna: 'To Singapore/Bangkok', bupa: 'Included', axa: 'Included' },
  { feature: 'Starting Price', cigna: '$$$', bupa: '$$$', axa: '$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Full coverage', bupa: 'Full coverage', axa: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', bupa: 'Comprehensive', axa: 'Comprehensive' },
  { coverage: 'Mental Health', cigna: 'Excellent', bupa: 'Excellent', axa: 'Good' },
  { coverage: 'Maternity', cigna: '12-month wait', bupa: '12-month wait', axa: '12-month wait' },
  { coverage: 'Ayurveda/Traditional', cigna: 'Limited', bupa: 'Limited', axa: 'Limited' },
  { coverage: 'Pre-existing Conditions', cigna: 'Moratorium option', bupa: 'Underwritten', axa: 'Underwritten' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const pricingRows = [
  { profile: 'Single, 35, India', cigna: '$3,000-4,200/yr', bupa: '$3,200-4,500/yr', axa: '$3,400-4,600/yr' },
  { profile: 'Single, 35, Sri Lanka', cigna: '$2,800-3,800/yr', bupa: '$3,000-4,200/yr', axa: '$3,200-4,400/yr' },
  { profile: 'Couple, 45, India', cigna: '$6,500-8,800/yr', bupa: '$7,000-9,500/yr', axa: '$7,200-9,800/yr' },
  { profile: 'Family of 4, India', cigna: '$12,000-16,000/yr', bupa: '$13,000-17,500/yr', axa: '$13,500-18,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'south-asia', text: 'South Asia Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Best Insurance for Asia', href: '/best/asia' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'AXA Global Review', href: '/providers/axa' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most extensive direct billing network across India's top hospitals and value their strong mental health coverage and customer service reputation.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You prioritize premium service, wellness programs, and want access to the best private hospitals in major Indian cities with excellent evacuation options.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-purple-800 text-sm">You want comprehensive coverage with strong wellness benefits and are looking for a global brand with solid South Asian presence.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>South Asia presents unique healthcare challenges: world-class private hospitals alongside variable public facilities, significant air pollution in major cities, tropical disease exposure, and diverse healthcare landscapes across countries. All three providers have strong India presence, with varying coverage in smaller regional countries.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global has one of the strongest networks in India, with established relationships at Apollo, Fortis, Max, and other premier hospital chains. Their extensive direct billing network and customer service reputation make them a top choice for South Asian expats.</p>

      <h3>Strengths for South Asia</h3>
      <ul>
        <li>Most extensive direct billing network in India</li>
        <li>Strong relationships with Apollo, Fortis, Max, and Manipal hospitals</li>
        <li>24/7 customer service with regional support</li>
        <li>Excellent mental health coverage for expat adjustment challenges</li>
        <li>Comprehensive tropical disease coverage</li>
        <li>Seamless evacuation to Singapore for complex cases</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing among the three options</li>
        <li>Limited Ayurveda/traditional medicine coverage</li>
        <li>Network thinner in Nepal, Bangladesh, Pakistan</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global offers premium coverage with excellent hospital partnerships across India's top facilities. Their wellness focus and comprehensive benefits make them attractive for expats who want the best care available in the region.</p>

      <h3>Strengths for South Asia</h3>
      <ul>
        <li>Premium hospital partnerships in Mumbai, Delhi, Bangalore, Chennai</li>
        <li>Excellent wellness and preventive care programs</li>
        <li>Comprehensive mental health coverage</li>
        <li>Strong emergency evacuation to Singapore/Thailand</li>
        <li>Health screening programs at partner facilities</li>
        <li>24/7 support for emergencies</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums in South Asia</li>
        <li>Direct billing network slightly smaller than Cigna in India</li>
        <li>Traditional medicine coverage limited</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global provides comprehensive coverage for South Asian expats with strong wellness benefits and global brand recognition. Their coverage works well for expats based in major cities with occasional regional travel.</p>

      <h3>Strengths for South Asia</h3>
      <ul>
        <li>Comprehensive coverage including wellness benefits</li>
        <li>Good network at major private hospitals in India</li>
        <li>Strong preventive care and health screening options</li>
        <li>Mental health coverage for expat stress</li>
        <li>Emergency evacuation included</li>
        <li>Global brand recognition and service standards</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Direct billing network smaller than Cigna in India</li>
        <li>12-month minimum commitment</li>
        <li>Coverage may be thinner in smaller South Asian countries</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>All three providers offer comprehensive coverage suitable for South Asia's healthcare environment. Key differences emerge in network breadth, traditional medicine coverage, and mental health benefits.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>South Asia is moderately priced for international health insurance due to lower medical costs compared to Western countries. India tends to be slightly higher than Sri Lanka due to more extensive private hospital infrastructure.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific city, age, health history, and coverage level. Major cities like Mumbai and Delhi may have slightly higher premiums.</p>
    </section>

    <section id="south-asia" class="mb-12">
      <h2>South Asia Insurance Considerations</h2>

      <h3>Healthcare Quality in India</h3>
      <p>India has world-class private hospitals in major cities—Apollo, Fortis, Max, and others offer care rivaling Western standards. However, quality varies dramatically between private and public facilities, and between urban and rural areas. International insurance ensures access to the best private care.</p>

      <h3>Air Quality and Respiratory Health</h3>
      <p>Delhi, Mumbai, and other major Indian cities have severe air pollution, especially during winter months. Respiratory issues, asthma exacerbations, and long-term lung health are real concerns. Comprehensive outpatient coverage ensures access to pulmonologists and ongoing treatment.</p>

      <h3>Tropical Disease Exposure</h3>
      <p>Dengue, typhoid, malaria (in some areas), and other tropical diseases exist across South Asia. All three providers cover these conditions fully. Monsoon season increases disease risk in many areas.</p>

      <h3>Traditional Medicine</h3>
      <p>Ayurveda and other traditional medicine systems are integral to South Asian healthcare. Coverage for traditional treatments is limited across all international insurers—expect to pay out of pocket for Ayurvedic treatments unless prescribed for specific conditions.</p>

      <h3>Regional Travel</h3>
      <p>If you travel within South Asia—to Nepal, Sri Lanka, Bangladesh, or the Maldives—verify coverage extends to these countries. All three providers typically cover the region, but network depth varies outside India.</p>

      <h3>Evacuation Considerations</h3>
      <p>For complex medical cases, evacuation to Singapore or Thailand may be necessary. All three providers include evacuation coverage. This is particularly important if you're based outside major metro areas with top-tier hospitals.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Expats wanting extensive India network</li>
            <li>• Those prioritizing direct billing access</li>
            <li>• Corporate assignees in India</li>
            <li>• Families needing reliable coverage</li>
            <li>• Those with mental health priorities</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Executives and senior professionals</li>
            <li>• Those wanting premium hospital access</li>
            <li>• Expats valuing wellness programs</li>
            <li>• Families in major metro areas</li>
            <li>• Those with employer contributions</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Expats seeking comprehensive wellness</li>
            <li>• Those in major Indian cities</li>
            <li>• Professionals with global mobility</li>
            <li>• Those wanting preventive care focus</li>
            <li>• Regional business travelers</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Which provider has the best hospital network in India?</h3>
          <p class="text-neutral-700">Cigna has the most extensive direct billing network in India, covering Apollo, Fortis, Max, Manipal, and other major chains. Bupa and AXA also have strong networks but with slightly fewer direct billing options.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is Ayurvedic medicine covered by international insurance?</h3>
          <p class="text-neutral-700">Coverage for Ayurveda and traditional Indian medicine is limited across all providers. Some treatments may be covered if prescribed by a physician for a specific medical condition, but routine Ayurvedic treatments are typically out of pocket.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does coverage include treatment for air pollution-related issues?</h3>
          <p class="text-neutral-700">Yes, respiratory conditions including those exacerbated by air pollution are covered under outpatient benefits. This includes consultations with pulmonologists, medications, and ongoing treatment for asthma and other respiratory issues.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I get coverage for travel to Nepal or Sri Lanka?</h3>
          <p class="text-neutral-700">Yes, all three providers cover travel within South Asia. However, direct billing options are more limited outside India. In Nepal or Sri Lanka, you may need to pay upfront and submit claims for reimbursement.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about medical evacuation from India?</h3>
          <p class="text-neutral-700">Evacuation is included but rarely needed from major Indian cities given excellent private hospital options. For complex cases or if you're in smaller cities, evacuation to Singapore or Thailand may be arranged.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Are tropical diseases like dengue covered?</h3>
          <p class="text-neutral-700">Yes, all three providers fully cover tropical diseases including dengue, typhoid, malaria, and chikungunya. Treatment, hospitalization, and follow-up care are all included in comprehensive plans.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
