---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'axa', text: 'AXA Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'uk-considerations', text: 'UK Expat Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global Full Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Full Review', href: '/providers/bupa-global' },
  { title: 'AXA Global Full Review', href: '/providers/axa-global' },
  { title: 'Insurance for UK Expats', href: '/insurance-for/uk-expats' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const mainComparisonRows = [
  { feature: 'UK return coverage', cigna: 'Up to 90 days/year', bupa: 'Up to 90 days/year', axa: 'Up to 60 days/year' },
  { feature: 'NHS top-up option', cigna: 'Yes—complements NHS', bupa: 'Yes—UK add-on available', axa: 'Limited options' },
  { feature: 'UK-based support', cigna: 'UK call center', bupa: 'UK headquarters', axa: 'European support' },
  { feature: 'GBP payment', cigna: 'Available', bupa: 'Native GBP', axa: 'Available' },
  { feature: 'UK private hospitals', cigna: 'Extensive network', bupa: 'Largest UK network', axa: 'Good network' },
  { feature: 'Mental health', cigna: 'Strong coverage', bupa: 'Industry leading', axa: 'Good coverage' },
  { feature: 'Chronic conditions', cigna: 'Good—moratorium option', bupa: 'Good—various options', axa: 'Standard terms' },
  { feature: 'Family plans', cigna: 'Competitive', bupa: 'Family-friendly', axa: 'Good value' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'axa', header: 'AXA Global' },
];

const pricingRows = [
  { scenario: 'Age 35, comprehensive', cigna: '£3,200-4,500/yr', bupa: '£3,000-4,200/yr', axa: '£2,800-3,800/yr' },
  { scenario: 'Age 45, comprehensive', cigna: '£4,200-5,800/yr', bupa: '£4,000-5,500/yr', axa: '£3,600-5,000/yr' },
  { scenario: 'Age 55, comprehensive', cigna: '£5,800-8,000/yr', bupa: '£5,500-7,500/yr', axa: '£5,000-7,000/yr' },
  { scenario: 'Family (2 adults, 2 kids)', cigna: '£8,500-12,000/yr', bupa: '£8,000-11,500/yr', axa: '£7,500-10,500/yr' },
  { scenario: 'With UK coverage add-on', cigna: '+£800-1,500/yr', bupa: '+£600-1,200/yr', axa: '+£700-1,400/yr' },
];
---

<PageShell
  title="Cigna vs Bupa vs AXA: Best for UK Expats 2025"
  description="Compare Cigna, Bupa, and AXA for British expats abroad. UK return coverage, NHS top-up options, GBP payments, and coverage for visits home."
  headline="Cigna vs Bupa vs AXA: Best for UK Expats"
  subheadline="Which insurer is best for British citizens living abroad? Home visits, NHS integration, and UK-friendly features."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Overall</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Strong global coverage with excellent UK return options. UK call center and comprehensive worldwide network.</p>
      <a href="/providers/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best UK Integration</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">UK-headquartered with the largest UK private hospital network. Native GBP billing and familiar British service.</p>
      <a href="/providers/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">AXA Global</p>
      <p class="text-sm text-neutral-600 mb-3">Competitive pricing with solid coverage. Good option for budget-conscious UK expats in Europe.</p>
      <a href="/providers/axa-global" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="cigna">Cigna Global</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Cigna Global offers UK expats comprehensive worldwide coverage with strong UK return options. Their UK call center understands British healthcare expectations, and they integrate well with NHS for returning expats.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">UK Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Up to 90 days UK coverage per year for home visits</li>
      <li>UK-based customer service team</li>
      <li>Extensive UK private hospital network</li>
      <li>GBP payment options available</li>
      <li>Good integration options with NHS</li>
      <li>Strong coverage for British retirees abroad</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Slightly higher premiums than competitors</li>
      <li>UK coverage add-on increases costs</li>
      <li>Some plans exclude UK as primary residence</li>
      <li>Pre-existing condition terms vary</li>
    </ul>
  </div>

  <h2 id="bupa">Bupa Global</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Bupa Global is UK-headquartered with deep roots in British healthcare. For UK expats, this means familiar service standards, the largest UK private hospital network, and seamless coverage when visiting home.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">UK Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>UK-headquartered—understands British expectations</li>
      <li>Largest UK private hospital network (Nuffield, Spire, BMI)</li>
      <li>Native GBP billing—no currency conversion</li>
      <li>Industry-leading mental health coverage</li>
      <li>Up to 90 days UK coverage annually</li>
      <li>Familiar Bupa brand and service standards</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Premium pricing for comprehensive plans</li>
      <li>Some regions have weaker networks than competitors</li>
      <li>UK coverage add-on required for extended visits</li>
      <li>Waiting periods for some benefits</li>
    </ul>
  </div>

  <h2 id="axa">AXA Global Healthcare</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">AXA Global offers competitive pricing for UK expats, particularly those in Europe. While not UK-headquartered, they provide solid coverage with good UK return options at lower premiums.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">UK Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most affordable premiums of the three</li>
      <li>Good UK private hospital network</li>
      <li>GBP payment available</li>
      <li>Strong European coverage—ideal for EU-based Brits</li>
      <li>Flexible plan options</li>
      <li>Good family plan value</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Shorter UK return coverage (60 days vs 90)</li>
      <li>European-based support—not UK-specific</li>
      <li>Smaller UK network than Bupa</li>
      <li>Mental health coverage less comprehensive</li>
    </ul>
  </div>

  <CTABox
    title="Find the Right Cover for Your Move Abroad"
    description="Compare plans designed for British expats. UK return coverage, GBP payments, and familiar service standards."
    buttonText="Compare UK Expat Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Annual premiums in GBP for UK expats. Prices exclude UK as primary residence—add UK coverage for home visits.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Prices are estimates based on residence outside UK/US. Including US coverage adds 30-50% to premiums.</p>

  <h2 id="uk-considerations">UK Expat Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">NHS Entitlement</h3>
      <p class="text-neutral-700">UK expats lose NHS entitlement after living abroad for 12+ months. You may still access NHS as an overseas visitor, but charges apply. Private insurance ensures you're covered during UK visits without NHS complications. Some plans offer "NHS top-up" that covers private treatment for faster access while NHS remains your safety net.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">UK Return Coverage</h3>
      <p class="text-neutral-700">Most international plans exclude your home country or limit coverage duration. Cigna and Bupa offer up to 90 days UK coverage per year; AXA offers 60 days. If you visit the UK frequently, this matters. Extended UK stays may require a separate UK add-on or switching to domestic UK cover temporarily.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Currency Considerations</h3>
      <p class="text-neutral-700">Bupa bills natively in GBP, avoiding currency conversion. Cigna and AXA offer GBP payment options. If you're paid in GBP or maintain UK accounts, this simplifies payments. Currency fluctuations can affect USD or EUR-denominated premiums for UK expats.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Brexit Considerations</h3>
      <p class="text-neutral-700">Post-Brexit, UK expats in the EU face different healthcare access rules. EHIC replacement (GHIC) has limitations. Private international insurance provides certainty regardless of bilateral agreements. S1 forms for pensioners still work in some countries but aren't guaranteed long-term.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">UK Private Hospital Access</h3>
      <p class="text-neutral-700">When visiting the UK, you'll want access to private hospitals for routine and specialist care. Bupa has the largest UK network (Nuffield, Spire, BMI, HCA). Cigna and AXA have good networks but may have fewer direct billing options. Check specific hospitals in areas you visit.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose Cigna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You want strong worldwide coverage</li>
        <li>UK call center support matters</li>
        <li>You travel globally beyond Europe</li>
        <li>You want flexible plan options</li>
        <li>US coverage may be needed</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose Bupa If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>UK hospital access is priority</li>
        <li>You want native GBP billing</li>
        <li>Mental health coverage matters</li>
        <li>Familiar British service appeals</li>
        <li>You visit UK frequently</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose AXA If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is primary concern</li>
        <li>You're based in Europe</li>
        <li>60 days UK coverage suffices</li>
        <li>You want family value</li>
        <li>European network strength matters</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Do I still qualify for NHS treatment?</h3>
      <p class="text-neutral-700">After 12 months abroad, you're generally no longer "ordinarily resident" in the UK and lose automatic NHS entitlement. You can still access NHS as an overseas visitor, but charges apply for most treatments. Private insurance ensures seamless UK healthcare access without navigating NHS visitor rules.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What happens if I move back to the UK permanently?</h3>
      <p class="text-neutral-700">International plans typically don't cover UK residents full-time. If you return permanently, you'd need to switch to UK domestic private health insurance (Bupa UK, AXA Health UK, etc.) or rely on NHS. Most plans allow conversion to domestic products. Plan the transition—don't have a coverage gap.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I use my cover for routine care during UK visits?</h3>
      <p class="text-neutral-700">Yes, within your plan's UK coverage limits (typically 60-90 days/year). You can see UK private GPs, specialists, and access private hospitals. Routine checkups, dental, and optical may depend on your plan level. Direct billing is available at most major UK private hospitals with these insurers.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How does Brexit affect my coverage in Europe?</h3>
      <p class="text-neutral-700">Private international insurance is unaffected by Brexit—it's a contract between you and the insurer. What's changed is public healthcare access (EHIC/GHIC limitations). With private cover, you have the same access to European hospitals regardless of bilateral agreements between UK and EU countries.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Should I maintain UK private insurance alongside international?</h3>
      <p class="text-neutral-700">Generally unnecessary—it's expensive to maintain both. International plans with UK coverage add-ons provide what you need for visits. If you spend more than 90 days in the UK annually, you may need to reconsider your residency status and insurance approach. Most expats find international cover sufficient.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Are UK prescriptions covered abroad?</h3>
      <p class="text-neutral-700">Yes, prescription medications are covered by all three insurers. You can fill prescriptions locally in your country of residence. If you need UK-specific medications, you may need to arrange supply during UK visits or find local equivalents. Chronic medication management is covered under outpatient benefits.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> UK expat status and NHS entitlement depend on individual circumstances. This comparison provides general guidance only. Tax implications of insurance payments vary by residence country. Consult a qualified adviser for personal circumstances. Coverage details and prices should be verified directly with insurers.
    </p>
  </div>
</PageShell>
