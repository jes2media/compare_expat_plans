---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Bupa vs SafetyWing: Best International Health Insurance for Scandinavia";
const description = "Compare Cigna Global, Bupa Global, and SafetyWing for expats in Scandinavia and the Nordic region. Coverage analysis for Sweden, Norway, Denmark, Finland, and Iceland.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mainComparisonRows = [
  { feature: 'Nordic Network', cigna: 'Strong', bupa: 'Strong', safetywing: 'Claims-based' },
  { feature: 'Private Hospital Access', cigna: 'Excellent', bupa: 'Excellent', safetywing: 'Limited' },
  { feature: 'Wait Time Bypass', cigna: 'Yes', bupa: 'Yes', safetywing: 'Limited' },
  { feature: 'Mental Health', cigna: 'Comprehensive', bupa: 'Excellent', safetywing: 'Limited' },
  { feature: 'EU-wide Coverage', cigna: 'Included', bupa: 'Included', safetywing: 'Included' },
  { feature: 'Contract Flexibility', cigna: 'Annual', bupa: 'Annual', safetywing: 'Monthly' },
  { feature: 'Starting Price', cigna: '$$$', bupa: '$$$', safetywing: '$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Full coverage', bupa: 'Full coverage', safetywing: 'Up to $250K' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', bupa: 'Comprehensive', safetywing: 'Emergency only' },
  { coverage: 'Mental Health', cigna: 'Excellent', bupa: 'Unlimited', safetywing: 'Limited' },
  { coverage: 'Dental', cigna: 'Optional add-on', bupa: 'Optional add-on', safetywing: 'Emergency only' },
  { coverage: 'Preventive Care', cigna: 'Included', bupa: 'Comprehensive', safetywing: 'Not included' },
  { coverage: 'Maternity', cigna: '12-month wait', bupa: '12-month wait', safetywing: 'Limited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const pricingRows = [
  { profile: 'Single, 35, Sweden', cigna: '$4,500-6,200/yr', bupa: '$4,800-6,500/yr', safetywing: '$550-700/yr' },
  { profile: 'Single, 35, Norway', cigna: '$5,000-6,800/yr', bupa: '$5,200-7,200/yr', safetywing: '$550-700/yr' },
  { profile: 'Couple, 45, Denmark', cigna: '$9,500-13,000/yr', bupa: '$10,000-13,500/yr', safetywing: '$1,400-1,800/yr' },
  { profile: 'Family of 4, Finland', cigna: '$16,000-22,000/yr', bupa: '$17,000-23,000/yr', safetywing: '$2,200-2,800/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'scandinavia-considerations', text: 'Scandinavia Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Best Insurance for Europe', href: '/best/europe' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want comprehensive private healthcare access to bypass Nordic public system wait times, with excellent mental health coverage and strong regional networks.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You want premium private coverage with unlimited mental health benefits and comprehensive wellness programs, particularly valuable for managing Nordic winter challenges.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-purple-800 text-sm">You're a young digital nomad relying primarily on Nordic public healthcare but wanting emergency backup and monthly flexibility at minimal cost.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Scandinavia presents a unique insurance situation: excellent public healthcare is available, but with potential wait times for non-emergency care. International health insurance provides private sector access, faster appointments, and coverage when traveling. The question is whether premium private access is worth the cost.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers comprehensive private healthcare access across Scandinavia, enabling expats to bypass public system wait times for specialist appointments and elective procedures. Their strong mental health coverage is particularly valuable given Nordic winter challenges.</p>

      <h3>Strengths for Scandinavia</h3>
      <ul>
        <li>Direct access to private hospitals and specialists</li>
        <li>Bypass public healthcare wait times</li>
        <li>Excellent mental health coverage for seasonal affective challenges</li>
        <li>Strong networks in Stockholm, Oslo, Copenhagen, Helsinki</li>
        <li>Full EU coverage for travel within Europe</li>
        <li>English-speaking care coordination</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—significant cost given free public option</li>
        <li>Annual commitment required</li>
        <li>May duplicate public healthcare access</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global provides premium private healthcare access with excellent wellness benefits. Their unlimited mental health coverage is particularly valuable in Scandinavia, where seasonal affective disorder and winter-related mental health challenges affect many expats.</p>

      <h3>Strengths for Scandinavia</h3>
      <ul>
        <li>Unlimited mental health sessions—crucial for Nordic winters</li>
        <li>Premium private hospital access across the region</li>
        <li>Comprehensive wellness and preventive care</li>
        <li>Health screening programs</li>
        <li>Fast access to specialists without wait times</li>
        <li>Full European coverage</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums in an already expensive region</li>
        <li>Annual commitment</li>
        <li>Premium coverage when public system is very good</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing offers budget-friendly coverage for digital nomads and expats who plan to use Nordic public healthcare for routine care but want emergency backup and travel coverage. Their low cost makes sense when public healthcare handles most needs.</p>

      <h3>Strengths for Scandinavia</h3>
      <ul>
        <li>Dramatically lower cost than premium providers</li>
        <li>Monthly flexibility—no annual commitment</li>
        <li>Good emergency and hospitalization coverage</li>
        <li>Travel coverage throughout Europe</li>
        <li>Complements free public healthcare access</li>
        <li>Simple enrollment for transient expats</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>No private healthcare network—claims-based only</li>
        <li>Limited mental health coverage</li>
        <li>Emergency-only outpatient—no routine private care</li>
        <li>Won't bypass public system wait times</li>
        <li>$250K limit may concern some</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>The key difference in Scandinavia is access to private healthcare versus relying on public systems. Cigna and Bupa provide private sector access; SafetyWing supplements public care with emergency coverage.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Scandinavia is expensive for international health insurance due to high local healthcare costs. Norway typically has the highest premiums, followed by Sweden and Denmark. SafetyWing's flat global pricing is dramatically cheaper but provides different coverage.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific country, age, health history, and coverage level. Nordic countries have high healthcare costs reflected in premiums.</p>
    </section>

    <section id="scandinavia-considerations" class="mb-12">
      <h2>Scandinavia Insurance Considerations</h2>

      <h3>Excellent Public Healthcare</h3>
      <p>Nordic countries have universal healthcare systems providing good care at low or no cost. The question isn't coverage quality—it's access speed and convenience. Private insurance provides faster appointments and more choice, but public care handles emergencies excellently.</p>

      <h3>Wait Times for Non-Emergency Care</h3>
      <p>Public healthcare wait times for specialists and elective procedures can be significant—weeks to months depending on the condition. Private insurance from Cigna or Bupa provides immediate access to private facilities, bypassing these queues.</p>

      <h3>Mental Health and Seasonal Challenges</h3>
      <p>Nordic winters with limited daylight affect mental health. Seasonal affective disorder (SAD) is common among expats. Public mental health services have wait times. Bupa's unlimited mental health coverage or Cigna's comprehensive support ensures quick access to therapy.</p>

      <h3>Dental Care</h3>
      <p>Dental care is expensive in Scandinavia and often not fully covered by public systems. All three providers offer dental as an add-on (or emergency-only for SafetyWing). Consider adding dental coverage given regional costs.</p>

      <h3>Registration and Residency</h3>
      <p>Public healthcare access typically requires residency registration (personnummer in Sweden, etc.). New expats may have a gap before registration completes—international insurance provides immediate coverage during this period.</p>

      <h3>EU/Schengen Considerations</h3>
      <p>Nordic countries are in the EU (except Norway and Iceland, which have equivalent arrangements). All three providers cover EU-wide travel seamlessly, important for expats who travel within Europe.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Professionals wanting private access</li>
            <li>• Those unwilling to wait for specialists</li>
            <li>• Expats prioritizing mental health</li>
            <li>• Families seeking comprehensive care</li>
            <li>• Corporate assignees</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Executives and senior professionals</li>
            <li>• Those prioritizing mental health</li>
            <li>• Expats wanting wellness programs</li>
            <li>• Those with employer contributions</li>
            <li>• Premium coverage seekers</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Digital nomads</li>
            <li>• Young healthy expats</li>
            <li>• Those comfortable with public healthcare</li>
            <li>• Budget-conscious travelers</li>
            <li>• Short-term Nordic stays</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do I need private insurance if Nordic public healthcare is free?</h3>
          <p class="text-neutral-700">It depends on your priorities. Public healthcare is excellent for emergencies and eventually handles everything, but wait times for specialists can be long. Private insurance provides faster access and more choice. It's about convenience and speed, not coverage quality.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How long are public healthcare wait times in Scandinavia?</h3>
          <p class="text-neutral-700">Varies by country and condition. Specialist appointments can take weeks to months. Elective procedures may have longer waits. Emergencies are handled immediately. Private insurance eliminates these waits through direct private sector access.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is mental health coverage important for Scandinavia expats?</h3>
          <p class="text-neutral-700">Very important. Nordic winters with limited daylight commonly cause seasonal affective disorder among expats. Public mental health services have wait times. Private insurance ensures quick access to therapy when needed.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage before I get my residence registration?</h3>
          <p class="text-neutral-700">New expats typically wait weeks or months for full residency registration (personnummer, etc.) required for public healthcare. International insurance provides immediate coverage during this gap period.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I add dental coverage in Scandinavia?</h3>
          <p class="text-neutral-700">Consider it. Dental care is expensive in Nordic countries and often not fully covered by public systems. The add-on cost may be worthwhile given high regional dental prices.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does SafetyWing work for living in Scandinavia long-term?</h3>
          <p class="text-neutral-700">It can work if you're comfortable using public healthcare for routine care and want SafetyWing as emergency backup and travel coverage. However, you won't get private sector access or bypass public wait times.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
