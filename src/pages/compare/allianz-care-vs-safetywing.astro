---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'quick-decision', text: 'Quick Decision Guide', level: 2 },
  { id: 'product-differences', text: 'Understanding the Product Difference', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'mental-health', text: 'Mental Health Coverage', level: 2 },
  { id: 'pricing', text: 'Pricing Analysis', level: 2 },
  { id: 'financial-backing', text: 'Financial Stability', level: 2 },
  { id: 'network-claims', text: 'Networks and Claims', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'Best Digital Nomad Insurance', href: '/best/digital-nomad-insurance' },
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
  { title: 'Portugal Insurance Guide', href: '/countries/portugal/insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Coverage Area' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing Nomad' },
];

const coverageRows = [
  { feature: 'Product Type', allianz: 'Health Insurance', safetywing: 'Travel Medical' },
  { feature: 'Maximum Coverage', allianz: '€1.35M–Unlimited', safetywing: '$250,000' },
  { feature: 'Inpatient Hospital', allianz: 'Full coverage', safetywing: 'Emergency only' },
  { feature: 'Outpatient Care', allianz: 'Full coverage', safetywing: 'Limited to emergencies' },
  { feature: 'Mental Health', allianz: 'Comprehensive', safetywing: 'Not covered' },
  { feature: 'Maternity', allianz: 'Optional add-on', safetywing: 'Not covered' },
  { feature: 'Pre-Existing Conditions', allianz: 'After waiting period', safetywing: 'Excluded' },
  { feature: 'Routine Checkups', allianz: 'Included', safetywing: 'Not covered' },
  { feature: 'Chronic Conditions', allianz: 'Covered', safetywing: 'Not covered' },
  { feature: 'Prescription Drugs', allianz: 'Covered', safetywing: 'Emergency prescriptions only' },
  { feature: 'Dental', allianz: 'Optional add-on', safetywing: 'Emergency only ($1,000 max)' },
  { feature: 'Medical Evacuation', allianz: 'Included', safetywing: '$100,000 limit' },
];

const mentalHealthColumns = [
  { key: 'aspect', header: 'Mental Health Aspect' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mentalHealthRows = [
  { aspect: 'Outpatient Therapy', allianz: 'Covered (limits vary by plan)', safetywing: 'Not covered' },
  { aspect: 'Inpatient Psychiatric', allianz: 'Covered', safetywing: 'Not covered' },
  { aspect: 'Counseling Services', allianz: 'Covered', safetywing: 'Not covered' },
  { aspect: 'Medication', allianz: 'Covered', safetywing: 'Not covered' },
  { aspect: 'Waiting Period', allianz: 'Varies by plan', safetywing: 'N/A' },
  { aspect: 'Crisis Intervention', allianz: 'Covered', safetywing: 'Not covered' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'difference', header: 'Monthly Gap' },
];

const pricingRows = [
  { profile: 'Single, Age 25', allianz: '€100–140/mo', safetywing: '$42/mo', difference: '€60–100/mo' },
  { profile: 'Single, Age 30', allianz: '€120–160/mo', safetywing: '$45/mo', difference: '€75–115/mo' },
  { profile: 'Single, Age 40', allianz: '€160–210/mo', safetywing: '$64/mo', difference: '€95–145/mo' },
  { profile: 'Single, Age 50', allianz: '€220–290/mo', safetywing: '$89/mo', difference: '€130–200/mo' },
  { profile: 'Couple, Age 35', allianz: '€240–320/mo', safetywing: '$90/mo', difference: '€150–230/mo' },
  { profile: 'Family of 4', allianz: '€400–550/mo', safetywing: '$140/mo', difference: '€260–410/mo' },
];

const financialColumns = [
  { key: 'metric', header: 'Financial Metric' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const financialRows = [
  { metric: 'Parent Company', allianz: 'Allianz SE (Germany)', safetywing: 'SafetyWing Inc. (startup)' },
  { metric: 'Founded', allianz: '1890', safetywing: '2017' },
  { metric: 'Total Assets', allianz: '€1.1+ trillion', safetywing: 'Venture-backed' },
  { metric: 'Regulatory Oversight', allianz: 'EU Insurance Directive', safetywing: 'US surplus lines' },
  { metric: 'AM Best Rating', allianz: 'A+ (Superior)', safetywing: 'Not rated' },
  { metric: 'Claims History', allianz: '130+ years', safetywing: '7+ years' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Claims Aspect' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const claimsRows = [
  { aspect: 'Direct Billing', allianz: 'Extensive network', safetywing: 'Limited' },
  { aspect: 'Reimbursement Time', allianz: '5–10 business days', safetywing: '7–14 business days' },
  { aspect: 'Claims Portal', allianz: 'Full-featured online', safetywing: 'Basic online' },
  { aspect: 'Mobile App', allianz: 'Yes, full functionality', safetywing: 'Basic app' },
  { aspect: 'Support Languages', allianz: '15+ languages', safetywing: 'English primarily' },
  { aspect: 'Case Managers', allianz: 'Dedicated for complex cases', safetywing: 'Not available' },
];
---

<PageShell
  title="Allianz Care vs SafetyWing: EU Health Insurance vs Travel Medical"
  description="Compare Allianz Care and SafetyWing for expat coverage. Traditional German-backed health insurance vs startup travel medical—understand what you're actually buying."
  headline="Allianz Care vs SafetyWing: EU Insurance Giant vs Nomad Startup"
  subheadline="This comparison is about two fundamentally different products. Make sure you understand what you're choosing between."
  heroBackgroundImage="/images/compare/allianz-vs-safetywing-hero-bg.png"
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Your Options"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Overview</h2>
  <p>
    This comparison requires an upfront warning: <strong>Allianz Care and SafetyWing are fundamentally different products</strong>. Comparing them is like comparing a car to a bicycle—both get you somewhere, but they serve different purposes.
  </p>
  <p>
    <strong>Allianz Care</strong> is international health insurance backed by Allianz SE, the German insurance giant founded in 1890 with over €1.1 trillion in assets. They offer comprehensive medical coverage regulated under EU insurance law, with strong mental health benefits, chronic condition coverage, and the full range of services you'd expect from major health insurance.
  </p>
  <p>
    <strong>SafetyWing</strong> is a venture-backed startup founded in 2017 offering travel medical insurance designed for digital nomads. They provide affordable emergency coverage with no long-term commitment—but it's explicitly not health insurance. Mental health, chronic conditions, routine care, and maternity are not covered.
  </p>
  <p>
    The price difference is dramatic: SafetyWing costs 60–75% less than Allianz Care. But that savings comes from covering emergency situations only, not your ongoing healthcare needs. This guide will help you understand exactly what you're trading when you choose between them.
  </p>

  <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 my-6">
    <p class="font-semibold text-amber-800 mb-2">Critical Distinction</p>
    <p class="text-amber-900 text-sm mb-0">
      Allianz Care is health insurance that covers your ongoing medical needs. SafetyWing is travel medical insurance for emergencies only. If you have any regular healthcare needs—prescriptions, therapy, chronic conditions—SafetyWing explicitly won't cover them.
    </p>
  </div>

  <h2 id="quick-decision">Quick Decision Guide</h2>
  <p>
    Don't have time for the full comparison? Here's the essential decision framework.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose Allianz Care If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-0">
        <li>✓ You take any regular medications</li>
        <li>✓ You have or need mental health care</li>
        <li>✓ You have chronic conditions (diabetes, hypertension, etc.)</li>
        <li>✓ You want routine checkups covered</li>
        <li>✓ You're settling long-term in one country</li>
        <li>✓ You want EU regulatory protections</li>
        <li>✓ Financial stability of your insurer matters to you</li>
      </ul>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose SafetyWing If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-0">
        <li>✓ You're young and healthy with no ongoing needs</li>
        <li>✓ You only need emergency/accident coverage</li>
        <li>✓ Budget is your primary constraint</li>
        <li>✓ You'll pay out-of-pocket for routine care</li>
        <li>✓ You move countries frequently</li>
        <li>✓ You understand and accept the coverage limitations</li>
        <li>✓ You have savings for non-emergency care</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Need Comprehensive Coverage?"
    description="If you have any ongoing healthcare needs, comprehensive health insurance is the safer choice."
    buttonText="Compare Health Insurance Options"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="product-differences">Understanding the Product Difference</h2>
  <p>
    Before diving into specific features, it's crucial to understand that these products serve different purposes:
  </p>

  <h3>Allianz Care: International Health Insurance</h3>
  <p>
    Allianz Care operates as proper health insurance under EU regulatory frameworks. This means:
  </p>
  <ul>
    <li><strong>Comprehensive coverage:</strong> Hospital care, outpatient visits, prescriptions, mental health, preventive care—the full spectrum of medical services</li>
    <li><strong>Chronic condition management:</strong> Ongoing conditions like diabetes, hypertension, or autoimmune disorders are covered once you're past any applicable waiting periods</li>
    <li><strong>Pre-existing conditions:</strong> Can be covered after a moratorium period (typically conditions you haven't needed treatment for in 2 years)</li>
    <li><strong>Regulatory protections:</strong> EU insurance directives require specific consumer protections, capital reserves, and dispute resolution processes</li>
    <li><strong>Long-term relationship:</strong> Designed for ongoing coverage, with guaranteed renewability and price adjustments tied to age bands rather than individual claims</li>
  </ul>

  <h3>SafetyWing: Travel Medical Insurance</h3>
  <p>
    SafetyWing is explicitly travel medical insurance, not health insurance. This means:
  </p>
  <ul>
    <li><strong>Emergency focus:</strong> Covers unexpected illness and accidents—the things that would ruin a trip</li>
    <li><strong>No chronic care:</strong> Conditions you have before purchasing, or that develop into ongoing needs, aren't covered</li>
    <li><strong>No routine care:</strong> Checkups, preventive screenings, or wellness visits aren't covered</li>
    <li><strong>No mental health:</strong> Therapy, counseling, psychiatric care, and mental health medications aren't covered</li>
    <li><strong>Short-term nature:</strong> Designed for travelers who have primary health coverage elsewhere or who don't need ongoing care</li>
  </ul>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">The "What If I Get Diagnosed" Question</h3>
    <p class="text-neutral-600 mb-0">
      Here's a critical scenario: What if you're healthy when you buy SafetyWing, but then you're diagnosed with something that requires ongoing treatment? SafetyWing would cover the initial emergency diagnosis and stabilization—but ongoing treatment for that condition wouldn't be covered. With Allianz Care, the same diagnosis would trigger coverage for the initial treatment AND ongoing management, because that's how health insurance works.
    </p>
  </div>

  <h2 id="coverage-comparison">Coverage Comparison</h2>
  <p>
    The coverage gap between these products is substantial. Allianz Care covers nearly everything you'd expect from health insurance. SafetyWing covers emergencies and unexpected acute illness only.
  </p>

  <ComparisonTable columns={coverageColumns} rows={coverageRows} />

  <h3>What This Means in Practice</h3>
  <p>
    Let's translate this table into real scenarios:
  </p>
  <ul>
    <li><strong>Food poisoning abroad:</strong> Both cover emergency treatment and hospitalization</li>
    <li><strong>Breaking your arm hiking:</strong> Both cover the ER visit, X-rays, and casting</li>
    <li><strong>Annual physical exam:</strong> Allianz covers it; SafetyWing doesn't</li>
    <li><strong>Ongoing anxiety treatment:</strong> Allianz covers therapy and medication; SafetyWing covers neither</li>
    <li><strong>Blood pressure medication refills:</strong> Allianz covers them; SafetyWing doesn't</li>
    <li><strong>Colonoscopy screening at 45:</strong> Allianz covers it; SafetyWing doesn't</li>
    <li><strong>Developing Type 2 diabetes:</strong> Allianz covers ongoing management; SafetyWing covers initial emergency only</li>
  </ul>

  <h3>The $250,000 Maximum: A Reality Check</h3>
  <p>
    SafetyWing's $250,000 maximum coverage sounds like a lot, but context matters:
  </p>
  <ul>
    <li>A serious car accident with surgery and ICU stay can exceed $250,000 in the US</li>
    <li>Cancer treatment often runs $300,000–$500,000+ over several years</li>
    <li>Heart surgery plus rehabilitation can reach $200,000–$400,000</li>
    <li>Premature birth with NICU stay regularly exceeds $500,000</li>
  </ul>
  <p>
    For young, healthy travelers visiting countries with reasonable healthcare costs, $250,000 is usually adequate for emergencies. But it's a cap that could matter in a truly catastrophic situation—especially in the US.
  </p>

  <h2 id="mental-health">Mental Health Coverage</h2>
  <p>
    Mental health is one of the starkest differences between these products. For expats and digital nomads, who often face isolation, culture shock, and the stress of constant adaptation, this gap can be significant.
  </p>

  <ComparisonTable columns={mentalHealthColumns} rows={mentalHealthRows} />

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Allianz Care Mental Health Coverage</h3>
    <p class="text-neutral-700 mb-4">
      Allianz Care includes mental health benefits in their comprehensive plans:
    </p>
    <ul class="text-neutral-700 mb-0">
      <li>Outpatient therapy sessions (limits vary by plan tier)</li>
      <li>Inpatient psychiatric hospitalization when medically necessary</li>
      <li>Prescription psychiatric medications</li>
      <li>Access to their global provider network for mental health specialists</li>
      <li>Crisis intervention and emergency psychiatric services</li>
    </ul>
  </div>

  <p>
    <strong>If you currently see a therapist</strong>, take medication for anxiety or depression, or might need mental health support while abroad, SafetyWing simply won't work for you. There's no workaround—mental health is explicitly excluded.
  </p>

  <h2 id="pricing">Pricing Analysis</h2>
  <p>
    The price difference between Allianz Care and SafetyWing is dramatic. SafetyWing costs roughly 60–75% less across all age groups. But you're not comparing equivalent products—you're comparing health insurance to travel medical insurance.
  </p>

  <ComparisonTable columns={pricingColumns} rows={pricingRows} />

  <h3>Understanding the Price Gap</h3>
  <p>
    Why does Allianz Care cost so much more? Because it covers so much more:
  </p>
  <ul>
    <li><strong>The €75–115/month gap (age 30)</strong> pays for routine care, mental health coverage, chronic condition management, preventive screenings, and prescription drug coverage beyond emergencies</li>
    <li><strong>You're paying for EU regulatory compliance:</strong> Allianz maintains significant capital reserves and operates under strict consumer protection laws</li>
    <li><strong>You're paying for a 130-year track record:</strong> The price reflects the certainty that claims will be paid by a company that will exist in 10 years</li>
    <li><strong>You're paying for comprehensive support:</strong> Case managers, multilingual support, and direct billing relationships take resources to maintain</li>
  </ul>

  <h3>When SafetyWing's Price Makes Sense</h3>
  <p>
    SafetyWing's pricing is excellent <em>if you actually only need emergency coverage</em>:
  </p>
  <ul>
    <li>You're genuinely healthy with no prescriptions or ongoing care needs</li>
    <li>You have savings to pay out-of-pocket for routine care ($100–300 per doctor visit in most countries)</li>
    <li>You're comfortable with the risk of uncovered situations</li>
    <li>You prioritize flexibility and low monthly costs over comprehensive protection</li>
  </ul>

  <h3>Cost of Out-of-Pocket Care</h3>
  <p>
    If you choose SafetyWing, budget for these common out-of-pocket expenses:
  </p>
  <ul>
    <li>Doctor visits: $50–200 depending on country</li>
    <li>Therapy sessions: $80–200 per session</li>
    <li>Prescription medications: $20–300/month depending on drugs</li>
    <li>Annual checkup with bloodwork: $150–400</li>
    <li>Dental cleaning: $50–150</li>
  </ul>

  <CTABox
    title="Calculate Your True Costs"
    description="Factor in likely out-of-pocket expenses when comparing monthly premiums."
    buttonText="View Pricing Details"
    buttonHref="/go/cigna-global"
  />

  <h2 id="financial-backing">Financial Stability Comparison</h2>
  <p>
    Insurance is a promise to pay future claims. The financial stability of your insurer determines whether that promise will be kept—especially for large claims or if you need coverage years from now.
  </p>

  <ComparisonTable columns={financialColumns} rows={financialRows} />

  <h3>What This Means for You</h3>
  <p>
    <strong>Allianz Care</strong> is backed by one of the world's largest insurance companies. Allianz SE:
  </p>
  <ul>
    <li>Has survived two World Wars, multiple financial crises, and 130+ years of market conditions</li>
    <li>Maintains €1.1+ trillion in assets to back their promises</li>
    <li>Holds an A+ (Superior) rating from AM Best, indicating excellent claims-paying ability</li>
    <li>Is regulated by BaFin (German federal financial regulator) under strict EU insurance laws</li>
  </ul>

  <p>
    <strong>SafetyWing</strong> is a venture-backed startup that's grown rapidly since 2017. They:
  </p>
  <ul>
    <li>Have raised significant venture capital and serve over 170,000 customers</li>
    <li>Use Tokio Marine as their claims administrator (a major, stable company)</li>
    <li>Are regulated as surplus lines insurance in the US, which has fewer protections than admitted insurance</li>
    <li>Don't have the same track record or capital reserves as established insurers</li>
  </ul>

  <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 my-6">
    <p class="font-semibold text-amber-800 mb-2">A Note on Startup Risk</p>
    <p class="text-amber-900 text-sm mb-0">
      SafetyWing appears to be well-run and has shown strong growth. Most SafetyWing customers report positive experiences. However, a company founded in 2017 simply doesn't have the track record or capital reserves of a 130-year-old insurance giant. For emergency travel medical coverage, this is probably fine. For long-term health insurance, the stability difference matters more.
    </p>
  </div>

  <h2 id="network-claims">Provider Networks and Claims</h2>
  <p>
    How easily can you access care and get reimbursed? The experience differs significantly between these providers.
  </p>

  <ComparisonTable columns={claimsColumns} rows={claimsRows} />

  <h3>Allianz Care Claims Experience</h3>
  <p>
    Allianz Care has built extensive direct billing relationships over decades:
  </p>
  <ul>
    <li><strong>Direct billing:</strong> At many hospitals and clinics worldwide, Allianz can pay the provider directly—you don't need to pay upfront</li>
    <li><strong>Hospital coordination:</strong> For planned procedures, Allianz can pre-authorize and coordinate payment before you arrive</li>
    <li><strong>Full-featured portal:</strong> Submit claims, track status, download EOBs, and manage your policy online</li>
    <li><strong>Multilingual support:</strong> 15+ languages with specialists who understand local healthcare systems</li>
    <li><strong>Case managers:</strong> For complex situations, dedicated case managers coordinate your care</li>
  </ul>

  <h3>SafetyWing Claims Experience</h3>
  <p>
    SafetyWing's claims process is simpler but more limited:
  </p>
  <ul>
    <li><strong>Primarily reimbursement:</strong> You typically pay for care and submit claims afterward</li>
    <li><strong>Online submission:</strong> Claims can be submitted through their website or app</li>
    <li><strong>English-focused support:</strong> Customer service is primarily in English</li>
    <li><strong>No case management:</strong> For complex medical situations, you're largely on your own</li>
    <li><strong>Simpler process for simpler coverage:</strong> Since coverage is limited to emergencies, claims are usually straightforward</li>
  </ul>

  <h2 id="scenarios">Real-World Scenarios</h2>
  <p>
    Let's walk through specific situations to see how each plan performs in practice.
  </p>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 1: The Emergency Appendectomy</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're in Portugal when you experience severe abdominal pain. You're rushed to the hospital and need emergency surgery.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Full coverage for ER, surgery, hospital stay, and follow-up care. Direct billing likely available. Estimated cost to you: deductible only (€0–1,500 depending on plan).</p>
      <p class="text-neutral-600 mb-0"><strong>SafetyWing:</strong> Covered as emergency. You may need to pay upfront and submit for reimbursement. $250 deductible, then covered up to $250,000. Follow-up care covered if still emergency-related.</p>
      <p class="text-green-700 font-medium mt-2">Winner: Both handle this well—it's exactly what travel medical insurance is designed for.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 2: Developing Depression While Abroad</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> Six months into your expat life, you're struggling with depression. You need therapy and possibly medication.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Mental health coverage kicks in. You can see a therapist (with session limits depending on plan), get prescribed antidepressants, and access ongoing support. Network psychiatrists available in major cities.</p>
      <p class="text-neutral-600 mb-0"><strong>SafetyWing:</strong> Not covered. Mental health is explicitly excluded. You'll pay 100% out-of-pocket for therapy ($80–200/session) and medication ($20–100+/month).</p>
      <p class="text-blue-700 font-medium mt-2">Winner: Allianz Care—this is exactly the coverage gap that matters.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 3: Routine Health Maintenance</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're 35, healthy, but want an annual physical, bloodwork, and maybe a dental cleaning.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Annual wellness visit covered. Bloodwork covered. Dental cleaning covered if you have dental add-on. Total out-of-pocket: minimal or zero.</p>
      <p class="text-neutral-600 mb-0"><strong>SafetyWing:</strong> None of this is covered. You'll pay: Physical ($100–300), bloodwork ($50–200), dental ($50–150). Total out-of-pocket: $200–650.</p>
      <p class="text-blue-700 font-medium mt-2">Winner: Allianz Care—routine care adds up over time.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 4: The Healthy Young Nomad</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're 26, completely healthy, take no medications, and haven't seen a doctor in years. You're hopping between Southeast Asian countries.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Excellent coverage you may never use. Cost: ~€120/month. Annual cost: ~€1,440.</p>
      <p class="text-neutral-600 mb-0"><strong>SafetyWing:</strong> Emergency coverage for accidents and unexpected illness. Cost: ~$42/month. Annual cost: ~$504. Occasional out-of-pocket: $100–300 if you need minor care.</p>
      <p class="text-amber-700 font-medium mt-2">Winner: SafetyWing—if you truly only need emergency coverage, you'd save ~$900/year.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 5: Diagnosed with Chronic Condition</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're traveling when you develop severe headaches. Testing reveals high blood pressure requiring ongoing medication and monitoring.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Initial diagnosis covered. Ongoing hypertension management covered—medication, regular checkups, specialist visits. You're protected long-term.</p>
      <p class="text-neutral-600 mb-0"><strong>SafetyWing:</strong> Emergency diagnosis and initial stabilization covered. But ongoing medication and management? Not covered—it's now a chronic condition. You'll pay out-of-pocket forever or need to find other insurance.</p>
      <p class="text-blue-700 font-medium mt-2">Winner: Allianz Care—the difference between coverage and no coverage for a condition you'll manage for life.</p>
    </div>
  </div>

  <h2 id="who-should-choose">Who Should Choose Which</h2>
  <p>
    Based on our analysis, here's detailed guidance on who each product serves best.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Allianz Care Is Right For:</h3>
      <ul class="space-y-3 text-neutral-700">
        <li><strong>Anyone with ongoing healthcare needs:</strong> If you take any regular medication or see any doctor regularly, you need health insurance</li>
        <li><strong>Mental health coverage needs:</strong> If you have or might need therapy, counseling, or psychiatric care</li>
        <li><strong>Chronic condition management:</strong> Diabetes, hypertension, autoimmune conditions, or any condition requiring ongoing treatment</li>
        <li><strong>Long-term expats:</strong> If you're settling in one country for years, proper health insurance makes more sense</li>
        <li><strong>Families with children:</strong> Kids need checkups, vaccinations, and pediatric care that travel medical doesn't cover</li>
        <li><strong>Risk-averse individuals:</strong> If the idea of uncovered situations stresses you, comprehensive coverage provides peace of mind</li>
        <li><strong>Those who value regulatory protection:</strong> EU insurance regulations provide real consumer protections</li>
      </ul>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">SafetyWing Is Right For:</h3>
      <ul class="space-y-3 text-neutral-700">
        <li><strong>Genuinely healthy young people:</strong> If you haven't needed healthcare beyond emergencies and don't expect to</li>
        <li><strong>Budget-conscious nomads:</strong> If cost is your primary constraint and you accept the coverage limitations</li>
        <li><strong>Short-term travelers:</strong> If you're traveling for months, not years, and have home-country coverage to return to</li>
        <li><strong>Those comfortable with risk:</strong> If you have savings to handle out-of-pocket costs and understand what's not covered</li>
        <li><strong>Frequent country-changers:</strong> If you're in a new country every few weeks, SafetyWing's flexibility is convenient</li>
        <li><strong>Those with other primary coverage:</strong> If you have home-country insurance and just need travel medical as a supplement</li>
        <li><strong>Digital nomads who understand the trade-off:</strong> If you've consciously decided emergency coverage is sufficient for your needs</li>
      </ul>
    </div>
  </div>

  <h2 id="faq">Frequently Asked Questions</h2>

  <div class="space-y-6 my-8">
    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Can I switch from SafetyWing to Allianz Care later?</h3>
      <p class="text-neutral-600 mb-0">
        Yes, but any conditions that develop while on SafetyWing become pre-existing conditions for Allianz Care, subject to waiting periods or exclusions. It's harder to get comprehensive coverage after you already need it. If you think you might want health insurance eventually, it's often better to start earlier when you're healthier.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What if I get injured and need ongoing physical therapy?</h3>
      <p class="text-neutral-600 mb-0">
        With Allianz Care, physical therapy related to a covered injury would typically be covered. With SafetyWing, the initial emergency treatment is covered, but extended rehabilitation is limited. Once you're "stabilized," ongoing PT may not be covered. Check both policies carefully for rehabilitation limits.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Does SafetyWing cover me in my home country?</h3>
      <p class="text-neutral-600 mb-0">
        SafetyWing includes limited home country coverage (up to 30 days per 90 days for US citizens, 15 days for others). Allianz Care plans vary—some exclude home country coverage, others include it. Verify home country coverage if you'll be returning frequently.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What about visa requirements? Which plan satisfies them?</h3>
      <p class="text-neutral-600 mb-0">
        Allianz Care's comprehensive plans typically satisfy visa insurance requirements for EU residency visas and most other countries. SafetyWing may not meet requirements for residency visas that specify "health insurance" rather than "travel insurance." Always verify with the specific embassy or consulate.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Can I use both together?</h3>
      <p class="text-neutral-600 mb-0">
        You could theoretically use SafetyWing for emergency coverage while abroad and maintain separate coverage (like a national health system or home country plan) for comprehensive care. However, having two private international plans rarely makes financial sense. Choose the coverage level that matches your actual needs.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What happens if SafetyWing goes out of business?</h3>
      <p class="text-neutral-600 mb-0">
        As a surplus lines insurer, SafetyWing doesn't have the same guaranty fund protections as admitted insurers. If they failed, you might lose coverage with limited recourse. With Allianz Care, EU insurance regulations require capital reserves and provide stronger consumer protections. This risk matters more for long-term coverage than short-term travel insurance.
      </p>
    </div>
  </div>

  <h2 id="verdict">Our Verdict</h2>
  <p>
    This comparison isn't about which provider is "better"—it's about understanding that you're choosing between fundamentally different products with different purposes.
  </p>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Allianz Care: Real Health Insurance</h3>
    <p class="text-neutral-700 mb-0">
      If you want actual health insurance that covers your ongoing medical needs—routine care, mental health, chronic conditions, prescriptions—Allianz Care delivers. Backed by 130 years of history and €1.1+ trillion in assets, regulated under EU law with strong consumer protections, they offer the comprehensive coverage that most people think of when they think of "health insurance." The higher cost reflects the broader coverage and institutional stability.
    </p>
  </div>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">SafetyWing: Budget Emergency Coverage</h3>
    <p class="text-neutral-700 mb-0">
      If you're young, healthy, and genuinely only need emergency coverage, SafetyWing offers excellent value. Their affordable subscription model and flexibility suit the digital nomad lifestyle well. But be honest with yourself: if you have any regular healthcare needs, take any medications, or value mental health coverage, SafetyWing explicitly won't work for you. It's travel medical insurance, not health insurance—and that's not a criticism, just a fact.
    </p>
  </div>

  <p>
    <strong>The honest question to ask yourself:</strong> "If I got diagnosed with something that needed ongoing treatment—depression, diabetes, hypertension—would I be okay paying 100% out-of-pocket?" If that thought is stressful, you need health insurance like Allianz Care, not travel medical insurance like SafetyWing.
