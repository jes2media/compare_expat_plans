---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'family-features', text: 'Family Coverage Features', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/families', text: 'Family Insurance Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const mainComparisonRows = [
  { feature: 'Child Coverage Model', safetywing: 'Free (under 10)', img: 'Per-child pricing', cigna: 'Per-child pricing' },
  { feature: 'Maximum Age for Children', safetywing: '18 (or 26 student)', img: '26', cigna: '26' },
  { feature: 'Pediatric Care', safetywing: 'Basic', img: 'Comprehensive', cigna: 'Comprehensive' },
  { feature: 'Vaccinations', safetywing: 'Emergency only', img: 'Routine included', cigna: 'Routine included' },
  { feature: 'Well-Child Visits', safetywing: 'Not covered', img: 'Included', cigna: 'Included' },
  { feature: 'Pediatric Dental', safetywing: 'Not covered', img: 'Optional add-on', cigna: 'Optional add-on' },
  { feature: 'NICU Coverage', safetywing: 'Limited', img: 'Full coverage', cigna: 'Full coverage' },
  { feature: 'Family Maximum', safetywing: '$250K/person', img: '$2-8M', cigna: 'Unlimited' },
];

const pricingColumns = [
  { key: 'family', header: 'Family Size' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const pricingRows = [
  { family: 'Couple only', safetywing: '$168/mo', img: '$400-600/mo', cigna: '$700-900/mo' },
  { family: '+1 child (age 5)', safetywing: '$168/mo (free)', img: '$500-750/mo', cigna: '$850-1,100/mo' },
  { family: '+2 children (5, 8)', safetywing: '$168/mo (free)', img: '$600-900/mo', cigna: '$950-1,250/mo' },
  { family: '+3 children', safetywing: '$168/mo (free)', img: '$700-1,050/mo', cigna: '$1,100-1,400/mo' },
];
---

<PageShell
  title="SafetyWing vs IMG vs Cigna for Families | 2025 Comparison"
  description="Compare SafetyWing, IMG Global, and Cigna Global for family coverage. Expert analysis of child pricing, pediatric care, vaccinations, and family-specific benefits."
  headline="SafetyWing vs IMG vs Cigna: Families with Children"
  subheadline="Complete comparison for expat families—covering child pricing, pediatric care, well-child visits, vaccinations, and benefits that matter for kids abroad."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget</p>
        <p class="text-neutral-700 text-sm mb-4">Children under 10 covered free—unbeatable for budget-conscious families. Best for nomadic families who need basic coverage and aren't planning preventive care.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Strong pediatric coverage at mid-range pricing. Includes vaccinations, well-child visits, and comprehensive care without premium costs.</p>
        <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 mb-3">Most Comprehensive</p>
        <p class="text-neutral-700 text-sm mb-4">Premium family coverage with unlimited benefits, extensive network, and full pediatric services. Best for families prioritizing care quality over cost.</p>
        <a href="/providers/cigna-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Free Kids Under 10</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Nomad Focused</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing's family proposition is simple: children under 10 are covered free when traveling with a covered parent. For families with young children on tight budgets, this creates substantial savings—a family of four pays the same as a couple. The coverage is basic but solid for emergencies and unexpected illness.</p>

    <p class="text-neutral-700 mb-4">The tradeoff is coverage depth. SafetyWing doesn't include routine pediatric care, vaccinations, or well-child checkups. It's designed for families who either handle preventive care out-of-pocket, use local healthcare systems, or simply need emergency backup while traveling. For young, healthy families without complex medical needs, this approach makes financial sense.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Family Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Children under 10 free</li>
          <li>• Lowest family cost</li>
          <li>• Monthly subscription model</li>
          <li>• No long-term commitment</li>
          <li>• Simple signup process</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• No vaccinations covered</li>
          <li>• No well-child visits</li>
          <li>• Limited NICU coverage</li>
          <li>• $250K maximum per person</li>
          <li>• Emergency-focused coverage</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Pediatric Care</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Vaccinations</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Value Pricing</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global delivers comprehensive family coverage at mid-tier pricing. Pediatric plans include routine vaccinations, well-child checkups, and the preventive care that children need for healthy development abroad. The network is strong globally, making it easy to find pediatric specialists wherever you're based.</p>

    <p class="text-neutral-700 mb-4">For families settling in one location (rather than constant travel), IMG's structure works well. Children are priced individually, but rates are reasonable—typically 60-70% of adult rates. NICU coverage and complex pediatric care are fully included, providing security for unexpected complications. Dental coverage is available as an add-on for growing smiles.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Family Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Vaccinations included</li>
          <li>• Well-child visits covered</li>
          <li>• Full NICU coverage</li>
          <li>• Good pediatric network</li>
          <li>• Dental add-on available</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Per-child pricing adds up</li>
          <li>• Annual commitment typically</li>
          <li>• US coverage costs more</li>
          <li>• Some plan limits apply</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Premium Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Benefits</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Full Pediatric</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global represents the premium tier for family coverage. Unlimited annual benefits, the most extensive global network, and complete pediatric services—including vaccinations, well-child care, pediatric specialists, and developmental screenings. For families who want the best possible coverage, Cigna delivers without compromise.</p>

    <p class="text-neutral-700 mb-4">The investment is significant—Cigna family plans cost 2-3x budget options—but the coverage matches. Children stay on family plans until 26, with full adult benefits. NICU coverage is unlimited, pediatric dental/vision can be added, and you'll never question whether a treatment is covered. For families with complex medical needs or those wanting peace of mind, Cigna is the gold standard.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Family Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Unlimited coverage</li>
          <li>• Best global network</li>
          <li>• Full preventive care</li>
          <li>• Pediatric specialists included</li>
          <li>• Children covered to 26</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Premium pricing</li>
          <li>• Per-child rates are high</li>
          <li>• Annual commitment required</li>
          <li>• May be overkill for healthy families</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <CTABox
    title="Get Family Coverage Quotes"
    description="Compare actual pricing for your family size and children's ages across providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">How family size affects monthly costs (parents mid-30s):</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative for comprehensive coverage. SafetyWing price assumes children under 10. IMG and Cigna prices vary by specific plan chosen and coverage area. Actual quotes depend on ages, health history, and location.</p>
  </section>

  <section id="family-features" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Family Coverage Features</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Pediatric Essentials</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Routine vaccinations</li>
          <li>• Well-child checkups</li>
          <li>• Developmental screenings</li>
          <li>• Growth monitoring</li>
          <li>• Vision/hearing tests</li>
          <li>• Pediatric specialists</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Emergency & Serious Care</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Emergency hospitalization</li>
          <li>• NICU coverage</li>
          <li>• Pediatric surgery</li>
          <li>• Cancer treatment</li>
          <li>• Air ambulance</li>
          <li>• Medical evacuation</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Important Family Considerations</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Newborns</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Added within 30 days</li>
            <li>• Coverage from birth</li>
            <li>• NICU included (IMG/Cigna)</li>
            <li>• SafetyWing more limited</li>
            <li>• Maternity plan needed</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">School Age</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• School entry requirements</li>
            <li>• Sports physicals</li>
            <li>• Vaccination records</li>
            <li>• Accident coverage</li>
            <li>• International school access</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Teens/Young Adults</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Coverage to 18-26</li>
            <li>• Student status matters</li>
            <li>• Mental health support</li>
            <li>• Transition to own plan</li>
            <li>• Adult pricing applies</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Children are under 10</li>
          <li>• Budget is the priority</li>
          <li>• You only need emergency coverage</li>
          <li>• You'll handle preventive care separately</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You want vaccinations and checkups covered</li>
          <li>• Mid-range budget for comprehensive care</li>
          <li>• Settling in one location longer-term</li>
          <li>• Dental coverage for kids would help</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Premium coverage is worth the cost</li>
          <li>• Children have medical needs</li>
          <li>• Best network and specialists matter</li>
          <li>• You want unlimited benefits</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How do I add a newborn to my policy?</h3>
        <p class="text-neutral-700">Most insurers allow 30 days to add newborns, with coverage backdated to birth. Contact your insurer as soon as possible after birth. Pre-existing conditions don't apply to newborns if added within the window. For planned births, discuss adding the child before delivery so paperwork is ready.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are vaccinations covered for children?</h3>
        <p class="text-neutral-700">IMG and Cigna include routine childhood vaccinations with comprehensive plans. SafetyWing only covers vaccinations required after emergency exposures (like rabies after animal bites). If childhood vaccinations are important, choose IMG or Cigna, or budget for them separately with SafetyWing.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What happens when children turn 18?</h3>
        <p class="text-neutral-700">IMG and Cigna extend coverage to 26 for full-time students. After aging out, children need their own policies. SafetyWing's free coverage ends at 10, then children need individual coverage. Start planning the transition about 6 months before the age cutoff.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is international school health coverage enough?</h3>
        <p class="text-neutral-700">Many international schools offer basic health coverage, but it's typically limited to on-campus emergencies or minor issues. For comprehensive family coverage including hospitalizations, specialist care, and medical evacuation, you need dedicated international health insurance. School coverage can supplement, not replace, family insurance.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Family coverage options, child pricing, and benefits vary by plan and change over time. This comparison represents typical offerings—actual coverage depends on your specific plan choice, children's ages, and family health history. Always verify child coverage details and age limits before enrolling.</p>
  </div>
</PageShell>
