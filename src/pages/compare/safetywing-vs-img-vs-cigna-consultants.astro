---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "img", title: "IMG Global" },
  { id: "cigna", title: "Cigna Global" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "consultant-details", title: "Consultant Considerations" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/safetywing", title: "SafetyWing Review" },
  { href: "/providers/img-global", title: "IMG Global Review" },
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/insurance-for/freelancers", title: "Insurance for Freelancers" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const mainComparisonRows = [
  { feature: "Monthly Cost", safetywing: "$45–85", img: "$200–400", cigna: "$350–600" },
  { feature: "Billing Flexibility", safetywing: "Monthly", img: "Annual/Quarterly", cigna: "Annual" },
  { feature: "Coverage Limit", safetywing: "$250K", img: "$1M–5M", cigna: "$1M–Unlimited" },
  { feature: "Multi-Country Coverage", safetywing: "185+ countries", img: "Global options", cigna: "Global options" },
  { feature: "Home Country Visits", safetywing: "30 days/90 days", img: "Varies by plan", cigna: "Full coverage option" },
  { feature: "Contract Gaps", safetywing: "Flexible start/stop", img: "Continuous coverage", cigna: "Continuous coverage" },
  { feature: "Pre-existing Conditions", safetywing: "Not covered", img: "Some coverage possible", cigna: "Case-by-case" },
  { feature: "Mental Health", safetywing: "Limited", img: "Available", cigna: "Comprehensive" },
  { feature: "Visa Letters", safetywing: "Available", img: "Available", cigna: "Available" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const pricingRows = [
  { profile: "Consultant, 30yo", safetywing: "$540–1,020/yr", img: "$2,400–4,800/yr", cigna: "$4,200–7,200/yr" },
  { profile: "Consultant, 40yo", safetywing: "$660–1,260/yr", img: "$3,200–6,400/yr", cigna: "$5,600–9,600/yr" },
  { profile: "Couple (both consultants)", safetywing: "$1,080–2,040/yr", img: "$5,200–10,400/yr", cigna: "$9,600–16,800/yr" },
  { profile: "3-month project coverage", safetywing: "$135–255", img: "$600–1,200", cigna: "Annual only" },
];
---

<PageShell
  title="SafetyWing vs IMG vs Cigna: Insurance for International Consultants (2025)"
  description="Compare health insurance for consultants and contractors working internationally. Analysis of SafetyWing, IMG Global, and Cigna Global for project-based work abroad."
  headline="SafetyWing vs IMG vs Cigna: Insurance for International Consultants"
  intro="International consulting means variable income, project-based travel, and gaps between contracts. Your health insurance needs to flex with your work—covering you across countries, through contract transitions, and without requiring corporate sponsors. Here's how SafetyWing, IMG Global, and Cigna Global compare for independent consultants."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 font-semibold mb-2">Best for Variable Income</p>
        <p class="text-neutral-700 text-sm">Monthly billing adapts to consulting income fluctuations. Low cost during slow periods, easy to maintain. Best for younger, healthy consultants.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best Mid-Tier Option</p>
        <p class="text-neutral-700 text-sm">Higher coverage limits with quarterly payment options. Good for established consultants wanting more protection without premium pricing.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 font-semibold mb-2">Best Comprehensive Coverage</p>
        <p class="text-neutral-700 text-sm">Premium coverage for successful consultants. Worth it when you're earning well and want top-tier protection. Best for those with health concerns.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- SafetyWing Section -->
  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Consultant Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Monthly billing:</strong> Pay as you go, aligned with consulting income</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>No commitment:</strong> Start, pause, restart without penalties</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>185+ countries:</strong> Coverage wherever projects take you</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Instant enrollment:</strong> Sign up online in minutes</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Visa support:</strong> Insurance letters for visa applications</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      SafetyWing's Nomad Insurance fits the consulting lifestyle perfectly. When you land a big project, you're covered. Between contracts, you keep paying $45-85/month—manageable even during slow periods. No need to re-enroll or prove insurability when the next project starts.
    </p>
    <p class="text-neutral-700">
      The $250K coverage limit is the main trade-off. For most healthcare needs, it's adequate. But a serious illness or accident in an expensive country could exhaust this quickly. Consultants earning well should consider whether this limitation is acceptable risk.
    </p>
  </section>

  <!-- IMG Global Section -->
  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Consultant Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Higher coverage:</strong> $1M–5M limits for serious protection</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Quarterly billing:</strong> More flexible than annual, more stable than monthly</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Pre-existing options:</strong> Some conditions coverable with underwriting</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Mental health:</strong> Coverage for consultant stress and burnout</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Maternity:</strong> Options for family planning consultants</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      IMG Global occupies the middle ground that works for many established consultants. Higher coverage limits provide real financial protection, while quarterly billing options offer some flexibility. The pricing scales better for those with consistent income.
    </p>
    <p class="text-neutral-700">
      The mental health coverage deserves attention. Consulting is stressful—constant travel, client pressures, uncertain pipelines. Having access to therapy and psychiatric care can help sustain a long consulting career.
    </p>
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Consultant Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Unlimited coverage:</strong> No worrying about hitting policy limits</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Full home country:</strong> Complete coverage during client visits home</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Pre-existing flexibility:</strong> Case-by-case consideration for conditions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Comprehensive mental health:</strong> Unlimited therapy sessions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Global network:</strong> Direct billing anywhere you work</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global is the consultant's choice when budget isn't the primary constraint. If you're billing $150-500/hour, the $400-600/month premium is a reasonable business expense. You get comprehensive coverage without worrying about gaps or limits.
    </p>
    <p class="text-neutral-700">
      The annual commitment is the main friction point. Unlike SafetyWing's month-to-month model, you're committed for the year. For consultants with consistent work, this isn't a problem. For those with feast-or-famine income, it requires planning.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Consultant Insurance Quotes"
    description="Compare plans from SafetyWing, IMG, and Cigna for international consulting work."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Consultant income varies widely—from struggling independents to highly-paid specialists. Consider these prices as a percentage of your annual consulting revenue when evaluating value.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for worldwide coverage excluding US. SafetyWing allows month-to-month; others typically annual.
    </p>
  </section>

  <!-- Consultant Details Section -->
  <section id="consultant-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Key Considerations for Consultants</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Income Variability</h3>
        <p class="text-neutral-700 mb-3">
          Consulting income isn't steady. Some months bring $20,000; others bring zero. Your insurance should accommodate this reality. SafetyWing's monthly model handles variability best. IMG's quarterly option is a middle ground. Cigna's annual commitment works for stable earners.
        </p>
        <p class="text-neutral-700">
          Don't let a slow period become a coverage gap. Even $45-85/month is worth maintaining during dry spells—the cost of re-enrollment, potential waiting periods, and pre-existing condition complications make continuous coverage valuable.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Multi-Country Work</h3>
        <p class="text-neutral-700 mb-3">
          Consultants often work in multiple countries within a single year—a project in Germany, then Singapore, then Brazil. All three insurers handle this well with global coverage. However, check specific country exclusions, particularly for places with US sanctions or conflict zones.
        </p>
        <p class="text-neutral-700">
          If your work takes you to high-risk locations, verify coverage explicitly. Some policies exclude certain countries or require additional riders for conflict zones. Development consulting in particular may encounter these limitations.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Visa and Work Permit Requirements</h3>
        <p class="text-neutral-700 mb-3">
          Many countries require proof of health insurance for work visas or business visas beyond tourist stays. All three insurers provide insurance letters for visa applications. Some countries have specific minimum coverage requirements—verify your policy meets them.
        </p>
        <p class="text-neutral-700">
          SafetyWing's $250K limit may fall short for some visa requirements, particularly Schengen business visas or certain Asian work permits. IMG and Cigna's higher limits generally satisfy any requirement.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Client-Required Coverage</h3>
        <p class="text-neutral-700 mb-3">
          Some clients require contractors to have health insurance as part of vendor compliance. Having professional international coverage demonstrates responsibility and can be a competitive advantage in proposals. Cigna's brand recognition particularly impresses corporate clients.
        </p>
        <p class="text-neutral-700">
          If you're bidding on government or large corporate contracts, check whether specific insurance requirements exist. Some contracts specify minimum coverage levels or require naming the client as an additional insured (typically professional liability, not health).
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose SafetyWing If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• Your income varies significantly</li>
          <li>• You're early in your consulting career</li>
          <li>• Budget flexibility is essential</li>
          <li>• You're young and healthy</li>
          <li>• You want month-to-month commitment</li>
          <li>• Short project coverage is needed</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose IMG If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want higher coverage limits</li>
          <li>• Mental health coverage matters</li>
          <li>• You have some health concerns</li>
          <li>• Quarterly billing works for you</li>
          <li>• Balance of cost and coverage matters</li>
          <li>• You're an established consultant</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You earn consistently and well</li>
          <li>• Comprehensive coverage is priority</li>
          <li>• You have pre-existing conditions</li>
          <li>• Client perception matters</li>
          <li>• You want unlimited coverage</li>
          <li>• Annual commitment is fine</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I deduct health insurance as a business expense?</h3>
        <p class="text-neutral-700">
          In most jurisdictions, self-employed consultants can deduct health insurance premiums as a business expense. Check with a tax professional familiar with your home country's rules and any tax treaties affecting your consulting income. Keep detailed records of premiums paid.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I take a full-time job? Can I cancel?</h3>
        <p class="text-neutral-700">
          SafetyWing allows cancellation anytime. IMG and Cigna have annual commitments but may allow early termination if you gain employer coverage—check specific terms. Some consultants maintain personal coverage even with employer plans for flexibility if they return to consulting.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I handle coverage during project transitions?</h3>
        <p class="text-neutral-700">
          With SafetyWing, just keep paying monthly—no gaps. With IMG or Cigna, your annual policy continues regardless of work status. Don't let coverage lapse between projects; re-enrollment complications and waiting periods make continuous coverage worth the cost.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can clients require specific insurance levels?</h3>
        <p class="text-neutral-700">
          Yes—some enterprise clients require contractors to demonstrate health insurance coverage. Government contracts may have specific requirements. If a client specifies coverage levels, verify your plan meets them before signing contracts.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about coverage when I visit clients in my home country?</h3>
        <p class="text-neutral-700">
          SafetyWing covers 30 days per 90-day period in your home country. Cigna can include full home country coverage. IMG varies by plan. If you frequently visit home for client meetings, factor home country coverage into your decision.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Should I get professional liability AND health insurance?</h3>
        <p class="text-neutral-700">
          Yes—they're different coverages. Health insurance covers your medical expenses. Professional liability (errors and omissions) protects against client claims of negligence or mistakes. Most serious consultants carry both, especially when working with corporate clients.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by specific plan, policy year, and individual circumstances. Tax deductibility depends on jurisdiction and individual tax situation—consult a tax professional. Client requirements for contractor insurance vary by contract and should be verified directly. This comparison reflects general plan features as of the publication date.
    </p>
  </aside>
</PageShell>
