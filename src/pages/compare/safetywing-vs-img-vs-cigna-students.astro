---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "img", title: "IMG Global" },
  { id: "cigna", title: "Cigna Global" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "student-details", title: "Student Considerations" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/safetywing", title: "SafetyWing Review" },
  { href: "/providers/img-global", title: "IMG Global Review" },
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/insurance-for/students", title: "Insurance for Students Abroad" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const mainComparisonRows = [
  { feature: "Monthly Cost", safetywing: "$45–69", img: "$80–200", cigna: "$200–400" },
  { feature: "Coverage Limit", safetywing: "$250K", img: "$500K–5M", cigna: "$1M–Unlimited" },
  { feature: "Academic Year Coverage", safetywing: "Monthly flex", img: "Semester/Annual", cigna: "Annual" },
  { feature: "Home Visits", safetywing: "30 days/90 days", img: "Varies", cigna: "Full coverage" },
  { feature: "Mental Health", safetywing: "Limited", img: "Available", cigna: "Comprehensive" },
  { feature: "Sports/Intramurals", safetywing: "Covered", img: "Covered", cigna: "Covered" },
  { feature: "Pre-existing Conditions", safetywing: "Not covered", img: "Some coverage", cigna: "Case-by-case" },
  { feature: "Visa Compliance", safetywing: "Most countries", img: "Most countries", cigna: "All countries" },
  { feature: "Parent Access", safetywing: "Account sharing", img: "Family portal", cigna: "Family portal" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const pricingRows = [
  { profile: "Student, age 20", safetywing: "$540–828/yr", img: "$960–2,400/yr", cigna: "$2,400–4,800/yr" },
  { profile: "Student, age 25", safetywing: "$540–828/yr", img: "$1,080–2,640/yr", cigna: "$2,640–5,280/yr" },
  { profile: "One semester (4 months)", safetywing: "$180–276", img: "$320–800", cigna: "Annual only" },
  { profile: "Summer program (3 months)", safetywing: "$135–207", img: "$240–600", cigna: "Annual only" },
];
---

<PageShell
  title="SafetyWing vs IMG vs Cigna: Insurance for International Students (2025)"
  description="Compare health insurance for international students studying abroad. Analysis of SafetyWing, IMG Global, and Cigna Global for university and exchange programs."
  headline="SafetyWing vs IMG vs Cigna: Insurance for International Students"
  intro="Studying abroad comes with unique insurance challenges—university requirements, student budgets, short program durations, and concerned parents back home. Finding coverage that meets visa requirements without breaking the bank matters. Here's how SafetyWing, IMG Global, and Cigna Global compare for international students."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 font-semibold mb-2">Best for Budget-Conscious Students</p>
        <p class="text-neutral-700 text-sm">Monthly billing fits student budgets. Affordable coverage for healthy young people. Great for short programs or semester abroad.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best Mid-Range Student Option</p>
        <p class="text-neutral-700 text-sm">Higher coverage limits with semester billing. Good for students wanting more protection. Mental health options for student stress.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 font-semibold mb-2">Best Comprehensive Coverage</p>
        <p class="text-neutral-700 text-sm">Premium coverage for students with health concerns or parents who want peace of mind. Full mental health and pre-existing condition options.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- SafetyWing Section -->
  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Student Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Student-friendly pricing:</strong> Under $70/month fits student budgets</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Monthly billing:</strong> No large upfront payment required</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Flexible duration:</strong> Perfect for semester or summer programs</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Home visits:</strong> Coverage during school breaks back home</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Easy sign-up:</strong> Online application takes minutes</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      SafetyWing understands student budgets. At $45-69/month, it's affordable even on a part-time job or limited allowance. The monthly billing means you're not scrambling to pay $1,000+ upfront before the semester starts.
    </p>
    <p class="text-neutral-700">
      The $250K coverage limit is the main consideration. For most student health needs—infections, minor injuries, routine care—it's plenty. But a serious accident or major illness could exceed this in high-cost countries. Healthy young students usually find this acceptable.
    </p>
  </section>

  <!-- IMG Global Section -->
  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Student Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Higher coverage:</strong> $500K–5M limits provide real protection</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Semester billing:</strong> Pay per semester, not annually</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Mental health:</strong> Coverage for student stress, anxiety, depression</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Sports coverage:</strong> Intramural and recreational sports included</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Family portal:</strong> Parents can access policy info and claims</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      IMG Global offers a step up for students (or their parents) who want more comprehensive protection. The higher coverage limits mean you're protected against worst-case scenarios, not just routine care. Many universities accept IMG as meeting their insurance requirements.
    </p>
    <p class="text-neutral-700">
      The mental health coverage deserves attention. Student mental health is a real concern—new environment, academic pressure, isolation from home. Having access to counseling and therapy can make the difference between struggling and thriving abroad.
    </p>
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Student Benefits</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Unlimited coverage:</strong> No worrying about hitting limits</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Full home country:</strong> Complete coverage during breaks</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Pre-existing conditions:</strong> Options for students with health history</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Comprehensive mental health:</strong> Unlimited therapy sessions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Global network:</strong> Quality care anywhere in the world</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global is the premium choice for students—or more realistically, for parents willing to invest in comprehensive coverage. The unlimited coverage means no anxiety about hitting caps. The mental health benefits are the strongest in the market.
    </p>
    <p class="text-neutral-700">
      For students with pre-existing conditions—diabetes, asthma, mental health history—Cigna's case-by-case consideration may provide coverage that budget options exclude. The higher cost buys peace of mind that's worth it for some families.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Student Insurance Quotes"
    description="Compare plans from SafetyWing, IMG, and Cigna for your study abroad program."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Student insurance needs to fit student budgets. SafetyWing's monthly billing keeps costs manageable. IMG offers semester options. Cigna requires annual commitment but provides premium coverage.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for worldwide coverage excluding US. Short-term rates available from SafetyWing and IMG.
    </p>
  </section>

  <!-- Student Details Section -->
  <section id="student-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Key Considerations for Students</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">University Requirements</h3>
        <p class="text-neutral-700 mb-3">
          Many universities require proof of health insurance before enrollment. Some mandate their own expensive plans; others accept outside coverage meeting minimum requirements. Check your university's policy early—some accept SafetyWing, others require higher limits like IMG or Cigna.
        </p>
        <p class="text-neutral-700">
          If you can use outside insurance, compare costs carefully. University plans often cost $2,000-4,000/year. SafetyWing at under $1,000/year might meet requirements while saving money, but verify acceptance first.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Visa Requirements</h3>
        <p class="text-neutral-700 mb-3">
          Student visas typically require health insurance proof. Schengen student visas require minimum €30,000 coverage. Other countries have varying requirements. All three insurers provide visa-compliant coverage letters, but verify minimum amounts match your specific visa type.
        </p>
        <p class="text-neutral-700">
          SafetyWing's $250K limit exceeds most visa requirements. But if your visa specifically requires higher minimums, IMG or Cigna may be necessary for compliance.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Mental Health Support</h3>
        <p class="text-neutral-700 mb-3">
          Study abroad is exciting but stressful. Culture shock, homesickness, academic pressure in a new language, and social isolation affect many students. Having access to mental health support—counseling, therapy, crisis services—can be crucial.
        </p>
        <p class="text-neutral-700">
          SafetyWing's limited mental health coverage may feel insufficient if you're struggling. IMG offers better options. Cigna provides unlimited therapy. Consider your mental health history and risk factors when choosing coverage level.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Coverage During Breaks</h3>
        <p class="text-neutral-700 mb-3">
          What happens during winter break, spring break, or summer? SafetyWing covers 30 days per 90-day period in your home country. Cigna can include full home country coverage. IMG varies by plan—check the fine print.
        </p>
        <p class="text-neutral-700">
          If you're traveling during breaks (which students often do), you need coverage that follows you. All three cover travel outside your study country, but home country limits may matter if you spend extended time back home.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose SafetyWing If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• Budget is your main constraint</li>
          <li>• You're young and healthy</li>
          <li>• You want monthly billing flexibility</li>
          <li>• You're on a short program</li>
          <li>• University accepts $250K coverage</li>
          <li>• You have no pre-existing conditions</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose IMG If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want higher coverage limits</li>
          <li>• Mental health support matters</li>
          <li>• Semester billing works for you</li>
          <li>• Parents want more protection</li>
          <li>• Sports coverage is needed</li>
          <li>• Balance of cost and coverage matters</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You have pre-existing conditions</li>
          <li>• Comprehensive mental health matters</li>
          <li>• Parents prioritize top coverage</li>
          <li>• Unlimited coverage provides peace of mind</li>
          <li>• Full home country coverage needed</li>
          <li>• Budget isn't the primary constraint</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can my parents manage my insurance account?</h3>
        <p class="text-neutral-700">
          Yes—all three offer ways for parents to stay involved. SafetyWing allows account sharing. IMG and Cigna have family portals where parents can view coverage, track claims, and communicate with the insurer. This is helpful when you're abroad and something happens.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I extend my study program?</h3>
        <p class="text-neutral-700">
          SafetyWing continues monthly—just keep paying. IMG allows extensions before expiration. Cigna annual plans can be renewed. Don't let coverage lapse between your original plan and extension—gaps could affect future coverage for any issues that arise.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Does insurance cover me for internships or work-study?</h3>
        <p class="text-neutral-700">
          Generally yes—student insurance covers you as a person, not just academic activities. Internships, part-time jobs, and work-study are covered. However, work-related injuries might require separate worker's compensation depending on your host country's laws.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about dental and vision?</h3>
        <p class="text-neutral-700">
          Basic plans typically don't include routine dental or vision. Emergency dental (broken tooth, sudden pain) is covered. If you need regular dental or vision care, consider add-ons from IMG or Cigna, or plan to handle these at home during breaks.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I get care at a foreign university?</h3>
        <p class="text-neutral-700">
          Most universities have student health centers for basic care—often free or low-cost. Your insurance kicks in for off-campus care, specialists, hospitals, and anything beyond basic clinic services. Check if your university clinic participates with your insurer for direct billing.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What happens if I drop out or transfer?</h3>
        <p class="text-neutral-700">
          Your insurance isn't tied to a specific school. If you leave your program, coverage continues until it expires. SafetyWing's monthly model is most flexible—just keep paying or cancel when ready. Annual plans continue regardless of student status.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by specific plan, policy year, and individual circumstances. University insurance requirements differ—verify acceptance of any plan before purchasing. Visa requirements vary by country and visa type. This comparison reflects general plan features as of the publication date.
    </p>
  </aside>
</PageShell>
