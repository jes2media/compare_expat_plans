---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'inpatient-details', text: 'Inpatient Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/compare/cigna-vs-bupa-vs-allianz-outpatient', text: 'Outpatient Coverage' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Hospital Coverage', cigna: 'Unlimited', bupa: 'Unlimited', allianz: 'Up to €1.5M' },
  { feature: 'ICU Coverage', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Full coverage' },
  { feature: 'Surgery', cigna: 'All procedures', bupa: 'All procedures', allianz: 'All procedures' },
  { feature: 'Hospital Room', cigna: 'Private room', bupa: 'Private room', allianz: 'Semi-private standard' },
  { feature: 'Cancer Treatment', cigna: 'Full coverage', bupa: 'Full coverage', allianz: 'Good coverage' },
  { feature: 'Direct Billing', cigna: 'Excellent', bupa: 'Excellent', allianz: 'Good' },
  { feature: 'Emergency Evacuation', cigna: 'Included', bupa: 'Included', allianz: 'Included' },
  { feature: 'Rehabilitation', cigna: '60 days', bupa: '45 days', allianz: '30 days' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Individual (35)', cigna: '$180-250/mo', bupa: '$200-280/mo', allianz: '$150-220/mo' },
  { profile: 'Individual (50)', cigna: '$320-420/mo', bupa: '$360-480/mo', allianz: '$280-370/mo' },
  { profile: 'Couple (35/35)', cigna: '$340-470/mo', bupa: '$380-530/mo', allianz: '$280-400/mo' },
  { profile: 'Family with 2 kids', cigna: '$550-750/mo', bupa: '$620-850/mo', allianz: '$450-620/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz Inpatient Only Plans | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for inpatient-only coverage. Expert analysis of hospital coverage, surgery, ICU, and rehabilitation benefits."
  headline="Cigna vs Bupa vs Allianz: Best Inpatient-Only Plans"
  subheadline="Complete comparison for expats seeking comprehensive hospital coverage without outpatient premiums—save 40-50% on monthly costs."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Inpatient</p>
        <p class="text-neutral-700 text-sm mb-4">Unlimited hospital coverage, longest rehab stays, and the largest direct billing network. Premium protection at a competitive price.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Hospital Network</p>
        <p class="text-neutral-700 text-sm mb-4">Premium hospital partnerships worldwide with seamless admissions. Private rooms standard and excellent care coordination.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Solid hospital coverage at the lowest price point. Great for healthy expats who want catastrophic protection without high premiums.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Coverage</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">60-Day Rehab</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Global Network</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global's inpatient-only plan offers unlimited hospital coverage with no annual caps—essential for major surgeries or extended treatments. You're covered for any medically necessary hospital stay, ICU, surgery, and cancer treatment without worrying about running out of benefits.</p>

    <p class="text-neutral-700 mb-4">The 60-day rehabilitation coverage is industry-leading, crucial if you need extended recovery after major surgery or a serious illness. Private rooms are standard, and their direct billing network covers 1.5+ million providers worldwide, meaning hospitals bill Cigna directly for most admissions.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Inpatient Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• No annual hospital limits</li>
          <li>• 60 days rehabilitation</li>
          <li>• Private room standard</li>
          <li>• Full cancer treatment coverage</li>
          <li>• Emergency evacuation included</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• No GP or routine visits covered</li>
          <li>• Prescriptions only during hospitalization</li>
          <li>• Mid-range pricing</li>
          <li>• US coverage costs extra</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Hospitals</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Care Coordination</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Private Rooms</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global's inpatient coverage focuses on quality and service. Their hospital network prioritizes prestigious medical centers worldwide, ensuring you receive care at leading institutions. Unlimited hospital coverage means no caps on your treatment costs.</p>

    <p class="text-neutral-700 mb-4">What sets Bupa apart is their care coordination—when you're hospitalized, a dedicated coordinator manages your treatment, communicates with doctors, and handles billing. This is invaluable during stressful medical situations abroad. Rehabilitation is covered for 45 days, and private rooms are standard.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Inpatient Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Premium hospital partnerships</li>
          <li>• Dedicated care coordinators</li>
          <li>• Seamless admission process</li>
          <li>• Private rooms at all levels</li>
          <li>• Strong UK and EU networks</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums of the three</li>
          <li>• 45 days rehab (vs Cigna's 60)</li>
          <li>• No outpatient coverage</li>
          <li>• Limited in some regions</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Lowest Cost</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Solid Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Global Reach</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers the most affordable inpatient-only option without sacrificing essential coverage. While capped at €1.5M annually (more than sufficient for most hospitalizations), you get comprehensive surgical coverage, ICU, and cancer treatment at a fraction of competitors' prices.</p>

    <p class="text-neutral-700 mb-4">Semi-private rooms are standard (you can upgrade), and rehabilitation is covered for 30 days. The network is smaller than Cigna or Bupa, but direct billing is available at major hospitals in most countries. For healthy expats wanting catastrophic protection without premium costs, Allianz delivers.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Inpatient Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable premiums</li>
          <li>• €1.5M coverage is substantial</li>
          <li>• Full surgical coverage</li>
          <li>• Cancer treatment included</li>
          <li>• Emergency evacuation covered</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Annual limit (vs unlimited)</li>
          <li>• Semi-private rooms standard</li>
          <li>• 30 days rehab (shortest)</li>
          <li>• Smaller direct billing network</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Inpatient-Only Quotes"
    description="Get personalized quotes for hospital-only coverage from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Inpatient-only plans save 40-50% versus full coverage—ideal for budget-conscious expats:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Prices vary by region, deductible, and health history. US coverage adds 30-50% to premiums. Quotes are approximate—get personalized pricing above.</p>
  </section>

  <section id="inpatient-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Inpatient Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">What's Covered</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Hospital room and board</li>
          <li>• Surgery and anesthesia</li>
          <li>• ICU and critical care</li>
          <li>• In-hospital medications</li>
          <li>• Cancer treatment (chemo, radiation)</li>
          <li>• Organ transplants</li>
          <li>• Emergency evacuation</li>
          <li>• Post-hospital rehabilitation</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">What's NOT Covered</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• GP or doctor visits</li>
          <li>• Specialist consultations</li>
          <li>• Outpatient prescriptions</li>
          <li>• Routine check-ups</li>
          <li>• Diagnostic tests (unless hospitalized)</li>
          <li>• Physiotherapy (unless post-hospital)</li>
          <li>• Mental health (outpatient)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Is Inpatient-Only Right For You?</h3>
      <p class="text-blue-700 mb-4">Consider inpatient-only coverage if:</p>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Good Fit</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• You're generally healthy</li>
            <li>• Budget is a priority</li>
            <li>• Local healthcare is affordable</li>
            <li>• You can pay cash for GP visits</li>
            <li>• You want catastrophic protection</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Consider Full Coverage</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Ongoing health conditions</li>
            <li>• Regular medications needed</li>
            <li>• Expensive local healthcare</li>
            <li>• Prefer paying premiums over cash</li>
            <li>• Want comprehensive protection</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want unlimited hospital coverage</li>
          <li>• Extended rehabilitation may be needed</li>
          <li>• Private rooms matter</li>
          <li>• Large direct billing network is important</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You want access to premium hospitals</li>
          <li>• Care coordination during hospitalization matters</li>
          <li>• You're based in UK or Europe</li>
          <li>• Service quality is your priority</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is your main concern</li>
          <li>• You're young and healthy</li>
          <li>• €1.5M coverage is sufficient</li>
          <li>• You're comfortable with semi-private rooms</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What counts as "inpatient" coverage?</h3>
        <p class="text-neutral-700">Inpatient coverage applies when you're formally admitted to a hospital and stay overnight or longer. Day surgeries may or may not be covered—check your policy. Emergency room visits are typically covered if they lead to admission; otherwise they may be considered outpatient.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How do I handle routine healthcare with inpatient-only coverage?</h3>
        <p class="text-neutral-700">You pay cash for GP visits, prescriptions, and routine care. In many countries (Thailand, Mexico, Portugal), this is very affordable—a doctor visit might cost $20-50. Build a small healthcare fund for routine expenses while your insurance covers catastrophic events.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I add outpatient coverage later?</h3>
        <p class="text-neutral-700">Yes, most insurers allow you to upgrade at renewal. However, new pre-existing condition exclusions may apply to outpatient benefits. It's often easier to downgrade from full coverage than to upgrade from inpatient-only if your health changes.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What deductibles should I consider?</h3>
        <p class="text-neutral-700">Higher deductibles reduce premiums further. For inpatient-only plans, a $2,500-5,000 deductible can cut costs by 20-30%. Since you're already paying cash for routine care, a higher deductible aligns with the catastrophic protection philosophy.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Inpatient coverage specifics vary by plan level and region. Always verify coverage directly with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
