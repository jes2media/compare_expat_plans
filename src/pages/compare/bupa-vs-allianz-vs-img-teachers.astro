---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Bupa vs Allianz vs IMG: Best International Health Insurance for Teachers Abroad";
const description = "Compare Bupa Global, Allianz Care, and IMG Global for teachers and educators working internationally. Coverage analysis for international schools, TEFL teachers, and education professionals overseas.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mainComparisonRows = [
  { feature: 'Premium Level', bupa: 'High', allianz: 'Mid-High', img: 'Budget-Mid' },
  { feature: 'Mental Health Coverage', bupa: 'Excellent', allianz: 'Good', img: 'Basic' },
  { feature: 'Family Plans', bupa: 'Comprehensive', allianz: 'Comprehensive', img: 'Available' },
  { feature: 'School Year Flexibility', bupa: 'Annual plans', allianz: '6-month minimum', img: 'Flexible terms' },
  { feature: 'Wellness Benefits', bupa: 'Extensive', allianz: 'Good', img: 'Limited' },
  { feature: 'Global Network', bupa: 'Excellent', allianz: 'Strong', img: 'Good' },
  { feature: 'Starting Price', bupa: '$$$', allianz: '$$-$$$', img: '$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', bupa: 'Full coverage', allianz: 'Full coverage', img: 'Full coverage' },
  { coverage: 'Outpatient', bupa: 'Comprehensive', allianz: 'Optional/Included', img: 'Plan dependent' },
  { coverage: 'Mental Health', bupa: 'Unlimited sessions', allianz: 'Annual limits', img: 'Limited' },
  { coverage: 'Preventive Care', bupa: 'Health screenings', allianz: 'Available', img: 'Basic' },
  { coverage: 'Maternity', bupa: '12-month wait', allianz: '12-month wait', img: 'Limited/None' },
  { coverage: 'Voice/Throat Issues', bupa: 'Covered', allianz: 'Covered', img: 'Covered' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const pricingRows = [
  { profile: 'TEFL Teacher, 28, Asia', bupa: '$3,200-4,500/yr', allianz: '$2,400-3,400/yr', img: '$1,400-2,000/yr' },
  { profile: 'IB Teacher, 35, Middle East', bupa: '$4,500-6,000/yr', allianz: '$3,500-4,800/yr', img: '$2,000-2,800/yr' },
  { profile: 'Teacher + Spouse, 40, Europe', bupa: '$7,500-10,000/yr', allianz: '$5,800-7,800/yr', img: '$3,500-4,800/yr' },
  { profile: 'Family of 4, Comprehensive', bupa: '$14,000-18,000/yr', allianz: '$10,000-14,000/yr', img: '$6,000-8,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'img-global', text: 'IMG Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'teacher-considerations', text: 'Teacher-Specific Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Educators', href: '/insurance-for/educators' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'IMG Global Review', href: '/providers/img' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-blue-800 text-sm">You work at a prestigious international school with good benefits, have a family, and want the best mental health support and wellness coverage available.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at a more reasonable price, with good family options and flexibility for teachers moving between contracts.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose IMG Global If...</h3>
          <p class="text-purple-800 text-sm">You're a young TEFL teacher or working at a school without benefits, and need affordable coverage that fits a teacher's budget with flexible contract terms.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Teachers working internationally face unique insurance challenges: varying school benefits, contract-based employment, mental health stress from relocation, and often, family coverage needs. These three providers represent different points on the price-coverage spectrum.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global is often the choice of top-tier international schools for staff benefits. Their comprehensive coverage, excellent mental health support, and family-friendly plans make them ideal for established international educators.</p>

      <h3>Strengths for Teachers</h3>
      <ul>
        <li>Excellent mental health coverage—crucial for managing expatriate stress</li>
        <li>Comprehensive family plans covering dependents fully</li>
        <li>Wellness benefits including health screenings and preventive care</li>
        <li>Coverage for voice and throat issues common among teachers</li>
        <li>Premium hospital networks in all major international school locations</li>
        <li>Strong support for chronic conditions that may develop</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums among the three providers</li>
        <li>Annual commitment typically required</li>
        <li>May be cost-prohibitive without employer contribution</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care offers a strong middle ground for international teachers—comprehensive enough for peace of mind, but more affordable than premium options. Their flexibility works well for teachers who may move between schools or countries.</p>

      <h3>Strengths for Teachers</h3>
      <ul>
        <li>Good balance of coverage and cost for teacher budgets</li>
        <li>6-month minimum allows alignment with school contracts</li>
        <li>Solid mental health coverage with annual session limits</li>
        <li>Monthly payment options reduce upfront costs</li>
        <li>Good family coverage options at reasonable rates</li>
        <li>Global network covering major international school locations</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health coverage may have session limits</li>
        <li>Some premium hospital access may require pre-authorization</li>
        <li>Wellness benefits less extensive than Bupa</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="img-global" class="mb-12">
      <h2>IMG Global</h2>
      <p>IMG Global provides affordable international coverage that fits within a teacher's budget, especially for younger educators or those at schools without benefits. Their flexible terms work well for the contract-based nature of teaching positions.</p>

      <h3>Strengths for Teachers</h3>
      <ul>
        <li>Most affordable option for budget-conscious teachers</li>
        <li>Flexible contract terms matching teaching assignments</li>
        <li>Easy extension if you renew your teaching contract</li>
        <li>Good basic coverage for emergencies and hospitalization</li>
        <li>Simple online enrollment and management</li>
        <li>Option to upgrade coverage as career progresses</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health coverage may be insufficient</li>
        <li>Outpatient coverage may not be comprehensive</li>
        <li>Smaller direct billing network in some regions</li>
        <li>Less suitable for teachers with families or ongoing health needs</li>
      </ul>

      <CTAButton href="/providers/img" variant="highlight" style="color: white !important;">Get IMG Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Teachers have specific health concerns: voice strain, stress-related issues, and the challenges of relocating families. Mental health support is particularly important given the adjustment challenges of international teaching.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>International teacher salaries vary dramatically—from modest TEFL wages to substantial international school packages. Insurance costs should align with your compensation and whether your school provides benefits.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by age, location, health history, and coverage level. Many international schools provide insurance as a benefit—verify before purchasing individual coverage.</p>
    </section>

    <section id="teacher-considerations" class="mb-12">
      <h2>Teacher-Specific Considerations</h2>

      <h3>School-Provided vs Individual Insurance</h3>
      <p>Top-tier international schools often provide comprehensive health insurance as part of employment packages—often from providers like Bupa or Cigna. Before purchasing individual coverage, understand what your school offers. Some teachers supplement school insurance with additional coverage for gaps.</p>

      <h3>Mental Health Support</h3>
      <p>Teaching abroad involves significant stress: cultural adjustment, isolation from support networks, challenging students, and work-life balance issues. Prioritize mental health coverage. Bupa's unlimited sessions are valuable, while IMG's limited coverage may leave you paying out of pocket for therapy.</p>

      <h3>Contract Timing</h3>
      <p>Teaching contracts typically run August-June or September-July. Align your insurance with contract dates if possible. IMG's flexibility is helpful here, while Bupa and Allianz may require alignment of renewal dates.</p>

      <h3>Dependent Coverage</h3>
      <p>If you're moving with a partner or children, family coverage becomes essential. Bupa and Allianz offer comprehensive family plans. IMG's family options exist but are less robust. Factor in the full family cost, not just individual premiums.</p>

      <h3>Summer Coverage</h3>
      <p>Many international teachers travel during summer breaks. Ensure your insurance covers you while traveling outside your country of residence. All three providers typically allow travel, but verify trip duration limits.</p>

      <h3>Voice and Occupational Health</h3>
      <p>Teachers commonly experience voice strain, throat issues, and repetitive stress injuries from standing and writing. Comprehensive outpatient coverage ensures access to specialists for these occupational health concerns.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Teachers at top-tier international schools</li>
            <li>• Those with employer insurance contributions</li>
            <li>• Families with children</li>
            <li>• Teachers prioritizing mental health support</li>
            <li>• Experienced educators with higher salaries</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-career international teachers</li>
            <li>• Those wanting value for comprehensive coverage</li>
            <li>• Teachers moving between contracts</li>
            <li>• Couples without children</li>
            <li>• Teachers supplementing basic school coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">IMG Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Young TEFL/ESL teachers</li>
            <li>• First-time international teachers</li>
            <li>• Budget-conscious educators</li>
            <li>• Short-term teaching positions</li>
            <li>• Teachers at schools without benefits</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do international schools usually provide health insurance?</h3>
          <p class="text-neutral-700">Top-tier international schools typically provide comprehensive health insurance as part of employment packages. Lower-tier schools and TEFL positions may offer limited or no coverage, requiring you to purchase individual insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can I keep my insurance when I change schools?</h3>
          <p class="text-neutral-700">Individual policies from IMG, Allianz, or Bupa stay with you when you change employers. This provides continuity that school-provided insurance doesn't. You'll need to update your country of residence if you relocate.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is voice therapy and throat treatment covered?</h3>
          <p class="text-neutral-700">Yes, treatment for voice strain and throat issues is covered under outpatient benefits. Bupa and Allianz provide comprehensive coverage, while IMG may require emergency presentation or have limits on specialist visits.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage during summer holidays?</h3>
          <p class="text-neutral-700">Your insurance continues during holidays and covers you while traveling. Verify any trip duration limits—most policies allow 30-90 days of travel outside your country of residence without issues.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I get insurance if my school provides basic coverage?</h3>
          <p class="text-neutral-700">Consider supplemental individual coverage if school insurance has low limits, excludes mental health, or doesn't cover your family. You can also maintain individual coverage for continuity between contracts.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How does maternity coverage work for teachers abroad?</h3>
          <p class="text-neutral-700">All three providers have 12-month waiting periods for maternity coverage. Plan ahead—you'll need to be insured for a full year before conception to have covered birth. School contracts may also affect maternity leave options.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
