---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'quick-decision', text: 'Quick Decision Guide', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'mental-health-parity', text: 'Mental Health: The Parity Difference', level: 2 },
  { id: 'pre-existing-maternity', text: 'Pre-Existing Conditions and Maternity', level: 2 },
  { id: 'pricing', text: 'Pricing Analysis', level: 2 },
  { id: 'five-year-math', text: 'The 5-Year Math', level: 2 },
  { id: 'network-claims', text: 'Networks and Claims', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'BUPA Global Review', href: '/providers/bupa-global' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'Best Budget Insurance', href: '/best/budget-expat-insurance' },
  { title: 'Best Premium Insurance', href: '/best/premium-expat-insurance' },
  { title: 'Thailand Insurance Guide', href: '/countries/thailand/insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Coverage Area' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { feature: 'Annual Maximum', bupa: 'Unlimited', img: '$1M–$8M' },
  { feature: 'Inpatient Hospital', bupa: 'Full coverage', img: 'Full coverage' },
  { feature: 'Outpatient Care', bupa: 'Full coverage', img: 'Full coverage' },
  { feature: 'Mental Health', bupa: 'Full parity with physical', img: 'Limited coverage' },
  { feature: 'Maternity', bupa: 'Up to $75,000', img: '$5,000–$10,000' },
  { feature: 'Pre-Existing Conditions', bupa: 'Often covered from day one', img: 'Usually excluded' },
  { feature: 'Dental', bupa: 'Included (Premier+)', img: 'Optional add-on' },
  { feature: 'Vision', bupa: 'Included (Premier+)', img: 'Optional add-on' },
  { feature: 'Wellness/Preventive', bupa: 'Comprehensive', img: 'Limited' },
  { feature: 'Medical Evacuation', bupa: 'Unlimited', img: '$500,000' },
  { feature: 'No-Claims Discount', bupa: 'Yes', img: 'No' },
  { feature: 'Deductible Range', bupa: '$0–$5,000', img: '$0–$25,000' },
];

const mentalHealthColumns = [
  { key: 'aspect', header: 'Mental Health Aspect' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'img', header: 'IMG Global' },
];

const mentalHealthRows = [
  { aspect: 'Coverage Philosophy', bupa: 'Parity with physical health', img: 'Limited/supplementary' },
  { aspect: 'Outpatient Therapy', bupa: 'Covered same as physical', img: 'Often excluded or capped' },
  { aspect: 'Inpatient Psychiatric', bupa: 'Full coverage', img: 'Limited coverage' },
  { aspect: 'Session Limits', bupa: 'Higher/no limits', img: 'Lower limits if covered' },
  { aspect: 'Psychiatric Medication', bupa: 'Covered', img: 'Limited' },
  { aspect: 'Waiting Period', bupa: 'Standard policy waiting', img: 'Varies by plan' },
];

const maternityColumns = [
  { key: 'aspect', header: 'Maternity Aspect' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'img', header: 'IMG Global' },
];

const maternityRows = [
  { aspect: 'Maximum Benefit', bupa: 'Up to $75,000', img: '$5,000–$10,000' },
  { aspect: 'Waiting Period', bupa: '12 months', img: '12 months' },
  { aspect: 'Prenatal Care', bupa: 'Covered', img: 'Limited' },
  { aspect: 'Delivery (Normal)', bupa: 'Covered', img: 'Subject to cap' },
  { aspect: 'C-Section', bupa: 'Covered', img: 'Subject to cap' },
  { aspect: 'Complications', bupa: 'Covered separately', img: 'Covered' },
  { aspect: 'Newborn Coverage', bupa: '30 days automatic', img: 'Varies' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'img', header: 'IMG Global' },
  { key: 'savings', header: 'Annual IMG Savings' },
];

const pricingRows = [
  { profile: 'Single, Age 30', bupa: '$200–300/mo', img: '$75–120/mo', savings: '$1,500–2,160/yr' },
  { profile: 'Single, Age 35', bupa: '$250–350/mo', img: '$90–140/mo', savings: '$1,920–2,520/yr' },
  { profile: 'Single, Age 45', bupa: '$350–450/mo', img: '$120–180/mo', savings: '$2,760–3,240/yr' },
  { profile: 'Couple, Age 35', bupa: '$400–550/mo', img: '$150–220/mo', savings: '$3,000–3,960/yr' },
  { profile: 'Family of 4', bupa: '$700–950/mo', img: '$280–400/mo', savings: '$5,040–6,600/yr' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Claims Aspect' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'img', header: 'IMG Global' },
];

const claimsRows = [
  { aspect: 'Direct Billing Network', bupa: '1.7M+ providers', img: 'Smaller network' },
  { aspect: 'Reimbursement Time', bupa: '5–7 business days', img: '5–10 business days' },
  { aspect: 'Claims Portal', bupa: 'MembersWorld portal/app', img: 'Online portal/app' },
  { aspect: 'In-House Medical Team', bupa: 'Yes', img: 'No' },
  { aspect: '24/7 Support', bupa: 'Multilingual', img: 'English primary' },
  { aspect: 'Trustpilot Rating', bupa: '4.4/5', img: '4.6/5' },
];
---

<PageShell
  title="BUPA Global vs IMG Global: Premium vs Budget International Insurance"
  description="Compare BUPA Global and IMG Global international health insurance. Mental health parity and $75K maternity vs budget-friendly high-deductible plans."
  headline="BUPA Global vs IMG Global: Premium vs Budget Coverage"
  subheadline="The most comprehensive option versus the most affordable. Here's what you're trading for those savings."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get BUPA Quote"
  ctaButtonHref="/go/bupa-global"
>
  <h2 id="overview">Overview</h2>
  <p>
    BUPA Global and IMG Global represent opposite ends of the international health insurance spectrum. BUPA offers unlimited coverage with mental health parity and $75,000 maternity benefits. IMG offers budget-friendly premiums with high-deductible options and a 50% deductible waiver for international care.
  </p>
  <p>
    <strong>BUPA Global</strong> is a UK-based premium insurer known for treating mental health equal to physical health—a rare feature in international insurance. They often cover pre-existing conditions from day one, offer unlimited annual coverage, and include dental and vision in top-tier plans. Their pricing reflects this comprehensive approach.
  </p>
  <p>
    <strong>IMG Global</strong> is an American insurer focused on affordable international coverage. They offer deductibles up to $25,000, a unique 50% deductible waiver for care outside the US, and maintain strong customer satisfaction (4.6/5 Trustpilot). They achieve lower prices by limiting mental health, capping maternity, and typically excluding pre-existing conditions.
  </p>
  <p>
    The price difference is dramatic: IMG costs 50–70% less than BUPA. Over 5 years, a 35-year-old could save $9,000+ choosing IMG over BUPA. But that savings comes with significant trade-offs in mental health coverage, maternity benefits, and pre-existing condition handling.
  </p>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="font-semibold text-blue-800 mb-2">BUPA's Mental Health Parity</p>
    <p class="text-blue-900 text-sm mb-0">
      BUPA Global treats mental health conditions equally to physical health conditions—same coverage limits, same access, same treatment. This "mental health parity" is rare in international insurance and can save thousands annually if you need therapy, counseling, or psychiatric care abroad.
    </p>
  </div>

  <h2 id="quick-decision">Quick Decision Guide</h2>
  <p>
    Short on time? Here's the essential decision framework.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose BUPA Global If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-4">
        <li>✓ Mental health coverage is essential</li>
        <li>✓ You have pre-existing conditions</li>
        <li>✓ You need strong maternity benefits ($75K)</li>
        <li>✓ You want dental and vision included</li>
        <li>✓ All-inclusive coverage gives you peace of mind</li>
        <li>✓ Budget is flexible for premium protection</li>
        <li>✓ You value no-claims discounts over time</li>
      </ul>
      <a href="/go/bupa-global" class="inline-block px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm font-medium" style="color: white !important;">Get BUPA Quote →</a>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose IMG Global If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-4">
        <li>✓ Minimizing premium cost is priority #1</li>
        <li>✓ You're young and healthy</li>
        <li>✓ You have no pre-existing conditions</li>
        <li>✓ Mental health coverage isn't critical for you</li>
        <li>✓ You're not planning to have children</li>
        <li>✓ You can handle a high deductible</li>
        <li>✓ You live outside the US (50% deductible waiver)</li>
      </ul>
      <a href="/go/img-global" class="inline-block px-4 py-2 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors text-sm font-medium" style="color: white !important;">Get IMG Quote →</a>
    </div>
  </div>

  <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Premium vs Budget</h3>
    <p class="text-neutral-600 mb-4">The right choice depends on your health needs, not just your budget.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/bupa-global" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get BUPA Quote</a>
      <a href="/go/img-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get IMG Quote</a>
    </div>
  </div>

  <h2 id="coverage-comparison">Coverage Comparison</h2>
  <p>
    This comparison highlights the premium vs budget trade-off clearly. BUPA Global includes benefits that IMG Global either limits, caps, or charges extra for.
  </p>

  <ComparisonTable columns={coverageColumns} rows={coverageRows} />

  <h3>Key Differences Explained</h3>
  <ul>
    <li><strong>Mental health:</strong> BUPA treats mental health equally to physical health. IMG's coverage is limited—a critical gap if you need therapy or psychiatric care</li>
    <li><strong>Pre-existing conditions:</strong> BUPA often covers pre-existing conditions from day one (subject to underwriting). IMG typically excludes them permanently</li>
    <li><strong>Maternity:</strong> BUPA offers up to $75,000. IMG caps at $5,000–$10,000. This is a 7–15x difference</li>
    <li><strong>Dental/vision:</strong> Included in BUPA's Premier and Elite plans. Add-on cost with IMG</li>
    <li><strong>Annual maximum:</strong> BUPA offers unlimited coverage. IMG caps at $8M (still extremely high)</li>
    <li><strong>No-claims discount:</strong> BUPA rewards claim-free years with lower premiums. IMG doesn't offer this</li>
    <li><strong>Deductible range:</strong> IMG goes up to $25,000 for maximum savings. BUPA caps at $5,000</li>
  </ul>

  <h2 id="mental-health-parity">Mental Health: The Parity Difference</h2>
  <p>
    BUPA Global's mental health parity is their standout feature. Here's what that means in practice.
  </p>

  <ComparisonTable columns={mentalHealthColumns} rows={mentalHealthRows} />

  <h3>What "Mental Health Parity" Actually Means</h3>
  <p>
    When BUPA says they offer mental health parity, they mean:
  </p>
  <ul>
    <li><strong>Same coverage limits:</strong> If your plan covers $2M in physical health care, it covers $2M in mental health care</li>
    <li><strong>Same access:</strong> No separate authorization process or additional hoops for mental health</li>
    <li><strong>Same network:</strong> Mental health providers are part of the standard network</li>
    <li><strong>No artificial caps:</strong> No "12 sessions per year" limits that many insurers impose</li>
    <li><strong>Medication coverage:</strong> Psychiatric medications covered like any other prescription</li>
  </ul>

  <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 my-6">
    <p class="font-semibold text-amber-800 mb-2">The Cost of No Mental Health Coverage</p>
    <p class="text-amber-900 text-sm mb-0">
      If you need weekly therapy at $150/session plus psychiatric medication at $100/month, that's ~$9,000/year out-of-pocket with IMG Global. With BUPA Global's parity coverage, you'd pay only your standard deductible and any copays. The premium difference between BUPA and IMG is roughly $1,800–$2,500/year for a 35-year-old—much less than the potential out-of-pocket mental health costs.
    </p>
  </div>

  <h3>IMG Global Mental Health Reality</h3>
  <p>
    IMG Global's mental health coverage is limited:
  </p>
  <ul>
    <li>Outpatient therapy often excluded or severely capped</li>
    <li>Lower limits for inpatient psychiatric care than physical health</li>
    <li>Session limits (e.g., 20 sessions/year) if covered at all</li>
    <li>Some plans exclude mental health entirely</li>
    <li>Check specific plan documents—coverage varies significantly</li>
  </ul>
  <p>
    If mental health support matters to you, BUPA Global is the safer choice. If you're confident you won't need mental health care, IMG's limited coverage may not affect you.
  </p>

  <h2 id="pre-existing-maternity">Pre-Existing Conditions and Maternity</h2>
  <p>
    Beyond mental health, the biggest coverage gaps are in pre-existing conditions and maternity benefits.
  </p>

  <h3>Pre-Existing Conditions</h3>
  <p>
    <strong>BUPA Global</strong> often covers pre-existing conditions from day one:
  </p>
  <ul>
    <li>Subject to medical underwriting during application</li>
    <li>Stable, well-managed conditions often accepted</li>
    <li>Some conditions may have waiting periods or loadings (premium increases)</li>
    <li>Continuation of care is a BUPA priority</li>
  </ul>
  <p>
    <strong>IMG Global</strong> typically excludes pre-existing conditions:
  </p>
  <ul>
    <li>Conditions you have before purchasing are usually excluded permanently</li>
    <li>Limited options for coverage even after waiting periods</li>
    <li>Any condition requiring ongoing treatment remains your out-of-pocket cost</li>
  </ul>

  <h3>Maternity Coverage Comparison</h3>

  <ComparisonTable columns={maternityColumns} rows={maternityRows} />

  <h3>The Maternity Math</h3>
  <p>
    Hospital delivery costs vary significantly by country:
  </p>
  <ul>
    <li><strong>Thailand (private hospital):</strong> $3,000–$8,000</li>
    <li><strong>Spain (private):</strong> €4,000–€10,000</li>
    <li><strong>UK (private):</strong> £5,000–£15,000</li>
    <li><strong>US:</strong> $10,000–$30,000+</li>
    <li><strong>C-section adds:</strong> $3,000–$15,000+ depending on country</li>
  </ul>
  <p>
    IMG Global's $5,000–$10,000 cap might cover a straightforward delivery in Thailand or Portugal. But complications, C-sections, or delivery in expensive countries could leave you with significant out-of-pocket costs. BUPA Global's $75,000 covers virtually any delivery scenario.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-2">Planning a Family?</h3>
    <p class="text-neutral-600 mb-4">If pregnancy is in your future, maternity coverage limits matter significantly.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/go/bupa-global" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium" style="color: white !important;">Get BUPA Quote</a>
      <a href="/go/img-global" class="inline-block px-5 py-2.5 bg-neutral-700 text-white rounded-lg hover:bg-neutral-800 transition-colors font-medium" style="color: white !important;">Get IMG Quote</a>
    </div>
  </div>

  <h2 id="pricing">Pricing Analysis</h2>
  <p>
    BUPA Global typically costs 2–3x more than IMG Global. Here's how the pricing compares across different profiles.
  </p>

  <ComparisonTable columns={pricingColumns} rows={pricingRows} />

  <h3>Understanding the Price Gap</h3>
  <p>
    IMG Global costs less because they:
  </p>
  <ul>
    <li>Limit mental health coverage (expensive to insure)</li>
    <li>Cap maternity at $5,000–$10,000 (pregnancy is costly)</li>
    <li>Exclude pre-existing conditions (reduces risk)</li>
    <li>Don't include dental/vision in base plans</li>
    <li>Offer ultra-high deductibles ($10K–$25K) that shift costs to members</li>
    <li>Have a smaller direct billing network (lower administrative costs)</li>
  </ul>
  <p>
    BUPA Global costs more because they:
  </p>
  <ul>
    <li>Offer mental health parity with physical health</li>
    <li>Provide $75,000 maternity benefits</li>
    <li>Often cover pre-existing conditions</li>
    <li>Include dental/vision in top-tier plans</li>
    <li>Offer unlimited annual coverage</li>
    <li>Maintain a 1.7M+ provider network</li>
    <li>Employ in-house medical teams</li>
  </ul>

  <h2 id="five-year-math">The 5-Year Math</h2>
  <p>
    Let's calculate the long-term cost difference and when BUPA's premium coverage pays off.
  </p>

  <h3>Base Premium Comparison (Age 35, Single)</h3>
  <ul>
    <li><strong>BUPA Global:</strong> ~$300/month = $3,600/year = $18,000 over 5 years</li>
    <li><strong>IMG Global:</strong> ~$115/month = $1,380/year = $6,900 over 5 years</li>
    <li><strong>5-year savings with IMG:</strong> ~$11,100</li>
  </ul>

  <h3>When BUPA Pays Off</h3>
  <p>
    Despite the higher premiums, BUPA Global is actually cheaper if you need:
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h4 class="font-semibold text-neutral-900 mb-3">Mental Health Care</h4>
    <ul class="text-neutral-600 mb-0">
      <li>Weekly therapy ($150/session) + medication ($100/month) = ~$9,000/year</li>
      <li>5-year cost with IMG (out-of-pocket): $45,000</li>
      <li>5-year cost with BUPA (covered): deductible + copays, perhaps $2,000 total</li>
      <li><strong>BUPA saves you: ~$43,000 over 5 years</strong></li>
    </ul>
  </div>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h4 class="font-semibold text-neutral-900 mb-3">Having a Baby</h4>
    <ul class="text-neutral-600 mb-0">
      <li>Hospital delivery with minor complications: $12,000</li>
      <li>IMG Global coverage: $5,000–$10,000 → you owe $2,000–$7,000</li>
      <li>BUPA Global coverage: $75,000 → fully covered (minus deductible)</li>
      <li><strong>BUPA saves you: $2,000–$7,000 per pregnancy</strong></li>
    </ul>
  </div>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h4 class="font-semibold text-neutral-900 mb-3">Pre-Existing Condition Management</h4>
    <ul class="text-neutral-600 mb-0">
      <li>Managing diabetes: medication ($200/mo) + quarterly checkups ($150) = ~$3,000/year</li>
      <li>5-year cost with IMG (out-of-pocket): $15,000</li>
      <li>5-year cost with BUPA (often covered): standard deductible/copays, perhaps $1,500</li>
      <li><strong>BUPA saves you: ~$13,500 over 5 years</strong></li>
    </ul>
  </div>

  <h3>When IMG Global Makes Sense</h3>
  <p>
    IMG Global's $11,100 savings over 5 years is real money if you're:
  </p>
  <ul>
    <li>Healthy with no pre-existing conditions</li>
    <li>Not planning to have children</li>
    <li>Confident you won't need mental health care</li>
    <li>Comfortable with high deductibles and potential out-of-pocket costs</li>
    <li>Living outside the US (benefiting from the 50% deductible waiver)</li>
  </ul>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 my-6">
    <p class="font-semibold text-amber-800 mb-2">IMG's 50% Deductible Waiver</p>
    <p class="text-amber-900 text-sm mb-0">
      IMG Global reduces your deductible by 50% for care outside the US. A $10,000 deductible becomes effectively $5,000 for international care. Combined with their already lower premiums, this makes IMG particularly attractive for healthy expats living outside the United States.
    </p>
  </div>

  <h2 id="network-claims">Provider Networks and Claims</h2>
  <p>
    BUPA Global has a larger direct billing network, while IMG Global compensates with strong customer service ratings.
  </p>

  <ComparisonTable columns={claimsColumns} rows={claimsRows} />

  <h3>BUPA Global Claims Experience</h3>
  <ul>
    <li><strong>1.7M+ providers:</strong> Extensive direct billing network globally</li>
    <li><strong>MembersWorld:</strong> Full-featured portal and app for claims, ID cards, and policy management</li>
    <li><strong>In-house medical team:</strong> BUPA employs medical professionals who can advise on treatment options</li>
    <li><strong>Fast processing:</strong> Most claims processed in 5–7 business days</li>
    <li><strong>24/7 multilingual support:</strong> Help in multiple languages worldwide</li>
  </ul>

  <h3>IMG Global Claims Experience</h3>
  <ul>
    <li><strong>Smaller network:</strong> Less direct billing—expect to pay and claim more often</li>
    <li><strong>4.6/5 Trustpilot:</strong> Higher customer satisfaction rating than BUPA (4.4/5)</li>
    <li><strong>Online portal/app:</strong> Good functionality for claims and policy management</li>
    <li><strong>Processing time:</strong> 5–10 business days typical</li>
    <li><strong>Any provider:</strong> Can see any licensed provider and claim reimbursement</li>
  </ul>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">The Trustpilot Paradox</h3>
    <p class="text-neutral-600 mb-0">
      IMG Global has a higher Trustpilot rating (4.6) than BUPA Global (4.4) despite being the budget option. This suggests IMG delivers strong customer service and reliable claims payment even at lower price points. Don't assume cheaper means worse service—IMG has built a solid reputation for actually paying claims.
    </p>
  </div>

  <h2 id="scenarios">Real-World Scenarios</h2>
  <p>
    Let's walk through specific situations to see how each plan performs.
  </p>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 1: Emergency Surgery in Thailand</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You need emergency appendectomy at a Bangkok private hospital. Total bill: $15,000.</p>
      <p class="text-neutral-600 mb-2"><strong>BUPA Global ($1,000 deductible):</strong> Direct billing likely at major Bangkok hospitals. You pay $1,000 deductible, BUPA pays $14,000 directly.</p>
      <p class="text-neutral-600 mb-0"><strong>IMG Global ($5,000 deductible):</strong> Outside US, deductible is $2,500 (50% waiver). You may pay upfront and claim. IMG reimburses $12,500.</p>
      <p class="text-green-700 font-medium mt-2">Winner: Both handle this well. BUPA has easier direct billing; IMG has competitive effective deductible with waiver.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 2: Depression Treatment Abroad</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You've been abroad a year and are struggling with depression. You need weekly therapy and antidepressants.</p>
