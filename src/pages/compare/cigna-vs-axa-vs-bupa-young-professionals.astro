---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', title: 'Quick Verdict' },
  { id: 'comparison', title: 'Side-by-Side Comparison' },
  { id: 'cigna', title: 'Cigna Global' },
  { id: 'axa', title: 'AXA Global' },
  { id: 'bupa', title: 'Bupa Global' },
  { id: 'pricing', title: 'Pricing Comparison' },
  { id: 'young-professional-needs', title: 'Young Professional Needs' },
  { id: 'best-for', title: 'Best For' },
  { id: 'faqs', title: 'FAQs' },
];

const relatedLinks = [
  { href: '/providers/cigna-global', title: 'Cigna Global Full Review' },
  { href: '/providers/axa-global', title: 'AXA Global Full Review' },
  { href: '/providers/bupa-global', title: 'Bupa Global Full Review' },
  { href: '/insurance-for/remote-workers', title: 'Insurance for Remote Workers' },
  { href: '/insurance-for/freelancers', title: 'Insurance for Freelancers' },
];

const mainComparisonColumns = ['Feature', 'Cigna Global', 'AXA Global', 'Bupa Global'];
const mainComparisonRows = [
  ['Entry-level plan cost', '$1,800-2,400/yr', '$1,600-2,200/yr', '$1,700-2,300/yr'],
  ['Deductible options', '$0-10,000', '$0-5,000', '$0-7,500'],
  ['Mental health coverage', 'Strong—included', 'Good—most plans', 'Excellent—industry leading'],
  ['Telemedicine', '24/7 global access', '24/7 access', '24/7 access'],
  ['Wellness/preventive', 'Comprehensive', 'Moderate', 'Good'],
  ['App experience', 'Excellent app', 'Good app', 'Excellent app'],
  ['Gym/fitness benefits', 'Limited', 'Some plans', 'Select plans offer subsidies'],
  ['Career break flexibility', 'Annual plans only', 'Annual plans only', 'Annual plans only'],
  ['Multi-country coverage', 'Excellent', 'Good', 'Excellent'],
];

const pricingColumns = ['Scenario', 'Cigna Global', 'AXA Global', 'Bupa Global'];
const pricingRows = [
  ['Age 28, $2,500 deductible', '$1,800-2,200/yr', '$1,600-2,000/yr', '$1,700-2,100/yr'],
  ['Age 28, $0 deductible', '$3,200-3,800/yr', '$2,900-3,400/yr', '$3,000-3,600/yr'],
  ['Age 35, $2,500 deductible', '$2,400-2,900/yr', '$2,100-2,600/yr', '$2,300-2,800/yr'],
  ['Age 35, $0 deductible', '$4,000-4,800/yr', '$3,600-4,200/yr', '$3,800-4,500/yr'],
  ['Adding maternity', '+$2,000-4,000/yr', '+$1,800-3,500/yr', '+$2,200-4,200/yr'],
];
---

<PageShell
  title="Cigna vs AXA vs Bupa: Best for Young Professionals 2025"
  description="Compare Cigna, AXA, and Bupa for young professionals aged 25-35. Mental health, telemedicine, flexibility, and value for early-career expats."
  headline="Cigna vs AXA vs Bupa"
  subheadline="Which Provider is Best for Young Professionals?"
  heroImage="/images/compare/young-professionals-hero.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Cigna Global</h3>
        <p class="text-neutral-700 mb-4">Best for young professionals prioritizing comprehensive coverage and global mobility. Strong app, excellent multi-country flexibility, and robust wellness benefits.</p>
        <p class="text-sm font-medium text-primary-700">Best for: Career-focused global mobility</p>
      </div>
      <div class="bg-orange-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-orange-800 mb-3">AXA Global</h3>
        <p class="text-neutral-700 mb-4">Best value option for budget-conscious young professionals. Solid coverage at lower premiums, though wellness benefits are more limited than competitors.</p>
        <p class="text-sm font-medium text-orange-700">Best for: Value-seekers on a budget</p>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Bupa Global</h3>
        <p class="text-neutral-700 mb-4">Best for mental health focus. Industry-leading psychological support, excellent app experience, and some plans offer fitness subsidies for active lifestyles.</p>
        <p class="text-sm font-medium text-purple-700">Best for: Mental health priority</p>
      </div>
    </div>
  </section>

  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <div class="bg-primary-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-primary-800 mb-4">Cigna Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Cigna Global offers comprehensive coverage that grows with your career. Their global network and flexibility make them ideal for ambitious young professionals expecting international moves or assignments.</p>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Strengths for Young Professionals</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Excellent mobile app for claims, ID cards, and provider search</li>
        <li>Strong multi-country coverage for career moves</li>
        <li>24/7 telemedicine in multiple languages</li>
        <li>Comprehensive wellness and preventive care</li>
        <li>Good mental health coverage included</li>
        <li>High deductible options reduce premiums significantly</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Premium pricing—not the cheapest option</li>
        <li>Limited fitness/gym benefits</li>
        <li>Annual commitment required</li>
        <li>Maternity add-on is expensive</li>
      </ul>
    </div>
  </section>

  <section id="axa" class="mb-12">
    <div class="bg-orange-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-orange-800 mb-4">AXA Global Healthcare</h2>
      <p class="text-lg text-neutral-700 mb-6">AXA offers solid coverage at competitive prices, making them attractive for young professionals watching their budget while still wanting quality international coverage.</p>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Strengths for Young Professionals</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Most affordable entry-level premiums</li>
        <li>Good app and digital experience</li>
        <li>24/7 telemedicine access</li>
        <li>Flexible deductible options</li>
        <li>Strong European network</li>
        <li>Decent mental health coverage on most plans</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Wellness benefits less comprehensive than Cigna</li>
        <li>Network strength varies by region</li>
        <li>Mental health coverage below Bupa's level</li>
        <li>Fewer premium plan features</li>
      </ul>
    </div>
  </section>

  <section id="bupa" class="mb-12">
    <div class="bg-purple-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-purple-800 mb-4">Bupa Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Bupa Global stands out for mental health coverage—increasingly important for young professionals facing career pressure, relocations, and work-life balance challenges.</p>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Strengths for Young Professionals</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Industry-leading mental health coverage</li>
        <li>Excellent mobile app experience</li>
        <li>Some plans include gym/fitness subsidies</li>
        <li>24/7 telemedicine with mental health options</li>
        <li>Good work-life balance support programs</li>
        <li>Strong global network</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Mid-range pricing—not the cheapest</li>
        <li>Wellness benefits vary by plan</li>
        <li>Fitness subsidies only on select plans</li>
        <li>Annual commitment required</li>
      </ul>
    </div>
  </section>

  <CTABox
    title="Start Your Global Career with the Right Coverage"
    description="Compare plans designed for mobile young professionals. Get coverage that supports your ambitions without breaking your budget."
    buttonText="Compare Plans Now"
    buttonHref="/best/expat-health-insurance"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing for Young Professionals</h2>
    <p class="text-neutral-600 mb-6">Annual premiums for healthy young professionals. High deductibles ($2,500+) significantly reduce costs—consider this if you're generally healthy and want catastrophic protection.</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">Prices are estimates for comprehensive plans excluding US coverage. Actual quotes depend on nationality, residence country, and health history.</p>
  </section>

  <section id="young-professional-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">What Young Professionals Need</h2>

    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Mental Health Support</h3>
        <p class="text-neutral-700">Career pressure, relocation stress, and work-life balance challenges make mental health coverage essential. Bupa leads here with comprehensive therapy coverage. Cigna and AXA both offer good support, but with lower annual limits. Look for plans covering therapy sessions, not just crisis intervention.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Telemedicine & Digital Access</h3>
        <p class="text-neutral-700">Young professionals expect digital-first healthcare. All three providers offer 24/7 telemedicine, but app quality varies. Cigna and Bupa have the best mobile apps. AXA's is functional but less polished. Consider how often you'll use digital services when choosing.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Career Mobility</h3>
        <p class="text-neutral-700">If you expect to change countries for work, coverage portability matters. Cigna excels at multi-country flexibility with seamless transitions. Bupa is also strong. AXA works well but may require more paperwork for country changes. All allow you to update your location annually.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Budget Optimization</h3>
        <p class="text-neutral-700">Young, healthy professionals can save significantly with high deductibles ($2,500-5,000). You're essentially buying catastrophic coverage at lower premiums. If you rarely see doctors, this makes sense. If you have ongoing needs, lower deductibles may be worth the premium increase.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Future Planning: Maternity</h3>
        <p class="text-neutral-700">If you're thinking about starting a family in the next few years, check maternity coverage now. All three require add-ons with 10-12 month waiting periods. AXA tends to be most affordable for maternity. Plan ahead—you can't add it once pregnant.</p>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Choose Cigna If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You expect multiple international moves</li>
          <li>You want comprehensive wellness benefits</li>
          <li>App quality and digital experience matter</li>
          <li>You're building a long-term global career</li>
          <li>Budget is secondary to coverage quality</li>
        </ul>
      </div>
      <div class="bg-orange-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-orange-800 mb-3">Choose AXA If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Budget is your primary concern</li>
          <li>You're healthy and want basic protection</li>
          <li>You're based in Europe</li>
          <li>You want affordable maternity options</li>
          <li>You don't need extensive wellness programs</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Choose Bupa If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Mental health coverage is a priority</li>
          <li>You value work-life balance support</li>
          <li>Fitness benefits appeal to you</li>
          <li>You want strong therapy coverage</li>
          <li>You're willing to pay for premium mental health</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What's the best deductible for a healthy 28-year-old?</h3>
        <p class="text-neutral-700">If you rarely see doctors and have no ongoing conditions, a $2,500-5,000 deductible can save $1,000-1,500/year in premiums. You're covered for serious issues while minimizing costs. If you have regular healthcare needs, lower deductibles make more sense despite higher premiums.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Should I get coverage through my employer or buy my own?</h3>
        <p class="text-neutral-700">Employer coverage is often cheaper (they subsidize it), but you lose it when you leave. Personal coverage is portable between jobs. If you're early in your career and may change employers, personal coverage provides stability. If you're at a stable company with good benefits, use theirs.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I handle coverage during job transitions?</h3>
        <p class="text-neutral-700">With personal coverage, no gap exists—your plan continues regardless of employment. If relying on employer coverage, bridge with short-term travel insurance during gaps, or time your personal plan purchase before leaving your job. Never be uninsured abroad.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is mental health coverage really necessary at my age?</h3>
        <p class="text-neutral-700">Statistically, mental health issues peak in your 20s and 30s. Career stress, relocation adjustment, and relationship pressures are real. Even if you feel fine now, having coverage means you can seek help without cost barriers. The stigma has reduced—using mental health services is increasingly normal and beneficial.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I add a partner to my plan if we're not married?</h3>
        <p class="text-neutral-700">Most international plans allow domestic partners without marriage requirements. You'll typically need to show you live together. Same-sex partners are usually accepted equally. Check specific provider policies—Bupa and Cigna are generally flexible on relationship definitions.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I want to return home for a few months?</h3>
        <p class="text-neutral-700">International plans typically cover home visits up to 30-90 days per year. If you're returning longer, you may need to adjust your coverage area or switch to home country insurance temporarily. Check your plan's home country coverage limits before extended visits.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 mb-12">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Prices and coverage details are estimates for illustrative purposes. Actual premiums depend on age, nationality, residence country, health history, and selected coverage options. Contact providers directly for accurate quotes. Young professional needs vary—assess your specific situation before choosing.
    </p>
  </div>
</PageShell>
