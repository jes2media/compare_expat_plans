---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Croatia Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Croatia's Digital Nomad Visa. Expert analysis of Cigna Global, SafetyWing, and Allianz Care for remote workers moving to Croatia.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz-care", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "Croatia Visa Acceptance", cigna: "✓ Widely accepted", safetywing: "✓ Accepted for DN visa", allianz: "✓ Widely accepted" },
  { feature: "Croatian Network", cigna: "Good (private hospitals)", safetywing: "Reimbursement model", allianz: "Good (private hospitals)" },
  { feature: "Schengen Coverage", cigna: "✓ Full Europe", safetywing: "✓ Worldwide", allianz: "✓ Full Europe" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Acute onset only", allianz: "Moratorium option" },
  { feature: "Monthly Flexibility", cigna: "Annual commitment", safetywing: "✓ Month-to-month", allianz: "Annual commitment" },
  { feature: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Full coverage" },
  { feature: "Annual Maximum", cigna: "€1M - Unlimited", safetywing: "$250,000", allianz: "€1M - Unlimited" },
  { feature: "Best For", cigna: "Long-term settlers", safetywing: "Budget nomads", allianz: "Premium seekers" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "100% covered", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited visits", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100,000", allianz: "Unlimited" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Emergency only", allianz: "100% covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", allianz: "Optional" },
  { coverage: "Wellness/Preventive", cigna: "Annual checkup", safetywing: "Not covered", allianz: "Annual checkup" },
  { coverage: "COVID-19", cigna: "Full coverage", safetywing: "Full coverage", allianz: "Full coverage" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "€140-220/month", safetywing: "$45-56/month", allianz: "€130-200/month" },
  { age: "30-35", cigna: "€170-260/month", safetywing: "$68-84/month", allianz: "€160-240/month" },
  { age: "35-40", cigna: "€210-320/month", safetywing: "$99-123/month", allianz: "€200-300/month" },
  { age: "40-45", cigna: "€260-400/month", safetywing: "$135-168/month", allianz: "€250-380/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { region: "Zagreb", cigna: "Good - private clinics", safetywing: "Reimbursement", allianz: "Good - private clinics" },
  { region: "Split", cigna: "Limited - some private", safetywing: "Reimbursement", allianz: "Limited - some private" },
  { region: "Dubrovnik", cigna: "Limited", safetywing: "Reimbursement", allianz: "Limited" },
  { region: "Rijeka", cigna: "Limited", safetywing: "Reimbursement", allianz: "Limited" },
  { region: "Islands", cigna: "Very limited", safetywing: "Reimbursement + evacuation", allianz: "Very limited" },
  { region: "Schengen Area", cigna: "Full coverage", safetywing: "Full coverage", allianz: "Full coverage" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Croatia's Digital Nomad Visa"
    heroImage="/images/countries/croatia-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Croatia Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Croatia launched its Digital Nomad Visa in 2021, becoming one of the first EU countries to offer such a program. As an EU member state, Croatia's insurance requirements align with Schengen standards, though the visa itself grants residence outside the Schengen Area (Croatia joined Schengen in 2023).
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Valid health insurance covering your entire stay in Croatia</li>
          <li>• Minimum coverage of €30,000 (standard Schengen requirement)</li>
          <li>• Must cover hospitalization, emergency care, and repatriation</li>
          <li>• Insurance from a recognized EU or international provider</li>
          <li>• Coverage must be valid from the visa start date</li>
          <li>• Visa duration: up to 1 year, renewable once</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Croatia has a good public healthcare system (HZZO), but digital nomads don't have automatic access. You'll rely on private insurance and private healthcare facilities, or pay out-of-pocket at public facilities (costs are moderate by Western European standards).
      </p>

      <p class="text-neutral-700">
        The visa requires proof of remote work (employment contract or client contracts), minimum income of €2,540/month (or €2,540 × 6 in savings), and accommodation in Croatia. Insurance is a straightforward requirement that all major international insurers meet.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Top 3 Insurers for Croatia Digital Nomad Visa</h2>

      <p class="text-neutral-700 mb-6">
        We've analyzed options from budget-friendly nomad insurance to comprehensive international coverage. All meet Croatia's visa requirements.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive international coverage well-suited for digital nomads planning longer stays in Croatia. Their European coverage is excellent, and modular plans allow customization.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Full Schengen/EU coverage for travel</li>
            <li>• Access to private hospitals in Zagreb</li>
            <li>• Comprehensive mental health coverage</li>
            <li>• Modular plans for customization</li>
            <li>• Good for longer-term stays</li>
            <li>• 24/7 multilingual support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Annual commitment required</li>
            <li>• Higher cost than nomad insurance</li>
            <li>• Limited Croatian-specific network</li>
            <li>• May be overkill for short stays</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive coverage for European digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing is designed specifically for digital nomads, with flexible monthly subscriptions and pricing that appeals to location-independent workers. Their Nomad Insurance is accepted for Croatia's DN visa.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable (starts under $50/month)</li>
            <li>• Month-to-month flexibility</li>
            <li>• Designed for nomad lifestyle</li>
            <li>• Worldwide coverage</li>
            <li>• Easy online management</li>
            <li>• Meets Croatia DN visa requirements</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Lower coverage limits ($250K max)</li>
            <li>• Pre-existing: acute onset only</li>
            <li>• No routine/preventive care</li>
            <li>• Reimbursement model everywhere</li>
            <li>• Limited mental health coverage</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget-friendly insurance for digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers flexible international coverage with strong European networks. Their brand is well-recognized across EU countries, and they offer various plan tiers to match different budgets.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong European coverage</li>
            <li>• Brand recognition in EU</li>
            <li>• Flexible plan options</li>
            <li>• Good wellness benefits</li>
            <li>• Multiple deductible choices</li>
            <li>• Comprehensive coverage</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Annual commitment</li>
            <li>• Croatian network limited</li>
            <li>• Claims can take time</li>
            <li>• Similar pricing to Cigna</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="Trusted European coverage for digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/allianz"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        All three options meet Croatia's €30,000 minimum requirement. Here's how they compare in depth:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing covers emergencies and hospital stays but lacks routine care. For nomads with ongoing health needs, Cigna or Allianz provide more comprehensive coverage.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically more affordable, but with corresponding coverage limitations:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing's pricing makes it attractive for healthy nomads testing Croatia. For longer commitments or health needs, comprehensive plans justify their cost.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Croatia</h2>

      <p class="text-neutral-700 mb-6">
        Croatia has good healthcare but limited private options outside Zagreb. Here's what to expect:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Zagreb has the best private healthcare infrastructure. Coastal cities have decent facilities, but islands and rural areas are limited. All insurers use reimbursement for most Croatian providers.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Testing Croatia for 3 Months</h3>
          <p class="text-neutral-600 mb-3">28-year-old developer, healthy, trying Split for one summer season.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">Perfect for testing. Month-to-month flexibility, meets visa requirements, affordable. Upgrade if you decide to extend.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Full Year in Zagreb</h3>
          <p class="text-neutral-600 mb-3">35-year-old designer committing to a full year in Zagreb, wants comprehensive coverage.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Allianz Care</p>
          <p class="text-neutral-600 text-sm">Year commitment makes annual plans cost-effective. Access to Zagreb private clinics. Comprehensive coverage for peace of mind.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Nomad with Mental Health Needs</h3>
          <p class="text-neutral-600 mb-3">32-year-old who sees a therapist regularly, planning 6 months in Croatia.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Best mental health coverage. Can continue therapy via telehealth or find English-speaking therapists in Zagreb.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Island-Hopping Nomad</h3>
          <p class="text-neutral-600 mb-3">30-year-old planning to work from various Croatian islands throughout the year.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global or Allianz Care</p>
          <p class="text-neutral-600 text-sm">Evacuation coverage important for islands. All insurers use reimbursement in Croatia anyway, but comprehensive coverage provides better catastrophic protection.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Budget-Conscious Long-Term Stay</h3>
          <p class="text-neutral-600 mb-3">26-year-old, very healthy, wants to minimize costs while staying a full year.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">Meets visa requirements at lowest cost. Croatian private care is affordable out-of-pocket for routine needs. SafetyWing covers emergencies and hospital stays.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For budget-conscious nomads, <strong>SafetyWing</strong> offers excellent value and meets all visa requirements. For those wanting comprehensive coverage or planning longer stays, <strong>Cigna Global</strong> provides the best combination of benefits and European coverage. <strong>Allianz Care</strong> is a strong alternative with good brand recognition in the EU.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Budget is priority</li>
            <li>• Very healthy</li>
            <li>• Want flexibility</li>
            <li>• Testing Croatia short-term</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want comprehensive coverage</li>
            <li>• Need mental health benefits</li>
            <li>• Planning 1+ year stay</li>
            <li>• Travel across Europe</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Prefer EU brand</li>
            <li>• Want flexible deductibles</li>
            <li>• Value wellness benefits</li>
            <li>• Based mainly in EU</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use Croatian public healthcare with the DN visa?</h3>
          <p class="text-neutral-600">Not automatically. The DN visa doesn't grant access to HZZO (Croatian public health insurance). You can use public facilities by paying out-of-pocket (costs are reasonable) or rely entirely on your private insurance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What's the income requirement for Croatia's DN visa?</h3>
          <p class="text-neutral-600">You need to prove minimum monthly income of €2,540 (about HRK 19,000) or have at least €2,540 × 6 = €15,240 in savings. This is lower than many digital nomad visas.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is Croatia in the Schengen Area?</h3>
          <p class="text-neutral-600">Yes, Croatia joined Schengen in January 2023. This means your Croatian DN visa allows free travel throughout the Schengen Area. Your insurance should cover you across the Schengen zone—all three options do.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about dental care in Croatia?</h3>
          <p class="text-neutral-600">Croatia is known for dental tourism—high quality at lower prices than Western Europe. You can pay out-of-pocket for dental work affordably, or add dental coverage to Cigna or Allianz plans if you want it included.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I extend the DN visa?</h3>
          <p class="text-neutral-600">Yes, the initial visa is for up to 1 year, and you can renew it once for another year (2 years total). After that, you'd need to apply for a different residence permit or leave for a period before reapplying.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Where do most digital nomads live in Croatia?</h3>
          <p class="text-neutral-600">Zagreb is the hub for year-round nomads (coworking spaces, community, best healthcare). Split and Dubrovnik are popular in warmer months. Islands like Hvar attract summer visitors but have limited infrastructure for long-term stays.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Insurance requirements and visa rules change. Verify current requirements with the Croatian Ministry of Interior or a local immigration lawyer. Confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or legal advice.</p>
    </div>
  </PageShell>
</Layout>
