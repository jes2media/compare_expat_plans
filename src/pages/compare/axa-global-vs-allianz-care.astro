  { key: 'profile', header: 'Profile' },
  { key: 'axa', header: 'AXA Comfort' },
  { key: 'allianz', header: 'Allianz Enhanced' },
];

const pricingRows = [
  { profile: 'Age 30, ex-US', axa: '€150-200/mo', allianz: '€110-140/mo' },
  { profile: 'Age 40, ex-US', axa: '€200-280/mo', allianz: '€135-180/mo' },
  { profile: 'Age 50, ex-US', axa: '€300-400/mo', allianz: '€220-300/mo' },
  { profile: 'Age 60, ex-US', axa: '€450-600/mo', allianz: '€350-400/mo' },
  { profile: 'Family of 4', axa: '€500-700/mo', allianz: '€380-500/mo' },
];

const planTiersColumns = [
  { key: 'tier', header: 'Tier' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const planTiersRows = [
  { tier: 'Entry Level', axa: 'Essential', allianz: 'Base' },
  { tier: 'Mid-Range', axa: 'Comfort', allianz: 'Enhanced' },
  { tier: 'Premium', axa: 'Excellence', allianz: 'Signature' },
  { tier: 'Ultra-Premium', axa: 'Exclusive', allianz: 'N/A' },
