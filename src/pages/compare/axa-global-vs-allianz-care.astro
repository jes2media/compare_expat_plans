];

const coverageColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const coverageRows = [
  { feature: 'Headquarters', axa: 'Paris, France', allianz: 'Munich, Germany' },
  { feature: 'Regulation', axa: 'French ACPR (EU)', allianz: 'EU regulated' },
  { feature: 'Network Size', axa: '1.6M+ providers', allianz: '2M+ providers' },
  { feature: 'Maximum Coverage', axa: 'Up to Unlimited', allianz: 'Up to €5M' },
