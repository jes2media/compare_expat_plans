---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'cancer-coverage', text: 'Cancer Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/compare/allianz-vs-bupa-vs-cigna-pre-existing-conditions', text: 'Pre-existing Conditions' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/aetna-international', text: 'Aetna Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'bupa', header: 'Bupa Global' },
];

const mainComparisonRows = [
  { feature: 'Cancer Treatment Limits', cigna: 'Unlimited', aetna: 'Unlimited', bupa: 'Unlimited' },
  { feature: 'Chemotherapy', cigna: 'Full coverage', aetna: 'Full coverage', bupa: 'Full coverage' },
  { feature: 'Radiation Therapy', cigna: 'Full coverage', aetna: 'Full coverage', bupa: 'Full coverage' },
  { feature: 'Immunotherapy', cigna: 'Covered', aetna: 'Covered', bupa: 'Covered' },
  { feature: 'Second Opinion Program', cigna: 'Included', aetna: 'Mayo/Cleveland Clinic', bupa: 'Premium option' },
  { feature: 'Centers of Excellence', cigna: 'Global network', aetna: 'US-focused', bupa: 'UK/Europe strong' },
  { feature: 'Experimental Treatment', cigna: 'Case by case', aetna: 'Clinical trials access', bupa: 'Limited' },
  { feature: 'Cancer Screening', cigna: 'Comprehensive', aetna: 'Comprehensive', bupa: 'Comprehensive' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'aetna', header: 'Aetna International' },
  { key: 'bupa', header: 'Bupa Global' },
];

const pricingRows = [
  { profile: 'Individual (45, comprehensive)', cigna: '$450-600/mo', aetna: '$480-650/mo', bupa: '$500-680/mo' },
  { profile: 'Couple (50s)', cigna: '$900-1,200/mo', aetna: '$950-1,300/mo', bupa: '$1,000-1,350/mo' },
  { profile: 'Family (parents 40s)', cigna: '$1,100-1,450/mo', aetna: '$1,150-1,550/mo', bupa: '$1,200-1,600/mo' },
  { profile: 'Senior (62)', cigna: '$750-1,000/mo', aetna: '$800-1,100/mo', bupa: '$850-1,150/mo' },
];
---

<PageShell
  title="Cigna vs Aetna vs Bupa for Cancer Coverage | 2025 Comparison"
  description="Compare Cigna Global, Aetna International, and Bupa Global for cancer coverage. Expert analysis of treatment limits, second opinions, and centers of excellence."
  headline="Cigna vs Aetna vs Bupa: Best Cancer Coverage for Expats"
  subheadline="Complete comparison of three leading providers for comprehensive cancer treatment coverage, second opinions, and access to world-class oncology centers."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Global Access</p>
        <p class="text-neutral-700 text-sm mb-4">Largest global network of oncology centers with comprehensive second opinion program included. Excellent worldwide cancer care access.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Aetna International</h3>
        <p class="text-purple-700 mb-3">Best US Cancer Centers</p>
        <p class="text-neutral-700 text-sm mb-4">Direct access to Mayo Clinic, MD Anderson, and Memorial Sloan Kettering. Best choice for US-based cancer treatment.</p>
        <a href="/providers/aetna-international" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Bupa Global</h3>
        <p class="text-green-700 mb-3">Best UK/Europe Care</p>
        <p class="text-neutral-700 text-sm mb-4">Strong relationships with leading European oncology centers. Excellent chronic cancer management and follow-up care.</p>
        <a href="/providers/bupa-global" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Global Oncology Network</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Second Opinion Included</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global provides comprehensive cancer coverage with no annual or lifetime limits on treatment. Their global network includes partnerships with leading oncology centers on every continent, ensuring access to quality cancer care wherever you live or travel.</p>

    <p class="text-neutral-700 mb-4">The included second medical opinion program connects you with oncology specialists to review your diagnosis and treatment plan. This is invaluable for cancer where treatment decisions significantly impact outcomes. Cigna's care coordination team helps navigate complex treatment journeys across multiple providers.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Cancer Coverage Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Unlimited treatment coverage</li>
          <li>• Largest global oncology network</li>
          <li>• Second opinion program included</li>
          <li>• Comprehensive screening covered</li>
          <li>• Care coordination support</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Experimental treatments case-by-case</li>
          <li>• US access may cost more</li>
          <li>• Prior authorization required</li>
          <li>• Some treatments need pre-approval</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">US Cancer Centers</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Mayo/Cleveland Clinic</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Clinical Trial Access</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International excels for expats who want access to America's premier cancer centers. Their partnerships with Mayo Clinic, MD Anderson, Memorial Sloan Kettering, and Cleveland Clinic provide direct access to world-leading oncologists and cutting-edge treatments.</p>

    <p class="text-neutral-700 mb-4">For complex or rare cancers, Aetna's clinical trial access is a significant advantage—they can help identify relevant trials and coordinate participation. The second opinion program specifically utilizes these top US institutions, ensuring expert review of your case.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Cancer Coverage Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Direct US cancer center access</li>
          <li>• Mayo/Cleveland Clinic partnerships</li>
          <li>• Clinical trial coordination</li>
          <li>• Second opinions from top oncologists</li>
          <li>• Unlimited treatment coverage</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• US-centric network</li>
          <li>• Less strong outside Americas</li>
          <li>• May require US travel</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Aetna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">UK/Europe Oncology</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Long-term Management</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Support Services</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global has deep relationships with leading oncology centers across the UK and Europe, including partnerships with Christie NHS Foundation Trust, Institut Gustave Roussy, and other world-class European cancer hospitals. Their care is particularly strong for ongoing cancer management and survivorship.</p>

    <p class="text-neutral-700 mb-4">Support services extend beyond treatment—Bupa offers cancer support programs including psychological counseling, nutrition guidance, and rehabilitation. For expats with chronic cancer requiring long-term management, Bupa's continuity of care is excellent.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Cancer Coverage Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Strong UK/Europe oncology network</li>
          <li>• Excellent long-term management</li>
          <li>• Comprehensive support services</li>
          <li>• Cancer counseling included</li>
          <li>• Survivorship programs</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Second opinion is premium option</li>
          <li>• Limited experimental treatment</li>
          <li>• US centers less accessible</li>
          <li>• Higher premiums for full coverage</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <CTABox
    title="Compare Cancer Coverage Quotes"
    description="Get personalized quotes with comprehensive cancer coverage from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Comprehensive plans with full cancer coverage. Cancer treatment itself is fully covered—no separate limits:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Cancer treatment costs can reach $500K+ for complex cases. All three providers offer unlimited cancer treatment coverage on comprehensive plans.</p>
  </section>

  <section id="cancer-coverage" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cancer Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Treatment Types Covered</h3>
        <p class="text-neutral-700 text-sm mb-4">All three cover standard cancer treatments:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Chemotherapy and radiation</li>
          <li>• Surgery (all types)</li>
          <li>• Immunotherapy and targeted therapy</li>
          <li>• Hormone therapy</li>
          <li>• Stem cell transplants</li>
          <li>• Palliative care when needed</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Screening & Prevention</h3>
        <p class="text-neutral-700 text-sm mb-4">Early detection saves lives—all cover:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Mammograms and breast exams</li>
          <li>• Colonoscopies</li>
          <li>• PSA testing</li>
          <li>• Skin cancer screening</li>
          <li>• Cervical cancer screening</li>
          <li>• Genetic testing (case by case)</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Centers of Excellence</h3>
      <p class="text-blue-700 mb-4">Where each provider has strongest oncology partnerships:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">Global network including Singapore, Germany, Australia, and US centers. Strong presence across Asia-Pacific and Europe.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Aetna</h4>
          <p class="text-blue-700 text-sm">Best US access: Mayo Clinic, MD Anderson, Memorial Sloan Kettering, Cleveland Clinic. Good Latin America coverage.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">Leading UK/Europe centers including Royal Marsden, Christie, and Institut Gustave Roussy. Strong Middle East relationships.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the largest global oncology network</li>
          <li>• Second opinion program included is important</li>
          <li>• You may need cancer care in Asia or multiple regions</li>
          <li>• Comprehensive care coordination matters to you</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Aetna International if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Access to top US cancer centers is your priority</li>
          <li>• You want Mayo/Cleveland Clinic second opinions</li>
          <li>• Clinical trial access matters for your situation</li>
          <li>• You have US ties and may receive treatment there</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• You're based in Europe or the UK</li>
          <li>• Long-term cancer management is a concern</li>
          <li>• Support services beyond treatment matter</li>
          <li>• You value European oncology excellence</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is cancer diagnosed before I buy insurance covered?</h3>
        <p class="text-neutral-700">Generally no—pre-existing cancer is excluded. However, if you've been cancer-free for a period (often 5+ years), some insurers may offer coverage for new, unrelated cancers. Always disclose your full medical history; non-disclosure can void your entire policy.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if I want treatment at a specific cancer center?</h3>
        <p class="text-neutral-700">All three providers allow treatment at their network centers. For out-of-network centers, coverage may be reduced or require pre-authorization. If a specific center is important to you, verify it's covered before enrolling. Aetna has best direct relationships with top US centers.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are experimental or cutting-edge treatments covered?</h3>
        <p class="text-neutral-700">Standard treatments are fully covered. Experimental treatments are typically case-by-case decisions. Aetna has the best clinical trial access and may cover trial-related care. Cigna and Bupa can approve experimental treatments but more conservatively. Always get pre-authorization.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about cancer-related costs beyond treatment?</h3>
        <p class="text-neutral-700">Comprehensive plans cover related costs: medications, imaging, lab tests, hospital stays, and follow-up care. Travel for treatment may be partially covered. Bupa includes psychological support and rehabilitation. Check your specific policy for coverage of wigs, prosthetics, and fertility preservation.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Cancer treatment decisions should be made with your oncologist. Insurance coverage details change frequently and vary by plan level. Pre-existing conditions and experimental treatments have specific exclusions. Always verify cancer coverage specifics directly with providers before purchasing. This comparison is for informational purposes only and does not constitute medical or insurance advice.</p>
  </div>
</PageShell>
