---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "cigna", title: "Cigna Global" },
  { id: "bupa", title: "Bupa Global" },
  { id: "aetna", title: "Aetna International" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "south-america-details", title: "South America Considerations" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/providers/bupa-global", title: "Bupa Global Review" },
  { href: "/providers/aetna-international", title: "Aetna International Review" },
  { href: "/countries/mexico/insurance", title: "Mexico Insurance Guide" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "aetna", header: "Aetna International" },
];

const mainComparisonRows = [
  { feature: "South America Network", cigna: "Extensive", bupa: "Excellent", aetna: "Good" },
  { feature: "Brazil Coverage", cigna: "Strong", bupa: "Strong", aetna: "Moderate" },
  { feature: "Argentina Coverage", cigna: "Good", bupa: "Good", aetna: "Moderate" },
  { feature: "Colombia Coverage", cigna: "Good", bupa: "Excellent", aetna: "Limited" },
  { feature: "Spanish/Portuguese Support", cigna: "Available", bupa: "Strong", aetna: "Available" },
  { feature: "US Evacuation", cigna: "Full coverage", bupa: "Full coverage", aetna: "Included" },
  { feature: "Regional Hospitals", cigna: "Direct billing", bupa: "Direct billing", aetna: "Select facilities" },
  { feature: "Tropical Disease", cigna: "Full coverage", bupa: "Full coverage", aetna: "Full coverage" },
  { feature: "High Altitude Coverage", cigna: "Full coverage", bupa: "Full coverage", aetna: "Full coverage" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "aetna", header: "Aetna International" },
];

const pricingRows = [
  { profile: "35-year-old, individual", cigna: "$2,800–3,800/yr", bupa: "$2,400–3,400/yr", aetna: "$3,200–4,200/yr" },
  { profile: "45-year-old, individual", cigna: "$4,200–5,600/yr", bupa: "$3,600–5,000/yr", aetna: "$4,600–6,200/yr" },
  { profile: "Couple (both 40)", cigna: "$6,800–9,200/yr", bupa: "$5,800–8,200/yr", aetna: "$7,600–10,200/yr" },
  { profile: "Family (2 adults, 2 kids)", cigna: "$11,400–15,400/yr", bupa: "$9,800–13,800/yr", aetna: "$12,600–17,000/yr" },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna: Health Insurance for South America (2025)"
  description="Compare international health insurance for expats in South America. Analysis of Cigna Global, Bupa Global, and Aetna International for Brazil, Argentina, Colombia, Chile, and beyond."
  headline="Cigna vs Bupa vs Aetna: South America Coverage Compared"
  intro="South America attracts expats with its vibrant cultures, lower costs, and growing economies. Healthcare quality varies dramatically—from world-class hospitals in São Paulo and Buenos Aires to limited options in remote areas. Here's how Cigna Global, Bupa Global, and Aetna International compare for expats across the continent."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 font-semibold mb-2">Best Overall for South America</p>
        <p class="text-neutral-700 text-sm">Strong networks across Brazil, Argentina, Chile, and Colombia. Comprehensive coverage with reliable claims processing. Premium pricing justified by service quality.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best Value for South America</p>
        <p class="text-neutral-700 text-sm">Excellent regional networks, particularly strong in Colombia and Brazil. Best balance of coverage and cost. Spanish/Portuguese language support.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 font-semibold mb-2">Best for US Citizens</p>
        <p class="text-neutral-700 text-sm">Integrated US coverage valuable for Americans. Smaller South America network but US evacuation included. Best for those with strong US ties.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">South America Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Continental coverage:</strong> Networks in Brazil, Argentina, Chile, Colombia, Peru, Ecuador</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Premium hospitals:</strong> Access to Sírio-Libanês (Brazil), Hospital Alemán (Argentina), Clínica Las Condes (Chile)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Direct billing:</strong> Cashless treatment at major facilities</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Evacuation:</strong> Transport to US, Miami, or home country</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Regional support:</strong> Spanish and Portuguese speaking assistance</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global maintains strong relationships with top hospitals across South America. In Brazil, you'll find direct billing at Hospital Sírio-Libanês and Hospital Albert Einstein—both world-class facilities. Argentina's Hospital Alemán and Chile's Clínica Las Condes are similarly integrated.
    </p>
    <p class="text-neutral-700">
      The comprehensive coverage handles everything from routine care to complex procedures. If local facilities can't handle your needs, evacuation to US medical centers (typically Miami) is covered. For expats in smaller cities or countries, this safety net matters.
    </p>
  </section>

  <!-- Bupa Global Section -->
  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">South America Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Excellent Colombia network:</strong> Strong presence in Bogotá, Medellín, Cartagena</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Brazil coverage:</strong> Major cities well covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Competitive pricing:</strong> Lower premiums than Cigna</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Language support:</strong> Native Spanish and Portuguese speakers</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Moratorium option:</strong> Easier enrollment with health history</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Bupa Global's South America network is particularly strong in Colombia, where they've invested significantly in recent years. Bogotá's top hospitals, Medellín's renowned medical tourism facilities, and Cartagena's private clinics are all well integrated. Brazil and Argentina coverage is similarly robust.
    </p>
    <p class="text-neutral-700">
      The pricing advantage matters for budget-conscious expats. Premiums run 15-25% lower than Cigna while offering comparable coverage. The language support—with native Spanish and Portuguese speakers—helps navigate the complex healthcare systems in these countries.
    </p>
  </section>

  <!-- Aetna International Section -->
  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">South America Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>US network included:</strong> Seamless coverage when traveling to America</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Miami access:</strong> Easy access to US medical centers</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Brazil network:</strong> Coverage in major Brazilian cities</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>CVS Health:</strong> Prescription access during US visits</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-600 mt-1">△</span>
          <span><strong>Limited regional network:</strong> Less extensive than Cigna or Bupa</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Aetna International's South America network is smaller than Cigna or Bupa's, but the integrated US coverage provides unique value for Americans. The short flight to Miami means US-quality care is always accessible, and Aetna covers it without add-ons.
    </p>
    <p class="text-neutral-700">
      For Americans living in South America who maintain strong US ties—frequent visits, family connections, preference for US medical care—Aetna simplifies coverage. You don't need separate policies or evacuation-only US access; it's all integrated.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get South America Insurance Quotes"
    description="Compare plans from Cigna, Bupa, and Aetna for expats in South America."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      South America generally has lower insurance premiums than North America or Europe, reflecting lower local healthcare costs. However, comprehensive coverage still represents a significant expense.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for Latin America regional coverage. Aetna prices include integrated US coverage.
    </p>
  </section>

  <!-- South America Details Section -->
  <section id="south-america-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">South America Healthcare Realities</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Healthcare Quality Varies by Country and City</h3>
        <p class="text-neutral-700 mb-3">
          Brazil's private hospitals in São Paulo rival anything in the world. Argentina's Buenos Aires has excellent facilities. Chile's healthcare is highly developed. But rural areas across the continent—and even secondary cities—may have limited options.
        </p>
        <p class="text-neutral-700">
          Your insurance strategy should match your location. In major cities, local care is usually excellent. In smaller towns or more remote areas, evacuation capability becomes more important. All three insurers cover evacuation when local facilities are insufficient.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Medical Tourism Hotspots</h3>
        <p class="text-neutral-700 mb-3">
          Colombia has become a medical tourism destination, particularly Medellín. Dental work, cosmetic procedures, and even complex surgeries draw people from North America. Brazil's reputation for certain specialties is similarly strong.
        </p>
        <p class="text-neutral-700">
          Your insurance covers medically necessary treatment, not elective procedures. But if you develop a condition requiring surgery, you might receive excellent care locally at a fraction of US costs—with your insurance covering it fully.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Altitude and Regional Considerations</h3>
        <p class="text-neutral-700 mb-3">
          Cities like Bogotá (2,640m), Quito (2,850m), and La Paz (3,640m) sit at significant altitude. Altitude sickness is covered as a medical condition. Chronic conditions may behave differently at altitude—cardiovascular and respiratory issues particularly.
        </p>
        <p class="text-neutral-700">
          Amazon regions present different challenges—tropical diseases, limited medical access, potential need for evacuation. Patagonia's remoteness similarly requires robust evacuation coverage. All three insurers understand these regional variations.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Language Considerations</h3>
        <p class="text-neutral-700 mb-3">
          Spanish is spoken throughout most of South America; Brazil speaks Portuguese. Medical terminology in another language adds complexity to healthcare interactions. All three insurers offer Spanish/Portuguese support, but Bupa's native-speaker support is particularly strong.
        </p>
        <p class="text-neutral-700">
          In major cities, many doctors speak English, especially at international hospitals. Smaller cities may require more language navigation. Having an insurer who can communicate in the local language helps resolve complex situations.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want strongest continental coverage</li>
          <li>• Premium hospital access matters</li>
          <li>• You travel across multiple countries</li>
          <li>• Comprehensive coverage is priority</li>
          <li>• Claims reliability is important</li>
          <li>• You're in the region long-term</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose Bupa If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're based in Colombia</li>
          <li>• Lower premiums are important</li>
          <li>• Language support matters</li>
          <li>• You have health history (moratorium)</li>
          <li>• Value for money is priority</li>
          <li>• Brazil or Colombia is your base</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Aetna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're an American expat</li>
          <li>• Integrated US coverage matters</li>
          <li>• You travel frequently to the US</li>
          <li>• Miami access is valuable</li>
          <li>• Your employer provides Aetna</li>
          <li>• US prescription access is needed</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Does coverage work across all South American countries?</h3>
        <p class="text-neutral-700">
          Yes—regional plans cover you throughout South America. Network strength varies by country, but you're covered everywhere. Venezuela may have restrictions with some insurers due to political situation—verify before traveling there.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about dental tourism in South America?</h3>
        <p class="text-neutral-700">
          Elective dental work isn't covered by health insurance. But if you develop a dental emergency or need medically necessary dental surgery, it's covered. Many expats pay out-of-pocket for routine dental—it's remarkably affordable in countries like Colombia and Argentina.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I handle prescriptions?</h3>
        <p class="text-neutral-700">
          Prescription coverage is included. Many medications are available locally, often cheaper than North America. Some controlled substances may require special permits. Brand names may differ—work with local pharmacists or your insurer to find equivalents.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is yellow fever vaccination required?</h3>
        <p class="text-neutral-700">
          Some countries and regions require yellow fever vaccination for entry. The vaccine itself may be covered under preventive care (varies by plan). Yellow fever treatment is covered as a medical condition. Check CDC recommendations for your specific destinations.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about Argentina's economic situation?</h3>
        <p class="text-neutral-700">
          Argentina's currency fluctuations don't affect your international insurance—premiums are in stable currencies (USD, EUR). Local healthcare costs in Argentina are very affordable in dollar terms during peso weakness. Medical care quality remains excellent.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I use public healthcare and keep insurance?</h3>
        <p class="text-neutral-700">
          Several South American countries offer public healthcare to residents (Brazil's SUS, Argentina's public hospitals). You can use public options and maintain private insurance for faster service, better facilities, or specific doctors. Many expats use this hybrid approach.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by specific plan, policy year, and individual circumstances. Healthcare quality and availability varies by country and city. Some countries may have coverage restrictions. This comparison reflects general plan features—always verify specific benefits and geographic coverage with insurers before purchasing.
    </p>
  </aside>
</PageShell>
