---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Indonesia Second Home Visa (2025)";
const description = "Compare top health insurance options for Indonesia's Second Home Visa for digital nomads and remote workers. Expert analysis of Cigna Global, SafetyWing, and local Indonesian options.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "local-indonesian", title: "Local Indonesian" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Indonesian" },
];

const comparisonRows = [
  { feature: "Second Home Visa Acceptance", cigna: "✓ Accepted", safetywing: "✓ Accepted", local: "✓ Accepted" },
  { feature: "Indonesia Network", cigna: "Good (international hospitals)", safetywing: "Reimbursement", local: "Extensive" },
  { feature: "Singapore Evacuation", cigna: "✓ Included", safetywing: "✓ Included", local: "Varies" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Not covered", local: "Case-by-case" },
  { feature: "International Coverage", cigna: "Worldwide", safetywing: "Outside home country", local: "Indonesia only" },
  { feature: "Monthly Cost (35yo)", cigna: "$400-600", safetywing: "$69-99", local: "$100-300" },
  { feature: "Annual Maximum", cigna: "Unlimited", safetywing: "$250,000", local: "$100K-500K" },
  { feature: "Best For", cigna: "Comprehensive coverage", safetywing: "Budget nomads", local: "Long-term residents" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Indonesian" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "$250K limit", local: "Per-incident limits" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited", local: "Often included" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100K limit", local: "Varies by plan" },
  { coverage: "Singapore Medevac", cigna: "✓ Full coverage", safetywing: "✓ Covered", local: "May not cover" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", local: "Some plans" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", local: "Rarely" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", local: "Limited" },
  { coverage: "Pregnancy", cigna: "Optional add-on", safetywing: "Limited maternity", local: "Some plans" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Indonesian" },
];

const pricingRows = [
  { age: "25-30", cigna: "$280-450/month", safetywing: "$69/month", local: "$80-180/month" },
  { age: "30-35", cigna: "$350-550/month", safetywing: "$69/month", local: "$100-220/month" },
  { age: "40-45", cigna: "$500-780/month", safetywing: "$99/month", local: "$150-350/month" },
  { age: "50-55", cigna: "$720-1,100/month", safetywing: "$148/month", local: "$250-500/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Indonesian" },
];

const networkRows = [
  { region: "Bali (Denpasar)", cigna: "BIMC, Siloam", safetywing: "Reimbursement", local: "All major hospitals" },
  { region: "Jakarta", cigna: "Pondok Indah, Siloam", safetywing: "Reimbursement", local: "Extensive network" },
  { region: "Yogyakarta", cigna: "Limited direct billing", safetywing: "Reimbursement", local: "Good coverage" },
  { region: "Other Islands", cigna: "Reimbursement", safetywing: "Reimbursement", local: "Variable" },
  { region: "Singapore (Evacuation)", cigna: "Mount Elizabeth, Raffles", safetywing: "Covered", local: "May not cover" },
  { region: "International", cigna: "Worldwide", safetywing: "Outside home country", local: "Not covered" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Indonesia's Second Home Visa for digital nomads and investors"
    heroImage="/images/countries/indonesia-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Indonesia Second Home Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Indonesia's Second Home Visa allows stays of 5-10 years for remote workers, retirees, and investors. Launched in 2022, this visa targets affluent foreigners who want to live in Indonesia long-term, with Bali being the most popular destination.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for visa application</li>
          <li>• Must cover medical treatment in Indonesia</li>
          <li>• Minimum coverage: typically $25,000-50,000 recommended</li>
          <li>• Financial requirement: $130,000 in Indonesian bank OR property ownership</li>
          <li>• Evacuation coverage to Singapore strongly recommended</li>
          <li>• Policy must be valid for duration of stay</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Indonesia has good private hospitals in Jakarta and Bali but limited options elsewhere. For serious conditions, medical evacuation to Singapore (90-minute flight from Bali) is common. Any insurance for Indonesia should include robust evacuation coverage.
      </p>

      <p class="text-neutral-700">
        The Second Home Visa targets higher-income individuals ($130K+ in assets), so comprehensive international insurance is often the appropriate choice. Budget options work for younger, healthier nomads who accept more risk.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Second Home Visa</h2>

      <p class="text-neutral-700 mb-6">
        Second Home Visa holders typically choose between comprehensive international coverage, nomad-focused plans, or local Indonesian insurance:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive coverage ideal for the affluent demographic the Second Home Visa targets. With direct billing at major Indonesian hospitals and full Singapore evacuation coverage, it's the premium choice.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Direct billing at BIMC Bali, Siloam, Pondok Indah</li>
            <li>• Unlimited medical evacuation to Singapore</li>
            <li>• Worldwide coverage for travel</li>
            <li>• Comprehensive outpatient and specialist care</li>
            <li>• Pre-existing condition options available</li>
            <li>• 24/7 support with Indonesian coordinators</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Expensive compared to local or nomad options</li>
            <li>• May be overkill for young, healthy individuals</li>
            <li>• Direct billing network limited outside major cities</li>
            <li>• Deductibles can be high to lower premiums</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive coverage with Singapore evacuation for Indonesia."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing Nomad Insurance</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing offers affordable coverage designed for digital nomads. At $69/month regardless of age (up to 39), it's the budget choice for younger Second Home Visa holders willing to accept coverage limits.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Extremely affordable ($69/month under 40)</li>
            <li>• Accepted for Second Home Visa</li>
            <li>• Medical evacuation included</li>
            <li>• Month-to-month flexibility</li>
            <li>• Good for nomads who travel frequently</li>
            <li>• Simple sign-up process</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• $250K coverage limit (low for serious illness)</li>
            <li>• $250 deductible per incident</li>
            <li>• No direct billing—must pay and claim</li>
            <li>• Pre-existing conditions not covered</li>
            <li>• Limited outpatient coverage</li>
            <li>• Not suitable for those with health conditions</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget-friendly nomad insurance starting at $69/month."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="local-indonesian" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Local Indonesian Insurance</h2>

      <p class="text-neutral-700 mb-4">
        Indonesian insurers like Allianz Indonesia, AXA Mandiri, and Prudential Indonesia offer plans for residents. These provide broad local networks but may lack international coverage and Singapore evacuation.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Extensive Indonesian hospital network</li>
            <li>• Direct billing widely available</li>
            <li>• Affordable premiums</li>
            <li>• Indonesian-language support</li>
            <li>• Can include dental and maternity</li>
            <li>• Local claims processing</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• May not cover Singapore evacuation</li>
            <li>• No international coverage</li>
            <li>• Per-incident and annual limits</li>
            <li>• Claims process can be bureaucratic</li>
            <li>• Pre-existing condition exclusions</li>
            <li>• Quality varies significantly by insurer</li>
          </ul>
        </div>
      </div>

      <div class="bg-neutral-50 p-4 rounded-lg">
        <p class="text-neutral-700 text-sm">
          <strong>Popular local options:</strong> Allianz Indonesia (SmartHealth), AXA Mandiri, Prudential Indonesia, BNI Life. Compare at the insurer websites directly or through local brokers. Ensure any plan includes emergency evacuation coverage.
        </p>
      </div>
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares. Singapore evacuation capability is critical for Indonesia:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        For Indonesia, medical evacuation coverage is essential. Jakarta and Bali have good private hospitals, but complex surgeries, cancer treatment, and cardiac care are often better handled in Singapore.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically cheaper but with coverage limits. Local Indonesian insurance offers middle-ground pricing:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        SafetyWing's flat-rate pricing is attractive for younger nomads. However, the $250K limit means a serious illness could exceed coverage. Consider your risk tolerance and financial situation.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Indonesia</h2>

      <p class="text-neutral-700 mb-6">
        Healthcare quality varies significantly across Indonesia. Here's network access by region:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        In Bali, BIMC is the go-to international hospital for expats. In Jakarta, Pondok Indah and Siloam are top choices. Outside major cities, healthcare can be limited—evacuation coverage becomes more important.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Digital Nomad in Bali</h3>
          <p class="text-neutral-600 mb-3">28-year-old remote worker, healthy, surfing lifestyle, plans to stay 2-3 years.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">At $69/month, SafetyWing covers the basics and includes evacuation. Young, healthy people rarely need the comprehensive coverage of Cigna. Accept the $250K limit as reasonable risk.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Affluent Retiree in Bali</h3>
          <p class="text-neutral-600 mb-3">58-year-old retiree with $500K+ assets, some health conditions, plans long-term stay.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">At this age and asset level, comprehensive coverage with unlimited evacuation is essential. Cigna's moratorium option can cover pre-existing conditions after waiting period. Don't risk your retirement savings on inadequate insurance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Family with Children in Jakarta</h3>
          <p class="text-neutral-600 mb-3">40-year-old couple with two young children, working remotely, need pediatric access.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global or Allianz Indonesia</p>
          <p class="text-neutral-600 text-sm">Children need reliable pediatric care. Cigna provides comprehensive family coverage. Allianz Indonesia is more affordable with good Jakarta networks. Either ensures access to quality pediatric specialists.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Frequent Traveler Using Bali as Base</h3>
          <p class="text-neutral-600 mb-3">35-year-old entrepreneur, travels to Singapore and Bangkok monthly, Bali home base.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global or SafetyWing</p>
          <p class="text-neutral-600 text-sm">International coverage is essential for your travel. Cigna provides premium coverage everywhere. SafetyWing also covers outside your home country at budget rates. Choose based on budget and risk tolerance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Remote Worker in Yogyakarta</h3>
          <p class="text-neutral-600 mb-3">32-year-old content creator living in Yogyakarta, limited local healthcare options.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global with evacuation focus</p>
          <p class="text-neutral-600 text-sm">Yogyakarta has limited international-standard healthcare. Evacuation coverage to Jakarta or Singapore is critical. Cigna's evacuation benefit covers transport to appropriate facilities—essential outside major cities.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For Second Home Visa holders, insurance choice depends on age, health, and risk tolerance. <strong>Young, healthy nomads</strong> can use SafetyWing as budget coverage. <strong>Older individuals or those with assets to protect</strong> should invest in Cigna Global's comprehensive coverage. <strong>Local Indonesian insurance</strong> works for long-term residents comfortable with the local healthcare system.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Over 45 or have health conditions</li>
            <li>• Significant assets to protect</li>
            <li>• Want Singapore evacuation certainty</li>
            <li>• Prefer direct billing</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Under 40 and healthy</li>
            <li>• Budget-conscious</li>
            <li>• Accept coverage limits</li>
            <li>• Flexible nomad lifestyle</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Local Insurance If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Long-term Indonesia resident</li>
            <li>• Comfortable with local system</li>
            <li>• Want extensive local network</li>
            <li>• Don't need international coverage</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What insurance is required for the Second Home Visa?</h3>
          <p class="text-neutral-600">Health insurance is mandatory, but Indonesia doesn't specify a minimum coverage amount. Most applicants use international insurance with at least $50,000 coverage. The visa also requires $130,000 in an Indonesian bank account OR property ownership.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Why is Singapore evacuation coverage important?</h3>
          <p class="text-neutral-600">Indonesia has good hospitals in Jakarta and Bali, but for complex surgeries, cancer treatment, cardiac care, and neurological conditions, Singapore offers world-class facilities. Singapore is a 90-minute flight from Bali. Medical evacuation there can cost $20,000+ without insurance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Which hospitals accept international insurance in Bali?</h3>
          <p class="text-neutral-600">BIMC Hospital (Kuta and Nusa Dua locations) is the main international hospital accepting most global insurers. Siloam Hospitals also work with international insurers. Always confirm direct billing with your specific insurer before treatment.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use Indonesian public healthcare?</h3>
          <p class="text-neutral-600">Indonesia has a public system (BPJS Kesehatan), but foreigners on Second Home Visas typically cannot enroll. Even if you could, public hospitals have long waits and language barriers. Private insurance is the practical choice for foreigners.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing's $250K limit enough?</h3>
          <p class="text-neutral-600">For most routine care and even many serious conditions, yes. However, extended ICU stays, cancer treatment, or complex surgeries can exceed $250K. If you have significant assets or pre-existing conditions, consider higher coverage. Young, healthy individuals with limited assets often accept this limit as reasonable.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about dengue fever coverage?</h3>
          <p class="text-neutral-600">All insurance options cover dengue fever treatment—it's not considered pre-existing. Dengue is common in Indonesia, especially during rainy season. Treatment is straightforward (hospitalization for monitoring), and insurance covers it without issues.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Indonesia visa requirements and healthcare options can change. Verify current Second Home Visa requirements with Indonesian immigration. Confirm policy details and coverage limits directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
