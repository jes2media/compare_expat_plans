---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "cigna", title: "Cigna Global" },
  { id: "bupa", title: "Bupa Global" },
  { id: "allianz", title: "Allianz Partners" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "maternity-details", title: "Maternity Coverage Details" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/providers/bupa-global", title: "Bupa Global Review" },
  { href: "/providers/allianz-partners", title: "Allianz Partners Review" },
  { href: "/guides/pregnancy-abroad", title: "Pregnancy Abroad Guide" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "allianz", header: "Allianz Partners" },
];

const mainComparisonRows = [
  { feature: "Waiting Period", cigna: "10-12 months", bupa: "12 months", allianz: "10-12 months" },
  { feature: "Prenatal Care", cigna: "Full coverage", bupa: "Full coverage", allianz: "Standard coverage" },
  { feature: "Delivery (Normal)", cigna: "Full coverage", bupa: "Full coverage", allianz: "Full coverage" },
  { feature: "C-Section", cigna: "Full coverage", bupa: "Full coverage", allianz: "Full coverage" },
  { feature: "Complications", cigna: "Full coverage", bupa: "Full coverage", allianz: "Full coverage" },
  { feature: "Newborn Coverage", cigna: "30 days auto", bupa: "30 days auto", allianz: "14 days auto" },
  { feature: "Fertility Treatment", cigna: "Some plans", bupa: "Some plans", allianz: "Limited" },
  { feature: "Midwife/Home Birth", cigna: "Covered", bupa: "Covered", allianz: "Limited" },
  { feature: "NICU if needed", cigna: "Full coverage", bupa: "Full coverage", allianz: "Full coverage" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "allianz", header: "Allianz Partners" },
];

const pricingRows = [
  { profile: "Woman, 30yo, with maternity", cigna: "$5,800–7,400/yr", bupa: "$5,200–6,800/yr", allianz: "$4,200–5,600/yr" },
  { profile: "Woman, 35yo, with maternity", cigna: "$6,400–8,200/yr", bupa: "$5,800–7,600/yr", allianz: "$4,800–6,400/yr" },
  { profile: "Couple, both 32, with maternity", cigna: "$11,200–14,400/yr", bupa: "$10,200–13,200/yr", allianz: "$8,400–11,200/yr" },
  { profile: "Maternity add-on only", cigna: "$1,200–2,400/yr", bupa: "$1,000–2,000/yr", allianz: "$800–1,600/yr" },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz: Maternity Coverage for Expats (2025)"
  description="Compare maternity and pregnancy coverage from Cigna Global, Bupa Global, and Allianz Partners. Analysis of prenatal care, delivery, and newborn coverage for expat families."
  headline="Cigna vs Bupa vs Allianz: Maternity Coverage Compared"
  intro="Having a baby abroad requires planning—especially when it comes to insurance. Maternity coverage has waiting periods, specific benefits, and important fine print about newborns. Here's how Cigna Global, Bupa Global, and Allianz Partners compare for expats planning or expecting a pregnancy."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 font-semibold mb-2">Best Overall Maternity Coverage</p>
        <p class="text-neutral-700 text-sm">Most comprehensive prenatal care, flexible birthing options, and 30-day automatic newborn coverage. Premium pricing but fewest restrictions.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Strong Coverage, Good Value</p>
        <p class="text-neutral-700 text-sm">Comprehensive maternity benefits at slightly lower cost than Cigna. Good balance of coverage and price. 12-month waiting period standard.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Partners</h3>
        <p class="text-green-700 font-semibold mb-2">Budget Maternity Option</p>
        <p class="text-neutral-700 text-sm">Lower premiums but more limited options. 14-day newborn coverage is shorter. Works for straightforward pregnancies.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Maternity Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Comprehensive prenatal:</strong> All appointments, tests, ultrasounds fully covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Flexible delivery:</strong> Hospital, birthing center, or midwife-assisted home birth</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>30-day newborn coverage:</strong> Baby automatically covered from birth</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Complication coverage:</strong> High-risk pregnancies, emergency C-sections, NICU</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Fertility options:</strong> Some plans include fertility treatment coverage</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global offers the most comprehensive maternity coverage among major international insurers. The 10-12 month waiting period is competitive, and the benefits are generous—no caps on prenatal visits, full coverage for any delivery method, and complications handled without question.
    </p>
    <p class="text-neutral-700">
      The 30-day automatic newborn coverage matters. Your baby is covered from the moment of birth, giving you time to formally add them to the policy without worrying about gaps. If the baby needs NICU care, it's covered immediately.
    </p>
  </section>

  <!-- Bupa Global Section -->
  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Maternity Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Full prenatal care:</strong> Appointments, tests, and monitoring covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Delivery coverage:</strong> Natural birth, C-section, birthing center options</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>30-day newborn:</strong> Automatic coverage from birth</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Competitive pricing:</strong> Slightly lower premiums than Cigna</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Global network:</strong> Access to quality maternity hospitals worldwide</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Bupa Global's maternity coverage closely matches Cigna's benefits at a slightly lower price point. The 12-month waiting period is standard for the industry. Full prenatal care, flexible delivery options, and 30-day automatic newborn coverage are all included.
    </p>
    <p class="text-neutral-700">
      Bupa's global maternity network includes excellent hospitals in popular expat destinations. From private hospitals in Bangkok to maternity centers in London, you'll find quality options. Pre-registration with your chosen hospital is recommended for direct billing.
    </p>
  </section>

  <!-- Allianz Partners Section -->
  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Partners</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Maternity Highlights</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Lower premiums:</strong> Most affordable maternity option</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Standard prenatal:</strong> Core prenatal care covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Delivery coverage:</strong> Hospital birth fully covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Complications:</strong> Emergency care and C-sections covered</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-600 mt-1">△</span>
          <span><strong>14-day newborn:</strong> Shorter automatic coverage window</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Allianz Partners offers the budget-friendly maternity option. Core benefits are covered—prenatal appointments, hospital delivery, complications. But the coverage is more limited than Cigna or Bupa: shorter newborn coverage, fewer birthing options, less comprehensive prenatal testing.
    </p>
    <p class="text-neutral-700">
      The 14-day newborn coverage is the key limitation. You need to add your baby to the policy within two weeks—which can be challenging while recovering and adjusting to parenthood. If complications require NICU beyond 14 days without formal enrollment, there could be coverage issues.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Maternity Coverage Quotes"
    description="Compare maternity coverage from Cigna, Bupa, and Allianz for your growing family."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Maternity coverage significantly increases premium costs. These prices reflect comprehensive health plans including maternity benefits. The maternity add-on cost shows the incremental cost for maternity-specific coverage.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for worldwide coverage excluding US. Maternity add-on assumes base health plan is already in place.
    </p>
  </section>

  <!-- Maternity Details Section -->
  <section id="maternity-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Understanding Maternity Coverage</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Waiting Periods</h3>
        <p class="text-neutral-700 mb-3">
          All three insurers impose 10-12 month waiting periods for maternity benefits. This means you need to have coverage in place before becoming pregnant—ideally a year before your planned conception. Getting pregnant before the waiting period ends means the pregnancy isn't covered.
        </p>
        <p class="text-neutral-700">
          Planning ahead is essential. If you're considering having a baby abroad within the next two years, get maternity coverage now. The waiting period starts from your policy effective date, not from when you add maternity benefits.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Prenatal Care</h3>
        <p class="text-neutral-700 mb-3">
          Prenatal care includes doctor visits, ultrasounds, blood tests, genetic screening, and monitoring throughout pregnancy. Cigna and Bupa cover comprehensive prenatal care without limits. Allianz covers standard care but may have limits on certain tests or extra monitoring.
        </p>
        <p class="text-neutral-700">
          High-risk pregnancies may require more frequent monitoring, additional specialists, or advanced testing. Verify your plan covers high-risk pregnancy care if you have risk factors (age, multiple pregnancy, health conditions).
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Delivery Options</h3>
        <p class="text-neutral-700 mb-3">
          All three cover hospital delivery—natural birth or C-section. Cigna and Bupa also cover birthing centers and midwife-assisted home births. Allianz focuses primarily on hospital birth, with limited coverage for alternative settings.
        </p>
        <p class="text-neutral-700">
          If you prefer a birthing center or home birth, confirm coverage explicitly. Some policies cover the midwife but not the home birth setting. Others cover everything. The hospital is always the safest bet for insurance purposes.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Newborn Coverage</h3>
        <p class="text-neutral-700 mb-3">
          Automatic newborn coverage gives you time to formally add your baby to the policy. Cigna and Bupa provide 30 days; Allianz provides 14 days. During this window, the baby is covered for any medical needs, including NICU if required.
        </p>
        <p class="text-neutral-700">
          Don't wait until the last day. Submit enrollment paperwork as soon as possible after birth. If complications arise and you miss the deadline without formal enrollment, coverage disputes can occur. Most insurers are reasonable, but don't test it.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want most comprehensive coverage</li>
          <li>• Flexible birthing options matter</li>
          <li>• 30-day newborn coverage is valuable</li>
          <li>• You have high-risk pregnancy factors</li>
          <li>• Fertility coverage is needed</li>
          <li>• Premium coverage justifies cost</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose Bupa If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want good coverage at better value</li>
          <li>• 30-day newborn coverage matters</li>
          <li>• Hospital birth is your plan</li>
          <li>• Balance of cost and coverage matters</li>
          <li>• Strong global network is important</li>
          <li>• You have straightforward pregnancy</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Allianz If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• Budget is the primary concern</li>
          <li>• You expect uncomplicated pregnancy</li>
          <li>• Hospital birth is planned</li>
          <li>• You can handle 14-day enrollment window</li>
          <li>• Basic maternity coverage is sufficient</li>
          <li>• Lower premiums outweigh extras</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I'm already pregnant when I apply?</h3>
        <p class="text-neutral-700">
          Existing pregnancy is a pre-existing condition—it won't be covered. You can still get insurance for other health needs, but that specific pregnancy is excluded. This is why planning ahead is essential for maternity coverage.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Does maternity coverage include fertility treatments?</h3>
        <p class="text-neutral-700">
          Some Cigna and Bupa plans include fertility coverage as an add-on or within premium tiers. Allianz generally doesn't cover fertility treatments. If IVF or other fertility assistance is anticipated, check specific plan details before enrolling.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What happens if my baby needs NICU?</h3>
        <p class="text-neutral-700">
          NICU care is covered during the automatic newborn coverage period (14-30 days depending on insurer). Extended NICU stays require formal enrollment. All three insurers cover NICU fully once the baby is formally on the policy.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I give birth in my home country?</h3>
        <p class="text-neutral-700">
          Coverage for home country delivery depends on your plan. Some include full home country coverage; others limit it. Many expats plan to deliver in their home country for family support—verify your plan covers this before making plans.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is postpartum care covered?</h3>
        <p class="text-neutral-700">
          Yes—postpartum checkups, recovery care, and treatment for postpartum complications are covered. This includes both physical recovery and mental health (postpartum depression). The mother remains covered under her existing policy; the baby needs enrollment.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I add my baby to the policy?</h3>
        <p class="text-neutral-700">
          Contact your insurer within the automatic coverage period (14-30 days). You'll need birth certificate or hospital documentation. Most insurers make this straightforward—it's a common process. The baby's coverage continues seamlessly once enrolled.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by specific plan, policy tier, and individual circumstances. Waiting periods apply to maternity benefits. Existing pregnancy is not covered when applying for new coverage. Automatic newborn coverage periods vary—enroll babies promptly. This comparison reflects general plan features—always verify specific maternity benefits with insurers before purchasing.
    </p>
  </aside>
</PageShell>
