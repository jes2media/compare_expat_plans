---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'aetna-international', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Family Pricing', level: 2 },
  { id: 'maternity', text: 'Maternity Coverage', level: 2 },
  { id: 'best-for', text: 'Which Is Best For Your Family?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'Aetna International Review', href: '/providers/aetna-international' },
  { title: 'Family Insurance', href: '/best/family-health-insurance' },
  { title: 'Maternity Insurance', href: '/best/maternity-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'Family Plan Options', cigna: 'Excellent', bupa: 'Excellent', aetna: 'Good' },
  { feature: 'Maternity Coverage', cigna: 'Comprehensive', bupa: 'Comprehensive', aetna: 'Good' },
  { feature: 'Pediatric Network', cigna: 'Excellent', bupa: 'Very Good', aetna: 'Good' },
  { feature: 'Vaccination Coverage', cigna: 'Included', bupa: 'Included', aetna: 'Included' },
  { feature: 'Direct Billing', cigna: 'Excellent', bupa: 'Excellent', aetna: 'Good' },
  { feature: 'Mobile App', cigna: 'Best in class', bupa: 'Good', aetna: 'Good' },
  { feature: 'Newborn Coverage', cigna: '30 days auto', bupa: '30 days auto', aetna: '14 days auto' },
  { feature: 'Family Discount', cigna: 'Limited', bupa: 'Limited', aetna: 'Available' },
];

const pricingColumns = [
  { key: 'profile', header: 'Family Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Couple, Age 35', cigna: '$350-450/mo', bupa: '$380-500/mo', aetna: '$320-420/mo' },
  { profile: 'Family (2 adults, 1 child)', cigna: '$450-580/mo', bupa: '$480-620/mo', aetna: '$400-520/mo' },
  { profile: 'Family (2 adults, 2 children)', cigna: '$500-650/mo', bupa: '$540-700/mo', aetna: '$460-600/mo' },
  { profile: 'Family (2 adults, 3 children)', cigna: '$550-720/mo', bupa: '$600-780/mo', aetna: '$520-680/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna: Best Family Expat Insurance 2026"
  description="Compare the top family health insurance options for expats: Cigna Global, Bupa Global, and Aetna International. Maternity, pediatric care, and family plan pricing compared."
  headline="Cigna vs Bupa vs Aetna: Best for Expat Families"
  subheadline="Three top insurers compared for families. Maternity coverage, pediatric care, and family-friendly features analyzed."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best for Families</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Cigna Global</p>
      <p class="text-sm text-neutral-600 mb-3">Largest pediatric network. Best app for managing family coverage. Seamless direct billing.</p>
      <a href="/go/cigna-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Cigna Quote</a>
    </div>
    <div class="bg-purple-50 border border-purple-200 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best Service</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Bupa Global</p>
      <p class="text-sm text-neutral-600 mb-3">Premium family service. Fast claims when kids get sick. No-claims discount for healthy families.</p>
      <a href="/go/bupa-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Bupa Quote</a>
    </div>
    <div class="bg-green-50 border border-green-200 rounded-lg p-5">
      <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Aetna International</p>
      <p class="text-sm text-neutral-600 mb-3">Lower family premiums. CVS integration for prescriptions. Good for US-based families.</p>
      <a href="/go/aetna-international" class="inline-block w-full text-center bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Get Aetna Quote</a>
    </div>
  </div>

  <p>
    All three insurers offer solid family coverage. Cigna leads for convenience and network size, Bupa delivers premium service, and Aetna provides the best value for families watching their budget.
  </p>

  <h2 id="comparison-table">Side-by-Side Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="cigna-global">Cigna Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Best for Families</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Largest Network</span>
    <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded">Best App</span>
  </div>

  <p>
    Cigna Global is our top pick for expat families. Their massive network means you'll find pediatricians and family doctors almost anywhere. The mobile app makes managing family coverage easy—add dependents, find doctors, and submit claims without paperwork hassles.
  </p>

  <p><strong>Family Strengths:</strong></p>
  <ul>
    <li>1.5M+ providers including excellent pediatric network</li>
    <li>Industry-leading app for family management</li>
    <li>30 days automatic newborn coverage</li>
    <li>Comprehensive maternity add-on</li>
    <li>Direct billing at children's hospitals worldwide</li>
    <li>24/7 support for middle-of-the-night emergencies</li>
  </ul>

  <p><strong>Considerations:</strong></p>
  <ul>
    <li>Higher premiums than Aetna</li>
    <li>Maternity has 10-12 month waiting period</li>
    <li>No significant family discount</li>
  </ul>

  <p><strong>Best for:</strong> Families who want the smoothest experience. Parents who value convenience and network access. Families who travel frequently.</p>

  <div class="my-6">
    <a href="/go/cigna-global" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Cigna Quote</a>
    <a href="/providers/cigna-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="bupa-global">Bupa Global</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Premium Service</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">Fast Claims</span>
    <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">No-Claims Discount</span>
  </div>

  <p>
    Bupa Global offers premium family coverage with the fastest claims processing in the industry. When your child gets sick abroad, you don't want to wait—Bupa typically processes claims in 5-7 days. Their no-claims discount can significantly reduce premiums for healthy families over time.
  </p>

  <p><strong>Family Strengths:</strong></p>
  <ul>
    <li>Fastest claims processing (5-7 days)</li>
    <li>No-claims discount up to 50%</li>
    <li>Premium family service experience</li>
    <li>30 days automatic newborn coverage</li>
    <li>Comprehensive maternity options</li>
    <li>Lifetime renewal guarantee</li>
  </ul>

  <p><strong>Considerations:</strong></p>
  <ul>
    <li>Highest starting premiums</li>
    <li>No-claims discount lost if you claim</li>
    <li>Network slightly smaller than Cigna</li>
  </ul>

  <p><strong>Best for:</strong> Healthy families who rarely claim (maximize no-claims discount). Parents who value premium service. Long-term planning families.</p>

  <div class="my-6">
    <a href="/go/bupa-global" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Bupa Quote</a>
    <a href="/providers/bupa-global" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <h2 id="aetna-international">Aetna International</h2>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Best Value</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">CVS Integration</span>
    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">Family Discount</span>
  </div>

  <p>
    Aetna International offers the most affordable family coverage of the three. Part of CVS Health, they provide unique benefits like MinuteClinic access and integrated pharmacy services—particularly valuable for families managing kids' prescriptions.
  </p>

  <p><strong>Family Strengths:</strong></p>
  <ul>
    <li>Lowest family premiums of the three</li>
    <li>CVS pharmacy integration</li>
    <li>MinuteClinic access for minor issues</li>
    <li>Family discount available</li>
    <li>Good telemedicine for quick consults</li>
    <li>Strong Americas coverage</li>
  </ul>

  <p><strong>Considerations:</strong></p>
  <ul>
    <li>Shorter automatic newborn coverage (14 days)</li>
    <li>Global network smaller than Cigna</li>
    <li>Maternity coverage less comprehensive</li>
    <li>Stronger in Americas than globally</li>
  </ul>

  <p><strong>Best for:</strong> Budget-conscious families. American expat families. Families in the Americas. Those who value pharmacy integration.</p>

  <div class="my-6">
    <a href="/go/aetna-international" class="inline-block bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline mr-3" style="color: white !important;">Get Aetna Quote</a>
    <a href="/providers/aetna-international" class="text-primary-600 hover:text-primary-700 font-medium">Read Full Review →</a>
  </div>

  <CTABox
    title="Compare Family Plans"
    description="Get personalized family quotes from Cigna, Bupa, and Aetna based on your specific needs."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
    variant="highlight"
  />

  <h2 id="pricing">Family Pricing Comparison</h2>

  <p>
    Family premiums vary significantly based on ages and number of children. Here's what to expect for comprehensive plans excluding US coverage:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">
    *Estimated ranges for comprehensive family plans excluding US coverage. Children pricing assumes ages 0-18.
  </p>

  <h2 id="maternity">Maternity Coverage Comparison</h2>

  <p>
    Planning to expand your family abroad? All three offer maternity coverage, but with important differences:
  </p>

  <h3>Cigna Global Maternity</h3>
  <ul>
    <li>10-12 month waiting period</li>
    <li>Comprehensive prenatal, delivery, postnatal</li>
    <li>Newborn covered automatically for 30 days</li>
    <li>Good network of maternity hospitals</li>
    <li>Add-on cost: $100-200/month</li>
  </ul>

  <h3>Bupa Global Maternity</h3>
  <ul>
    <li>10-12 month waiting period</li>
    <li>Comprehensive coverage similar to Cigna</li>
    <li>Newborn covered automatically for 30 days</li>
    <li>Premium maternity hospital access</li>
    <li>Add-on cost: $120-220/month</li>
  </ul>

  <h3>Aetna International Maternity</h3>
  <ul>
    <li>12 month waiting period</li>
    <li>Good basic coverage</li>
    <li>Newborn covered automatically for 14 days only</li>
    <li>Lower limits than Cigna/Bupa</li>
    <li>Add-on cost: $80-150/month</li>
  </ul>

  <p>
    <strong>Key takeaway:</strong> If maternity is important, Cigna and Bupa offer more comprehensive coverage. Aetna is more affordable but has shorter newborn coverage and lower limits.
  </p>

  <h2 id="best-for">Which Is Best For Your Family?</h2>

  <div class="space-y-4 my-8">
    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Cigna Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Want the largest network and easiest access to care</li>
        <li>Value a great mobile app for managing family coverage</li>
        <li>Travel frequently with kids</li>
        <li>Plan to have a baby abroad (strong maternity)</li>
        <li>Hate paperwork and want direct billing everywhere</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Bupa Global if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Have a generally healthy family (maximize no-claims discount)</li>
        <li>Want premium service when issues arise</li>
        <li>Value fast claims processing</li>
        <li>Plan to keep coverage for many years</li>
        <li>Can afford higher starting premiums</li>
      </ul>
    </div>

    <div class="border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Choose Aetna International if you...</h3>
      <ul class="text-neutral-600 space-y-1">
        <li>Need to keep family insurance costs down</li>
        <li>Value CVS integration for prescriptions</li>
        <li>Live in the Americas (US, Canada, Latin America)</li>
        <li>Are an American family abroad</li>
        <li>Don't need premium maternity coverage</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Which is best for families with young children?</h3>
  <p>
    Cigna Global is our top pick for families with young kids. Their massive pediatric network means you'll find children's doctors almost anywhere, and the app makes managing appointments and claims easy during the chaos of parenting abroad.
  </p>

  <h3>Is maternity covered automatically?</h3>
  <p>
    No. All three insurers require you to add maternity coverage as an optional benefit, and all have 10-12 month waiting periods before benefits activate. Plan ahead if you're thinking about having a baby abroad.
  </p>

  <h3>What about newborn coverage?</h3>
  <p>
    Cigna and Bupa automatically cover newborns for 30 days after birth. Aetna only covers newborns for 14 days. After that, you need to formally add the child to your policy.
  </p>

  <h3>Can I add children later?</h3>
  <p>
    Yes, all three allow you to add children to your policy. Newborns can typically be added without underwriting if done within 30-60 days of birth. Older children may require health declarations.
  </p>

  <h3>What's covered for kids that isn't covered for adults?</h3>
  <p>
    Routine vaccinations are typically covered for children on all three plans. Well-child checkups and developmental screenings are also included. These preventive services may have limits for adults.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This comparison is for informational purposes only. Prices and coverage details change. We are not insurance brokers. Verify current information directly with each provider before purchasing.
    </p>
  </div>
</PageShell>
