---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'quick-decision', text: 'Quick Decision Guide', level: 2 },
  { id: 'coverage-comparison', text: 'Coverage Comparison', level: 2 },
  { id: 'mental-health-maternity', text: 'Mental Health and Maternity', level: 2 },
  { id: 'deductible-strategy', text: 'The Deductible Strategy', level: 2 },
  { id: 'pricing', text: 'Pricing Analysis', level: 2 },
  { id: 'network-claims', text: 'Networks and Claims', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-should-choose', text: 'Who Should Choose Which', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'Best Budget Insurance', href: '/best/budget-expat-insurance' },
  { title: 'Spain Insurance Guide', href: '/countries/spain/insurance' },
  { title: 'Italy Insurance Guide', href: '/countries/italy/insurance' },
];

const coverageColumns = [
  { key: 'feature', header: 'Coverage Area' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const coverageRows = [
  { feature: 'Annual Maximum', allianz: '€1.35M–€3M', img: '$1M–$8M' },
  { feature: 'Inpatient Hospital', allianz: 'Full coverage', img: 'Full coverage' },
  { feature: 'Outpatient Care', allianz: 'Full coverage', img: 'Full coverage' },
  { feature: 'Mental Health', allianz: 'Comprehensive', img: 'Limited coverage' },
  { feature: 'Maternity', allianz: 'Up to €30,000', img: '$5,000–$10,000' },
  { feature: 'Pre-Existing Conditions', allianz: 'Moratorium underwriting', img: 'Usually excluded' },
  { feature: 'Routine Checkups', allianz: 'Included', img: 'Varies by plan' },
  { feature: 'Wellness Programs', allianz: 'Included', img: 'Limited' },
  { feature: 'Dental', allianz: 'Optional add-on', img: 'Optional add-on' },
  { feature: 'Vision', allianz: 'Optional add-on', img: 'Optional add-on' },
  { feature: 'Medical Evacuation', allianz: 'Included', img: '$500,000' },
  { feature: 'Deductible Range', allianz: '€0–€5,000', img: '$0–$25,000' },
];

const mentalMaternityColumns = [
  { key: 'aspect', header: 'Coverage Aspect' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const mentalMaternityRows = [
  { aspect: 'Outpatient Mental Health', allianz: 'Covered (limits vary by plan)', img: 'Limited or excluded' },
  { aspect: 'Inpatient Psychiatric', allianz: 'Covered', img: 'Limited' },
  { aspect: 'Therapy Sessions', allianz: 'Covered', img: 'Often excluded' },
  { aspect: 'Psychiatric Medication', allianz: 'Covered', img: 'Limited' },
  { aspect: 'Maternity Maximum', allianz: 'Up to €30,000', img: '$5,000–$10,000' },
  { aspect: 'Maternity Waiting Period', allianz: '10–12 months', img: '12 months' },
  { aspect: 'Complications of Pregnancy', allianz: 'Covered separately', img: 'Covered' },
  { aspect: 'Newborn Coverage', allianz: '30 days automatic', img: 'Varies' },
];

const deductibleColumns = [
  { key: 'deductible', header: 'Deductible' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
  { key: 'imgOutsideUS', header: 'IMG Outside US*' },
];

const deductibleRows = [
  { deductible: '$0', allianz: 'Available', img: 'Available', imgOutsideUS: '$0' },
  { deductible: '$500', allianz: 'Available', img: 'Available', imgOutsideUS: '$250' },
  { deductible: '$1,000', allianz: 'Available', img: 'Available', imgOutsideUS: '$500' },
  { deductible: '$2,500', allianz: 'Available', img: 'Available', imgOutsideUS: '$1,250' },
  { deductible: '$5,000', allianz: 'Maximum', img: 'Available', imgOutsideUS: '$2,500' },
  { deductible: '$10,000', allianz: 'Not available', img: 'Available', imgOutsideUS: '$5,000' },
  { deductible: '$25,000', allianz: 'Not available', img: 'Available', imgOutsideUS: '$12,500' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
  { key: 'savings', header: 'IMG Savings' },
];

const pricingRows = [
  { profile: 'Single, Age 30 (low deductible)', allianz: '€130–180/mo', img: '$120–160/mo', savings: '~10–20%' },
  { profile: 'Single, Age 30 (high deductible)', allianz: '€80–120/mo', img: '$60–90/mo', savings: '~25–35%' },
  { profile: 'Single, Age 45 (low deductible)', allianz: '€200–280/mo', img: '$160–220/mo', savings: '~15–25%' },
  { profile: 'Single, Age 45 (high deductible)', allianz: '€130–180/mo', img: '$90–140/mo', savings: '~30–40%' },
  { profile: 'Couple, Age 35', allianz: '€260–360/mo', img: '$150–220/mo', savings: '~35–45%' },
  { profile: 'Family of 4', allianz: '€400–600/mo', img: '$280–400/mo', savings: '~30–35%' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Claims Aspect' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'img', header: 'IMG Global' },
];

const claimsRows = [
  { aspect: 'Direct Billing Network', allianz: '2M+ providers globally', img: 'Smaller network' },
  { aspect: 'Reimbursement Time', allianz: '5–7 business days', img: '5–10 business days' },
  { aspect: 'Claims Portal', allianz: 'MyHealth portal/app', img: 'Online portal/app' },
  { aspect: 'Mobile App', allianz: 'Full-featured', img: 'Good functionality' },
  { aspect: '24/7 Support', allianz: 'Multilingual (15+)', img: 'English primary' },
  { aspect: 'Trustpilot Rating', allianz: '~4.0/5', img: '4.6/5' },
];
---

<PageShell
  title="Allianz Care vs IMG Global: Mid-Range vs Budget Comprehensive"
  description="Compare Allianz Care and IMG Global international health insurance. Strong mental health and maternity vs budget-friendly high-deductible options."
  headline="Allianz Care vs IMG Global: Comprehensive vs Budget Coverage"
  subheadline="German insurance giant vs budget-friendly American provider. Both offer real health insurance—but with significant trade-offs."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Compare Your Options"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="overview">Overview</h2>
  <p>
    Allianz Care and IMG Global both offer legitimate international health insurance—not travel medical—but they target different markets. Allianz provides comprehensive coverage with strong mental health and maternity benefits. IMG offers lower premiums with flexible high-deductible options for budget-conscious expats.
  </p>
  <p>
    <strong>Allianz Care</strong> is backed by Allianz SE, the German insurance giant with €1.1+ trillion in assets. They offer comprehensive international health plans with strong mental health coverage, maternity benefits up to €30,000, and a direct billing network of 2 million+ providers. Their plans tend to be mid-range priced with premium features.
  </p>
  <p>
    <strong>IMG Global</strong> is an American insurer known for budget-friendly international health plans. They offer deductibles up to $25,000 (the highest in the industry) and a unique 50% deductible waiver for care received outside the US. Their Trustpilot rating of 4.6/5 demonstrates reliable claims payment despite lower prices.
  </p>
  <p>
    The price difference ranges from 15–40% depending on plan configuration, with IMG consistently cheaper. But that gap comes with trade-offs in mental health coverage, maternity benefits, and network size.
  </p>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="font-semibold text-blue-800 mb-2">IMG's 50% Deductible Waiver</p>
    <p class="text-blue-900 text-sm mb-0">
      IMG Global offers a unique feature: your deductible is reduced by 50% for care received outside the United States. A $10,000 deductible becomes effectively $5,000 for international care. For expats living outside the US, this makes IMG's high-deductible plans particularly attractive.
    </p>
  </div>

  <h2 id="quick-decision">Quick Decision Guide</h2>
  <p>
    Short on time? Here's the essential decision framework.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose Allianz Care If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-0">
        <li>✓ Mental health coverage is important to you</li>
        <li>✓ You need strong maternity benefits (up to €30K)</li>
        <li>✓ You have pre-existing conditions to cover</li>
        <li>✓ You prefer a larger direct billing network</li>
        <li>✓ You want wellness programs included</li>
        <li>✓ You're based in Europe (strong network)</li>
        <li>✓ Multilingual support matters (15+ languages)</li>
      </ul>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Choose IMG Global If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-0">
        <li>✓ Minimizing premium cost is your priority</li>
        <li>✓ You're healthy and rarely use healthcare</li>
        <li>✓ You can manage a high deductible ($5K–$25K)</li>
        <li>✓ You live outside the US (50% deductible waiver)</li>
        <li>✓ You don't need extensive mental health coverage</li>
        <li>✓ Maternity coverage isn't critical</li>
        <li>✓ You're comfortable with smaller direct billing network</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Budget vs Benefits"
    description="The right choice depends on your health needs and how you use healthcare."
    buttonText="Compare Options"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="coverage-comparison">Coverage Comparison</h2>
  <p>
    Both providers offer comprehensive international health insurance. The differences are in the details—particularly mental health, maternity, and deductible flexibility.
  </p>

  <ComparisonTable columns={coverageColumns} rows={coverageRows} />

  <h3>Key Differences Explained</h3>
  <ul>
    <li><strong>Annual maximum:</strong> IMG offers higher limits ($8M vs €3M), though both are adequate for virtually any medical situation</li>
    <li><strong>Mental health:</strong> Allianz provides comprehensive mental health coverage; IMG's is limited—a significant gap if you need therapy or psychiatric care</li>
    <li><strong>Maternity:</strong> Allianz offers up to €30,000 for maternity; IMG caps at $5,000–$10,000—a major difference if you're planning a family</li>
    <li><strong>Pre-existing conditions:</strong> Allianz uses moratorium underwriting (conditions can be covered after 2 years treatment-free); IMG typically excludes them</li>
    <li><strong>Deductible range:</strong> IMG goes up to $25,000 for maximum premium savings; Allianz caps at €5,000</li>
    <li><strong>Network size:</strong> Allianz has 2M+ providers for direct billing; IMG's network is smaller, meaning more reimbursement claims</li>
  </ul>

  <h2 id="mental-health-maternity">Mental Health and Maternity: The Coverage Gap</h2>
  <p>
    The most significant differences between these providers are in mental health and maternity coverage. If either matters to you, this section is critical.
  </p>

  <ComparisonTable columns={mentalMaternityColumns} rows={mentalMaternityRows} />

  <h3>Mental Health Coverage</h3>
  <p>
    <strong>Allianz Care</strong> treats mental health as a core part of healthcare:
  </p>
  <ul>
    <li>Outpatient therapy sessions covered (limits vary by plan tier)</li>
    <li>Inpatient psychiatric hospitalization covered</li>
    <li>Psychiatric medication covered</li>
    <li>Access to mental health providers in their global network</li>
  </ul>
  <p>
    <strong>IMG Global</strong> has limited mental health coverage:
  </p>
  <ul>
    <li>Coverage is often limited or excluded depending on plan</li>
    <li>Outpatient therapy may not be covered</li>
    <li>Inpatient psychiatric care may have lower limits</li>
    <li>Check specific plan documents carefully</li>
  </ul>

  <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 my-6">
    <p class="font-semibold text-amber-800 mb-2">If You Need Mental Health Coverage</p>
    <p class="text-amber-900 text-sm mb-0">
      If you currently see a therapist, take psychiatric medication, or anticipate needing mental health support while abroad, Allianz Care is the safer choice. IMG Global's limited mental health coverage could leave you paying hundreds or thousands out-of-pocket for therapy and medication.
    </p>
  </div>

  <h3>Maternity Coverage</h3>
  <p>
    <strong>Allianz Care</strong> offers strong maternity benefits:
  </p>
  <ul>
    <li>Coverage up to €30,000 for pregnancy and delivery</li>
    <li>10–12 month waiting period</li>
    <li>Complications of pregnancy often covered separately (no waiting period)</li>
    <li>Newborn covered automatically for first 30 days</li>
  </ul>
  <p>
    <strong>IMG Global</strong> has limited maternity:
  </p>
  <ul>
    <li>Coverage capped at $5,000–$10,000</li>
    <li>12 month waiting period</li>
    <li>Complications of pregnancy covered</li>
    <li>Limited for planned pregnancies—the cap may not cover delivery costs</li>
  </ul>
  <p>
    <strong>Reality check:</strong> Hospital delivery costs range from $3,000–$15,000+ depending on country. Allianz's €30,000 covers most scenarios comfortably. IMG's $5,000–$10,000 might not cover a standard delivery, especially with complications.
  </p>

  <h2 id="deductible-strategy">The Deductible Strategy</h2>
  <p>
    IMG Global offers the widest deductible range in international health insurance—up to $25,000. Combined with their 50% international deductible waiver, this creates significant premium savings for healthy expats.
  </p>

  <ComparisonTable columns={deductibleColumns} rows={deductibleRows} />

  <p class="text-sm text-neutral-600 italic">*IMG's 50% deductible waiver applies to medical care received outside the United States</p>

  <h3>How the 50% Waiver Works</h3>
  <p>
    IMG Global reduces your deductible by 50% for care received outside the US:
  </p>
  <ul>
    <li><strong>$5,000 deductible:</strong> You pay $2,500 before coverage kicks in for international care</li>
    <li><strong>$10,000 deductible:</strong> You pay $5,000 for international care</li>
    <li><strong>$25,000 deductible:</strong> You pay $12,500 for international care</li>
  </ul>
  <p>
    For expats living outside the US who rarely need US healthcare, this effectively doubles the value of high-deductible plans. You get catastrophic coverage at very low premiums while the halved deductible makes the plan more usable for significant but non-catastrophic events.
  </p>

  <h3>High-Deductible Strategy</h3>
  <p>
    High-deductible plans work well if you:
  </p>
  <ul>
    <li>Are healthy and rarely need medical care beyond emergencies</li>
    <li>Have savings to cover the deductible if needed</li>
    <li>Live in a country with affordable healthcare (paying out-of-pocket for routine care)</li>
    <li>Want insurance primarily for catastrophic events</li>
  </ul>
  <p>
    High-deductible plans are risky if you:
  </p>
  <ul>
    <li>Have ongoing health conditions requiring regular care</li>
    <li>Don't have savings to cover a large deductible</li>
    <li>Prefer predictable healthcare costs</li>
  </ul>

  <CTABox
    title="Calculate Your Savings"
    description="See how much you could save with different deductible options."
    buttonText="Get a Quote"
    buttonHref="/go/img-global"
  />

  <h2 id="pricing">Pricing Analysis</h2>
  <p>
    IMG Global is consistently 15–40% cheaper than Allianz Care, with the gap widening at higher deductible levels. Here's how the pricing compares across different profiles.
  </p>

  <ComparisonTable columns={pricingColumns} rows={pricingRows} />

  <h3>Understanding the Price Gap</h3>
  <p>
    IMG Global costs less because they:
  </p>
  <ul>
    <li>Offer limited mental health coverage (expensive to insure)</li>
    <li>Cap maternity benefits at $5,000–$10,000 (pregnancy is costly)</li>
    <li>Typically exclude pre-existing conditions (reduces risk)</li>
    <li>Maintain a smaller direct billing network (lower administrative costs)</li>
    <li>Offer ultra-high deductibles that shift more costs to members</li>
  </ul>
  <p>
    Allianz Care costs more because they:
  </p>
  <ul>
    <li>Include comprehensive mental health coverage</li>
    <li>Offer strong maternity benefits (up to €30,000)</li>
    <li>Cover pre-existing conditions after moratorium period</li>
    <li>Maintain a 2M+ provider direct billing network</li>
    <li>Include wellness programs and preventive care</li>
    <li>Provide multilingual support (15+ languages)</li>
  </ul>

  <h3>5-Year Cost Comparison</h3>
  <p>
    For a healthy 35-year-old single expat with high deductible plans:
  </p>
  <ul>
    <li><strong>Allianz Care:</strong> ~€1,800/year × 5 = €9,000</li>
    <li><strong>IMG Global:</strong> ~$1,200/year × 5 = $6,000</li>
    <li><strong>5-year savings with IMG:</strong> ~$3,000–$4,000</li>
  </ul>
  <p>
    However, if you need mental health care or become pregnant, Allianz's coverage could save you more than the premium difference.
  </p>

  <h2 id="network-claims">Provider Networks and Claims</h2>
  <p>
    Allianz Care has a significantly larger direct billing network, while IMG Global compensates with strong claims service and their 4.6/5 Trustpilot rating.
  </p>

  <ComparisonTable columns={claimsColumns} rows={claimsRows} />

  <h3>Allianz Care Claims Experience</h3>
  <ul>
    <li><strong>2M+ providers:</strong> Extensive direct billing network, especially strong in Europe</li>
    <li><strong>MyHealth portal:</strong> Full-featured claims submission and policy management</li>
    <li><strong>Fast processing:</strong> Most claims processed in 5–7 business days</li>
    <li><strong>Multilingual support:</strong> 15+ languages with specialists who understand local healthcare systems</li>
    <li><strong>Hospital coordination:</strong> Pre-authorization and direct payment for planned procedures</li>
  </ul>

  <h3>IMG Global Claims Experience</h3>
  <ul>
    <li><strong>Smaller network:</strong> Less direct billing availability—expect to pay and claim more often</li>
    <li><strong>4.6/5 Trustpilot:</strong> Excellent claims reputation despite budget pricing</li>
    <li><strong>Online portal/app:</strong> Good functionality for claims submission</li>
    <li><strong>Processing time:</strong> 5–10 business days for most claims</li>
    <li><strong>Any provider:</strong> You can see any licensed provider worldwide and claim reimbursement</li>
  </ul>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">IMG's Trustpilot Advantage</h3>
    <p class="text-neutral-600 mb-0">
      IMG Global's 4.6/5 Trustpilot rating is notable for a budget insurer. Customers consistently praise reliable claims payment and responsive service. This suggests IMG prioritizes claims satisfaction even while offering lower premiums—an important consideration when choosing budget insurance.
    </p>
  </div>

  <h2 id="scenarios">Real-World Scenarios</h2>
  <p>
    Let's walk through specific situations to see how each plan performs in practice.
  </p>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 1: Emergency Hospitalization in Spain</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're living in Barcelona when you need emergency surgery. Hospital bill: €15,000.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care (€1,000 deductible):</strong> Direct billing likely at major Barcelona hospitals. You pay €1,000 deductible, Allianz pays €14,000 directly.</p>
      <p class="text-neutral-600 mb-0"><strong>IMG Global ($2,500 deductible):</strong> Outside US, deductible is $1,250 (50% waiver). You may pay upfront and claim reimbursement. IMG pays ~$13,750 after deductible.</p>
      <p class="text-green-700 font-medium mt-2">Winner: Both handle this well. Allianz has easier direct billing; IMG has lower effective deductible.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 2: Ongoing Therapy for Anxiety</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You've been abroad 6 months and are struggling with anxiety. You need weekly therapy ($150/session) and medication ($80/month).</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Mental health coverage kicks in. Therapy sessions covered (with limits depending on plan tier). Medication covered. Annual cost to you: deductible + any copays.</p>
      <p class="text-neutral-600 mb-0"><strong>IMG Global:</strong> Limited or no coverage for outpatient mental health. You likely pay 100% out-of-pocket: ~$8,500/year for weekly therapy + medication.</p>
      <p class="text-blue-700 font-medium mt-2">Winner: Allianz Care—mental health coverage saves thousands annually.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 3: Having a Baby Abroad</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're planning to have a baby while living in Portugal. Estimated delivery cost: €8,000 for uncomplicated birth.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Maternity benefit up to €30,000 after waiting period. €8,000 delivery fully covered. Newborn automatically covered for 30 days.</p>
      <p class="text-neutral-600 mb-0"><strong>IMG Global:</strong> Maternity capped at $5,000–$10,000 after waiting period. €8,000 delivery may not be fully covered, depending on plan. You could owe €3,000–€5,000+ out-of-pocket.</p>
      <p class="text-blue-700 font-medium mt-2">Winner: Allianz Care—€30K maternity benefit vs $5K–$10K cap makes a real difference.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 4: The Healthy Budget Expat</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're 32, healthy, no pre-existing conditions, no plans for children, and comfortable with high deductibles. You live in Thailand where healthcare is affordable.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care (€5,000 deductible):</strong> Comprehensive coverage at ~€100/month. Annual: ~€1,200.</p>
      <p class="text-neutral-600 mb-0"><strong>IMG Global ($10,000 deductible):</strong> Coverage with effective $5,000 international deductible at ~$70/month. Annual: ~$840.</p>
      <p class="text-amber-700 font-medium mt-2">Winner: IMG Global—you save ~$360/year and the 50% deductible waiver makes the high deductible manageable.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 5: Pre-Existing Condition Management</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You have well-controlled Type 2 diabetes that hasn't required treatment changes in 3 years. You need ongoing medication and monitoring.</p>
      <p class="text-neutral-600 mb-2"><strong>Allianz Care:</strong> Moratorium underwriting may cover diabetes after 2 years treatment-free. If eligible, ongoing care is covered. Direct billing network makes pharmacy access easier.</p>
      <p class="text-neutral-600 mb-0"><strong>IMG Global:</strong> Pre-existing conditions typically excluded permanently. Diabetes management paid 100% out-of-pocket forever.</p>
      <p class="text-blue-700 font-medium mt-2">Winner: Allianz Care—moratorium underwriting offers a path to coverage that IMG doesn't.</p>
    </div>
  </div>

  <h2 id="who-should-choose">Who Should Choose Which</h2>
  <p>
    Based on our analysis, here's detailed guidance on who each provider serves best.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Allianz Care Is Right For:</h3>
      <ul class="space-y-3 text-neutral-700">
        <li><strong>Anyone needing mental health coverage:</strong> If you see a therapist, take psychiatric medication, or value having this safety net</li>
        <li><strong>Families planning children:</strong> The €30,000 maternity benefit vs $5K–$10K cap is a major difference</li>
        <li><strong>Those with pre-existing conditions:</strong> Moratorium underwriting offers potential coverage after 2 years</li>
        <li><strong>Europe-based expats:</strong> Strong network and multilingual support across EU countries</li>
        <li><strong>Those who prefer direct billing:</strong> 2M+ provider network means less upfront payment</li>
        <li><strong>Risk-averse individuals:</strong> Comprehensive coverage with fewer gaps provides peace of mind</li>
      </ul>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">IMG Global Is Right For:</h3>
      <ul class="space-y-3 text-neutral-700">
        <li><strong>Healthy expats who rarely use healthcare:</strong> Maximum premium savings when you don't need extensive coverage</li>
        <li><strong>Those comfortable with high deductibles:</strong> $10K–$25K deductibles (halved internationally) for lowest premiums</li>
        <li><strong>Expats outside the US:</strong> The 50% deductible waiver makes high-deductible plans much more attractive</li>
        <li><strong>Those who don't need mental health coverage:</strong> No gap to worry about if you won't use it</li>
        <li><strong>Those not planning children:</strong> Limited maternity doesn't matter if you don't need it</li>
        <li><strong>Budget-conscious expats:</strong> When premium cost is the primary constraint</li>
        <li><strong>Those comfortable with reimbursement:</strong> Smaller network means more pay-and-claim situations</li>
      </ul>
