---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "SafetyWing vs Bupa vs Cigna: Best International Health Insurance for Creatives";
const description = "Compare SafetyWing, Bupa Global, and Cigna Global for artists, designers, writers, and creative professionals working abroad. Coverage analysis for freelance creatives with variable income.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const mainComparisonRows = [
  { feature: 'Monthly Flexibility', safetywing: 'Subscribe/cancel anytime', bupa: 'Annual commitment', cigna: 'Annual plans' },
  { feature: 'Variable Income Friendly', safetywing: 'Very flexible', bupa: 'Fixed annual cost', cigna: 'Fixed annual cost' },
  { feature: 'Mental Health Coverage', safetywing: 'Limited', bupa: 'Comprehensive', cigna: 'Comprehensive' },
  { feature: 'Global Mobility', safetywing: 'Built-in', bupa: 'Available', cigna: 'Available' },
  { feature: 'RSI/Ergonomic Issues', safetywing: 'Emergency only', bupa: 'Full outpatient', cigna: 'Full outpatient' },
  { feature: 'Vision/Hearing', safetywing: 'Emergency only', bupa: 'Optional add-on', cigna: 'Optional add-on' },
  { feature: 'Starting Price', safetywing: '$', bupa: '$$$', cigna: '$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', safetywing: 'Up to $250K', bupa: 'Full coverage', cigna: 'Unlimited options' },
  { coverage: 'Outpatient', safetywing: 'Emergency only', bupa: 'Comprehensive', cigna: 'Comprehensive' },
  { coverage: 'Mental Health', safetywing: 'Limited', bupa: 'Unlimited sessions', cigna: 'Full coverage' },
  { coverage: 'Physiotherapy', safetywing: 'Emergency only', bupa: 'Included', cigna: 'Included' },
  { coverage: 'Dental', safetywing: 'Emergency only', bupa: 'Optional add-on', cigna: 'Optional add-on' },
  { coverage: 'Pre-existing Conditions', safetywing: 'Excluded', bupa: 'Underwritten', cigna: 'Moratorium option' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'cigna', header: 'Cigna Global' },
];

const pricingRows = [
  { profile: 'Designer, 28', safetywing: '$45-55/mo', bupa: '$300-450/mo', cigna: '$280-400/mo' },
  { profile: 'Writer, 35', safetywing: '$55-70/mo', bupa: '$400-550/mo', cigna: '$350-500/mo' },
  { profile: 'Artist, 42', safetywing: '$75-95/mo', bupa: '$500-700/mo', cigna: '$450-650/mo' },
  { profile: 'With mental health priority', safetywing: 'Limited benefit', bupa: 'Included', cigna: 'Included' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'creative-considerations', text: 'Creative Professional Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Freelancers', href: '/insurance-for/freelancers' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-blue-800 text-sm">You're a young creative with variable income who values flexibility over comprehensive coverage, and you're comfortable with basic protection while building your career.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You're an established creative who can afford premium coverage, value mental health support for creative wellbeing, and want comprehensive care including physiotherapy.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-purple-800 text-sm">You want excellent coverage with strong mental health benefits and global flexibility, and you're at a career stage where comprehensive insurance makes sense.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Creative professionals face unique challenges: irregular income streams, high rates of anxiety and depression, repetitive strain injuries from computer work or instruments, and the need for location flexibility. These three providers offer very different approaches to serving creative expats.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing has become popular among creative freelancers and digital nomads for its flexibility and affordability. Their subscription model works well with variable creative income, though coverage is more limited than premium alternatives.</p>

      <h3>Strengths for Creatives</h3>
      <ul>
        <li>Monthly subscription with no long-term commitment</li>
        <li>Affordable for creatives with variable income</li>
        <li>Global coverage built-in for nomadic lifestyles</li>
        <li>Simple signup—minutes to get covered</li>
        <li>Pause coverage during slow periods if needed</li>
        <li>Popular in creative communities for peer support</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>$250K annual maximum—may be concerning for serious illness</li>
        <li>Mental health coverage very limited—a significant gap for creatives</li>
        <li>No routine outpatient care—physio for RSI not covered</li>
        <li>Pre-existing conditions excluded entirely</li>
        <li>May not cover professional-specific injuries adequately</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global represents the premium end of coverage for creative professionals. Their comprehensive mental health benefits, wellness programs, and outpatient coverage address the specific health challenges creatives face, including stress, burnout, and repetitive strain injuries.</p>

      <h3>Strengths for Creatives</h3>
      <ul>
        <li>Excellent mental health coverage—unlimited therapy sessions</li>
        <li>Comprehensive outpatient including physiotherapy for RSI</li>
        <li>Wellness programs for preventive health</li>
        <li>Vision and hearing coverage available as add-ons</li>
        <li>Global network for creatives who relocate frequently</li>
        <li>Second opinion services for complex conditions</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—significant investment for freelancers</li>
        <li>Annual commitment not ideal for variable income</li>
        <li>May be excessive for young, healthy creatives</li>
        <li>Better suited when income is stable or growing</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers comprehensive coverage with particularly strong mental health benefits, making them well-suited for creative professionals who understand the importance of psychological wellbeing in sustaining creative work.</p>

      <h3>Strengths for Creatives</h3>
      <ul>
        <li>Comprehensive mental health coverage for anxiety and depression</li>
        <li>Full outpatient coverage including physio and specialist care</li>
        <li>Strong global network for nomadic creatives</li>
        <li>24/7 support for those working irregular hours</li>
        <li>Moratorium option for some pre-existing conditions</li>
        <li>Telemedicine access for remote consultations</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Annual commitment with fixed costs</li>
        <li>Premium pricing requires stable income</li>
        <li>Application process more involved than SafetyWing</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>The gap between SafetyWing and premium providers is substantial—especially for mental health and outpatient care. Creatives should carefully consider whether budget savings justify coverage limitations.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>The pricing difference is dramatic: SafetyWing costs roughly 10-15% of premium alternatives. The question is whether that savings is worth the coverage limitations, particularly around mental health.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by age, health history, location, and coverage level. Consider mental health needs carefully when choosing between providers.</p>
    </section>

    <section id="creative-considerations" class="mb-12">
      <h2>Creative Professional Considerations</h2>

      <h3>Mental Health is Critical</h3>
      <p>Creative professionals experience higher rates of anxiety, depression, and burnout than many other professions. SafetyWing's limited mental health coverage is a significant gap. If you've ever needed therapy or anticipate needing support, Bupa or Cigna's comprehensive coverage is worth the investment.</p>

      <h3>Repetitive Strain and Ergonomic Issues</h3>
      <p>Designers, writers, musicians, and visual artists often develop RSI, carpal tunnel, back problems, or other ergonomic issues. Bupa and Cigna cover physiotherapy and specialist treatment. SafetyWing's emergency-only outpatient coverage doesn't address ongoing ergonomic health needs.</p>

      <h3>Variable Income Realities</h3>
      <p>Creative income fluctuates with projects, commissions, and client work. SafetyWing's monthly model accommodates this—you can adjust or pause coverage during lean periods. Bupa and Cigna's annual commitments require steadier cash flow or savings to cover premiums during slow periods.</p>

      <h3>Vision and Hearing</h3>
      <p>Visual artists, photographers, and musicians depend on their senses professionally. Routine vision and hearing care isn't included in base plans but available as add-ons with Bupa and Cigna. SafetyWing covers only emergencies, not the routine care professionals may need.</p>

      <h3>Nomadic Lifestyle Support</h3>
      <p>Many creatives work from multiple countries throughout the year. All three providers support global mobility, but SafetyWing is built specifically for nomadic work patterns. Bupa and Cigna accommodate it through their worldwide coverage options.</p>

      <h3>Community Health</h3>
      <p>Creative communities often share health insurance recommendations. SafetyWing has strong word-of-mouth among nomadic creatives and digital nomads. However, community popularity doesn't always indicate best fit—assess your own health needs carefully.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Young creatives (20s-early 30s)</li>
            <li>• Those building freelance careers</li>
            <li>• Creatives with variable income</li>
            <li>• Digital nomad artists and designers</li>
            <li>• Budget-focused coverage seekers</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Established creative professionals</li>
            <li>• Those prioritizing mental health</li>
            <li>• Creatives with physical health needs</li>
            <li>• Artists with stable income streams</li>
            <li>• Those valuing wellness programs</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Mid-career creative professionals</li>
            <li>• Those needing mental health support</li>
            <li>• Creatives with pre-existing conditions</li>
            <li>• Globally mobile artists</li>
            <li>• Balance of cost and coverage seekers</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is SafetyWing's mental health coverage really inadequate for creatives?</h3>
          <p class="text-neutral-700">SafetyWing covers acute psychiatric emergencies but not ongoing therapy or counseling. Given creative professionals' higher rates of anxiety and depression, this gap can be significant. If mental health support matters to you, budget for premium coverage.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does insurance cover repetitive strain injuries for designers/writers?</h3>
          <p class="text-neutral-700">Bupa and Cigna cover physiotherapy, occupational therapy, and specialist treatment for RSI and carpal tunnel. SafetyWing's emergency-only outpatient coverage typically doesn't cover ongoing ergonomic treatment.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How do I handle insurance during months with low income?</h3>
          <p class="text-neutral-700">SafetyWing's monthly model lets you maintain coverage during lean periods at low cost. For Bupa or Cigna's annual premiums, budget throughout the year or consider setting aside funds during good months for insurance costs.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Can musicians get coverage for hearing-related issues?</h3>
          <p class="text-neutral-700">Routine hearing care and hearing aids typically require add-on coverage with Bupa or Cigna. Hearing damage from acute incidents would be covered as emergency care. SafetyWing covers only emergency situations.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I upgrade from SafetyWing as my creative career grows?</h3>
          <p class="text-neutral-700">Consider upgrading when you have stable income, are developing health needs (especially mental health), or want peace of mind that basic coverage doesn't provide. Many creatives upgrade in their 30s as careers stabilize.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is health insurance tax-deductible for freelance creatives?</h3>
          <p class="text-neutral-700">In many countries, self-employed individuals can deduct health insurance premiums as a business expense. This effectively reduces the net cost of premium coverage. Consult a tax professional for your specific situation.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
