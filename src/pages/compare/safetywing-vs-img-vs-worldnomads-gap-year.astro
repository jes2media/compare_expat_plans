---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'worldnomads', text: 'World Nomads', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'gap-year-needs', text: 'Gap Year Considerations', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/compare/safetywing-vs-worldnomads-vs-img-backpackers', text: 'Backpacker Insurance' },
  { href: '/compare/safetywing-vs-cigna-vs-allianz-students', text: 'Student Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/best/travel-insurance', text: 'Best Travel Insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const mainComparisonRows = [
  { feature: 'Best For', safetywing: 'Budget gap year', img: 'Flexible coverage', worldnomads: 'Adventure gap year' },
  { feature: 'Coverage Duration', safetywing: 'Unlimited (subscription)', img: '5 days to 3 years', worldnomads: 'Up to 12 months' },
  { feature: 'Adventure Activities', safetywing: 'Basic only', img: 'Add-on available', worldnomads: '150+ activities' },
  { feature: 'Working Holiday Covered', safetywing: 'Yes', img: 'Yes', worldnomads: 'Yes' },
  { feature: 'Volunteer Work', safetywing: 'Yes', img: 'Yes', worldnomads: 'Yes' },
  { feature: 'Trip Cancellation', safetywing: 'No', img: 'Optional', worldnomads: 'Included' },
  { feature: 'Gear Coverage', safetywing: 'Limited ($3K)', img: 'Limited', worldnomads: 'Good coverage' },
  { feature: 'Parent Peace of Mind', safetywing: 'Basic tracking', img: 'Good support', worldnomads: 'Best app/tracking' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const pricingRows = [
  { profile: 'Gap year (age 22, 6 months)', safetywing: '$252', img: '$300-450', worldnomads: '$350-500' },
  { profile: 'Gap year (age 22, 12 months)', safetywing: '$504', img: '$550-800', worldnomads: '$650-950' },
  { profile: 'With adventure add-on', safetywing: 'N/A (not available)', img: '+$100-200', worldnomads: 'Included' },
  { profile: 'Monthly cost (age 22)', safetywing: '$42', img: '$50-75', worldnomads: '$60-85' },
];
---

<PageShell
  title="SafetyWing vs IMG vs World Nomads for Gap Year | 2025 Comparison"
  description="Compare SafetyWing, IMG Global, and World Nomads for gap year travelers. Expert analysis of working holiday coverage, adventure activities, and year-long travel insurance."
  headline="SafetyWing vs IMG vs World Nomads: Best Gap Year Insurance"
  subheadline="Complete comparison of three leading providers for gap year travelers taking a year abroad for travel, work, and adventure."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Cheapest year-long coverage with subscription billing. Perfect for budget-conscious gap year travelers.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 mb-3">Best Flexibility</p>
        <p class="text-neutral-700 text-sm mb-4">Most flexible duration with optional adventure coverage. Good for gap years with uncertain plans.</p>
        <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">World Nomads</h3>
        <p class="text-green-700 mb-3">Best for Adventure</p>
        <p class="text-neutral-700 text-sm mb-4">150+ adventure activities covered with trip cancellation included. Ideal for active gap year travelers.</p>
        <a href="/get-quotes" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Get Quote</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Cheapest Option</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Subscription Model</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">No End Date Needed</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing is the obvious choice for budget-conscious gap year travelers. At roughly $42/month for those under 40, a full year costs around $500—significantly less than competitors. The subscription model means you don't need to know exactly when your gap year will end.</p>

    <p class="text-neutral-700 mb-4">Coverage works for working holidays and volunteer programs, common gap year activities. The main limitation is adventure sports—if you're planning bungee jumping, scuba diving, or motorbike adventures, SafetyWing won't cover injuries from these activities.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Gap Year Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Cheapest year-long coverage</li>
          <li>• No need to set end date</li>
          <li>• Working holiday covered</li>
          <li>• Volunteer work included</li>
          <li>• Simple monthly billing</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited adventure sports</li>
          <li>• No trip cancellation</li>
          <li>• Basic gear coverage ($3K)</li>
          <li>• Lower evacuation limits</li>
          <li>• 1-month minimum</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Duration</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Adventure Add-on</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Higher Evacuation</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers the most flexibility for gap year travelers whose plans might evolve. Coverage ranges from 5 days to 3 years, with easy online extensions. If you're not sure whether your gap year will be 6 months or 18 months, IMG accommodates uncertainty.</p>

    <p class="text-neutral-700 mb-4">The optional adventure sports add-on covers activities that SafetyWing excludes, though not as comprehensively as World Nomads. IMG's $500K evacuation limit provides strong protection for gap year travelers in remote areas.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Gap Year Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Flexible duration (5 days to 3 years)</li>
          <li>• Adventure sports add-on available</li>
          <li>• High evacuation limit ($500K)</li>
          <li>• Easy online extensions</li>
          <li>• Working holiday and volunteer covered</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• More expensive than SafetyWing</li>
          <li>• Adventure coverage costs extra</li>
          <li>• Trip cancellation not included</li>
          <li>• Less activity coverage than World Nomads</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="worldnomads" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">World Nomads</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">150+ Activities</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Trip Cancellation</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Gear Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">World Nomads is built for adventure-filled gap years. Their Explorer plan covers 150+ activities including scuba diving, bungee jumping, trekking, and even motorbike riding (with license). Trip cancellation coverage protects your investment if plans change.</p>

    <p class="text-neutral-700 mb-4">The app provides peace of mind for parents—they can see your coverage status and emergency contacts. Gear coverage protects expensive cameras, laptops, and equipment that gap year travelers often carry. The premium price reflects this comprehensive protection.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Gap Year Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 150+ adventure activities covered</li>
          <li>• Trip cancellation included</li>
          <li>• Best gear/equipment coverage</li>
          <li>• Great app for parent peace of mind</li>
          <li>• Motorbike coverage (with license)</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Most expensive option</li>
          <li>• 12-month maximum (requires renewal)</li>
          <li>• Must specify dates upfront</li>
          <li>• Extension process required</li>
        </ul>
      </div>
    </div>

    <a href="/get-quotes" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get World Nomads Quote</a>
  </section>

  <CTABox
    title="Compare Gap Year Coverage Quotes"
    description="Get personalized quotes for your gap year adventure from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Gap year pricing for typical travelers aged 18-25:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*SafetyWing's pricing advantage is most significant for year-long coverage. World Nomads' premium includes adventure activities and trip cancellation.</p>
  </section>

  <section id="gap-year-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Gap Year Considerations</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Working Holiday Coverage</h3>
        <p class="text-neutral-700 text-sm mb-4">All three cover working holidays, but with differences:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>SafetyWing:</strong> Covers casual work, not manual labor</li>
          <li>• <strong>IMG:</strong> Good working holiday coverage</li>
          <li>• <strong>World Nomads:</strong> Covers most legal work activities</li>
        </ul>
        <p class="text-neutral-600 text-xs mt-3">Verify coverage for your specific work type before enrolling.</p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Parent Considerations</h3>
        <p class="text-neutral-700 text-sm mb-4">Features that help parents feel comfortable:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>SafetyWing:</strong> Parents can purchase/manage coverage</li>
          <li>• <strong>IMG:</strong> 24/7 emergency line parents can call</li>
          <li>• <strong>World Nomads:</strong> Best app for sharing coverage status</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Common Gap Year Activities</h3>
      <p class="text-blue-700 mb-4">Coverage varies significantly by activity:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">SafetyWing Covers</h4>
          <p class="text-blue-700 text-sm">Hiking, surfing (amateur), cycling, kayaking, snorkeling. Basic activities only—check exclusions carefully.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">IMG + Add-on Covers</h4>
          <p class="text-blue-700 text-sm">Above plus scuba diving (basic), skiing, zip-lining. Some activities excluded even with add-on.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">World Nomads Covers</h4>
          <p class="text-blue-700 text-sm">150+ activities including bungee, skydiving, motorbikes (with license), mountaineering. Most comprehensive.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Budget is your main concern</li>
          <li>• You're not planning extreme activities</li>
          <li>• Your gap year length is uncertain</li>
          <li>• You want simple subscription billing</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You want flexibility with some adventure coverage</li>
          <li>• Your plans might extend beyond 12 months</li>
          <li>• Higher evacuation limits matter to you</li>
          <li>• You want the option to add adventure sports</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose World Nomads if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Adventure activities are central to your gap year</li>
          <li>• You're planning scuba, bungee, or motorbike travel</li>
          <li>• Trip cancellation protection is important</li>
          <li>• You have expensive gear to protect</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can my parents buy gap year insurance for me?</h3>
        <p class="text-neutral-700">Yes, parents can purchase and manage coverage for adult children. SafetyWing and IMG allow this easily. World Nomads requires the traveler to be the policyholder but parents can pay. Keep policy documents accessible to both parents and traveler.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if my gap year extends beyond 12 months?</h3>
        <p class="text-neutral-700">SafetyWing continues automatically—no action needed. IMG allows extensions up to 3 years total. World Nomads requires purchasing a new policy before the first expires (they allow purchase while abroad). Don't let coverage lapse between policies.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Am I covered for volunteer work abroad?</h3>
        <p class="text-neutral-700">Yes, all three cover general volunteer work. However, high-risk volunteer activities (construction, medical work without credentials) may be excluded or require verification. Standard teaching, conservation, and community work are typically covered.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about mental health coverage during my gap year?</h3>
        <p class="text-neutral-700">All three provide basic emergency mental health coverage. For ongoing therapy or counseling, coverage is limited—these are travel insurance products, not comprehensive health plans. If you have existing mental health needs, consider whether travel insurance is sufficient.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Activity coverage has specific requirements and exclusions. Working holiday and volunteer coverage may have limitations. Always verify specific coverage directly with providers before purchasing. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
