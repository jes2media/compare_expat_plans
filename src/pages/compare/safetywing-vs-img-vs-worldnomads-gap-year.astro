---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'worldnomads', text: 'World Nomads', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'gap-year-details', text: 'Gap Year Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/gap-year', text: 'Gap Year Insurance Guide' },
  { href: '/best/travel-insurance', text: 'Best Travel Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/providers/world-nomads', text: 'World Nomads Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const mainComparisonRows = [
  { feature: 'Maximum Duration', safetywing: 'Unlimited', img: '12 months', worldnomads: '12 months' },
  { feature: 'Adventure Sports', safetywing: 'Basic included', img: 'Add-on available', worldnomads: 'Extensive (150+)' },
  { feature: 'Medical Maximum', safetywing: '\$250,000', img: '\$2-8 million', worldnomads: '\$100K-\$500K' },
  { feature: 'Trip Cancellation', safetywing: 'Not included', img: 'Available', worldnomads: 'Included' },
  { feature: 'Gear Coverage', safetywing: 'Limited', img: 'Available', worldnomads: 'Good (\$3K+)' },
  { feature: 'Age Limit', safetywing: '18-69', img: '14-74', worldnomads: '18-70' },
  { feature: 'Extend While Traveling', safetywing: 'Yes (automatic)', img: 'Yes', worldnomads: 'Yes' },
  { feature: 'Work Coverage', safetywing: 'Basic remote work', img: 'Plan dependent', worldnomads: 'Limited' },
];

const pricingColumns = [
  { key: 'duration', header: 'Duration' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const pricingRows = [
  { duration: '3 months', safetywing: '\$126', img: '\$200-400', worldnomads: '\$180-350' },
  { duration: '6 months', safetywing: '\$252', img: '\$350-700', worldnomads: '\$320-600' },
  { duration: '12 months', safetywing: '\$504', img: '\$600-1,200', worldnomads: '\$550-1,100' },
  { duration: 'With adventure sports', safetywing: 'Included', img: '+\$50-150', worldnomads: 'Included' },
];
---

<PageShell
  title="SafetyWing vs IMG vs World Nomads for Gap Year | 2025 Comparison"
  description="Compare SafetyWing, IMG Global, and World Nomads for gap year travelers. Expert analysis of adventure sports, long-term coverage, gear protection, and flexibility."
  headline="SafetyWing vs IMG vs World Nomads: Gap Year"
  subheadline="Complete comparison for gap year travelers—covering adventure activities, extended trips, flexibility to change plans, and coverage that keeps up with your journey."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget</p>
        <p class="text-neutral-700 text-sm mb-4">Lowest cost for year-long coverage with unlimited duration. Best for budget gap year travelers focused on basic medical coverage.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 mb-3">Best Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Highest medical limits and most comprehensive coverage. Best for those wanting premium protection during their gap year.</p>
        <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">World Nomads</h3>
        <p class="text-green-700 mb-3">Best Adventure</p>
        <p class="text-neutral-700 text-sm mb-4">Covers 150+ adventure activities as standard. Best for gap year travelers planning extreme sports and outdoor adventures.</p>
        <a href="/providers/world-nomads" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Duration</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Monthly Billing</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing is the budget choice for gap year coverage. At approximately $42 per month ($504 per year), it costs significantly less than alternatives for year-long trips. The subscription model means no lock-in—cancel anytime, extend indefinitely, and pay as you go. Perfect for open-ended gap years without fixed end dates.</p>

    <p class="text-neutral-700 mb-4">Coverage is basic but solid: $250,000 medical maximum, emergency evacuation, and 24/7 support. Basic adventure sports (hiking, surfing, skiing) are included. The main tradeoff is no trip cancellation, limited gear coverage, and a lower medical maximum than comprehensive plans.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Gap Year Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest annual cost</li>
          <li>• Unlimited trip duration</li>
          <li>• Monthly subscription</li>
          <li>• Basic sports included</li>
          <li>• No commitment required</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• $250K medical limit</li>
          <li>• No trip cancellation</li>
          <li>• Limited gear coverage</li>
          <li>• Extreme sports not covered</li>
          <li>• Basic coverage only</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">High Limits</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Plans</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers the most comprehensive coverage for gap year travelers willing to pay more. Medical maximums up to $8 million mean serious injuries or illnesses will not lead to financial hardship. The iTravelInsured platform offers multiple plan tiers for budget flexibility.</p>

    <p class="text-neutral-700 mb-4">Trip cancellation and interruption coverage is available if your gap year gets disrupted. Adventure sports add-ons cover more extreme activities. Gear coverage protects expensive equipment. The tradeoff is cost—IMG runs 2-3x the price of SafetyWing for comprehensive coverage.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Gap Year Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Highest medical limits</li>
          <li>• Trip cancellation available</li>
          <li>• Adventure sports add-ons</li>
          <li>• Gear coverage options</li>
          <li>• Flexible plan tiers</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Higher cost (2-3x budget options)</li>
          <li>• 12-month maximum</li>
          <li>• Sports add-ons cost extra</li>
          <li>• More complex plan selection</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="worldnomads" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">World Nomads</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Adventure Sports</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">150+ Activities</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Gear Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">World Nomads is built for adventure. Over 150 activities are covered as standard—bungee jumping, skydiving, scuba diving, mountain climbing, and more. If your gap year involves pushing limits and trying extreme sports, World Nomads is designed for you.</p>

    <p class="text-neutral-700 mb-4">Gear coverage is strong ($3,000+ for equipment), protecting expensive cameras, laptops, and sports gear. Trip cancellation is included. The medical limit ($100K-$500K depending on plan) is lower than IMG but higher than SafetyWing.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Gap Year Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• 150+ adventure sports included</li>
          <li>• Strong gear coverage</li>
          <li>• Trip cancellation included</li>
          <li>• Easy online management</li>
          <li>• Good for extreme sports</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Mid-range medical limits</li>
          <li>• 12-month maximum trip</li>
          <li>• Higher than budget options</li>
          <li>• Some extreme sports excluded</li>
        </ul>
      </div>
    </div>

    <a href="/providers/world-nomads" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get World Nomads Quote</a>
  </section>

  <CTABox
    title="Get Gap Year Coverage Quotes"
    description="Compare pricing for your specific trip duration, destinations, and planned activities."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Typical costs for gap year coverage (age 25, worldwide):</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative for worldwide coverage excluding US. Including US typically adds 30-50%.</p>
  </section>

  <section id="gap-year-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Gap Year Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Common Gap Year Activities</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Backpacking and hiking</li>
          <li>• Scuba diving (certified)</li>
          <li>• Surfing and water sports</li>
          <li>• Skiing and snowboarding</li>
          <li>• Volunteer work (varies)</li>
          <li>• Working holiday activities</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Often Excluded or Limited</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Professional or paid sports</li>
          <li>• Extreme mountaineering</li>
          <li>• Some motorsports</li>
          <li>• Manual labor jobs</li>
          <li>• War zones and high-risk areas</li>
          <li>• Unlicensed activities</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Budget is the priority</li>
          <li>• Your trip has no fixed end date</li>
          <li>• Basic medical coverage suffices</li>
          <li>• Adventure activities are moderate</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Maximum coverage is worth the cost</li>
          <li>• Trip cancellation protection matters</li>
          <li>• You want high medical limits</li>
          <li>• Comprehensive protection is the goal</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose World Nomads if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Adventure sports are central to your trip</li>
          <li>• You need gear coverage</li>
          <li>• You want trip cancellation included</li>
          <li>• 150+ covered activities appeals</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I work during my gap year with travel insurance?</h3>
        <p class="text-neutral-700">It depends on the type of work. SafetyWing covers basic remote work. World Nomads has limited work coverage. Physical labor or dangerous jobs are typically excluded.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if my gap year extends beyond 12 months?</h3>
        <p class="text-neutral-700">SafetyWing has no maximum duration—just keep paying monthly. IMG and World Nomads cap at 12 months but can usually be renewed when the first policy expires.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need to list all countries I will visit?</h3>
        <p class="text-neutral-700">Most gap year insurance covers you worldwide with some country exclusions. Check if specific countries are excluded (often Iran, North Korea, sanctioned countries).</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is volunteer work covered during gap year travel?</h3>
        <p class="text-neutral-700">Organized volunteer programs with reputable organizations are usually covered. Manual labor, construction, or anything resembling paid work may be excluded.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Gap year travel insurance coverage, activities, and limits vary by plan and change over time. Always verify activity coverage and exclusions before your trip.</p>
  </div>
</PageShell>
