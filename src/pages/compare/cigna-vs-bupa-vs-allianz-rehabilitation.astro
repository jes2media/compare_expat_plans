---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'rehab-details', text: 'Rehabilitation Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/guides/rehabilitation-abroad', text: 'Rehabilitation Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Physical Therapy', cigna: 'Covered (limits vary)', bupa: 'Covered (limits vary)', allianz: 'Limited sessions' },
  { feature: 'Inpatient Rehab', cigna: 'Covered', bupa: 'Covered', allianz: 'Covered' },
  { feature: 'Outpatient Rehab', cigna: 'With outpatient plan', bupa: 'With outpatient plan', allianz: 'Limited' },
  { feature: 'Occupational Therapy', cigna: 'Covered', bupa: 'Covered', allianz: 'Some plans' },
  { feature: 'Speech Therapy', cigna: 'Covered', bupa: 'Covered', allianz: 'Limited' },
  { feature: 'Cardiac Rehab', cigna: 'Covered', bupa: 'Covered', allianz: 'Covered' },
  { feature: 'Stroke Rehab', cigna: 'Comprehensive', bupa: 'Comprehensive', allianz: 'Basic' },
  { feature: 'Annual Session Limit', cigna: '30-60 sessions', bupa: '25-50 sessions', allianz: '15-25 sessions' },
];

const pricingColumns = [
  { key: 'plan', header: 'Plan Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { plan: 'Inpatient only', cigna: '\$200/mo', bupa: '\$230/mo', allianz: '\$170/mo' },
  { plan: 'With outpatient rehab', cigna: '\$350/mo', bupa: '\$400/mo', allianz: '\$280/mo' },
  { plan: 'Comprehensive', cigna: '\$450/mo', bupa: '\$500/mo', allianz: '\$350/mo' },
  { plan: 'Enhanced rehab limits', cigna: '\$500/mo', bupa: '\$550/mo', allianz: 'N/A' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Rehabilitation Coverage | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for rehabilitation and physical therapy. Expert analysis of session limits, inpatient rehab, and therapy coverage."
  headline="Cigna vs Bupa vs Allianz: Rehabilitation Coverage"
  subheadline="Complete comparison of rehabilitation benefits—including physical therapy, occupational therapy, cardiac rehab, stroke recovery, and session limits."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall</p>
        <p class="text-neutral-700 text-sm mb-4">Highest session limits and most comprehensive rehabilitation coverage. Best for those needing extensive physical therapy or complex rehab programs.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Strong Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Comprehensive rehab with good therapy networks. Strong cardiac and stroke rehabilitation programs with care coordination.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Basic Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Lower session limits but adequate for basic rehabilitation needs. Best for those with occasional therapy requirements at lower premiums.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Highest Limits</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">All Therapy Types</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers the most generous rehabilitation coverage with 30-60 physical therapy sessions annually depending on plan tier. All major therapy types are covered: physical therapy, occupational therapy, speech therapy, and specialized rehabilitation. Inpatient rehab following surgery or serious illness has no separate limit.</p>

    <p class="text-neutral-700 mb-4">Cardiac rehabilitation programs are comprehensive, typically covering the full recommended course of sessions. Stroke rehabilitation includes both inpatient and outpatient phases with coordination between specialists. For expats recovering from serious injuries or surgeries, Cigna's rehab coverage provides the depth needed for full recovery.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Rehab Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Highest annual session limits</li>
          <li>• All therapy types covered</li>
          <li>• Comprehensive cardiac rehab</li>
          <li>• Full stroke recovery programs</li>
          <li>• Good therapist networks</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Requires outpatient plan</li>
          <li>• Higher premium for full benefits</li>
          <li>• Pre-authorization for some</li>
          <li>• Network varies by location</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Care Coordination</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Cardiac Programs</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Good Networks</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global provides strong rehabilitation coverage with 25-50 sessions annually. Their care coordination stands out—case managers help navigate complex rehabilitation programs, coordinating between surgeons, therapists, and specialists. This is valuable for stroke recovery or post-surgical rehabilitation.</p>

    <p class="text-neutral-700 mb-4">Cardiac rehabilitation is a particular strength, with partnerships with leading cardiac centers. The full recommended program of sessions is typically approved. Occupational and speech therapy are covered without separate sub-limits on comprehensive plans. Network quality in Europe and major global cities is excellent.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Rehab Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Excellent care coordination</li>
          <li>• Strong cardiac rehab</li>
          <li>• Good European networks</li>
          <li>• Case management support</li>
          <li>• All therapy types</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lower limits than Cigna</li>
          <li>• Premium pricing</li>
          <li>• Pre-authorization needed</li>
          <li>• Plan-dependent benefits</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Basic Coverage</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Lower Premiums</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care offers more limited rehabilitation coverage—typically 15-25 sessions annually for physical therapy. Inpatient rehabilitation following surgery or hospitalization is covered, but outpatient therapy sessions are restricted. This works for occasional therapy needs but may be insufficient for serious recovery programs.</p>

    <p class="text-neutral-700 mb-4">Speech therapy and occupational therapy coverage is limited or excluded on some plans. Cardiac rehab is covered but may have tighter session limits. For expats who need occasional physical therapy or have straightforward rehabilitation needs, Allianz offers adequate coverage at lower cost. Complex recoveries may require out-of-pocket supplementation.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Rehab Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lower premium costs</li>
          <li>• Inpatient rehab covered</li>
          <li>• Basic PT included</li>
          <li>• Adequate for light needs</li>
          <li>• Clear session limits</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lowest session limits</li>
          <li>• Speech therapy limited</li>
          <li>• OT may be excluded</li>
          <li>• Not for complex rehab</li>
          <li>• May exhaust limits quickly</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Get Rehabilitation Coverage Quotes"
    description="Compare therapy session limits and rehabilitation benefits across providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">How rehabilitation coverage affects premiums (individual, 45):</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative. Rehabilitation is typically included in outpatient coverage, not priced separately. Enhanced limits may be available on premium tiers. Actual costs depend on age, location, and health history.</p>
  </section>

  <section id="rehab-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Rehabilitation Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Therapy Types Covered</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Physical therapy (PT)</li>
          <li>• Occupational therapy (OT)</li>
          <li>• Speech and language therapy</li>
          <li>• Cardiac rehabilitation</li>
          <li>• Pulmonary rehabilitation</li>
          <li>• Neurological rehabilitation</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Common Exclusions</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Maintenance therapy (non-progressive)</li>
          <li>• Sports performance enhancement</li>
          <li>• Wellness/fitness programs</li>
          <li>• Long-term custodial care</li>
          <li>• Alternative therapy rehab</li>
          <li>• Cosmetic rehabilitation</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">When Rehabilitation Is Covered</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Post-Surgical</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Joint replacement</li>
            <li>• Spinal surgery</li>
            <li>• Cardiac surgery</li>
            <li>• Orthopedic procedures</li>
            <li>• Reconstruction</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Medical Conditions</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Stroke recovery</li>
            <li>• Heart attack</li>
            <li>• Traumatic injury</li>
            <li>• Neurological conditions</li>
            <li>• Chronic illness</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Injury Recovery</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Sports injuries</li>
            <li>• Accident recovery</li>
            <li>• Fracture rehabilitation</li>
            <li>• Soft tissue injuries</li>
            <li>• Work-related injuries</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You need maximum rehabilitation coverage</li>
          <li>• Complex recovery programs are likely</li>
          <li>• Multiple therapy types may be needed</li>
          <li>• Extensive session limits matter</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Care coordination is valuable</li>
          <li>• Cardiac rehabilitation is a concern</li>
          <li>• European network quality matters</li>
          <li>• Case management support helps</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Rehabilitation needs are occasional</li>
          <li>• Budget is the priority</li>
          <li>• Basic PT coverage suffices</li>
          <li>• You are generally healthy</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need pre-authorization for physical therapy?</h3>
        <p class="text-neutral-700">Often yes, especially for extended courses of treatment. Initial sessions may be approved automatically, but ongoing therapy typically requires authorization with supporting documentation from your physician explaining medical necessity.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What happens when I reach my session limit?</h3>
        <p class="text-neutral-700">Once you exhaust annual session limits, additional therapy is out-of-pocket until your policy renews. Some insurers allow medical necessity appeals for extended sessions in serious cases. Planning your rehabilitation within limits is important.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is home-based physical therapy covered?</h3>
        <p class="text-neutral-700">Usually yes if medically necessary—for example, post-surgical patients who cannot travel to clinics. Home visits from licensed therapists can be covered, though session limits still apply. This typically requires pre-authorization.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Are rehabilitation facilities covered for inpatient stays?</h3>
        <p class="text-neutral-700">Yes, inpatient rehabilitation facilities are covered when medically necessary—typically following major surgery, stroke, or serious injury. This is separate from outpatient session limits. Length of stay depends on medical necessity and insurer approval.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Rehabilitation coverage, session limits, and therapy types vary by specific plan and change over time. This comparison represents typical offerings—actual coverage depends on your plan tier and medical necessity. Always verify rehabilitation benefits before enrolling, especially if you anticipate needing extensive therapy.</p>
  </div>
</PageShell>
