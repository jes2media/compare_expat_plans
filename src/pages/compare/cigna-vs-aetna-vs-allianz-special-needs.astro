---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', title: 'Quick Verdict' },
  { id: 'comparison', title: 'Side-by-Side Comparison' },
  { id: 'cigna', title: 'Cigna Global' },
  { id: 'aetna', title: 'Aetna International' },
  { id: 'allianz', title: 'Allianz Care' },
  { id: 'pricing', title: 'Pricing Considerations' },
  { id: 'special-needs-details', title: 'Special Needs Coverage Details' },
  { id: 'best-for', title: 'Best For' },
  { id: 'faqs', title: 'FAQs' },
];

const relatedLinks = [
  { href: '/providers/cigna-global', title: 'Cigna Global Full Review' },
  { href: '/providers/aetna-international', title: 'Aetna International Full Review' },
  { href: '/providers/allianz-care', title: 'Allianz Care Full Review' },
  { href: '/insurance-for/families', title: 'Family Insurance Guide' },
  { href: '/guides/chronic-conditions-abroad', title: 'Chronic Conditions Guide' },
];

const mainComparisonColumns = ['Feature', 'Cigna Global', 'Aetna International', 'Allianz Care'];
const mainComparisonRows = [
  ['Autism Spectrum Coverage', 'Therapy covered—limits apply', 'Good coverage—limits apply', 'Plan dependent'],
  ['Physical Therapy', 'Included—session limits', 'Included—session limits', 'Included—session limits'],
  ['Occupational Therapy', 'Included—session limits', 'Included—session limits', 'Plan dependent'],
  ['Speech Therapy', 'Included—session limits', 'Included—session limits', 'Plan dependent'],
  ['Behavioral Therapy/ABA', 'Often covered with limits', 'Covered with limits', 'Limited coverage'],
  ['Developmental Assessments', 'Covered', 'Covered', 'Covered'],
  ['Specialist Access', 'Global network', 'Good network', 'Regional network'],
  ['Care Coordination', 'Case management available', 'Case management available', 'Limited'],
  ['Pre-existing Consideration', 'Full underwriting', 'Full underwriting', 'Full underwriting'],
];

const pricingColumns = ['Coverage Type', 'Cigna Global', 'Aetna International', 'Allianz Care'];
const pricingRows = [
  ['Family comprehensive', '$12,000-18,000/yr', '$11,000-16,000/yr', '$10,000-14,000/yr'],
  ['With therapy benefits', '+$2,000-4,000/yr', '+$1,500-3,500/yr', '+$1,000-2,500/yr'],
  ['Therapy session limits', '30-60 sessions/yr', '25-50 sessions/yr', '20-40 sessions/yr'],
  ['ABA therapy limits', 'Up to $15,000/yr', 'Up to $12,000/yr', 'Limited or excluded'],
  ['Child premium (0-18)', '$2,500-4,500/yr', '$2,200-4,000/yr', '$2,000-3,500/yr'],
];
---

<PageShell
  title="Cigna vs Aetna vs Allianz: Special Needs Family Insurance Comparison 2025"
  description="Compare Cigna, Aetna, and Allianz for expat families with special needs children. Autism coverage, therapy benefits, and specialist access abroad."
  headline="Cigna vs Aetna vs Allianz"
  subheadline="Which Provider is Best for Families with Special Needs?"
  heroImage="/images/compare/special-needs-hero.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Cigna Global</h3>
        <p class="text-neutral-700 mb-4">Best overall for special needs families with comprehensive therapy coverage, strong care coordination, and global specialist network.</p>
        <p class="text-sm font-medium text-primary-700">Most comprehensive therapy limits</p>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Aetna International</h3>
        <p class="text-neutral-700 mb-4">Strong option for US expat families with good ABA coverage and established US specialist connections for consistency of care.</p>
        <p class="text-sm font-medium text-purple-700">Good US network ties</p>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Allianz Care</h3>
        <p class="text-neutral-700 mb-4">Budget-conscious option with basic therapy coverage. May require supplementing with local services for comprehensive support.</p>
        <p class="text-sm font-medium text-green-700">More limited but affordable</p>
      </div>
    </div>
  </section>

  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <div class="bg-primary-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-primary-800 mb-4">Cigna Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Cigna Global provides comprehensive coverage for special needs families, including various therapies and care coordination services. Their global network helps maintain consistent care across relocations.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Special Needs Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Physical, occupational, and speech therapy included</li>
        <li>ABA therapy covered with annual limits (often up to $15,000)</li>
        <li>Developmental assessments and evaluations covered</li>
        <li>Case management for complex care coordination</li>
        <li>Global network of pediatric specialists</li>
        <li>Mental health coverage for families and children</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Session limits on therapies (typically 30-60 per year)</li>
        <li>Pre-existing conditions require full disclosure and may be excluded</li>
        <li>ABA limits may not cover intensive programs fully</li>
        <li>Higher premiums than competitors</li>
        <li>Specialist availability varies by location</li>
      </ul>
    </div>
  </section>

  <section id="aetna" class="mb-12">
    <div class="bg-purple-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-purple-800 mb-4">Aetna International</h2>
      <p class="text-lg text-neutral-700 mb-6">Aetna International offers solid special needs coverage, particularly beneficial for US families abroad who want to maintain connections with US-based specialists and treatment protocols.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Special Needs Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Good therapy coverage including ABA</li>
        <li>Strong US specialist network for telemedicine consultations</li>
        <li>Developmental and psychological assessments covered</li>
        <li>Case management for ongoing care coordination</li>
        <li>Coverage for autism spectrum treatments</li>
        <li>Integration with US employer benefits when applicable</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Therapy session limits apply (typically 25-50 per year)</li>
        <li>Pre-existing developmental conditions may be excluded</li>
        <li>Coverage outside US network may be more complex</li>
        <li>ABA limits may not cover full-time programs</li>
        <li>Less established in some international locations</li>
      </ul>
    </div>
  </section>

  <section id="allianz" class="mb-12">
    <div class="bg-green-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-green-800 mb-4">Allianz Care</h2>
      <p class="text-lg text-neutral-700 mb-6">Allianz Care provides more basic special needs coverage, which may be sufficient when combined with local services. Lower premiums make it accessible but may require supplemental coverage.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Special Needs Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Physical therapy coverage on most plans</li>
        <li>Developmental assessments typically covered</li>
        <li>More affordable family premiums</li>
        <li>Flexibility to add coverage as needed</li>
        <li>Good for supplementing local public services</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Occupational and speech therapy may require higher plans</li>
        <li>ABA therapy coverage limited or excluded</li>
        <li>Lower session limits than competitors</li>
        <li>Less care coordination support</li>
        <li>May not cover specialized autism treatments</li>
      </ul>
    </div>
  </section>

  <CTABox
    title="Need Coverage for Special Needs Care?"
    description="Finding the right coverage for your family's needs is crucial. Get personalized quotes that account for therapy requirements and specialist access."
    buttonText="Get Family Quotes"
    buttonHref="/insurance-for/families"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Considerations</h2>
    <p class="text-neutral-600 mb-6">Family coverage costs and therapy benefit limits. Actual premiums depend on family size, ages, locations, and medical history.</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">Pre-existing conditions may result in exclusions or loading. Discuss specific needs with insurers before purchasing.</p>
  </section>

  <section id="special-needs-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Special Needs Coverage Considerations</h2>
    
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Autism Spectrum Coverage</h3>
        <p class="text-neutral-700">Coverage for autism varies significantly. ABA (Applied Behavior Analysis) therapy is expensive—intensive programs can cost $30,000-60,000+ annually. Cigna typically offers the highest ABA limits ($15,000/year). Aetna provides good coverage. Allianz has limited autism-specific benefits. If your child needs intensive ABA, verify exact coverage before committing.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Therapy Session Limits</h3>
        <p class="text-neutral-700">All insurers impose session limits on therapies. Cigna typically offers 30-60 sessions per therapy type per year. Aetna offers 25-50. Allianz may be 20-40. For children requiring multiple therapies (PT, OT, speech), these limits add up but may not cover intensive intervention programs. Consider whether limits align with your child's treatment plan.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Pre-existing Condition Challenges</h3>
        <p class="text-neutral-700">If your child has an existing diagnosis (autism, developmental delays, etc.), insurers will likely exclude these conditions or apply significant loading. Disclosure is mandatory—non-disclosure can void coverage. Group plans through employers sometimes offer better terms. Be prepared for detailed medical history requirements.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Specialist Access Abroad</h3>
        <p class="text-neutral-700">Finding qualified pediatric specialists abroad can be challenging. Cigna's global network helps, but availability varies by location. Consider whether your destination has appropriate specialists. Telemedicine can bridge gaps—Aetna's US connections are valuable for maintaining specialist relationships remotely.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">School and Local Services</h3>
        <p class="text-neutral-700">Many international schools offer support services. Some countries provide public therapy services. Insurance can complement rather than replace these resources. Research your destination's special education landscape. Insurance may cover what's not available locally, while local services handle daily needs.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Care Coordination</h3>
        <p class="text-neutral-700">Managing care for a special needs child abroad requires coordination. Cigna and Aetna offer case management services to help navigate care, find specialists, and coordinate between providers. This support is valuable but Allianz offers less in this area. Consider how much support you'll need managing your child's care.</p>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Choose Cigna If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You need comprehensive therapy coverage</li>
          <li>ABA therapy is part of your child's plan</li>
          <li>Care coordination support is important</li>
          <li>You'll relocate between multiple countries</li>
          <li>Budget allows for premium coverage</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Choose Aetna If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>You're a US family wanting US connections</li>
          <li>Telemedicine with US specialists matters</li>
          <li>You have employer-sponsored coverage</li>
          <li>Your child's specialists are US-based</li>
          <li>You want good therapy with US continuity</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Choose Allianz If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Budget is a primary constraint</li>
          <li>Local services supplement insurance</li>
          <li>Therapy needs are moderate</li>
          <li>Your destination has good public services</li>
          <li>You need basic coverage at lower cost</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Will my child's existing diagnosis be covered?</h3>
        <p class="text-neutral-700">Likely not initially. Pre-existing developmental conditions are typically excluded through underwriting. Some group plans through employers offer better coverage. If coverage is offered, expect loading (higher premiums). Always disclose—non-disclosure can void your entire policy.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I use therapists not in the insurance network?</h3>
        <p class="text-neutral-700">Yes, typically through reimbursement rather than direct billing. You pay the therapist and submit claims for reimbursement. Out-of-network reimbursement may be at a lower percentage (e.g., 80% vs 100%). This flexibility is important in locations with limited network providers.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if therapy session limits aren't enough?</h3>
        <p class="text-neutral-700">Once you hit limits, you pay out of pocket or pause therapy. Some families supplement with local services, school programs, or budget for additional sessions. Intensive programs (40 hours/week ABA) will exceed most limits. Plan for this gap in coverage.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I find qualified therapists abroad?</h3>
        <p class="text-neutral-700">Your insurer's case management can help locate providers. International schools often have recommendations. Expat communities and special needs parent groups share resources. Telemedicine can supplement local care. Research your destination thoroughly before relocating.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Does coverage include assistive devices and equipment?</h3>
        <p class="text-neutral-700">Coverage varies. Basic equipment (walkers, wheelchairs) is often covered. Communication devices may be included. Advanced technology or specialized equipment may have limits or require pre-approval. Check specific coverage for any equipment your child uses.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about coverage during home leave or vacation?</h3>
        <p class="text-neutral-700">International plans typically include home country coverage. You can continue therapy during visits home, subject to session limits. This is valuable for maintaining relationships with home-country specialists or accessing services not available abroad.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 mb-12">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Special needs coverage is complex and highly individual. This comparison provides general guidance only. Coverage for specific conditions, therapies, and treatments varies by plan, location, and individual underwriting. Consult directly with insurers about your child's specific needs before purchasing coverage. Pre-existing conditions may be excluded or subject to waiting periods.
    </p>
  </div>
</PageShell>
