---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Bermuda Work from Bermuda Certificate (2025)";
const description = "Compare top health insurance options for Bermuda's Work from Bermuda Certificate. Expert analysis of Cigna Global, Bupa Global, and local Bermuda insurance for remote workers.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "bupa-global", title: "Bupa Global" },
  { id: "local-bermuda", title: "Local Bermuda" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "local", header: "Local Bermuda" },
];

const comparisonRows = [
  { feature: "WFB Certificate Acceptance", cigna: "✓ Accepted", bupa: "✓ Accepted", local: "✓ Accepted" },
  { feature: "Bermuda Network", cigna: "King Edward VII", bupa: "King Edward VII", local: "Full local network" },
  { feature: "US Evacuation", cigna: "✓ Unlimited", bupa: "✓ Unlimited", local: "Varies" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", bupa: "Moratorium option", local: "Case-by-case" },
  { feature: "International Coverage", cigna: "Worldwide", bupa: "Worldwide", local: "Bermuda focused" },
  { feature: "Monthly Cost (35yo)", cigna: "$400-600", bupa: "$450-680", local: "$300-500" },
  { feature: "Annual Maximum", cigna: "Unlimited", bupa: "Unlimited", local: "Varies widely" },
  { feature: "Best For", cigna: "Comprehensive protection", bupa: "Premium coverage", local: "Long-term residents" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "local", header: "Local Bermuda" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", bupa: "100% covered", local: "Network hospitals" },
  { coverage: "Outpatient Care", cigna: "100% covered", bupa: "100% covered", local: "Often included" },
  { coverage: "US Medical Evacuation", cigna: "Unlimited (critical)", bupa: "Unlimited (critical)", local: "May have limits" },
  { coverage: "US Hospital Access", cigna: "✓ Full network", bupa: "✓ Full network", local: "Limited/referral" },
  { coverage: "Prescription Drugs", cigna: "100% covered", bupa: "100% covered", local: "Included" },
  { coverage: "Dental", cigna: "Optional", bupa: "Optional", local: "Often included" },
  { coverage: "Mental Health", cigna: "Full coverage", bupa: "Full coverage", local: "Limited" },
  { coverage: "Maternity", cigna: "Optional add-on", bupa: "Optional add-on", local: "Usually included" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "local", header: "Local Bermuda" },
];

const pricingRows = [
  { age: "25-30", cigna: "$300-450/month", safetywing: "$350-520/month", local: "$220-380/month" },
  { age: "30-35", cigna: "$380-580/month", safetywing: "$420-650/month", local: "$280-480/month" },
  { age: "40-45", cigna: "$540-820/month", safetywing: "$600-920/month", local: "$400-680/month" },
  { age: "50-55", cigna: "$780-1,200/month", safetywing: "$880-1,350/month", local: "$580-980/month" },
];

const networkColumns = [
  { key: "location", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "bupa", header: "Bupa Global" },
  { key: "local", header: "Local Bermuda" },
];

const networkRows = [
  { location: "Bermuda (King Edward VII)", cigna: "Direct billing", bupa: "Direct billing", local: "Full access" },
  { location: "Bermuda Private Clinics", cigna: "Good coverage", bupa: "Good coverage", local: "Full network" },
  { location: "US East Coast (Evacuation)", cigna: "Mass General, Johns Hopkins", bupa: "Major US hospitals", local: "Referral basis" },
  { location: "International", cigna: "Worldwide", bupa: "Worldwide", local: "Limited" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Bermuda's Work from Bermuda Certificate"
    heroImage="/images/countries/bermuda-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Bermuda Work from Bermuda Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Bermuda's Work from Bermuda Certificate allows remote workers to live in this British Overseas Territory for up to one year. Known for pink sand beaches, no income tax, and proximity to the US East Coast (90-minute flight to NYC), Bermuda attracts affluent digital nomads.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for certificate application</li>
          <li>• Must cover medical treatment in Bermuda</li>
          <li>• US medical evacuation coverage strongly recommended</li>
          <li>• International insurance accepted</li>
          <li>• No specific minimum coverage stated</li>
          <li>• Certificate valid for 1 year (renewable)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Bermuda has one main hospital—King Edward VII Memorial Hospital. It provides good general care but has limited specialty services. For complex cases, patients are evacuated to US East Coast hospitals (Boston, NYC, Johns Hopkins). Medical evacuation coverage is essential, not optional.
      </p>

      <p class="text-neutral-700">
        Bermuda is expensive in general, and healthcare is no exception. Without insurance, even routine care costs significantly more than most locations. Comprehensive coverage is strongly recommended.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Work from Bermuda</h2>

      <p class="text-neutral-700 mb-6">
        Given Bermuda's limited healthcare infrastructure, comprehensive coverage with US evacuation is recommended:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global is ideal for Bermuda with its strong US network and unlimited medical evacuation. Their coverage extends seamlessly from Bermuda to top US hospitals.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Unlimited US medical evacuation</li>
            <li>• Access to top US hospitals</li>
            <li>• Direct billing in Bermuda</li>
            <li>• Worldwide coverage</li>
            <li>• Pre-existing condition options</li>
            <li>• 24/7 English support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Expensive (but Bermuda is expensive)</li>
            <li>• May require US address for some plans</li>
            <li>• Deductibles can be significant</li>
            <li>• Premium pricing matches location</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive coverage with US hospital access for Bermuda."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Bupa Global</h2>

      <p class="text-neutral-700 mb-4">
        Bupa Global offers premium international coverage with excellent Americas networks. Their Executive and Prestige plans provide VIP access to top US hospitals—valuable for Bermuda's evacuation needs.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Premium US hospital access</li>
            <li>• Unlimited evacuation coverage</li>
            <li>• Executive health checkups</li>
            <li>• Second opinion services</li>
            <li>• Mental health coverage</li>
            <li>• VIP coordination services</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Premium pricing</li>
            <li>• Complex plan options</li>
            <li>• May be more than needed</li>
            <li>• Annual commitment often required</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Bupa Global Quote"
        description="Premium coverage with VIP US hospital access."
        buttonText="Get Quote"
        buttonHref="/go/bupa"
      />
    </section>

    <section id="local-bermuda" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Local Bermuda Insurance</h2>

      <p class="text-neutral-700 mb-4">
        Local Bermuda insurers (BF&M, Colonial, Argus) offer plans designed for the local market. These often include maternity and dental but may have limited US evacuation coverage.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Designed for Bermuda healthcare</li>
            <li>• Full local network access</li>
            <li>• Often includes dental</li>
            <li>• Maternity usually included</li>
            <li>• Local claims processing</li>
            <li>• Lower premiums than international</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• US evacuation may be limited</li>
            <li>• Coverage caps common</li>
            <li>• Limited international coverage</li>
            <li>• Pre-existing condition exclusions</li>
            <li>• Not portable if you leave</li>
          </ul>
        </div>
      </div>

      <div class="bg-neutral-50 p-4 rounded-lg">
        <p class="text-neutral-700 text-sm">
          <strong>Local insurers:</strong> BF&M (Bermuda's largest), Colonial Insurance, Argus. These work well for long-term residents but short-term nomads may prefer international coverage for portability and guaranteed US evacuation.
        </p>
      </div>
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares. US evacuation capability is critical for Bermuda:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        For Bermuda, the main insurance value is US evacuation and hospital access. King Edward VII handles routine care, but anything complex requires US transfer. Ensure your policy has robust evacuation coverage.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Insurance in Bermuda is expensive, reflecting the island's high cost of living:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Bermuda attracts affluent nomads who can afford comprehensive coverage. Don't skimp on insurance here—healthcare costs without coverage can be devastating.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Bermuda and US</h2>

      <p class="text-neutral-700 mb-6">
        Bermuda has one hospital. US evacuation options are critical:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        King Edward VII is Bermuda's only hospital. It handles general care well, but cardiac surgery, cancer treatment, and complex procedures require US evacuation. Boston (2-hour flight) and NYC (90 minutes) are typical destinations.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Finance Professional in Hamilton</h3>
          <p class="text-neutral-600 mb-3">35-year-old investment banker, high income, healthy, working remotely.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Bupa Global</p>
          <p class="text-neutral-600 text-sm">With high income (Bermuda attracts finance professionals), comprehensive coverage makes sense. Cigna or Bupa provide seamless US hospital access and unlimited evacuation. Worth the premium for your financial profile.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Entrepreneur with Family</h3>
          <p class="text-neutral-600 mb-3">42-year-old with spouse and child, relocating to Bermuda.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global family plan</p>
          <p class="text-neutral-600 text-sm">Families need reliable pediatric care. Bermuda's pediatric services are limited. Cigna's family plan ensures your child has access to top US children's hospitals if needed. Non-negotiable for families.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Retiree with Health Conditions</h3>
          <p class="text-neutral-600 mb-3">58-year-old retiree with cardiac history, attracted by Bermuda's tax benefits.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global with moratorium or Bupa Global</p>
          <p class="text-neutral-600 text-sm">Cardiac conditions in Bermuda require US evacuation capability. With your history, unlimited evacuation isn't optional—it's essential. Both Cigna and Bupa offer pre-existing condition coverage after waiting periods.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Young Tech Worker</h3>
          <p class="text-neutral-600 mb-3">28-year-old software developer, healthy, trying Bermuda for a year.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global (lower tier) or local Bermuda</p>
          <p class="text-neutral-600 text-sm">Young and healthy, you're lower risk. Cigna's lower-tier plans still provide US evacuation at reduced cost. Local Bermuda insurance is an option but verify US evacuation coverage is adequate.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Long-term Settlement (2+ Years)</h3>
          <p class="text-neutral-600 mb-3">40-year-old planning multi-year Bermuda residence.</p>
          <p class="text-amber-700 font-medium">Recommendation: Local Bermuda insurance + US evacuation rider</p>
          <p class="text-neutral-600 text-sm">For long-term settlement, local insurance (BF&M, Colonial) may offer better value. Ensure the plan includes adequate US evacuation coverage. You can always supplement with a standalone evacuation policy.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For Bermuda, <strong>US evacuation coverage is non-negotiable</strong>. The island has one hospital and limited specialty services. <strong>Cigna Global</strong> and <strong>Bupa Global</strong> provide the comprehensive US access you need. <strong>Local insurance</strong> can work for long-term residents but verify evacuation coverage carefully.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want guaranteed US access</li>
            <li>• Have health conditions</li>
            <li>• Family with children</li>
            <li>• Value unlimited evacuation</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Bupa Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want VIP hospital access</li>
            <li>• Value executive health checks</li>
            <li>• Prefer premium services</li>
            <li>• Need second opinion service</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Local Insurance If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Long-term settlement planned</li>
            <li>• Young and healthy</li>
            <li>• Verify evacuation coverage</li>
            <li>• Want dental/maternity included</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Why is US evacuation so important for Bermuda?</h3>
          <p class="text-neutral-600">Bermuda has one hospital (King Edward VII) with limited specialty services. For cardiac surgery, cancer treatment, complex trauma, neurosurgery, and many other conditions, patients must be evacuated to US hospitals. Boston is 2 hours away; NYC is 90 minutes. Without insurance, evacuation costs $50,000-100,000+.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing adequate for Bermuda?</h3>
          <p class="text-neutral-600">SafetyWing's $100K evacuation limit may be insufficient for complex US medical evacuations. Given Bermuda's limited healthcare and the potential need for US hospital care (which can cost hundreds of thousands), SafetyWing is riskier here than in most destinations. Consider comprehensive coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How expensive is healthcare in Bermuda?</h3>
          <p class="text-neutral-600">Very expensive. GP visits cost $150-200+. Hospital stays are $1,000+/night. Even routine procedures are costly. And if you need US evacuation and treatment, costs escalate dramatically. Insurance is essential in Bermuda—going uninsured is financially dangerous.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use US insurance in Bermuda?</h3>
          <p class="text-neutral-600">Some US plans may cover Bermuda as "international" coverage, but verify carefully. Many US plans have limited out-of-network coverage internationally. International insurers (Cigna Global, Bupa Global) are designed for this scenario and provide clearer coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about routine care in Bermuda?</h3>
          <p class="text-neutral-600">Routine care (GP visits, minor illness, basic procedures) is handled well at King Edward VII and private clinics. The hospital is modern and English-speaking. Issues arise with specialty care—oncology, cardiology, complex surgery—which requires US referral.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is the Work from Bermuda certificate renewable?</h3>
          <p class="text-neutral-600">Yes, the certificate is valid for one year and renewable. Many remote workers extend their stay. Maintain continuous insurance coverage for renewal. If you're settling long-term, consider transitioning to local insurance with adequate evacuation coverage.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Bermuda immigration requirements can change. Verify current Work from Bermuda Certificate requirements with the Bermuda government. Confirm policy coverage for US evacuation directly with insurers. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
