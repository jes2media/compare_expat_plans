---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Cyprus Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Cyprus Digital Nomad Visa. Expert analysis of Cigna Global, SafetyWing, and Allianz Care for remote workers in Limassol and Nicosia.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "allianz", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "Cyprus DNV Acceptance", cigna: "✓ Accepted", safetywing: "✓ Accepted", allianz: "✓ Accepted" },
  { feature: "Cyprus Network", cigna: "Good (private hospitals)", safetywing: "Reimbursement", allianz: "Good coverage" },
  { feature: "EU/Schengen Coverage", cigna: "✓ Worldwide", safetywing: "✓ Outside home country", allianz: "✓ Worldwide" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Not covered", allianz: "Moratorium option" },
  { feature: "Monthly Cost (35yo)", cigna: "$320-480", safetywing: "$69", allianz: "$280-420" },
  { feature: "Annual Maximum", cigna: "Unlimited", safetywing: "$250,000", allianz: "€1-2 million" },
  { feature: "Best For", cigna: "Comprehensive needs", safetywing: "Budget nomads", allianz: "European focus" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "$250K limit", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100K limit", allianz: "Included" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", allianz: "Optional" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", allianz: "Covered" },
  { coverage: "Maternity", cigna: "Optional add-on", safetywing: "Limited", allianz: "Optional add-on" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "25-30", cigna: "$240-360/month", safetywing: "$69/month", allianz: "$210-320/month" },
  { age: "30-35", cigna: "$300-450/month", safetywing: "$69/month", allianz: "$260-400/month" },
  { age: "40-45", cigna: "$430-650/month", safetywing: "$99/month", allianz: "$380-570/month" },
  { age: "50-55", cigna: "$620-940/month", safetywing: "$148/month", allianz: "$550-820/month" },
];

const networkColumns = [
  { key: "location", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { location: "Limassol Private", cigna: "Ygia Polyclinic, Mediterranean", safetywing: "Reimbursement", allianz: "Good coverage" },
  { location: "Nicosia Private", cigna: "Apollonion, Aretaeio", safetywing: "Reimbursement", allianz: "Good coverage" },
  { location: "Public Hospitals", cigna: "Reimbursement", safetywing: "Reimbursement", allianz: "Reimbursement" },
  { location: "Greece (nearby)", cigna: "Full coverage", safetywing: "Covered", allianz: "Full coverage" },
  { location: "EU/Schengen", cigna: "Worldwide", safetywing: "Covered", allianz: "Worldwide" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Cyprus Digital Nomad Visa"
    heroImage="/images/countries/cyprus-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cyprus Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Cyprus offers a Digital Nomad Visa allowing remote workers to live in this Mediterranean EU island for up to one year (renewable for 2 more years). Popular among digital nomads for its warm climate, low taxes, English proficiency, and EU membership.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for visa application</li>
          <li>• Must cover medical treatment in Cyprus</li>
          <li>• Policy must cover entire stay duration</li>
          <li>• International insurance accepted</li>
          <li>• Income requirement: €3,500/month (individual)</li>
          <li>• Cyprus is EU but NOT in Schengen zone</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Cyprus has good private healthcare, especially in Limassol and Nicosia. The island has modern hospitals and English-speaking medical professionals (British influence). For complex cases, Greece is nearby.
      </p>

      <p class="text-neutral-700">
        Note: Cyprus is in the EU but not the Schengen zone. Your insurance should cover Cyprus specifically, plus any EU/Schengen travel you plan. The visa allows stays up to 3 years total with renewals.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Cyprus DNV</h2>

      <p class="text-neutral-700 mb-6">
        Cyprus accepts various international insurers. Here are the top options:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global provides comprehensive international coverage with good networks in Cyprus. Their worldwide coverage works well for nomads who travel frequently beyond Cyprus.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Worldwide coverage including Cyprus</li>
            <li>• Direct billing at Cyprus private hospitals</li>
            <li>• Greece hospital access</li>
            <li>• Pre-existing condition options</li>
            <li>• 24/7 English support</li>
            <li>• Comprehensive outpatient coverage</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Higher cost than SafetyWing</li>
            <li>• May be more than needed for healthy nomads</li>
            <li>• Cyprus private care is reasonably affordable</li>
            <li>• Deductibles can be significant</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive global coverage for Cyprus digital nomads."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing Nomad Insurance</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing offers affordable coverage that meets Cyprus visa requirements. At $69/month, it's popular among budget-conscious nomads attracted to Cyprus's lifestyle.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable ($69/month under 40)</li>
            <li>• Accepted for Cyprus visa</li>
            <li>• Covers Cyprus + EU travel</li>
            <li>• Medical evacuation included</li>
            <li>• Month-to-month flexibility</li>
            <li>• Simple claims process</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No direct billing—pay and claim</li>
            <li>• Pre-existing conditions not covered</li>
            <li>• $250 deductible per incident</li>
            <li>• Limited outpatient coverage</li>
            <li>• $250K coverage limit</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget nomad insurance starting at $69/month."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="allianz" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers European-focused international coverage with good Mediterranean networks. Their plans work well for nomads spending time across southern Europe.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong European/Mediterranean network</li>
            <li>• Direct billing available</li>
            <li>• Greece and EU coverage</li>
            <li>• Pre-existing condition options</li>
            <li>• European-based support</li>
            <li>• Multiple plan tiers</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Similar pricing to Cigna</li>
            <li>• Claims processing time</li>
            <li>• Plan complexity</li>
            <li>• Less competitive outside Europe</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="European-focused coverage with Mediterranean networks."
        buttonText="Get Quote"
        buttonHref="/go/allianz-care"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares across the main options:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        All three options work for Cyprus visa requirements. The difference is in coverage depth and pricing. SafetyWing covers basics affordably; Cigna and Allianz provide comprehensive protection.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        SafetyWing is dramatically cheaper than comprehensive options:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Given Cyprus's €3,500/month income requirement, nomads who qualify likely have budget flexibility. Choose based on health needs and risk tolerance.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Cyprus</h2>

      <p class="text-neutral-700 mb-6">
        Cyprus has good private hospitals in main cities. Network access comparison:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Limassol and Nicosia have excellent private hospitals. English is widely spoken due to British influence. For highly specialized care, Athens is a short flight away.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Remote Worker in Limassol</h3>
          <p class="text-neutral-600 mb-3">30-year-old fintech professional, healthy, enjoying Cyprus's beach lifestyle.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">SafetyWing meets visa requirements at $69/month. Cyprus private healthcare is affordable for routine care. Save the premium difference for enjoying the Mediterranean lifestyle.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Crypto/Finance Professional</h3>
          <p class="text-neutral-600 mb-3">35-year-old attracted by Cyprus's crypto-friendly regulations, higher income.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">With higher income (Cyprus attracts finance professionals), comprehensive coverage makes sense. Cigna provides premium protection matching your financial profile. Direct billing at private hospitals adds convenience.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Family Relocating</h3>
          <p class="text-neutral-600 mb-3">40-year-old couple with children, attracted by Cyprus's international schools.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Allianz Care family plan</p>
          <p class="text-neutral-600 text-sm">Families need reliable pediatric coverage. Cyprus has good children's hospitals. Cigna or Allianz family plans provide comprehensive coverage for the whole family with direct billing convenience.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Mediterranean Hopper</h3>
          <p class="text-neutral-600 mb-3">32-year-old using Cyprus as base for Greece, Malta, Croatia exploration.</p>
          <p class="text-green-700 font-medium">Recommendation: Allianz Care</p>
          <p class="text-neutral-600 text-sm">Allianz's European/Mediterranean network shines for regional travelers. Good coverage throughout southern Europe, direct billing in major Mediterranean cities. Perfect for island-hopping lifestyle.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Long-term Settlement (3 Years)</h3>
          <p class="text-neutral-600 mb-3">45-year-old planning full 3-year Cyprus stay, considering permanent relocation.</p>
          <p class="text-amber-700 font-medium">Recommendation: Cigna Global or local Cyprus insurance</p>
          <p class="text-neutral-600 text-sm">For long-term settlement, consider local Cyprus private insurance (GESY-supplemental plans). Cigna provides stability and international coverage. After establishing residency, explore local options that may offer better long-term value.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most Cyprus digital nomads, <strong>SafetyWing</strong> is the practical choice—affordable, meets requirements, and covers regional travel. <strong>Cigna Global</strong> or <strong>Allianz Care</strong> are worth the extra cost for families, finance professionals, or anyone wanting comprehensive EU coverage.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Young and healthy</li>
            <li>• Budget-conscious</li>
            <li>• Typical nomad lifestyle</li>
            <li>• No pre-existing conditions</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Family with children</li>
            <li>• Higher income professional</li>
            <li>• Pre-existing conditions</li>
            <li>• Want comprehensive coverage</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz Care If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Mediterranean exploration</li>
            <li>• Prefer European insurer</li>
            <li>• Strong EU network priority</li>
            <li>• European-based support</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is Cyprus in the Schengen zone?</h3>
          <p class="text-neutral-600">No. Cyprus is an EU member but not in the Schengen zone. This means your Cyprus visa doesn't automatically allow Schengen travel, and you may need separate Schengen arrangements. However, most international insurance covers both Cyprus and Schengen countries.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How is Cyprus's healthcare system?</h3>
          <p class="text-neutral-600">Good, especially private care. Cyprus has modern private hospitals in Limassol, Nicosia, and Paphos. GESY (the national health system) launched in 2019 but most expats use private healthcare. English is widely spoken due to British colonial history. Quality is similar to southern European standards.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can digital nomads access GESY (public healthcare)?</h3>
          <p class="text-neutral-600">Generally no. GESY is for Cyprus residents with specific status. Digital nomad visa holders typically don't qualify and must maintain private insurance. However, emergency care is available to everyone. Confirm your specific situation with Cyprus authorities.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about the divided Cyprus situation?</h3>
          <p class="text-neutral-600">The Republic of Cyprus (southern part) is where the digital nomad visa applies. Northern Cyprus is a separate territory. Your insurance should cover the Republic of Cyprus. If you visit the North, coverage may not apply—check your policy. Most digital nomads stay in the Republic (Limassol, Nicosia, Paphos).</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing accepted for the Cyprus visa?</h3>
          <p class="text-neutral-600">Yes. Many nomads successfully use SafetyWing for Cyprus digital nomad visa applications. The $250,000 coverage is comprehensive. Request a visa letter from SafetyWing if needed for your application.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How affordable is private healthcare in Cyprus?</h3>
          <p class="text-neutral-600">Reasonably affordable by European standards. A GP visit costs €40-60, specialist consultations €60-100. Private hospital stays are €200-400/night. Dental and optical care are affordable. With insurance, you'll have minimal out-of-pocket costs.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Cyprus visa requirements can change. Verify current digital nomad visa requirements with the Cyprus Civil Registry and Migration Department. Confirm policy details and visa compliance directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
