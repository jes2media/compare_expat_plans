---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for France Long-Stay Visa (2025)";
const description = "Compare top health insurance options for France's long-stay visa (VLS-TS). Expert analysis of Cigna Global, April International, and Allianz Care for expats moving to France.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "april-international", title: "April International" },
  { id: "allianz-care", title: "Allianz Care" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "april", header: "April International" },
  { key: "allianz", header: "Allianz Care" },
];

const comparisonRows = [
  { feature: "France Visa Acceptance", cigna: "✓ Widely accepted", april: "✓ French company, preferred", allianz: "✓ Widely accepted" },
  { feature: "French Hospital Network", cigna: "Strong (direct billing)", april: "Excellent (local expertise)", allianz: "Strong (direct billing)" },
  { feature: "Repatriation Coverage", cigna: "✓ Included", april: "✓ Included", allianz: "✓ Included" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", april: "Case-by-case review", allianz: "Moratorium option" },
  { feature: "Maternity Coverage", cigna: "Optional add-on", april: "10-month wait", allianz: "Optional add-on" },
  { feature: "Mental Health", cigna: "Full coverage", april: "Limited outpatient", allianz: "Full coverage" },
  { feature: "Annual Maximum", cigna: "€1M - Unlimited", april: "€1M - €2M", allianz: "€1M - Unlimited" },
  { feature: "Best For", cigna: "Global coverage needs", april: "France-focused expats", allianz: "Flexible plan design" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "april", header: "April International" },
  { key: "allianz", header: "Allianz Care" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", april: "100% covered", allianz: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", april: "80-100% covered", allianz: "100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", april: "€500,000", allianz: "Unlimited" },
  { coverage: "Prescription Drugs", cigna: "100% covered", april: "80% outpatient", allianz: "100% covered" },
  { coverage: "Dental", cigna: "Optional", april: "Basic included", allianz: "Optional" },
  { coverage: "Vision", cigna: "Optional", april: "Basic included", allianz: "Optional" },
  { coverage: "Wellness/Preventive", cigna: "Annual checkup", april: "Limited", allianz: "Annual checkup" },
  { coverage: "COVID-19", cigna: "Full coverage", april: "Full coverage", allianz: "Full coverage" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "april", header: "April International" },
  { key: "allianz", header: "Allianz Care" },
];

const pricingRows = [
  { age: "30-35", cigna: "€180-280/month", april: "€120-180/month", allianz: "€170-260/month" },
  { age: "40-45", cigna: "€250-380/month", april: "€160-240/month", allianz: "€240-360/month" },
  { age: "50-55", cigna: "€380-550/month", april: "€240-350/month", allianz: "€360-520/month" },
  { age: "60-65", cigna: "€550-800/month", april: "€380-550/month", allianz: "€520-750/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "april", header: "April International" },
  { key: "allianz", header: "Allianz Care" },
];

const networkRows = [
  { region: "Paris/Île-de-France", cigna: "Excellent - 50+ hospitals", april: "Excellent - 60+ hospitals", allianz: "Excellent - 45+ hospitals" },
  { region: "Lyon/Rhône-Alpes", cigna: "Strong - 15+ hospitals", april: "Excellent - 20+ hospitals", allianz: "Strong - 15+ hospitals" },
  { region: "Marseille/PACA", cigna: "Good - 12+ hospitals", april: "Excellent - 18+ hospitals", allianz: "Good - 12+ hospitals" },
  { region: "Bordeaux/Nouvelle-Aquitaine", cigna: "Good - 8+ facilities", april: "Strong - 12+ facilities", allianz: "Good - 8+ facilities" },
  { region: "Nice/Côte d'Azur", cigna: "Strong - 10+ facilities", april: "Excellent - 15+ facilities", allianz: "Strong - 10+ facilities" },
  { region: "Rest of France", cigna: "Good - reimbursement model", april: "Strong - direct billing common", allianz: "Good - reimbursement model" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for France's long-stay visa (VLS-TS)"
    heroImage="/images/countries/france-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">France Long-Stay Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        France's long-stay visa (Visa de Long Séjour valant Titre de Séjour, or VLS-TS) requires proof of health insurance for the duration of your stay. This applies to all non-EU citizens, whether you're moving for work, retirement, study, or family reunification.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Coverage must be valid for the entire visa duration</li>
          <li>• Minimum €30,000 medical coverage required</li>
          <li>• Must include hospitalization and repatriation</li>
          <li>• French consulates prefer established international insurers</li>
          <li>• After 3 months of residence, you may qualify for French social security (PUMA)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        France has a unique healthcare system. Once you're a legal resident for more than 3 months and meet income/contribution requirements, you become eligible for Protection Universelle Maladie (PUMA)—the French public healthcare system. However, PUMA covers only about 70% of costs, so most expats maintain private "top-up" insurance (mutuelle) even after enrollment.
      </p>

      <p class="text-neutral-700">
        For visa approval, you need comprehensive private coverage. After settling in France, you can transition to PUMA plus a mutuelle, or continue with international insurance for more flexibility.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Top 3 Insurers for France</h2>

      <p class="text-neutral-700 mb-6">
        We've analyzed the three best insurance options for France long-stay visa applicants. April International stands out as a French company with deep local expertise, while Cigna and Allianz offer broader global coverage.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global is a top-tier international health insurer with excellent coverage in France and worldwide. Their modular plan structure lets you build coverage that matches your needs, from basic inpatient to comprehensive wellness plans.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Modular plans—pay only for what you need</li>
            <li>• Strong direct billing network in France</li>
            <li>• Excellent mental health coverage</li>
            <li>• Global coverage if you travel frequently</li>
            <li>• 24/7 multilingual support including French</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Higher premiums than France-specific options</li>
            <li>• Best value requires annual commitment</li>
            <li>• Outpatient dental/vision costs extra</li>
            <li>• Some administrative processes in English</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Customize your France coverage with Cigna's modular plans."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="april-international" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">April International</h2>

      <p class="text-neutral-700 mb-4">
        April International is a French insurance company specializing in expat coverage. Being French, they have unmatched local expertise and are particularly well-regarded by French consulates. Their network in France is extensive, and their plans are designed with French healthcare norms in mind.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• French company—consulates know and trust them</li>
            <li>• Best direct billing network in France</li>
            <li>• More affordable than global competitors</li>
            <li>• Basic dental/vision included in most plans</li>
            <li>• French-speaking support as standard</li>
            <li>• Easy transition to/from French public system</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Coverage outside Europe more limited</li>
            <li>• Lower annual maximums than competitors</li>
            <li>• Mental health coverage more restricted</li>
            <li>• Less flexibility in plan customization</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an April International Quote"
        description="French expertise for expats—preferred by consulates."
        buttonText="Get Quote"
        buttonHref="/go/april"
      />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care offers flexible international health insurance with strong coverage in France. Their plans range from essential coverage to comprehensive options, and they're well-established with French healthcare providers.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Flexible plan tiers from budget to premium</li>
            <li>• Good direct billing relationships in France</li>
            <li>• Comprehensive wellness and preventive care</li>
            <li>• Strong chronic condition management</li>
            <li>• Multiple deductible options for premium savings</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Less French-specific expertise than April</li>
            <li>• Some plans exclude France for cost savings</li>
            <li>• Dental/vision are optional add-ons</li>
            <li>• Claims processing can take longer</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="Flexible international coverage with strong France network."
        buttonText="Get Quote"
        buttonHref="/go/allianz-care"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        All three insurers meet France's visa requirements. Here's how their coverage compares across key categories:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Coverage details vary by plan tier. April's basic dental/vision inclusion can be valuable for routine care, though the annual limits are modest.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Premiums vary based on age, coverage level, and deductible. These ranges represent mid-tier plans with moderate deductibles:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        April International typically offers the most competitive pricing for France-focused coverage. Cigna and Allianz cost more but provide stronger global coverage and higher annual limits.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in France</h2>

      <p class="text-neutral-700 mb-6">
        France has world-class healthcare facilities. Here's how each insurer's network coverage compares by region:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        April's French origins give them an edge in direct billing arrangements, particularly outside major cities. All three work well in Paris and other major metropolitan areas.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Professional Moving to Paris</h3>
          <p class="text-neutral-600 mb-3">35-year-old relocating for work, healthy, travels frequently within Europe.</p>
          <p class="text-green-700 font-medium">Recommendation: April International</p>
          <p class="text-neutral-600 text-sm">Best value for France-focused coverage with included dental/vision. European coverage handles travel needs.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Family with Children</h3>
          <p class="text-neutral-600 mb-3">Couple in their 40s with two children, relocating to Lyon for 3+ years.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Allianz Care</p>
          <p class="text-neutral-600 text-sm">Higher coverage limits and comprehensive family plans. Better pediatric and maternity coverage if planning to expand family.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Retiree in Provence</h3>
          <p class="text-neutral-600 mb-3">62-year-old retiree with managed high blood pressure, planning permanent relocation.</p>
          <p class="text-amber-700 font-medium">Recommendation: April International or Allianz Care</p>
          <p class="text-neutral-600 text-sm">April for cost-effectiveness; Allianz for more comprehensive chronic condition management. Both handle pre-existing conditions reasonably.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Digital Nomad with Global Travel</h3>
          <p class="text-neutral-600 mb-3">Freelancer using France as a base but spending 4+ months/year outside Europe.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Best worldwide coverage. April's limited coverage outside Europe makes it less suitable for frequent global travelers.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Budget-Conscious Student</h3>
          <p class="text-neutral-600 mb-3">28-year-old pursuing graduate studies in France, needs visa-compliant coverage at lowest cost.</p>
          <p class="text-green-700 font-medium">Recommendation: April International</p>
          <p class="text-neutral-600 text-sm">Most affordable option that meets visa requirements. Consider transitioning to PUMA after 3 months of residence.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most France long-stay visa applicants, <strong>April International</strong> offers the best combination of value, local expertise, and consulate recognition. If you need comprehensive global coverage or have complex health needs, <strong>Cigna Global</strong> or <strong>Allianz Care</strong> provide stronger international networks and higher coverage limits.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose April If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Budget is a priority</li>
            <li>• Staying mainly in France/Europe</li>
            <li>• Want French company familiarity</li>
            <li>• Planning to transition to PUMA</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Traveling globally frequently</li>
            <li>• Want modular plan flexibility</li>
            <li>• Need comprehensive mental health</li>
            <li>• Prefer English-language support</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Have chronic conditions</li>
            <li>• Want flexible deductible options</li>
            <li>• Need strong wellness coverage</li>
            <li>• Value established brand</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Do I need private insurance once I qualify for PUMA?</h3>
          <p class="text-neutral-600">PUMA covers about 70% of medical costs, so most expats maintain a "mutuelle" (top-up insurance) or continue international coverage. Without supplementary insurance, you'll face significant out-of-pocket costs, especially for dental, vision, and specialized care.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Which insurer do French consulates prefer?</h3>
          <p class="text-neutral-600">French consulates generally accept all three insurers. April International, being a French company, may receive slightly more familiarity, but Cigna and Allianz are well-established and widely recognized. Ensure your policy certificate clearly states the coverage duration and minimum amounts.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I switch from international insurance to a French mutuelle?</h3>
          <p class="text-neutral-600">Yes. Once enrolled in PUMA (typically after 3 months of residence), you can cancel international insurance and purchase a French mutuelle. Many expats make this transition to reduce costs, though international insurance offers more flexibility for travel and returning home.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about the French Carte Vitale?</h3>
          <p class="text-neutral-600">The Carte Vitale is France's health insurance card for PUMA enrollees. It takes several months to receive after registering. In the meantime, you'll pay upfront and request reimbursement. International insurance provides coverage during this transition period.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Are pre-existing conditions covered?</h3>
          <p class="text-neutral-600">All three insurers handle pre-existing conditions, typically through moratorium periods (usually 2 years) or medical underwriting. April may be more flexible for common conditions given their focus on the French market. Disclose all conditions accurately to avoid claims issues later.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What if I travel back to my home country regularly?</h3>
          <p class="text-neutral-600">Cigna Global and Allianz Care provide strong worldwide coverage, including in your home country (check specific plan terms). April International has more limited coverage outside Europe, making it less suitable for frequent global travelers.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Insurance requirements and coverage details change regularly. Verify current requirements with the French consulate in your jurisdiction and confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance advice.</p>
    </div>
  </PageShell>
</Layout>
