---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'freelancer-needs', text: 'Freelancer-Specific Needs', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/insurance-for/freelancers', text: 'Freelancer Insurance Guide' },
  { href: '/insurance-for/remote-workers', text: 'Remote Worker Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Monthly Cost (32)', safetywing: '$45', img: '$140-220', allianz: '$200-320' },
  { feature: 'Coverage Limit', safetywing: '$250,000', img: '$1M-5M', allianz: 'Up to €1.5M' },
  { feature: 'Payment Flexibility', safetywing: 'Monthly', img: 'Annual (quarterly avail)', allianz: 'Annual' },
  { feature: 'Routine Care', safetywing: 'Not covered', img: 'Optional', allianz: 'Included' },
  { feature: 'Visa Letters', safetywing: 'Yes', img: 'Yes', allianz: 'Yes' },
  { feature: 'Income Variability', safetywing: 'Perfect fit', img: 'Manageable', allianz: 'Challenging' },
  { feature: 'Cancellation', safetywing: 'Anytime', img: 'Limited', allianz: 'Limited' },
  { feature: 'Target User', safetywing: 'Budget nomads', img: 'Established freelancers', allianz: 'High earners' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'New freelancer (28)', safetywing: '$42/mo', img: '$120-160/mo', allianz: '$180-260/mo' },
  { profile: 'Established (35)', safetywing: '$45/mo', img: '$160-240/mo', allianz: '$240-360/mo' },
  { profile: 'Senior freelancer (45)', safetywing: '$78/mo', img: '$220-340/mo', allianz: '$340-500/mo' },
  { profile: 'Annual total (35)', safetywing: '$540', img: '$1,920-2,880', allianz: '$2,880-4,320' },
];
---

<PageShell
  title="SafetyWing vs IMG vs Allianz for Freelancers | 2025 Comparison"
  description="Compare health insurance for freelancers abroad: SafetyWing's budget flexibility, IMG's mid-tier coverage, and Allianz Care's comprehensive plans. Expert analysis for self-employed expats."
  headline="SafetyWing vs IMG vs Allianz: Insurance for Freelancers"
  subheadline="From feast-or-famine budgets to stable six-figure contracts—find health coverage that fits freelance life abroad."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 mb-3">Best Budget/Flexibility</p>
        <p class="text-neutral-700 text-sm mb-4">Monthly billing, anytime cancellation, $45/month. Perfect for variable income and early-stage freelancers.</p>
        <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 mb-3">Best Mid-Range</p>
        <p class="text-neutral-700 text-sm mb-4">Real insurance with $1M-5M coverage and optional routine care. Sweet spot for established freelancers.</p>
        <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Comprehensive</p>
        <p class="text-neutral-700 text-sm mb-4">Full coverage including routine care for high-earning freelancers who want complete protection.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">$45/Month</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Cancel Anytime</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Freelancer-Built</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing was built by freelancers for freelancers. The monthly billing and anytime cancellation matches the feast-or-famine reality of freelance income—if a client ghosted or you're between projects, you can pause coverage. At $45/month, it's affordable even during slow periods.</p>

    <p class="text-neutral-700 mb-4">Coverage is basic but covers emergencies: hospitalization, surgery, and urgent care up to $250,000. No routine visits or prescriptions, so plan to pay cash for minor healthcare. For healthy freelancers prioritizing flexibility over comprehensiveness, SafetyWing is purpose-built.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Freelancer Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest cost ($45/mo)</li>
          <li>• Monthly flexibility</li>
          <li>• Cancel anytime (no penalty)</li>
          <li>• Matches variable income</li>
          <li>• 5-minute signup</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Limitations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• $250K limit (lower)</li>
          <li>• No routine care</li>
          <li>• Pre-existing excluded</li>
          <li>• Limited US coverage</li>
          <li>• Basic mental health</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Mid-Range</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Real Coverage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Customizable</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global is the upgrade for established freelancers with stable income. Their Global Medical Insurance offers $1M-5M in coverage—real protection for serious medical events. Optional outpatient coverage adds routine visits, prescriptions, and ongoing care.</p>

    <p class="text-neutral-700 mb-4">Annual commitment with some quarterly payment options available. Customizable plans let you balance coverage and cost—higher deductibles lower premiums when cash flow is tight. For freelancers earning $5K+/month consistently, IMG provides meaningful upgrade from SafetyWing.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Freelancer Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• $1M-5M coverage</li>
          <li>• Optional routine care</li>
          <li>• Quarterly payment option</li>
          <li>• Customizable plans</li>
          <li>• Good visa compliance</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Annual commitment</li>
          <li>• Higher premiums</li>
          <li>• Less flexible than SafetyWing</li>
          <li>• Pre-existing limitations</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Routine Included</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">High Earners</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care is for high-earning freelancers who want comprehensive coverage without compromises. Full medical benefits including routine care, preventive screenings, and prescriptions. This is the coverage employees at good companies enjoy—now available to successful independents.</p>

    <p class="text-neutral-700 mb-4">The annual commitment and higher premiums require stable high income ($10K+/month). Less flexibility but complete peace of mind. For freelancers who've made it and want proper health coverage as a business expense, Allianz delivers premium protection.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Freelancer Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Comprehensive coverage</li>
          <li>• Routine care included</li>
          <li>• Preventive screenings</li>
          <li>• Professional-grade benefits</li>
          <li>• Strong visa compliance</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums</li>
          <li>• Annual commitment only</li>
          <li>• Requires stable income</li>
          <li>• Less flexible</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Freelancer Coverage"
    description="Get quotes that match your income level and coverage needs."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Annual cost differences matter for freelance budgeting:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*SafetyWing is month-to-month; IMG/Allianz are annual. Consider insurance as a business expense (often tax-deductible).</p>
  </section>

  <section id="freelancer-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Freelancer-Specific Needs</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Income Considerations</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Under $3K/mo:</strong> SafetyWing only realistic option</li>
          <li>• <strong>$3-6K/mo:</strong> IMG becomes viable</li>
          <li>• <strong>$6-10K/mo:</strong> IMG or Allianz based on needs</li>
          <li>• <strong>$10K+/mo:</strong> Allianz comprehensive makes sense</li>
          <li>• Budget 5-10% of income for health coverage</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Tax Considerations</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Health insurance often tax-deductible</li>
          <li>• Check your tax residency rules</li>
          <li>• May be deductible as business expense</li>
          <li>• Reduces effective cost significantly</li>
          <li>• Consult an international tax advisor</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Freelancer Insurance Strategy</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Starting Out</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• SafetyWing for affordability</li>
            <li>• Build emergency health fund</li>
            <li>• Pay cash for routine care</li>
            <li>• Upgrade as income stabilizes</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Established</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• IMG or Allianz for real coverage</li>
            <li>• Include routine care</li>
            <li>• Consider it business expense</li>
            <li>• Prioritize pre-existing coverage path</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Income is variable or under $5K/month</li>
          <li>• Flexibility is essential</li>
          <li>• You're healthy with no pre-existing conditions</li>
          <li>• Basic emergency coverage is sufficient</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Income is stable at $5K+/month</li>
          <li>• Real coverage limits matter</li>
          <li>• You want routine care options</li>
          <li>• Annual commitment is acceptable</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• You're a high earner ($10K+/month)</li>
          <li>• Comprehensive coverage is important</li>
          <li>• You want routine/preventive included</li>
          <li>• You value premium benefits</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I deduct health insurance from freelance taxes?</h3>
        <p class="text-neutral-700">Often yes, but it depends on your tax residency. In many jurisdictions, self-employed individuals can deduct health insurance premiums as business expenses. This effectively reduces the cost by your marginal tax rate. Consult a tax professional familiar with your situation.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if my income drops and I can't afford premiums?</h3>
        <p class="text-neutral-700">SafetyWing's monthly billing shines here—just cancel and restart when stable. IMG and Allianz annual plans are harder to exit mid-term. Build a 3-month premium reserve when times are good. Some insurers offer hardship provisions, but don't count on them.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do clients ever provide health insurance for freelancers?</h3>
        <p class="text-neutral-700">Rarely, but it happens. Some long-term contracts include health coverage or stipends. Corporate clients may offer benefits to retain key freelancers. Always ask—but don't rely on it. Having your own portable coverage is essential for independence.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Should I maintain coverage during gaps between clients?</h3>
        <p class="text-neutral-700">Yes. Medical emergencies don't wait for contracts. A gap in coverage can also create pre-existing condition issues when you restart. SafetyWing's $45/month is affordable even during slow periods. Think of insurance as overhead like software subscriptions—always on.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage vary by age, location, and specific needs. Freelance tax treatment varies by jurisdiction. Always verify coverage meets your requirements and consult tax professionals for deductibility questions. This comparison is for informational purposes only.</p>
  </div>
</PageShell>
