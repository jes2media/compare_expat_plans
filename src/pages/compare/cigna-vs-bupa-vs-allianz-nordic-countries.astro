---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', title: 'Quick Verdict' },
  { id: 'comparison', title: 'Side-by-Side Comparison' },
  { id: 'cigna', title: 'Cigna Global' },
  { id: 'bupa', title: 'Bupa Global' },
  { id: 'allianz', title: 'Allianz Care' },
  { id: 'pricing', title: 'Pricing Comparison' },
  { id: 'nordic-details', title: 'Nordic Coverage Details' },
  { id: 'best-for', title: 'Best For' },
  { id: 'faqs', title: 'FAQs' },
];

const relatedLinks = [
  { href: '/providers/cigna-global', title: 'Cigna Global Full Review' },
  { href: '/providers/bupa-global', title: 'Bupa Global Full Review' },
  { href: '/providers/allianz-care', title: 'Allianz Care Full Review' },
  { href: '/countries/sweden/insurance', title: 'Sweden Expat Insurance' },
  { href: '/countries/denmark/insurance', title: 'Denmark Expat Insurance' },
];

const mainComparisonColumns = ['Feature', 'Cigna Global', 'Bupa Global', 'Allianz Care'];
const mainComparisonRows = [
  ['Nordic Network', 'Strong—all countries', 'Strong—all countries', 'Strong—all countries'],
  ['Public System Integration', 'Works alongside', 'Complements public', 'Hybrid approach'],
  ['Private Hospital Access', 'Excellent', 'Excellent', 'Very good'],
  ['Waiting Time Bypass', 'Yes—private care', 'Yes—private care', 'Yes—private care'],
  ['Nordic Language Support', 'English primary', 'English + some Nordic', 'Multilingual'],
  ['Schengen Compliance', 'Yes', 'Yes', 'Yes'],
  ['Home Country Coverage', 'Configurable', 'Optional', 'Configurable'],
  ['Telemedicine', '24/7 included', '24/7 included', '24/7 included'],
  ['Mental Health', 'Comprehensive', 'Good coverage', 'Plan dependent'],
];

const pricingColumns = ['Coverage Level', 'Cigna Global', 'Bupa Global', 'Allianz Care'];
const pricingRows = [
  ['Core/Silver (inpatient)', '$3,200-4,500/yr', '$3,000-4,200/yr', '$2,800-4,000/yr'],
  ['Comprehensive/Gold', '$5,500-7,500/yr', '$5,200-7,000/yr', '$5,000-6,800/yr'],
  ['Premium/Platinum', '$7,500-10,000/yr', '$7,200-9,500/yr', '$7,000-9,200/yr'],
  ['Family coverage', '+80-100%', '+75-95%', '+70-90%'],
  ['High deductible option', '$2,000-2,500/yr', '$1,800-2,400/yr', '$1,600-2,200/yr'],
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz: Nordic Countries Insurance Comparison 2025"
  description="Compare Cigna, Bupa, and Allianz for expats in Sweden, Norway, Denmark, Finland, and Iceland. Private healthcare options and public system integration."
  headline="Cigna vs Bupa vs Allianz"
  subheadline="Which Provider is Best for the Nordic Countries?"
  heroImage="/images/compare/nordic-countries-hero.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Cigna Global</h3>
        <p class="text-neutral-700 mb-4">Best for comprehensive coverage with strong mental health benefits and seamless multi-country mobility across and beyond the Nordic region.</p>
        <p class="text-sm font-medium text-primary-700">From $3,200/year</p>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Bupa Global</h3>
        <p class="text-neutral-700 mb-4">Best for accessing premium private healthcare facilities with excellent service quality and established Nordic hospital partnerships.</p>
        <p class="text-sm font-medium text-purple-700">From $3,000/year</p>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Allianz Care</h3>
        <p class="text-neutral-700 mb-4">Best value option with flexible plan configurations and good coverage that works well alongside Nordic public healthcare systems.</p>
        <p class="text-sm font-medium text-green-700">From $2,800/year</p>
      </div>
    </div>
  </section>

  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <div class="bg-primary-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-primary-800 mb-4">Cigna Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Cigna Global offers robust coverage throughout the Nordic region with particular strength in comprehensive benefits and mental health support. Their global network provides flexibility for expats who travel frequently.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Nordic Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Strong network across all Nordic countries</li>
        <li>Excellent mental health coverage—important given dark winters</li>
        <li>Seamless coverage for business travel across Europe</li>
        <li>Direct billing at major private facilities</li>
        <li>Comprehensive preventive care and wellness programs</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Higher premiums than some alternatives</li>
        <li>Less local language support than European-based competitors</li>
        <li>Some find customer service response times slower in Nordic time zones</li>
        <li>May be more coverage than needed if using public system primarily</li>
      </ul>
    </div>
  </section>

  <section id="bupa" class="mb-12">
    <div class="bg-purple-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-purple-800 mb-4">Bupa Global</h2>
      <p class="text-lg text-neutral-700 mb-6">Bupa Global provides premium private healthcare access throughout the Nordic countries. Their established relationships with top private hospitals ensure quality care and efficient service.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Nordic Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Excellent private hospital partnerships in all Nordic capitals</li>
        <li>Strong coverage for specialist consultations and treatments</li>
        <li>Good integration with local healthcare practices</li>
        <li>24/7 assistance with some Nordic language support</li>
        <li>Efficient claims processing for the region</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Mental health coverage less comprehensive than Cigna</li>
        <li>Home country coverage requires additional selection</li>
        <li>Network in smaller Nordic cities may be limited</li>
        <li>Premium pricing for top-tier coverage</li>
      </ul>
    </div>
  </section>

  <section id="allianz" class="mb-12">
    <div class="bg-green-50 rounded-lg p-8">
      <h2 class="text-3xl font-bold text-green-800 mb-4">Allianz Care</h2>
      <p class="text-lg text-neutral-700 mb-6">Allianz Care offers flexible and competitively priced coverage for the Nordic region. Their European roots mean good understanding of how private insurance works alongside strong public healthcare systems.</p>
      
      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Nordic Strengths</h3>
      <ul class="list-disc pl-6 mb-6 space-y-2 text-neutral-700">
        <li>Competitive pricing across all plan levels</li>
        <li>Flexible plan design works well with public system</li>
        <li>Good multilingual support including Nordic languages</li>
        <li>Strong presence in Denmark through local partnerships</li>
        <li>High deductible options for cost-conscious expats</li>
      </ul>

      <h3 class="text-xl font-semibold text-neutral-800 mb-3">Limitations</h3>
      <ul class="list-disc pl-6 space-y-2 text-neutral-700">
        <li>Mental health coverage varies significantly by plan</li>
        <li>Network not as extensive as Cigna in some areas</li>
        <li>Claims processing can be slower for complex cases</li>
        <li>Service quality varies by country within the region</li>
      </ul>
    </div>
  </section>

  <CTABox
    title="Moving to a Nordic Country?"
    description="Get personalized quotes for private health insurance that complements the Nordic public healthcare system."
    buttonText="Compare Nordic Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-600 mb-6">Estimated annual costs for a 35-year-old in the Nordic region. Nordic countries have higher premiums due to local healthcare costs.</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">Prices vary by specific country, age, coverage level, and deductible selection. Norway tends to be the most expensive; Denmark the least.</p>
  </section>

  <section id="nordic-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Nordic Coverage Considerations</h2>
    
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Public Healthcare Integration</h3>
        <p class="text-neutral-700">Nordic public healthcare is excellent but often involves waiting times for non-urgent care. Private insurance provides access to specialists without waiting lists and allows you to choose your own doctors. Most expats use public care for emergencies and primary care while using private insurance for specialists and elective procedures.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Country-by-Country Considerations</h3>
        <p class="text-neutral-700"><strong>Sweden:</strong> Strong public system, good private options in Stockholm and Gothenburg. <strong>Norway:</strong> Most expensive region, private insurance valuable for avoiding public waiting lists. <strong>Denmark:</strong> Mix of public and private works well, good private hospital access. <strong>Finland:</strong> Occupational health common, private insurance supplements well. <strong>Iceland:</strong> Smaller private sector, but insurers provide access to regional hospitals.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Seasonal Health Considerations</h3>
        <p class="text-neutral-700">Long, dark winters affect mental health—ensure your plan includes robust mental health coverage including SAD (Seasonal Affective Disorder) treatment. Preventive care and wellness benefits help manage the challenges of Nordic living. All three providers offer telemedicine, valuable during winter months.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">EU/EEA Mobility</h3>
        <p class="text-neutral-700">All Nordic countries except Iceland are EU members (Norway is EEA). EU citizens have EHIC coverage, but this is limited to public care. International health insurance provides consistent private coverage as you travel between Nordic countries and the rest of Europe. Non-EU citizens especially benefit from comprehensive international coverage.</p>
      </div>

      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Family Coverage Considerations</h3>
        <p class="text-neutral-700">Nordic countries have excellent public pediatric care, but private insurance offers faster access to specialists and orthodontics. Maternity care in public systems is excellent, but some expats prefer private midwives and birthing options. All three providers offer family plans with child discounts.</p>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-primary-800 mb-3">Choose Cigna If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Mental health coverage is important</li>
          <li>You travel frequently beyond Nordic region</li>
          <li>You want comprehensive preventive care</li>
          <li>You're assigned to multiple Nordic offices</li>
          <li>Budget allows for premium coverage</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-purple-800 mb-3">Choose Bupa If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Access to premium private hospitals matters</li>
          <li>You're in a major Nordic capital</li>
          <li>You want established local partnerships</li>
          <li>Service quality is a priority</li>
          <li>You prefer a European-focused provider</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-semibold text-green-800 mb-3">Choose Allianz If:</h3>
        <ul class="list-disc pl-6 space-y-2 text-neutral-700">
          <li>Budget is a primary consideration</li>
          <li>You'll use public care for most needs</li>
          <li>High deductible plans appeal to you</li>
          <li>You want multilingual support</li>
          <li>You're based in Denmark specifically</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Do I need private insurance if Nordic public healthcare is so good?</h3>
        <p class="text-neutral-700">It depends on your priorities. Nordic public healthcare is excellent but involves waiting times for specialists and elective procedures. Private insurance provides faster access, choice of doctors, and often better facilities. Many expats maintain both—using public for primary care and private for specialists.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I access public healthcare as an expat in Nordic countries?</h3>
        <p class="text-neutral-700">EU/EEA citizens register with local systems through residency. Non-EU expats need residency permits to access public healthcare. Processing times vary—Denmark is fastest, Norway slowest. Private insurance bridges the gap during the registration period and provides ongoing private care options.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Is dental covered in Nordic countries?</h3>
        <p class="text-neutral-700">Public dental care is limited or absent for adults in most Nordic countries. Children get free dental care. Adult dental is mostly private and expensive—Copenhagen dentists are particularly costly. Ensure your international plan includes dental coverage if this is important to you.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Which Nordic country is most expensive for healthcare?</h3>
        <p class="text-neutral-700">Norway is the most expensive, followed by Iceland. Denmark tends to be the most affordable. Premium differences between countries can be 10-25%. If you're moving within the region, check how your premium changes with each country.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I use my insurance in multiple Nordic countries?</h3>
        <p class="text-neutral-700">Yes, all three providers cover you throughout the Nordic region and beyond. This is valuable if you travel for work between Stockholm, Copenhagen, and Oslo. Ensure your plan covers your primary country of residence and any regular travel destinations.</p>
      </div>
      <div class="bg-white border border-neutral-200 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What about coverage for winter sports activities?</h3>
        <p class="text-neutral-700">Standard plans typically cover recreational skiing and winter sports. Competitive or extreme winter sports may require verification. The Nordic region has excellent mountain rescue services that coordinate with medical evacuation coverage. Verify specific activities if you're an avid skier.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 mb-12">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Nordic healthcare systems and insurance requirements vary by country. This comparison is for informational purposes only. Verify current coverage details, pricing, and residency requirements directly with providers and local authorities. Healthcare access rules may change with residency status and duration.
    </p>
  </div>
</PageShell>
