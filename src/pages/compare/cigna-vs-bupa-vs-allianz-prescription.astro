---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'prescription-details', text: 'Prescription Coverage Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/guides/medications-abroad', text: 'Medications Abroad Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
  { href: '/providers/allianz-care', text: 'Allianz Care Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Outpatient Rx Coverage', cigna: 'Yes (with outpatient)', bupa: 'Yes (with outpatient)', allianz: 'Yes (with outpatient)' },
  { feature: 'Annual Rx Limit', cigna: 'Typically unlimited', bupa: 'Varies by plan', allianz: '$10K-25K+' },
  { feature: 'Chronic Medications', cigna: 'Covered ongoing', bupa: 'Covered ongoing', allianz: 'Covered (may cap)' },
  { feature: 'Brand vs Generic', cigna: 'Both covered', bupa: 'Both covered', allianz: 'Generic preferred' },
  { feature: 'Mail Order Option', cigna: 'Available', bupa: 'Available', allianz: 'Limited' },
  { feature: 'Direct Pharmacy Billing', cigna: 'Extensive network', bupa: 'Good network', allianz: 'Varies by region' },
  { feature: 'Pre-authorization Required', cigna: 'Specialty drugs only', bupa: 'Specialty drugs', allianz: 'More common' },
  { feature: 'Specialty/Biologics', cigna: 'Covered', bupa: 'Covered', allianz: 'Limited coverage' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { scenario: 'No regular medications', cigna: '$350/mo', bupa: '$400/mo', allianz: '$280/mo' },
  { scenario: 'Common chronic (e.g., statins)', cigna: '$350/mo + Rx cost', bupa: '$400/mo + Rx cost', allianz: '$280/mo + Rx cost' },
  { scenario: 'Specialty medications', cigna: '$400/mo + copay', bupa: '$450/mo + copay', allianz: 'May exclude' },
  { scenario: 'High Rx utilization plan', cigna: '$450/mo', bupa: '$500/mo', allianz: 'Limited options' },
];
---

<PageShell
  title="Cigna vs Bupa vs Allianz for Prescription Medications | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Allianz Care for prescription medication coverage. Expert analysis of drug formularies, chronic meds, specialty drugs, and pharmacy networks."
  headline="Cigna vs Bupa vs Allianz: Prescription Coverage"
  subheadline="Complete comparison for expats who rely on medications—covering chronic prescriptions, specialty drugs, pharmacy networks, and international fills."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best for Specialty Drugs</p>
        <p class="text-neutral-700 text-sm mb-4">Strongest coverage for expensive specialty medications and biologics. Extensive pharmacy network and mail-order options for chronic conditions.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Overall Rx</p>
        <p class="text-neutral-700 text-sm mb-4">Comprehensive prescription coverage with good chronic medication support. Strong pharmacy networks in Europe and excellent claims process.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Good for basic prescription needs at lower premiums. Best if your medications are generic or you don't rely heavily on prescriptions.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Specialty Drugs</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Mail Order</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Global Pharmacy Network</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global provides the most comprehensive prescription coverage for expats. When you choose a plan with outpatient coverage, prescription medications are included without restrictive annual caps. The network includes pharmacies worldwide with direct billing, so you often pay nothing at the point of sale for covered medications.</p>

    <p class="text-neutral-700 mb-4">For expensive specialty medications—biologics, cancer drugs, immunosuppressants—Cigna stands out. While pre-authorization is required, approval rates are high for medically necessary treatments. Mail-order options help chronic medication users get 90-day supplies delivered internationally, reducing pharmacy visits and ensuring supply continuity.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Prescription Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Specialty/biologic coverage</li>
          <li>• Mail-order for chronic meds</li>
          <li>• Extensive direct-billing pharmacies</li>
          <li>• No typical annual caps</li>
          <li>• Brand and generic covered</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Requires outpatient plan option</li>
          <li>• Specialty drugs need pre-auth</li>
          <li>• Higher premium tier</li>
          <li>• Some copays may apply</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Chronic Coverage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">European Network</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Easy Claims</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global offers well-rounded prescription coverage that works smoothly for everyday medication needs. Their pharmacy network is particularly strong in Europe and the Middle East, with direct billing reducing out-of-pocket expenses. Chronic medications are covered indefinitely as long as your plan includes outpatient care.</p>

    <p class="text-neutral-700 mb-4">The claims process for prescriptions is straightforward—either direct billing at network pharmacies or quick reimbursement when paying out-of-pocket. Bupa's app makes submitting prescription receipts simple. For specialty medications, pre-authorization is required but the team is responsive and approvals typically come within 48-72 hours.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Prescription Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Strong European pharmacy network</li>
          <li>• Easy claims/reimbursement</li>
          <li>• Chronic medications covered</li>
          <li>• Good specialty drug process</li>
          <li>• App-based receipt submission</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Plan-dependent annual limits</li>
          <li>• Network thinner outside Europe</li>
          <li>• Premium pricing</li>
          <li>• Specialty pre-auth required</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Generic Focus</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Basic Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care provides prescription coverage but with more limitations than Cigna or Bupa. Annual caps ($10K-25K depending on plan) mean heavy prescription users could hit limits. The formulary tends to favor generic medications, and brand-name drugs may require additional justification or be excluded.</p>

    <p class="text-neutral-700 mb-4">For expats with basic prescription needs—occasional medications, common generics, or no chronic conditions—Allianz offers good value at lower premiums. However, those relying on specialty medications, biologics, or expensive chronic treatments should look to Cigna or Bupa instead. The pharmacy network varies significantly by region.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Prescription Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lower premium cost</li>
          <li>• Good generic coverage</li>
          <li>• Basic chronic meds included</li>
          <li>• Adequate for light users</li>
          <li>• Clear annual limits</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Annual caps on Rx spending</li>
          <li>• Limited specialty coverage</li>
          <li>• Generic-preferred formulary</li>
          <li>• More pre-authorization</li>
          <li>• Network varies by location</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Prescription Coverage"
    description="Get quotes that detail exactly what your medications will cost with each provider."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">How prescription needs affect plan selection and costs:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Base premium shown for individual (35) with outpatient coverage. Prescription costs vary by medication, quantity, and whether you use network pharmacies with direct billing.</p>
  </section>

  <section id="prescription-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Prescription Coverage Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Chronic Medications</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Covered with outpatient plan</li>
          <li>• Refills allowed monthly or quarterly</li>
          <li>• Mail order saves on trips</li>
          <li>• Typically no prior authorization</li>
          <li>• Generic substitution common</li>
          <li>• Brand may require justification</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Specialty Medications</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Pre-authorization required</li>
          <li>• Often shipped directly</li>
          <li>• May have copays/coinsurance</li>
          <li>• Step therapy possible</li>
          <li>• Regular reviews required</li>
          <li>• Coverage varies by insurer</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Common Medication Types & Coverage</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Usually Covered</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Blood pressure meds</li>
            <li>• Cholesterol statins</li>
            <li>• Thyroid medications</li>
            <li>• Diabetes medications</li>
            <li>• Common antibiotics</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">With Pre-Auth</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Biologics (Humira, etc.)</li>
            <li>• Cancer medications</li>
            <li>• MS treatments</li>
            <li>• HIV antiretrovirals</li>
            <li>• Growth hormones</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Often Limited</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Fertility medications</li>
            <li>• Weight loss drugs</li>
            <li>• Cosmetic treatments</li>
            <li>• Experimental drugs</li>
            <li>• Some ADHD medications</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You need specialty or biologic medications</li>
          <li>• Mail-order for chronic meds is valuable</li>
          <li>• Extensive pharmacy network matters</li>
          <li>• You want no annual prescription caps</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You're primarily in Europe/Middle East</li>
          <li>• Easy claims process is important</li>
          <li>• You have regular chronic medications</li>
          <li>• Balance of coverage and cost matters</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Your medications are basic/generic</li>
          <li>• Budget is the priority</li>
          <li>• You don't rely heavily on prescriptions</li>
          <li>• Annual caps won't affect you</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I get my home country medications abroad?</h3>
        <p class="text-neutral-700">Usually yes, though availability varies. Many medications have international equivalents with different names. Your insurer can help identify local alternatives or arrange mail-order from countries where your medication is available. Some controlled substances have import restrictions—check destination country rules.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if my medication isn't covered?</h3>
        <p class="text-neutral-700">First, request a medical exception review—doctors can often justify coverage for necessary medications. If truly not covered, you pay out-of-pocket. Consider countries where your medication costs less, or ask about therapeutic alternatives that are covered. Many expensive US medications cost far less internationally.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does pre-authorization work for medications?</h3>
        <p class="text-neutral-700">Your doctor submits clinical documentation explaining why the medication is necessary. Insurers review (typically 48-72 hours) and approve, deny, or suggest alternatives. Approvals are usually for 6-12 months, then require renewal. Emergency exceptions are available for urgent needs.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do I need a new prescription when moving countries?</h3>
        <p class="text-neutral-700">Generally yes—most countries require local prescriptions from locally licensed doctors. Bring your original prescriptions and medical records when relocating. A local doctor can usually write equivalent prescriptions based on your records. Some insulers help coordinate this transition.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Prescription coverage, formularies, and pharmacy networks change regularly. This comparison represents typical coverage—your specific medications and location affect actual coverage. Always confirm coverage for specific medications before enrolling. Some medications may be restricted or unavailable in certain countries regardless of insurance coverage.</p>
  </div>
</PageShell>
