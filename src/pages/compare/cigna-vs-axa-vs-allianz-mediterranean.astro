---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs AXA vs Allianz: Best International Health Insurance for the Mediterranean";
const description = "Compare Cigna Global, AXA Global Healthcare, and Allianz Care for expats in Mediterranean countries. Coverage analysis for Italy, Greece, Malta, Croatia, Cyprus, and Southern Europe.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Mediterranean Network', cigna: 'Excellent', axa: 'Strong', allianz: 'Strong' },
  { feature: 'EU Coverage', cigna: 'Comprehensive', axa: 'Comprehensive', allianz: 'Comprehensive' },
  { feature: 'Mental Health', cigna: 'Excellent', axa: 'Comprehensive', allianz: 'Good' },
  { feature: 'Retiree-Friendly', cigna: 'Good', axa: 'Good', allianz: 'Excellent' },
  { feature: 'Chronic Conditions', cigna: 'Full coverage', axa: 'Underwritten', allianz: 'Moratorium option' },
  { feature: 'Contract Flexibility', cigna: 'Annual', axa: '12-month min', allianz: '6-month min' },
  { feature: 'Starting Price', cigna: '$$$', axa: '$$$', allianz: '$$-$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Unlimited options', axa: 'Full coverage', allianz: 'Full coverage' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', axa: 'Comprehensive', allianz: 'Comprehensive' },
  { coverage: 'Mental Health', cigna: 'Full coverage', axa: 'Full coverage', allianz: 'Annual limits' },
  { coverage: 'Preventive Care', cigna: 'Included', axa: 'Health screenings', allianz: 'Available' },
  { coverage: 'Chronic Conditions', cigna: 'Covered', axa: 'Underwritten', allianz: 'Moratorium' },
  { coverage: 'Home Country Cover', cigna: 'Included', axa: 'Included', allianz: 'Included' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'axa', header: 'AXA Global' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Individual, 35, Italy', cigna: '$3,500-4,800/yr', axa: '$3,200-4,400/yr', allianz: '$2,800-3,800/yr' },
  { profile: 'Individual, 50, Greece', cigna: '$5,500-7,500/yr', axa: '$5,000-6,800/yr', allianz: '$4,200-5,800/yr' },
  { profile: 'Retiree, 65, Malta', cigna: '$8,500-11,500/yr', axa: '$7,800-10,500/yr', allianz: '$6,500-9,000/yr' },
  { profile: 'Family of 4, Croatia', cigna: '$12,000-16,500/yr', axa: '$11,000-15,000/yr', allianz: '$9,500-13,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'axa-global', text: 'AXA Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'mediterranean-considerations', text: 'Mediterranean Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Europe', href: '/insurance-for/europe' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'AXA Global Review', href: '/providers/axa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want excellent comprehensive coverage with strong Mediterranean networks, excellent mental health support, and full coverage for chronic conditions.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose AXA Global If...</h3>
          <p class="text-green-800 text-sm">You want premium coverage with strong wellness programs, executive health screenings, and comprehensive care at slightly more competitive pricing than Cigna.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-purple-800 text-sm">You want solid comprehensive coverage at the most competitive pricing, with flexibility that works well for retirees and those on variable schedules.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>The Mediterranean draws expats seeking quality of life—Italy's culture, Greece's islands, Malta's tax benefits, Croatia's coast, and Cyprus's climate. Whether working professionals, digital nomads, or retirees, expats need insurance that complements the region's diverse public healthcare systems while providing reliable private access.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers excellent comprehensive coverage throughout the Mediterranean with strong hospital networks in all major countries. Their full coverage for chronic conditions and excellent mental health benefits suit the region's retiree and professional populations.</p>

      <h3>Strengths for Mediterranean Expats</h3>
      <ul>
        <li>Excellent networks in Italy, Greece, Malta, and Cyprus</li>
        <li>Full coverage for chronic conditions</li>
        <li>Excellent mental health coverage</li>
        <li>24/7 multilingual support</li>
        <li>Direct billing at major Mediterranean hospitals</li>
        <li>Preventive care included</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>Annual commitment required</li>
        <li>May exceed needs for younger, healthier expats</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="axa-global" class="mb-12">
      <h2>AXA Global Healthcare</h2>
      <p>AXA Global provides premium coverage with strong wellness and preventive care programs. Their European roots make them well-suited to Mediterranean healthcare systems, with good hospital partnerships across the region.</p>

      <h3>Strengths for Mediterranean Expats</h3>
      <ul>
        <li>Strong networks across Mediterranean Europe</li>
        <li>Comprehensive wellness and preventive programs</li>
        <li>Executive health screenings available</li>
        <li>Good mental health coverage</li>
        <li>Slightly more competitive than Cigna</li>
        <li>European headquarters understand regional healthcare</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Pre-existing conditions underwritten case-by-case</li>
        <li>12-month minimum commitment</li>
        <li>Some conditions may be excluded after underwriting</li>
      </ul>

      <CTAButton href="/providers/axa" variant="highlight" style="color: white !important;">Get AXA Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care offers solid comprehensive coverage at the most competitive pricing among the three, with flexibility particularly valuable for retirees and those with variable arrangements. Their moratorium option helps those with pre-existing conditions get coverage.</p>

      <h3>Strengths for Mediterranean Expats</h3>
      <ul>
        <li>Most competitive pricing in the Mediterranean</li>
        <li>6-month minimum provides flexibility</li>
        <li>Moratorium option for pre-existing conditions</li>
        <li>Monthly payment options</li>
        <li>Good mental health coverage with session limits</li>
        <li>Strong regional networks</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions may have annual limits</li>
        <li>Pre-existing conditions excluded initially under moratorium</li>
        <li>Network may be smaller in some island locations</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Mediterranean expats—particularly retirees—often have chronic conditions requiring ongoing care. How insurers handle pre-existing conditions matters significantly. Cigna covers fully; AXA underwrites; Allianz offers moratorium.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Mediterranean countries offer excellent quality of life at various price points. Southern Europe is generally less expensive for healthcare than Northern Europe or the US, but private insurance ensures access to premium facilities and avoids public healthcare waiting lists.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific country, age, health history, and coverage level. EU/EEA citizens may have additional public healthcare access through EHIC/GHIC.</p>
    </section>

    <section id="mediterranean-considerations" class="mb-12">
      <h2>Mediterranean Considerations</h2>

      <h3>Public vs Private Healthcare</h3>
      <p>Mediterranean countries have public healthcare systems of varying quality. Italy's SSN is good in the north, weaker in the south. Greece's ESY has improved but has limitations. Malta has excellent public care. Private insurance bypasses public system constraints and provides English-speaking care.</p>

      <h3>Retiree Considerations</h3>
      <p>The Mediterranean attracts many retirees. Age-related premium increases matter for long-term planning. Pre-existing conditions are common at retirement age. Cigna's full coverage or Allianz's moratorium option help manage these realities. Plan for increasing costs over time.</p>

      <h3>Island Living</h3>
      <p>Malta, Greek islands, Cyprus—island living is popular but healthcare access varies. Smaller islands may have limited facilities. Medical evacuation to mainland hospitals may be necessary for serious conditions. All three providers include evacuation coverage.</p>

      <h3>EU Residency Benefits</h3>
      <p>EU/EEA citizens have public healthcare access through EHIC/GHIC cards for temporary stays and S1 forms for retirees. Non-EU citizens typically need private insurance for residency visas. Even with public healthcare rights, private insurance ensures faster access and specialist care.</p>

      <h3>Chronic Condition Management</h3>
      <p>Many Mediterranean expats—especially retirees—have ongoing health conditions. Diabetes, heart disease, and similar conditions need consistent management. Cigna covers chronic conditions fully. AXA and Allianz may exclude or limit pre-existing conditions initially.</p>

      <h3>Language Barriers</h3>
      <p>While tourist areas often have English speakers, navigating healthcare in Italian, Greek, or Croatian can be challenging. Premium insurers offer multilingual support and can help arrange English-speaking providers.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Retirees with chronic conditions</li>
            <li>• Those prioritizing mental health</li>
            <li>• Expats wanting premium networks</li>
            <li>• Long-term Mediterranean residents</li>
            <li>• Families relocating</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">AXA Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Healthy professionals abroad</li>
            <li>• Those valuing wellness programs</li>
            <li>• Executive expats</li>
            <li>• Younger couples in the region</li>
            <li>• Those without pre-existing conditions</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Value-conscious expats</li>
            <li>• Budget-minded retirees</li>
            <li>• Digital nomads in the region</li>
            <li>• Those needing flexibility</li>
            <li>• Short-term assignments</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do I need private insurance if I have EHIC/GHIC?</h3>
          <p class="text-neutral-700">EHIC/GHIC covers emergency treatment for temporary stays but isn't designed for residents. Private insurance provides faster access, specialist care, and coverage the public system doesn't offer. Most Mediterranean visa applications require private health insurance regardless of EU citizenship.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How do insurers handle pre-existing conditions?</h3>
          <p class="text-neutral-700">Cigna covers pre-existing conditions fully after underwriting. AXA underwrites individually—conditions may be excluded or covered with loadings. Allianz offers moratorium (conditions excluded initially, potentially covered after claim-free period). Choose based on your health situation.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about coverage on Greek islands or Malta's Gozo?</h3>
          <p class="text-neutral-700">All three providers cover island locations, but medical facilities vary. Smaller islands may require evacuation to larger islands or mainland for serious care. Verify evacuation coverage and understand logistics for your specific island.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does coverage work across multiple Mediterranean countries?</h3>
          <p class="text-neutral-700">Yes, all three offer regional or worldwide coverage. If you spend time in multiple Mediterranean countries—summers in Greece, winters in Malta—your coverage travels with you within your covered region.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should retirees prioritize any specific coverage?</h3>
          <p class="text-neutral-700">Focus on chronic condition coverage, cardiac care, cancer treatment, and medical evacuation. Age-related conditions become more relevant. Preventive care (health screenings) helps catch issues early. Mental health support matters for adjustment to retirement abroad.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How much do premiums increase with age?</h3>
          <p class="text-neutral-700">All insurers increase premiums with age. Expect significant increases at 55, 60, 65, and 70. Budget for rising costs over retirement. Starting with a provider you plan to stay with avoids re-underwriting pre-existing conditions later.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
