---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Netherlands DAFT Visa (2025)";
const description = "Compare top health insurance options for the Dutch American Friendship Treaty (DAFT) visa. Expert analysis of Cigna Global, Allianz Care, and Dutch private insurers for American entrepreneurs in the Netherlands.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "allianz-care", title: "Allianz Care" },
  { id: "dutch-insurance", title: "Dutch Basic Insurance" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "dutch", header: "Dutch Insurance" },
];

const comparisonRows = [
  { feature: "DAFT Visa Acceptance", cigna: "✓ Accepted with exemption", allianz: "✓ Accepted with exemption", dutch: "✓ Required by default" },
  { feature: "Dutch Hospital Network", cigna: "Good (direct billing)", allianz: "Good (direct billing)", dutch: "Excellent (all hospitals)" },
  { feature: "US Coverage", cigna: "✓ Optional add-on", allianz: "✓ Optional add-on", dutch: "✗ Not covered" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", allianz: "Moratorium option", dutch: "✓ Full coverage required" },
  { feature: "Eigen Risico (Deductible)", cigna: "Customizable", allianz: "Customizable", dutch: "€385 mandatory" },
  { feature: "Mental Health", cigna: "Full coverage", allianz: "Full coverage", dutch: "Covered (with referral)" },
  { feature: "Annual Maximum", cigna: "€1M - Unlimited", allianz: "€1M - Unlimited", dutch: "Unlimited (basic care)" },
  { feature: "Best For", cigna: "US visits, global needs", allianz: "Flexible coverage", dutch: "Full Dutch integration" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "dutch", header: "Dutch Insurance" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", allianz: "100% covered", dutch: "100% (contracted)" },
  { coverage: "Outpatient Care", cigna: "100% covered", allianz: "100% covered", dutch: "100% (with referral)" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", allianz: "Unlimited", dutch: "Limited" },
  { coverage: "Prescription Drugs", cigna: "100% covered", allianz: "100% covered", dutch: "Formulary based" },
  { coverage: "Dental", cigna: "Optional", allianz: "Optional", dutch: "Optional add-on" },
  { coverage: "Vision", cigna: "Optional", allianz: "Optional", dutch: "Optional add-on" },
  { coverage: "Maternity", cigna: "Optional add-on", allianz: "Optional add-on", dutch: "✓ Included (midwife)" },
  { coverage: "Fysio (Physiotherapy)", cigna: "Varies by plan", allianz: "Varies by plan", dutch: "Limited sessions" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "dutch", header: "Dutch Insurance" },
];

const pricingRows = [
  { age: "25-30", cigna: "€180-280/month", allianz: "€170-260/month", dutch: "€120-140/month" },
  { age: "30-35", cigna: "€220-340/month", allianz: "€210-320/month", dutch: "€120-140/month" },
  { age: "40-45", cigna: "€320-480/month", allianz: "€300-450/month", dutch: "€120-140/month" },
  { age: "50-55", cigna: "€450-650/month", allianz: "€420-600/month", dutch: "€120-140/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "dutch", header: "Dutch Insurance" },
];

const networkRows = [
  { region: "Amsterdam", cigna: "Strong - 10+ hospitals", allianz: "Strong - 10+ hospitals", dutch: "Excellent - all hospitals" },
  { region: "Rotterdam", cigna: "Good - 6+ hospitals", allianz: "Good - 6+ hospitals", dutch: "Excellent - all hospitals" },
  { region: "The Hague", cigna: "Good - 5+ facilities", allianz: "Good - 5+ facilities", dutch: "Excellent - all hospitals" },
  { region: "Other Cities", cigna: "Limited - reimbursement", allianz: "Limited - reimbursement", dutch: "Full network access" },
  { region: "United States", cigna: "Strong (with US option)", allianz: "Strong (with US option)", dutch: "Not covered" },
  { region: "Rest of World", cigna: "Worldwide coverage", allianz: "Worldwide coverage", dutch: "Emergency only" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Dutch American Friendship Treaty (DAFT) visa holders"
    heroImage="/images/countries/netherlands-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Netherlands DAFT Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        The Dutch American Friendship Treaty (DAFT) allows US citizens to establish a business in the Netherlands with a relatively low investment threshold (€4,500). As a Dutch resident, you're normally required to have Dutch basic health insurance (basisverzekering). However, DAFT visa holders can apply for an exemption if they have equivalent international coverage.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Dutch health insurance (basisverzekering) is mandatory for residents</li>
          <li>• International insurance requires exemption from SVB/CAK</li>
          <li>• Exemption requires "equivalent coverage" to Dutch basic package</li>
          <li>• Coverage must include hospitalization, GP care, and prescriptions</li>
          <li>• Pre-existing conditions must be covered (for Dutch insurance)</li>
          <li>• Decision: Dutch insurance OR international with exemption</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        The Netherlands has a unique system: everyone must have basic insurance (basisverzekering) at a regulated price (around €120-140/month). This covers essential care. For more coverage, you add supplementary insurance (aanvullende verzekering). Insurers cannot reject you for basic insurance regardless of health status.
      </p>

      <p class="text-neutral-700">
        For DAFT visa holders, the choice comes down to: Do you want to fully integrate into the Dutch system, or maintain international coverage for flexibility (especially if you travel to the US frequently)?
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for DAFT Visa</h2>

      <p class="text-neutral-700 mb-6">
        DAFT visa holders have three paths: premium international insurance with exemption, standard international with exemption, or Dutch basic insurance. Here's how they compare:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global is a strong choice for DAFT visa holders who travel frequently or maintain ties to the US. Their plans can include US coverage—essential if you're visiting family or have business interests stateside.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• US coverage available (critical for Americans)</li>
            <li>• Good network in Dutch cities</li>
            <li>• Modular plans for customization</li>
            <li>• Comprehensive mental health coverage</li>
            <li>• Can qualify for Dutch exemption</li>
            <li>• 24/7 English-speaking support</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• US inclusion adds significant cost</li>
            <li>• Must apply for Dutch exemption</li>
            <li>• Network smaller than Dutch insurers</li>
            <li>• Age-based pricing increases over time</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="International coverage with US access for American expats."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care provides flexible international coverage with strong European networks. Their plans can qualify for the Dutch exemption while offering more flexibility than local insurance.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Good Dutch hospital network</li>
            <li>• Flexible plan options and deductibles</li>
            <li>• Strong European coverage</li>
            <li>• Wellness and preventive benefits</li>
            <li>• Brand recognition in Netherlands</li>
            <li>• Can qualify for Dutch exemption</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• US coverage varies by plan</li>
            <li>• Must apply for exemption</li>
            <li>• Claims processing can be slower</li>
            <li>• Age-based pricing</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="Flexible international coverage for Dutch residents."
        buttonText="Get Quote"
        buttonHref="/go/allianz"
      />
    </section>

    <section id="dutch-insurance" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Dutch Basic Insurance (Basisverzekering)</h2>

      <p class="text-neutral-700 mb-4">
        Dutch basic health insurance is the standard path for residents. Multiple insurers offer it (Zilveren Kruis, CZ, VGZ, etc.) at regulated prices around €120-140/month. No one can be rejected, and pre-existing conditions must be covered.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Flat pricing regardless of age/health</li>
            <li>• All pre-existing conditions covered</li>
            <li>• Access to entire Dutch healthcare network</li>
            <li>• No exemption paperwork needed</li>
            <li>• Maternity fully included</li>
            <li>• Seamless integration with Dutch system</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No US coverage at all</li>
            <li>• €385 mandatory deductible (eigen risico)</li>
            <li>• Limited coverage outside Netherlands</li>
            <li>• Dental, vision need supplementary</li>
            <li>• Referral required for specialists</li>
          </ul>
        </div>
      </div>

      <div class="bg-neutral-50 p-4 rounded-lg">
        <p class="text-neutral-700 text-sm">
          <strong>How to get Dutch insurance:</strong> Compare at Independer.nl or Zorgwijzer.nl (in Dutch). Popular insurers include Zilveren Kruis, CZ, OHRA, and VGZ. Most offer English online portals. Sign up within 4 months of registration in the Netherlands.
        </p>
      </div>
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares across key categories for DAFT visa holders:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Dutch basic insurance covers essential care comprehensively but requires referrals for specialists. International plans offer more direct access but may have network limitations in the Netherlands.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Dutch insurance has flat pricing; international insurance varies by age. This creates an interesting decision point:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        For younger Americans, Dutch insurance is more expensive than basic international coverage. For older Americans, Dutch insurance becomes very competitive. The real differentiator is US coverage—if you need it, international is your only option.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access</h2>

      <p class="text-neutral-700 mb-6">
        Network access varies significantly depending on your choice:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        If you're staying primarily in the Netherlands, Dutch insurance provides the best network access. If you travel to the US regularly, international insurance is essential.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Entrepreneur, No US Ties</h3>
          <p class="text-neutral-600 mb-3">28-year-old starting a tech company in Amsterdam, no plans to return to the US regularly.</p>
          <p class="text-green-700 font-medium">Recommendation: Dutch Basic Insurance</p>
          <p class="text-neutral-600 text-sm">Best network, flat pricing, no exemption hassle. Add supplementary for dental/vision. At this age, Dutch pricing is slightly higher but full integration is valuable.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Consultant with US Clients</h3>
          <p class="text-neutral-600 mb-3">35-year-old consultant who visits US clients 4-6 times per year, 2-3 weeks each trip.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global with US coverage</p>
          <p class="text-neutral-600 text-sm">US coverage is essential for this travel pattern. The extra cost is justified by meaningful US network access. Apply for Dutch exemption.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Older Entrepreneur with Pre-existing Conditions</h3>
          <p class="text-neutral-600 mb-3">52-year-old with managed hypertension, establishing business in Rotterdam, occasional US trips.</p>
          <p class="text-amber-700 font-medium">Recommendation: Dutch Basic Insurance + Travel Insurance</p>
          <p class="text-neutral-600 text-sm">Dutch insurance covers all conditions at flat rate. Much cheaper than age-adjusted international premiums. Buy separate travel insurance for US trips.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Family Moving to Netherlands</h3>
          <p class="text-neutral-600 mb-3">Couple in their 40s with two children, planning 5+ years in the Netherlands.</p>
          <p class="text-green-700 font-medium">Recommendation: Dutch Basic Insurance for all</p>
          <p class="text-neutral-600 text-sm">Family coverage is much more affordable in Dutch system. Excellent pediatric care. Full maternity coverage if planning more children. Kids get zorgtoeslag (subsidy).</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Digital Nomad Testing DAFT</h3>
          <p class="text-neutral-600 mb-3">30-year-old using DAFT for residency but traveling 6+ months/year across Europe and US.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global with US coverage</p>
          <p class="text-neutral-600 text-sm">Global coverage essential for this lifestyle. Dutch insurance provides almost no coverage outside Netherlands. Apply for exemption.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For DAFT visa holders planning to stay primarily in the Netherlands, <strong>Dutch basic insurance</strong> offers the best value and network access. For those who travel to the US regularly or maintain a global lifestyle, <strong>Cigna Global</strong> with US coverage provides necessary flexibility despite higher costs.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Dutch Insurance If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Staying mainly in Netherlands</li>
            <li>• Have pre-existing conditions</li>
            <li>• Want full local network</li>
            <li>• Planning family/maternity</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Regular US travel needed</li>
            <li>• Want worldwide coverage</li>
            <li>• Prefer premium service</li>
            <li>• Young and healthy</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Europe-focused travel</li>
            <li>• Want flexible deductibles</li>
            <li>• Don't need US coverage</li>
            <li>• Like brand recognition</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How do I apply for the Dutch insurance exemption?</h3>
          <p class="text-neutral-600">Apply through SVB (Sociale Verzekeringsbank) or CAK. You'll need to prove your international insurance provides "equivalent coverage" to Dutch basic insurance. This includes GP care, hospital care, prescriptions, maternity, and mental health. Processing takes several weeks.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What is the €385 eigen risico?</h3>
          <p class="text-neutral-600">The eigen risico is a mandatory annual deductible for Dutch basic insurance. You pay the first €385 of care costs (except GP visits, which are free). After that, insurance covers 100%. You can opt for a higher deductible (up to €885) for lower premiums.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I switch between Dutch and international insurance?</h3>
          <p class="text-neutral-600">Yes, but timing matters. Dutch insurance typically switches annually (by January). To move from international to Dutch, cancel your international plan and enroll in Dutch insurance. Going the other direction requires applying for exemption first.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What happens if I get sick in the US with Dutch insurance?</h3>
          <p class="text-neutral-600">Dutch basic insurance covers only emergency care abroad, with significant limitations. You'd pay US rates (extremely high) and seek partial reimbursement at Dutch rates. For any meaningful US time, you need separate US coverage or international insurance.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Do I qualify for zorgtoeslag (healthcare subsidy)?</h3>
          <p class="text-neutral-600">Possibly. Zorgtoeslag is a monthly subsidy (up to ~€150/month) for those with lower incomes. As a DAFT entrepreneur with variable income, you may qualify in some years. Check Belastingdienst (tax office) for current thresholds.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What's the minimum investment for DAFT?</h3>
          <p class="text-neutral-600">Currently €4,500 in your Dutch business bank account. This is notably lower than most entrepreneur visa programs. You also need a viable business plan and the usual documentation (insurance, housing, etc.).</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Insurance requirements and DAFT visa rules change. Verify current requirements with IND (Dutch immigration) and confirm insurance details with providers before purchasing. This comparison is for informational purposes and does not constitute legal or insurance advice.</p>
    </div>
  </PageShell>
</Layout>
