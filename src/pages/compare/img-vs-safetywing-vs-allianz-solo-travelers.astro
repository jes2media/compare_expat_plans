---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'allianz', text: 'Allianz Care', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'solo-needs', text: 'Solo Traveler Considerations', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/compare/safetywing-vs-worldnomads-vs-img-backpackers', text: 'Backpacker Insurance' },
  { href: '/compare/safetywing-vs-img-vs-cigna-digital-nomads', text: 'Digital Nomad Insurance' },
  { href: '/providers/safetywing', text: 'SafetyWing Review' },
  { href: '/providers/img-global', text: 'IMG Global Review' },
  { href: '/best/travel-insurance', text: 'Best Travel Insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'img', header: 'IMG Global' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'allianz', header: 'Allianz Care' },
];

const mainComparisonRows = [
  { feature: 'Best For', img: 'Flexible coverage', safetywing: 'Budget long-term', allianz: 'Comprehensive care' },
  { feature: 'Minimum Duration', img: '5 days', safetywing: '1 month', allianz: '12 months' },
  { feature: 'Emergency Evacuation', img: 'Up to $500K', safetywing: '$100K', allianz: 'Up to $1M' },
  { feature: '24/7 Assistance', img: 'Yes', safetywing: 'Yes', allianz: 'Yes' },
  { feature: 'Trip Cancellation', img: 'Optional', safetywing: 'No', allianz: 'Optional' },
  { feature: 'Personal Liability', img: 'Included', safetywing: 'Limited', allianz: 'Included' },
  { feature: 'Buy While Abroad', img: 'Yes', safetywing: 'Yes', allianz: 'Yes' },
  { feature: 'Solo-Specific Features', img: 'Good', safetywing: 'Basic', allianz: 'Excellent' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'img', header: 'IMG Global' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'allianz', header: 'Allianz Care' },
];

const pricingRows = [
  { profile: 'Solo traveler (30, 1 month)', img: '$65-100', safetywing: '$42-56', allianz: 'N/A (12 mo min)' },
  { profile: 'Solo traveler (30, 6 months)', img: '$320-480', safetywing: '$252-336', allianz: '$1,560-2,100' },
  { profile: 'Solo traveler (30, 1 year)', img: '$600-900', safetywing: '$504-672', allianz: '$3,120-4,200' },
  { profile: 'Solo traveler (45, 1 year)', img: '$900-1,300', safetywing: '$650-850', allianz: '$4,200-5,400' },
];
---

<PageShell
  title="IMG vs SafetyWing vs Allianz for Solo Travelers | 2025 Comparison"
  description="Compare IMG Global, SafetyWing, and Allianz Care for solo travelers. Expert analysis of single-person coverage, emergency assistance, and travel flexibility."
  headline="IMG vs SafetyWing vs Allianz: Best Insurance for Solo Travelers"
  subheadline="Complete comparison of three leading providers for independent travelers exploring the world alone."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">IMG Global</h3>
        <p class="text-primary-700 mb-3">Best Flexibility</p>
        <p class="text-neutral-700 text-sm mb-4">Most flexible duration options (5 days to 3 years) with highest evacuation coverage. Great for variable travel plans.</p>
        <a href="/providers/img-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">SafetyWing</h3>
        <p class="text-purple-700 mb-3">Best Budget Option</p>
        <p class="text-neutral-700 text-sm mb-4">Cheapest long-term coverage with subscription billing. Perfect for budget-conscious solo travelers.</p>
        <a href="/providers/safetywing" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Allianz Care</h3>
        <p class="text-green-700 mb-3">Best Comprehensive Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Full expat-level coverage for serious solo travelers. Best for long-term stays with health priorities.</p>
        <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Duration</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">High Evacuation</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Trip Cancellation Available</span>
    </div>

    <p class="text-neutral-700 mb-4">IMG Global offers the most flexibility for solo travelers whose plans might change. Coverage starts from just 5 days, extends up to 3 years, and can be easily extended online if your trip runs longer. Their $500K emergency evacuation limit provides strong protection for solo travelers in remote areas.</p>

    <p class="text-neutral-700 mb-4">Personal liability coverage is particularly valuable for solo travelers—if you accidentally damage property or injure someone, you're covered. The optional trip cancellation add-on protects your investment if you need to cut your trip short due to covered events.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Solo Traveler Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Ultra-flexible duration (5 days to 3 years)</li>
          <li>• Highest evacuation coverage ($500K)</li>
          <li>• Personal liability included</li>
          <li>• Trip cancellation available</li>
          <li>• Easy online extensions</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• More expensive than SafetyWing</li>
          <li>• Limited adventure sports coverage</li>
          <li>• Mostly reimbursement-based</li>
          <li>• Pre-existing conditions limited</li>
        </ul>
      </div>
    </div>

    <a href="/providers/img-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get IMG Quote</a>
  </section>

  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Budget Friendly</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Subscription Model</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Unlimited Duration</span>
    </div>

    <p class="text-neutral-700 mb-4">SafetyWing is the most affordable option for solo travelers planning extended trips. At roughly $42/month for those under 40, it's hard to beat for budget-conscious adventurers. The subscription model means you never have to worry about renewals—coverage continues automatically until you cancel.</p>

    <p class="text-neutral-700 mb-4">Coverage is basic but adequate for most situations. The main trade-offs are lower evacuation limits ($100K) and no trip cancellation coverage. For healthy solo travelers doing standard travel activities, SafetyWing provides solid protection at an unbeatable price.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Solo Traveler Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Cheapest long-term coverage</li>
          <li>• Unlimited duration (subscription)</li>
          <li>• Simple monthly billing</li>
          <li>• Buy from anywhere</li>
          <li>• No renewal hassles</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Lower evacuation limits ($100K)</li>
          <li>• 1-month minimum commitment</li>
          <li>• No trip cancellation</li>
          <li>• Limited liability coverage</li>
          <li>• Basic adventure sports only</li>
        </ul>
      </div>
    </div>

    <a href="/providers/safetywing" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get SafetyWing Quote</a>
  </section>

  <section id="allianz" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Allianz Care</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Comprehensive</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Long-term Focus</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Full Expat Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Allianz Care provides full expat-level insurance for solo travelers making serious long-term commitments. While more expensive and requiring a 12-month minimum, you get comprehensive coverage including outpatient care, specialists, and extensive medical services not available with travel insurance.</p>

    <p class="text-neutral-700 mb-4">The $1M evacuation coverage is the highest available, and their 24/7 assistance line provides support in 20+ languages. For solo travelers with health conditions, regular medication needs, or planning to truly settle abroad, Allianz offers the most complete protection.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Solo Traveler Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Full expat-level coverage</li>
          <li>• Highest evacuation ($1M)</li>
          <li>• Outpatient care included</li>
          <li>• 20+ language support</li>
          <li>• Best for health-conscious travelers</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Much higher premiums</li>
          <li>• 12-month minimum commitment</li>
          <li>• Overkill for short trips</li>
          <li>• Not designed for travel flexibility</li>
        </ul>
      </div>
    </div>

    <a href="/providers/allianz-care" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Allianz Quote</a>
  </section>

  <CTABox
    title="Compare Solo Traveler Coverage Quotes"
    description="Get personalized quotes designed for independent travelers from all three providers."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Solo traveler pricing—remember, you can't split costs with a travel partner:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*SafetyWing pricing is most competitive for long-term travel. IMG offers best value for shorter, flexible trips. Allianz is for those prioritizing comprehensive health coverage.</p>
  </section>

  <section id="solo-needs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Solo Traveler Considerations</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Emergency Assistance</h3>
        <p class="text-neutral-700 text-sm mb-4">Critical when traveling alone without backup:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>IMG:</strong> 24/7 hotline, coordinates all emergencies</li>
          <li>• <strong>SafetyWing:</strong> 24/7 support, basic coordination</li>
          <li>• <strong>Allianz:</strong> 24/7 in 20+ languages, comprehensive</li>
        </ul>
        <p class="text-neutral-600 text-xs mt-3">All three can arrange emergency contacts and coordinate with local services.</p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Personal Liability</h3>
        <p class="text-neutral-700 text-sm mb-4">Protection if you accidentally cause damage:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>IMG:</strong> Good coverage included</li>
          <li>• <strong>SafetyWing:</strong> Limited liability coverage</li>
          <li>• <strong>Allianz:</strong> Comprehensive liability</li>
        </ul>
        <p class="text-neutral-600 text-xs mt-3">Important for accommodations, rentals, and public spaces.</p>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-amber-800 mb-3">Solo Safety Considerations</h3>
      <p class="text-amber-700 mb-4">What solo travelers should prioritize in insurance:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-amber-800 mb-2">Evacuation Coverage</h4>
          <p class="text-amber-700 text-sm">Without a travel partner, you need reliable evacuation coordination. IMG's $500K and Allianz's $1M provide strongest protection.</p>
        </div>
        <div>
          <h4 class="font-bold text-amber-800 mb-2">24/7 Assistance</h4>
          <p class="text-amber-700 text-sm">When you're alone in a medical emergency, a responsive 24/7 line is essential. All three offer this, but Allianz has most languages.</p>
        </div>
        <div>
          <h4 class="font-bold text-amber-800 mb-2">Trip Flexibility</h4>
          <p class="text-amber-700 text-sm">Solo plans change often. IMG offers most flexibility; SafetyWing's subscription handles indefinite travel; Allianz requires commitment.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose IMG Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• Your travel plans are flexible or uncertain</li>
          <li>• You want the highest evacuation coverage</li>
          <li>• Trip cancellation protection matters</li>
          <li>• You need coverage for short or variable trips</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose SafetyWing if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Budget is your primary concern</li>
          <li>• You're planning extended travel (6+ months)</li>
          <li>• You want simple subscription billing</li>
          <li>• You're healthy with basic coverage needs</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Allianz Care if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Comprehensive health coverage is a priority</li>
          <li>• You're committing to 12+ months abroad</li>
          <li>• You have health conditions or regular medical needs</li>
          <li>• You want full expat-level insurance</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is solo travel more expensive to insure than couples?</h3>
        <p class="text-neutral-700">Not per person—solo travelers pay individual rates, which are the same whether traveling alone or as a couple. However, couples can sometimes find family rates that provide slight per-person savings. The bigger factor is that solo travelers can't split premium costs with a partner.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What if I need help but can't communicate due to illness?</h3>
        <p class="text-neutral-700">All three providers can coordinate with local emergency services and hospitals. Provide emergency contact information when enrolling. Some travelers carry a card with their policy number and emergency line. Allianz's 20+ language support helps when you're in non-English speaking regions.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Should I buy travel insurance or expat insurance as a solo traveler?</h3>
        <p class="text-neutral-700">For trips under 6-12 months, travel insurance (IMG or SafetyWing) usually makes sense—it's designed for travelers and offers flexibility. For longer stays or if health coverage is important, expat insurance (Allianz) provides more comprehensive care. Consider your health needs and how long you'll actually be abroad.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Does being solo affect coverage for adventure activities?</h3>
        <p class="text-neutral-700">Not directly—coverage depends on the activities themselves, not whether you're alone. However, solo adventure activities can be riskier without a partner to assist. If you're doing solo hiking, diving, or other activities, ensure your plan covers them and that emergency evacuation is adequate for your destinations.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. Solo travel considerations include personal risk factors. Always verify specific coverage directly with providers before purchasing. This comparison is for informational purposes only and does not constitute financial or insurance advice.</p>
  </div>
</PageShell>
