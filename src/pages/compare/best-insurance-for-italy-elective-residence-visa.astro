---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Italy Elective Residence Visa (2025)";
const description = "Compare top health insurance options for Italy's Elective Residence Visa. Expert analysis of Cigna Global, Allianz Care, and IMG Global for retirees and independent income earners moving to Italy.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "allianz-care", title: "Allianz Care" },
  { id: "img-global", title: "IMG Global" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "img", header: "IMG Global" },
];

const comparisonRows = [
  { feature: "Italy Visa Acceptance", cigna: "✓ Widely accepted", allianz: "✓ Widely accepted", img: "✓ Widely accepted" },
  { feature: "Italian Hospital Network", cigna: "Strong (direct billing)", allianz: "Strong (direct billing)", img: "Good (reimbursement)" },
  { feature: "Age Limits", cigna: "Up to 74", allianz: "Up to 74", img: "Up to 80" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", allianz: "Moratorium option", img: "Limited coverage" },
  { feature: "Repatriation", cigna: "✓ Unlimited", allianz: "✓ Unlimited", img: "✓ Included" },
  { feature: "Mental Health", cigna: "Full coverage", allianz: "Full coverage", img: "Limited" },
  { feature: "Annual Maximum", cigna: "€1M - Unlimited", allianz: "€1M - Unlimited", img: "$1M - $8M" },
  { feature: "Best For", cigna: "Premium coverage", allianz: "Flexibility", img: "Budget-conscious" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "img", header: "IMG Global" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", allianz: "100% covered", img: "100% covered" },
  { coverage: "Outpatient Care", cigna: "100% covered", allianz: "100% covered", img: "80-100% covered" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", allianz: "Unlimited", img: "$500,000" },
  { coverage: "Prescription Drugs", cigna: "100% covered", allianz: "100% covered", img: "Subject to limits" },
  { coverage: "Dental", cigna: "Optional", allianz: "Optional", img: "Optional" },
  { coverage: "Vision", cigna: "Optional", allianz: "Optional", img: "Optional" },
  { coverage: "Wellness/Preventive", cigna: "Annual checkup", allianz: "Annual checkup", img: "Limited" },
  { coverage: "Chronic Conditions", cigna: "Full management", allianz: "Full management", img: "Maintenance only" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "img", header: "IMG Global" },
];

const pricingRows = [
  { age: "50-55", cigna: "€350-500/month", allianz: "€320-480/month", img: "$250-380/month" },
  { age: "55-60", cigna: "€450-650/month", allianz: "€420-600/month", img: "$320-480/month" },
  { age: "60-65", cigna: "€550-800/month", allianz: "€520-750/month", img: "$400-600/month" },
  { age: "65-70", cigna: "€700-1,000/month", allianz: "€650-950/month", img: "$500-750/month" },
  { age: "70-75", cigna: "€900-1,300/month", allianz: "€850-1,200/month", img: "$650-950/month" },
];

const networkColumns = [
  { key: "region", header: "Region/City" },
  { key: "cigna", header: "Cigna Global" },
  { key: "allianz", header: "Allianz Care" },
  { key: "img", header: "IMG Global" },
];

const networkRows = [
  { region: "Rome/Lazio", cigna: "Excellent - 25+ hospitals", allianz: "Excellent - 20+ hospitals", img: "Good - reimbursement" },
  { region: "Milan/Lombardy", cigna: "Excellent - 30+ hospitals", allianz: "Excellent - 25+ hospitals", img: "Good - reimbursement" },
  { region: "Florence/Tuscany", cigna: "Strong - 15+ facilities", allianz: "Strong - 15+ facilities", img: "Good - reimbursement" },
  { region: "Naples/Campania", cigna: "Good - 10+ facilities", allianz: "Good - 10+ facilities", img: "Reimbursement model" },
  { region: "Sicily/Sardinia", cigna: "Limited - reimbursement", allianz: "Limited - reimbursement", img: "Reimbursement model" },
  { region: "Rest of Italy", cigna: "Reimbursement available", allianz: "Reimbursement available", img: "Reimbursement model" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Italy's Elective Residence (Residenza Elettiva) visa"
    heroImage="/images/countries/italy-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Italy Elective Residence Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Italy's Elective Residence Visa (Visto per Residenza Elettiva) is designed for non-EU citizens who can support themselves through passive income—retirees, investors, and those with independent wealth. Health insurance is a mandatory requirement for visa approval.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Coverage must be valid for the entire visa duration (typically 1 year initially)</li>
          <li>• Must cover all medical expenses including hospitalization</li>
          <li>• Repatriation coverage is strongly recommended</li>
          <li>• No specific minimum amount, but comprehensive coverage expected</li>
          <li>• Italian consulates prefer established international insurers</li>
          <li>• Coverage must be in place before visa issuance</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Italy has both public healthcare (SSN - Servizio Sanitario Nazionale) and private options. As an Elective Residence visa holder, you're not automatically enrolled in SSN. You can voluntarily enroll (about €400/year) after establishing residency, or maintain private insurance.
      </p>

      <p class="text-neutral-700">
        Many retirees in Italy use a combination: private international insurance for major expenses and serious conditions, with voluntary SSN enrollment for routine care and prescriptions.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Top 3 Insurers for Italy Elective Residence</h2>

      <p class="text-neutral-700 mb-6">
        We've analyzed the best options for retirees and independent income earners moving to Italy. These insurers offer the coverage depth and age acceptance that Elective Residence visa holders typically need.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global is a premium international health insurer with excellent coverage for retirees in Italy. Their modular plans allow customization based on your specific needs, and they have strong relationships with Italian private hospitals.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Strong direct billing network in Italy</li>
            <li>• Excellent chronic condition management</li>
            <li>• Comprehensive mental health coverage</li>
            <li>• Modular plans—customize coverage</li>
            <li>• 24/7 multilingual support including Italian</li>
            <li>• Good pre-existing condition options</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Premium pricing tier</li>
            <li>• Age limit of 74 for new enrollees</li>
            <li>• Dental/vision are optional add-ons</li>
            <li>• Network thinner in southern Italy</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Premium coverage for retirees in Italy."
        buttonText="Get Quote"
        buttonHref="/go/cigna"
      />
    </section>

    <section id="allianz-care" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Allianz Care</h2>

      <p class="text-neutral-700 mb-4">
        Allianz Care provides flexible international health insurance with strong coverage in Italy. Their range of plan options and deductible choices make them popular with cost-conscious retirees who still want comprehensive coverage.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Flexible plan tiers and deductibles</li>
            <li>• Good Italian hospital network</li>
            <li>• Strong chronic condition support</li>
            <li>• Wellness and preventive care included</li>
            <li>• Slightly lower premiums than Cigna</li>
            <li>• Brand recognition with Italian authorities</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Age limit of 74 for new enrollees</li>
            <li>• Claims processing can be slower</li>
            <li>• Dental/vision are optional</li>
            <li>• Some plans exclude specific regions</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an Allianz Care Quote"
        description="Flexible coverage with strong Italy network."
        buttonText="Get Quote"
        buttonHref="/go/allianz"
      />
    </section>

    <section id="img-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">IMG Global</h2>

      <p class="text-neutral-700 mb-4">
        IMG Global offers more budget-friendly international health insurance with higher age acceptance—up to 80 for new enrollees. This makes them a valuable option for older retirees who may not qualify for Cigna or Allianz.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Higher age acceptance (up to 80)</li>
            <li>• More affordable premiums</li>
            <li>• Good for healthy retirees</li>
            <li>• Meets visa requirements</li>
            <li>• Flexible plan options</li>
            <li>• US coverage available if needed</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• Primarily reimbursement model in Italy</li>
            <li>• Pre-existing condition coverage limited</li>
            <li>• Mental health coverage restricted</li>
            <li>• Lower coverage limits on some benefits</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get an IMG Global Quote"
        description="Budget-friendly option with higher age acceptance."
        buttonText="Get Quote"
        buttonHref="/go/img"
      />
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        All three insurers meet Italy's Elective Residence visa requirements. Here's how their coverage compares across key categories important for retirees:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Cigna and Allianz offer more comprehensive chronic condition management—important for older applicants. IMG is suitable for healthy retirees seeking basic coverage at lower cost.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Premium costs increase significantly with age. These ranges represent comprehensive plans suitable for Elective Residence visa holders:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        IMG offers meaningful savings, particularly for older applicants. However, weigh the cost savings against more limited pre-existing condition coverage and reimbursement-only access in Italy.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Italy</h2>

      <p class="text-neutral-700 mb-6">
        Italy has excellent healthcare, particularly in the north. Here's how network coverage varies by region:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        If you're settling in Tuscany, Umbria, or southern regions, be prepared for more reimbursement-based care. Major cities have strong direct billing options with Cigna and Allianz.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Healthy Retiree in Tuscany</h3>
          <p class="text-neutral-600 mb-3">65-year-old couple, no major health issues, retiring to a small town near Florence.</p>
          <p class="text-green-700 font-medium">Recommendation: Allianz Care</p>
          <p class="text-neutral-600 text-sm">Good balance of coverage and cost. Network strong in Tuscany. Consider voluntary SSN enrollment after residency for routine care.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Retiree with Chronic Conditions</h3>
          <p class="text-neutral-600 mb-3">68-year-old with managed diabetes and high cholesterol, moving to Rome.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global</p>
          <p class="text-neutral-600 text-sm">Best chronic condition management. Strong Rome network. Higher premiums justified by comprehensive ongoing care coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Older Retiree on Budget</h3>
          <p class="text-neutral-600 mb-3">76-year-old, generally healthy, needs visa-compliant coverage at reasonable cost.</p>
          <p class="text-amber-700 font-medium">Recommendation: IMG Global</p>
          <p class="text-neutral-600 text-sm">Only option available at this age. Meets visa requirements. Combine with voluntary SSN for comprehensive coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Split-Year Retiree</h3>
          <p class="text-neutral-600 mb-3">62-year-old spending 6 months in Italy, 6 months in the US visiting family.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global (with US coverage)</p>
          <p class="text-neutral-600 text-sm">Best worldwide coverage. US inclusion adds cost but essential for meaningful time in America. IMG also offers US coverage at lower cost.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Active Retiree in Milan</h3>
          <p class="text-neutral-600 mb-3">58-year-old early retiree, very health-conscious, wants premium preventive care access.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or Allianz Care</p>
          <p class="text-neutral-600 text-sm">Both offer excellent wellness benefits. Milan has strong private hospital networks. Good age for locking in premiums long-term.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most Elective Residence visa applicants under 74, <strong>Allianz Care</strong> offers the best balance of coverage and value. If you have chronic conditions or want premium service, <strong>Cigna Global</strong> is worth the higher cost. For applicants over 74 or on a tight budget, <strong>IMG Global</strong> provides viable visa-compliant coverage.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Have chronic conditions</li>
            <li>• Want premium service</li>
            <li>• Need mental health coverage</li>
            <li>• Value direct billing network</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Allianz If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Want value for money</li>
            <li>• Prefer flexible deductibles</li>
            <li>• Generally healthy</li>
            <li>• Like wellness benefits</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose IMG If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Over 74 years old</li>
            <li>• Budget is primary concern</li>
            <li>• Generally very healthy</li>
            <li>• Need US coverage option</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I use Italy's public healthcare (SSN) with an Elective Residence Visa?</h3>
          <p class="text-neutral-600">Not automatically. After establishing residency, you can voluntarily enroll in SSN for about €400/year. Many retirees combine private international insurance with SSN enrollment for comprehensive coverage.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What income do I need for the Elective Residence Visa?</h3>
          <p class="text-neutral-600">Generally €31,000+ per year for a single applicant, with additional amounts for dependents. This must be passive income (pensions, investments, rental income). The exact amount varies by consulate.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Will my pre-existing conditions be covered?</h3>
          <p class="text-neutral-600">Cigna and Allianz typically use moratorium periods—conditions excluded for 2 years, then covered if treatment-free. IMG has more limited pre-existing coverage. Disclose all conditions accurately to avoid claims issues.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How does healthcare quality vary across Italy?</h3>
          <p class="text-neutral-600">Northern Italy (Milan, Bologna, Turin) has world-class facilities. Central Italy (Rome, Florence) is excellent. Southern regions and islands have good care but fewer private options. Private insurance provides access to the best facilities regardless of location.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What if I'm over 74 and can't get Cigna or Allianz?</h3>
          <p class="text-neutral-600">IMG Global accepts applications up to age 80. Combine IMG with voluntary SSN enrollment for more comprehensive coverage. Some Italy-specific insurers may also accept older applicants—check with a local broker.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Should I maintain coverage in my home country too?</h3>
          <p class="text-neutral-600">If you'll spend significant time in your home country (especially the US), consider maintaining coverage there or choosing an international plan that includes it. Cigna and IMG offer US coverage options. Allianz varies by plan.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Insurance requirements and coverage details change regularly. Verify current requirements with the Italian consulate in your jurisdiction and confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance advice.</p>
    </div>
  </PageShell>
</Layout>
