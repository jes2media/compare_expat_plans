---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: "quick-verdict", title: "Quick Verdict" },
  { id: "comparison", title: "Side-by-Side Comparison" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "img", title: "IMG Global" },
  { id: "cigna", title: "Cigna Global" },
  { id: "pricing", title: "Pricing Comparison" },
  { id: "teacher-details", title: "Teacher Considerations" },
  { id: "best-for", title: "Best For" },
  { id: "faqs", title: "FAQs" },
];

const relatedLinks = [
  { href: "/providers/safetywing", title: "SafetyWing Review" },
  { href: "/providers/img-global", title: "IMG Global Review" },
  { href: "/providers/cigna-global", title: "Cigna Global Review" },
  { href: "/insurance-for/teachers-abroad", title: "Insurance for Teachers Abroad" },
  { href: "/best/international-health-insurance", title: "Best International Insurance" },
];

const mainComparisonColumns = [
  { key: "feature", header: "Feature", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const mainComparisonRows = [
  { feature: "Monthly Cost", safetywing: "$45–85", img: "$150–300", cigna: "$350–500" },
  { feature: "Coverage Limit", safetywing: "$250K", img: "$1M–5M", cigna: "$1M–Unlimited" },
  { feature: "School Year Coverage", safetywing: "Monthly flexibility", img: "Annual plans", cigna: "Annual plans" },
  { feature: "Home Visits", safetywing: "30 days/90 days", img: "Varies by plan", cigna: "Full coverage" },
  { feature: "School Holidays", safetywing: "Included", img: "Included", cigna: "Included" },
  { feature: "Mental Health", safetywing: "Limited", img: "Available", cigna: "Comprehensive" },
  { feature: "Pre-existing Conditions", safetywing: "Not covered", img: "Possible with underwriting", cigna: "Case-by-case" },
  { feature: "Sports/Activities", safetywing: "Adventure sports included", img: "Most covered", cigna: "Full sports coverage" },
  { feature: "Dental Coverage", safetywing: "Emergency only", img: "Add-on available", cigna: "Optional comprehensive" },
];

const pricingColumns = [
  { key: "profile", header: "Profile", isRowHeader: true },
  { key: "safetywing", header: "SafetyWing" },
  { key: "img", header: "IMG Global" },
  { key: "cigna", header: "Cigna Global" },
];

const pricingRows = [
  { profile: "Single teacher, 28yo", safetywing: "$540–1,020/yr", img: "$1,800–3,600/yr", cigna: "$4,200–6,000/yr" },
  { profile: "Single teacher, 35yo", safetywing: "$600–1,140/yr", img: "$2,100–4,200/yr", cigna: "$5,100–7,200/yr" },
  { profile: "Teacher couple, both 30", safetywing: "$1,080–2,040/yr", img: "$3,600–7,200/yr", cigna: "$8,400–12,000/yr" },
  { profile: "Teaching family (2+2)", safetywing: "$1,620–3,060/yr", img: "$5,400–10,800/yr", cigna: "$14,400–20,400/yr" },
];
---

<PageShell
  title="SafetyWing vs IMG vs Cigna: Insurance for Teachers Abroad (2025)"
  description="Compare health insurance for teachers and educators working abroad. Analysis of SafetyWing, IMG Global, and Cigna Global for international school contracts."
  headline="SafetyWing vs IMG vs Cigna: Insurance for Teachers Abroad"
  intro="Teaching abroad offers incredible experiences but requires navigating health insurance that fits academic calendars, school-provided gaps in coverage, and the reality of educator salaries. Here's how SafetyWing, IMG Global, and Cigna Global compare for international teachers and educators."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <!-- Quick Verdict -->
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">SafetyWing</h3>
        <p class="text-primary-700 font-semibold mb-2">Best for Budget-Conscious Teachers</p>
        <p class="text-neutral-700 text-sm">Monthly billing works with teaching contracts. Affordable premiums fit educator salaries. Good for healthy teachers without complex medical needs.</p>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">IMG Global</h3>
        <p class="text-purple-700 font-semibold mb-2">Best Mid-Range Option</p>
        <p class="text-neutral-700 text-sm">Higher coverage limits and more comprehensive benefits. Good for teachers wanting security without premium prices. Solid for those with some health concerns.</p>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Cigna Global</h3>
        <p class="text-green-700 font-semibold mb-2">Best Comprehensive Coverage</p>
        <p class="text-neutral-700 text-sm">Premium coverage for teachers at well-funded international schools. Worth it if employer subsidizes costs or you prioritize top-tier care.</p>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison Table -->
  <section id="comparison" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <!-- SafetyWing Section -->
  <section id="safetywing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">SafetyWing</h2>
    <div class="bg-primary-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-primary-800 mb-4">Key Features for Teachers</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Monthly billing:</strong> Aligns with teaching contracts and payroll cycles</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>No commitment:</strong> Cancel anytime—perfect for contract teachers</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Home country visits:</strong> Coverage for breaks and holidays back home</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Adventure sports:</strong> Covers activities common among active teachers</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 mt-1">✓</span>
          <span><strong>Simple sign-up:</strong> Online application takes minutes, instant coverage</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      SafetyWing's Nomad Insurance fits the financial reality of many teaching positions. At $45–85/month, it's manageable on a teaching salary that might be $1,500–3,500/month in many countries. The monthly billing means you're not locked into year-long commitments if contracts change.
    </p>
    <p class="text-neutral-700">
      The downside: $250K coverage limit is lower than competitors, and there's no coverage for pre-existing conditions. Healthy teachers in their 20s and 30s will find this adequate, but those with ongoing health needs should look elsewhere.
    </p>
  </section>

  <!-- IMG Global Section -->
  <section id="img" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">IMG Global</h2>
    <div class="bg-purple-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-purple-800 mb-4">Key Features for Teachers</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Higher coverage limits:</strong> $1M–5M provides real financial protection</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Mental health options:</strong> Available coverage for teacher stress and burnout</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Pre-existing possibilities:</strong> Some conditions coverable with underwriting</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Dental add-ons:</strong> Option for preventive and routine dental care</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600 mt-1">✓</span>
          <span><strong>Global network:</strong> Access to quality providers in teaching destinations</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      IMG Global offers a middle ground that works well for teachers at established international schools. The premium isn't as eye-watering as Cigna, but coverage is substantially better than SafetyWing. For teachers with some savings or at schools offering insurance stipends, IMG hits a sweet spot.
    </p>
    <p class="text-neutral-700">
      Teaching is stressful, and IMG's mental health coverage matters. Burnout, anxiety about job security, and isolation are real concerns for international educators. Having access to therapy coverage can make the difference between thriving and struggling abroad.
    </p>
  </section>

  <!-- Cigna Global Section -->
  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="bg-green-50 rounded-lg p-6 mb-6">
      <h3 class="text-xl font-semibold text-green-800 mb-4">Key Features for Teachers</h3>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Unlimited coverage:</strong> No worrying about hitting policy limits</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Full home country:</strong> Complete coverage during summers and holidays</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Comprehensive mental health:</strong> Unlimited therapy sessions</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Family coverage:</strong> Excellent for teaching families abroad</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600 mt-1">✓</span>
          <span><strong>Maternity:</strong> Full pregnancy and childbirth coverage</span>
        </li>
      </ul>
    </div>
    <p class="text-neutral-700 mb-4">
      Cigna Global represents the gold standard in international health insurance, and some teachers—particularly at top-tier international schools—get this coverage as part of their benefits package. If your school offers Cigna or subsidizes its cost, don't hesitate.
    </p>
    <p class="text-neutral-700">
      For teachers paying out-of-pocket, Cigna's premiums are significant. A teaching salary of $3,000/month with $500 going to health insurance isn't sustainable for everyone. But for teachers with families, health concerns, or those planning long-term international careers, the investment may be worth it.
    </p>
  </section>

  <!-- CTA Box -->
  <CTABox
    title="Get Teacher Insurance Quotes"
    description="Compare plans from SafetyWing, IMG, and Cigna tailored to international educators."
    buttonText="Compare Plans Now"
    buttonHref="https://www.thimble.com/expat-insurance-quotes"
  />

  <!-- Pricing Comparison -->
  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">
      Teacher salaries vary dramatically by country and school type. These prices assume you're purchasing individually—many international schools provide insurance or stipends that offset costs significantly.
    </p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-500 mt-4">
      *Prices for worldwide coverage excluding US. SafetyWing offers monthly billing; others typically annual.
    </p>
  </section>

  <!-- Teacher Details Section -->
  <section id="teacher-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Key Considerations for Teachers</h2>
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">School-Provided Insurance</h3>
        <p class="text-neutral-700 mb-3">
          Many international schools provide health insurance—but quality varies enormously. Some offer Cigna or Bupa-level coverage; others provide bare-bones local plans that may not meet your needs. Always review what your school offers before purchasing additional coverage.
        </p>
        <p class="text-neutral-700">
          Some teachers layer SafetyWing on top of basic school insurance to fill gaps, particularly for home country visits during breaks. This hybrid approach can be cost-effective.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Contract Timing and Coverage Gaps</h3>
        <p class="text-neutral-700 mb-3">
          Teaching contracts often run August-June, leaving summer gaps where school insurance may lapse. SafetyWing's monthly model handles this naturally—just keep paying during summer. With annual plans from IMG or Cigna, ensure your policy dates align with your actual needs.
        </p>
        <p class="text-neutral-700">
          Teachers between contracts face particular challenges. SafetyWing works well for these transition periods without committing to expensive annual plans while job hunting.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Summer and Holiday Coverage</h3>
        <p class="text-neutral-700 mb-3">
          Teachers travel more than most expats—winter breaks, spring breaks, and summers often mean trips home or adventures abroad. Ensure your plan covers these periods, including time spent in your home country.
        </p>
        <p class="text-neutral-700">
          SafetyWing includes 30 days per 90-day period in your home country. Cigna provides full home country coverage. IMG varies by plan—verify before purchasing if extended home visits are planned.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-800 mb-3">Teacher Burnout and Mental Health</h3>
        <p class="text-neutral-700 mb-3">
          Teaching internationally can be isolating. You're far from family, possibly working in a different language, and may face challenging school environments. Mental health support matters more than many teachers anticipate before moving abroad.
        </p>
        <p class="text-neutral-700">
          Cigna's comprehensive mental health coverage and IMG's therapy options become valuable when you need them. SafetyWing's limited mental health benefits may feel insufficient during difficult periods.
        </p>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Best For</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-3">Choose SafetyWing If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You're young and healthy</li>
          <li>• Budget is a primary concern</li>
          <li>• You want monthly billing flexibility</li>
          <li>• Your school provides basic coverage</li>
          <li>• You're on a 1-year initial contract</li>
          <li>• You need gap coverage between positions</li>
        </ul>
      </div>
      <div class="bg-purple-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-3">Choose IMG If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• You want higher coverage limits</li>
          <li>• Mental health support matters</li>
          <li>• You have some health concerns</li>
          <li>• School offers insurance stipend</li>
          <li>• You want dental options</li>
          <li>• Balance of cost and coverage matters</li>
        </ul>
      </div>
      <div class="bg-green-50 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-3">Choose Cigna If...</h3>
        <ul class="space-y-2 text-neutral-700">
          <li>• School provides or subsidizes it</li>
          <li>• You have a family abroad</li>
          <li>• You're planning long-term career</li>
          <li>• You have pre-existing conditions</li>
          <li>• Comprehensive care is priority</li>
          <li>• Budget isn't the primary constraint</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Should I accept my school's insurance or purchase my own?</h3>
        <p class="text-neutral-700">
          Review the school's plan carefully first. If they offer coverage from a reputable international insurer (Cigna, Bupa, Allianz), it's likely sufficient. If they offer local insurance or a basic plan, consider supplementing with SafetyWing for travel coverage and gap protection.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What happens if I change schools mid-year?</h3>
        <p class="text-neutral-700">
          Personal insurance (SafetyWing, IMG, Cigna) stays with you regardless of employer. If you rely on school insurance, you'll need bridge coverage between positions. SafetyWing's monthly model works well for transitions—just sign up immediately when school coverage ends.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Are school sports and activities covered?</h3>
        <p class="text-neutral-700">
          Most plans cover injuries from school activities including sports coaching, field trips, and extracurriculars. SafetyWing explicitly includes adventure sports. IMG and Cigna cover most activities, but confirm professional duties are included if you're a PE teacher or coach.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">How do I get care during school holidays?</h3>
        <p class="text-neutral-700">
          All three plans cover you during holidays whether you're traveling, visiting home, or staying put. For routine care, try to schedule appointments during school breaks. For emergencies, you're covered anywhere within your plan's geographic scope.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">Can I add my teaching partner or family?</h3>
        <p class="text-neutral-700">
          Yes—all three offer family coverage. SafetyWing has group rates for families. IMG offers family plans with children included. Cigna provides comprehensive family coverage. If both adults teach, some schools offer family coverage through one contract.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="font-semibold text-neutral-800 mb-2">What if I decide to stay permanently in my teaching country?</h3>
        <p class="text-neutral-700">
          Cigna works well for permanent expatriates. IMG's long-term plans can convert to indefinite coverage. SafetyWing is designed for nomads and may not be ideal for permanent residents—check local insurance requirements for long-term visas.
        </p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <aside class="bg-neutral-100 border border-neutral-200 rounded-lg p-6 text-sm text-neutral-600 mb-8">
    <p class="font-semibold mb-2">Disclaimer</p>
    <p>
      Coverage details vary by plan, employer arrangements, and individual circumstances. School-provided insurance terms depend on your specific contract. Always review policy documents and consult with school HR about your coverage options before purchasing additional insurance. This comparison reflects general plan features as of the publication date.
    </p>
  </aside>
</PageShell>
