---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import CTABox from "../../components/CTABox.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";

const title = "Best Health Insurance for Colombia Digital Nomad Visa (2025)";
const description = "Compare top health insurance options for Colombia's Digital Nomad Visa. Expert analysis of Cigna Global, SafetyWing, and local Colombian insurance for remote workers in Medellín and Bogotá.";

const tocItems = [
  { id: "visa-requirements", title: "Visa Insurance Requirements" },
  { id: "quick-comparison", title: "Quick Comparison" },
  { id: "cigna-global", title: "Cigna Global" },
  { id: "safetywing", title: "SafetyWing" },
  { id: "local-colombian", title: "Local Colombian" },
  { id: "coverage-comparison", title: "Coverage Comparison" },
  { id: "pricing", title: "Pricing" },
  { id: "network-access", title: "Network Access" },
  { id: "scenarios", title: "Real-World Scenarios" },
  { id: "verdict", title: "Our Verdict" },
  { id: "faqs", title: "FAQs" },
];

const comparisonColumns = [
  { key: "feature", header: "Feature" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Colombian" },
];

const comparisonRows = [
  { feature: "DNV Acceptance", cigna: "✓ Accepted", safetywing: "✓ Accepted", local: "✓ Accepted" },
  { feature: "Colombia Network", cigna: "Good (private hospitals)", safetywing: "Reimbursement", local: "Extensive" },
  { feature: "Miami Evacuation", cigna: "✓ Included", safetywing: "✓ Included", local: "Varies" },
  { feature: "Pre-existing Conditions", cigna: "Moratorium option", safetywing: "Not covered", local: "After waiting period" },
  { feature: "International Coverage", cigna: "Worldwide", safetywing: "Outside home country", local: "Colombia only" },
  { feature: "Monthly Cost (35yo)", cigna: "$300-480", safetywing: "$69", local: "$80-200" },
  { feature: "Annual Maximum", cigna: "Unlimited", safetywing: "$250,000", local: "COP 500M-2B" },
  { feature: "Best For", cigna: "Comprehensive needs", safetywing: "Budget nomads", local: "Long-term residents" },
];

const coverageColumns = [
  { key: "coverage", header: "Coverage Type" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Colombian" },
];

const coverageRows = [
  { coverage: "Inpatient Hospital", cigna: "100% covered", safetywing: "$250K limit", local: "Plan limits apply" },
  { coverage: "Outpatient Care", cigna: "100% covered", safetywing: "Limited", local: "Included" },
  { coverage: "Emergency Evacuation", cigna: "Unlimited", safetywing: "$100K limit", local: "Varies" },
  { coverage: "Prescription Drugs", cigna: "100% covered", safetywing: "Limited", local: "Included" },
  { coverage: "Dental", cigna: "Optional", safetywing: "Emergency only", local: "Often included" },
  { coverage: "Vision", cigna: "Optional", safetywing: "Not covered", local: "Some plans" },
  { coverage: "Mental Health", cigna: "Full coverage", safetywing: "Limited", local: "Limited" },
  { coverage: "Pregnancy", cigna: "Optional add-on", safetywing: "Limited maternity", local: "After waiting period" },
];

const pricingColumns = [
  { key: "age", header: "Age Group" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Colombian" },
];

const pricingRows = [
  { age: "25-30", cigna: "$220-350/month", safetywing: "$69/month", local: "$60-150/month" },
  { age: "30-35", cigna: "$280-440/month", safetywing: "$69/month", local: "$80-180/month" },
  { age: "40-45", cigna: "$400-620/month", safetywing: "$99/month", local: "$120-280/month" },
  { age: "50-55", cigna: "$580-900/month", safetywing: "$148/month", local: "$180-400/month" },
];

const networkColumns = [
  { key: "location", header: "Location" },
  { key: "cigna", header: "Cigna Global" },
  { key: "safetywing", header: "SafetyWing" },
  { key: "local", header: "Local Colombian" },
];

const networkRows = [
  { location: "Medellín", cigna: "Clínica Las Américas, Pablo Tobón", safetywing: "Reimbursement", local: "Full network" },
  { location: "Bogotá", cigna: "Fundación Santa Fe, Country", safetywing: "Reimbursement", local: "Full network" },
  { location: "Cartagena", cigna: "Limited direct billing", safetywing: "Reimbursement", local: "Good coverage" },
  { location: "Cali", cigna: "Limited direct billing", safetywing: "Reimbursement", local: "Good coverage" },
  { location: "Miami (Evacuation)", cigna: "Full access", safetywing: "Covered", local: "May not cover" },
  { location: "International", cigna: "Worldwide", safetywing: "Outside home country", local: "Not covered" },
];
---

<Layout title={title} description={description}>
  <PageShell
    title={title}
    subtitle="Expert comparison for Colombia's Digital Nomad Visa (Visa V)"
    heroImage="/images/countries/colombia-hero-bg.png"
    tocItems={tocItems}
  >
    <section id="visa-requirements" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Colombia Digital Nomad Visa Insurance Requirements</h2>

      <p class="text-neutral-700 mb-4">
        Colombia's Digital Nomad Visa (Visa tipo V - Nómada Digital) allows remote workers to live in Colombia for up to 2 years. Medellín has become one of the world's top digital nomad destinations, known for its perfect climate, low cost of living, and thriving expat community.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <h3 class="font-semibold text-blue-900 mb-2">Key Insurance Requirements</h3>
        <ul class="text-blue-800 space-y-1">
          <li>• Health insurance is mandatory for visa application</li>
          <li>• Must cover medical expenses in Colombia</li>
          <li>• Minimum income requirement: ~$3,000/month (3x minimum wage)</li>
          <li>• Policy must be valid for visa duration</li>
          <li>• International insurance accepted</li>
          <li>• Evacuation coverage to Miami recommended (3-hour flight)</li>
        </ul>
      </div>

      <p class="text-neutral-700 mb-4">
        Colombia has excellent private healthcare in major cities—Medellín's hospitals are world-renowned for medical tourism. However, for complex cases, Miami is a short flight away. Any insurance should include medical evacuation coverage.
      </p>

      <p class="text-neutral-700">
        The visa is valid for 2 years and can be renewed. Many nomads start with international insurance and consider local Colombian coverage (EPS or prepagada) for longer stays.
      </p>
    </section>

    <section id="quick-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Quick Comparison: Insurance Options for Colombia DNV</h2>

      <p class="text-neutral-700 mb-6">
        Digital Nomad Visa holders can choose from international insurers, nomad-specific plans, or local Colombian options:
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Cigna Global</h2>

      <p class="text-neutral-700 mb-4">
        Cigna Global offers comprehensive international coverage with good networks in Colombia's major cities. Their direct billing at top Colombian hospitals and Miami evacuation coverage make them a premium choice.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Direct billing at top Colombian hospitals</li>
            <li>• Miami evacuation included</li>
            <li>• Worldwide coverage for travel</li>
            <li>• Pre-existing condition options</li>
            <li>• Comprehensive outpatient coverage</li>
            <li>• 24/7 support with Spanish speakers</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• More expensive than local options</li>
            <li>• May be overkill for young, healthy nomads</li>
            <li>• Direct billing limited outside major cities</li>
            <li>• Colombian healthcare is affordable out-of-pocket</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get a Cigna Global Quote"
        description="Comprehensive coverage with Colombian and Miami networks."
        buttonText="Get Quote"
        buttonHref="/go/cigna-global"
      />
    </section>

    <section id="safetywing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">SafetyWing Nomad Insurance</h2>

      <p class="text-neutral-700 mb-4">
        SafetyWing is extremely popular among digital nomads in Medellín. At $69/month, it meets visa requirements and provides adequate coverage for the typically young, healthy nomad demographic.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Very affordable ($69/month under 40)</li>
            <li>• Widely used for Colombia DNV</li>
            <li>• Medical evacuation included</li>
            <li>• Month-to-month flexibility</li>
            <li>• Popular in Medellín nomad community</li>
            <li>• Easy sign-up process</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No direct billing—pay and claim</li>
            <li>• Pre-existing conditions not covered</li>
            <li>• $250 deductible per incident</li>
            <li>• $250K coverage limit</li>
            <li>• Limited outpatient coverage</li>
          </ul>
        </div>
      </div>

      <CTABox
        title="Get SafetyWing Coverage"
        description="Budget nomad insurance starting at $69/month."
        buttonText="Get Quote"
        buttonHref="/go/safetywing"
      />
    </section>

    <section id="local-colombian" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Local Colombian Insurance</h2>

      <p class="text-neutral-700 mb-4">
        Colombia has two types of health coverage: EPS (mandatory public system, ~$50/month) and Medicina Prepagada (private plans, $80-200/month). For long-term residents, local insurance offers excellent value.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-2">Strengths</h3>
          <ul class="text-green-800 space-y-1 text-sm">
            <li>• Extensive Colombian network</li>
            <li>• Affordable premiums</li>
            <li>• Direct billing everywhere</li>
            <li>• Dental often included</li>
            <li>• Spanish support (immersion!)</li>
            <li>• Pre-existing conditions after waiting period</li>
          </ul>
        </div>
        <div class="bg-amber-50 p-4 rounded-lg">
          <h3 class="font-semibold text-amber-900 mb-2">Considerations</h3>
          <ul class="text-amber-800 space-y-1 text-sm">
            <li>• No international coverage</li>
            <li>• May not cover Miami evacuation</li>
            <li>• Spanish-language processes</li>
            <li>• Requires Colombian bank account for some</li>
            <li>• Waiting periods for some conditions</li>
          </ul>
        </div>
      </div>

      <div class="bg-neutral-50 p-4 rounded-lg">
        <p class="text-neutral-700 text-sm">
          <strong>Popular options:</strong> Sura (Medicina Prepagada), Colsanitas, Sanitas, Medisanitas. Prepagada plans range from $80-200/month and provide private hospital access throughout Colombia.
        </p>
      </div>
    </section>

    <section id="coverage-comparison" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Coverage Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Here's how coverage compares across the main options:
      </p>

      <ComparisonTable columns={coverageColumns} rows={coverageRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Colombian private healthcare is excellent and affordable. The main value of international insurance is evacuation coverage and worldwide protection—not necessarily better Colombian care.
      </p>
    </section>

    <section id="pricing" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Pricing Comparison</h2>

      <p class="text-neutral-700 mb-6">
        Local Colombian insurance offers the best value for in-country coverage:
      </p>

      <ComparisonTable columns={pricingColumns} rows={pricingRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Colombian healthcare is so affordable that some nomads pay out-of-pocket for routine care (GP visits ~$20-40) and keep SafetyWing only for emergencies and evacuation.
      </p>
    </section>

    <section id="network-access" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Network Access in Colombia</h2>

      <p class="text-neutral-700 mb-6">
        Colombia's major cities have excellent private hospitals:
      </p>

      <ComparisonTable columns={networkColumns} rows={networkRows} />

      <p class="text-neutral-600 text-sm mt-4">
        Medellín's hospitals (Las Américas, Pablo Tobón Uribe) are internationally accredited. Bogotá's Fundación Santa Fe is world-class. Local insurance provides the broadest network access.
      </p>
    </section>

    <section id="scenarios" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Real-World Scenarios</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 1: Young Nomad in Medellín</h3>
          <p class="text-neutral-600 mb-3">28-year-old remote developer, healthy, enjoying Medellín's lifestyle.</p>
          <p class="text-green-700 font-medium">Recommendation: SafetyWing</p>
          <p class="text-neutral-600 text-sm">SafetyWing is the Medellín nomad standard. At $69/month, it meets visa requirements and covers emergencies. Pay out-of-pocket for cheap local GP visits (~$25). Most nomads in your coworking space use SafetyWing.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 2: Long-term Resident (2+ Years)</h3>
          <p class="text-neutral-600 mb-3">35-year-old planning to stay in Colombia indefinitely, building local life.</p>
          <p class="text-green-700 font-medium">Recommendation: Sura Medicina Prepagada</p>
          <p class="text-neutral-600 text-sm">For long-term residents, local prepagada offers the best value—full Colombian network, dental included, direct billing everywhere. Add travel insurance for international trips. You're living locally; insure locally.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 3: Frequent Traveler Using Colombia as Base</h3>
          <p class="text-neutral-600 mb-3">32-year-old who spends 6 months in Colombia, travels Latin America rest of year.</p>
          <p class="text-amber-700 font-medium">Recommendation: SafetyWing or Cigna Global</p>
          <p class="text-neutral-600 text-sm">SafetyWing covers you throughout Latin America at $69/month. Cigna is better if you want comprehensive coverage and direct billing in multiple countries. Choose based on budget and coverage needs.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 4: Family with Children</h3>
          <p class="text-neutral-600 mb-3">40-year-old couple with two young children, relocating to Bogotá.</p>
          <p class="text-green-700 font-medium">Recommendation: Cigna Global or local prepagada</p>
          <p class="text-neutral-600 text-sm">Families need reliable pediatric care. Cigna provides English-speaking access and Miami evacuation for peace of mind. Local prepagada (Colsanitas, Sanitas) is more affordable with excellent pediatric networks if you're comfortable in Spanish.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Scenario 5: Pre-existing Health Condition</h3>
          <p class="text-neutral-600 mb-3">45-year-old with managed chronic condition, needs regular specialist care.</p>
          <p class="text-amber-700 font-medium">Recommendation: Local prepagada + Cigna (moratorium)</p>
          <p class="text-neutral-600 text-sm">Local prepagada covers pre-existing conditions after waiting period (usually 6-12 months). Colombian specialists are excellent and affordable. Add Cigna with moratorium for international coverage and Miami evacuation for serious issues.</p>
        </div>
      </div>
    </section>

    <section id="verdict" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-4">Our Verdict</h2>

      <p class="text-neutral-700 mb-6">
        For most digital nomads, <strong>SafetyWing</strong> is the practical choice—affordable, meets visa requirements, and covers emergencies. <strong>Local prepagada</strong> offers better value for long-term residents comfortable with Spanish. <strong>Cigna Global</strong> is worth it for families, those with health conditions, or anyone wanting premium coverage with Miami evacuation.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose SafetyWing If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Young and healthy</li>
            <li>• Budget-conscious</li>
            <li>• Typical nomad lifestyle</li>
            <li>• OK with reimbursement claims</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Local Prepagada If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Long-term Colombia resident</li>
            <li>• Comfortable with Spanish</li>
            <li>• Want direct billing</li>
            <li>• Building local life</li>
          </ul>
        </div>
        <div class="bg-primary-50 p-4 rounded-lg border border-primary-200">
          <h3 class="font-semibold text-primary-900 mb-2">Choose Cigna Global If...</h3>
          <ul class="text-primary-800 text-sm space-y-1">
            <li>• Family with children</li>
            <li>• Pre-existing conditions</li>
            <li>• Want Miami evacuation</li>
            <li>• Prefer English service</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2 class="text-2xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing accepted for the Colombia Digital Nomad Visa?</h3>
          <p class="text-neutral-600">Yes. Many nomads successfully use SafetyWing for their Colombia DNV applications. The $250,000 coverage exceeds typical requirements. Request a visa letter from SafetyWing if needed.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">How good is Colombian healthcare really?</h3>
          <p class="text-neutral-600">Excellent. Colombia is a major medical tourism destination. Medellín's hospitals are JCI-accredited. A specialist visit costs $30-50, and quality is comparable to US/Europe. The main barrier is Spanish—bring a translator or use international departments.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What's the difference between EPS and Prepagada?</h3>
          <p class="text-neutral-600">EPS is the mandatory public system (~$50/month)—decent care but long waits. Prepagada is private supplemental insurance ($80-200/month)—better hospitals, shorter waits, direct billing. Most expats get prepagada for private hospital access.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Should I worry about evacuations to Miami?</h3>
          <p class="text-neutral-600">For most conditions, no—Colombian hospitals handle them well. Miami evacuation matters for very complex cases (major trauma, rare cancers, transplants). SafetyWing and Cigna both include evacuation coverage. Miami is a 3-hour flight from Medellín.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">Can I get local insurance as a digital nomad?</h3>
          <p class="text-neutral-600">Yes. With a cédula de extranjería (foreign ID card from your visa), you can sign up for prepagada plans. Some insurers accept visa holders directly. Sura and Colsanitas are expat-friendly. Spanish proficiency helps with the paperwork.</p>
        </div>

        <div class="bg-white border border-neutral-200 rounded-lg p-5">
          <h3 class="font-semibold text-neutral-800 mb-2">What about altitude sickness in Bogotá?</h3>
          <p class="text-neutral-600">Bogotá is at 2,640m (8,660ft). Some people experience mild symptoms for a few days. All insurance covers altitude-related issues as they're not pre-existing. Medellín (1,500m) is lower and has no altitude concerns for most people.</p>
        </div>
      </div>
    </section>

    <div class="bg-neutral-100 p-4 rounded-lg text-sm text-neutral-600">
      <p><strong>Disclaimer:</strong> Colombia visa requirements and healthcare options can change. Verify current Digital Nomad Visa requirements with Colombian immigration (Migración Colombia). Confirm policy details directly with insurers before purchasing. This comparison is for informational purposes and does not constitute insurance or immigration advice.</p>
    </div>
  </PageShell>
</Layout>
