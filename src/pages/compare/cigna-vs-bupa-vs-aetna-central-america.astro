---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'central-america-details', text: 'Central America Details', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/countries/costa-rica/insurance', text: 'Costa Rica Insurance Guide' },
  { href: '/countries/panama/insurance', text: 'Panama Insurance Guide' },
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/bupa-global', text: 'Bupa Global Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'Costa Rica Network', cigna: 'Strong', bupa: 'Good', aetna: 'Strong' },
  { feature: 'Panama Network', cigna: 'Strong', bupa: 'Good', aetna: 'Good' },
  { feature: 'Guatemala Network', cigna: 'Moderate', bupa: 'Moderate', aetna: 'Limited' },
  { feature: 'Other Central America', cigna: 'Limited', bupa: 'Limited', aetna: 'Limited' },
  { feature: 'US Evacuation', cigna: 'Miami/Houston', bupa: 'Miami', aetna: 'Miami/Houston' },
  { feature: 'Spanish Support', cigna: 'Yes', bupa: 'Yes', aetna: 'Yes' },
  { feature: 'Direct Billing', cigna: 'Good in CR/Panama', bupa: 'Moderate', aetna: 'Good in CR/Panama' },
  { feature: 'Regional Specialists', cigna: 'Via US evacuation', bupa: 'Via US evacuation', aetna: 'Via US evacuation' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Individual (40, Costa Rica)', cigna: '\$320/mo', bupa: '\$360/mo', cigna: '\$290/mo' },
  { profile: 'Individual (40, Panama)', cigna: '\$310/mo', bupa: '\$350/mo', aetna: '\$280/mo' },
  { profile: 'Couple (50s)', cigna: '\$680/mo', bupa: '\$760/mo', aetna: '\$620/mo' },
  { profile: 'Retiree (65)', cigna: '\$550/mo', bupa: '\$620/mo', aetna: '\$500/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna for Central America | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Aetna International for Central America. Expert analysis of networks in Costa Rica, Panama, Guatemala, and US evacuation options."
  headline="Cigna vs Bupa vs Aetna: Central America"
  subheadline="Complete comparison for expats in Central America—covering networks in Costa Rica, Panama, Guatemala, US evacuation, and regional healthcare options."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall</p>
        <p class="text-neutral-700 text-sm mb-4">Strong networks in Costa Rica and Panama with excellent US evacuation coordination. Best balance of regional coverage and comprehensive benefits.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Premium Coverage</p>
        <p class="text-neutral-700 text-sm mb-4">Comprehensive benefits with good regional coverage. Premium option for those wanting the highest level of care coordination.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 mb-3">Best Value</p>
        <p class="text-neutral-700 text-sm mb-4">Most affordable with strong Costa Rica/Panama networks. Best for budget-conscious expats in major Central American hubs.</p>
        <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Strong Networks</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">US Evacuation</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Spanish Support</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers excellent coverage for Central America with strong networks in Costa Rica and Panama—the two countries with the most developed private healthcare. Direct billing is available at major hospitals in San Jose, Panama City, and other key cities. Spanish-speaking support staff understand regional healthcare systems.</p>

    <p class="text-neutral-700 mb-4">For conditions requiring specialists not available locally, evacuation to Miami or Houston is well-coordinated. Cigna's US network integration means seamless care if evacuated stateside. Coverage in Guatemala is moderate; other Central American countries (Honduras, Nicaragua, El Salvador, Belize) have limited direct billing but full reimbursement coverage.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Central America Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Strong Costa Rica/Panama networks</li>
          <li>• Excellent US evacuation</li>
          <li>• Spanish support available</li>
          <li>• Good direct billing</li>
          <li>• Unlimited coverage</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited in smaller countries</li>
          <li>• Premium pricing</li>
          <li>• Some rural areas thin</li>
          <li>• May need US evacuation for complex care</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Premium Coverage</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Care Coordination</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Global Network</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global provides comprehensive coverage for Central America with good networks in Costa Rica and Panama. While slightly smaller than Cigna's regional network, Bupa's care coordination and case management are excellent—valuable when navigating healthcare systems in developing countries.</p>

    <p class="text-neutral-700 mb-4">Spanish-speaking support helps with local arrangements. Evacuation to the US (primarily Miami) is efficient for serious conditions. Bupa's global network means coverage is strong if you travel beyond Central America. Premium pricing reflects premium service and comprehensive benefits including preventive care and wellness programs.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Central America Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Excellent care coordination</li>
          <li>• Spanish support</li>
          <li>• Strong US evacuation</li>
          <li>• Comprehensive benefits</li>
          <li>• Global travel coverage</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premium cost</li>
          <li>• Network smaller than Cigna</li>
          <li>• Limited beyond CR/Panama</li>
          <li>• May exceed needs</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">US Connection</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Competitive Pricing</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International offers the most competitive pricing for Central America while maintaining strong networks in Costa Rica and Panama. Their US roots mean excellent coordination for evacuations to Miami or Houston. The CVS Health integration provides additional pharmacy benefits when stateside.</p>

    <p class="text-neutral-700 mb-4">Coverage in Guatemala is more limited than competitors, and smaller Central American countries are primarily reimbursement-based. For expats based in Costa Rica or Panama who want solid coverage without premium pricing, Aetna provides excellent value. Spanish support is available for regional coordination.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Central America Strengths</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Most affordable option</li>
          <li>• Strong CR/Panama networks</li>
          <li>• Excellent US evacuation</li>
          <li>• CVS Health benefits</li>
          <li>• Spanish support</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Guatemala limited</li>
          <li>• Smaller countries thin</li>
          <li>• \$8M cap (vs unlimited)</li>
          <li>• Less comprehensive than others</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Aetna Quote</a>
  </section>

  <CTABox
    title="Get Central America Coverage Quotes"
    description="Compare pricing and networks for your specific Central American destination."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">Monthly premiums for Central American coverage:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Pricing is indicative for comprehensive inpatient + outpatient coverage including US evacuation. Central America generally costs less than US coverage. Actual premiums depend on age, health history, and specific country.</p>
  </section>

  <section id="central-america-details" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Central America Details</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Strong Healthcare (Direct Billing)</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Costa Rica - CIMA, Clinica Biblica</li>
          <li>• Panama - Punta Pacifica, Hospital Nacional</li>
          <li>• Guatemala City - Private hospitals</li>
          <li>• San Salvador - Select facilities</li>
        </ul>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Limited Coverage (Reimbursement)</h3>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• Honduras - Tegucigalpa only</li>
          <li>• Nicaragua - Limited facilities</li>
          <li>• Belize - Basic only, US evacuation</li>
          <li>• Rural areas throughout region</li>
        </ul>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">Country Healthcare Quality</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Costa Rica</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Excellent private healthcare</li>
            <li>• Medical tourism destination</li>
            <li>• JCI-accredited hospitals</li>
            <li>• English widely spoken</li>
            <li>• Strong network options</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Panama</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Johns Hopkins affiliate</li>
            <li>• Good private facilities</li>
            <li>• Panama City focus</li>
            <li>• US-trained doctors</li>
            <li>• Growing medical tourism</li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Other Countries</h4>
          <ul class="text-blue-700 text-sm space-y-1">
            <li>• Guatemala - Capital only</li>
            <li>• El Salvador - Limited</li>
            <li>• Honduras - Basic</li>
            <li>• Nicaragua - Very limited</li>
            <li>• US evacuation important</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the strongest regional networks</li>
          <li>• Unlimited coverage matters</li>
          <li>• Based in Costa Rica or Panama</li>
          <li>• US evacuation coordination is important</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• Premium coverage and service are worth the cost</li>
          <li>• Care coordination is valuable</li>
          <li>• You travel beyond Central America</li>
          <li>• Comprehensive wellness benefits appeal</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Aetna International if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Budget is the priority</li>
          <li>• Based in Costa Rica or Panama</li>
          <li>• US connection is valuable</li>
          <li>• Good coverage at lower cost appeals</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Is Costa Rica healthcare really good enough to avoid US evacuation?</h3>
        <p class="text-neutral-700">For most conditions, yes. Costa Rica has JCI-accredited hospitals with excellent outcomes. Complex cancer treatment, organ transplants, or rare conditions may still warrant US evacuation. Most expats handle routine and moderate care locally without issues.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does evacuation to the US work from Central America?</h3>
        <p class="text-neutral-700">For serious conditions, insurers arrange air ambulance or medical escort on commercial flights to Miami or Houston—typically 2-4 hours flight time. Coordination includes ground transport on both ends and receiving hospital arrangements. Process is well-established from the region.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What about coverage in smaller Central American countries?</h3>
        <p class="text-neutral-700">Honduras, Nicaragua, El Salvador, and Belize have limited direct billing networks. Coverage exists but often requires upfront payment and reimbursement claims. For serious conditions, plan on evacuation to Costa Rica, Panama, or the US. Always carry emergency funds.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Do insurers have Spanish-speaking support for Central America?</h3>
        <p class="text-neutral-700">Yes, all three insurers offer Spanish support. This helps with local hospital coordination, claims assistance, and navigating regional healthcare systems. While many Costa Rican and Panamanian doctors speak English, Spanish support is valuable throughout the region.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Central American coverage, networks, and healthcare quality vary significantly by country and city. This comparison represents typical coverage—actual options depend on your specific location. Always verify network coverage and facility quality in your destination before enrolling.</p>
  </div>
</PageShell>
