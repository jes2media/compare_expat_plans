---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Allianz vs SafetyWing: Best International Health Insurance for the Baltic States";
const description = "Compare Cigna Global, Allianz Care, and SafetyWing for expats in the Baltic region. Coverage analysis for Estonia, Latvia, and Lithuania including digital nomads and tech workers.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mainComparisonRows = [
  { feature: 'Baltic Network', cigna: 'Good', allianz: 'Good', safetywing: 'Claims-based' },
  { feature: 'EU Coverage', cigna: 'Comprehensive', allianz: 'Comprehensive', safetywing: 'Global' },
  { feature: 'Mental Health', cigna: 'Excellent', allianz: 'Good', safetywing: 'Limited' },
  { feature: 'Digital Nomad Friendly', cigna: 'Good', allianz: 'Flexible', safetywing: 'Excellent' },
  { feature: 'E-Residency Compatible', cigna: 'Yes', allianz: 'Yes', safetywing: 'Yes' },
  { feature: 'Contract Flexibility', cigna: 'Annual', allianz: '6-month min', safetywing: 'Monthly' },
  { feature: 'Starting Price', cigna: '$$$', allianz: '$$-$$$', safetywing: '$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Unlimited options', allianz: 'Full coverage', safetywing: 'Up to $250K' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', allianz: 'Comprehensive', safetywing: 'Emergency only' },
  { coverage: 'Mental Health', cigna: 'Full coverage', allianz: 'Annual limits', safetywing: 'Limited' },
  { coverage: 'Preventive Care', cigna: 'Included', allianz: 'Available', safetywing: 'Not included' },
  { coverage: 'Dental', cigna: 'Optional add-on', allianz: 'Optional add-on', safetywing: 'Emergency only' },
  { coverage: 'Home Country Cover', cigna: 'Included', allianz: 'Included', safetywing: 'Limited' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const pricingRows = [
  { profile: 'Digital nomad, 30, Tallinn', cigna: '$3,000-4,200/yr', allianz: '$2,400-3,400/yr', safetywing: '$500-650/yr' },
  { profile: 'Tech worker, 35, Riga', cigna: '$3,500-4,800/yr', allianz: '$2,800-3,900/yr', safetywing: '$600-780/yr' },
  { profile: 'Professional, 45, Vilnius', cigna: '$5,000-6,800/yr', allianz: '$4,000-5,500/yr', safetywing: '$780-1,000/yr' },
  { profile: 'Family of 4, Estonia', cigna: '$11,000-15,000/yr', allianz: '$8,500-11,500/yr', safetywing: '$1,900-2,500/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'baltics-considerations', text: 'Baltic Region Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Europe', href: '/insurance-for/europe' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most comprehensive coverage with excellent mental health support, full preventive care, and premium benefits for long-term Baltic residency.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at competitive pricing, with flexibility that works well for tech workers and professionals in the Baltic startup scene.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-purple-800 text-sm">You're a digital nomad using Estonia's e-Residency or exploring the Baltic tech scene, needing affordable basic coverage with maximum flexibility.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>The Baltic states—Estonia, Latvia, and Lithuania—have emerged as attractive destinations for digital nomads, tech workers, and entrepreneurs. Estonia's e-Residency program and the region's tech-forward culture draw internationally mobile professionals. Insurance needs range from basic nomad coverage to comprehensive family plans.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers the most comprehensive coverage for Baltic expats, with excellent mental health benefits and full preventive care. Their EU-wide coverage supports those who split time between Baltic states and other European destinations.</p>

      <h3>Strengths for Baltic Expats</h3>
      <ul>
        <li>Excellent mental health coverage for remote work isolation</li>
        <li>Comprehensive EU-wide coverage</li>
        <li>Full preventive care included</li>
        <li>Strong hospital networks in Baltic capitals</li>
        <li>24/7 multilingual support</li>
        <li>Home country coverage for visits</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—highest among the three</li>
        <li>Annual commitment required</li>
        <li>May exceed needs for short-term nomads</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid comprehensive coverage at competitive pricing, with flexibility that suits the Baltic tech scene. Their 6-month minimum works well for those testing the region before committing long-term.</p>

      <h3>Strengths for Baltic Expats</h3>
      <ul>
        <li>Competitive pricing for comprehensive coverage</li>
        <li>6-month minimum suits exploration phase</li>
        <li>Good EU-wide coverage</li>
        <li>Mental health coverage with annual limits</li>
        <li>Monthly payment options</li>
        <li>Works with e-Residency arrangements</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions have annual limits</li>
        <li>Network smaller than Cigna in some areas</li>
        <li>Some preventive care requires higher tiers</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing is extremely popular among digital nomads in the Baltics, offering affordable monthly coverage that aligns with the flexible lifestyle. Their remote-first approach matches the region's digital culture.</p>

      <h3>Strengths for Baltic Expats</h3>
      <ul>
        <li>Most affordable option by far</li>
        <li>Monthly subscription—perfect for nomads</li>
        <li>Remote-first company culture alignment</li>
        <li>Global coverage for mobile workers</li>
        <li>Simple enrollment and management</li>
        <li>Popular in Baltic digital nomad community</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Emergency-only outpatient coverage</li>
        <li>Limited mental health—gap for isolated remote workers</li>
        <li>No preventive care</li>
        <li>$250K limit may concern some</li>
        <li>Claims-based—no direct billing</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Baltic expats should consider mental health coverage (remote work isolation is common), comprehensive outpatient for ongoing health needs, and EU-wide coverage for regional travel.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>The Baltics offer relatively affordable cost of living, making SafetyWing's budget pricing attractive. However, those with higher incomes from remote work can afford comprehensive coverage from Cigna or Allianz.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates and vary by specific country, age, health history, and coverage level. EU citizens may have public healthcare access through bilateral agreements.</p>
    </section>

    <section id="baltics-considerations" class="mb-12">
      <h2>Baltic Region Considerations</h2>

      <h3>Estonia's E-Residency</h3>
      <p>Estonia's e-Residency program attracts digital entrepreneurs worldwide. E-Residency provides business registration, not residency—you still need separate visa/residency arrangements and health insurance. All three providers work for e-Residents establishing Baltic presence.</p>

      <h3>Digital Nomad Visas</h3>
      <p>Estonia offers digital nomad visas; Latvia and Lithuania have similar programs. These require health insurance coverage. SafetyWing is accepted for most nomad visas; comprehensive options from Cigna or Allianz exceed requirements.</p>

      <h3>Baltic Tech Scene</h3>
      <p>Tallinn, Riga, and Vilnius have thriving tech ecosystems. Startups often employ international workers. Some provide health insurance; others expect employees to arrange their own. Verify your employer's provision before purchasing individual coverage.</p>

      <h3>Remote Work Isolation</h3>
      <p>Remote work in the Baltics—particularly during dark winters—can be isolating. Mental health support matters. Cigna's excellent coverage addresses this need. SafetyWing's limited mental health is a significant gap for remote workers.</p>

      <h3>EU Healthcare Access</h3>
      <p>EU/EEA citizens can access public healthcare through EHIC/GHIC. Non-EU citizens typically need private insurance. Even with public access, private insurance provides faster care and English-speaking providers in countries where language can be a barrier.</p>

      <h3>Winter Health</h3>
      <p>Baltic winters are cold and dark—Seasonal Affective Disorder (SAD), vitamin D deficiency, and cold-related health issues are common. Access to mental health support and comprehensive outpatient care helps manage these seasonal challenges.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Long-term Baltic residents</li>
            <li>• Those prioritizing mental health</li>
            <li>• Families in the Baltics</li>
            <li>• Higher-earning remote workers</li>
            <li>• Tech executives</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Tech workers testing the region</li>
            <li>• E-Residency entrepreneurs</li>
            <li>• Value-conscious professionals</li>
            <li>• Those wanting flexibility</li>
            <li>• Startup employees</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Digital nomads</li>
            <li>• Short-term Baltic stays</li>
            <li>• Budget-conscious nomads</li>
            <li>• Young remote workers</li>
            <li>• Those exploring the region</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does Estonia's e-Residency include health insurance?</h3>
          <p class="text-neutral-700">No. E-Residency provides digital business registration only—not residency, not healthcare. You need separate visa arrangements and health insurance. All three providers work for e-Residents living in or visiting the Baltics.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is SafetyWing accepted for Baltic digital nomad visas?</h3>
          <p class="text-neutral-700">Generally yes. SafetyWing meets minimum requirements for most digital nomad visas. However, check specific visa requirements—some may require higher coverage levels that comprehensive providers offer.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How is healthcare quality in the Baltic states?</h3>
          <p class="text-neutral-700">Healthcare quality is good in Baltic capitals (Tallinn, Riga, Vilnius) with modern facilities. Smaller cities have more limited options. Private clinics often have English-speaking staff. Public healthcare may have longer waits.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should I prioritize mental health coverage for remote work?</h3>
          <p class="text-neutral-700">Consider it seriously. Remote work isolation, particularly during dark Baltic winters, affects mental health. SAD, loneliness, and burnout are common. Cigna's excellent coverage or Allianz's good support matter more than SafetyWing's limited offering.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do Baltic tech companies provide health insurance?</h3>
          <p class="text-neutral-700">Larger tech companies often provide health benefits. Startups vary—some offer coverage, others expect employees to arrange their own. Verify what your employer provides before purchasing individual insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does coverage work across all three Baltic states?</h3>
          <p class="text-neutral-700">Yes, all three providers offer EU-wide or worldwide coverage. If you travel between Estonia, Latvia, and Lithuania—or to other EU countries—your coverage works seamlessly throughout the region.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
