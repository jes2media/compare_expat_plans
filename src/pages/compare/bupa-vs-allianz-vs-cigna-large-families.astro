---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Bupa vs Allianz vs Cigna: Best International Health Insurance for Large Families";
const description = "Compare Bupa Global, Allianz Care, and Cigna Global for large families with 3+ children living abroad. Coverage analysis for family policies, pediatric care, and multi-child discounts.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
];

const mainComparisonRows = [
  { feature: 'Family Plan Options', bupa: 'Comprehensive', cigna: 'Comprehensive', allianz: 'Comprehensive' },
  { feature: 'Child Pricing', bupa: 'Per child', allianz: 'Per child', cigna: 'Per child' },
  { feature: 'Pediatric Care', bupa: 'Excellent', allianz: 'Comprehensive', cigna: 'Excellent' },
  { feature: 'Mental Health (Parents)', bupa: 'Unlimited', allianz: 'Annual limits', cigna: 'Excellent' },
  { feature: 'Vaccinations', bupa: 'Comprehensive', allianz: 'Available', cigna: 'Included' },
  { feature: 'Maternity (Future)', bupa: 'After 12 months', allianz: 'After 12 months', cigna: 'After 12 months' },
  { feature: 'Starting Price (Family 6)', bupa: '$$$', allianz: '$$-$$$', cigna: '$$$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
];

const coverageRows = [
  { coverage: 'Inpatient', bupa: 'Full coverage', cigna: 'Unlimited options', allianz: 'Full coverage' },
  { coverage: 'Outpatient', bupa: 'Comprehensive', cigna: 'Comprehensive', allianz: 'Comprehensive' },
  { coverage: 'Well-Child Visits', bupa: 'Included', cigna: 'Included', allianz: 'Available' },
  { coverage: 'Pediatric Dental', bupa: 'Optional add-on', cigna: 'Optional add-on', allianz: 'Optional add-on' },
  { coverage: 'Mental Health', bupa: 'Unlimited (all)', cigna: 'Full (all)', allianz: 'Limited (all)' },
  { coverage: 'Vaccinations', bupa: 'All schedules', cigna: 'Included', allianz: 'Available' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'allianz', header: 'Allianz Care' },
  { key: 'cigna', header: 'Cigna Global' },
];

const pricingRows = [
  { profile: '2 adults + 3 children', bupa: '$18,000-24,000/yr', allianz: '$14,000-19,000/yr', cigna: '$17,000-23,000/yr' },
  { profile: '2 adults + 4 children', bupa: '$21,000-28,000/yr', allianz: '$16,500-22,000/yr', cigna: '$20,000-27,000/yr' },
  { profile: '2 adults + 5 children', bupa: '$24,000-32,000/yr', allianz: '$19,000-25,500/yr', cigna: '$23,000-31,000/yr' },
  { profile: 'With dental for all', bupa: '+$3,500-5,500/yr', allianz: '+$2,800-4,500/yr', cigna: '+$3,200-5,000/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'allianz-care', text: 'Allianz Care', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'large-family-considerations', text: 'Large Family Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Families', href: '/insurance-for/families' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'Allianz Care Review', href: '/providers/allianz' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-blue-800 text-sm">You want the most comprehensive pediatric coverage with unlimited mental health for stressed parents, comprehensive vaccinations, and premium care access for the whole family.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Allianz Care If...</h3>
          <p class="text-green-800 text-sm">You want solid comprehensive coverage at the most competitive pricing for large families, with flexibility and payment options that help manage substantial family healthcare costs.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-purple-800 text-sm">You want excellent comprehensive coverage with strong pediatric networks, excellent mental health support, and robust global coverage for internationally mobile families.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>Large families (3+ children) have significant health insurance needs: multiple pediatric checkups, vaccinations across age groups, potential emergencies, and stressed parents managing complex household logistics. Insurance costs multiply with each family member, making value and comprehensive family coverage essential.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global offers the most comprehensive coverage for large families, with unlimited mental health sessions (critical for stressed parents), comprehensive pediatric care, and full vaccination coverage for children of all ages.</p>

      <h3>Strengths for Large Families</h3>
      <ul>
        <li>Unlimited mental health for parents managing family stress</li>
        <li>Comprehensive well-child visits for all children</li>
        <li>Full vaccination coverage across all schedules</li>
        <li>Premium pediatric networks worldwide</li>
        <li>Excellent emergency and urgent care</li>
        <li>24/7 family support services</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums—significant with 3+ children</li>
        <li>Annual commitment required</li>
        <li>Costs multiply with each additional child</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="allianz-care" class="mb-12">
      <h2>Allianz Care</h2>
      <p>Allianz Care provides solid comprehensive coverage at the most competitive pricing—significant savings when multiplied across a large family. Their flexibility and payment options help manage substantial family healthcare costs.</p>

      <h3>Strengths for Large Families</h3>
      <ul>
        <li>Most competitive pricing for large families</li>
        <li>Comprehensive pediatric coverage</li>
        <li>Monthly payment options for cash flow</li>
        <li>6-month minimum provides flexibility</li>
        <li>Good vaccination coverage available</li>
        <li>Worldwide coverage for mobile families</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Mental health sessions have annual limits per person</li>
        <li>Some preventive care may require higher tiers</li>
        <li>Network may be smaller in some locations</li>
      </ul>

      <CTAButton href="/providers/allianz" variant="highlight" style="color: white !important;">Get Allianz Care Quote</CTAButton>
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers excellent comprehensive coverage with strong pediatric networks and good mental health support. Their global presence serves internationally mobile families with children in schools across different countries.</p>

      <h3>Strengths for Large Families</h3>
      <ul>
        <li>Excellent mental health coverage for all family members</li>
        <li>Strong global pediatric networks</li>
        <li>Comprehensive vaccinations included</li>
        <li>24/7 multilingual family support</li>
        <li>Good chronic condition management for children</li>
        <li>Robust international coverage</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—second highest</li>
        <li>Annual commitment required</li>
        <li>Per-child costs add up significantly</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Large families need comprehensive pediatric coverage, mental health support for parents and children, and vaccinations across age groups. Dental care for children is often important—consider add-ons.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Family insurance costs multiply with each child. Large families face significant annual premiums. Allianz's competitive pricing provides substantial savings over premium providers when multiplied across multiple children.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates for comprehensive coverage and vary by location, ages, health history, and coverage level. Many employers provide family coverage—verify before purchasing individual plans.</p>
    </section>

    <section id="large-family-considerations" class="mb-12">
      <h2>Large Family Considerations</h2>

      <h3>Cost Management</h3>
      <p>Health insurance for 5-7+ people represents substantial annual cost. Allianz can save $4,000-8,000 annually compared to premium providers—money that matters for large family budgets. Balance cost savings against coverage adequacy for your family's needs.</p>

      <h3>Mental Health for Parents</h3>
      <p>Managing a large family abroad is demanding—multiple children's needs, school coordination, activities, healthcare, and household management without extended family support. Parent burnout is common. Bupa's unlimited mental health or Cigna's excellent coverage provides necessary support.</p>

      <h3>Multiple Pediatric Needs</h3>
      <p>Large families have children at different developmental stages—infant checkups, toddler vaccinations, school-age health needs, adolescent concerns. Insurance should cover well-child visits across age groups. Premium providers include comprehensive pediatric care.</p>

      <h3>Vaccination Logistics</h3>
      <p>Managing vaccinations for multiple children across different schedules is complex. Comprehensive vaccination coverage simplifies this—no decisions about which vaccines to pay for out-of-pocket. Bupa's comprehensive coverage excels here.</p>

      <h3>Emergency Preparedness</h3>
      <p>More children means more potential emergencies—accidents, sudden illnesses, urgent care needs. Reliable access to emergency services and urgent care matters. All three providers offer comprehensive emergency coverage.</p>

      <h3>Employer Family Coverage</h3>
      <p>Many international employers provide family health insurance. Coverage often includes spouse and children. Verify what your employer offers—some cap children covered or have maximum family sizes. Individual coverage may supplement employer benefits if needed.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Affluent large families</li>
            <li>• Parents prioritizing mental health</li>
            <li>• Families wanting premium care</li>
            <li>• Those with young children</li>
            <li>• Families with employer contributions</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Allianz Care Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Budget-conscious large families</li>
            <li>• Families needing cost management</li>
            <li>• Those with healthy children</li>
            <li>• Families wanting flexibility</li>
            <li>• Self-employed parents</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Globally mobile large families</li>
            <li>• Families with chronic conditions</li>
            <li>• Those wanting balanced coverage</li>
            <li>• Families in multiple countries</li>
            <li>• Executive families abroad</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do insurers offer discounts for large families?</h3>
          <p class="text-neutral-700">Generally no—children are priced individually. Some insurers cap children's premiums at certain family sizes. The main way to manage costs is choosing a more affordable provider like Allianz, where per-child savings multiply across your family.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is there a maximum number of children covered?</h3>
          <p class="text-neutral-700">Most international insurers don't cap children numbers. Family plans typically cover 2 adults plus dependent children (usually under 18-25 depending on education status). Very large families should verify specific policies.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">How do I manage vaccinations for multiple children?</h3>
          <p class="text-neutral-700">Choose a plan with comprehensive vaccination coverage to simplify decisions. Keep records for all children. Premium providers include all recommended vaccines; budget options may require selecting which to cover.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is mental health coverage important for parents of large families?</h3>
          <p class="text-neutral-700">Very important. Managing multiple children abroad without extended family support is demanding. Burnout, anxiety, and depression affect parents. Access to therapy helps maintain parental wellbeing—which affects the whole family.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should we add dental coverage for all children?</h3>
          <p class="text-neutral-700">Consider it seriously. Children need regular dental care—checkups, cleanings, orthodontic evaluations. Dental costs multiply with multiple children. Adding family dental coverage provides predictable costs and encourages regular care.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What happens when children age out of family coverage?</h3>
          <p class="text-neutral-700">Children typically remain covered until age 18-25 depending on education status. When they age out, they'll need individual coverage. Some insurers offer continuation options. Plan ahead for transitions as older children approach adulthood.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
