---
import PageShell from '../../components/PageShell.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';

const title = "Cigna vs Bupa vs SafetyWing: Best International Health Insurance for Journalists & Media Professionals";
const description = "Compare Cigna Global, Bupa Global, and SafetyWing for foreign correspondents, freelance journalists, and media professionals working internationally.";
const heroImage = "/images/pages/provider-card-generic.png";

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const mainComparisonRows = [
  { feature: 'Global Coverage', cigna: 'Worldwide', bupa: 'Worldwide', safetywing: 'Worldwide' },
  { feature: 'Mental Health', cigna: 'Excellent', bupa: 'Unlimited', safetywing: 'Limited' },
  { feature: 'Trauma/PTSD Support', cigna: 'Comprehensive', bupa: 'Comprehensive', safetywing: 'Limited' },
  { feature: 'Medical Evacuation', cigna: 'Comprehensive', bupa: 'Comprehensive', safetywing: 'Included' },
  { feature: 'Hostile Area Coverage', cigna: 'Check policy', bupa: 'Check policy', safetywing: 'Exclusions apply' },
  { feature: 'Contract Flexibility', cigna: 'Annual', bupa: 'Annual', safetywing: 'Monthly' },
  { feature: 'Starting Price', cigna: '$$$', bupa: '$$$', safetywing: '$' },
];

const coverageColumns = [
  { key: 'coverage', header: 'Coverage Type' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const coverageRows = [
  { coverage: 'Inpatient', cigna: 'Unlimited options', bupa: 'Full coverage', safetywing: 'Up to $250K' },
  { coverage: 'Outpatient', cigna: 'Comprehensive', bupa: 'Comprehensive', safetywing: 'Emergency only' },
  { coverage: 'Mental Health', cigna: 'Full coverage', bupa: 'Unlimited sessions', safetywing: 'Limited' },
  { coverage: 'Medical Evacuation', cigna: 'Worldwide', bupa: 'Worldwide', safetywing: 'Included' },
  { coverage: 'Preventive Care', cigna: 'Included', bupa: 'Comprehensive', safetywing: 'Not included' },
  { coverage: 'Pre-existing Conditions', cigna: 'Underwritten', bupa: 'Underwritten', safetywing: 'Excluded' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'safetywing', header: 'SafetyWing' },
];

const pricingRows = [
  { profile: 'Freelance journalist, 30', cigna: '$3,200-4,400/yr', bupa: '$3,500-4,800/yr', safetywing: '$550-700/yr' },
  { profile: 'Staff correspondent, 40', cigna: '$4,500-6,200/yr', bupa: '$4,800-6,600/yr', safetywing: '$700-900/yr' },
  { profile: 'Bureau chief, 50', cigna: '$6,500-8,800/yr', bupa: '$7,000-9,500/yr', safetywing: '$900-1,200/yr' },
  { profile: 'Journalist + family', cigna: '$13,000-17,500/yr', bupa: '$14,000-19,000/yr', safetywing: '$2,100-2,700/yr' },
];

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'main-comparison', text: 'Main Comparison', level: 2 },
  { id: 'cigna-global', text: 'Cigna Global', level: 2 },
  { id: 'bupa-global', text: 'Bupa Global', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'journalist-considerations', text: 'Journalist Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Insurance for Media Professionals', href: '/insurance-for/media-professionals' },
  { title: 'Cigna Global Review', href: '/providers/cigna' },
  { title: 'Bupa Global Review', href: '/providers/bupa' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
];
---

<PageShell {title} {description} {tocItems} {relatedLinks} heroImage={heroImage}>
  <main class="prose prose-lg max-w-none">

    <section id="quick-verdict" class="mb-12">
      <h2>Quick Verdict</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-blue-900 mb-2">Choose Cigna Global If...</h3>
          <p class="text-blue-800 text-sm">You want comprehensive coverage with excellent mental health support including trauma/PTSD resources, strong evacuation coverage, and global networks for foreign correspondents.</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-green-900 mb-2">Choose Bupa Global If...</h3>
          <p class="text-green-800 text-sm">You want the most premium coverage with unlimited mental health sessions—essential for journalists covering difficult stories—and comprehensive worldwide care.</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-purple-900 mb-2">Choose SafetyWing If...</h3>
          <p class="text-purple-800 text-sm">You're a freelance journalist in safe locations needing affordable basic coverage while building your career, with flexibility matching irregular income.</p>
        </div>
      </div>
    </section>

    <section id="main-comparison" class="mb-12">
      <h2>Main Comparison</h2>
      <p>International journalists face unique risks: exposure to traumatic events, work in challenging locations, irregular schedules, and the psychological toll of covering difficult stories. Insurance should address mental health extensively, provide reliable evacuation, and work globally regardless of assignment location.</p>
      <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
    </section>

    <section id="cigna-global" class="mb-12">
      <h2>Cigna Global</h2>
      <p>Cigna Global offers excellent comprehensive coverage for international journalists, with strong mental health support including trauma and PTSD resources. Their global networks serve correspondents wherever stories take them.</p>

      <h3>Strengths for Journalists</h3>
      <ul>
        <li>Excellent mental health including trauma support</li>
        <li>Comprehensive medical evacuation worldwide</li>
        <li>Strong global networks in news capitals</li>
        <li>24/7 multilingual support across time zones</li>
        <li>Preventive care included</li>
        <li>Good chronic condition coverage for established journalists</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Premium pricing—may strain freelancer budgets</li>
        <li>Annual commitment required</li>
        <li>War zone coverage requires verification</li>
      </ul>

      <CTAButton href="/providers/cigna" variant="highlight" style="color: white !important;">Get Cigna Global Quote</CTAButton>
    </section>

    <section id="bupa-global" class="mb-12">
      <h2>Bupa Global</h2>
      <p>Bupa Global provides the most premium coverage with unlimited mental health sessions—critical for journalists covering traumatic events. Their comprehensive benefits support long-term psychological wellbeing in demanding careers.</p>

      <h3>Strengths for Journalists</h3>
      <ul>
        <li>Unlimited mental health sessions for trauma exposure</li>
        <li>Comprehensive PTSD and psychological support</li>
        <li>Premium worldwide evacuation</li>
        <li>Excellent hospital networks globally</li>
        <li>Second medical opinion services</li>
        <li>Comprehensive wellness programs</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Highest premiums—typically requires employer support</li>
        <li>Annual commitment required</li>
        <li>Hostile area exclusions may apply</li>
      </ul>

      <CTAButton href="/providers/bupa" variant="highlight" style="color: white !important;">Get Bupa Global Quote</CTAButton>
    </section>

    <section id="safetywing" class="mb-12">
      <h2>SafetyWing</h2>
      <p>SafetyWing offers budget-friendly coverage popular among freelance journalists. Their monthly flexibility suits irregular income, but limited mental health coverage is a significant gap for trauma-exposed professionals.</p>

      <h3>Strengths for Journalists</h3>
      <ul>
        <li>Most affordable option for freelancers</li>
        <li>Monthly subscription matches irregular income</li>
        <li>Global coverage for various assignments</li>
        <li>Medical evacuation included</li>
        <li>Simple enrollment and management</li>
        <li>Can cancel between assignments</li>
      </ul>

      <h3>Considerations</h3>
      <ul>
        <li>Limited mental health—critical gap for journalists</li>
        <li>No PTSD or trauma-specific support</li>
        <li>Emergency-only outpatient</li>
        <li>Hostile area exclusions apply</li>
        <li>$250K limit may concern some</li>
      </ul>

      <CTAButton href="/providers/safetywing" variant="highlight" style="color: white !important;">Get SafetyWing Quote</CTAButton>
    </section>

    <section id="coverage-details" class="mb-12">
      <h2>Coverage Details</h2>
      <p>Mental health coverage is paramount for journalists—exposure to trauma, vicarious trauma from stories, and career stress all affect wellbeing. Comprehensive outpatient access and psychological support matter enormously in this profession.</p>
      <ComparisonTable columns={coverageColumns} rows={coverageRows} />
    </section>

    <section id="pricing" class="mb-12">
      <h2>Pricing Comparison</h2>
      <p>Journalism salaries vary dramatically—from struggling freelancers to well-compensated bureau chiefs. Major news organizations provide health benefits; freelancers must self-fund. Match coverage level to your income and assignment risk.</p>
      <ComparisonTable columns={pricingColumns} rows={pricingRows} />
      <p class="text-sm text-neutral-600 mt-4">Prices are estimates for standard coverage areas and vary by age, health history, and location. War zone or hostile area coverage requires specialized policies.</p>
    </section>

    <section id="journalist-considerations" class="mb-12">
      <h2>Journalist Considerations</h2>

      <h3>Mental Health and Trauma</h3>
      <p>Journalists covering conflict, disaster, crime, and human suffering experience trauma directly and vicariously. PTSD rates are elevated in the profession. Comprehensive mental health coverage isn't optional—it's essential. Bupa's unlimited sessions or Cigna's excellent coverage provide necessary support. SafetyWing's limited coverage is inadequate for most journalists.</p>

      <h3>Hostile Area Exclusions</h3>
      <p>Standard health insurance typically excludes war zones and hostile areas. Journalists covering conflict need specialized war correspondent insurance in addition to standard health coverage. Verify exclusions carefully and obtain supplementary coverage for dangerous assignments.</p>

      <h3>Evacuation Capability</h3>
      <p>Medical evacuation matters when assignments take you to areas with limited healthcare. All three providers include evacuation, but premium providers may have stronger logistics networks. For conflict zones, security evacuation (separate from medical) is also necessary.</p>

      <h3>Freelance vs Staff</h3>
      <p>Staff correspondents typically receive employer-provided insurance. Freelancers must self-fund—making SafetyWing's affordability attractive but its gaps concerning. Consider whether budget savings justify inadequate mental health coverage.</p>

      <h3>Income Variability</h3>
      <p>Freelance journalism income is irregular. SafetyWing's monthly model accommodates this variability. Premium providers' annual commitments require budget planning. Treat insurance as a necessary professional expense regardless of income fluctuations.</p>

      <h3>Long-term Career Health</h3>
      <p>Journalism careers expose you to cumulative psychological impact. Investing in mental health coverage early supports career longevity. Many veteran journalists develop PTSD or burnout—adequate support helps prevent or manage these issues.</p>
    </section>

    <section id="best-for" class="mb-12">
      <h2>Best For</h2>
      <div class="grid md:grid-cols-3 gap-6 not-prose">
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Cigna Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Foreign correspondents</li>
            <li>• Bureau staff journalists</li>
            <li>• Those covering difficult beats</li>
            <li>• Established freelancers</li>
            <li>• Journalist families abroad</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Bupa Global Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Senior correspondents</li>
            <li>• Those prioritizing mental health</li>
            <li>• War/conflict journalists (with supplements)</li>
            <li>• Bureau chiefs</li>
            <li>• Those with employer coverage</li>
          </ul>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">SafetyWing Best For</h3>
          <ul class="text-neutral-700 text-sm space-y-1">
            <li>• Early-career freelancers</li>
            <li>• Lifestyle/travel journalists</li>
            <li>• Those in safe assignment areas</li>
            <li>• Budget-conscious freelancers</li>
            <li>• Between-assignment coverage</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-12">
      <h2>Frequently Asked Questions</h2>

      <div class="space-y-6 not-prose">
        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Does standard health insurance cover war zones?</h3>
          <p class="text-neutral-700">Generally no. Standard health insurance excludes war zones and hostile areas. Journalists covering conflict need specialized war correspondent insurance in addition to standard coverage. This is a separate policy category with specialized providers.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is mental health coverage really important for journalists?</h3>
          <p class="text-neutral-700">Extremely important. Journalists have elevated PTSD rates from direct and vicarious trauma exposure. Covering violence, disaster, and suffering takes psychological toll. Adequate mental health coverage supports career longevity and personal wellbeing.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Do news organizations provide health insurance for correspondents?</h3>
          <p class="text-neutral-700">Major news organizations typically provide comprehensive coverage for staff correspondents. Quality varies. Freelancers and stringers usually must arrange their own coverage. Verify what your organization provides before purchasing individual insurance.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Is SafetyWing adequate for journalism work?</h3>
          <p class="text-neutral-700">For lifestyle, travel, or soft news journalism in safe areas, SafetyWing may suffice. For hard news, conflict coverage, or work involving trauma exposure, the limited mental health coverage is a significant gap. Consider your actual assignment risk.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">What about PTSD treatment coverage?</h3>
          <p class="text-neutral-700">Cigna and Bupa cover PTSD treatment under their mental health benefits. Bupa's unlimited sessions are particularly valuable for ongoing PTSD therapy. SafetyWing's limited mental health coverage is inadequate for comprehensive PTSD treatment.</p>
        </div>

        <div class="bg-neutral-50 rounded-lg p-6">
          <h3 class="font-bold text-neutral-900 mb-2">Should freelancers prioritize affordability or coverage?</h3>
          <p class="text-neutral-700">It depends on your work. Safe assignments may allow budget coverage. Trauma-exposure work requires comprehensive mental health coverage regardless of cost. Treat adequate insurance as a professional necessity, not an optional expense.</p>
        </div>
      </div>
    </section>

  </main>
</PageShell>
