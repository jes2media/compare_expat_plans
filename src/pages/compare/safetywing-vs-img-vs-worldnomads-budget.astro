---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'safetywing', text: 'SafetyWing', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'worldnomads', text: 'World Nomads', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'budget-considerations', text: 'Budget Traveler Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'SafetyWing Full Review', href: '/providers/safetywing' },
  { title: 'IMG Global Full Review', href: '/providers/img-global' },
  { title: 'World Nomads Full Review', href: '/providers/world-nomads' },
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
  { title: 'Best Budget Expat Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const mainComparisonRows = [
  { feature: 'Monthly pricing', safetywing: '$45-85/mo', img: '$80-150/mo', worldnomads: '$100-200/mo' },
  { feature: 'Target audience', safetywing: 'Digital nomads', img: 'Budget expats', worldnomads: 'Adventure travelers' },
  { feature: 'Coverage type', safetywing: 'Travel medical', img: 'Travel/expat medical', worldnomads: 'Travel medical' },
  { feature: 'Adventure sports', safetywing: 'Limited', img: 'Add-on available', worldnomads: 'Excellent—included' },
  { feature: 'Trip gear coverage', safetywing: 'No', img: 'Add-on', worldnomads: 'Yes—included' },
  { feature: 'Max coverage', safetywing: '$250,000', img: '$500,000-$2M', worldnomads: '$100,000-$300,000' },
  { feature: 'Deductible', safetywing: '$250', img: 'Flexible ($0-$2,500)', worldnomads: '$100' },
  { feature: 'US coverage', safetywing: 'Limited (30 days)', img: 'Yes—full', worldnomads: 'Yes—full' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'safetywing', header: 'SafetyWing' },
  { key: 'img', header: 'IMG Global' },
  { key: 'worldnomads', header: 'World Nomads' },
];

const pricingRows = [
  { scenario: 'Age 25, basic coverage', safetywing: '$42-50/mo', img: '$75-95/mo', worldnomads: '$95-120/mo' },
  { scenario: 'Age 35, basic coverage', safetywing: '$48-60/mo', img: '$90-120/mo', worldnomads: '$110-140/mo' },
  { scenario: 'Age 45, basic coverage', safetywing: '$68-85/mo', img: '$120-160/mo', worldnomads: '$150-200/mo' },
  { scenario: 'With adventure sports', safetywing: '+$10-15/mo', img: '+$20-40/mo', worldnomads: 'Included' },
  { scenario: 'Annual (12 months)', safetywing: '$500-700/yr', img: '$900-1,400/yr', worldnomads: '$1,100-1,800/yr' },
];
---

<PageShell
  title="SafetyWing vs IMG vs World Nomads: Best Budget Travel Insurance 2025"
  description="Compare SafetyWing, IMG Global, and World Nomads for budget-conscious travelers. Pricing, coverage limits, adventure sports, and value for digital nomads."
  headline="SafetyWing vs IMG vs World Nomads: Budget Travel Insurance"
  subheadline="Which affordable insurer is best for digital nomads and budget travelers? Pricing, coverage limits, and real value compared."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">SafetyWing</p>
      <p class="text-sm text-neutral-600 mb-3">Lowest premiums for digital nomads. Simple subscription model. Best for healthy young travelers who need basic coverage.</p>
      <a href="/providers/safetywing" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best Mid-Range</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">IMG Global</p>
      <p class="text-sm text-neutral-600 mb-3">Higher coverage limits at reasonable prices. Flexible deductibles. Good balance between cost and protection.</p>
      <a href="/providers/img-global" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best for Adventure</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">World Nomads</p>
      <p class="text-sm text-neutral-600 mb-3">Adventure sports included. Gear coverage. Best for active travelers despite higher premiums.</p>
      <a href="/providers/world-nomads" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="safetywing">SafetyWing</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">SafetyWing built their product specifically for digital nomads on a budget. Their subscription model ($45/month starting) made international health insurance accessible to a generation of remote workers who couldn't afford traditional expat plans.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Budget Traveler Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Lowest premiums in the market ($45-85/month)</li>
      <li>No contracts—pay monthly, cancel anytime</li>
      <li>Simple signup—get covered in minutes online</li>
      <li>Good for healthy, young travelers</li>
      <li>Covers COVID-19 as any other illness</li>
      <li>Remote working lifestyle understood</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Lower coverage limit ($250,000 max)</li>
      <li>Limited US coverage (30 days per 90)</li>
      <li>No trip cancellation or gear coverage</li>
      <li>Adventure sports coverage limited</li>
      <li>$250 deductible per injury/illness</li>
      <li>Not accepted for some visa requirements</li>
    </ul>
  </div>

  <h2 id="img">IMG Global</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">IMG Global offers a middle ground between bare-bones travel insurance and expensive expat plans. Their flexible deductible options let budget travelers control costs while maintaining higher coverage limits.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Budget Traveler Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Higher coverage limits ($500K-$2M options)</li>
      <li>Flexible deductibles reduce premiums</li>
      <li>Full US coverage available</li>
      <li>Adventure sports add-on available</li>
      <li>More comprehensive than travel insurance</li>
      <li>Good for longer stays (6-12+ months)</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Higher premiums than SafetyWing</li>
      <li>Less modern signup experience</li>
      <li>Add-ons increase costs</li>
      <li>Can be confusing to navigate options</li>
      <li>Customer service varies by region</li>
    </ul>
  </div>

  <h2 id="worldnomads">World Nomads</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">World Nomads targets adventure travelers with comprehensive activity coverage included in base plans. If you're climbing mountains, scuba diving, or skiing, the "higher" premiums suddenly look reasonable.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Budget Traveler Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>150+ adventure activities covered</li>
      <li>Trip gear and equipment coverage included</li>
      <li>Trip cancellation/interruption coverage</li>
      <li>Can buy while already traveling</li>
      <li>Full US coverage</li>
      <li>24/7 emergency assistance</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Highest premiums of the three</li>
      <li>Lower medical coverage limit ($100K-$300K)</li>
      <li>Maximum trip length limits (vary by country)</li>
      <li>Not designed for long-term expats</li>
      <li>Pre-existing conditions rarely covered</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage That Fits Your Budget"
    description="Compare affordable plans for digital nomads and budget travelers. Get covered without breaking the bank."
    buttonText="Compare Budget Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Monthly and annual costs for different traveler profiles. All prices in USD.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">Prices vary by age, citizenship, and destination. SafetyWing is month-to-month; IMG and World Nomads typically price per trip or term.</p>

  <h2 id="budget-considerations">Budget Traveler Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">The "Cheap" Insurance Trap</h3>
      <p class="text-neutral-700">The cheapest plan isn't always the best value. A $40/month plan with $100,000 coverage might cost you more than a $100/month plan if you face a serious medical emergency. Hospital bills in the US or evacuations from remote areas can easily exceed $100,000. Balance price against risk.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Deductibles and Out-of-Pocket Costs</h3>
      <p class="text-neutral-700">SafetyWing's $250 deductible applies per injury/illness. IMG's flexible deductibles ($0-$2,500) let you trade lower premiums for higher out-of-pocket. World Nomads has a low $100 deductible. Consider how many claims you might make—frequent small claims favor low deductibles; rare claims favor high.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">US Coverage Matters</h3>
      <p class="text-neutral-700">If you're American or visit the US frequently, coverage matters enormously. SafetyWing limits US coverage to 30 days per 90-day period. IMG and World Nomads offer full US coverage. A single ER visit in the US without coverage can cost $10,000+. Don't cheap out on US coverage.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Adventure Sports Reality Check</h3>
      <p class="text-neutral-700">Planning to scuba dive, ski, or ride motorbikes? SafetyWing has limited coverage. IMG requires add-ons. World Nomads includes 150+ activities. Getting injured doing an uncovered activity means paying everything yourself. If you're active, World Nomads' higher premiums may be better value.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Visa Requirements</h3>
      <p class="text-neutral-700">Some visas require specific insurance minimums. Schengen requires €30,000 medical coverage. Some countries don't accept SafetyWing (Czech Republic requires PVZP/Maxima). Check your destination's requirements before buying—the cheapest plan that doesn't meet visa requirements is worthless.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose SafetyWing If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is your top priority</li>
        <li>You're young and healthy</li>
        <li>You won't spend much time in US</li>
        <li>You don't do adventure sports</li>
        <li>You want month-to-month flexibility</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose IMG If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You want higher coverage limits</li>
        <li>You need full US coverage</li>
        <li>You're staying 6+ months abroad</li>
        <li>You want flexible deductibles</li>
        <li>You need something more than travel insurance</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose World Nomads If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You do adventure activities</li>
        <li>You want gear coverage</li>
        <li>You need trip cancellation</li>
        <li>You're taking shorter trips</li>
        <li>You want comprehensive coverage</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Is SafetyWing really enough coverage?</h3>
      <p class="text-neutral-700">For most healthy young travelers staying outside the US, SafetyWing's $250,000 coverage is adequate. It covers hospitalizations, surgeries, and emergencies in most countries. However, for US coverage, older travelers, or those with health concerns, IMG's higher limits provide better protection. Evaluate your personal risk tolerance.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I use these for visa applications?</h3>
      <p class="text-neutral-700">IMG is accepted for most visa applications including Schengen. World Nomads is widely accepted for travel visas. SafetyWing works for many visas but is rejected by some countries (notably Czech Republic for long-stay visas). Always verify your specific visa requirements before purchasing.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Do any of these cover pre-existing conditions?</h3>
      <p class="text-neutral-700">Generally, no. All three have limited or no coverage for pre-existing conditions. SafetyWing excludes them entirely. IMG may cover acute episodes of chronic conditions in some plans. World Nomads has strict exclusions. If you have pre-existing conditions, you may need a traditional expat health plan with underwriting.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What if I need to see a doctor for something minor?</h3>
      <p class="text-neutral-700">Minor care is covered, but deductibles apply. SafetyWing's $250 deductible means routine doctor visits likely come out of pocket. IMG's flexible deductibles give you options. For routine care, consider paying out of pocket in countries with affordable healthcare—$20-50 doctor visits in Southeast Asia aren't worth filing claims.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I buy after I've already left home?</h3>
      <p class="text-neutral-700">Yes—all three allow purchase while traveling. SafetyWing is subscription-based and starts immediately. IMG and World Nomads can be purchased abroad for future dates. This flexibility is valuable for digital nomads who don't have fixed travel plans. No need to commit to coverage dates before you leave.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How do these compare to traditional expat insurance?</h3>
      <p class="text-neutral-700">These are budget alternatives to full expat health insurance. Traditional plans (Cigna, Bupa, Allianz) offer $1-5M coverage, comprehensive benefits, and guaranteed renewability—but cost $200-500+/month. Budget options work for healthy travelers but lack the depth of coverage for those planning long-term expat life with families or health concerns.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> Insurance needs vary by individual circumstances. Coverage limits, exclusions, and pricing change regularly. Always read policy documents carefully before purchasing. Budget insurance may not be suitable for those with significant health needs, families, or high-risk activities. Verify visa requirements independently.
    </p>
  </div>
</PageShell>
