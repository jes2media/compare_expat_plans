---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison-table', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'cigna', text: 'Cigna Global', level: 2 },
  { id: 'bupa', text: 'Bupa Global', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'us-coverage', text: 'US Healthcare Integration', level: 2 },
  { id: 'best-for', text: 'Which Is Best For You?', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { href: '/best/expat-health-insurance', text: 'Best Expat Insurance' },
  { href: '/guides/us-expat-health-insurance', text: 'US Expat Insurance Guide' },
  { href: '/providers/cigna-global', text: 'Cigna Global Review' },
  { href: '/providers/aetna-international', text: 'Aetna Review' },
  { href: '/providers/bupa-global', text: 'Bupa Review' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'US Network Size', cigna: 'Cigna domestic network', bupa: 'PPO network access', aetna: 'Aetna domestic network' },
  { feature: 'US Coverage Options', cigna: 'Included or excluded', bupa: 'Add-on available', aetna: 'Included standard' },
  { feature: 'US Prescription Coverage', cigna: 'Full US formulary', bupa: 'Good', aetna: 'Full US formulary' },
  { feature: 'Medicare Coordination', cigna: 'Available', bupa: 'Limited', aetna: 'Excellent' },
  { feature: 'US Home Leave Coverage', cigna: '180 days/year', bupa: '90-180 days', aetna: '180 days/year' },
  { feature: 'ACA Compliance', cigna: 'Plans available', bupa: 'Not compliant', aetna: 'Plans available' },
  { feature: 'Global Network', cigna: '1.5M+ providers', bupa: '1.3M+ providers', aetna: '1.2M+ providers' },
  { feature: 'US Customer Service', cigna: 'US-based team', bupa: 'UK-based primarily', aetna: 'US-based team' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'bupa', header: 'Bupa Global' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { profile: 'Individual (35) with US', cigna: '$450-600/mo', bupa: '$400-550/mo', aetna: '$480-650/mo' },
  { profile: 'Individual (35) excl. US', cigna: '$280-380/mo', bupa: '$300-420/mo', aetna: 'N/A (US included)' },
  { profile: 'Family with US coverage', cigna: '$1,200-1,600/mo', bupa: '$1,100-1,450/mo', aetna: '$1,300-1,700/mo' },
  { profile: 'Senior (62) with US', cigna: '$850-1,100/mo', bupa: '$780-1,000/mo', aetna: '$900-1,200/mo' },
];
---

<PageShell
  title="Cigna vs Bupa vs Aetna for US Expats | 2025 Comparison"
  description="Compare Cigna Global, Bupa Global, and Aetna International for American expats. Expert analysis of US coverage, home leave benefits, and Medicare coordination."
  headline="Cigna vs Bupa vs Aetna: Best Insurance for US Expats"
  subheadline="Complete comparison of three leading providers for American expats needing coverage abroad with US healthcare integration."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Quotes"
  ctaButtonHref="/get-quotes"
>
  <section id="quick-verdict" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Quick Verdict</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-primary-800 mb-2">Cigna Global</h3>
        <p class="text-primary-700 mb-3">Best Overall Choice</p>
        <p class="text-neutral-700 text-sm mb-4">Largest global network with excellent US Cigna domestic integration. Best balance of worldwide coverage and US healthcare access.</p>
        <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-4 py-2 rounded hover:bg-primary-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-purple-800 mb-2">Bupa Global</h3>
        <p class="text-purple-700 mb-3">Best Without US</p>
        <p class="text-neutral-700 text-sm mb-4">Most competitive pricing when US coverage isn't needed. Strong international network with optional US add-on.</p>
        <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-green-800 mb-2">Aetna International</h3>
        <p class="text-green-700 mb-3">Best US Integration</p>
        <p class="text-neutral-700 text-sm mb-4">Seamless Aetna domestic network access with best Medicare coordination. Ideal for frequent US travel.</p>
        <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm" style="color: white !important;">Learn More</a>
      </div>
    </div>
  </section>

  <section id="comparison-table" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Side-by-Side Comparison</h2>
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </section>

  <section id="cigna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Cigna Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Largest Network</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">US Integration</span>
      <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-medium">Flexible Coverage</span>
    </div>

    <p class="text-neutral-700 mb-4">Cigna Global offers US expats the best of both worlds—access to Cigna's domestic US network when home, combined with their massive international network of 1.5 million+ providers worldwide. American expats can choose plans that include or exclude US coverage, providing flexibility based on how often they return.</p>

    <p class="text-neutral-700 mb-4">Their US-based customer service team understands American healthcare expectations and can coordinate care across both domestic and international providers. For expats who maintain US prescriptions, Cigna's formulary integration means your medications are covered seamlessly.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for US Expats</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Cigna domestic network access</li>
          <li>• Flexible US include/exclude options</li>
          <li>• Full US prescription formulary</li>
          <li>• 180 days/year home leave coverage</li>
          <li>• US-based customer service</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Premiums higher with US included</li>
          <li>• ACA compliance varies by plan</li>
          <li>• Medicare coordination less seamless than Aetna</li>
          <li>• 12-month minimum commitment</li>
        </ul>
      </div>
    </div>

    <a href="/providers/cigna-global" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-medium" style="color: white !important;">Get Cigna Quote</a>
  </section>

  <section id="bupa" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Bupa Global</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Best Value</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Global Focus</span>
      <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">Optional US</span>
    </div>

    <p class="text-neutral-700 mb-4">Bupa Global offers the most competitive pricing for US expats who don't need comprehensive US coverage. Their base plans exclude the US, keeping premiums significantly lower. For those who do return occasionally, an optional US treatment add-on provides coverage during home visits.</p>

    <p class="text-neutral-700 mb-4">While Bupa is UK-based, they've developed strong US partnerships for expat coverage. Their international network is excellent, particularly in Europe, Asia, and the Middle East where many American expats live. The service quality is premium, though customer support hours may not always align with US time zones.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for US Expats</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Lowest premiums (excluding US)</li>
          <li>• Optional US coverage add-on</li>
          <li>• Excellent international network</li>
          <li>• Premium service quality</li>
          <li>• Strong chronic condition management</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Limited US network compared to Cigna/Aetna</li>
          <li>• UK-based support (time zone challenges)</li>
          <li>• No Medicare coordination</li>
          <li>• Not ACA compliant</li>
        </ul>
      </div>
    </div>

    <a href="/providers/bupa-global" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition font-medium" style="color: white !important;">Get Bupa Quote</a>
  </section>

  <section id="aetna" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Aetna International</h2>
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Best US Access</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">Medicare Expert</span>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">US Heritage</span>
    </div>

    <p class="text-neutral-700 mb-4">Aetna International provides the most seamless US healthcare integration for American expats. As a major US health insurer, your coverage works directly with Aetna's extensive domestic network—no coordination headaches when you return home. Their Medicare coordination is industry-leading for expat retirees.</p>

    <p class="text-neutral-700 mb-4">All Aetna International plans include US coverage by default, reflecting their understanding that American expats typically maintain strong ties to US healthcare. Their US-based team is available during American business hours and understands the nuances of coordinating international and domestic care.</p>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4">
        <h4 class="font-bold text-green-800 mb-2">Strengths for US Expats</h4>
        <ul class="text-green-700 text-sm space-y-1">
          <li>• Full Aetna domestic network access</li>
          <li>• US coverage included standard</li>
          <li>• Best Medicare coordination</li>
          <li>• US-based customer service</li>
          <li>• ACA-compliant plans available</li>
        </ul>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <h4 class="font-bold text-amber-800 mb-2">Considerations</h4>
        <ul class="text-amber-700 text-sm space-y-1">
          <li>• Highest premiums (US always included)</li>
          <li>• Cannot exclude US for savings</li>
          <li>• Smaller global network than Cigna</li>
          <li>• Less presence in some regions</li>
        </ul>
      </div>
    </div>

    <a href="/providers/aetna-international" class="inline-block bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-medium" style="color: white !important;">Get Aetna Quote</a>
  </section>

  <CTABox
    title="Compare US Expat Coverage Quotes"
    description="Get personalized quotes from all three providers with US coverage options tailored to your needs."
    buttonText="Get Free Quotes"
    buttonHref="/get-quotes"
  />

  <section id="pricing" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Pricing Comparison</h2>
    <p class="text-neutral-700 mb-6">US coverage significantly impacts pricing. These estimates show comprehensive plans with $1,000 deductible:</p>
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
    <p class="text-sm text-neutral-600 mt-4">*Premiums are 40-60% higher with US coverage included due to American healthcare costs. Bupa offers the lowest non-US rates.</p>
  </section>

  <section id="us-coverage" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">US Healthcare Integration</h2>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Home Leave Coverage</h3>
        <p class="text-neutral-700 text-sm mb-4">All three providers cover healthcare during visits to the US:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> Up to 180 days/year in US</li>
          <li>• <strong>Bupa:</strong> 90-180 days (plan dependent)</li>
          <li>• <strong>Aetna:</strong> Up to 180 days/year in US</li>
        </ul>
        <p class="text-neutral-600 text-xs mt-3">Note: Extended US stays may require different coverage.</p>
      </div>
      <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
        <h3 class="text-xl font-bold text-neutral-800 mb-3">Medicare Coordination</h3>
        <p class="text-neutral-700 text-sm mb-4">For expats 65+ maintaining Medicare:</p>
        <ul class="text-neutral-700 text-sm space-y-2">
          <li>• <strong>Cigna:</strong> Coordinates with Medicare A/B</li>
          <li>• <strong>Bupa:</strong> Limited coordination</li>
          <li>• <strong>Aetna:</strong> Best coordination—acts as supplement</li>
        </ul>
        <p class="text-neutral-600 text-xs mt-3">Medicare only covers care in the US.</p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h3 class="text-xl font-bold text-blue-800 mb-3">ACA Compliance & Tax Considerations</h3>
      <p class="text-blue-700 mb-4">Important for US expats maintaining tax residency:</p>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Cigna</h4>
          <p class="text-blue-700 text-sm">ACA-compliant plans available. Provides 1095-B forms for US tax filing. Check specific plan compliance.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Bupa</h4>
          <p class="text-blue-700 text-sm">Not ACA compliant. Expats with US tax obligations may need supplemental coverage or exemption.</p>
        </div>
        <div>
          <h4 class="font-bold text-blue-800 mb-2">Aetna</h4>
          <p class="text-blue-700 text-sm">ACA-compliant plans available. Provides documentation for US tax requirements. Best for tax compliance.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="best-for" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Which Is Best For You?</h2>
    <div class="space-y-4">
      <div class="bg-primary-50 border-l-4 border-primary-600 p-4">
        <h3 class="font-bold text-primary-800 mb-2">Choose Cigna Global if:</h3>
        <ul class="text-primary-700 space-y-1">
          <li>• You want the largest global network with US access</li>
          <li>• You need flexibility to include or exclude US coverage</li>
          <li>• US prescription formulary access is important</li>
          <li>• You want comprehensive worldwide coverage</li>
        </ul>
      </div>
      <div class="bg-purple-50 border-l-4 border-purple-600 p-4">
        <h3 class="font-bold text-purple-800 mb-2">Choose Bupa Global if:</h3>
        <ul class="text-purple-700 space-y-1">
          <li>• You rarely return to the US for healthcare</li>
          <li>• Budget is a significant consideration</li>
          <li>• You're based in Europe, Asia, or Middle East</li>
          <li>• You only need occasional US coverage via add-on</li>
        </ul>
      </div>
      <div class="bg-green-50 border-l-4 border-green-600 p-4">
        <h3 class="font-bold text-green-800 mb-2">Choose Aetna International if:</h3>
        <ul class="text-green-700 space-y-1">
          <li>• Seamless US healthcare access is your priority</li>
          <li>• You're 65+ and need Medicare coordination</li>
          <li>• ACA compliance is required for tax purposes</li>
          <li>• You return to the US frequently</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="faqs" class="mb-12">
    <h2 class="text-3xl font-bold text-neutral-800 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Should I keep my US health insurance while abroad?</h3>
        <p class="text-neutral-700">It depends on your situation. If you're permanently relocating with no plans to return soon, international coverage alone may suffice. If you maintain US tax residency, return frequently, or want to preserve domestic coverage options, keeping a US plan or choosing an ACA-compliant international plan makes sense. Cigna and Aetna offer good bridges between worlds.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">What happens if I need emergency care during a US visit?</h3>
        <p class="text-neutral-700">All three providers cover emergencies in the US as long as you have US coverage included. Cigna and Aetna provide direct network access, meaning you can go to in-network facilities just like domestic insurance. Bupa's US coverage works more like international coverage—you may need to pay and file for reimbursement.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">How does Medicare work for expats?</h3>
        <p class="text-neutral-700">Medicare only covers care in the US. Many expats maintain Medicare Part A (free if you paid Medicare taxes) and use international insurance abroad. Aetna offers the best coordination—their plans can work as Medicare supplements during US visits. You can delay Part B enrollment without penalty while covered by qualifying expat insurance.</p>
      </div>
      <div class="bg-neutral-50 rounded-lg p-6">
        <h3 class="text-lg font-bold text-neutral-800 mb-2">Can I use my US prescriptions abroad?</h3>
        <p class="text-neutral-700">Yes, all three providers cover prescriptions internationally. Cigna and Aetna maintain the same formularies as their US plans, making transitions seamless. You may need to work with your provider to ensure your medications are available in your destination country, as brand names and formulations sometimes differ.</p>
      </div>
    </div>
  </section>

  <div class="bg-neutral-100 rounded-lg p-6 text-sm text-neutral-600">
    <p><strong>Disclaimer:</strong> Insurance pricing and coverage details change frequently. US healthcare costs significantly impact international insurance premiums. Tax and Medicare implications vary by individual situation—consult a tax professional. This comparison is for informational purposes only and does not constitute financial, tax, or insurance advice.</p>
  </div>
</PageShell>
