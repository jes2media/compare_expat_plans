---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'quick-verdict', text: 'Quick Verdict', level: 2 },
  { id: 'comparison', text: 'Side-by-Side Comparison', level: 2 },
  { id: 'img', text: 'IMG Global', level: 2 },
  { id: 'geoblue', text: 'GeoBlue', level: 2 },
  { id: 'aetna', text: 'Aetna International', level: 2 },
  { id: 'pricing', text: 'Pricing Comparison', level: 2 },
  { id: 'us-expat-considerations', text: 'US Expat Considerations', level: 2 },
  { id: 'best-for', text: 'Best For', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'IMG Global Full Review', href: '/providers/img-global' },
  { title: 'GeoBlue Full Review', href: '/providers/geoblue' },
  { title: 'Aetna International Full Review', href: '/providers/aetna-international' },
  { title: 'Insurance for US Expats', href: '/insurance-for/us-expats' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
];

const mainComparisonColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'img', header: 'IMG Global' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'aetna', header: 'Aetna International' },
];

const mainComparisonRows = [
  { feature: 'US return coverage', img: 'Full coverage available', geoblue: 'Full US coverage', aetna: 'Full coverage available' },
  { feature: 'US network access', img: 'PPO networks', geoblue: 'Blue Cross network', aetna: 'Aetna US network' },
  { feature: 'Target audience', img: 'Budget-conscious expats', geoblue: 'US citizens abroad', aetna: 'Corporate expats' },
  { feature: 'ACA compliance', img: 'MEC plans available', geoblue: 'Designed for expats', aetna: 'MEC plans available' },
  { feature: 'Direct billing US', img: 'Some facilities', geoblue: 'Blue Cross facilities', aetna: 'Aetna facilities' },
  { feature: 'US prescriptions', img: 'Covered', geoblue: 'Blue Cross pharmacies', aetna: 'CVS/Caremark network' },
  { feature: 'US customer service', img: 'US-based', geoblue: 'US-based', aetna: 'US-based' },
  { feature: 'HIPAA compliant', img: 'Yes', geoblue: 'Yes', aetna: 'Yes' },
];

const pricingColumns = [
  { key: 'scenario', header: 'Scenario' },
  { key: 'img', header: 'IMG Global' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'aetna', header: 'Aetna International' },
];

const pricingRows = [
  { scenario: 'Age 35, with US coverage', img: '$200-350/mo', geoblue: '$300-450/mo', aetna: '$350-500/mo' },
  { scenario: 'Age 45, with US coverage', img: '$300-500/mo', geoblue: '$450-650/mo', aetna: '$500-750/mo' },
  { scenario: 'Age 55, with US coverage', img: '$450-750/mo', geoblue: '$650-950/mo', aetna: '$750-1,100/mo' },
  { scenario: 'Family (2+2), with US', img: '$700-1,200/mo', geoblue: '$1,000-1,500/mo', aetna: '$1,200-1,800/mo' },
  { scenario: 'Without US coverage', img: '-40-50%', geoblue: 'Not available', aetna: '-30-40%' },
];
---

<PageShell
  title="IMG vs GeoBlue vs Aetna: Best for US Expats 2025"
  description="Compare IMG, GeoBlue, and Aetna International for American expats. US return coverage, domestic networks, ACA compliance, and coverage for visits home."
  headline="IMG vs GeoBlue vs Aetna: Best for US Expats"
  subheadline="Which insurer is best for American citizens living abroad? US return coverage, domestic networks, and American-friendly features compared."
  heroImage="/images/pages/provider-card-generic.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
>
  <h2 id="quick-verdict">Quick Verdict</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 border-2 border-primary-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wide mb-1">Best Value</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">IMG Global</p>
      <p class="text-sm text-neutral-600 mb-3">Most affordable US coverage. Good for budget-conscious Americans abroad. Flexible deductibles help control costs.</p>
      <a href="/providers/img-global" class="inline-block w-full text-center bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-purple-50 border-2 border-purple-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-purple-600 uppercase tracking-wide mb-1">Best US Network</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">GeoBlue</p>
      <p class="text-sm text-neutral-600 mb-3">Blue Cross Blue Shield network access. Best for frequent US visits. Purpose-built for American expats.</p>
      <a href="/providers/geoblue" class="inline-block w-full text-center bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
    <div class="bg-orange-50 border-2 border-orange-300 rounded-lg p-5">
      <p class="text-xs font-semibold text-orange-600 uppercase tracking-wide mb-1">Best for Executives</p>
      <p class="text-xl font-bold text-neutral-900 mb-2">Aetna International</p>
      <p class="text-sm text-neutral-600 mb-3">Comprehensive coverage for corporate expats. Strong US network access. Premium service and benefits.</p>
      <a href="/providers/aetna-international" class="inline-block w-full text-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors no-underline" style="color: white !important;">Learn More</a>
    </div>
  </div>

  <h2 id="comparison">Side-by-Side Comparison</h2>

  <div class="my-6">
    <ComparisonTable columns={mainComparisonColumns} rows={mainComparisonRows} />
  </div>

  <h2 id="img">IMG Global</h2>

  <div class="bg-primary-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">IMG Global offers the most affordable international health insurance for US expats with full US coverage options. Their flexible plans let budget-conscious Americans get comprehensive coverage without the premium pricing of traditional expat insurers.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">US Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Most affordable US coverage option</li>
      <li>Flexible deductibles ($0-$5,000+) control costs</li>
      <li>PPO network access in the US</li>
      <li>MEC-compliant plans available for ACA</li>
      <li>US-based customer service</li>
      <li>Good for long-term expats on a budget</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Smaller US network than GeoBlue or Aetna</li>
      <li>Direct billing limited to select facilities</li>
      <li>Less brand recognition in US hospitals</li>
      <li>Claims process can be slower</li>
    </ul>
  </div>

  <h2 id="geoblue">GeoBlue</h2>

  <div class="bg-purple-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">GeoBlue was built specifically for American expats, with Blue Cross Blue Shield network access as a core feature. If you return to the US frequently, their seamless domestic coverage makes healthcare navigation easy.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">US Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Blue Cross Blue Shield network—largest in US</li>
      <li>Designed specifically for US citizens abroad</li>
      <li>Seamless coverage when visiting home</li>
      <li>Direct billing at Blue Cross facilities</li>
      <li>US pharmacy access (Blue Cross pharmacies)</li>
      <li>Familiar American healthcare experience</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Higher premiums than IMG</li>
      <li>US coverage is mandatory (can't exclude to save)</li>
      <li>International network smaller than Cigna/Bupa</li>
      <li>Limited plan customization</li>
    </ul>
  </div>

  <h2 id="aetna">Aetna International</h2>

  <div class="bg-orange-50 rounded-lg p-6 my-6">
    <p class="text-lg text-neutral-700 mb-4">Aetna International offers comprehensive coverage for American expats, particularly executives and corporate assignees. Their strong US network and premium benefits make them ideal for those wanting top-tier coverage.</p>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">US Expat Strengths</h3>
    <ul class="list-disc pl-6 mb-4 space-y-1 text-neutral-700">
      <li>Aetna domestic network access</li>
      <li>CVS/Caremark pharmacy network</li>
      <li>Comprehensive benefits package</li>
      <li>Strong corporate/executive coverage</li>
      <li>MEC-compliant plans for ACA</li>
      <li>US-based customer service</li>
    </ul>

    <h3 class="text-lg font-semibold text-neutral-800 mb-3">Limitations</h3>
    <ul class="list-disc pl-6 space-y-1 text-neutral-700">
      <li>Highest premiums of the three</li>
      <li>Better suited for corporate than individual</li>
      <li>Complex plan structures</li>
      <li>May be overkill for simple needs</li>
    </ul>
  </div>

  <CTABox
    title="Find Coverage That Works Back Home"
    description="Compare plans designed for American expats. Full US coverage, domestic network access, and seamless care when visiting home."
    buttonText="Compare US Expat Plans"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pricing">Pricing Comparison</h2>

  <p class="text-neutral-600 mb-4">Monthly premiums for US citizens living abroad with full US return coverage. US coverage significantly impacts pricing.</p>

  <div class="my-6">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p class="text-sm text-neutral-500">US coverage adds 30-50% to international premiums. GeoBlue includes US coverage by default. Prices vary by age, residence country, and plan level.</p>

  <h2 id="us-expat-considerations">US Expat Considerations</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">US Healthcare Costs</h3>
      <p class="text-neutral-700">US healthcare is among the world's most expensive. An ER visit averages $2,000-3,000. Hospital stays run $3,000-5,000/night. Surgery can exceed $50,000. Without US coverage, a single medical event during a visit home can be financially devastating. All three insurers offer full US coverage—it's worth the premium increase.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">ACA and Tax Implications</h3>
      <p class="text-neutral-700">US expats abroad for 330+ days/year are exempt from ACA individual mandate penalties. However, MEC (Minimum Essential Coverage) plans from IMG and Aetna provide documentation if needed. GeoBlue plans are designed for expats and satisfy requirements. Consult a tax professional for your specific situation.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Network Access in the US</h3>
      <p class="text-neutral-700">GeoBlue's Blue Cross network is the largest in the US—most hospitals and doctors accept it. Aetna's network is also extensive. IMG uses PPO networks that are smaller but adequate. If you have preferred doctors or hospitals in the US, verify they're in your chosen insurer's network before purchasing.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Prescriptions in the US</h3>
      <p class="text-neutral-700">All three cover US prescriptions. GeoBlue uses Blue Cross pharmacies. Aetna uses CVS/Caremark—convenient given CVS locations nationwide. IMG covers prescriptions but may require reimbursement rather than direct billing. If you take regular medications, verify your pharmacy access.</p>
    </div>

    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-neutral-800 mb-2">Returning to the US Permanently</h3>
      <p class="text-neutral-700">If you move back to the US, international plans won't work long-term. You'll need domestic US insurance—employer coverage, ACA marketplace, or Medicare (if eligible). GeoBlue and Aetna make transitions easier given their US domestic operations. IMG is international-only. Plan your transition carefully to avoid coverage gaps.</p>
    </div>
  </div>

  <h2 id="best-for">Best For</h2>

  <div class="grid md:grid-cols-3 gap-4 my-6">
    <div class="bg-primary-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-primary-800 mb-3">Choose IMG If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>Budget is top priority</li>
        <li>You rarely visit the US</li>
        <li>You're comfortable with smaller networks</li>
        <li>Flexible deductibles appeal to you</li>
        <li>You want value over brand name</li>
      </ul>
    </div>
    <div class="bg-purple-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-purple-800 mb-3">Choose GeoBlue If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You visit the US frequently</li>
        <li>Blue Cross network access matters</li>
        <li>Seamless US coverage is priority</li>
        <li>You want American healthcare experience</li>
        <li>You have US doctors you want to keep</li>
      </ul>
    </div>
    <div class="bg-orange-50 rounded-lg p-5">
      <h3 class="text-lg font-semibold text-orange-800 mb-3">Choose Aetna If:</h3>
      <ul class="list-disc pl-5 space-y-1 text-neutral-700 text-sm">
        <li>You're a corporate expat</li>
        <li>Comprehensive benefits matter</li>
        <li>Employer is paying</li>
        <li>You want premium service</li>
        <li>CVS pharmacy access is convenient</li>
      </ul>
    </div>
  </div>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <div class="space-y-4 my-6">
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Do I need US coverage if I rarely visit home?</h3>
      <p class="text-neutral-700">Even occasional visits warrant US coverage. US healthcare costs are extreme—a single ER visit or emergency can cost tens of thousands. IMG offers the option to exclude US coverage for 40-50% savings, but one medical event during a visit can exceed years of premium savings. Most advisers recommend including US coverage.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I use my US health insurance abroad instead?</h3>
      <p class="text-neutral-700">Most US domestic health insurance (employer plans, ACA marketplace) provides limited or no coverage abroad. Even if they cover emergencies, you'll typically pay out of pocket and seek reimbursement. International expat insurance provides direct billing abroad and proper worldwide coverage. Don't rely on US domestic plans while living overseas.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">What about Medicare for older US expats?</h3>
      <p class="text-neutral-700">Medicare does not cover healthcare outside the US (with rare exceptions near borders). US expats over 65 need international insurance abroad. You can maintain Medicare enrollment for US visits but need separate coverage internationally. All three insurers serve expats well into their 70s, though premiums increase with age.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">How do claims work when I'm in the US?</h3>
      <p class="text-neutral-700">GeoBlue offers direct billing at Blue Cross facilities—show your card like any US insurance. Aetna provides direct billing at Aetna network facilities. IMG may require you to pay and submit for reimbursement at some facilities. For planned US visits, verify direct billing options at facilities you might use.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Are pre-existing conditions covered in the US?</h3>
      <p class="text-neutral-700">Coverage terms apply worldwide, including the US. If you have pre-existing condition coverage internationally, it works in the US too. New applicants may face exclusions or waiting periods depending on the condition. Underwriting varies by insurer—some are stricter than others. Disclose all conditions honestly during application.</p>
    </div>
    <div class="bg-white border border-neutral-200 rounded-lg p-5">
      <h3 class="font-semibold text-neutral-800 mb-2">Can I see my regular US doctors during visits?</h3>
      <p class="text-neutral-700">Yes, if they're in your insurer's network. GeoBlue's Blue Cross network includes most US doctors. Aetna's network is similarly extensive. IMG's PPO networks are smaller—verify your specific doctors are included. Out-of-network care is typically covered but at lower reimbursement rates, meaning higher out-of-pocket costs.</p>
    </div>
  </div>

  <div class="bg-neutral-100 rounded-lg p-5 my-6">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> US expat insurance needs vary by individual circumstances. Tax implications, ACA requirements, and Medicare eligibility are complex—consult qualified professionals. Network availability, pricing, and coverage terms change regularly. Verify specific benefits with insurers before purchasing.
    </p>
  </div>
</PageShell>
