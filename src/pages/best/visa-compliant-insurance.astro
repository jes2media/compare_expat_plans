---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'requirements', text: 'Common Requirements', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'by-country', text: 'Requirements by Country', level: 2 },
  { id: 'documentation', text: 'Getting Documentation', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Digital Nomad Visa Insurance', href: '/visas/digital-nomad' },
  { title: 'Retirement Visa Insurance', href: '/visas/retirement' },
  { title: 'Student Visa Insurance', href: '/visas/student' },
  { title: 'Schengen Insurance', href: '/insurance-for/schengen' },
  { title: 'Understanding Requirements', href: '/guides/understanding-requirements' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'certificate', header: 'Visa Certificate' },
  { key: 'schengen', header: 'Schengen Compliant' },
  { key: 'minimums', header: 'Meets Minimums' },
  { key: 'repatriation', header: 'Repatriation' },
];

const comparisonRows = [
  { provider: 'Cigna Global', certificate: 'Yes', schengen: 'Yes', minimums: 'Yes (€30K+)', repatriation: 'Included' },
  { provider: 'Bupa Global', certificate: 'Yes', schengen: 'Yes', minimums: 'Yes (€30K+)', repatriation: 'Included' },
  { provider: 'Allianz Care', certificate: 'Yes', schengen: 'Yes', minimums: 'Yes (€30K+)', repatriation: 'Included' },
  { provider: 'IMG Global', certificate: 'Yes', schengen: 'Yes', minimums: 'Yes (€30K+)', repatriation: 'Included' },
  { provider: 'SafetyWing', certificate: 'Limited', schengen: 'Check plan', minimums: 'Maybe', repatriation: 'Included' },
];

const countryColumns = [
  { key: 'country', header: 'Country/Visa' },
  { key: 'minimum', header: 'Minimum Coverage' },
  { key: 'requirements', header: 'Key Requirements' },
  { key: 'notes', header: 'Notes' },
];

const countryRows = [
  { country: 'Schengen Area', minimum: '€30,000', requirements: 'Medical + repatriation', notes: 'Short-stay visas' },
  { country: 'Spain (DNV)', minimum: '€30,000', requirements: 'No copay, public/private', notes: 'Digital Nomad Visa' },
  { country: 'Portugal (D7)', minimum: 'No minimum', requirements: 'Valid health coverage', notes: 'Flexible requirements' },
  { country: 'Thailand (LTR)', minimum: '$50,000', requirements: 'Inpatient coverage', notes: 'Long-Term Resident' },
  { country: 'Germany', minimum: 'Comprehensive', requirements: 'Must meet statutory standards', notes: 'Strict requirements' },
  { country: 'UAE', minimum: 'Government specified', requirements: 'Approved insurers only', notes: 'Emirate-specific' },
];
---

<PageShell
  title="Best Visa-Compliant Expat Insurance 2026"
  description="Find international health insurance that meets visa requirements. Compare plans that provide documentation for Schengen, digital nomad visas, and residency applications."
  headline="Best Visa-Compliant Expat Insurance"
  subheadline="Many visas require specific health insurance. Here's how to find coverage that meets your visa requirements and provides the documentation you need."
  heroImage="/images/answers/best-visa-compliant-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Visa Compliance</h2>
  <p>
    These insurers are most reliable for visa documentation:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">📋</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for Visa Documentation</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Experience with visa letters across many countries. Quick documentation turnaround.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇪🇺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for European Visas</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Strong European presence, familiar to immigration authorities. Good for Schengen and EU visas.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👑</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Premium Option</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Recognized worldwide. Premium coverage that exceeds any visa requirements.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Value Option</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">IMG Global</p>
      <p class="text-neutral-600">Meets requirements at lower cost. Good visa documentation support.</p>
    </div>
  </div>

  <h2 id="requirements">Common Visa Insurance Requirements</h2>
  <p>
    Different visas have different insurance requirements:
  </p>

  <h3>Typical Requirements</h3>
  <ul>
    <li><strong>Minimum coverage amount:</strong> €30,000-50,000 common</li>
    <li><strong>Emergency medical:</strong> Almost always required</li>
    <li><strong>Repatriation:</strong> Often required (return to home country)</li>
    <li><strong>Coverage duration:</strong> Must cover visa validity period</li>
    <li><strong>No copay:</strong> Some countries (Spain) require zero copay</li>
    <li><strong>Certificate/letter:</strong> Proof document for application</li>
  </ul>

  <h3>Schengen Requirements</h3>
  <p>
    For short-stay Schengen visas:
  </p>
  <ul>
    <li>Minimum €30,000 coverage</li>
    <li>Valid in all Schengen countries</li>
    <li>Covers emergency medical and repatriation</li>
    <li>No excess/deductible requirement in some cases</li>
    <li>Insurance certificate required with application</li>
  </ul>

  <h3>Long-Term Visa Requirements</h3>
  <p>
    For residency and long-term visas:
  </p>
  <ul>
    <li>Requirements vary significantly by country</li>
    <li>Often need comprehensive health coverage</li>
    <li>May need to be from approved insurers</li>
    <li>Letter confirming coverage usually required</li>
    <li>Some countries specify local insurance only</li>
  </ul>

  <CTABox
    title="Get Visa-Compliant Coverage"
    description="Find insurance that meets your specific visa requirements."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Visa Compliance Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best for Visa Documentation</h3>
  <p>
    Cigna Global has extensive experience providing documentation for visa applications worldwide.
  </p>
  <p><strong>Why it works for visas:</strong></p>
  <ul>
    <li>Experienced with visa letters for many countries</li>
    <li>Quick turnaround on documentation requests</li>
    <li>Coverage exceeds most minimums</li>
    <li>Recognized by immigration authorities</li>
    <li>Can customize letters to specific requirements</li>
    <li>Repatriation included</li>
  </ul>
  <p><strong>Considerations:</strong> Premium pricing. May be more than you need for basic visa compliance. Best if you also want comprehensive coverage.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Allianz Care — Best for European Visas</h3>
  <p>
    Allianz Care is well-known to European immigration authorities and handles EU visa requirements well.
  </p>
  <p><strong>Why it works for visas:</strong></p>
  <ul>
    <li>Strong European recognition</li>
    <li>Familiar to Schengen authorities</li>
    <li>Meets all EU requirements</li>
    <li>Good documentation support</li>
    <li>Multiple plan levels</li>
    <li>Repatriation included</li>
  </ul>
  <p><strong>Considerations:</strong> Network weaker outside Europe. Best for Europe-focused visas. May need higher tier for some requirements.</p>
  <p><a href="/providers/allianz-care">Read our full Allianz Care review</a></p>

  <h3>IMG Global — Best Value Option</h3>
  <p>
    IMG Global meets visa requirements at lower price points.
  </p>
  <p><strong>Why it works for visas:</strong></p>
  <ul>
    <li>Lower premiums than Cigna/Bupa</li>
    <li>Meets minimum coverage requirements</li>
    <li>Provides visa documentation</li>
    <li>Repatriation included</li>
    <li>Multiple coverage levels</li>
  </ul>
  <p><strong>Considerations:</strong> Less recognized than major insurers. Some countries may question. Service less polished. Good value for straightforward requirements.</p>
  <p><a href="/providers/img-global">Read our full IMG Global review</a></p>

  <h2 id="by-country">Requirements by Country</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={countryColumns} rows={countryRows} />
  </div>

  <h3>Spain Digital Nomad Visa</h3>
  <ul>
    <li>€30,000 minimum coverage</li>
    <li>No copay requirement (some interpret this strictly)</li>
    <li>Can be public or private insurer</li>
    <li>Must cover full visa period</li>
    <li>Repatriation coverage required</li>
  </ul>

  <h3>Portugal D7 Visa</h3>
  <ul>
    <li>No specific minimum amount</li>
    <li>Must show valid health coverage</li>
    <li>International insurance accepted</li>
    <li>Some applicants use Portuguese NHS access</li>
    <li>Relatively flexible requirements</li>
  </ul>

  <h3>Germany Residence Permit</h3>
  <ul>
    <li>Must meet statutory health insurance standards</li>
    <li>Stricter requirements for some visa types</li>
    <li>May require German-approved insurance</li>
    <li>Comprehensive coverage mandatory</li>
    <li>Check specific visa category</li>
  </ul>

  <h3>Thailand Long-Term Resident</h3>
  <ul>
    <li>$50,000 minimum coverage</li>
    <li>Inpatient coverage required</li>
    <li>International insurance accepted</li>
    <li>Some visas require Thai insurance</li>
    <li>Check specific visa category</li>
  </ul>

  <CTABox
    title="Check Your Visa Requirements"
    description="Requirements vary by country and visa type. Verify before applying."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="documentation">Getting Documentation</h2>

  <h3>What You'll Need</h3>
  <p>
    Typical visa documentation includes:
  </p>
  <ul>
    <li><strong>Insurance certificate:</strong> Confirms you have coverage</li>
    <li><strong>Coverage details:</strong> Shows what's covered and limits</li>
    <li><strong>Validity period:</strong> Must cover visa duration</li>
    <li><strong>Coverage area:</strong> Must include destination country</li>
    <li><strong>Repatriation confirmation:</strong> If required</li>
  </ul>

  <h3>How to Request Documentation</h3>
  <ol>
    <li>Contact your insurer's customer service</li>
    <li>Specify what documentation you need</li>
    <li>Mention specific visa requirements</li>
    <li>Request in the language needed (if applicable)</li>
    <li>Allow 2-5 business days for processing</li>
  </ol>

  <h3>Common Issues</h3>
  <ul>
    <li><strong>Certificate not detailed enough:</strong> Request specific letter format</li>
    <li><strong>Wrong language:</strong> Ask for translation or certified version</li>
    <li><strong>Missing information:</strong> Specify exactly what authorities require</li>
    <li><strong>Deductible mentioned:</strong> Some visas require no-copay proof</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Will SafetyWing work for visa applications?</h3>
  <p>
    Sometimes. SafetyWing meets some visa requirements but may not meet all. Issues include: may not reach minimum coverage amounts, certificate format may not be accepted, some countries specifically require full health insurance (not travel medical). Verify with your specific visa requirements.
  </p>

  <h3>What if my insurance doesn't meet requirements?</h3>
  <p>
    You may need to: upgrade to a higher plan, switch to a different insurer, or purchase supplemental coverage for the visa application. Some people buy compliant insurance for the visa, then switch later.
  </p>

  <h3>Do I need local insurance or is international okay?</h3>
  <p>
    Most countries accept international insurance. Some (like UAE, parts of Germany) require locally-approved insurers. Always verify with the specific consulate or immigration authority for your visa type.
  </p>

  <h3>What's the "no copay" requirement some countries have?</h3>
  <p>
    Countries like Spain require insurance with no out-of-pocket costs at time of service. This means no deductible or copay. Some plans meet this; others don't. Verify your plan has €0 copay/excess for the covered services.
  </p>

  <h3>How long does it take to get visa documentation?</h3>
  <p>
    Typically 2-5 business days from major insurers. Allow extra time during busy periods. Request documentation well before your visa application deadline. Some insurers offer expedited processing.
  </p>

  <h3>What if the embassy rejects my insurance?</h3>
  <p>
    Contact your insurer—they may be able to provide additional documentation or a letter addressing specific concerns. If the insurer isn't accepted, you may need to purchase coverage from an approved provider for the visa application.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Visa requirements change frequently and vary by country, visa type, and individual circumstances. We are not immigration advisors. Always verify current requirements with the relevant embassy or immigration authority.
    </p>
  </div>
</PageShell>
