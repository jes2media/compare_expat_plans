---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-preventive-care-covers', text: 'What Preventive Care Covers', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'screening-coverage', text: 'Screening Coverage', level: 2 },
  { id: 'vaccination-coverage', text: 'Vaccination Coverage', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Wellness Insurance', href: '/best/wellness-insurance' },
  { title: 'Outpatient Insurance', href: '/best/outpatient-insurance' },
  { title: 'Senior Insurance', href: '/best/senior-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'annualCheckup', header: 'Annual Checkup' },
  { key: 'screenings', header: 'Health Screenings' },
  { key: 'vaccinations', header: 'Vaccinations' },
  { key: 'allowance', header: 'Annual Allowance' },
];

const comparisonRows = [
  { provider: 'Cigna Global', annualCheckup: 'Yes', screenings: 'Comprehensive', vaccinations: 'Yes', allowance: '$500-1,500' },
  { provider: 'Bupa Global', annualCheckup: 'Yes', screenings: 'Comprehensive', vaccinations: 'Yes', allowance: '$500-2,000' },
  { provider: 'Aetna International', annualCheckup: 'Yes', screenings: 'Good', vaccinations: 'Yes', allowance: '$400-1,000' },
  { provider: 'Allianz Care', annualCheckup: 'Some plans', screenings: 'Limited', vaccinations: 'Some plans', allowance: '$300-800' },
  { provider: 'IMG Global', annualCheckup: 'No', screenings: 'Limited', vaccinations: 'No', allowance: 'Not included' },
];

const screeningsColumns = [
  { key: 'screening', header: 'Screening Type' },
  { key: 'coverage', header: 'Typical Coverage' },
  { key: 'frequency', header: 'Usual Frequency' },
];

const screeningsRows = [
  { screening: 'Annual physical exam', coverage: 'Usually covered', frequency: 'Yearly' },
  { screening: 'Blood tests (cholesterol, glucose)', coverage: 'Usually covered', frequency: 'Yearly' },
  { screening: 'Cancer screenings (mammogram, colonoscopy)', coverage: 'Often covered', frequency: 'Age-based' },
  { screening: 'Cardiovascular screening', coverage: 'Often covered', frequency: 'Every 2-5 years' },
  { screening: 'Vision screening', coverage: 'Some plans', frequency: 'Yearly' },
  { screening: 'Hearing screening', coverage: 'Some plans', frequency: 'Every 2-3 years' },
  { screening: 'Bone density scan', coverage: 'Age-based', frequency: 'Every 2 years' },
];
---

<PageShell
  title="Best Expat Insurance for Preventive Care 2026"
  description="Compare international health insurance with comprehensive preventive care coverage. Find plans that cover annual checkups, health screenings, vaccinations, and wellness programs."
  headline="Best Expat Insurance for Preventive Care"
  subheadline="Prevention is better than cure. Here are the international health plans with the best preventive care coverage including annual checkups, screenings, and vaccinations."
  heroImage="/images/answers/best-preventive-care-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Preventive Care</h2>
  <p>
    These insurers offer the best preventive care benefits:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🩺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Preventive Care</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Comprehensive preventive benefits including annual checkups, screenings, and vaccinations on most plans.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🔬</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Screening Coverage</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Excellent health screening coverage with higher allowances on premium plans.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💉</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Vaccination Coverage</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Good vaccination coverage including travel vaccines and routine immunizations.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">📈</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Why It Matters</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Early Detection</p>
      <p class="text-neutral-600">Preventive care catches health issues early when they're most treatable and least costly.</p>
    </div>
  </div>

  <h2 id="what-preventive-care-covers">What Preventive Care Covers</h2>
  <p>
    Preventive care focuses on maintaining health and catching problems early:
  </p>

  <h3>Annual Health Checkups</h3>
  <ul>
    <li>Comprehensive physical examination</li>
    <li>Blood pressure, heart rate, weight monitoring</li>
    <li>Basic blood tests (CBC, metabolic panel)</li>
    <li>Health risk assessment</li>
    <li>Doctor consultation and recommendations</li>
  </ul>

  <h3>Health Screenings</h3>
  <ul>
    <li>Cancer screenings (breast, colon, prostate, skin)</li>
    <li>Cardiovascular risk assessment</li>
    <li>Diabetes screening</li>
    <li>Cholesterol testing</li>
    <li>Bone density for osteoporosis</li>
  </ul>

  <h3>Immunizations</h3>
  <ul>
    <li>Routine adult vaccinations (flu, pneumonia, shingles)</li>
    <li>Travel vaccines (hepatitis, typhoid, yellow fever)</li>
    <li>Booster shots</li>
    <li>COVID-19 vaccinations</li>
    <li>Childhood immunizations for family plans</li>
  </ul>

  <CTABox
    title="Invest in Prevention"
    description="Compare plans with comprehensive preventive care coverage."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Preventive Care Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best Preventive Care</h3>
  <p>
    Cigna Global offers comprehensive preventive benefits on most plans.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Annual checkups included</li>
    <li>Comprehensive health screenings</li>
    <li>Vaccinations covered</li>
    <li>$500-1,500 annual preventive allowance</li>
    <li>Cancer screenings included</li>
    <li>Cardiovascular screenings</li>
    <li>Wellness programs available</li>
  </ul>
  <p><strong>Considerations:</strong> Best preventive coverage on comprehensive plans. Allowance varies by plan tier. Good balance of preventive and treatment coverage.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Best Screening Coverage</h3>
  <p>
    Bupa Global excels in health screening benefits.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Extensive screening coverage</li>
    <li>Higher allowances on premium plans ($2,000+)</li>
    <li>Annual checkups included</li>
    <li>Cancer screening programs</li>
    <li>Cardiovascular health assessments</li>
    <li>Vaccinations covered</li>
    <li>Health risk assessments</li>
  </ul>
  <p><strong>Considerations:</strong> Premium pricing. Best preventive benefits on higher tiers. Worth it for those who value proactive health management.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Aetna International — Good Vaccination Coverage</h3>
  <p>
    Aetna International provides solid preventive care with good vaccination benefits.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Good vaccination coverage including travel vaccines</li>
    <li>Annual checkups included</li>
    <li>Health screenings covered</li>
    <li>$400-1,000 annual allowance</li>
    <li>US preventive care network</li>
    <li>Wellness resources</li>
  </ul>
  <p><strong>Considerations:</strong> Moderate allowances. Good for those wanting solid preventive care without premium pricing. Best on comprehensive plans.</p>
  <p><a href="/providers/aetna-international">Read our full Aetna International review</a></p>

  <h2 id="screening-coverage">Health Screening Coverage</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={screeningsColumns} rows={screeningsRows} />
  </div>

  <h3>Cancer Screenings</h3>
  <p>
    Early detection saves lives:
  </p>
  <ul>
    <li>Mammograms for breast cancer</li>
    <li>Colonoscopy for colorectal cancer</li>
    <li>Pap smears for cervical cancer</li>
    <li>PSA tests for prostate cancer</li>
    <li>Skin cancer checks</li>
    <li>Usually age-based coverage guidelines</li>
  </ul>

  <h3>Cardiovascular Screenings</h3>
  <p>
    Heart health assessments:
  </p>
  <ul>
    <li>Blood pressure monitoring</li>
    <li>Cholesterol panels (lipid profiles)</li>
    <li>ECG/EKG when indicated</li>
    <li>Stress tests for at-risk individuals</li>
    <li>Cardiovascular risk assessments</li>
  </ul>

  <h3>Metabolic Screenings</h3>
  <p>
    Monitoring metabolic health:
  </p>
  <ul>
    <li>Blood glucose testing for diabetes</li>
    <li>HbA1c for diabetes management</li>
    <li>Thyroid function tests</li>
    <li>Liver and kidney function tests</li>
    <li>Usually included in annual checkup</li>
  </ul>

  <CTABox
    title="Stay Ahead of Health Issues"
    description="Regular screenings catch problems early."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="vaccination-coverage">Vaccination Coverage</h2>

  <h3>Routine Adult Vaccinations</h3>
  <p>
    Standard immunizations for adults:
  </p>
  <ul>
    <li>Annual flu vaccine</li>
    <li>Pneumococcal vaccine (pneumonia)</li>
    <li>Shingles vaccine</li>
    <li>Tetanus/diphtheria boosters</li>
    <li>COVID-19 vaccinations</li>
  </ul>

  <h3>Travel Vaccinations</h3>
  <p>
    Important for expats and travelers:
  </p>
  <ul>
    <li>Hepatitis A and B</li>
    <li>Typhoid</li>
    <li>Yellow fever</li>
    <li>Japanese encephalitis</li>
    <li>Rabies (pre-exposure)</li>
    <li>Coverage varies by plan</li>
  </ul>

  <h3>Childhood Vaccinations</h3>
  <p>
    For family plans:
  </p>
  <ul>
    <li>Standard childhood immunization schedule</li>
    <li>MMR, DTaP, polio vaccines</li>
    <li>Hepatitis B series</li>
    <li>Varicella (chickenpox)</li>
    <li>Usually covered for dependent children</li>
  </ul>

  <h3>Tips for Vaccination Coverage</h3>
  <ul>
    <li>Check if travel vaccines are included</li>
    <li>Verify coverage for destination-specific vaccines</li>
    <li>Ask about administration fees</li>
    <li>Some vaccines may have separate limits</li>
    <li>Keep vaccination records for claims</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Is an annual checkup covered by international health insurance?</h3>
  <p>
    On comprehensive plans with preventive care benefits, yes. Basic plans may exclude preventive care or have limited allowances. Premium plans typically include annual checkups as standard. Check specific plan benefits.
  </p>

  <h3>Are cancer screenings covered?</h3>
  <p>
    Most comprehensive international health plans cover age-appropriate cancer screenings as part of preventive care. Coverage usually follows medical guidelines for screening frequency based on age and risk factors.
  </p>

  <h3>Does preventive care have a separate allowance?</h3>
  <p>
    Often yes. Many plans have a dedicated annual preventive care or wellness allowance ($300-2,000 typically). This covers checkups, screenings, and vaccinations. Some plans include preventive care in overall outpatient benefits instead.
  </p>

  <h3>Are travel vaccinations covered?</h3>
  <p>
    Varies by plan. Comprehensive plans often cover travel vaccines as part of preventive care. Budget plans may exclude them. Coverage may be limited to certain vaccines or have caps. Check specific vaccine coverage.
  </p>

  <h3>Do I need pre-authorization for preventive care?</h3>
  <p>
    Usually not for standard preventive services like annual checkups and routine screenings. However, some advanced screenings or tests may require pre-authorization. Check your plan requirements.
  </p>

  <h3>Can I use any doctor for preventive care?</h3>
  <p>
    Most international health plans allow you to see any licensed provider for preventive services. Some may have preferred provider networks. Verify coverage and claim processes for out-of-network providers.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Preventive care coverage varies by plan and insurer. We are not insurance brokers or medical professionals. Always verify current coverage directly with insurers.
    </p>
  </div>
</PageShell>
