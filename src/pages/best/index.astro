---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ContentCards from '../../components/ContentCards.astro';

const categories = [
  {
    title: 'Best Expat Health Insurance',
    description: 'Top picks for long-term international coverage.',
    href: '/best/expat-health-insurance',
    image: '/images/answers/best-expat-insurance.png',
  },
  {
    title: 'Best for US Expats',
    description: 'Plans with built-in US coverage for Americans abroad.',
    href: '/best/us-expat-insurance',
    image: '/images/answers/best-us-expat-insurance.png',
  },
  {
    title: 'Best for Retirees',
    description: 'Medicare alternatives and coverage for 50+ expats.',
    href: '/best/retiree-health-insurance',
    image: '/images/answers/best-retiree-insurance.png',
  },
  {
    title: 'Best for Families',
    description: 'Plans with strong family and maternity benefits.',
    href: '/best/family-health-insurance',
    image: '/images/answers/best-family-insurance.png',
  },
  {
    title: 'Best Budget Options',
    description: 'Affordable coverage without sacrificing essentials.',
    href: '/best/budget-expat-insurance',
    image: '/images/answers/best-budget-insurance.png',
  },
  {
    title: 'Best for Digital Nomads',
    description: 'Flexible coverage for location-independent workers.',
    href: '/best/digital-nomad-insurance',
    image: '/images/answers/best-digital-nomad-insurance.png',
  },
];
---

<Layout title="Best Insurance Categories" description="Find the best international health insurance for your needs. Browse our curated recommendations by category.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Find the Best Insurance for Your Needs
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          Browse our curated recommendations to find the right coverage for your situation.
        </p>
        <CTAButton href="/best/expat-health-insurance" size="lg">
          See Top Picks
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={categories} title="Browse Categories" />
    </div>
  </section>
</Layout>
