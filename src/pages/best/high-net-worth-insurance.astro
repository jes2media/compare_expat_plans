---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-hnw-means', text: 'What HNW Coverage Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'key-features', text: 'Key Features', level: 2 },
  { id: 'considerations', text: 'Considerations', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Premium Insurance', href: '/best/premium-insurance' },
  { title: 'Worldwide Insurance', href: '/best/worldwide-insurance' },
  { title: 'Cancer Coverage Insurance', href: '/best/cancer-coverage-insurance' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'Understanding Premium Plans', href: '/guides/understanding-premium-plans' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'topPlan', header: 'Top-Tier Plan' },
  { key: 'coverage', header: 'Coverage Limit' },
  { key: 'concierge', header: 'Concierge Service' },
  { key: 'priceRange', header: 'Price Range' },
];

const comparisonRows = [
  { provider: 'Bupa Global', topPlan: 'Lifeline', coverage: 'Unlimited', concierge: 'Dedicated advisor', priceRange: '$800-2,500+/mo' },
  { provider: 'Cigna Global', topPlan: 'Platinum', coverage: 'Unlimited', concierge: 'Personal advisor', priceRange: '$600-1,800+/mo' },
  { provider: 'Aetna International', topPlan: 'Apex Elite', coverage: '$10M+', concierge: 'Dedicated team', priceRange: '$700-2,000+/mo' },
  { provider: 'AXA Global', topPlan: 'Excellence', coverage: '$5M+', concierge: 'Priority service', priceRange: '$500-1,500+/mo' },
  { provider: 'Allianz Care', topPlan: 'Platinum Plus', coverage: '$5M+', concierge: 'Priority service', priceRange: '$450-1,200+/mo' },
];

const featuresColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'hnw', header: 'HNW Plans' },
  { key: 'standard', header: 'Standard Plans' },
];

const featuresRows = [
  { feature: 'Coverage limit', hnw: 'Unlimited or $10M+', standard: '$1-5M' },
  { feature: 'Hospital choice', hnw: 'Any hospital worldwide', standard: 'Network preferred' },
  { feature: 'Concierge service', hnw: 'Dedicated personal advisor', standard: 'Standard support' },
  { feature: 'Second opinions', hnw: 'Unlimited, top specialists', standard: 'Limited or extra' },
  { feature: 'Executive health checks', hnw: 'Comprehensive annual', standard: 'Basic or not included' },
  { feature: 'Mental health', hnw: 'Unlimited sessions', standard: 'Capped sessions' },
  { feature: 'Evacuation', hnw: 'Unlimited, any destination', standard: 'Limited amount' },
  { feature: 'Privacy', hnw: 'Enhanced confidentiality', standard: 'Standard' },
];
---

<PageShell
  title="Best High Net Worth Expat Insurance 2026"
  description="Compare ultra-premium international health insurance for high net worth individuals and families. Find plans with unlimited coverage, concierge service, and exclusive benefits."
  headline="Best High Net Worth Expat Insurance"
  subheadline="For those who want the absolute best healthcare anywhere in the world. Unlimited coverage, dedicated advisors, and access to top specialists globally."
  heroImage="/images/answers/best-high-net-worth-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for High Net Worth</h2>
  <p>
    These insurers offer the most comprehensive coverage for high net worth individuals:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💎</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Overall HNW</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Unlimited coverage, any hospital worldwide, dedicated personal advisor. The benchmark for ultra-premium coverage.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🌐</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Global Service</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Unlimited coverage with excellent global network and service. Strong combination of coverage and support.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best US Access</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Top-tier coverage with the strongest US hospital network. Ideal for those who want Mayo Clinic, Cleveland Clinic access.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👔</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Executive Focus</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">AXA Global</p>
      <p class="text-neutral-600">Strong executive health programs, comprehensive wellness, priority service.</p>
    </div>
  </div>

  <h2 id="what-hnw-means">What HNW Coverage Means</h2>
  <p>
    High net worth insurance goes beyond standard premium coverage:
  </p>

  <h3>Unlimited Everything</h3>
  <ul>
    <li>No maximum coverage limits—treatment is never cut short</li>
    <li>No sub-limits on expensive treatments</li>
    <li>Unlimited evacuation to anywhere</li>
    <li>Unlimited mental health sessions</li>
    <li>Unlimited second opinions</li>
  </ul>

  <h3>Any Hospital, Any Doctor</h3>
  <ul>
    <li>No network restrictions whatsoever</li>
    <li>Access to world-renowned specialists</li>
    <li>Top cancer centers (MD Anderson, Memorial Sloan Kettering)</li>
    <li>Cardiac centers of excellence</li>
    <li>Transplant centers globally</li>
    <li>Direct billing or immediate reimbursement</li>
  </ul>

  <h3>Concierge-Level Service</h3>
  <ul>
    <li>Dedicated personal health advisor</li>
    <li>24/7 access to your team</li>
    <li>Proactive health management</li>
    <li>Appointment scheduling assistance</li>
    <li>Travel and logistics coordination</li>
    <li>Family support during treatment</li>
  </ul>

  <CTABox
    title="Get Elite Coverage"
    description="Compare the top plans for high net worth individuals and families."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">HNW Plan Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <p class="text-sm text-neutral-600">
    * Prices vary significantly based on age, family size, and coverage area. Figures shown are representative ranges.
  </p>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Bupa Global Lifeline — Best Overall HNW</h3>
  <p>
    Bupa Global's Lifeline plan is the benchmark for ultra-premium international health insurance.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Truly unlimited coverage—no caps, no sub-limits</li>
    <li>Any hospital in the world without restrictions</li>
    <li>Dedicated personal health advisor</li>
    <li>Second opinions from world-leading specialists</li>
    <li>Comprehensive executive health assessments</li>
    <li>Unlimited mental health coverage</li>
    <li>Wellness and prevention programs</li>
    <li>Family coverage with same benefits</li>
  </ul>
  <p><strong>Considerations:</strong> The most expensive option. But for unlimited, unrestricted coverage, it's the gold standard.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Cigna Global Platinum — Best Global Service</h3>
  <p>
    Cigna Global's Platinum plan combines unlimited coverage with excellent service worldwide.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Unlimited coverage</li>
    <li>Extensive global network</li>
    <li>Personal health advisor</li>
    <li>Excellent claims and service</li>
    <li>Strong second opinion services</li>
    <li>Comprehensive wellness programs</li>
    <li>Good telemedicine platform</li>
  </ul>
  <p><strong>Considerations:</strong> Network-focused (though extensive). Slightly less unrestricted than Bupa. Excellent value in the ultra-premium category.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h2 id="key-features">Key HNW Features</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={featuresColumns} rows={featuresRows} />
  </div>

  <h3>Executive Health Assessments</h3>
  <p>
    HNW plans include comprehensive annual health checks:
  </p>
  <ul>
    <li>Full-day executive health screening</li>
    <li>Advanced diagnostics (MRI, CT, genetic testing)</li>
    <li>Cardiac assessment</li>
    <li>Cancer screening</li>
    <li>Personalized health roadmap</li>
    <li>At premier medical centers worldwide</li>
  </ul>

  <h3>Privacy and Discretion</h3>
  <p>
    For high-profile individuals:
  </p>
  <ul>
    <li>Enhanced confidentiality protocols</li>
    <li>Private communication channels</li>
    <li>Discrete handling of medical information</li>
    <li>VIP hospital arrangements</li>
  </ul>

  <h3>Family Coverage</h3>
  <p>
    HNW plans extend to family:
  </p>
  <ul>
    <li>Same unlimited benefits for spouse/partner</li>
    <li>Children covered with full benefits</li>
    <li>Maternity with high limits ($75,000+)</li>
    <li>Pediatric specialists access</li>
    <li>Family wellness programs</li>
  </ul>

  <CTABox
    title="Protect Your Family"
    description="HNW coverage extends comprehensive protection to your entire family."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="considerations">Considerations</h2>

  <h3>Is HNW Coverage Worth It?</h3>
  <p>
    HNW coverage makes sense if:
  </p>
  <ul>
    <li>You have significant assets to protect</li>
    <li>Medical costs are inconsequential to your wealth</li>
    <li>You want the absolute best care available</li>
    <li>You value concierge service and convenience</li>
    <li>You travel extensively or live in multiple locations</li>
    <li>Peace of mind is worth the premium</li>
  </ul>

  <h3>The Cost Perspective</h3>
  <p>
    HNW plans cost $800-2,500+/month ($10,000-30,000+/year). For perspective:
  </p>
  <ul>
    <li>A single serious illness could cost $500,000-1,000,000+</li>
    <li>Medical evacuation: $50,000-200,000</li>
    <li>The premium buys unlimited protection</li>
    <li>For HNW individuals, it's a small fraction of net worth</li>
    <li>The convenience and service have real value</li>
  </ul>

  <h3>Premium vs HNW</h3>
  <p>
    The difference between premium and HNW plans:
  </p>
  <ul>
    <li><strong>Premium ($300-600/mo):</strong> High limits, good service, some restrictions</li>
    <li><strong>HNW ($800-2,500/mo):</strong> Unlimited, unrestricted, concierge service</li>
  </ul>
  <p>
    If $5M coverage and a good network is enough, premium plans offer excellent value. If you want truly unlimited, unrestricted coverage with white-glove service, HNW is the tier to choose.
  </p>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>What's the difference between premium and HNW plans?</h3>
  <p>
    Premium plans have high limits ($5M+) but still have caps. HNW plans are truly unlimited with no restrictions on hospitals, specialists, or treatments. HNW also includes dedicated concierge service rather than standard support.
  </p>

  <h3>Can I see any doctor at any hospital?</h3>
  <p>
    Yes, with true HNW plans. Bupa Global Lifeline, for example, has no network restrictions. You can go to any hospital, any specialist, anywhere in the world without pre-authorization for most care.
  </p>

  <h3>How does the concierge service work?</h3>
  <p>
    You're assigned a dedicated advisor who knows your medical history and preferences. They can schedule appointments, coordinate travel for treatment, arrange second opinions, and navigate complex care situations. Available 24/7, they're your personal healthcare coordinator.
  </p>

  <h3>Are experimental treatments covered?</h3>
  <p>
    Varies by plan and situation. Standard-of-care treatments are always covered. Experimental treatments may be considered case-by-case. HNW plans are more likely to approve cutting-edge treatments than standard plans.
  </p>

  <h3>What about privacy for high-profile individuals?</h3>
  <p>
    HNW insurers understand privacy needs. They offer enhanced confidentiality, private communication channels, and discrete handling. Some can arrange VIP hospital services. Discuss specific needs with your advisor.
  </p>

  <h3>Is there a wealth requirement to purchase HNW insurance?</h3>
  <p>
    No formal requirement, but the premiums ($10,000-30,000+/year) naturally limit the market. Anyone can purchase these plans if they can afford the premiums. The coverage is designed for those for whom cost is not the primary consideration.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Coverage details, benefits, and pricing change frequently. We are not insurance brokers. Always verify current terms directly with insurers.
    </p>
  </div>
</PageShell>
