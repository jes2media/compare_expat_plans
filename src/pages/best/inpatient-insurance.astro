---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-inpatient-means', text: 'What Inpatient Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'coverage-details', text: 'What\'s Covered', level: 2 },
  { id: 'inpatient-vs-comprehensive', text: 'Inpatient vs Comprehensive', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Outpatient Insurance', href: '/best/outpatient-insurance' },
  { title: 'Budget Insurance', href: '/best/budget-insurance' },
  { title: 'Emergency Evacuation', href: '/best/emergency-evacuation-insurance' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
  { title: 'Understanding Coverage Types', href: '/guides/understanding-coverage-types' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'inpatientOption', header: 'Inpatient-Only' },
  { key: 'coverage', header: 'Hospital Coverage' },
  { key: 'savings', header: 'vs Comprehensive' },
  { key: 'price', header: 'Price Range' },
];

const comparisonRows = [
  { provider: 'IMG Global', inpatientOption: 'Yes', coverage: 'Up to $5M', savings: '30-40% less', price: '$80-180/mo' },
  { provider: 'Cigna Global', inpatientOption: 'Core plan', coverage: 'Up to $1M', savings: '25-35% less', price: '$120-250/mo' },
  { provider: 'Allianz Care', inpatientOption: 'Hospital plan', coverage: 'Up to $2M', savings: '30-40% less', price: '$100-220/mo' },
  { provider: 'Bupa Global', inpatientOption: 'Essential', coverage: 'Up to $1.5M', savings: '20-30% less', price: '$150-300/mo' },
  { provider: 'SafetyWing', inpatientOption: 'Default', coverage: '$250K', savings: 'Already budget', price: '$45-85/mo' },
];

const coverageColumns = [
  { key: 'item', header: 'Service' },
  { key: 'inpatient', header: 'Inpatient Plans' },
  { key: 'comprehensive', header: 'Comprehensive Plans' },
];

const coverageRows = [
  { item: 'Hospital room & board', inpatient: '✓ Covered', comprehensive: '✓ Covered' },
  { item: 'Surgery', inpatient: '✓ Covered', comprehensive: '✓ Covered' },
  { item: 'ICU/intensive care', inpatient: '✓ Covered', comprehensive: '✓ Covered' },
  { item: 'In-hospital medications', inpatient: '✓ Covered', comprehensive: '✓ Covered' },
  { item: 'Doctor visits (clinic)', inpatient: '✗ Not covered', comprehensive: '✓ Covered' },
  { item: 'Specialist consultations', inpatient: '✗ Not covered', comprehensive: '✓ Covered' },
  { item: 'Prescriptions (outpatient)', inpatient: '✗ Not covered', comprehensive: '✓ Covered' },
  { item: 'Lab tests (standalone)', inpatient: '✗ Not covered', comprehensive: '✓ Covered' },
  { item: 'Preventive care', inpatient: '✗ Not covered', comprehensive: 'Often covered' },
];
---

<PageShell
  title="Best Inpatient-Only Expat Insurance 2026"
  description="Compare international health insurance with inpatient/hospital-only coverage. Find affordable plans that cover hospitalization without paying for outpatient care."
  headline="Best Inpatient-Only Expat Insurance"
  subheadline="Want coverage for serious situations without paying for routine care? Inpatient-only plans cover hospitalization at significantly lower premiums."
  heroImage="/images/answers/best-inpatient-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Inpatient Coverage</h2>
  <p>
    These insurers offer the best inpatient-only options:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏥</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Inpatient-Only Value</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">IMG Global</p>
      <p class="text-neutral-600">Dedicated inpatient plans with high coverage limits at 30-40% less than comprehensive.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">⚖️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Core Hospital Plan</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Core plan focuses on hospital coverage with option to add outpatient later.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇪🇺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best European Inpatient</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Hospital-focused plans with strong European network coverage.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Budget Inpatient</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">SafetyWing</p>
      <p class="text-neutral-600">Travel medical that's essentially inpatient-focused at $45/month.</p>
    </div>
  </div>

  <h2 id="what-inpatient-means">What Inpatient Coverage Means</h2>
  <p>
    Inpatient coverage focuses on hospital-based care:
  </p>

  <h3>What's Included</h3>
  <ul>
    <li>Hospital admission and room</li>
    <li>Surgery and surgical procedures</li>
    <li>Intensive care unit (ICU)</li>
    <li>In-hospital doctor visits</li>
    <li>In-hospital medications and supplies</li>
    <li>In-hospital diagnostics (X-rays, labs, etc.)</li>
    <li>Anesthesia and operating room</li>
    <li>Emergency room visits leading to admission</li>
  </ul>

  <h3>What's NOT Included</h3>
  <ul>
    <li>Doctor visits at clinics</li>
    <li>Specialist consultations (non-hospital)</li>
    <li>Outpatient prescriptions</li>
    <li>Standalone lab tests</li>
    <li>Preventive care and checkups</li>
    <li>Routine care</li>
  </ul>

  <h3>Why Choose Inpatient-Only?</h3>
  <ul>
    <li>Save 25-40% on premiums vs comprehensive</li>
    <li>Catastrophic coverage for serious situations</li>
    <li>Pay out-of-pocket for minor things</li>
    <li>Works well in affordable healthcare countries</li>
    <li>Good for healthy people who rarely see doctors</li>
  </ul>

  <CTABox
    title="Save on Premiums"
    description="Compare inpatient-only plans for significant savings."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Inpatient Plan Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>IMG Global — Best Inpatient-Only Value</h3>
  <p>
    IMG Global offers dedicated inpatient plans with good coverage at competitive prices.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Clear inpatient-only option</li>
    <li>Up to $5M hospital coverage</li>
    <li>30-40% cheaper than their comprehensive plans</li>
    <li>Can add outpatient later</li>
    <li>Good for catastrophic coverage</li>
  </ul>
  <p><strong>Considerations:</strong> Limited outpatient—you pay for clinic visits. Network smaller than premium insurers. Good value for hospital-focused coverage.</p>
  <p><a href="/providers/img-global">Read our full IMG Global review</a></p>

  <h3>Cigna Global Core — Best Major Insurer Option</h3>
  <p>
    Cigna Global's Core plan focuses on hospital coverage with premium insurer quality.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Hospital coverage from a top insurer</li>
    <li>Excellent network and service</li>
    <li>Can upgrade to add outpatient</li>
    <li>Strong claims processing</li>
    <li>Good hospital network globally</li>
  </ul>
  <p><strong>Considerations:</strong> More expensive than IMG. Still good value vs Cigna comprehensive. Premium insurer quality.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>SafetyWing — Budget Option</h3>
  <p>
    SafetyWing is essentially inpatient-focused travel medical at very low cost.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Only $45-85/month</li>
    <li>Covers hospitalization and emergencies</li>
    <li>Good for serious situations</li>
    <li>No health questions</li>
    <li>Monthly billing</li>
  </ul>
  <p><strong>Considerations:</strong> Lower limits ($250K). Travel medical, not full health insurance. Pre-existing excluded. Good for healthy nomads.</p>
  <p><a href="/providers/safetywing">Read our full SafetyWing review</a></p>

  <h2 id="coverage-details">What's Covered</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Day Surgery</h3>
  <p>
    Many inpatient plans also cover day surgery:
  </p>
  <ul>
    <li>Procedures that don't require overnight stay</li>
    <li>Colonoscopy, minor surgeries, etc.</li>
    <li>Usually covered as "inpatient" even without admission</li>
    <li>Verify with your specific plan</li>
  </ul>

  <h3>Emergency Room</h3>
  <p>
    ER coverage varies:
  </p>
  <ul>
    <li>ER visits leading to admission: covered</li>
    <li>ER visits without admission: may or may not be covered</li>
    <li>Some plans cover ER regardless</li>
    <li>Check your specific policy terms</li>
  </ul>

  <CTABox
    title="Understand Your Coverage"
    description="Compare what's included in different inpatient plans."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="inpatient-vs-comprehensive">Inpatient vs Comprehensive</h2>

  <h3>When Inpatient-Only Makes Sense</h3>
  <ul>
    <li>You're healthy and rarely visit doctors</li>
    <li>You're in a country with affordable outpatient care</li>
    <li>You want to minimize premiums</li>
    <li>You can pay out-of-pocket for clinic visits</li>
    <li>You mainly want catastrophic protection</li>
  </ul>

  <h3>When Comprehensive Is Better</h3>
  <ul>
    <li>You have ongoing health needs</li>
    <li>You see doctors regularly</li>
    <li>You're in an expensive healthcare country</li>
    <li>You want everything covered</li>
    <li>You have a family with various needs</li>
  </ul>

  <h3>The Math</h3>
  <p>
    Example calculation:
  </p>
  <ul>
    <li>Comprehensive plan: $350/month = $4,200/year</li>
    <li>Inpatient-only plan: $200/month = $2,400/year</li>
    <li>Savings: $1,800/year</li>
    <li>That covers a lot of clinic visits if you pay out-of-pocket</li>
  </ul>
  <p>
    In countries like Thailand, Mexico, or Portugal, $1,800 pays for many doctor visits.
  </p>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Does inpatient-only cover emergency room visits?</h3>
  <p>
    Usually yes if the ER visit leads to hospital admission. Standalone ER visits (treat and release) may or may not be covered—check your specific plan. Some inpatient plans include ER regardless.
  </p>

  <h3>What about outpatient surgery?</h3>
  <p>
    Day surgery (procedures at a hospital facility) is often covered under inpatient plans even without overnight admission. Minor procedures at a clinic are typically not covered. Verify with your insurer.
  </p>

  <h3>Can I add outpatient coverage later?</h3>
  <p>
    Usually yes, at renewal. Most insurers allow you to upgrade from inpatient-only to comprehensive. You may need underwriting, and conditions developed may affect the upgrade.
  </p>

  <h3>How much can I save with inpatient-only?</h3>
  <p>
    Typically 25-40% compared to comprehensive coverage from the same insurer. On a $400/month comprehensive plan, that could be $100-160/month savings ($1,200-1,920/year).
  </p>

  <h3>Is inpatient-only enough for visa requirements?</h3>
  <p>
    Depends on the visa. Some visas specify minimum coverage amounts that inpatient plans meet. Others require "comprehensive" or specify outpatient coverage. Check your specific visa requirements.
  </p>

  <h3>What happens if I need outpatient care?</h3>
  <p>
    You pay out-of-pocket. See a doctor, pay at the clinic, no claim to file. In many countries, this is affordable ($20-100 per visit). In expensive countries, costs add up quickly.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Coverage details vary by plan. We are not insurance brokers. Always verify current terms directly with insurers.
    </p>
  </div>
</PageShell>
