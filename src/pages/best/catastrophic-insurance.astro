---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-catastrophic-means', text: 'What Catastrophic Coverage Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'how-it-works', text: 'How It Works', level: 2 },
  { id: 'who-should-consider', text: 'Who Should Consider It', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Budget Insurance', href: '/best/budget-insurance' },
  { title: 'Flexible Deductible Insurance', href: '/best/flexible-deductible-insurance' },
  { title: 'Digital Nomad Insurance', href: '/best/digital-nomad-insurance' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'IMG Global Review', href: '/providers/img-global' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'catastrophic', header: 'High-Deductible Option' },
  { key: 'deductible', header: 'Deductible Range' },
  { key: 'premium', header: 'Monthly Premium' },
  { key: 'coverage', header: 'Coverage Limit' },
];

const comparisonRows = [
  { provider: 'Cigna Global', catastrophic: 'Yes', deductible: '$5,000-10,000', premium: '$100-200', coverage: '$1M+' },
  { provider: 'IMG Global', catastrophic: 'Yes', deductible: '$2,500-5,000', premium: '$50-150', coverage: '$1M-5M' },
  { provider: 'SafetyWing', catastrophic: 'Yes (travel)', deductible: '$250-500', premium: '$45-100', coverage: '$250K' },
  { provider: 'Allianz Care', catastrophic: 'Yes', deductible: '$2,500-5,000', premium: '$80-180', coverage: '$1M+' },
  { provider: 'GeoBlue', catastrophic: 'Yes', deductible: '$2,500-5,000', premium: '$100-200', coverage: '$1M-5M' },
];

const comparisonColumns2 = [
  { key: 'factor', header: 'Factor' },
  { key: 'catastrophic', header: 'Catastrophic Plan' },
  { key: 'comprehensive', header: 'Comprehensive Plan' },
];

const comparisonRows2 = [
  { factor: 'Monthly premium', catastrophic: '$50-200', comprehensive: '$300-800+' },
  { factor: 'Annual deductible', catastrophic: '$2,500-10,000', comprehensive: '$0-1,000' },
  { factor: 'Routine care', catastrophic: 'Pay out-of-pocket', comprehensive: 'Covered (copay)' },
  { factor: 'Major illness/accident', catastrophic: 'Fully covered after deductible', comprehensive: 'Fully covered' },
  { factor: 'Best for', catastrophic: 'Healthy individuals', comprehensive: 'Regular healthcare users' },
  { factor: 'Financial risk', catastrophic: 'Higher (up to deductible)', comprehensive: 'Lower' },
];
---

<PageShell
