  heroImage="/images/answers/best-catastrophic-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Catastrophic Coverage</h2>
  <p>
    These insurers offer the best high-deductible options:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🛡️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Catastrophic Coverage</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">High-deductible options with excellent underlying coverage and global network.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Value</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">IMG Global</p>
      <p class="text-neutral-600">Affordable high-deductible plans with good coverage limits for the price.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🌏</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for Nomads</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">SafetyWing</p>
      <p class="text-neutral-600">Travel-style catastrophic coverage at very low cost for digital nomads.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">⚠️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Key Concept</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">High Risk, Low Premium</p>
      <p class="text-neutral-600">You pay more out-of-pocket for routine care but are protected against major expenses.</p>
    </div>
  </div>

  <h2 id="what-catastrophic-means">What Catastrophic Coverage Means</h2>
  <p>
    Catastrophic insurance protects against major medical expenses with high deductibles:
  </p>

  <h3>The Basic Concept</h3>
  <ul>
    <li>Very high deductible ($2,500-10,000+)</li>
    <li>Much lower monthly premiums</li>
    <li>You pay for routine care out-of-pocket</li>
    <li>Insurance kicks in for major expenses</li>
    <li>Protects against financial catastrophe</li>
  </ul>

  <h3>What's Covered</h3>
  <ul>
    <li>Hospital stays (after deductible)</li>
    <li>Surgery and major procedures</li>
    <li>Emergency care</li>
    <li>Cancer treatment</li>
    <li>Serious accidents and illness</li>
    <li>Everything a comprehensive plan covers—after deductible</li>
  </ul>

  <h3>What You Pay Out-of-Pocket</h3>
  <ul>
    <li>All costs up to your deductible</li>
    <li>Doctor visits (likely under deductible)</li>
    <li>Routine prescriptions</li>
    <li>Minor procedures</li>
    <li>Preventive care (unless plan includes pre-deductible)</li>
  </ul>

  <CTABox
    title="Protection Without High Premiums"
    description="Compare catastrophic insurance options."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Catastrophic Plan Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

