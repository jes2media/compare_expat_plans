const tocItems = [
  { id: 'top-picks', text: 'Our Top Picks', level: 2 },
  { id: 'teacher-types', text: 'Coverage by Teacher Type', level: 2 },
  { id: 'how-we-evaluated', text: 'How We Evaluated', level: 2 },
  { id: 'comparison-table', text: 'Quick Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'choosing-the-right-plan', text: 'Choosing the Right Plan', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Budget Expat Insurance', href: '/best/budget-expat-insurance' },
  { title: 'Asia Insurance', href: '/best/asia-insurance' },
  { title: 'Europe Insurance', href: '/best/europe-insurance' },
  { title: 'First-Time Expat Insurance', href: '/best/first-time-expat-insurance' },
  { title: 'Family Health Insurance', href: '/best/family-health-insurance' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'monthlyFrom', header: 'Monthly From' },
  { key: 'coverage', header: 'Max Coverage' },
  { key: 'mentalHealth', header: 'Mental Health' },
  { key: 'bestFor', header: 'Best For' },
];

const comparisonRows = [
  { provider: 'SafetyWing', monthlyFrom: '$45-68', coverage: '$250K', mentalHealth: 'Limited', bestFor: 'ESL teachers, budget-conscious' },
  { provider: 'Cigna Global', monthlyFrom: '$150-300', coverage: 'Unlimited', mentalHealth: 'Full', bestFor: 'International school teachers' },
  { provider: 'Now Health', monthlyFrom: '$120-220', coverage: '$1.5M+', mentalHealth: 'Included', bestFor: 'Value seekers, Asia-based' },
  { provider: 'Allianz Care', monthlyFrom: '$135-250', coverage: '$2M+', mentalHealth: 'Included', bestFor: 'Europe-based, families' },
  { provider: 'IMG Global', monthlyFrom: '$85-150', coverage: '$2M', mentalHealth: 'Optional', bestFor: 'Mid-range comprehensive' },
];
---

<PageShell
  title="Best Health Insurance for Teachers Abroad 2026 | ESL & International Schools"
  description="Compare health insurance for teachers working abroad. From ESL teachers in Asia to international school educators—find coverage that fits your situation and budget."
  headline="Best Health Insurance for Teachers Abroad"
  subheadline="Whether you're teaching English in Vietnam or working at an international school in Switzerland, you need insurance that matches your situation—and your budget."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Teacher Quotes →"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="top-picks">Our Top Picks</h2>
  <p>
    Teaching abroad spans a huge range—from first-year ESL teachers earning $1,500/month in Thailand to veteran international school teachers making $80,000+ in Dubai. Insurance needs vary just as much.
  </p>

  <p>
    After analyzing coverage options for educators abroad, here are our recommendations:
  </p>

  <h3>Best for ESL Teachers: SafetyWing</h3>
  <p>
    <strong>The good:</strong> $45/month subscription, works globally, no commitment. Perfect for entry-level ESL teachers watching every dollar. Monthly billing means you can cancel if you move home.
  </p>
  <p>
    <strong>The limits:</strong> $250K coverage cap, basic mental health coverage. This is travel medical insurance, not comprehensive health coverage. Fine for healthy 20-somethings; less ideal for teachers with health concerns.
  </p>
  <p>
    <strong>Best for:</strong> First-time ESL teachers, TEFL certificate holders teaching in Asia or Latin America, teachers earning under $2,500/month.
  </p>

  <h3>Best for International School Teachers: Cigna Global</h3>
  <p>
    <strong>The good:</strong> Comprehensive coverage matching what you'd expect from a proper employer plan. Unlimited coverage, strong network, excellent mental health benefits. Many international schools use Cigna for faculty.
  </p>
  <p>
    <strong>The limits:</strong> Premium pricing—$150-300/month for individuals. Worth it if your school provides it; harder to justify if paying yourself on a modest salary.
  </p>
  <p>
    <strong>Best for:</strong> International school teachers, especially those with families or health concerns. Often provided by top-tier international schools.
  </p>

  <h3>Best Value Comprehensive: Now Health</h3>
  <p>
    <strong>The good:</strong> Cigna-level coverage at lower price points. Strong in Asia where many teachers are based. Modular plans let you build what you need.
  </p>
  <p>
    <strong>The limits:</strong> Smaller network than Cigna/BUPA, less brand recognition. May need to pay-and-claim in some locations.
  </p>
  <p>
    <strong>Best for:</strong> Mid-career teachers wanting real health insurance without international school pricing.
  </p>

  <CTABox
    title="Get Teacher Insurance Quotes"
    description="Compare plans suited to educators abroad. Multiple options for every budget."
    buttonText="Compare Plans →"
    buttonHref="/go/cigna-global"
  />

  <h2 id="teacher-types">Coverage by Teacher Type</h2>

  <h3>ESL/TEFL Teachers</h3>
  <p>
    You're likely earning $1,000-3,000/month teaching English in Asia, Latin America, or the Middle East. Budget matters. But so does having coverage when you get food poisoning in Vietnam or need to see a doctor for a recurring issue.
  </p>
  <ul>
    <li><strong>Minimum coverage:</strong> SafetyWing or similar travel medical insurance. Covers emergencies and acute care.</li>
    <li><strong>Upgrade when:</strong> You have chronic conditions, plan to stay 2+ years, or earn enough to afford better coverage.</li>
    <li><strong>School insurance:</strong> Some ESL schools offer basic coverage. Check what's included—often minimal.</li>
  </ul>

  <h3>International School Teachers</h3>
  <p>
    You're a credentialed teacher at an accredited international school, likely earning $40,000-100,000+ depending on location and experience. Many schools provide insurance as part of your package.
  </p>
  <ul>
    <li><strong>School-provided:</strong> Check the plan details. Top schools provide Cigna, BUPA, or Allianz. Others offer local plans with limitations.</li>
    <li><strong>Gaps to fill:</strong> Home country coverage during summer? Family not covered by school plan? Mental health limits?</li>
    <li><strong>Supplemental coverage:</strong> If school insurance is weak, consider adding personal comprehensive coverage.</li>
  </ul>

  <h3>University Lecturers/Professors</h3>
  <p>
    Academic positions abroad often include insurance, but quality varies widely. State universities may offer local public health access; private universities might provide international coverage.
  </p>
  <ul>
    <li><strong>Verify coverage scope:</strong> Does it cover you only in-country or during conference travel and sabbaticals?</li>
    <li><strong>Research positions:</strong> Grant-funded positions may have insurance requirements—check with your institution.</li>
  </ul>

  <h3>Private Tutors/Online Teachers</h3>
  <p>
    Self-employed teachers need to arrange their own coverage entirely. No employer is providing anything.
  </p>
  <ul>
    <li><strong>Budget option:</strong> SafetyWing for basic protection</li>
    <li><strong>Comprehensive:</strong> Now Health or IMG for real health insurance at reasonable rates</li>
    <li><strong>Tax considerations:</strong> Insurance premiums may be deductible as business expenses depending on your tax situation</li>
  </ul>

  <h2 id="how-we-evaluated">How We Evaluated</h2>
  <p>
    We focused on factors that matter specifically for teachers abroad:
  </p>

  <ul>
    <li><strong>Value for money:</strong> Most teachers aren't highly paid. We prioritized plans offering good coverage at realistic prices.</li>
    <li><strong>Geographic coverage:</strong> Strong networks in common teaching destinations—Asia, Middle East, Europe, Latin America.</li>
    <li><strong>Mental health:</strong> Teaching abroad can be isolating. Mental health coverage matters more than teachers often realize.</li>
    <li><strong>Summer/home leave coverage:</strong> Do you lose coverage when you visit home? This matters for teachers.</li>
    <li><strong>Family plans:</strong> Many teachers bring families. We evaluated family coverage options and pricing.</li>
  </ul>

  <h2 id="comparison-table">Quick Comparison</h2>
  <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>SafetyWing Nomad Insurance</h3>
  <p>
    SafetyWing has become the default choice for budget-conscious ESL teachers, and for good reason. At $45/month, it's affordable on even modest teaching salaries. The subscription model means no annual commitment—sign up when you arrive, cancel when you leave.
  </p>

  <p>
    Coverage includes emergency medical ($250K limit), hospital stays, and basic outpatient care. Home country visits up to 30 days are included, useful for summer breaks. The app is simple, claims processing is straightforward.
  </p>

  <p>
    The limitations are real: $250 deductible per incident, minimal chronic condition coverage, basic mental health. If you're healthy and just need emergency backup, it works. If you have ongoing health needs, you need more.
  </p>

  <p>
    <strong>Pricing:</strong> $45-68/month depending on age. No family discount—each person pays individually.
  </p>

  <p>
    <strong>Verdict:</strong> Best starting point for ESL teachers. Upgrade when you can afford it or your health needs change.
  </p>

  <h3>Cigna Global</h3>
  <p>
    Cigna is what good international school insurance looks like. If your school provides Cigna, you're in good hands. If you're buying it yourself, you're getting premium coverage at premium prices.
  </p>

  <p>
    The modular system lets you build your coverage: inpatient core, add outpatient, add mental health, add dental/vision. For teachers, the mental health module is worth considering—culture shock, isolation, and work stress are real.
  </p>

  <p>
    Network coverage is excellent in major teaching destinations. Bangkok, Dubai, Shanghai, London, Mexico City—you'll find direct billing options. Claims through the app work smoothly.
  </p>

  <p>
    <strong>Pricing:</strong> $150-300/month for individuals with solid coverage. Families run $400-700/month.
  </p>

  <p>
    <strong>Verdict:</strong> The standard for international school teachers. Worth it if provided by your school or if you can comfortably afford it.
  </p>

  <h3>Now Health</h3>
  <p>
    Now Health offers Cigna-style coverage at more accessible prices. For teachers earning decent salaries but not international school packages, this is the sweet spot.
  </p>

  <p>
    Strong presence in Asia, where many teachers are based. Hong Kong, Singapore, Thailand, Vietnam networks are solid. Modular plans work similarly to Cigna—build what you need.
  </p>

  <p>
    Trade-off: smaller global footprint than the premium brands. If you're teaching in rural Africa, network coverage may be limited. But for typical teaching destinations, it works well.
  </p>

  <p>
    <strong>Pricing:</strong> $120-220/month for individuals. Families around $350-550/month.
  </p>

  <p>
    <strong>Verdict:</strong> Best value for teachers wanting comprehensive coverage without international school pricing.
  </p>

  <h3>Allianz Care</h3>
  <p>
    German reliability applied to international health insurance. Allianz is particularly strong in Europe—if you're teaching in Germany, France, Spain, or the UK, their network shines.
  </p>

  <p>
    Good preventive care coverage including vaccinations and check-ups. Mental health is included. Family coverage works well for teachers with children.
  </p>

  <p>
    <strong>Pricing:</strong> $135-250/month for individuals. Competitive family rates.
  </p>

  <p>
    <strong>Verdict:</strong> Strong choice for Europe-based teachers, especially families.
  </p>

  <h3>IMG Global</h3>
  <p>
    IMG offers solid comprehensive coverage at mid-range prices. Less premium than Cigna/BUPA, more comprehensive than SafetyWing. Good middle ground for teachers.
  </p>

  <p>
    Coverage up to $2M handles virtually any scenario. Network is decent in major cities. Mental health coverage available as add-on. US coverage less expensive than European insurers if you're American.
  </p>

  <p>
    <strong>Pricing:</strong> $85-150/month for individuals. Good family options.
  </p>

  <p>
    <strong>Verdict:</strong> Solid mid-range option for teachers wanting more than travel medical at reasonable cost.
  </p>

  <CTABox
    title="Compare Teacher Insurance Plans"
    description="Find coverage that fits your teaching situation and budget."
    buttonText="Get Your Quote →"
    buttonHref="/go/now-health"
  />

  <h2 id="choosing-the-right-plan">Choosing the Right Plan</h2>

  <h3>By Income Level</h3>
  <ul>
    <li><strong>Under $2,000/month:</strong> SafetyWing—it's affordable and covers emergencies</li>
    <li><strong>$2,000-4,000/month:</strong> Now Health or IMG—step up to real health insurance</li>
    <li><strong>$4,000+/month:</strong> Cigna Global or Allianz—comprehensive coverage you can comfortably afford</li>
    <li><strong>School-provided:</strong> Verify what's included, fill gaps if needed</li>
  </ul>

  <h3>By Location</h3>
  <ul>
    <li><strong>Asia (Thailand, Vietnam, Korea, Japan):</strong> Now Health (best regional network) or SafetyWing (budget)</li>
    <li><strong>Middle East (UAE, Saudi, Qatar):</strong> Cigna Global (strong Gulf network) or local mandatory plans</li>
    <li><strong>Europe:</strong> Allianz Care (European strength) or Cigna</li>
    <li><strong>Latin America:</strong> SafetyWing (budget) or Cigna Global (comprehensive)</li>
  </ul>

  <h3>By Situation</h3>
  <ul>
    <li><strong>First year teaching abroad:</strong> Start with SafetyWing, upgrade as you settle</li>
    <li><strong>Family teaching abroad:</strong> Cigna Global or Allianz for comprehensive family coverage</li>
    <li><strong>Existing health conditions:</strong> Comprehensive plans with proper underwriting (not travel medical)</li>
    <li><strong>Planning pregnancy:</strong> Check maternity coverage and waiting periods (typically 10-12 months)</li>
  </ul>

  <h2 id="faqs">Common Questions</h2>

  <div class="space-y-6 my-8">
    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Should I rely on my school's insurance?</h3>
      <p class="text-neutral-600 mb-0">
        Depends on the school. Top international schools provide excellent coverage (Cigna, BUPA, Allianz). Budget ESL schools may offer minimal local plans. Always request the full policy details—coverage limits, exclusions, network, home country coverage during breaks. If it's inadequate, supplement or replace it.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What about coverage during summer break?</h3>
      <p class="text-neutral-600 mb-0">
        Many teacher plans maintain coverage during school breaks. SafetyWing includes home country visits up to 30 days. School-provided plans vary—some pause during summer, others continue. Always verify summer coverage, especially if you'll be traveling or returning home.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Is mental health coverage important for teachers?</h3>
      <p class="text-neutral-600 mb-0">
        Yes. Teaching abroad involves culture shock, isolation, demanding work, and separation from support networks. Burnout is common, especially in first-year teachers. Mental health coverage provides access to counseling when you need it. SafetyWing has limited coverage; Cigna and Now Health have better options.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Can I get insurance with a pre-existing condition?</h3>
      <p class="text-neutral-600 mb-0">
        Yes, but it affects your options. SafetyWing and travel medical plans typically exclude pre-existing conditions. Comprehensive plans (Cigna, Allianz, Now Health) can cover them with proper underwriting—expect waiting periods, exclusions, or premium loading depending on the condition. Full disclosure is essential.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What if I'm teaching in a remote location?</h3>
      <p class="text-neutral-600 mb-0">
        Evacuation coverage becomes critical. Make sure your plan covers medical evacuation to appropriate facilities—not just the nearest clinic, but proper hospitals. SafetyWing includes $100K evacuation; Cigna has unlimited. In truly remote areas, you may need to pay upfront and claim reimbursement.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">How do I handle insurance when changing schools/countries?</h3>
      <p class="text-neutral-600 mb-0">
        Personal plans (SafetyWing, Cigna individual) travel with you. School-provided plans typically end with employment. Plan transitions carefully—maintain continuous coverage to avoid gaps that could affect future underwriting. Notify your insurer of address changes; some plans require destination approval.
      </p>
    </div>
  </div>

  <CTABox
    title="Ready to Get Covered?"
    description="Compare plans designed for teachers abroad. From ESL to international schools."
    buttonText="Compare Plans Now →"
    buttonHref="/go/cigna-global"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600 mb-0">
      <strong>Disclaimer:</strong> Insurance requirements and costs vary by location, school, and individual circumstances. School-provided coverage should be verified directly with your employer. Prices shown are estimates for healthy applicants. Always confirm coverage details and current pricing with providers before purchasing.
    </p>
  </div>
</PageShell>
