const comparisonRows = [
  { provider: 'Cigna Global', networkSize: '1.5M+ providers', directBilling: 'Excellent', regions: 'US, Europe, Asia', setup: 'Easy via app' },
  { provider: 'Bupa Global', networkSize: '1M+ providers', directBilling: 'Excellent', regions: 'Worldwide', setup: 'Contact team' },
  { provider: 'Aetna International', networkSize: '1M+ providers', directBilling: 'Very Good', regions: 'US (best), Global', setup: 'Easy via app' },
  { provider: 'Allianz Care', networkSize: 'Large', directBilling: 'Good', regions: 'Europe (best)', setup: 'Contact team' },
  { provider: 'IMG Global', networkSize: 'Moderate', directBilling: 'Limited', regions: 'US, selective global', setup: 'Pre-approval' },
];

const processColumns = [
  { key: 'step', header: 'Step' },
  { key: 'directBilling', header: 'Direct Billing' },
  { key: 'reimbursement', header: 'Reimbursement' },
];

const processRows = [
  { step: '1. Before appointment', directBilling: 'Find in-network provider', reimbursement: 'Go to any provider' },
  { step: '2. Check-in', directBilling: 'Show insurance card', reimbursement: 'Provide your details' },
  { step: '3. Treatment', directBilling: 'Receive care', reimbursement: 'Receive care' },
  { step: '4. Payment', directBilling: 'Insurer pays provider directly', reimbursement: 'You pay full bill' },
  { step: '5. Your cost', directBilling: 'Pay only deductible/copay', reimbursement: 'Submit claim for reimbursement' },
  { step: '6. Settlement', directBilling: 'Immediate', reimbursement: 'Wait 2-6 weeks for refund' },
];
---

<PageShell
  title="Best Expat Insurance with Direct Billing 2026"
  description="Compare international health insurance with strong direct billing networks. Find plans where hospitals bill your insurer directly so you don't pay upfront."
  headline="Best Expat Insurance with Direct Billing"
  subheadline="Don't want to pay large hospital bills upfront and wait for reimbursement? Direct billing means the hospital bills your insurer directly. Here are the best options."
  heroImage="/images/answers/best-direct-billing-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Direct Billing</h2>
  <p>
    These insurers have the strongest direct billing networks:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏥</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Direct Billing Network</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">1.5M+ providers globally, excellent app for finding direct billing hospitals. Seamless cashless experience.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🌍</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Worldwide Direct Billing</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Strong network globally with excellent coordination. Premium service for arranging cashless care.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best US Direct Billing</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Strongest US hospital network with excellent direct billing at major American hospitals.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇪🇺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best European Direct Billing</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Strong European network with good direct billing across EU countries.</p>
    </div>
  </div>

  <h2 id="what-direct-billing-means">What Direct Billing Means</h2>
  <p>
    Direct billing (also called "cashless" or "third-party billing") means:
  </p>

  <h3>The Simple Version</h3>
  <ul>
    <li>You go to a network hospital</li>
    <li>Hospital bills your insurer directly</li>
    <li>You pay only your deductible/copay (if any)</li>
    <li>No large upfront payment required</li>
    <li>No claim submission needed</li>
  </ul>

  <h3>The Alternative: Reimbursement</h3>
  <ul>
    <li>You go to any hospital</li>
    <li>You pay the full bill upfront</li>
    <li>You submit a claim with receipts</li>
    <li>Insurer reimburses you 2-6 weeks later</li>
    <li>You need cash/credit available for large bills</li>
  </ul>

  <h3>Why Direct Billing Matters</h3>
  <ul>
    <li>A hospital stay can cost $5,000-50,000+</li>
    <li>Not everyone has that available on a credit card</li>
    <li>Waiting weeks for reimbursement is stressful</li>
    <li>Direct billing eliminates financial stress during illness</li>
  </ul>

  <CTABox
    title="Find Cashless Coverage"
    description="Compare plans with strong direct billing networks in your area."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Network Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best Direct Billing Network</h3>
  <p>
    Cigna Global has built one of the most extensive direct billing networks in international health insurance.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>1.5 million+ providers globally</li>
    <li>Easy-to-use app for finding network providers</li>
    <li>Pre-authorization handled electronically</li>
    <li>Direct billing at most major hospitals</li>
    <li>Strong in US, Europe, and Asia</li>
    <li>Hospital coordination team available</li>
    <li>Real-time eligibility verification</li>
  </ul>
  <p><strong>Considerations:</strong> Direct billing requires using network providers. May need pre-authorization for some procedures. Premium pricing.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Best Worldwide Direct Billing</h3>
  <p>
    Bupa Global offers excellent direct billing with premium service to coordinate cashless care globally.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Strong global network</li>
    <li>Concierge service arranges direct billing</li>
    <li>Can often arrange direct billing at out-of-network hospitals</li>
    <li>Premium service coordination</li>
    <li>24/7 support for hospital arrangements</li>
    <li>Good in diverse global locations</li>
  </ul>
  <p><strong>Considerations:</strong> Most expensive option. Service-based approach (call to arrange) rather than app-based. Worth it for the coordination.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Aetna International — Best US Direct Billing</h3>
  <p>
    Aetna International offers the best direct billing network in the United States.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Largest US hospital network</li>
    <li>Direct billing at major US hospitals</li>
    <li>Familiar to US healthcare providers</li>
    <li>Easy app-based provider search</li>
    <li>Good global network as well</li>
  </ul>
  <p><strong>Considerations:</strong> US coverage is expensive. Best if US access matters. Global network not quite as extensive as Cigna outside US.</p>
  <p><a href="/providers/aetna-international">Read our full Aetna International review</a></p>

  <h2 id="how-it-works">How Direct Billing Works</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={processColumns} rows={processRows} />
  </div>

  <h3>Setting Up Direct Billing</h3>
  <ol>
    <li><strong>Find a network provider:</strong> Use your insurer's app or website</li>
    <li><strong>Call ahead:</strong> Confirm they accept your specific plan</li>
    <li><strong>Get pre-authorization:</strong> For planned procedures (often handled by insurer)</li>
    <li><strong>Bring your insurance card:</strong> Provider verifies coverage</li>
    <li><strong>Receive care:</strong> Hospital bills insurer directly</li>
    <li><strong>Pay your share:</strong> Just deductible/copay if applicable</li>
  </ol>

  <h3>Emergency Direct Billing</h3>
  <p>
    In emergencies:
  </p>
  <ul>
    <li>Go to nearest hospital (network or not)</li>
    <li>Have someone call your insurer ASAP</li>
    <li>Insurer can often arrange direct billing even at non-network hospitals</li>
    <li>If not possible, they'll guide you on reimbursement</li>
    <li>Emergency care is covered regardless of network</li>
  </ul>

  <CTABox
    title="Understand Your Network"
    description="Check network coverage in your location before choosing a plan."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="considerations">Key Considerations</h2>

  <h3>Network Varies by Location</h3>
  <p>
    Important to understand:
  </p>
  <ul>
    <li>Network strength varies by country and city</li>
    <li>An insurer strong in one region may be weak in another</li>
    <li>Check network specifically for where you live</li>
    <li>Major cities usually have better coverage</li>
    <li>Rural areas may have limited direct billing</li>
  </ul>

  <h3>Pre-Authorization Requirements</h3>
  <ul>
    <li>Planned procedures often need pre-approval</li>
    <li>Insurer verifies medical necessity</li>
    <li>Usually done within 24-48 hours</li>
    <li>Emergency care doesn't need pre-authorization</li>
    <li>Skipping pre-auth may affect coverage</li>
  </ul>

  <h3>When Direct Billing Isn't Available</h3>
  <ul>
    <li>Out-of-network providers</li>
    <li>Small clinics and private practices</li>
    <li>Some countries with limited networks</li>
    <li>You'll need to pay and claim reimbursement</li>
    <li>Keep all receipts and documentation</li>
  </ul>

  <h3>Direct Billing vs Freedom</h3>
  <p>
    The trade-off:
  </p>
  <ul>
    <li><strong>Network-focused (Cigna):</strong> Best direct billing, but incentivized to use network</li>
    <li><strong>Freedom-focused (Bupa):</strong> Any hospital, but may need to pay and claim</li>
  </ul>
  <p>
    Choose based on your priority: cashless convenience or complete freedom.
  </p>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>What if there's no network hospital near me?</h3>
  <p>
    You can still use any hospital—you'll just pay upfront and claim reimbursement. Premium insurers like Bupa can sometimes arrange direct billing even at non-network hospitals. Check with your insurer before assuming no direct billing is available.
  </p>

  <h3>Does direct billing work for all treatments?</h3>
  <p>
    Generally yes for covered treatments at network facilities. Some procedures need pre-authorization. Experimental treatments may not be approved for direct billing. Outpatient care sometimes requires paying and claiming.
  </p>

  <h3>What do I pay at a direct billing hospital?</h3>
  <p>
    Just your deductible and any copay/coinsurance. If you have a $500 deductible and 20% coinsurance, you pay $500 + 20% of remaining costs. With $0 deductible and full coverage, you may pay nothing at point of service.
  </p>

  <h3>How do I find direct billing hospitals?</h3>
  <p>
    Most insurers provide: (1) Mobile app with provider search, (2) Website provider directory, (3) Customer service to confirm specific providers. Call ahead to confirm—directories aren't always current.
  </p>

  <h3>What about prescription medications?</h3>
  <p>
    Direct billing for pharmacy varies. Some networks include pharmacies; others don't. You may need to pay for medications and claim reimbursement. Hospital pharmacy during admission is usually included in direct billing.
  </p>

  <h3>Is direct billing available worldwide?</h3>
  <p>
    In theory, but strength varies dramatically. US and Europe have strong networks. Asia is improving. Developing countries may have limited direct billing. Always check network coverage for your specific location.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Network coverage and direct billing availability change. We are not insurance brokers. Always verify current network coverage directly with insurers.
    </p>
  </div>
</PageShell>
