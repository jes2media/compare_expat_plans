---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-rehab-covers', text: 'What Rehabilitation Covers', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'types-of-rehab', text: 'Types of Rehabilitation', level: 2 },
  { id: 'coverage-limits', text: 'Coverage Limits', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Inpatient Insurance', href: '/best/inpatient-insurance' },
  { title: 'Outpatient Insurance', href: '/best/outpatient-insurance' },
  { title: 'Chronic Condition Insurance', href: '/best/chronic-condition-insurance' },
  { title: 'Alternative Medicine Insurance', href: '/best/alternative-medicine-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'physicalTherapy', header: 'Physical Therapy' },
  { key: 'inpatientRehab', header: 'Inpatient Rehab' },
  { key: 'speechTherapy', header: 'Speech Therapy' },
  { key: 'limits', header: 'Session Limits' },
];

const comparisonRows = [
  { provider: 'Cigna Global', physicalTherapy: 'Covered', inpatientRehab: 'Covered', speechTherapy: 'Covered', limits: '30-60 sessions' },
  { provider: 'Bupa Global', physicalTherapy: 'Covered', inpatientRehab: 'Covered', speechTherapy: 'Covered', limits: '30-90 sessions' },
  { provider: 'Aetna International', physicalTherapy: 'Covered', inpatientRehab: 'Covered', speechTherapy: 'Covered', limits: '20-60 sessions' },
  { provider: 'Allianz Care', physicalTherapy: 'Covered', inpatientRehab: 'Covered', speechTherapy: 'Some plans', limits: '20-40 sessions' },
  { provider: 'IMG Global', physicalTherapy: 'Limited', inpatientRehab: 'Limited', speechTherapy: 'Limited', limits: 'Low limits' },
];

const rehabColumns = [
  { key: 'type', header: 'Rehabilitation Type' },
  { key: 'coverage', header: 'Typical Coverage' },
  { key: 'scenarios', header: 'Common Scenarios' },
];

const rehabRows = [
  { type: 'Physical therapy', coverage: 'Usually covered', scenarios: 'Post-surgery, injuries, chronic pain' },
  { type: 'Occupational therapy', coverage: 'Usually covered', scenarios: 'Stroke recovery, disability adaptation' },
  { type: 'Speech therapy', coverage: 'Often covered', scenarios: 'Stroke, head injury, neurological conditions' },
  { type: 'Cardiac rehabilitation', coverage: 'Usually covered', scenarios: 'Post heart attack, heart surgery' },
  { type: 'Pulmonary rehabilitation', coverage: 'Often covered', scenarios: 'COPD, lung conditions' },
  { type: 'Neurological rehabilitation', coverage: 'Usually covered', scenarios: 'Stroke, brain injury, MS' },
  { type: 'Inpatient rehabilitation', coverage: 'Covered (limits)', scenarios: 'Severe injuries, major surgery recovery' },
];
---

<PageShell
  title="Best Expat Insurance for Rehabilitation 2026"
  description="Compare international health insurance with comprehensive rehabilitation coverage. Find plans that cover physical therapy, occupational therapy, and inpatient rehab abroad."
  headline="Best Expat Insurance for Rehabilitation"
  subheadline="Recovery takes time and therapy. Here are the international health plans with the best rehabilitation coverage for physical therapy, occupational therapy, and specialized rehab programs."
  heroImage="/images/answers/best-rehabilitation-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Rehabilitation Coverage</h2>
  <p>
    These insurers offer the best rehabilitation benefits:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏃</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Rehabilitation Coverage</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Comprehensive rehab coverage with higher session limits and inpatient rehabilitation included.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💪</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Physical Therapy</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Strong physical therapy coverage with good session limits and wide provider network.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏥</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Inpatient Rehab</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Good inpatient rehabilitation coverage with access to US rehabilitation facilities.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">⚕️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Why It Matters</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Full Recovery</p>
      <p class="text-neutral-600">Rehabilitation is often essential for full recovery from surgery, injury, or illness. Poor coverage means incomplete recovery.</p>
    </div>
  </div>

  <h2 id="what-rehab-covers">What Rehabilitation Coverage Means</h2>
  <p>
    Rehabilitation coverage helps you recover from illness, injury, or surgery:
  </p>

  <h3>Outpatient Rehabilitation</h3>
  <ul>
    <li>Physical therapy sessions</li>
    <li>Occupational therapy</li>
    <li>Speech and language therapy</li>
    <li>Vestibular rehabilitation</li>
    <li>Typically covered under outpatient benefits</li>
  </ul>

  <h3>Inpatient Rehabilitation</h3>
  <ul>
    <li>Intensive rehabilitation facilities</li>
    <li>Daily therapy programs</li>
    <li>Post-stroke or post-injury recovery</li>
    <li>Major surgery recovery</li>
    <li>Typically has day/dollar limits</li>
  </ul>

  <h3>Specialized Rehabilitation</h3>
  <ul>
    <li>Cardiac rehabilitation (post heart attack/surgery)</li>
    <li>Pulmonary rehabilitation (lung conditions)</li>
    <li>Neurological rehabilitation (stroke, brain injury)</li>
    <li>Orthopedic rehabilitation (joint replacement, fractures)</li>
  </ul>

  <CTABox
    title="Recovery Requires Support"
    description="Compare plans with comprehensive rehabilitation coverage."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Rehabilitation Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Bupa Global — Best Rehabilitation Coverage</h3>
  <p>
    Bupa Global offers comprehensive rehabilitation benefits.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Physical therapy included with good limits</li>
    <li>Occupational therapy covered</li>
    <li>Speech therapy included</li>
    <li>Inpatient rehabilitation covered</li>
    <li>30-90 sessions per year typical</li>
    <li>Specialized rehab programs</li>
    <li>Good network of rehabilitation facilities</li>
  </ul>
  <p><strong>Considerations:</strong> Premium pricing. Best rehab on higher-tier plans. Worth it for those who may need extensive rehabilitation.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Cigna Global — Strong Physical Therapy</h3>
  <p>
    Cigna Global offers solid physical therapy and rehabilitation coverage.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Physical therapy well covered</li>
    <li>30-60 sessions per year typical</li>
    <li>Occupational therapy included</li>
    <li>Speech therapy covered</li>
    <li>Inpatient rehab available</li>
    <li>Good provider network</li>
    <li>Modular plans allow customization</li>
  </ul>
  <p><strong>Considerations:</strong> Session limits apply. Best coverage on comprehensive plans. Good balance of coverage and cost.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Aetna International — US Rehabilitation Access</h3>
  <p>
    Aetna International provides good rehabilitation coverage with US facility access.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Access to US rehabilitation centers</li>
    <li>Physical therapy covered</li>
    <li>Inpatient rehabilitation included</li>
    <li>Speech and occupational therapy</li>
    <li>Specialized programs available</li>
    <li>Good for complex rehabilitation needs</li>
  </ul>
  <p><strong>Considerations:</strong> Best for those wanting US facility access. Session limits apply. Good overall rehabilitation coverage.</p>
  <p><a href="/providers/aetna-international">Read our full Aetna International review</a></p>

  <h2 id="types-of-rehab">Types of Rehabilitation</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={rehabColumns} rows={rehabRows} />
  </div>

  <h3>Physical Therapy</h3>
  <p>
    The most common rehabilitation coverage:
  </p>
  <ul>
    <li>Exercise programs and manual therapy</li>
    <li>Post-surgical recovery</li>
    <li>Injury rehabilitation</li>
    <li>Chronic pain management</li>
    <li>Usually 20-60 sessions covered per year</li>
    <li>May need physician referral</li>
  </ul>

  <h3>Occupational Therapy</h3>
  <p>
    Helps restore daily living skills:
  </p>
  <ul>
    <li>Stroke recovery</li>
    <li>Brain injury rehabilitation</li>
    <li>Adapting to disability</li>
    <li>Work-related injury recovery</li>
    <li>Usually covered alongside physical therapy</li>
  </ul>

  <h3>Speech and Language Therapy</h3>
  <p>
    Critical for certain conditions:
  </p>
  <ul>
    <li>Stroke affecting speech</li>
    <li>Head injuries</li>
    <li>Neurological conditions</li>
    <li>Swallowing difficulties</li>
    <li>Often covered but may have lower limits</li>
  </ul>

  <h3>Cardiac Rehabilitation</h3>
  <p>
    After heart events:
  </p>
  <ul>
    <li>Post heart attack recovery</li>
    <li>After cardiac surgery</li>
    <li>Supervised exercise programs</li>
    <li>Heart health education</li>
    <li>Usually covered as part of cardiac care</li>
  </ul>

  <h3>Inpatient Rehabilitation</h3>
  <p>
    For intensive recovery needs:
  </p>
  <ul>
    <li>Severe injuries or illness</li>
    <li>Major surgery recovery</li>
    <li>Daily intensive therapy</li>
    <li>Typically 30-60 days covered</li>
    <li>May need pre-authorization</li>
  </ul>

  <CTABox
    title="Complete Recovery"
    description="Don't let insurance gaps affect your rehabilitation."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="coverage-limits">Coverage Limits to Watch</h2>

  <h3>Session Limits</h3>
  <p>
    Most plans limit rehabilitation sessions:
  </p>
  <ul>
    <li>Basic plans: 10-20 sessions per year</li>
    <li>Standard plans: 20-40 sessions per year</li>
    <li>Premium plans: 40-90 sessions per year</li>
    <li>May combine all therapy types into one limit</li>
    <li>Verify limits meet potential needs</li>
  </ul>

  <h3>Inpatient Rehabilitation Limits</h3>
  <ul>
    <li>Typically 30-60 days maximum per year</li>
    <li>May have separate limit from regular hospital stay</li>
    <li>Premium plans have higher limits</li>
    <li>Pre-authorization usually required</li>
  </ul>

  <h3>When to Request Exceptions</h3>
  <p>
    If you exceed limits but still need care:
  </p>
  <ul>
    <li>Contact insurer to request extension</li>
    <li>Provide medical documentation of necessity</li>
    <li>Some insurers grant exceptions for severe cases</li>
    <li>Appeal if initially denied</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>How many physical therapy sessions are typically covered?</h3>
  <p>
    Most international health plans cover 20-60 sessions per year, with premium plans offering up to 90 sessions. Sessions may be limited per condition or combined across all rehabilitation types. Always verify your specific plan limits.
  </p>

  <h3>Is inpatient rehabilitation covered?</h3>
  <p>
    Yes, most comprehensive international health plans cover inpatient rehabilitation. Typical limits are 30-60 days per year. Pre-authorization is usually required. Coverage is separate from regular hospital stay limits.
  </p>

  <h3>Do I need a referral for physical therapy?</h3>
  <p>
    Depends on your plan. Some require a physician referral, others allow direct access to physical therapists. Pre-authorization may be needed for ongoing treatment beyond initial sessions. Check your specific policy requirements.
  </p>

  <h3>Is occupational therapy covered the same as physical therapy?</h3>
  <p>
    Usually yes—most plans that cover physical therapy also cover occupational therapy with similar limits. Some plans may combine limits for all rehabilitation services. Verify specific coverage for your plan.
  </p>

  <h3>What about rehabilitation after an accident abroad?</h3>
  <p>
    Rehabilitation following covered accidents is included in comprehensive plans. You may receive rehabilitation in the country where the accident occurred or be repatriated for recovery. Evacuation coverage may help access better rehabilitation facilities.
  </p>

  <h3>Are home-based rehabilitation services covered?</h3>
  <p>
    Some plans cover home health visits including rehabilitation services at home. This is more common on premium plans. May require medical necessity determination. Less common than facility-based rehabilitation coverage.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Rehabilitation coverage varies by plan and insurer. We are not insurance brokers or medical professionals. Always verify current coverage directly with insurers.
    </p>
  </div>
</PageShell>
