---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'why-small-business', text: 'Why Small Business Coverage', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'group-vs-individual', text: 'Group vs Individual', level: 2 },
  { id: 'tax-considerations', text: 'Tax Considerations', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Entrepreneur Insurance', href: '/best/entrepreneur-insurance' },
  { title: 'Freelancer Insurance', href: '/best/freelancer-insurance' },
  { title: 'Remote Worker Insurance', href: '/best/remote-worker-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Group Insurance Guide', href: '/guides/group-insurance' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'smallGroup', header: 'Small Group Plans' },
  { key: 'minSize', header: 'Min Group Size' },
  { key: 'flexibility', header: 'Plan Flexibility' },
  { key: 'pricing', header: 'Group Pricing' },
];

const comparisonRows = [
  { provider: 'Cigna Global', smallGroup: 'Excellent', minSize: '2+ employees', flexibility: 'High', pricing: 'Competitive' },
  { provider: 'Bupa Global', smallGroup: 'Good', minSize: '3+ employees', flexibility: 'High', pricing: 'Premium' },
  { provider: 'Allianz Care', smallGroup: 'Good', minSize: '2+ employees', flexibility: 'Moderate', pricing: 'Competitive' },
  { provider: 'IMG Global', smallGroup: 'Moderate', minSize: '5+ employees', flexibility: 'Moderate', pricing: 'Budget' },
  { provider: 'Aetna International', smallGroup: 'Good', minSize: '2+ employees', flexibility: 'High', pricing: 'Mid-range' },
];

const benefitColumns = [
  { key: 'benefit', header: 'Benefit' },
  { key: 'group', header: 'Group Plans' },
  { key: 'individual', header: 'Individual Plans' },
];

const benefitRows = [
  { benefit: 'Per-person cost', group: 'Often lower', individual: 'Higher' },
  { benefit: 'Underwriting', group: 'Simpler (group)', individual: 'Individual medical review' },
  { benefit: 'Pre-existing conditions', group: 'Often better terms', individual: 'Waiting periods/exclusions' },
  { benefit: 'Administration', group: 'Centralized billing', individual: 'Each person manages own' },
  { benefit: 'Flexibility', group: 'Limited plan choices', individual: 'Full flexibility' },
  { benefit: 'Portability', group: 'May lose on departure', individual: 'Keep when leaving' },
];
---

<PageShell
  title="Best Expat Insurance for Small Businesses 2026"
  description="Compare international health insurance for small businesses with remote or international teams. Find group plans for 2-50 employees abroad."
  headline="Best Expat Insurance for Small Businesses"
  subheadline="Running a small business with international employees? Here are the best group health insurance options for teams of 2-50 people across borders."
  heroImage="/images/answers/best-small-business-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Small Businesses</h2>
  <p>
    These insurers offer the best small group international health plans:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏢</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for Small Groups</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Excellent small group plans starting at 2 employees with flexible benefit options.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👑</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Premium Option</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Premium coverage for small businesses wanting top-tier benefits for their team.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Value</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Competitive group rates with solid international coverage for small teams.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🌐</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for Remote Teams</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">SafetyWing Remote</p>
      <p class="text-neutral-600">Built for distributed teams with simple global coverage and easy administration.</p>
    </div>
  </div>

  <h2 id="why-small-business">Why Small Business Coverage Matters</h2>
  <p>
    Health insurance for international small businesses serves multiple purposes:
  </p>

  <h3>Attract and Retain Talent</h3>
  <p>
    Good benefits help compete for employees:
  </p>
  <ul>
    <li>Remote workers expect health coverage</li>
    <li>International hires need portable insurance</li>
    <li>Health benefits show you care about employees</li>
    <li>Reduces turnover and improves loyalty</li>
  </ul>

  <h3>Simplify Administration</h3>
  <p>
    Group plans reduce administrative burden:
  </p>
  <ul>
    <li>Single policy for entire team</li>
    <li>Centralized billing and renewals</li>
    <li>HR dashboard for many providers</li>
    <li>Easier than managing individual policies</li>
  </ul>

  <h3>Legal and Visa Requirements</h3>
  <p>
    Many situations require employer-provided insurance:
  </p>
  <ul>
    <li>Some countries mandate employer health coverage</li>
    <li>Work visas may require proof of insurance</li>
    <li>Contractor classification may require benefits</li>
    <li>Employment contracts often specify coverage</li>
  </ul>

  <CTABox
    title="Cover Your Team"
    description="Compare small group international health plans."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Small Business Plan Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best for Small Groups</h3>
  <p>
    Cigna Global excels at small group international coverage.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Groups starting at 2 employees</li>
    <li>Flexible benefit design</li>
    <li>Modular coverage options</li>
    <li>Good worldwide network</li>
    <li>Online administration portal</li>
    <li>Multiple plan tiers available</li>
    <li>Experience with international small businesses</li>
  </ul>
  <p><strong>Considerations:</strong> Mid-range pricing. Best value with larger groups. Excellent option for most small businesses.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Premium Small Business Coverage</h3>
  <p>
    Bupa Global offers top-tier coverage for small businesses wanting the best.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Comprehensive coverage options</li>
    <li>Access to best hospitals globally</li>
    <li>Excellent service reputation</li>
    <li>Strong wellness benefits</li>
    <li>Good for executive teams</li>
    <li>Flexible group structures</li>
  </ul>
  <p><strong>Considerations:</strong> Premium pricing. Minimum group size of 3. Worth it for businesses prioritizing employee benefits.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>SafetyWing Remote — Built for Distributed Teams</h3>
  <p>
    SafetyWing offers a product specifically designed for remote teams.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Designed for remote-first companies</li>
    <li>Simple global coverage</li>
    <li>Easy team administration</li>
    <li>Affordable pricing</li>
    <li>No minimum group size</li>
    <li>Month-to-month flexibility</li>
    <li>Includes remote health benefits</li>
  </ul>
  <p><strong>Considerations:</strong> Less comprehensive than traditional insurers. Better for younger, healthier teams. Good for startups and digital businesses.</p>
  <p><a href="/providers/safetywing">Read our full SafetyWing review</a></p>

  <h3>Allianz Care — Value Group Coverage</h3>
  <p>
    Allianz Care offers competitive small group rates.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Competitive pricing</li>
    <li>Groups from 2 employees</li>
    <li>Good international coverage</li>
    <li>Strong European network</li>
    <li>Multiple plan options</li>
    <li>Established insurer</li>
  </ul>
  <p><strong>Considerations:</strong> Less flexibility than Cigna. Network varies by region. Good value option for cost-conscious businesses.</p>
  <p><a href="/providers/allianz-care">Read our full Allianz Care review</a></p>

  <h2 id="group-vs-individual">Group vs Individual Plans</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={benefitColumns} rows={benefitRows} />
  </div>

  <h3>When Group Plans Make Sense</h3>
  <ul>
    <li>3+ employees (economies of scale)</li>
    <li>Want centralized administration</li>
    <li>Employees have pre-existing conditions (better terms)</li>
    <li>Standardized benefits preferred</li>
    <li>Company wants to control coverage</li>
  </ul>

  <h3>When Individual Plans May Be Better</h3>
  <ul>
    <li>Only 1-2 employees</li>
    <li>Employees in very different locations</li>
    <li>Employees want to choose their own coverage</li>
    <li>High turnover (portability matters)</li>
    <li>Budget for health stipends instead of group plan</li>
  </ul>

  <h3>Hybrid Approaches</h3>
  <p>
    Some businesses combine approaches:
  </p>
  <ul>
    <li>Health insurance stipend for employees to buy own coverage</li>
    <li>Group plan for core team, stipends for contractors</li>
    <li>Different plans for different regions</li>
    <li>Supplement group with individual top-ups</li>
  </ul>

  <CTABox
    title="Find the Right Structure"
    description="Group, individual, or hybrid—find what works for your team."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="tax-considerations">Tax Considerations</h2>

  <h3>Business Deductions</h3>
  <p>
    Health insurance premiums may be tax deductible:
  </p>
  <ul>
    <li>Business expense in most jurisdictions</li>
    <li>Check local rules for your company's tax residence</li>
    <li>Documentation requirements vary</li>
    <li>Consult a tax professional for your situation</li>
  </ul>

  <h3>Employee Taxation</h3>
  <p>
    Employer-paid premiums have varying tax treatment:
  </p>
  <ul>
    <li>May be tax-free benefit in some countries</li>
    <li>May be taxable income in others</li>
    <li>Depends on employee's tax residence</li>
    <li>US employees have specific rules (COBRA, ACA)</li>
  </ul>

  <h3>International Considerations</h3>
  <ul>
    <li>Where is your business registered?</li>
    <li>Where are employees tax resident?</li>
    <li>Do employees have dual tax obligations?</li>
    <li>Consider consulting international tax advisor</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>What's the minimum group size for international health insurance?</h3>
  <p>
    Most insurers start at 2-3 employees. Cigna and Allianz accept groups of 2. Bupa typically requires 3+. SafetyWing Remote has no minimum. For solo founders, individual plans are the only option until you hire.
  </p>

  <h3>Can I cover contractors, not just employees?</h3>
  <p>
    It depends on the insurer and local regulations. Some group plans include contractors; others are employee-only. An alternative is providing a health stipend that contractors use to buy their own coverage.
  </p>

  <h3>How much does small business international health insurance cost?</h3>
  <p>
    Typically $200-600 per person per month, depending on age, location, and coverage level. Group discounts of 5-15% are common compared to individual rates. Premium plans cost more; budget options cost less.
  </p>

  <h3>What happens when an employee leaves?</h3>
  <p>
    With group plans, coverage typically ends when employment ends. Some plans offer conversion to individual coverage. Employees may need to find their own insurance. Consider this when designing your benefits package.
  </p>

  <h3>Can employees be in different countries on the same plan?</h3>
  <p>
    Yes, international group plans are designed for this. All employees can be on one policy regardless of location. The plan covers them globally (within the coverage area). This is a key advantage of international vs. local group plans.
  </p>

  <h3>How do claims work for a group plan?</h3>
  <p>
    Each employee manages their own claims, typically through an app or portal. The business handles premium payments centrally. HR may get reports on overall utilization but not individual health information (privacy laws).
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Group plan availability, minimums, and terms vary by insurer and location. We are not insurance brokers or tax advisors. Always verify current offerings and consult appropriate professionals for your specific situation.
    </p>
  </div>
</PageShell>
