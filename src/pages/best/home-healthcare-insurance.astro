---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-home-healthcare-covers', text: 'What Home Healthcare Covers', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'services-covered', text: 'Services Covered', level: 2 },
  { id: 'when-needed', text: 'When It\'s Needed', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Senior Insurance', href: '/best/senior-insurance' },
  { title: 'Rehabilitation Insurance', href: '/best/rehabilitation-insurance' },
  { title: 'Chronic Condition Insurance', href: '/best/chronic-condition-insurance' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'Premium Insurance', href: '/best/premium-insurance' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'homeNursing', header: 'Home Nursing' },
  { key: 'homeTherapy', header: 'Home Therapy' },
  { key: 'limits', header: 'Coverage Limits' },
  { key: 'included', header: 'Included In' },
];

const comparisonRows = [
  { provider: 'Bupa Global', homeNursing: 'Yes', homeTherapy: 'Yes', limits: '30-90 days', included: 'Most plans' },
  { provider: 'Cigna Global', homeNursing: 'Yes', homeTherapy: 'Yes', limits: '30-60 days', included: 'Premium plans' },
  { provider: 'Aetna International', homeNursing: 'Yes', homeTherapy: 'Limited', limits: '30 days', included: 'Select plans' },
  { provider: 'Allianz Care', homeNursing: 'Limited', homeTherapy: 'Limited', limits: 'Varies', included: 'Premium plans' },
  { provider: 'IMG Global', homeNursing: 'No', homeTherapy: 'No', limits: 'N/A', included: 'Not included' },
];

const servicesColumns = [
  { key: 'service', header: 'Service Type' },
  { key: 'coverage', header: 'Typical Coverage' },
  { key: 'notes', header: 'Notes' },
];

const servicesRows = [
  { service: 'Skilled nursing', coverage: 'Often covered', notes: 'Post-hospital recovery, wound care' },
  { service: 'Physical therapy at home', coverage: 'Sometimes covered', notes: 'When unable to travel to clinic' },
  { service: 'IV therapy/infusions', coverage: 'Usually covered', notes: 'When medically appropriate at home' },
  { service: 'Wound care', coverage: 'Usually covered', notes: 'Post-surgical or chronic wounds' },
  { service: 'Medical equipment', coverage: 'Often covered', notes: 'Hospital beds, oxygen, etc.' },
  { service: 'Palliative care', coverage: 'Premium plans', notes: 'End-of-life comfort care' },
  { service: 'Custodial care', coverage: 'Rarely covered', notes: 'Non-medical assistance excluded' },
];
---

<PageShell
  title="Best Expat Insurance with Home Healthcare 2026"
  description="Compare international health insurance with home healthcare coverage. Find plans that cover home nursing, home therapy, and medical care at home abroad."
  headline="Best Expat Insurance with Home Healthcare"
  subheadline="Sometimes recovery happens best at home. Here are the international health plans that cover skilled nursing, home therapy, and medical care in your residence."
  heroImage="/images/answers/best-home-healthcare-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Home Healthcare</h2>
  <p>
    These insurers offer the best home healthcare coverage:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏠</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Home Healthcare</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Comprehensive home nursing and therapy coverage with generous day limits on most plans.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👩‍⚕️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Home Nursing</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Good skilled nursing coverage at home with therapy options on premium plans.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best US Home Care</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Good home healthcare with strong US home health agency network.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">⚠️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Important Note</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Premium Feature</p>
      <p class="text-neutral-600">Home healthcare is typically only available on comprehensive or premium plans.</p>
    </div>
  </div>

  <h2 id="what-home-healthcare-covers">What Home Healthcare Covers</h2>
  <p>
    Home healthcare coverage provides medical services in your residence:
  </p>

  <h3>Skilled Medical Care</h3>
  <ul>
    <li>Nursing care (wound care, IV management, injections)</li>
    <li>Physical therapy at home</li>
    <li>Occupational therapy</li>
    <li>Speech therapy</li>
    <li>Medical monitoring</li>
  </ul>

  <h3>What's NOT Covered</h3>
  <ul>
    <li>Custodial care (bathing, dressing, meals)</li>
    <li>Housekeeping services</li>
    <li>Long-term live-in care</li>
    <li>Companion services</li>
    <li>Non-medical assistance</li>
  </ul>

  <h3>Key Distinction</h3>
  <p>
    Home healthcare coverage is for skilled medical services, not general assistance with daily living. The care must be medically necessary and typically follows hospitalization or treats specific conditions.
  </p>

  <CTABox
    title="Recover at Home"
    description="Compare plans with home healthcare coverage."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Home Healthcare Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Bupa Global — Best Home Healthcare</h3>
  <p>
    Bupa Global offers the most comprehensive home healthcare coverage.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Home nursing included on most plans</li>
    <li>Home physical therapy covered</li>
    <li>30-90 days coverage typical</li>
    <li>IV therapy and wound care at home</li>
    <li>Medical equipment for home use</li>
    <li>Palliative care options on premium plans</li>
    <li>Good network of home health providers</li>
  </ul>
  <p><strong>Considerations:</strong> Premium pricing. Best coverage on higher-tier plans. Worth it for those who may need home recovery.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Cigna Global — Good Home Nursing</h3>
  <p>
    Cigna Global offers solid home healthcare on premium plans.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Skilled nursing at home</li>
    <li>Home therapy options</li>
    <li>30-60 days typical coverage</li>
    <li>Post-hospital recovery support</li>
    <li>Medical equipment coverage</li>
    <li>Good coordination services</li>
  </ul>
  <p><strong>Considerations:</strong> Premium plans required for best coverage. Day limits apply. Good option with comprehensive plans.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Aetna International — US Home Care Network</h3>
  <p>
    Aetna International has strong US home health agency connections.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Good US home health network</li>
    <li>Skilled nursing coverage</li>
    <li>Home therapy options</li>
    <li>Equipment coverage</li>
    <li>Care coordination</li>
  </ul>
  <p><strong>Considerations:</strong> Best for US-based home care. Coverage varies by plan. Good for those spending time in US.</p>
  <p><a href="/providers/aetna-international">Read our full Aetna International review</a></p>

  <h2 id="services-covered">Services Covered</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={servicesColumns} rows={servicesRows} />
  </div>

  <h3>Skilled Nursing</h3>
  <p>
    Medical nursing services at home:
  </p>
  <ul>
    <li>Wound care and dressing changes</li>
    <li>IV medication administration</li>
    <li>Injection administration</li>
    <li>Vital signs monitoring</li>
    <li>Catheter care</li>
    <li>Post-surgical care</li>
  </ul>

  <h3>Home Therapy</h3>
  <p>
    Rehabilitation services at home:
  </p>
  <ul>
    <li>Physical therapy when homebound</li>
    <li>Occupational therapy</li>
    <li>Speech therapy</li>
    <li>Usually limited to those unable to travel</li>
    <li>Session limits typically apply</li>
  </ul>

  <h3>Medical Equipment</h3>
  <p>
    Durable medical equipment for home:
  </p>
  <ul>
    <li>Hospital beds</li>
    <li>Oxygen equipment</li>
    <li>Wheelchairs and walkers</li>
    <li>Monitoring devices</li>
    <li>Usually rental, sometimes purchase</li>
  </ul>

  <CTABox
    title="Care Where You're Comfortable"
    description="Home healthcare can speed recovery and improve outcomes."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="when-needed">When Home Healthcare Is Needed</h2>

  <h3>Common Scenarios</h3>
  <ul>
    <li><strong>Post-surgery recovery:</strong> Wound care, physical therapy after major surgery</li>
    <li><strong>After hospitalization:</strong> Continued medical care during recovery</li>
    <li><strong>Chronic conditions:</strong> Ongoing medical management at home</li>
    <li><strong>Mobility limitations:</strong> When traveling to facilities is difficult</li>
    <li><strong>Terminal illness:</strong> Palliative care at home</li>
  </ul>

  <h3>Benefits of Home Care</h3>
  <ul>
    <li>More comfortable recovery environment</li>
    <li>Reduced infection risk vs. hospital</li>
    <li>Family involvement in care</li>
    <li>Often less expensive than inpatient</li>
    <li>Better for mental health and morale</li>
  </ul>

  <h3>Availability Abroad</h3>
  <p>
    Home healthcare availability varies by country:
  </p>
  <ul>
    <li>Well-developed in US, Europe, Australia</li>
    <li>Growing in Asia (Singapore, Thailand)</li>
    <li>Limited in developing countries</li>
    <li>Your insurer can help locate services</li>
    <li>May need to coordinate internationally</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Is home healthcare covered by international health insurance?</h3>
  <p>
    On comprehensive and premium plans, yes. Coverage includes skilled nursing and therapy at home when medically necessary. Budget plans typically exclude home healthcare. Day limits usually apply (30-90 days).
  </p>

  <h3>What's the difference between home healthcare and home care?</h3>
  <p>
    Home healthcare is skilled medical care (nursing, therapy) covered by insurance. Home care or custodial care (bathing, meals, housekeeping) is non-medical assistance that's generally not covered by health insurance.
  </p>

  <h3>Do I need pre-authorization for home healthcare?</h3>
  <p>
    Usually yes. Contact your insurer before arranging home health services. They'll verify medical necessity, authorize coverage, and may help arrange providers. Emergency situations may have different requirements.
  </p>

  <h3>Can I receive home healthcare in any country?</h3>
  <p>
    Coverage applies globally, but home health services aren't available everywhere. Well-developed in North America, Europe, and some Asian countries. Your insurer can help identify providers or alternatives in your location.
  </p>

  <h3>How long is home healthcare covered?</h3>
  <p>
    Typically 30-90 days per year or per condition, depending on your plan. Premium plans have higher limits. Extensions may be possible for complex cases. Contact your insurer if you need longer coverage.
  </p>

  <h3>Is palliative home care covered?</h3>
  <p>
    Premium plans often include palliative care at home for terminal conditions. This covers comfort-focused medical care, pain management, and nursing support. Verify specific coverage with your insurer.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Home healthcare coverage varies by plan and insurer. We are not insurance brokers or medical professionals. Always verify current coverage directly with insurers.
    </p>
  </div>
</PageShell>
