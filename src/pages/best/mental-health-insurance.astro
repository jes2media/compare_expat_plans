  { id: 'why-it-matters', text: 'Why Mental Health Coverage Matters', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'what-to-look-for', text: 'What to Look For', level: 2 },
  { id: 'finding-care', text: 'Finding Care Abroad', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Mental Health Coverage Guide', href: '/insurance-for/mental-health' },
  { title: 'Best Remote Worker Insurance', href: '/best/remote-worker-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Telemedicine Abroad', href: '/guides/telemedicine-abroad' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'therapy', header: 'Therapy Coverage' },
  { key: 'psychiatry', header: 'Psychiatry' },
  { key: 'inpatient', header: 'Inpatient' },
  { key: 'telehealth', header: 'Telehealth' },
];

const comparisonRows = [
  { provider: 'Cigna Global', therapy: 'Yes, varies by plan', psychiatry: 'Yes', inpatient: 'Yes', telehealth: 'Yes' },
  { provider: 'Allianz Care', therapy: 'Yes, varies by plan', psychiatry: 'Yes', inpatient: 'Yes', telehealth: 'Yes' },
  { provider: 'Bupa Global', therapy: 'Yes, varies by plan', psychiatry: 'Yes', inpatient: 'Yes', telehealth: 'Yes' },
  { provider: 'IMG Global', therapy: 'Yes, limited', psychiatry: 'Yes', inpatient: 'Yes', telehealth: 'Limited' },
  { provider: 'SafetyWing', therapy: 'No', psychiatry: 'No', inpatient: 'Crisis only', telehealth: 'No' },
];

const coverageColumns = [
  { key: 'type', header: 'Coverage Type' },
  { key: 'typical', header: 'Typical Coverage' },
  { key: 'limits', header: 'Common Limits' },
];

const coverageRows = [
  { type: 'Outpatient therapy', typical: 'Most full health plans', limits: '20-30 sessions/year or $ limit' },
  { type: 'Psychiatry', typical: 'Most full health plans', limits: 'Usually unlimited consultations' },
  { type: 'Medications', typical: 'Included with prescriptions', limits: 'Standard prescription coverage' },
  { type: 'Inpatient treatment', typical: 'Most full health plans', limits: '30-60 days/year common' },
  { type: 'Crisis intervention', typical: 'Even basic plans', limits: 'Emergency coverage' },
  { type: 'Substance abuse', typical: 'Varies significantly', limits: 'Often limited or excluded' },
];
---

<PageShell
