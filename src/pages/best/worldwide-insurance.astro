---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-worldwide-means', text: 'What Worldwide Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'coverage-areas', text: 'Coverage Area Options', level: 2 },
  { id: 'considerations', text: 'Key Considerations', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Multi-Country Insurance', href: '/best/multi-country-insurance' },
  { title: 'US Coverage Insurance', href: '/best/us-coverage-insurance' },
  { title: 'Premium Insurance', href: '/best/premium-insurance' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
  { title: 'Understanding Coverage Areas', href: '/guides/understanding-coverage-areas' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'worldwide', header: 'Worldwide Option' },
  { key: 'countries', header: 'Countries Covered' },
  { key: 'restrictions', header: 'Restrictions' },
  { key: 'priceRange', header: 'Price Range' },
];

const comparisonRows = [
  { provider: 'Bupa Global', worldwide: 'Yes (incl US)', countries: '190+', restrictions: 'None', priceRange: '$400-1,000+/mo' },
  { provider: 'Cigna Global', worldwide: 'Yes (incl US)', countries: '200+', restrictions: 'None', priceRange: '$300-800+/mo' },
  { provider: 'Aetna International', worldwide: 'Yes (incl US)', countries: '190+', restrictions: 'None', priceRange: '$350-900+/mo' },
  { provider: 'Allianz Care', worldwide: 'Yes (incl US)', countries: '180+', restrictions: 'Minor', priceRange: '$250-600+/mo' },
  { provider: 'SafetyWing', worldwide: 'Yes (excl home)', countries: '180+', restrictions: 'Home country limited', priceRange: '$45-85/mo' },
];

const areaColumns = [
  { key: 'area', header: 'Coverage Area' },
  { key: 'includes', header: 'What It Covers' },
  { key: 'priceImpact', header: 'Price Impact' },
  { key: 'bestFor', header: 'Best For' },
];

const areaRows = [
  { area: 'Worldwide including US', includes: 'Every country on earth', priceImpact: 'Highest', bestFor: 'Maximum flexibility' },
  { area: 'Worldwide excluding US', includes: 'All except United States', priceImpact: 'Moderate', bestFor: 'Most expats' },
  { area: 'Europe', includes: 'EU/EEA/UK/Switzerland', priceImpact: 'Lower', bestFor: 'Europe-based expats' },
  { area: 'Asia Pacific', includes: 'Asia, Australia, Pacific', priceImpact: 'Lower', bestFor: 'Asia-based expats' },
  { area: 'Americas', includes: 'North/South America', priceImpact: 'Varies', bestFor: 'Americas expats' },
];
---

<PageShell
  title="5 Best Worldwide Expat Insurance Plans 2026 (190+ Countries)"
  description="Compare 5 international health plans with true worldwide coverage including the US. No country restrictions—prices and features compared."
  headline="Best Worldwide Expat Insurance"
  subheadline="Need coverage that works literally everywhere? True worldwide insurance covers you in every country—no restrictions, no exceptions."
  heroImage="/images/answers/best-worldwide-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Worldwide Coverage</h2>
  <p>
    These insurers offer the most comprehensive worldwide coverage:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🌍</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best True Worldwide</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Any hospital, any country, unlimited coverage. The gold standard for unrestricted worldwide access.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🌐</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Global Network</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Extensive network in 200+ countries. Strong worldwide coverage with excellent service.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Worldwide + US</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Strong worldwide coverage with the best US network. Ideal if US access matters.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Budget Worldwide</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">SafetyWing</p>
      <p class="text-neutral-600">180+ countries at $45/month. Travel medical coverage with true global reach.</p>
    </div>
  </div>

  <h2 id="what-worldwide-means">What "Worldwide" Actually Means</h2>
  <p>
    Not all "worldwide" coverage is the same:
  </p>

  <h3>True Worldwide (Including US)</h3>
  <ul>
    <li>Covers every country including the United States</li>
    <li>No geographical restrictions</li>
    <li>Most expensive option</li>
    <li>Maximum flexibility</li>
    <li>Offered by: Bupa, Cigna, Aetna, Allianz</li>
  </ul>

  <h3>Worldwide Excluding US</h3>
  <ul>
    <li>Covers every country except the United States</li>
    <li>Most popular option for expats</li>
    <li>40-50% cheaper than including US</li>
    <li>Works for most people with no US connection</li>
    <li>Offered by: All major insurers</li>
  </ul>

  <h3>Travel Medical "Worldwide"</h3>
  <ul>
    <li>Covers many countries (150-180+)</li>
    <li>May have home country restrictions</li>
    <li>May exclude certain regions</li>
    <li>Check specific exclusions</li>
    <li>Offered by: SafetyWing, World Nomads</li>
  </ul>

  <CTABox
    title="Get True Worldwide Coverage"
    description="Compare plans with unrestricted global coverage."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Worldwide Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Bupa Global — Best True Worldwide</h3>
  <p>
    Bupa Global offers the most unrestricted worldwide coverage available.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Any hospital in any country</li>
    <li>No network restrictions</li>
    <li>Unlimited coverage on top plans</li>
    <li>190+ countries covered</li>
    <li>No pre-authorization for most care</li>
    <li>True freedom to choose where to be treated</li>
  </ul>
  <p><strong>Considerations:</strong> Most expensive option. Premium for the freedom. Best if you need maximum flexibility and are willing to pay for it.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Cigna Global — Best Global Network</h3>
  <p>
    Cigna Global combines worldwide coverage with an extensive global network.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>200+ countries covered</li>
    <li>Extensive global provider network</li>
    <li>Direct billing in most countries</li>
    <li>Strong claims service worldwide</li>
    <li>Good balance of coverage and network</li>
    <li>Multiple plan levels</li>
  </ul>
  <p><strong>Considerations:</strong> Network-focused (direct billing requires in-network). Premium pricing with US included. Very good but not quite as unrestricted as Bupa.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>SafetyWing — Best Budget Worldwide</h3>
  <p>
    SafetyWing offers global coverage at a fraction of full health insurance costs.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>180+ countries covered</li>
    <li>Only $45-85/month</li>
    <li>Simple global coverage</li>
    <li>No primary residence restrictions</li>
    <li>True nomad-friendly coverage</li>
  </ul>
  <p><strong>Considerations:</strong> Travel medical only—not full health insurance. Home country coverage limited. Pre-existing conditions excluded. Good for healthy nomads, not comprehensive coverage.</p>
  <p><a href="/providers/safetywing">Read our full SafetyWing review</a></p>

  <h2 id="coverage-areas">Coverage Area Options</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={areaColumns} rows={areaRows} />
  </div>

  <h3>Why US Coverage Costs So Much More</h3>
  <p>
    Including the US typically adds 40-100% to premiums:
  </p>
  <ul>
    <li>US healthcare costs 2-10x more than other countries</li>
    <li>Average hospital stay: $3,000-5,000/day in US vs $500-1,000 elsewhere</li>
    <li>Insurers price this risk into premiums</li>
    <li>If you don't need US coverage, excluding it saves significantly</li>
  </ul>

  <h3>When You Need True Worldwide</h3>
  <ul>
    <li>You have no fixed home base</li>
    <li>You might end up anywhere</li>
    <li>You want maximum flexibility</li>
    <li>You have connections to the US</li>
    <li>Your employer requires it</li>
  </ul>

  <h3>When Regional is Enough</h3>
  <ul>
    <li>You know you'll stay in one region</li>
    <li>You have no US connection</li>
    <li>Budget is a primary concern</li>
    <li>You want to save 20-50% on premiums</li>
  </ul>

  <CTABox
    title="Choose Your Coverage Area"
    description="Balance global flexibility with cost based on your actual needs."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="considerations">Key Considerations</h2>

  <h3>Network Quality Varies</h3>
  <p>
    Even with worldwide coverage:
  </p>
  <ul>
    <li>Direct billing availability varies by country</li>
    <li>Network strength varies by region</li>
    <li>Some countries may require pay-and-claim</li>
    <li>Premium insurers have better networks</li>
  </ul>

  <h3>Country-Specific Issues</h3>
  <ul>
    <li>Some countries have mandatory local insurance (UAE, Germany)</li>
    <li>Worldwide coverage may not meet visa requirements</li>
    <li>Local regulations may affect how coverage works</li>
    <li>Verify your specific situation</li>
  </ul>

  <h3>War and Conflict Zones</h3>
  <p>
    Most policies exclude:
  </p>
  <ul>
    <li>Active war zones</li>
    <li>Areas under travel advisories</li>
    <li>Countries with UN sanctions</li>
    <li>Check your policy for specific exclusions</li>
  </ul>

  <h3>Evacuation Matters</h3>
  <p>
    With worldwide coverage, evacuation is important:
  </p>
  <ul>
    <li>If local care is inadequate, evacuation gets you to better facilities</li>
    <li>Worldwide coverage + evacuation = complete protection</li>
    <li>Verify evacuation limits and coverage</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Is worldwide coverage worth the extra cost?</h3>
  <p>
    Depends on your lifestyle. If you move between countries frequently or might end up anywhere, yes. If you're settled in one region with no US connection, regional coverage saves money without sacrificing much.
  </p>

  <h3>Can I upgrade from regional to worldwide later?</h3>
  <p>
    Usually yes, at renewal. You may need underwriting, and any conditions developed during regional coverage become pre-existing. It's easier to start with the coverage area you need.
  </p>

  <h3>What if I visit the US occasionally but don't have US coverage?</h3>
  <p>
    You're uninsured during those visits. Some worldwide-excluding-US plans offer emergency-only US coverage as an add-on. Or buy separate travel insurance for US trips.
  </p>

  <h3>Does worldwide coverage work in my home country?</h3>
  <p>
    Varies by insurer and plan. Some offer limited home country coverage (30-60 days/year). Others exclude it entirely. Travel medical plans like SafetyWing have specific home country limitations. Verify for your situation.
  </p>

  <h3>Are there any countries not covered by "worldwide"?</h3>
  <p>
    Usually yes—active war zones, sanctioned countries, and areas under severe travel advisories. These exclusions are reasonable and apply to all insurers. Check your policy for the specific list.
  </p>

  <h3>Which insurer has the best worldwide network?</h3>
  <p>
    Cigna Global and Bupa Global have the most extensive global networks. Cigna is particularly strong for network-based direct billing. Bupa offers more freedom to go out-of-network. Both are excellent for worldwide coverage.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Coverage areas, restrictions, and network availability change. We are not insurance brokers. Always verify current coverage terms directly with insurers.
    </p>
  </div>
</PageShell>
