const comparisonRows = [
  { provider: 'Cigna Global', usIncluded: 'Optional (+50-100%)', familyCoverage: 'Excellent', preExisting: 'With underwriting', bestFor: 'Families relocating abroad' },
  { provider: 'Aetna International', usIncluded: 'Good rates', familyCoverage: 'Excellent', preExisting: 'With underwriting', bestFor: 'US-centric coverage needs' },
