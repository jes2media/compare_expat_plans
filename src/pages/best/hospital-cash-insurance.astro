---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-hospital-cash-means', text: 'What Hospital Cash Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'how-it-works', text: 'How It Works', level: 2 },
  { id: 'who-needs-it', text: 'Who Needs It', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Inpatient Insurance', href: '/best/inpatient-insurance' },
  { title: 'Budget Insurance', href: '/best/budget-insurance' },
  { title: 'Flexible Deductible Insurance', href: '/best/flexible-deductible-insurance' },
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Self-Employed Insurance', href: '/best/self-employed-insurance' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'hospitalCash', header: 'Hospital Cash' },
  { key: 'dailyBenefit', header: 'Daily Benefit' },
  { key: 'maxDays', header: 'Max Days' },
  { key: 'icuBenefit', header: 'ICU Benefit' },
];

const comparisonRows = [
  { provider: 'Allianz Care', hospitalCash: 'Available', dailyBenefit: '$50-200/day', maxDays: '30-90 days', icuBenefit: 'Higher rate' },
  { provider: 'Cigna Global', hospitalCash: 'Some plans', dailyBenefit: '$100-150/day', maxDays: '60 days', icuBenefit: 'Some plans' },
  { provider: 'Bupa Global', hospitalCash: 'Optional', dailyBenefit: 'Varies', maxDays: 'Varies', icuBenefit: 'Varies' },
  { provider: 'IMG Global', hospitalCash: 'Limited', dailyBenefit: '$50-100/day', maxDays: '30 days', icuBenefit: 'No' },
  { provider: 'SafetyWing', hospitalCash: 'No', dailyBenefit: 'N/A', maxDays: 'N/A', icuBenefit: 'N/A' },
];

const benefitsColumns = [
  { key: 'benefit', header: 'Benefit Type' },
  { key: 'typicalAmount', header: 'Typical Amount' },
  { key: 'purpose', header: 'Purpose' },
];

const benefitsRows = [
  { benefit: 'Daily hospital benefit', typicalAmount: '$50-200/day', purpose: 'Incidental expenses during stay' },
  { benefit: 'ICU/intensive care', typicalAmount: '2x daily rate', purpose: 'Higher costs in intensive care' },
  { benefit: 'Surgical cash benefit', typicalAmount: '$500-2,000', purpose: 'Lump sum for surgery' },
  { benefit: 'Outpatient surgery', typicalAmount: '$200-500', purpose: 'Same-day procedure benefit' },
  { benefit: 'Convalescence benefit', typicalAmount: '$50-100/day', purpose: 'Recovery period at home' },
];
---

<PageShell
  title="Best Expat Insurance with Hospital Cash Benefits 2026"
  description="Compare international health insurance with hospital cash benefits. Find plans that pay daily cash benefits during hospital stays to cover incidental expenses."
  headline="Best Expat Insurance with Hospital Cash Benefits"
  subheadline="Get cash payments for every day you're hospitalized. Hospital cash benefits help cover incidental expenses and lost income during your recovery."
  heroImage="/images/answers/best-hospital-cash-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Hospital Cash Benefits</h2>
  <p>
    These insurers offer the best hospital cash benefits:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💵</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Hospital Cash</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Comprehensive hospital cash benefits with daily payments, ICU bonuses, and long coverage periods.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏥</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Good Cash Benefits</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Hospital cash available on some plans with competitive daily rates.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">➕</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Optional Add-On</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Hospital cash available as optional benefit on select plans.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💡</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What It's For</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Extra Support</p>
      <p class="text-neutral-600">Cash for expenses insurance doesn't cover: lost income, family travel, childcare, meals.</p>
    </div>
  </div>

  <h2 id="what-hospital-cash-means">What Hospital Cash Benefits Mean</h2>
  <p>
    Hospital cash benefits pay you a daily amount for each day you're hospitalized:
  </p>

  <h3>How It Works</h3>
  <ul>
    <li>You receive a fixed cash payment per day in hospital</li>
    <li>Payment is in addition to medical coverage</li>
    <li>No receipts or documentation needed</li>
    <li>Use the money however you want</li>
    <li>Usually paid after discharge</li>
  </ul>

  <h3>What It Covers</h3>
  <ul>
    <li>Lost income during hospitalization</li>
    <li>Family member travel to visit</li>
    <li>Childcare while you're hospitalized</li>
    <li>Meals and incidentals not covered by insurance</li>
    <li>Personal comfort items</li>
    <li>Transportation for follow-up care</li>
  </ul>

  <h3>Typical Amounts</h3>
  <ul>
    <li>Standard hospital stay: $50-200 per day</li>
    <li>ICU/intensive care: Often double the standard rate</li>
    <li>Maximum days: Usually 30-90 days per year</li>
    <li>Some plans include surgical cash benefits</li>
  </ul>

  <CTABox
    title="Get Cash When You Need It"
    description="Compare plans with hospital cash benefits."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Hospital Cash Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Allianz Care — Best Hospital Cash Benefits</h3>
  <p>
    Allianz Care offers the most comprehensive hospital cash benefits.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Daily hospital cash benefit available</li>
    <li>$50-200 per day depending on plan</li>
    <li>Higher rate for ICU stays</li>
    <li>Up to 90 days coverage</li>
    <li>Surgical cash benefits included</li>
    <li>Convalescence benefit on some plans</li>
    <li>Simple claims process</li>
  </ul>
  <p><strong>Considerations:</strong> Hospital cash is optional on some plans. Check specific benefit amounts. Good for those wanting extra financial cushion.</p>
  <p><a href="/providers/allianz-care">Read our full Allianz Care review</a></p>

  <h3>Cigna Global — Good Cash Benefits</h3>
  <p>
    Cigna Global offers hospital cash on select plans.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Hospital cash on some plans</li>
    <li>Competitive daily rates ($100-150)</li>
    <li>Up to 60 days coverage</li>
    <li>ICU benefits on some plans</li>
    <li>Easy claims process</li>
    <li>Good overall coverage</li>
  </ul>
  <p><strong>Considerations:</strong> Not available on all plans. Check if included in your chosen tier. Best combined with comprehensive medical coverage.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Optional Add-On</h3>
  <p>
    Bupa Global offers hospital cash as an optional benefit.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Can add hospital cash to plans</li>
    <li>Flexible benefit amounts</li>
    <li>Combined with excellent medical coverage</li>
    <li>Quality underlying insurance</li>
  </ul>
  <p><strong>Considerations:</strong> Additional cost for benefit. Not standard on all plans. Worth considering if hospital cash is important to you.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h2 id="how-it-works">How Hospital Cash Works</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={benefitsColumns} rows={benefitsRows} />
  </div>

  <h3>Claiming Hospital Cash</h3>
  <p>
    The process is straightforward:
  </p>
  <ul>
    <li>Get admitted to hospital for covered condition</li>
    <li>Your medical treatment is covered separately</li>
    <li>Hospital cash is paid per day admitted</li>
    <li>Submit claim form with admission/discharge dates</li>
    <li>Receive payment (no receipts needed for cash portion)</li>
  </ul>

  <h3>ICU and Special Care</h3>
  <p>
    Higher benefits for intensive care:
  </p>
  <ul>
    <li>ICU stays often pay double the daily rate</li>
    <li>Recognizes higher stress and costs</li>
    <li>May include other high-dependency units</li>
    <li>Check plan definition of qualifying care</li>
  </ul>

  <h3>Surgical Cash Benefits</h3>
  <p>
    Some plans include lump sum surgical benefits:
  </p>
  <ul>
    <li>One-time payment when you have surgery</li>
    <li>Amount varies by surgery type</li>
    <li>Major surgery: $1,000-2,000</li>
    <li>Minor surgery: $200-500</li>
    <li>In addition to daily hospital cash</li>
  </ul>

  <h3>Waiting Periods</h3>
  <ul>
    <li>Some plans have waiting period before benefit applies</li>
    <li>Typically 24-48 hours of admission</li>
    <li>May waive for accidents</li>
    <li>Check specific plan terms</li>
  </ul>

  <CTABox
    title="Extra Financial Support"
    description="Hospital cash helps with expenses insurance doesn't cover."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="who-needs-it">Who Needs Hospital Cash Benefits</h2>

  <h3>Good Fit For</h3>
  <ul>
    <li><strong>Self-employed:</strong> No paid sick leave, lost income hurts</li>
    <li><strong>Families:</strong> Childcare costs when parent hospitalized</li>
    <li><strong>Those with local plans:</strong> Supplement basic coverage</li>
    <li><strong>High deductible plans:</strong> Cash helps cover deductible</li>
    <li><strong>Peace of mind:</strong> Extra financial cushion during crisis</li>
  </ul>

  <h3>Less Necessary For</h3>
  <ul>
    <li>Comprehensive plans with low deductibles</li>
    <li>Employees with paid sick leave</li>
    <li>Those with substantial emergency savings</li>
    <li>Minimal hospitalization risk</li>
  </ul>

  <h3>Common Uses for Hospital Cash</h3>
  <ul>
    <li>Replacing lost income during recovery</li>
    <li>Flying family members to your bedside</li>
    <li>Hiring help for home/childcare</li>
    <li>Private room upgrade if desired</li>
    <li>Meals and comfort items</li>
    <li>Transportation for follow-up appointments</li>
  </ul>

  <h3>Hospital Cash vs. Income Protection</h3>
  <p>
    Understanding the difference:
  </p>
  <ul>
    <li><strong>Hospital cash:</strong> Pays per day in hospital only</li>
    <li><strong>Income protection:</strong> Pays percentage of salary during disability</li>
    <li>Hospital cash is simpler and faster</li>
    <li>Income protection covers longer-term disability</li>
    <li>Consider both for comprehensive protection</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Is hospital cash the same as regular medical coverage?</h3>
  <p>
    No. Hospital cash is a separate benefit that pays you cash for each day hospitalized, in addition to your medical coverage. Your hospital bills are paid by insurance; hospital cash is extra money paid to you.
  </p>

  <h3>Do I need receipts to claim hospital cash?</h3>
  <p>
    Usually no. You just need to provide proof of hospitalization (admission and discharge dates). The cash is yours to use however you want—no need to justify expenses.
  </p>

  <h3>How much hospital cash benefit do I need?</h3>
  <p>
    Consider your daily expenses and lost income. If hospitalized, what would you need per day for lost work, family help, and incidentals? $100-150/day is common, but choose based on your situation.
  </p>

  <h3>Is there a waiting period before benefits start?</h3>
  <p>
    Some plans have a 24-48 hour waiting period before hospital cash kicks in (day 1-2 may not be covered). Accidents often waive this period. Check your specific plan terms.
  </p>

  <h3>Can I get hospital cash for outpatient surgery?</h3>
  <p>
    Some plans include outpatient surgical benefits—a lump sum payment for same-day procedures. This is different from daily hospital cash, which requires overnight admission.
  </p>

  <h3>Does hospital cash cover maternity hospitalization?</h3>
  <p>
    Often yes, if your plan includes maternity coverage and hospital cash benefits. The daily rate applies to maternity hospital stays just like other hospitalizations. Check specific plan terms.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Hospital cash benefits vary by plan and insurer. We are not insurance brokers. Always verify current benefits directly with insurers.
    </p>
  </div>
</PageShell>
