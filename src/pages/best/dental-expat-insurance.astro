const comparisonRows = [
  {
    provider: 'Cigna Global',
    dentalIncluded: 'Optional add-on',
    annualMax: '$1,500-5,000',
    waitingPeriod: '3-12 months',
    price: '+$30-80/month',
  },
  {
    provider: 'Allianz Care',
    dentalIncluded: 'Premium plans only',
    annualMax: '$2,000-10,000',
    waitingPeriod: '6-12 months',
    price: '+$40-100/month',
  },
  {
    provider: 'Bupa Global',
    dentalIncluded: 'Optional module',
    annualMax: '$1,000-5,000',
    waitingPeriod: '6 months',
    price: '+$35-75/month',
  },
  {
    provider: 'IMG Global',
