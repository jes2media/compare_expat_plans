const relatedLinks = [
  { title: 'Premium Expat Insurance', href: '/best/premium-insurance' },
  { title: 'Dental Care Abroad Guide', href: '/guides/managing-dental-care-abroad' },
  { title: 'Family Health Insurance', href: '/best/family-health-insurance' },
  { title: 'Understanding Insurance Benefits', href: '/guides/understanding-international-health-insurance-benefits' },
  { title: 'Budget Expat Insurance', href: '/best/budget-insurance' },
