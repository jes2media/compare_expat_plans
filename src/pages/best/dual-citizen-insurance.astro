import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Our Top Picks', level: 2 },
  { id: 'dual-citizen-challenges', text: 'Unique Challenges', level: 2 },
  { id: 'how-we-evaluated', text: 'How We Evaluated', level: 2 },
  { id: 'comparison-table', text: 'Quick Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'choosing-the-right-plan', text: 'Choosing the Right Plan', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

const relatedLinks = [
  { title: 'Multi-Country Insurance', href: '/best/multi-country-insurance' },
  { title: 'US Coverage Insurance', href: '/best/us-coverage-insurance' },
  { title: 'Global Nomad Insurance', href: '/best/global-nomad-insurance' },
  { title: 'Worldwide Insurance', href: '/best/worldwide-insurance' },
  { title: 'Expat Health Insurance', href: '/best/expat-health-insurance' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'multiCountry', header: 'Multi-Country' },
  { key: 'usIncluded', header: 'US Coverage' },
  { key: 'flexibility', header: 'Residence Flexibility' },
  { key: 'bestFor', header: 'Best For' },
];

const comparisonRows = [
  { provider: 'Cigna Global', multiCountry: 'Full', usIncluded: 'Optional (+50-100%)', flexibility: 'Change anytime', bestFor: 'US/EU dual citizens' },
  { provider: 'BUPA Global', multiCountry: 'Full', usIncluded: 'Optional (+50-100%)', flexibility: 'Change anytime', bestFor: 'UK/anywhere dual citizens' },
  { provider: 'Allianz Care', multiCountry: 'Full', usIncluded: 'Optional', flexibility: 'With notice', bestFor: 'EU dual citizens' },
  { provider: 'Aetna International', multiCountry: 'Full', usIncluded: 'Included options', flexibility: 'Change anytime', bestFor: 'US-based dual citizens' },
  { provider: 'IMG Global', multiCountry: 'Full', usIncluded: 'Better rates', flexibility: 'Change anytime', bestFor: 'Budget dual coverage' },
];
---

<PageShell
  title="Best Health Insurance for Dual Citizens 2026 | Multi-Passport Coverage"
  description="Compare health insurance for dual citizens and multi-passport holders. Coverage that works across your citizenships without gaps or complications."
  headline="Best Health Insurance for Dual Citizens"
  subheadline="Two passports, two potential home countries, and complex insurance needs. Here's how to get coverage that works wherever your citizenships take you."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get Dual Citizen Quotes →"
  ctaButtonHref="/go/cigna-global"
>
  <h2 id="top-picks">Our Top Picks</h2>
  <p>
    Dual citizenship creates insurance complications that single-nationality expats don't face. You might live in Country A, hold passports from Countries A and B, travel frequently to both, and want healthcare access in either. Standard expat insurance doesn't always handle this gracefully.
  </p>

  <p>
    After analyzing coverage for multi-passport holders, here are our recommendations:
  </p>

  <h3>Best for US/EU Dual Citizens: Cigna Global</h3>
  <p>
    <strong>The good:</strong> True worldwide coverage including US (optional). Change your residence country without losing coverage. Excellent networks in both US and Europe. One plan covers both sides of your dual citizenship.
  </p>
  <p>
    <strong>The limits:</strong> US coverage adds 50-100% to premiums—expensive but sometimes necessary. Premium pricing overall.
  </p>
  <p>
    <strong>Best for:</strong> US/European dual citizens who live in Europe but visit the US regularly, or vice versa.
  </p>

  <h3>Best for UK-Based Dual Citizens: BUPA Global</h3>
  <p>
    <strong>The good:</strong> Strong UK network plus global coverage. Flexible residence designation. Lifetime renewal guarantee. Works well for UK/Commonwealth dual citizens.
  </p>
  <p>
    <strong>The limits:</strong> US coverage expensive. Premium brand with premium pricing.
  </p>
  <p>
    <strong>Best for:</strong> UK/Australian, UK/Canadian, UK/South African dual citizens with flexible lifestyles.
  </p>

  <h3>Best Value: IMG Global</h3>
  <p>
    <strong>The good:</strong> Comprehensive global coverage at lower prices than European brands. US coverage more affordable for US citizens. Flexible residence requirements.
  </p>
  <p>
    <strong>The limits:</strong> Smaller network outside major cities. Less brand prestige if that matters.
  </p>
  <p>
    <strong>Best for:</strong> Dual citizens seeking comprehensive coverage without premium brand pricing.
  </p>

  <CTABox
    title="Get Dual Citizen Quotes"
    description="Compare plans that work across your citizenships."
    buttonText="Compare Plans →"
    buttonHref="/go/cigna-global"
  />

  <h2 id="dual-citizen-challenges">Unique Challenges for Dual Citizens</h2>
  <p>
    Dual citizenship creates specific insurance complications:
  </p>

  <h3>Residence Definition</h3>
  <p>
    Most international insurance bases pricing and coverage on your "country of residence." But dual citizens often don't have a single clear residence:
  </p>
  <ul>
    <li><strong>Tax residence:</strong> Where you pay taxes may differ from where you spend most time</li>
    <li><strong>Primary home:</strong> You might own property in both countries</li>
    <li><strong>Split time:</strong> 6 months here, 6 months there doesn't give a clear answer</li>
    <li><strong>Insurance perspective:</strong> They need to know where to price your risk and build your network</li>
  </ul>

  <h3>Home Country Coverage</h3>
  <p>
    Standard expat insurance often excludes or limits coverage in your "home country." For dual citizens, this creates problems:
  </p>
  <ul>
    <li><strong>Which home?</strong> Both countries are technically home</li>
    <li><strong>Coverage gaps:</strong> Plan may cover you in Country A but exclude Country B visits</li>
    <li><strong>Extended stays:</strong> Visiting "home" for 3 months may exceed policy limits</li>
  </ul>

  <h3>US Citizenship Complications</h3>
  <p>
    If one of your citizenships is US, everything gets more expensive:
  </p>
  <ul>
    <li><strong>US healthcare costs:</strong> Insurance covering the US costs 50-100% more</li>
    <li><strong>Even if you don't live there:</strong> Visits to family require US coverage or you're uninsured</li>
    <li><strong>Tax implications:</strong> US citizens are taxed globally—insurance choices have tax angles</li>
  </ul>

  <h3>Public Health Entitlements</h3>
  <p>
    Your citizenships may provide public health access:
  </p>
  <ul>
    <li><strong>EU citizenship:</strong> EHIC/GHIC covers you in EU countries</li>
    <li><strong>UK citizenship:</strong> NHS access when resident in UK</li>
    <li><strong>Canadian citizenship:</strong> Provincial health if resident and meeting requirements</li>
    <li><strong>Coordination:</strong> International insurance should complement, not replace, public entitlements</li>
  </ul>

  <h2 id="how-we-evaluated">How We Evaluated</h2>
  <p>
    We assessed plans on criteria specific to dual citizens:
  </p>

  <ul>
    <li><strong>Multi-country functionality:</strong> Does coverage work equally well in both your citizenship countries?</li>
    <li><strong>Residence flexibility:</strong> Can you change your designated residence without reunderwriting?</li>
    <li><strong>Home country inclusion:</strong> Are visits to both "home" countries covered?</li>
    <li><strong>US handling:</strong> How expensive and seamless is US coverage?</li>
    <li><strong>Network quality:</strong> Strong networks in both/all your citizenship countries?</li>
    <li><strong>Administrative simplicity:</strong> One plan that just works vs. managing multiple policies</li>
  </ul>

  <h2 id="comparison-table">Quick Comparison</h2>
  <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global</h3>
  <p>
    Cigna handles dual citizenship gracefully. You designate a primary residence for pricing purposes, but coverage works globally. Move from Germany to the US? Update your residence and coverage adjusts—no new application, no reunderwriting.
  </p>

  <p>
    The modular system lets you build appropriate coverage. If you're US/EU, you might want full coverage in Europe (your residence) plus US coverage for extended visits. Or full coverage in both if you split time evenly.
  </p>

  <p>
    US coverage adds significantly to cost—typically 50-100% premium increase. But for US dual citizens who actually visit or may return, it's necessary. The US network is strong; you're not getting second-tier care.
  </p>

  <p>
    Home country coverage is configurable. You can include full coverage in your citizenship countries, not just emergency care during visits.
  </p>

  <p>
    <strong>Pricing:</strong> $300-500/month without US; $500-900/month with US for healthy adults.
  </p>

  <p>
    <strong>Verdict:</strong> Best overall for dual citizens needing seamless multi-country coverage, especially with US involvement.
  </p>

  <h3>BUPA Global</h3>
  <p>
    BUPA offers similar flexibility to Cigna with perhaps stronger UK roots. If one of your citizenships is UK, BUPA understands that market intimately. Commonwealth dual citizens (UK/Australia, UK/Canada, UK/New Zealand) find BUPA particularly intuitive.
  </p>

  <p>
    Coverage tiers let you choose geographic scope: Europe, Worldwide excluding US, or Worldwide including US. Dual citizens typically need the broadest coverage, but you can adjust if one country isn't relevant.
  </p>

  <p>
    The lifetime renewal guarantee matters for dual citizens planning decades of mobile lifestyle. Once enrolled, you keep coverage regardless of health changes or country moves.
  </p>

  <p>
    <strong>Pricing:</strong> Similar to Cigna—$300-500/month baseline, add $200-400/month for US coverage.
  </p>

  <p>
    <strong>Verdict:</strong> Excellent for UK-based dual citizens or anyone valuing BUPA's global reputation.
  </p>

  <h3>Allianz Care</h3>
  <p>
    German precision applied to international coverage. Allianz excels within Europe—if both your citizenships are EU countries, their network density is hard to beat.
  </p>

  <p>
    France/Germany, Spain/Italy, Netherlands/Belgium—these EU dual citizen combinations find Allianz's European strength valuable. The network extends globally, but European coverage is the standout.
  </p>

  <p>
    Residence changes require notification but are generally smooth within Europe. Moving to US or changing to US coverage is a bigger adjustment requiring new underwriting.
  </p>

  <p>
    <strong>Pricing:</strong> Competitive in Europe—$250-400/month for EU coverage. US options add significantly.
  </p>

  <p>
    <strong>Verdict:</strong> Best for EU/EU dual citizens who primarily live in Europe.
  </p>

  <h3>Aetna International</h3>
  <p>
    Aetna has US roots, which helps for US dual citizens. They understand American healthcare complexity in ways European insurers sometimes don't.
  </p>

  <p>
    Plans can include US coverage more naturally than European competitors—it's not an expensive add-on but an integrated option. For US/anywhere dual citizens, this can mean better US pricing.
  </p>

  <p>
    Global coverage is solid though network may be thinner than Cigna/BUPA in some regions. For US-centric dual citizens, this trade-off often works.
  </p>

  <p>
    <strong>Pricing:</strong> $300-600/month including US coverage—often better US value than European competitors.
  </p>

  <p>
    <strong>Verdict:</strong> Consider if US coverage is primary need and European competitors' US pricing is prohibitive.
  </p>

  <h3>IMG Global</h3>
  <p>
    IMG offers comprehensive global coverage at lower prices than the premium European brands. For dual citizens prioritizing value over brand prestige, IMG delivers.
  </p>

  <p>
    US coverage is more affordable than Cigna/BUPA—IMG's US base means US healthcare isn't exotic to them. Global coverage is genuine, though network density varies by region.
  </p>

  <p>
    Flexibility is good—change residence, adjust coverage, no dramatic underwriting events. Coverage continues as you move between citizenship countries.
  </p>

  <p>
    <strong>Pricing:</strong> $200-400/month with US coverage—often 20-30% below Cigna/BUPA.
  </p>

  <p>
    <strong>Verdict:</strong> Best value for dual citizens who don't need premium brand positioning.
  </p>

  <CTABox
    title="Compare Plans for Dual Citizens"
    description="Get quotes that work across both your citizenships."
    buttonText="Get Your Quote →"
    buttonHref="/go/cigna-global"
  />

  <h2 id="choosing-the-right-plan">Choosing the Right Plan</h2>

  <h3>By Citizenship Combination</h3>
  <ul>
    <li><strong>US/EU:</strong> Cigna Global (handles both sides well) or Aetna (better US pricing)</li>
    <li><strong>US/Canada:</strong> Cigna or IMG (US-North America coverage)</li>
    <li><strong>UK/EU:</strong> BUPA Global or Allianz Care</li>
    <li><strong>UK/Commonwealth:</strong> BUPA Global (UK expertise plus global reach)</li>
    <li><strong>EU/EU:</strong> Allianz Care (European network strength)</li>
    <li><strong>Any/US:</strong> Budget for US coverage—it's always expensive but necessary</li>
  </ul>

  <h3>By Living Situation</h3>
  <ul>
    <li><strong>Primarily in one country:</strong> Base coverage there, add travel coverage for other citizenship country</li>
    <li><strong>Split fairly evenly:</strong> True global plan (Cigna, BUPA) covering both equally</li>
    <li><strong>Nomadic between both:</strong> Worldwide coverage with both countries as "home"</li>
    <li><strong>One for work, one for retirement:</strong> Plan for where you are now; adjust coverage as life changes</li>
  </ul>

  <h3>US Inclusion Strategy</h3>
  <ul>
    <li><strong>US citizen who never goes back:</strong> Consider excluding US to save 50%+ on premiums</li>
    <li><strong>Regular US visits:</strong> Include US coverage—medical emergency in US without insurance is catastrophic</li>
    <li><strong>May return to US eventually:</strong> Include US to maintain coverage continuity</li>
    <li><strong>US for family only:</strong> Short visits might work with travel medical top-up; longer stays need real coverage</li>
  </ul>

  <h2 id="faqs">Common Questions</h2>

  <div class="space-y-6 my-8">
    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Which citizenship should I declare for insurance?</h3>
      <p class="text-neutral-600 mb-0">
        Insurers typically ask for your country of residence, not citizenship. Declare where you actually live and pay taxes. Your citizenships affect coverage scope—if you're US citizen living in Germany, you need coverage that works in both. Full disclosure is important; misrepresentation can void policies.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Can I use public health in both countries?</h3>
      <p class="text-neutral-600 mb-0">
        Depends on specific entitlements. EU citizens have EHIC rights across EU. UK NHS requires UK residency. Canadian provincial health requires provincial residency for 6+ months/year. US has no universal public health. International insurance complements these entitlements—it covers gaps and provides private care options.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What if I move between my citizenship countries?</h3>
      <p class="text-neutral-600 mb-0">
        Good international plans (Cigna, BUPA) allow residence changes without reunderwriting. You notify them, they adjust pricing for new location, coverage continues. This flexibility is crucial for dual citizens who may move multiple times.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Is US coverage always worth the extra cost?</h3>
      <p class="text-neutral-600 mb-0">
        If you'll actually be in the US, yes. A single ER visit can be $5,000-20,000+. Hospitalization without insurance is financial catastrophe. If you truly never visit the US, you can exclude it. But most US dual citizens visit family, and that requires coverage.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">How do I handle maternity as a dual citizen?</h3>
      <p class="text-neutral-600 mb-0">
        Maternity coverage works wherever you're covered—you could deliver in either country. Waiting periods (typically 10-12 months) apply regardless. Consider where you want to deliver, verify network coverage there, and ensure your plan's maternity benefits meet your expectations. Citizenship for the child may depend on birth location—separate consideration.
      </p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">What about tax implications of international insurance?</h3>
      <p class="text-neutral-600 mb-0">
        Complex and country-specific. US citizens are taxed globally and may have FBAR/FATCA reporting. Some countries offer tax relief for health insurance premiums. Others don't. Consult a tax professional familiar with your citizenship combination. Insurance decisions shouldn't be purely tax-driven, but tax implications exist.
      </p>
    </div>
  </div>

  <CTABox
    title="Ready for Dual Citizen Coverage?"
    description="Get quotes from providers who understand multi-passport needs."
    buttonText="Compare Plans Now →"
    buttonHref="/go/cigna-global"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600 mb-0">
      <strong>Disclaimer:</strong> Dual citizenship creates complex insurance, tax, and legal situations that vary by specific country combinations. This guide provides general information—consult professionals for advice specific to your citizenship combination and circumstances. Insurance coverage and pricing depend on individual underwriting.
    </p>
  </div>
</PageShell>
