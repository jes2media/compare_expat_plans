---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-outpatient-only-means', text: 'What Outpatient-Only Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'coverage-details', text: 'Coverage Details', level: 2 },
  { id: 'pros-cons', text: 'Pros and Cons', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Budget Insurance', href: '/best/budget-insurance' },
  { title: 'Outpatient Insurance', href: '/best/outpatient-insurance' },
  { title: 'Inpatient Insurance', href: '/best/inpatient-insurance' },
  { title: 'Digital Nomad Insurance', href: '/best/digital-nomad-insurance' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'outpatientOnly', header: 'Outpatient-Only Option' },
  { key: 'price', header: 'Approx. Monthly Cost' },
  { key: 'coverage', header: 'Coverage Limit' },
  { key: 'bestFor', header: 'Best For' },
];

const comparisonRows = [
  { provider: 'Cigna Global', outpatientOnly: 'Yes (modular)', price: '$100-200', coverage: '$10K-50K', bestFor: 'Supplement to local plan' },
  { provider: 'Allianz Care', outpatientOnly: 'Yes (modular)', price: '$80-150', coverage: '$10K-30K', bestFor: 'European coverage' },
  { provider: 'Aetna International', outpatientOnly: 'Limited options', price: '$120-180', coverage: 'Varies', bestFor: 'US access' },
  { provider: 'IMG Global', outpatientOnly: 'Some plans', price: '$60-120', coverage: '$10K-25K', bestFor: 'Budget option' },
  { provider: 'Local insurers', outpatientOnly: 'Common', price: '$30-100', coverage: 'Varies', bestFor: 'Country-specific' },
];

const coverageColumns = [
  { key: 'service', header: 'Service' },
  { key: 'included', header: 'Typically Included' },
  { key: 'notes', header: 'Notes' },
];

const coverageRows = [
  { service: 'Doctor visits', included: 'Yes', notes: 'GP and specialist consultations' },
  { service: 'Diagnostic tests', included: 'Yes', notes: 'Blood tests, X-rays, scans' },
  { service: 'Prescriptions', included: 'Usually', notes: 'Outpatient medications' },
  { service: 'Preventive care', included: 'Some plans', notes: 'Check specific coverage' },
  { service: 'Physical therapy', included: 'Often', notes: 'Usually with limits' },
  { service: 'Mental health', included: 'Some plans', notes: 'Outpatient therapy' },
  { service: 'Hospital stays', included: 'No', notes: 'Not covered—that\'s inpatient' },
  { service: 'Surgery', included: 'Limited', notes: 'Only same-day procedures' },
];
---

<PageShell
  title="Best Outpatient-Only Insurance for Expats 2026"
  description="Compare outpatient-only international health insurance options. Find affordable plans that cover doctor visits, tests, and prescriptions without hospital coverage."
  headline="Best Outpatient-Only Insurance for Expats"
  subheadline="Don't need hospital coverage? Outpatient-only plans cover doctor visits, tests, and prescriptions at a fraction of the cost of comprehensive insurance."
  heroImage="/images/answers/best-outpatient-only-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Outpatient-Only Coverage</h2>
  <p>
    These insurers offer the best outpatient-only options:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🩺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Outpatient-Only</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Modular plans let you choose outpatient-only coverage with comprehensive benefits.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇪🇺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for Europe</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Good outpatient modules with strong European network and coverage.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Budget Option</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">IMG Global</p>
      <p class="text-neutral-600">Affordable outpatient coverage for budget-conscious expats.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">⚠️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Important Warning</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">No Hospital Coverage</p>
      <p class="text-neutral-600">Outpatient-only plans don't cover hospitalization. Have a backup plan for emergencies.</p>
    </div>
  </div>

  <h2 id="what-outpatient-only-means">What Outpatient-Only Means</h2>
  <p>
    Outpatient-only insurance covers medical care that doesn't require hospital admission:
  </p>

  <h3>What's Covered</h3>
  <ul>
    <li>Doctor consultations (GP and specialists)</li>
    <li>Diagnostic tests (blood work, X-rays, MRIs)</li>
    <li>Prescription medications</li>
    <li>Outpatient procedures</li>
    <li>Physical therapy and rehabilitation</li>
    <li>Mental health (outpatient therapy)</li>
  </ul>

  <h3>What's NOT Covered</h3>
  <ul>
    <li>Hospital stays (inpatient treatment)</li>
    <li>Surgery requiring hospital admission</li>
    <li>Emergency room that leads to admission</li>
    <li>Intensive care</li>
    <li>Maternity (requires inpatient)</li>
  </ul>

  <h3>Why Choose Outpatient-Only</h3>
  <ul>
    <li>Significantly lower premiums (50-70% less)</li>
    <li>Supplement local/employer inpatient coverage</li>
    <li>Have separate emergency/catastrophic plan</li>
    <li>Healthy individuals with low hospital risk</li>
    <li>Budget constraints but need doctor access</li>
  </ul>

  <CTABox
    title="Affordable Coverage for Routine Care"
    description="Compare outpatient-only options."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Outpatient-Only Options Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best Outpatient-Only</h3>
  <p>
    Cigna Global's modular approach allows outpatient-only coverage.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Can select outpatient module alone</li>
    <li>Comprehensive outpatient benefits</li>
    <li>Global provider network</li>
    <li>Prescription coverage included</li>
    <li>Mental health options</li>
    <li>Preventive care included</li>
    <li>Good claims process</li>
  </ul>
  <p><strong>Considerations:</strong> More expensive than local options. Still significant cost vs. full coverage. Best for those wanting international quality outpatient.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Allianz Care — Best for Europe</h3>
  <p>
    Allianz Care offers good outpatient modules for European expats.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Outpatient-only option available</li>
    <li>Strong European network</li>
    <li>Good diagnostic coverage</li>
    <li>Prescription benefits</li>
    <li>Multilingual support</li>
    <li>Competitive pricing</li>
  </ul>
  <p><strong>Considerations:</strong> Best for Europe-based expats. Network varies outside Europe. Good supplementary coverage.</p>
  <p><a href="/providers/allianz-care">Read our full Allianz Care review</a></p>

  <h3>IMG Global — Budget Option</h3>
  <p>
    IMG Global provides affordable outpatient options.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Lower cost options available</li>
    <li>Basic outpatient coverage</li>
    <li>Doctor visits covered</li>
    <li>Prescription benefits</li>
    <li>Simple plans</li>
  </ul>
  <p><strong>Considerations:</strong> More limited benefits than premium insurers. Network less extensive. Good for budget-conscious expats.</p>
  <p><a href="/providers/img-global">Read our full IMG Global review</a></p>

  <h2 id="coverage-details">Coverage Details</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Doctor Visits</h3>
  <p>
    Core outpatient coverage:
  </p>
  <ul>
    <li>General practitioner visits</li>
    <li>Specialist consultations</li>
    <li>Follow-up appointments</li>
    <li>May have visit limits or copays</li>
    <li>Usually direct billing available</li>
  </ul>

  <h3>Diagnostic Services</h3>
  <p>
    Tests and imaging:
  </p>
  <ul>
    <li>Blood tests and lab work</li>
    <li>X-rays</li>
    <li>CT scans and MRIs</li>
    <li>Ultrasounds</li>
    <li>May need referral for advanced imaging</li>
  </ul>

  <h3>Prescription Coverage</h3>
  <p>
    Medication benefits:
  </p>
  <ul>
    <li>Outpatient prescriptions covered</li>
    <li>Usually includes maintenance medications</li>
    <li>May have annual limits</li>
    <li>Copays common for medications</li>
  </ul>

  <h3>Outpatient Procedures</h3>
  <p>
    Same-day procedures:
  </p>
  <ul>
    <li>Minor procedures without admission</li>
    <li>Outpatient surgery (day surgery)</li>
    <li>Endoscopies, colonoscopies</li>
    <li>Biopsies</li>
    <li>Check specific coverage limits</li>
  </ul>

  <CTABox
    title="Cover Your Routine Care"
    description="Find affordable outpatient coverage."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="pros-cons">Pros and Cons of Outpatient-Only</h2>

  <h3>Advantages</h3>
  <ul>
    <li><strong>Much lower cost:</strong> 50-70% less than comprehensive plans</li>
    <li><strong>Covers most needs:</strong> Day-to-day healthcare covered</li>
    <li><strong>Good supplement:</strong> Works with local inpatient coverage</li>
    <li><strong>Simple plans:</strong> Easier to understand</li>
    <li><strong>Immediate use:</strong> Often shorter waiting periods</li>
  </ul>

  <h3>Disadvantages</h3>
  <ul>
    <li><strong>No hospital coverage:</strong> Major gap if hospitalized</li>
    <li><strong>No surgery:</strong> Except same-day procedures</li>
    <li><strong>Emergency exposure:</strong> ER leading to admission not covered</li>
    <li><strong>No maternity:</strong> Delivery requires hospitalization</li>
    <li><strong>Risk if serious illness:</strong> Major conditions need inpatient</li>
  </ul>

  <h3>Who Should Consider Outpatient-Only</h3>
  <ul>
    <li>Those with separate inpatient coverage (local plan, employer)</li>
    <li>Young, healthy individuals with emergency savings</li>
    <li>Short-term expats with travel insurance backup</li>
    <li>Budget-constrained needing basic coverage</li>
    <li>Those wanting international outpatient + local inpatient</li>
  </ul>

  <h3>Who Should Avoid Outpatient-Only</h3>
  <ul>
    <li>Anyone without backup hospitalization coverage</li>
    <li>Families (children can need hospitalization)</li>
    <li>Those with chronic conditions</li>
    <li>Pregnant or planning pregnancy</li>
    <li>Those in areas with expensive hospital care</li>
  </ul>

  <h3>Combining Coverage</h3>
  <p>
    Many expats use outpatient-only strategically:
  </p>
  <ul>
    <li><strong>Local inpatient + international outpatient:</strong> Best of both worlds</li>
    <li><strong>Employer inpatient + personal outpatient:</strong> Supplement work coverage</li>
    <li><strong>Travel insurance + outpatient:</strong> Short-term emergency backup</li>
    <li><strong>National health system + outpatient:</strong> Better access to private doctors</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>What happens if I need hospitalization with outpatient-only insurance?</h3>
  <p>
    You're not covered. You'd pay out-of-pocket for hospital stays, surgery, and inpatient care. This is why many combine outpatient-only with local inpatient coverage or emergency insurance.
  </p>

  <h3>Is outpatient-only cheaper than comprehensive coverage?</h3>
  <p>
    Yes, significantly. Expect 50-70% lower premiums compared to full coverage. Inpatient care is the most expensive component, so removing it dramatically reduces cost.
  </p>

  <h3>Can I upgrade to comprehensive coverage later?</h3>
  <p>
    Usually yes, but with conditions. You may face new underwriting, waiting periods, or exclusions for pre-existing conditions. It's not automatic—you're essentially applying for a new policy.
  </p>

  <h3>Does outpatient-only cover emergencies?</h3>
  <p>
    It covers emergency room visits that don't result in admission. If the ER visit leads to hospitalization, only the initial ER care is covered—not the hospital stay.
  </p>

  <h3>Is outpatient-only good for digital nomads?</h3>
  <p>
    It can work as a supplement to travel/emergency insurance. Many nomads have travel insurance for emergencies and add outpatient coverage for routine care. Understand the gaps before relying on this approach.
  </p>

  <h3>What about pre-existing conditions?</h3>
  <p>
    Coverage varies by insurer. Some outpatient plans cover pre-existing conditions with waiting periods. Others exclude them entirely. Check specific plan terms carefully.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Outpatient-only coverage has significant gaps. We are not insurance brokers. Verify coverage directly with insurers.
    </p>
  </div>
</PageShell>
