---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'how-prescription-works', text: 'How Prescription Coverage Works', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'coverage-types', text: 'Types of Coverage', level: 2 },
  { id: 'considerations', text: 'Key Considerations', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Chronic Condition Insurance', href: '/best/chronic-condition-insurance' },
  { title: 'Premium Insurance', href: '/best/premium-insurance' },
  { title: 'Direct Billing Insurance', href: '/best/direct-billing-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Medications Abroad Guide', href: '/guides/medications-abroad' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'rxCoverage', header: 'Rx Coverage' },
  { key: 'limits', header: 'Annual Limits' },
  { key: 'specialty', header: 'Specialty Drugs' },
  { key: 'delivery', header: 'Intl Delivery' },
];

const comparisonRows = [
  { provider: 'Cigna Global', rxCoverage: 'Comprehensive', limits: 'Included in overall', specialty: 'Covered', delivery: 'Coordination' },
  { provider: 'Bupa Global', rxCoverage: 'Comprehensive', limits: 'Included in overall', specialty: 'Covered', delivery: 'Coordination' },
  { provider: 'Aetna International', rxCoverage: 'Comprehensive', limits: 'Included in overall', specialty: 'Covered', delivery: 'Limited' },
  { provider: 'Allianz Care', rxCoverage: 'Good', limits: 'Some sub-limits', specialty: 'Most covered', delivery: 'Limited' },
  { provider: 'SafetyWing', rxCoverage: 'Acute only', limits: '$5,000', specialty: 'Not covered', delivery: 'None' },
];

const coverageColumns = [
  { key: 'type', header: 'Medication Type' },
  { key: 'fullHealth', header: 'Full Health Plans' },
  { key: 'travelMedical', header: 'Travel Medical' },
];

const coverageRows = [
  { type: 'Acute prescriptions', fullHealth: 'Fully covered', travelMedical: 'Usually covered' },
  { type: 'Maintenance medications', fullHealth: 'Fully covered', travelMedical: 'Usually excluded' },
  { type: 'Pre-existing condition meds', fullHealth: 'After waiting period', travelMedical: 'Excluded' },
  { type: 'Specialty/biologic drugs', fullHealth: 'Usually covered', travelMedical: 'Excluded' },
  { type: 'Cancer medications', fullHealth: 'Covered (high cost)', travelMedical: 'Excluded' },
  { type: 'Mental health meds', fullHealth: 'Usually covered', travelMedical: 'Limited/excluded' },
  { type: 'Preventive vaccines', fullHealth: 'Often covered', travelMedical: 'Varies' },
];
---

<PageShell
  title="Best Expat Insurance with Prescription Coverage 2026"
  description="Compare international health insurance with comprehensive prescription drug coverage. Find plans that cover medications, specialty drugs, and pharmacy benefits abroad."
  headline="Best Expat Insurance with Prescription Coverage"
  subheadline="Medications can be expensive—especially specialty drugs. Here's how to find international health insurance with strong prescription drug coverage."
  heroImage="/images/answers/best-prescription-coverage-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Prescription Coverage</h2>
  <p>
    These insurers offer the best prescription drug benefits:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💊</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Overall Rx Coverage</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Comprehensive prescription coverage included in overall limits. Good specialty drug coverage and pharmacy coordination.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👑</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Premium Rx</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Unlimited medication coverage, specialty drugs included, coordination for international delivery.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best US Pharmacy Network</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Strong US pharmacy coverage with familiar pharmacy benefit structure.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Value Rx</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Good prescription coverage at moderate prices. Some specialty drug limitations.</p>
    </div>
  </div>

  <h2 id="how-prescription-works">How Prescription Coverage Works</h2>
  <p>
    Prescription drug coverage varies significantly between international health plans:
  </p>

  <h3>Full Health Insurance</h3>
  <ul>
    <li>Prescriptions typically included in overall coverage</li>
    <li>No separate prescription deductible (usually)</li>
    <li>Both acute and maintenance medications covered</li>
    <li>Specialty drugs often covered</li>
    <li>Pay at pharmacy, claim reimbursement (most common)</li>
    <li>Some plans have pharmacy networks for direct billing</li>
  </ul>

  <h3>Travel Medical Insurance</h3>
  <ul>
    <li>Acute prescriptions only (new conditions)</li>
    <li>Maintenance medications NOT covered</li>
    <li>Pre-existing condition medications excluded</li>
    <li>Low limits ($2,500-5,000 typical)</li>
    <li>Designed for short-term, not ongoing needs</li>
  </ul>

  <h3>How to Get Prescriptions Abroad</h3>
  <ol>
    <li>See a doctor (in-person or telemedicine)</li>
    <li>Get a prescription written</li>
    <li>Take to local pharmacy</li>
    <li>Pay for medication</li>
    <li>Submit claim for reimbursement (or use pharmacy network)</li>
  </ol>

  <CTABox
    title="Get Prescription Coverage"
    description="Compare plans with comprehensive medication benefits."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Prescription Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best Overall Prescription Coverage</h3>
  <p>
    Cigna Global offers comprehensive prescription coverage as part of their overall health benefits.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Prescriptions included in overall coverage (no separate limit)</li>
    <li>Specialty drugs covered</li>
    <li>Cancer medications fully covered</li>
    <li>Some pharmacy network for direct billing</li>
    <li>Telemedicine can prescribe</li>
    <li>Coordination for international medication needs</li>
    <li>Pre-existing condition meds after waiting period</li>
  </ul>
  <p><strong>Considerations:</strong> Specialty drugs may need pre-approval. Pharmacy network varies by location. Premium pricing.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Best Premium Prescription</h3>
  <p>
    Bupa Global includes unlimited medication coverage with their premium plans.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Unlimited prescription coverage</li>
    <li>Specialty and biologic drugs covered</li>
    <li>No separate prescription limits</li>
    <li>Coordination for international delivery</li>
    <li>Concierge service for complex medication needs</li>
    <li>Cancer medications fully covered</li>
  </ul>
  <p><strong>Considerations:</strong> Most expensive option. Best if you need comprehensive coverage or expensive medications.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>SafetyWing — Limited Prescription Coverage</h3>
  <p>
    SafetyWing covers prescriptions, but with significant limitations.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Acute prescription coverage included</li>
    <li>Up to $5,000 coverage</li>
    <li>Affordable overall ($45/month)</li>
    <li>Good for new, unexpected prescriptions</li>
  </ul>
  <p><strong>Critical limitations:</strong> Does NOT cover maintenance medications. Pre-existing condition meds excluded. Specialty drugs not covered. Only covers prescriptions for new conditions.</p>
  <p><a href="/providers/safetywing">Read our full SafetyWing review</a></p>

  <h2 id="coverage-types">Types of Medication Coverage</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Specialty Drugs</h3>
  <p>
    High-cost specialty medications (often $10,000-100,000+/year):
  </p>
  <ul>
    <li>Biologics for autoimmune conditions</li>
    <li>Cancer immunotherapy drugs</li>
    <li>Hepatitis C treatments</li>
    <li>Multiple sclerosis medications</li>
    <li>Rheumatoid arthritis drugs</li>
  </ul>
  <p>
    Premium plans cover these; budget and travel medical plans typically exclude them.
  </p>

  <h3>Maintenance Medications</h3>
  <p>
    Ongoing medications for chronic conditions:
  </p>
  <ul>
    <li>Blood pressure medications</li>
    <li>Diabetes medications (including insulin)</li>
    <li>Thyroid medications</li>
    <li>Cholesterol medications</li>
    <li>Mental health medications</li>
  </ul>
  <p>
    Full health plans cover these after waiting periods. Travel medical typically does not.
  </p>

  <CTABox
    title="Need Specialty Drug Coverage?"
    description="Compare plans that cover expensive specialty medications."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="considerations">Key Considerations</h2>

  <h3>Medication Availability Abroad</h3>
  <ul>
    <li>Not all medications available in all countries</li>
    <li>Brand names differ by country</li>
    <li>Some medications require local prescriptions</li>
    <li>Controlled substances have strict regulations</li>
    <li>Check availability before relocating</li>
  </ul>

  <h3>Getting Prescriptions Refilled</h3>
  <p>
    Options for ongoing medications:
  </p>
  <ul>
    <li><strong>Local doctor:</strong> Get new prescription locally</li>
    <li><strong>Telemedicine:</strong> Some insurers offer remote prescribing</li>
    <li><strong>Home country refills:</strong> Mail-order from home (check legality)</li>
    <li><strong>Travel with supply:</strong> Bring several months when visiting home</li>
  </ul>

  <h3>Prior Authorization</h3>
  <p>
    Some medications need pre-approval:
  </p>
  <ul>
    <li>Specialty drugs often need authorization</li>
    <li>Step therapy may be required (try cheaper drugs first)</li>
    <li>Process usually takes 24-72 hours</li>
    <li>Insurer verifies medical necessity</li>
    <li>Emergency medications typically don't need pre-auth</li>
  </ul>

  <h3>Cost Differences</h3>
  <p>
    Medication costs vary dramatically by country:
  </p>
  <ul>
    <li>US: Often highest prices globally</li>
    <li>Europe: Regulated, moderate prices</li>
    <li>Asia: Often much cheaper</li>
    <li>Same medication can cost 10x more in US vs India</li>
    <li>Generic availability varies</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Are my current medications covered?</h3>
  <p>
    With full health insurance, after any waiting period for pre-existing conditions, yes. With travel medical insurance, maintenance medications are typically NOT covered—only new prescriptions for acute conditions.
  </p>

  <h3>How do I get my prescriptions filled abroad?</h3>
  <p>
    See a local doctor or use telemedicine to get a prescription valid in your country. Take it to a local pharmacy, pay, and submit for reimbursement. Some insurers have pharmacy networks for direct billing in certain countries.
  </p>

  <h3>Can I bring medications from home?</h3>
  <p>
    Generally yes, for personal use. Bring documentation (prescription, doctor's letter). Controlled substances have strict rules—check destination country regulations. Usually 90-day supply is acceptable.
  </p>

  <h3>What about expensive specialty drugs?</h3>
  <p>
    Full health plans from major insurers (Cigna, Bupa, Aetna) typically cover specialty drugs, though pre-authorization may be required. Travel medical and budget plans usually exclude them. If you need specialty drugs, choose comprehensive coverage.
  </p>

  <h3>Is insulin covered?</h3>
  <p>
    With full health insurance, yes (after any waiting period for pre-existing conditions). With travel medical, typically no—diabetes is pre-existing. Insulin costs vary dramatically by country ($30 in Mexico vs $300 in US for same product).
  </p>

  <h3>Can telemedicine prescribe medications internationally?</h3>
  <p>
    Often yes, but with limitations. The prescription must be valid in your country. Controlled substances usually can't be prescribed remotely. Some countries don't recognize telemedicine prescriptions. Check your insurer's telemedicine prescription policies.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Prescription coverage varies by plan and medication regulations vary by country. We are not insurance brokers or pharmacists. Always verify coverage and medication availability directly with insurers and local authorities.
    </p>
  </div>
</PageShell>
