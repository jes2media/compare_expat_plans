---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'coverage-explained', text: 'How Adventure Coverage Works', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'activities-covered', text: 'Activities Covered', level: 2 },
  { id: 'exclusions', text: 'Common Exclusions', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Budget Insurance', href: '/best/budget-insurance' },
  { title: 'Short-Term Insurance', href: '/best/short-term-expat-insurance' },
  { title: 'World Nomads Review', href: '/providers/world-nomads' },
  { title: 'SafetyWing Review', href: '/providers/safetywing' },
  { title: 'Understanding Exclusions', href: '/guides/understanding-exclusions' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'activities', header: 'Activities' },
  { key: 'level', header: 'Coverage Level' },
  { key: 'rescue', header: 'Mountain Rescue' },
  { key: 'price', header: 'Monthly Cost' },
];

const comparisonRows = [
  { provider: 'World Nomads', activities: '150+', level: 'Strong', rescue: 'Included', price: '$80-200' },
  { provider: 'SafetyWing', activities: '30+', level: 'Basic', rescue: 'Limited', price: '$45-85' },
  { provider: 'IMG Global', activities: '50+', level: 'Good', rescue: 'Add-on', price: '$100-250' },
  { provider: 'Bupa Global', activities: 'Standard', level: 'Excellent', rescue: 'Included', price: '$300-600+' },
  { provider: 'Cigna Global', activities: 'Standard', level: 'Excellent', rescue: 'Included', price: '$250-500+' },
];

const activitiesColumns = [
  { key: 'activity', header: 'Activity' },
  { key: 'worldNomads', header: 'World Nomads' },
  { key: 'safetyWing', header: 'SafetyWing' },
  { key: 'fullHealth', header: 'Full Health Plans' },
];

const activitiesRows = [
  { activity: 'Hiking/trekking', worldNomads: 'Up to 6,000m', safetyWing: 'Up to 4,500m', fullHealth: 'Usually covered' },
  { activity: 'Scuba diving', worldNomads: 'Up to 40m', safetyWing: 'Up to 30m', fullHealth: 'Recreational only' },
  { activity: 'Skiing/snowboarding', worldNomads: 'On-piste included', safetyWing: 'On-piste only', fullHealth: 'Usually covered' },
  { activity: 'Surfing', worldNomads: 'Included', safetyWing: 'Included', fullHealth: 'Usually covered' },
  { activity: 'Rock climbing', worldNomads: 'Included', safetyWing: 'Limited', fullHealth: 'Check policy' },
  { activity: 'Bungee jumping', worldNomads: 'Included', safetyWing: 'Excluded', fullHealth: 'Often excluded' },
  { activity: 'Skydiving', worldNomads: 'Included', safetyWing: 'Excluded', fullHealth: 'Often excluded' },
  { activity: 'Motorcycling', worldNomads: 'Under 125cc', safetyWing: 'Under 125cc', fullHealth: 'Check policy' },
];
---

<PageShell
  title="Best Expat Insurance for Adventure Sports 2026"
  description="Compare international health insurance that covers extreme sports and adventure activities. Find coverage for hiking, diving, skiing, and more risky pursuits abroad."
  headline="Best Expat Insurance for Adventure Sports"
  subheadline="Standard insurance excludes many adventure activities. If you're into extreme sports, hiking at altitude, or diving, here's how to stay covered."
  heroImage="/images/answers/best-adventure-sports-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Adventure Sports</h2>
  <p>
    If you're active and adventurous, these insurers offer the best coverage:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏔️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Adventure Coverage</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">World Nomads</p>
      <p class="text-neutral-600">150+ adventure activities covered including extreme sports. Purpose-built for active travelers.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Budget Option</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">SafetyWing</p>
      <p class="text-neutral-600">Basic adventure coverage at $45/month. Good for common activities like hiking and surfing.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏥</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Full Health + Adventure</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">IMG Global</p>
      <p class="text-neutral-600">Full health insurance with good adventure coverage. Better for long-term expats who are active.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👑</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Premium Option</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Comprehensive coverage including most recreational activities. Premium service with mountain rescue.</p>
    </div>
  </div>

  <h2 id="coverage-explained">How Adventure Coverage Works</h2>
  <p>
    Most insurance policies exclude "hazardous activities." Adventure coverage addresses this gap:
  </p>

  <h3>Why Activities Are Excluded</h3>
  <p>
    Insurance is based on risk. Activities like skydiving, mountain climbing, and scuba diving have higher injury rates. Standard policies exclude them to keep premiums down for everyone.
  </p>

  <h3>Types of Coverage</h3>

  <h4>Travel Medical with Adventure Add-On</h4>
  <ul>
    <li>Base plan covers standard risks</li>
    <li>Adventure activities added as coverage</li>
    <li>World Nomads specializes in this approach</li>
    <li>Good for active short-term travelers</li>
  </ul>

  <h4>Full Health Insurance</h4>
  <ul>
    <li>Premium plans often include recreational sports</li>
    <li>May exclude professional or competitive activities</li>
    <li>Higher limits but check specific exclusions</li>
    <li>Better for long-term adventurous expats</li>
  </ul>

  <h3>Key Things to Check</h3>
  <ul>
    <li><strong>Specific activity list:</strong> Is your activity explicitly covered?</li>
    <li><strong>Altitude limits:</strong> Most plans cap trekking altitude (4,000-6,000m)</li>
    <li><strong>Depth limits:</strong> Diving usually limited to 30-40m</li>
    <li><strong>Certification requirements:</strong> Some activities require certification</li>
    <li><strong>Competition exclusions:</strong> Racing and competition often excluded</li>
    <li><strong>Rescue coverage:</strong> Mountain/sea rescue not always included</li>
  </ul>

  <CTABox
    title="Compare Adventure Coverage"
    description="Find insurance that covers your favorite activities."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Adventure Insurance Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>World Nomads — Best Adventure Coverage</h3>
  <p>
    World Nomads was built specifically for adventure travelers and covers more activities than any other travel insurance.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>150+ adventure activities covered</li>
    <li>Includes extreme sports (skydiving, bungee, etc.)</li>
    <li>High-altitude trekking up to 6,000m</li>
    <li>Scuba diving to 40m</li>
    <li>Mountain rescue included</li>
    <li>Search and rescue coverage</li>
    <li>Can buy while already traveling</li>
  </ul>
  <p><strong>Considerations:</strong> Travel medical insurance only—not full health. Pre-existing conditions excluded. More expensive than SafetyWing. Some activities require their Explorer plan.</p>
  <p><strong>Best for:</strong> Active travelers doing adventure sports who need specific activity coverage.</p>

  <h3>SafetyWing — Budget Adventure Option</h3>
  <p>
    SafetyWing covers basic adventure activities at a fraction of World Nomads' price.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Starts at $45/month</li>
    <li>Covers common activities (hiking, surfing, etc.)</li>
    <li>Skiing/snowboarding on-piste covered</li>
    <li>Scuba diving to 30m</li>
    <li>Trekking up to 4,500m</li>
    <li>No health questions</li>
  </ul>
  <p><strong>Considerations:</strong> Excludes extreme sports (skydiving, bungee). Lower altitude limits. Limited mountain rescue. No rock climbing beyond basic. Pre-existing excluded.</p>
  <p><strong>Best for:</strong> Budget-conscious adventurers doing common activities.</p>
  <p><a href="/providers/safetywing">Read our full SafetyWing review</a></p>

  <h3>IMG Global — Full Health + Adventure</h3>
  <p>
    IMG offers full health insurance with decent adventure activity coverage—good for long-term active expats.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Full health insurance coverage</li>
    <li>Adventure activities can be added</li>
    <li>Pre-existing conditions after waiting period</li>
    <li>Higher coverage limits</li>
    <li>Good for long-term expats</li>
  </ul>
  <p><strong>Considerations:</strong> Adventure coverage may require add-on. Check specific activities. Higher premiums than travel medical. Some extreme sports excluded.</p>
  <p><a href="/providers/img-global">Read our full IMG Global review</a></p>

  <h2 id="activities-covered">Activities by Provider</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={activitiesColumns} rows={activitiesRows} />
  </div>

  <h3>Altitude Matters</h3>
  <p>
    Trekking coverage typically has altitude limits:
  </p>
  <ul>
    <li><strong>Basic plans:</strong> Up to 3,000-4,000m</li>
    <li><strong>SafetyWing:</strong> Up to 4,500m</li>
    <li><strong>World Nomads:</strong> Up to 6,000m</li>
  </ul>
  <p>
    For Everest Base Camp (5,364m), Kilimanjaro (5,895m), or similar high-altitude treks, you need World Nomads or a premium plan.
  </p>

  <h3>Diving Depth Limits</h3>
  <p>
    Scuba diving coverage varies:
  </p>
  <ul>
    <li><strong>Basic plans:</strong> 18-30m (recreational limit)</li>
    <li><strong>World Nomads:</strong> Up to 40m</li>
    <li><strong>Technical diving:</strong> Often excluded</li>
  </ul>

  <CTABox
    title="Check Your Activities"
    description="Make sure your specific activities are covered before you go."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="exclusions">Common Exclusions</h2>
  <p>
    Even adventure-focused plans have exclusions:
  </p>

  <h3>Usually Excluded</h3>
  <ul>
    <li><strong>Professional competition:</strong> Racing, tournaments, professional sports</li>
    <li><strong>Base jumping:</strong> Too high-risk for most insurers</li>
    <li><strong>Free solo climbing:</strong> Unroped climbing without certification</li>
    <li><strong>Cave diving:</strong> Technical diving in caves</li>
    <li><strong>Mountaineering above limits:</strong> Above 6,000m usually excluded</li>
    <li><strong>Activities without certification:</strong> Some require proof of training</li>
    <li><strong>Motorized vehicles:</strong> Motorcycles over 125cc often excluded</li>
  </ul>

  <h3>Conditionally Covered</h3>
  <ul>
    <li><strong>Skiing:</strong> On-piste usually covered, backcountry may not be</li>
    <li><strong>Rock climbing:</strong> Indoor/guided often okay, lead climbing varies</li>
    <li><strong>Motorcycles:</strong> Under 125cc, with helmet, licensed</li>
    <li><strong>Water sports:</strong> Recreational okay, competitive often not</li>
  </ul>

  <h3>Always Check</h3>
  <ul>
    <li>Read the policy document, not just marketing</li>
    <li>Look for your specific activity by name</li>
    <li>Note any conditions (certification, guide, etc.)</li>
    <li>Understand altitude and depth limits</li>
    <li>Check if search and rescue is included</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Will regular travel insurance cover hiking?</h3>
  <p>
    Basic hiking usually yes, but altitude limits apply. Most standard plans cover hiking up to 3,000-4,000m. For high-altitude treks (Everest Base Camp, Kilimanjaro), you need adventure coverage with higher limits.
  </p>

  <h3>Is skiing covered by normal insurance?</h3>
  <p>
    On-piste skiing at marked resorts is usually covered. Off-piste, backcountry, and heli-skiing are often excluded or require adventure add-ons. Always verify before hitting the slopes.
  </p>

  <h3>What about scuba diving?</h3>
  <p>
    Recreational diving (under 30-40m) is covered by most adventure policies. Technical diving, cave diving, and diving without certification are usually excluded. Check depth limits for your specific plan.
  </p>

  <h3>Does adventure insurance cover rescue costs?</h3>
  <p>
    Not always. Search and rescue, mountain rescue, and helicopter evacuation may be separate coverage. World Nomads includes rescue; SafetyWing has limitations. Verify rescue is covered before high-altitude or remote activities.
  </p>

  <h3>Can I buy adventure insurance after an accident?</h3>
  <p>
    No. Insurance must be in place before the incident. You cannot retroactively add coverage for an injury that already occurred.
  </p>

  <h3>What if I try an activity not on my policy?</h3>
  <p>
    You're not covered. Any injury from an excluded activity won't be paid. If you decide to go bungee jumping on a policy that excludes it, you're taking that risk uninsured.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Activity coverage varies by plan and policy version. We are not insurance brokers. Always verify specific activities are covered in your policy document.
    </p>
  </div>
</PageShell>
