---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-outpatient-means', text: 'What Outpatient Means', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'coverage-details', text: 'What\'s Covered', level: 2 },
  { id: 'considerations', text: 'Key Considerations', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Inpatient Insurance', href: '/best/inpatient-insurance' },
  { title: 'Comprehensive Insurance', href: '/best/premium-insurance' },
  { title: 'Telemedicine Insurance', href: '/best/telemedicine-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Understanding Coverage Types', href: '/guides/understanding-coverage-types' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'outpatientOption', header: 'Outpatient Option' },
  { key: 'coverage', header: 'Outpatient Limits' },
  { key: 'addOn', header: 'Add-On Available' },
  { key: 'price', header: 'Add-On Cost' },
];

const comparisonRows = [
  { provider: 'Cigna Global', outpatientOption: 'Modular add-on', coverage: 'Full coverage', addOn: 'Yes', price: '+$50-150/mo' },
  { provider: 'Bupa Global', outpatientOption: 'Included in most', coverage: 'Full coverage', addOn: 'N/A', price: 'Included' },
  { provider: 'Allianz Care', outpatientOption: 'Modular add-on', coverage: 'Full coverage', addOn: 'Yes', price: '+$40-120/mo' },
  { provider: 'IMG Global', outpatientOption: 'Modular add-on', coverage: 'With limits', addOn: 'Yes', price: '+$30-80/mo' },
  { provider: 'Aetna International', outpatientOption: 'Included in most', coverage: 'Full coverage', addOn: 'N/A', price: 'Included' },
];

const coverageColumns = [
  { key: 'service', header: 'Service' },
  { key: 'outpatient', header: 'Outpatient Coverage' },
  { key: 'notes', header: 'Notes' },
];

const coverageRows = [
  { service: 'Doctor consultations', outpatient: '✓ Covered', notes: 'GP and specialist visits' },
  { service: 'Diagnostic tests', outpatient: '✓ Covered', notes: 'Blood tests, imaging, etc.' },
  { service: 'Prescriptions', outpatient: '✓ Covered', notes: 'Medications from pharmacy' },
  { service: 'Specialist visits', outpatient: '✓ Covered', notes: 'May need referral' },
  { service: 'Physical therapy', outpatient: '✓ Covered', notes: 'Often with session limits' },
  { service: 'Mental health', outpatient: 'Varies', notes: 'Session limits common' },
  { service: 'Preventive care', outpatient: 'Varies', notes: 'Some plans include, some don\'t' },
  { service: 'Vaccinations', outpatient: 'Varies', notes: 'Check specific plan' },
];
---

<PageShell
  title="Best Expat Insurance with Outpatient Coverage 2026"
  description="Compare international health insurance with strong outpatient coverage. Find plans that cover doctor visits, prescriptions, and clinic care abroad."
  headline="Best Expat Insurance with Outpatient Coverage"
  subheadline="Outpatient coverage handles the day-to-day—doctor visits, prescriptions, lab tests. Here's how to find plans with comprehensive outpatient benefits."
  heroImage="/images/answers/best-outpatient-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Outpatient Coverage</h2>
  <p>
    These insurers offer the best outpatient benefits:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🩺</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Outpatient Coverage</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Flexible outpatient module with comprehensive doctor and prescription coverage.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">👑</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Included Outpatient</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Full outpatient included in most plans. No need to add separately.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💰</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Value Outpatient</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Allianz Care</p>
      <p class="text-neutral-600">Good outpatient add-on at moderate cost. Strong European coverage.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best US Outpatient</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Comprehensive outpatient with strong US provider network.</p>
    </div>
  </div>

  <h2 id="what-outpatient-means">What Outpatient Coverage Means</h2>
  <p>
    Outpatient coverage handles medical care that doesn't require hospital admission:
  </p>

  <h3>What's Included</h3>
  <ul>
    <li>Doctor office visits</li>
    <li>Specialist consultations</li>
    <li>Diagnostic tests (blood work, X-rays, MRI)</li>
    <li>Prescription medications</li>
    <li>Physical therapy</li>
    <li>Mental health visits</li>
    <li>Minor procedures at clinics</li>
    <li>Follow-up care</li>
  </ul>

  <h3>Why It Matters</h3>
  <p>
    Most healthcare interactions are outpatient:
  </p>
  <ul>
    <li>Catching a cold—doctor visit and prescription</li>
    <li>Annual checkup—doctor visit and lab tests</li>
    <li>Sprained ankle—doctor visit and maybe X-ray</li>
    <li>Managing diabetes—regular visits and medications</li>
    <li>Therapy sessions—mental health visits</li>
  </ul>
  <p>
    Without outpatient coverage, you pay for all of this out-of-pocket.
  </p>

  <CTABox
    title="Get Comprehensive Coverage"
    description="Compare plans with strong outpatient benefits."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Outpatient Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best Outpatient Module</h3>
  <p>
    Cigna Global offers a flexible modular structure where you can add outpatient to a base plan.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Comprehensive outpatient module</li>
    <li>Doctor visits fully covered</li>
    <li>Prescriptions included</li>
    <li>Diagnostic tests covered</li>
    <li>Good specialist access</li>
    <li>Physical therapy included</li>
    <li>Mental health outpatient options</li>
  </ul>
  <p><strong>Considerations:</strong> Add-on cost ($50-150/month). Worth it if you use outpatient regularly. Can start with inpatient and add later.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Best Included Outpatient</h3>
  <p>
    Bupa Global includes comprehensive outpatient in most plans without add-on fees.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Outpatient included in most plans</li>
    <li>No separate module to add</li>
    <li>Full coverage for doctor visits</li>
    <li>Prescriptions covered</li>
    <li>Diagnostics included</li>
    <li>Physical therapy included</li>
    <li>Mental health covered</li>
  </ul>
  <p><strong>Considerations:</strong> Higher base premium (but includes outpatient). Premium pricing overall. Worth it for comprehensive coverage.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Allianz Care — Best Value Outpatient</h3>
  <p>
    Allianz Care offers good outpatient coverage at competitive prices.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Flexible outpatient add-on</li>
    <li>Good coverage at moderate cost</li>
    <li>Strong European network</li>
    <li>Doctor visits covered</li>
    <li>Prescriptions included</li>
  </ul>
  <p><strong>Considerations:</strong> Some limits may apply. Network best in Europe. Good value option.</p>
  <p><a href="/providers/allianz-care">Read our full Allianz Care review</a></p>

  <h2 id="coverage-details">What's Covered</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Primary Care vs Specialists</h3>
  <p>
    Most plans cover both, but access differs:
  </p>
  <ul>
    <li><strong>Primary care:</strong> Usually unlimited visits</li>
    <li><strong>Specialists:</strong> May need GP referral</li>
    <li><strong>Self-referral:</strong> Premium plans allow direct specialist access</li>
  </ul>

  <h3>Prescriptions</h3>
  <p>
    Outpatient typically includes prescriptions:
  </p>
  <ul>
    <li>Acute medications (antibiotics, etc.)</li>
    <li>Maintenance medications (after pre-existing waiting period)</li>
    <li>Usually pay at pharmacy and claim reimbursement</li>
    <li>Some plans have pharmacy networks</li>
  </ul>

  <h3>Mental Health Outpatient</h3>
  <p>
    Varies significantly:
  </p>
  <ul>
    <li>Some plans: unlimited sessions</li>
    <li>Some plans: 10-30 session limit</li>
    <li>Some plans: separate add-on needed</li>
    <li>Telemedicine mental health often available</li>
  </ul>

  <CTABox
    title="Include Outpatient"
    description="Most people use outpatient care more than inpatient."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="considerations">Key Considerations</h2>

  <h3>Modular vs Included</h3>
  <p>
    Two approaches to outpatient:
  </p>
  <ul>
    <li><strong>Modular (Cigna, Allianz):</strong> Add outpatient to base plan. More flexibility, choose what you need.</li>
    <li><strong>Included (Bupa, Aetna):</strong> Outpatient included in most plans. Higher base price, but comprehensive.</li>
  </ul>

  <h3>Limits and Caps</h3>
  <p>
    Watch for:
  </p>
  <ul>
    <li>Annual outpatient maximums</li>
    <li>Per-visit caps</li>
    <li>Physical therapy session limits</li>
    <li>Mental health session limits</li>
    <li>Prescription maximums</li>
  </ul>

  <h3>Network for Outpatient</h3>
  <p>
    Unlike hospitals, outpatient networks matter more:
  </p>
  <ul>
    <li>More frequent use means more chances to use network</li>
    <li>Direct billing saves hassle on regular visits</li>
    <li>Out-of-network means paying and claiming each time</li>
    <li>Check network near where you live</li>
  </ul>

  <h3>When to Skip Outpatient</h3>
  <p>
    You might skip outpatient if:
  </p>
  <ul>
    <li>You're in a country with very cheap outpatient care</li>
    <li>You rarely visit doctors</li>
    <li>You want to minimize premiums</li>
    <li>Savings exceed expected outpatient costs</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Is outpatient coverage worth the extra cost?</h3>
  <p>
    Depends on usage. If you visit doctors several times a year, take regular medications, or have ongoing care needs—yes. If you rarely see a doctor and are in an affordable healthcare country—maybe not. Do the math: add-on cost vs expected out-of-pocket.
  </p>

  <h3>Can I add outpatient coverage later?</h3>
  <p>
    Usually yes, at renewal. You may face underwriting, and conditions developed may affect coverage. If you think you'll want outpatient, consider including it from the start.
  </p>

  <h3>Does outpatient include preventive care?</h3>
  <p>
    Varies by plan. Some include annual checkups and screenings. Others exclude preventive care as a separate wellness benefit. Verify what's included in your specific plan.
  </p>

  <h3>What about telemedicine—is that outpatient?</h3>
  <p>
    Yes, telemedicine counts as outpatient care. With outpatient coverage, telemedicine consultations are typically covered. Prescriptions from telemedicine visits are also covered.
  </p>

  <h3>Are there limits on doctor visits?</h3>
  <p>
    Most comprehensive outpatient plans don't limit GP visits. Some may have limits on specialist visits, physical therapy sessions, or mental health sessions. Premium plans typically have no limits.
  </p>

  <h3>How do I claim outpatient expenses?</h3>
  <p>
    Usually: pay at the provider, keep receipts, submit claim via app or portal. Reimbursement typically takes 1-4 weeks. Some insurers have networks where you can use direct billing for outpatient care.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Coverage details vary by plan. We are not insurance brokers. Always verify current terms directly with insurers.
    </p>
  </div>
</PageShell>
