---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'top-picks', text: 'Top Picks', level: 2 },
  { id: 'what-prescription-covers', text: 'What Prescription Coverage Includes', level: 2 },
  { id: 'comparison-table', text: 'Plan Comparison', level: 2 },
  { id: 'detailed-reviews', text: 'Detailed Reviews', level: 2 },
  { id: 'medication-types', text: 'Medication Types Covered', level: 2 },
  { id: 'getting-medications', text: 'Getting Medications Abroad', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
];

const relatedLinks = [
  { title: 'Chronic Condition Insurance', href: '/best/chronic-condition-insurance' },
  { title: 'Outpatient Insurance', href: '/best/outpatient-insurance' },
  { title: 'Telemedicine Insurance', href: '/best/telemedicine-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'Bupa Global Review', href: '/providers/bupa-global' },
];

const comparisonColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'rxCoverage', header: 'Rx Coverage' },
  { key: 'limits', header: 'Annual Limits' },
  { key: 'copay', header: 'Copay Structure' },
  { key: 'specialty', header: 'Specialty Drugs' },
];

const comparisonRows = [
  { provider: 'Cigna Global', rxCoverage: 'Comprehensive', limits: 'High/Unlimited', copay: 'Low or none', specialty: 'Usually covered' },
  { provider: 'Bupa Global', rxCoverage: 'Comprehensive', limits: 'High/Unlimited', copay: 'Low or none', specialty: 'Usually covered' },
  { provider: 'Aetna International', rxCoverage: 'Good', limits: 'Varies by plan', copay: 'Varies', specialty: 'Covered' },
  { provider: 'Allianz Care', rxCoverage: 'Good', limits: 'Varies by plan', copay: 'Some copays', specialty: 'Some plans' },
  { provider: 'IMG Global', rxCoverage: 'Basic', limits: 'Lower limits', copay: 'Higher copays', specialty: 'Limited' },
];

const medicationColumns = [
  { key: 'type', header: 'Medication Type' },
  { key: 'coverage', header: 'Typical Coverage' },
  { key: 'notes', header: 'Notes' },
];

const medicationRows = [
  { type: 'Acute medications', coverage: 'Usually covered', notes: 'Antibiotics, pain relief, etc.' },
  { type: 'Maintenance medications', coverage: 'Usually covered', notes: 'Blood pressure, cholesterol, etc.' },
  { type: 'Specialty drugs', coverage: 'Often covered', notes: 'Biologics, cancer drugs (may need pre-auth)' },
  { type: 'Generic drugs', coverage: 'Preferred', notes: 'Lower cost, often encouraged' },
  { type: 'Brand name drugs', coverage: 'Covered', notes: 'May have higher copay' },
  { type: 'OTC medications', coverage: 'Rarely covered', notes: 'Usually out-of-pocket' },
  { type: 'Vitamins/supplements', coverage: 'Not covered', notes: 'Excluded from most plans' },
];
---

<PageShell
  title="Best Expat Insurance for Prescription Coverage 2026"
  description="Compare international health insurance with comprehensive prescription drug coverage. Find plans that cover medications abroad including specialty drugs and chronic disease maintenance."
  headline="Best Expat Insurance for Prescription Coverage"
  subheadline="Getting your medications abroad shouldn't be complicated. Here are the international health plans with the best prescription drug coverage for expats."
  heroImage="/images/answers/best-prescription-insurance.png"
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  showHeroCta={false}
  ctaButtonText="Compare Plans"
  ctaButtonHref="/compare/"
>
  <h2 id="top-picks">Top Picks for Prescription Coverage</h2>
  <p>
    These insurers offer the best medication benefits:
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
      <div class="text-4xl mb-3">💊</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best Prescription Coverage</h3>
      <p class="text-2xl font-bold text-primary-700 mb-2">Cigna Global</p>
      <p class="text-neutral-600">Comprehensive prescription coverage with high limits, low copays, and specialty drug access.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🏆</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best for Specialty Drugs</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Bupa Global</p>
      <p class="text-neutral-600">Excellent specialty medication coverage including biologics and cancer drugs.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">🇺🇸</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Best US Pharmacy Access</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Aetna International</p>
      <p class="text-neutral-600">Strong US pharmacy network with good international coverage.</p>
    </div>
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <div class="text-4xl mb-3">⚕️</div>
      <h3 class="text-lg font-semibold text-neutral-900 mb-2">Why It Matters</h3>
      <p class="text-2xl font-bold text-neutral-700 mb-2">Medication Access</p>
      <p class="text-neutral-600">Good prescription coverage ensures you can continue essential medications wherever you live.</p>
    </div>
  </div>

  <h2 id="what-prescription-covers">What Prescription Coverage Includes</h2>
  <p>
    Prescription coverage in international health insurance typically includes:
  </p>

  <h3>Covered Medications</h3>
  <ul>
    <li>Prescription medications from licensed pharmacies</li>
    <li>Both generic and brand name drugs</li>
    <li>Acute treatment medications</li>
    <li>Chronic disease maintenance medications</li>
    <li>Specialty and biologic drugs (with pre-authorization)</li>
  </ul>

  <h3>How It Works</h3>
  <ul>
    <li>Get prescription from doctor or via telemedicine</li>
    <li>Fill at local pharmacy in any country</li>
    <li>Pay copay (if any) or full cost and claim reimbursement</li>
    <li>Some insurers have pharmacy networks for direct billing</li>
    <li>Submit receipts for out-of-network pharmacies</li>
  </ul>

  <h3>What's Usually Excluded</h3>
  <ul>
    <li>Over-the-counter medications</li>
    <li>Vitamins and supplements</li>
    <li>Cosmetic medications</li>
    <li>Experimental drugs (unless approved)</li>
    <li>Fertility medications (unless fertility coverage included)</li>
  </ul>

  <CTABox
    title="Keep Your Medications Covered"
    description="Compare plans with comprehensive prescription benefits."
    buttonText="Compare Plans"
    buttonHref="/compare/"
    variant="highlight"
  />

  <h2 id="comparison-table">Prescription Coverage Comparison</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />
  </div>

  <h2 id="detailed-reviews">Detailed Reviews</h2>

  <h3>Cigna Global — Best Prescription Coverage</h3>
  <p>
    Cigna Global offers comprehensive prescription benefits on most plans.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Comprehensive medication coverage</li>
    <li>High or unlimited annual limits</li>
    <li>Low or no copays on premium plans</li>
    <li>Specialty drug coverage</li>
    <li>Global pharmacy access</li>
    <li>Telemedicine prescriptions supported</li>
    <li>Mail-order pharmacy options</li>
    <li>Generic substitution savings</li>
  </ul>
  <p><strong>Considerations:</strong> Best coverage on comprehensive plans. Specialty drugs may need pre-authorization. Overall excellent prescription experience.</p>
  <p><a href="/providers/cigna-global">Read our full Cigna Global review</a></p>

  <h3>Bupa Global — Best for Specialty Drugs</h3>
  <p>
    Bupa Global excels in specialty medication coverage.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Excellent specialty drug coverage</li>
    <li>Biologics and cancer drugs covered</li>
    <li>High prescription limits</li>
    <li>Low copays</li>
    <li>Global pharmacy access</li>
    <li>Care coordination for complex medications</li>
    <li>Delivery coordination available</li>
  </ul>
  <p><strong>Considerations:</strong> Premium pricing. Specialty drugs require pre-authorization. Worth it for those needing expensive medications.</p>
  <p><a href="/providers/bupa-global">Read our full Bupa Global review</a></p>

  <h3>Aetna International — US Pharmacy Access</h3>
  <p>
    Aetna International offers strong prescription coverage with good US access.
  </p>
  <p><strong>What works well:</strong></p>
  <ul>
    <li>Strong US pharmacy network</li>
    <li>Good international coverage</li>
    <li>Specialty drug access</li>
    <li>Mail-order options</li>
    <li>Maintenance medication programs</li>
    <li>Digital prescription management</li>
  </ul>
  <p><strong>Considerations:</strong> Best for those needing US pharmacy access. Coverage varies by plan tier. Good overall prescription benefits.</p>
  <p><a href="/providers/aetna-international">Read our full Aetna International review</a></p>

  <h2 id="medication-types">Medication Types Covered</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={medicationColumns} rows={medicationRows} />
  </div>

  <h3>Acute Medications</h3>
  <p>
    Short-term treatment medications:
  </p>
  <ul>
    <li>Antibiotics for infections</li>
    <li>Pain medications</li>
    <li>Anti-inflammatory drugs</li>
    <li>Allergy medications (prescription)</li>
    <li>Usually covered without limits</li>
  </ul>

  <h3>Maintenance Medications</h3>
  <p>
    Ongoing medications for chronic conditions:
  </p>
  <ul>
    <li>Blood pressure medications</li>
    <li>Cholesterol medications</li>
    <li>Diabetes medications (insulin, oral)</li>
    <li>Thyroid medications</li>
    <li>Usually covered with good limits</li>
  </ul>

  <h3>Specialty Medications</h3>
  <p>
    High-cost specialized drugs:
  </p>
  <ul>
    <li>Biologic drugs (for autoimmune conditions)</li>
    <li>Cancer medications</li>
    <li>MS treatments</li>
    <li>Hepatitis C treatments</li>
    <li>Usually require pre-authorization</li>
    <li>May have separate limits</li>
  </ul>

  <h3>Generic vs Brand Name</h3>
  <p>
    Understanding drug coverage:
  </p>
  <ul>
    <li>Generics typically preferred and cheaper</li>
    <li>Brand name covered but may have higher copay</li>
    <li>Some plans require trying generic first</li>
    <li>Medical necessity can override generic requirement</li>
  </ul>

  <CTABox
    title="Don't Worry About Medication Costs"
    description="Find plans that cover your prescription needs."
    buttonText="Compare Plans"
    buttonHref="/compare/"
  />

  <h2 id="getting-medications">Getting Medications Abroad</h2>

  <h3>Finding Your Medications</h3>
  <p>
    Tips for accessing medications internationally:
  </p>
  <ul>
    <li>Know generic name (not just brand name)</li>
    <li>Medications may have different names abroad</li>
    <li>Some medications available OTC in other countries</li>
    <li>Bring copies of your prescriptions</li>
    <li>Ask your doctor for international generic names</li>
  </ul>

  <h3>Prescription Requirements</h3>
  <ul>
    <li>Most countries require local prescription</li>
    <li>Home country prescriptions may not be accepted</li>
    <li>See local doctor or use telemedicine</li>
    <li>Some countries more flexible than others</li>
    <li>Hospital pharmacies may be more accommodating</li>
  </ul>

  <h3>Mail-Order and Delivery</h3>
  <p>
    Options for medication delivery:
  </p>
  <ul>
    <li>Some insurers offer mail-order pharmacy</li>
    <li>International medication delivery services exist</li>
    <li>Useful for hard-to-find medications</li>
    <li>Check customs regulations for your country</li>
    <li>Keep prescriptions and documentation</li>
  </ul>

  <h3>Controlled Substances</h3>
  <p>
    Special considerations:
  </p>
  <ul>
    <li>Laws vary dramatically by country</li>
    <li>Some medications legal at home may be restricted abroad</li>
    <li>Carry prescription and doctor's letter</li>
    <li>Check destination country regulations</li>
    <li>May need special permits for some medications</li>
  </ul>

  <h3>Running Out of Medications</h3>
  <p>
    If you run out abroad:
  </p>
  <ul>
    <li>Use telemedicine for prescription</li>
    <li>Visit local doctor or clinic</li>
    <li>Contact your insurer for assistance</li>
    <li>Explain medication and dosage clearly</li>
    <li>Bring empty packaging if possible</li>
  </ul>

  <h2 id="faqs">Frequently Asked Questions</h2>

  <h3>Are my prescription medications covered abroad?</h3>
  <p>
    Yes, comprehensive international health plans cover prescription medications globally. You can fill prescriptions at pharmacies worldwide. You may need a local prescription, as home country prescriptions aren't always accepted.
  </p>

  <h3>How do I get prescriptions filled in another country?</h3>
  <p>
    Get a prescription from a local doctor or via telemedicine. Take it to any licensed pharmacy. Pay at the pharmacy (copay or full amount). Submit receipt for reimbursement if needed. Know your medication's generic name.
  </p>

  <h3>Are specialty/biologic drugs covered?</h3>
  <p>
    Yes, on comprehensive plans. Specialty drugs typically require pre-authorization. Coverage includes biologics, cancer drugs, and other high-cost medications. May have separate limits or require medical necessity documentation.
  </p>

  <h3>What if my medication isn't available in my new country?</h3>
  <p>
    Your doctor can prescribe an equivalent medication. Some insurers help coordinate international delivery. Mail-order pharmacy may be an option. Discuss alternatives with your prescribing doctor before moving.
  </p>

  <h3>Do prescription costs count toward my deductible?</h3>
  <p>
    Usually yes—prescription costs typically apply to your deductible and out-of-pocket maximum. Some plans have separate prescription deductibles. Premium plans may have no prescription deductible. Check specific plan terms.
  </p>

  <h3>Can I bring medications from home?</h3>
  <p>
    Generally yes for personal use quantities (90-day supply typical). Keep medications in original packaging. Carry prescription and doctor's letter. Some medications restricted in certain countries. Check destination country regulations before traveling.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This content is for informational purposes only. Prescription coverage varies by plan and insurer. We are not insurance brokers or pharmacists. Always verify current coverage directly with insurers.
    </p>
  </div>
</PageShell>
