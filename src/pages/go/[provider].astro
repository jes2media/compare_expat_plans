---
import { providers, getProviderBySlug } from '../../data/providers';

export function getStaticPaths() {
  return providers
    .filter(p => p.externalUrl)
    .map(p => ({
      params: { provider: p.slug },
    }));
}

const { provider: providerSlug } = Astro.params;
const provider = getProviderBySlug(providerSlug);

if (!provider?.externalUrl) {
  return Astro.redirect('/providers');
}

const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redirecting to {provider.name}...</title>
  <meta name="robots" content="noindex, nofollow">

  {GA_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GA_ID);
      </script>
    </>
  )}
</head>
<body style="font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f8fafc;">
  <div style="text-align: center; padding: 2rem;">
    <p style="color: #64748b; margin-bottom: 1rem;">Redirecting to {provider.name}...</p>
    <a href={provider.externalUrl} style="color: #2563eb;">Click here if not redirected</a>
  </div>

  <script is:inline define:vars={{ externalUrl: provider.externalUrl, providerSlug, providerName: provider.name, GA_ID }}>
    // Track outbound click with reliable redirect
    var redirected = false;

    function doRedirect() {
      if (!redirected) {
        redirected = true;
        window.location.href = externalUrl;
      }
    }

    // Fallback redirect - ensures user isn't stuck if GA fails
    setTimeout(doRedirect, 1500);

    // Wait for gtag to be ready, then track and redirect
    function trackAndRedirect() {
      if (typeof gtag === 'function') {
        // GA4 event with callback
        gtag('event', 'outbound_click', {
          'event_category': 'outbound',
          'event_label': providerName,
          'link_url': externalUrl,
          'provider': providerSlug,
          'send_to': GA_ID,
          'event_callback': doRedirect,
          'event_timeout': 1000
        });
      } else {
        // GA not available, redirect immediately
        doRedirect();
      }
    }

    // Check if gtag is ready, otherwise wait for it
    if (GA_ID) {
      if (typeof gtag === 'function') {
        trackAndRedirect();
      } else {
        // Wait for gtag.js to load
        var checkGtag = setInterval(function() {
          if (typeof gtag === 'function') {
            clearInterval(checkGtag);
            trackAndRedirect();
          }
        }, 50);
        // Stop checking after 1 second
        setTimeout(function() { clearInterval(checkGtag); }, 1000);
      }
    } else {
      doRedirect();
    }
  </script>
</body>
</html>
