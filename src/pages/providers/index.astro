---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ContentCards from '../../components/ContentCards.astro';

const providers = [
  {
    title: 'Cigna Global',
    description: 'Large network, strong family options, 24/7 service in multiple languages.',
    href: '/providers/cigna-global',
    image: '/images/providers/cigna-global.png',
  },
  {
    title: 'Allianz Care',
    description: 'Flexible deductibles, 2M+ provider network, up to 60% savings with high deductible.',
    href: '/providers/allianz-care',
    image: '/images/providers/allianz-care.png',
  },
  {
    title: 'BUPA Global',
    description: 'Premium coverage, excellent mental health parity, 4.4/5 Trustpilot rating.',
    href: '/providers/bupa-global',
    image: '/images/providers/bupa-global.png',
  },
  {
    title: 'IMG Global',
    description: 'Budget-friendly pricing, 4.6/5 Trustpilot rating, 50% deductible waived outside US.',
    href: '/providers/img-global',
    image: '/images/providers/img-global.png',
  },
  {
    title: 'Aetna International',
    description: 'Best-in-class US coverage integration. Ideal for US expats needing seamless stateside access.',
    href: '/providers/aetna-international',
    image: '/images/providers/aetna-international.png',
  },
  {
    title: 'GeoBlue',
    description: 'Blue Cross Blue Shield international. US network continuity for Americans abroad.',
    href: '/providers/geoblue',
    image: '/images/providers/geoblue.png',
  },
  {
    title: 'AXA Global Healthcare',
    description: 'French insurance giant. Strong in Europe and Asia with EU regulatory benefits.',
    href: '/providers/axa-global',
    image: '/images/providers/axa-global.png',
  },
  {
    title: 'SafetyWing',
    description: 'Digital nomad favorite. Subscription-based, affordable, cancel anytime.',
    href: '/providers/safetywing',
    image: '/images/providers/safetywing.png',
  },
];
---

<Layout title="Insurance Providers" description="In-depth reviews of international health insurance providers. Compare coverage, pricing, and service quality.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Insurance Provider Reviews
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          Honest reviews of international health insurance companies. Learn about coverage, pricing, pros and cons.
        </p>
        <CTAButton href="/best/expat-health-insurance" size="lg">
          See Our Top Picks
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={providers} title="All Providers" />
    </div>
  </section>
</Layout>
