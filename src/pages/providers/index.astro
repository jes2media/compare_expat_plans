---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ContentCards from '../../components/ContentCards.astro';

const providers = [
  {
    title: 'Cigna Global',
    description: 'Large network, strong family options, comprehensive coverage.',
    href: '/providers/cigna-global',
  },
  {
    title: 'Allianz Care',
    description: 'Flexible plans, competitive pricing, good mental health coverage.',
    href: '/providers/allianz-care',
  },
  {
    title: 'Aetna International',
    description: 'Strong US coverage, established network, wellness programs.',
    href: '/providers/aetna-international',
  },
  {
    title: 'BUPA Global',
    description: 'Premium coverage, extensive benefits, top-tier service.',
    href: '/providers/bupa-global',
  },
  {
    title: 'IMG Global',
    description: 'Budget-friendly options, high-deductible plans available.',
    href: '/providers/img-global',
  },
  {
    title: 'GeoBlue',
    description: 'Blue Cross Blue Shield international arm, US expat focused.',
    href: '/providers/geoblue',
  },
];
---

<Layout title="Insurance Providers" description="In-depth reviews of international health insurance providers. Compare coverage, pricing, and service quality.">
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
          Insurance Provider Reviews
        </h1>
        <p class="text-xl text-neutral-600 mb-8">
          Honest reviews of international health insurance companies. Learn about coverage, pricing, pros and cons.
        </p>
        <CTAButton href="/best/expat-health-insurance" size="lg">
          See Our Top Picks
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ContentCards cards={providers} title="All Providers" />
    </div>
  </section>
</Layout>
