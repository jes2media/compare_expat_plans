---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'quick-assessment', text: 'Quick Assessment', level: 2 },
  { id: 'plans-coverage', text: 'Plans and Coverage', level: 2 },
  { id: 'pricing-analysis', text: 'Pricing Analysis', level: 2 },
  { id: 'claims-experience', text: 'Claims Experience', level: 2 },
  { id: 'customer-service', text: 'Customer Service', level: 2 },
  { id: 'pros-cons', text: 'Pros and Cons', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-its-for', text: 'Who It\'s For', level: 2 },
  { id: 'how-it-compares', text: 'How It Compares', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'BUPA vs Cigna', href: '/compare/bupa-global-vs-cigna-global' },
  { title: 'BUPA vs Allianz', href: '/compare/allianz-care-vs-bupa-global' },
  { title: 'BUPA vs Aetna', href: '/compare/bupa-global-vs-aetna-international' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
  { title: 'Insurance for Mental Health', href: '/insurance-for/mental-health' },
];

const planColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'major', header: 'Major Medical' },
  { key: 'select', header: 'Select' },
  { key: 'premier', header: 'Premier' },
  { key: 'elite', header: 'Elite' },
];

const planRows = [
  { feature: 'Inpatient Hospital', major: 'Full coverage', select: 'Full coverage', premier: 'Full coverage', elite: 'Full coverage' },
  { feature: 'Day Patient', major: 'Full coverage', select: 'Full coverage', premier: 'Full coverage', elite: 'Full coverage' },
  { feature: 'Outpatient Care', major: 'Not included', select: 'Limited', premier: 'Full coverage', elite: 'Full coverage' },
  { feature: 'Mental Health', major: 'Emergency only', select: 'Limited', premier: 'Full parity', elite: 'Full parity' },
  { feature: 'Maternity', major: 'Not included', select: 'Not included', premier: 'Optional add-on', elite: 'Included' },
  { feature: 'Dental', major: 'Not included', select: 'Not included', premier: 'Included', elite: 'Enhanced' },
  { feature: 'Vision', major: 'Not included', select: 'Not included', premier: 'Included', elite: 'Enhanced' },
  { feature: 'Wellness/Preventive', major: 'Not included', select: 'After 10 months', premier: 'Included', elite: 'Enhanced' },
  { feature: 'Evacuation', major: 'Included', select: 'Included', premier: 'Included', elite: 'Inc. repatriation' },
  { feature: 'Deductible', major: '~$6,300 fixed', select: 'Options available', premier: 'Options available', elite: 'Options available' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'select', header: 'Select' },
  { key: 'premier', header: 'Premier' },
  { key: 'elite', header: 'Elite' },
];

const pricingRows = [
  { profile: 'Age 30, $500 deductible', select: '$180-240/mo', premier: '$280-360/mo', elite: '$380-480/mo' },
  { profile: 'Age 40, $500 deductible', select: '$260-340/mo', premier: '$380-480/mo', elite: '$520-660/mo' },
  { profile: 'Age 50, $500 deductible', select: '$380-480/mo', premier: '$520-660/mo', elite: '$720-900/mo' },
  { profile: 'Age 60, $500 deductible', select: '$540-680/mo', premier: '$720-900/mo', elite: '$980-1,220/mo' },
  { profile: 'Family of 4 (adults 35/35)', select: '$680-860/mo', premier: '$940-1,180/mo', elite: '$1,280-1,600/mo' },
];

const mentalHealthColumns = [
  { key: 'aspect', header: 'Mental Health Aspect' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'competitors', header: 'Most Competitors' },
];

const mentalHealthRows = [
  { aspect: 'Inpatient Treatment', bupa: 'Same limits as physical health', competitors: 'Often sub-limited or capped' },
  { aspect: 'Outpatient Therapy', bupa: 'Same limits as physical health', competitors: 'Typically 20-30 visit cap' },
  { aspect: 'ADHD Coverage', bupa: 'Covered (assessment + treatment)', competitors: 'Often excluded entirely' },
  { aspect: 'Addiction Treatment', bupa: 'Covered (rehab included)', competitors: 'Usually excluded' },
  { aspect: 'Self-Inflicted Injuries', bupa: 'Covered', competitors: 'Almost always excluded' },
  { aspect: 'Waiting Period', bupa: 'Same as physical health', competitors: 'Often 2+ year waiting period' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Claims Aspect' },
  { key: 'details', header: 'BUPA Global' },
];

const claimsRows = [
  { aspect: 'Submission Methods', details: 'MembersWorld app, online portal, direct billing' },
  { aspect: 'Processing Time', details: '5-7 business days (routine), 24-48 hours (urgent)' },
  { aspect: 'Direct Billing', details: '1.7M+ providers globally' },
  { aspect: 'Pre-authorization', details: 'Required for planned hospitalization, some procedures' },
  { aspect: 'Reimbursement', details: 'Bank transfer, multiple currencies supported' },
  { aspect: 'Appeals Process', details: 'Formal appeals with independent medical review' },
];

const competitorColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'bupa', header: 'BUPA Global' },
  { key: 'competitor', header: 'Key Difference' },
];

const competitorRows = [
  { aspect: 'Mental Health', bupa: 'Full parity (no limits)', competitor: 'Best in class for mental health' },
  { aspect: 'Pricing', bupa: 'Premium tier', competitor: 'Cigna/Allianz often cheaper' },
  { aspect: 'Pre-existing Conditions', bupa: 'Individual assessment', competitor: 'More favorable than average' },
  { aspect: 'Network Size', bupa: '1.7M+ providers', competitor: 'Comparable to Cigna/Aetna' },
  { aspect: 'Maternity Wait', bupa: '18 months', competitor: 'Longer than most (typically 10-12)' },
  { aspect: 'Customer Satisfaction', bupa: '4.4/5 Trustpilot', competitor: 'Above average ratings' },
];
---

<PageShell
  title="BUPA Global Review 2024: Comprehensive Analysis for Expats"
  description="In-depth BUPA Global review covering plans, pricing, mental health parity, and real scenarios. Find out if BUPA's premium coverage is worth it for your expat needs."
  headline="BUPA Global International Health Insurance Review"
  subheadline="The gold standard for mental health coverage. But premium pricing means it's not for everyone. Here's our honest assessment."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a BUPA Quote"
  ctaButtonHref="/go/bupa-global"
  heroImage="/images/lifestyle/pre-existing-conditions.png"
>
  <h2 id="overview">Overview</h2>
  <p>
    BUPA Global is the international arm of Bupa, a healthcare company with over 75 years of history and a unique structure: they have no shareholders. All profits are reinvested into healthcare services, which has helped them build a reputation for quality coverage and customer care rather than maximizing returns.
  </p>
  <p>
    With a presence in over 190 countries and a network of 1.7 million healthcare providers, BUPA Global is positioned as a premium option in the international health insurance market. Their standout feature is mental health parity—they treat mental health equally to physical health, with no separate limits or caps.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Quick Facts</h3>
    <ul class="space-y-2 text-neutral-600">
      <li><strong>Headquarters:</strong> London, UK</li>
      <li><strong>Founded:</strong> 1947 (75+ years in healthcare)</li>
      <li><strong>Structure:</strong> No shareholders (mutual-like, reinvests profits)</li>
      <li><strong>Network Providers:</strong> 1.7 million+</li>
      <li><strong>Countries Covered:</strong> 190+</li>
      <li><strong>Plan Types:</strong> Major Medical, Select, Premier, Elite</li>
      <li><strong>Age Limit:</strong> Up to 74 to enroll</li>
      <li><strong>Trustpilot Rating:</strong> 4.4/5 stars</li>
      <li><strong>Financial Rating:</strong> A (Excellent) - Standard & Poor's</li>
    </ul>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="text-blue-800 text-sm">
      <strong>Why No Shareholders Matters:</strong> Unlike publicly traded insurers who must balance member care with shareholder returns, BUPA reinvests profits into healthcare services. This structure means decisions are made for member benefit, not quarterly earnings. It's not a guarantee of better service, but it removes a common conflict of interest.
    </p>
  </div>

  <CTABox
    title="Get a Personalized Quote"
    description="See what BUPA Global would cost for your specific situation."
    buttonText="Get Quote"
    buttonHref="/go/bupa-global"
    variant="highlight"
  />

  <h2 id="quick-assessment">Quick Assessment: Is BUPA Global Right for You?</h2>
  <p>
    Before diving into details, here's a quick framework to assess whether BUPA Global fits your needs.
  </p>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-3">BUPA is likely a great fit if you:</h3>
    <ul class="space-y-2 text-green-800">
      <li>Need comprehensive mental health coverage (therapy, ADHD, addiction)</li>
      <li>Have or anticipate mental health needs without arbitrary limits</li>
      <li>Can afford premium pricing for premium coverage</li>
      <li>Value customer service and claims experience over lowest price</li>
      <li>Have pre-existing conditions (more favorable individual assessment)</li>
      <li>Want a provider with a long, stable track record</li>
      <li>Appreciate the no-shareholder structure</li>
    </ul>
  </div>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-3">Consider alternatives if you:</h3>
    <ul class="space-y-2 text-amber-800">
      <li>Are on a strict budget (Cigna/Allianz often cheaper for similar coverage)</li>
      <li>Need maternity coverage soon (18-month waiting period)</li>
      <li>Prioritize US coverage integration (Aetna is better)</li>
      <li>Don't anticipate mental health needs (you're paying for a feature you won't use)</li>
      <li>Want the absolute lowest premiums available</li>
    </ul>
  </div>

  <h2 id="plans-coverage">Plans and Coverage</h2>
  <p>
    BUPA Global offers four plan tiers, from catastrophic coverage to comprehensive premium protection.
  </p>

  <h3>Plan Comparison</h3>
  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Major Medical</h3>
  <p>
    The most affordable option, designed for catastrophic coverage only. It has a high fixed deductible (~$6,300/£5,000) and covers emergencies, major hospitalization, and evacuation. No routine care, wellness, or maternity. Best for healthy individuals who want protection against major medical events while paying out-of-pocket for routine care.
  </p>

  <h3>Select</h3>
  <p>
    Basic coverage with regional (rather than worldwide) options available. Covers health screenings and wellness after a 10-month waiting period, but excludes maternity, dental, and optical. A step up from Major Medical for those who want some outpatient coverage.
  </p>

  <h3>Premier</h3>
  <p>
    Comprehensive coverage suitable for most expats. Includes health screenings, vaccinations, dental, and optical. Maternity available as an add-on (with 18-month waiting period). This is the sweet spot for most expats who want full coverage without paying Elite prices.
  </p>

  <h3>Elite</h3>
  <p>
    BUPA Global's most comprehensive plan. Everything in Premier plus:
  </p>
  <ul>
    <li>Maternity included by default (still has 18-month waiting period)</li>
    <li>Medical evacuation AND repatriation of remains</li>
    <li>Complementary therapies (acupuncture, chiropractic, etc.)</li>
    <li>Enhanced wellness benefits and health screenings</li>
    <li>Higher per-incident and annual limits</li>
  </ul>

  <h3>The Mental Health Parity Advantage</h3>
  <p>
    This is BUPA Global's key differentiator. Unlike most insurers who sub-limit mental health to 20-30 therapy sessions or cap inpatient stays, BUPA treats mental health equally to physical health.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={mentalHealthColumns} rows={mentalHealthRows} />
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="text-blue-800 text-sm">
      <strong>Real Impact:</strong> If you need intensive therapy (say, 50+ sessions for complex PTSD), most insurers cut you off at 20-30 visits. BUPA doesn't. If you need 90-day residential addiction treatment, most insurers exclude it. BUPA covers it. For anyone with serious mental health needs, this can be worth thousands in uncapped coverage.
    </p>
  </div>

  <h3>Pre-Existing Conditions Approach</h3>
  <p>
    BUPA Global takes a more favorable approach than many competitors:
  </p>
  <ul>
    <li><strong>Individual Assessment:</strong> Each application is reviewed on its own merits, not blanket exclusions</li>
    <li><strong>Potential Coverage:</strong> Many pre-existing conditions may be covered (subject to underwriting)</li>
    <li><strong>Transparency:</strong> You'll know what's covered/excluded before committing</li>
    <li><strong>No Moratorium Option:</strong> Unlike Allianz, BUPA doesn't offer moratorium underwriting</li>
  </ul>

  <h3>Waiting Periods</h3>
  <ul>
    <li><strong>Accidental dental:</strong> Immediate</li>
    <li><strong>Routine dental:</strong> 6 months</li>
    <li><strong>Wellness/screenings:</strong> 10 months</li>
    <li><strong>Maternity:</strong> 18 months (longer than most competitors)</li>
  </ul>

  <h2 id="pricing-analysis">Pricing Analysis</h2>
  <p>
    BUPA Global is positioned as a premium provider. Expect higher prices than Cigna, Allianz, or IMG—but the mental health parity and customer service often justify the cost for those who need it.
  </p>

  <h3>Estimated Monthly Premiums (Worldwide Excluding USA)</h3>
  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p>
    <strong>Note:</strong> These are estimates for worldwide coverage excluding USA, with $500 deductible. Including USA adds 30-50% to premiums. Major Medical is significantly cheaper due to the high fixed deductible.
  </p>

  <h3>Ways to Reduce Premiums</h3>
  <ul>
    <li><strong>Higher deductible:</strong> Moving from $500 to $2,500 can save 20-25%</li>
    <li><strong>Regional coverage:</strong> Select Europe or Asia-Pacific instead of worldwide</li>
    <li><strong>Exclude US coverage:</strong> Significant savings if you won't visit the US</li>
    <li><strong>No-claims discount:</strong> BUPA offers discounts for claim-free years (up to 10%)</li>
    <li><strong>Professional discounts:</strong> Doctors and dentists get 15% off</li>
    <li><strong>Major Medical tier:</strong> If you just need catastrophic coverage, the high-deductible plan is much cheaper</li>
  </ul>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 my-6">
    <p class="text-amber-800 text-sm">
      <strong>Premium vs Value Math:</strong> BUPA Premier at $400/month vs Cigna Gold at $340/month is $720/year more. But if you use 40 therapy sessions annually that Cigna would cap at 20, BUPA's uncapped coverage could save you $4,000+ in out-of-pocket therapy costs. Know your needs.
    </p>
  </div>

  <h3>5-Year Cost Projection</h3>
  <p>
    For a 40-year-old on Premier with $1,000 deductible:
  </p>
  <ul>
    <li><strong>Year 1:</strong> ~$4,560 ($380/month)</li>
    <li><strong>Year 2:</strong> ~$4,790 (5% increase)</li>
    <li><strong>Year 3:</strong> ~$5,030 (age + inflation)</li>
    <li><strong>Year 4:</strong> ~$5,280</li>
    <li><strong>Year 5:</strong> ~$5,540</li>
    <li><strong>5-Year Total:</strong> ~$25,200</li>
  </ul>
  <p>
    Budget for 5-8% annual increases. No-claims discounts can offset some of this if you don't file claims.
  </p>

  <CTABox
    title="See Your Actual Price"
    description="Get a quote based on your age, location, and coverage needs."
    buttonText="Get a Quote"
    buttonHref="/go/bupa-global"
  />

  <h2 id="claims-experience">Claims Experience</h2>
  <p>
    BUPA Global's claims process is generally well-regarded, with their 4.4/5 Trustpilot rating reflecting positive member experiences.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={claimsColumns} rows={claimsRows} />
  </div>

  <h3>Direct Billing Network</h3>
  <p>
    BUPA's 1.7 million provider network offers direct billing at most major hospitals worldwide:
  </p>
  <ul>
    <li><strong>Process:</strong> Show your member card, hospital bills BUPA directly</li>
    <li><strong>Benefit:</strong> No large out-of-pocket expenses while waiting for reimbursement</li>
    <li><strong>Coverage:</strong> Most major international hospital groups participate</li>
    <li><strong>Limitations:</strong> Some smaller clinics may require reimbursement</li>
  </ul>

  <h3>Pre-authorization Requirements</h3>
  <p>
    Pre-authorization is required for:
  </p>
  <ul>
    <li>All planned/elective hospitalizations</li>
    <li>Mental health inpatient stays</li>
    <li>Advanced imaging (MRI, CT, PET scans)</li>
    <li>Surgical procedures over certain thresholds</li>
    <li>Cancer treatments and chemotherapy</li>
    <li>Rehabilitation programs</li>
  </ul>
  <p>
    Emergency care does not require pre-authorization, but you should notify BUPA within 48 hours.
  </p>

  <h3>Claims Processing Timeline</h3>
  <ul>
    <li><strong>Routine claims:</strong> 5-7 business days</li>
    <li><strong>Urgent/emergency:</strong> 24-48 hours</li>
    <li><strong>Complex cases:</strong> Up to 30 days (medical review)</li>
    <li><strong>Reimbursement:</strong> Direct deposit in your preferred currency</li>
  </ul>

  <h3>Member Feedback</h3>
  <p>
    Customer reviews frequently praise claims processing. One reviewer noted: "All the claims are settled timely and have hardly any claim rejected in past 4 years." However, some reviews mention occasional administrative delays during initial onboarding.
  </p>

  <h2 id="customer-service">Customer Service</h2>
  <p>
    BUPA Global provides 24/7 multilingual support through a global team of advisers, doctors, and nurses.
  </p>

  <h3>Support Channels</h3>
  <ul>
    <li><strong>Phone:</strong> 24/7 global hotlines with regional numbers</li>
    <li><strong>Email:</strong> Typically 24-48 hour response</li>
    <li><strong>MembersWorld App:</strong> Claims, ID cards, provider search, telehealth</li>
    <li><strong>Online Portal:</strong> Full account management</li>
    <li><strong>Languages:</strong> English, Spanish, French, German, Arabic, Mandarin, more</li>
  </ul>

  <h3>Digital Services</h3>
  <ul>
    <li><strong>Global Virtual Care:</strong> 24/7 telemedicine through the MembersWorld app</li>
    <li><strong>Second Medical Opinion:</strong> Expert review for serious, complex, or chronic conditions</li>
    <li><strong>Digital ID Cards:</strong> Access your membership instantly</li>
    <li><strong>Claims Tracking:</strong> Real-time status updates</li>
    <li><strong>Provider Finder:</strong> Search 1.7M+ providers by location and specialty</li>
  </ul>

  <h3>Case Management</h3>
  <p>
    For complex medical situations, BUPA provides dedicated case managers who coordinate care across countries, arrange medical evacuations, facilitate second opinions, and navigate treatment options.
  </p>

  <h2 id="pros-cons">Pros and Cons</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Pros</h3>
      <ul class="space-y-2 text-green-800">
        <li>Mental health parity (no limits, same as physical)</li>
        <li>ADHD, addiction, self-harm covered</li>
        <li>No shareholders (reinvests in healthcare)</li>
        <li>Excellent customer reviews (4.4/5 Trustpilot)</li>
        <li>Pre-existing conditions individually assessed</li>
        <li>Large global network (1.7M+ providers)</li>
        <li>24/7 multilingual support</li>
        <li>Strong telemedicine and digital tools</li>
        <li>Second Medical Opinion included</li>
        <li>No-claims discounts available</li>
        <li>75+ years healthcare experience</li>
        <li>Professional discounts for doctors/dentists</li>
      </ul>
    </div>
    <div class="bg-red-50 border border-red-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-red-900 mb-3">Cons</h3>
      <ul class="space-y-2 text-red-800">
        <li>Premium pricing (not budget-friendly)</li>
        <li>18-month maternity waiting period (longest in market)</li>
        <li>Some onboarding/admin delays reported</li>
        <li>US coverage significantly increases costs</li>
        <li>No moratorium underwriting option</li>
        <li>Benefit levels vary by country</li>
        <li>Not the best value if you don't need mental health</li>
        <li>Waiting periods for some routine benefits</li>
      </ul>
    </div>
  </div>

  <h2 id="scenarios">Real-World Scenarios</h2>
  <p>
    Here's how BUPA Global performs in common expat situations:
  </p>

  <div class="space-y-6 my-8">
    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 1: Expat with Depression Needs Intensive Therapy</h3>
      <p class="text-neutral-600 mb-3">45-year-old in Singapore develops severe depression after job loss. Psychiatrist recommends twice-weekly therapy for 18 months (150+ sessions) plus medication.</p>
      <p class="text-green-700 font-medium">Outcome: BUPA covers all 150+ sessions without limits. Psychiatrist visits, medications, and eventual tapering all covered. With Cigna's 30-session cap, this member would pay $15,000+ out-of-pocket. With BUPA, total out-of-pocket is deductible only.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 2: Family Planning Maternity Coverage</h3>
      <p class="text-neutral-600 mb-3">Couple relocating to Portugal wants to have a baby within the next year.</p>
      <p class="text-red-700 font-medium">Outcome: BUPA's 18-month maternity waiting period means first pregnancy won't be covered. Couple pays out-of-pocket for delivery (~$4,000-8,000 in Portugal) or chooses Allianz/Cigna with 10-12 month waiting periods instead.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 3: Adult ADHD Diagnosis and Treatment</h3>
      <p class="text-neutral-600 mb-3">35-year-old expat in Germany suspects undiagnosed ADHD. Wants comprehensive assessment and treatment.</p>
      <p class="text-green-700 font-medium">Outcome: BUPA covers full ADHD assessment ($2,000+), ongoing psychiatrist visits, and medication management. Most competitors exclude ADHD entirely or only cover childhood diagnoses. Member gets proper diagnosis and treatment without arbitrary exclusions.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 4: Pre-existing Condition Application</h3>
      <p class="text-neutral-600 mb-3">50-year-old with controlled hypertension and past knee surgery applies for Premier coverage.</p>
      <p class="text-amber-700 font-medium">Outcome: BUPA's individual underwriting assesses both conditions. Hypertension is covered with documentation of stable control. Knee is covered for new injuries but pre-existing joint issues excluded for 2 years. Better outcome than blanket exclusion policies.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 5: Budget-Conscious Healthy Expat</h3>
      <p class="text-neutral-600 mb-3">28-year-old healthy digital nomad comparing BUPA Premier ($320/month) vs Cigna Gold ($260/month). No mental health history or anticipated needs.</p>
      <p class="text-amber-700 font-medium">Outcome: For a healthy person without mental health needs, BUPA's premium pricing doesn't add enough value. The $720/year savings with Cigna makes more sense. Mental health parity is valuable only if you'll use it.</p>
    </div>
  </div>

  <h2 id="who-its-for">Who It's For</h2>

  <h3>Ideal BUPA Global Members</h3>
  <ul>
    <li><strong>Mental health priority:</strong> Anyone who needs or anticipates therapy, psychiatric care, ADHD treatment, or addiction support</li>
    <li><strong>Quality over price:</strong> Those who value excellent service and are willing to pay premium</li>
    <li><strong>Pre-existing conditions:</strong> BUPA's individual assessment may be more favorable than blanket exclusions</li>
    <li><strong>Long-term expats:</strong> The no-shareholder structure and 75-year track record suggest stability</li>
    <li><strong>Healthcare professionals:</strong> 15% discount for doctors and dentists</li>
    <li><strong>Families with mental health history:</strong> Uncapped coverage protects against high therapy costs</li>
  </ul>

  <h3>Better Alternatives Exist If You:</h3>
  <ul>
    <li><strong>Budget is priority:</strong> Cigna Global or Allianz Care offer similar coverage at lower prices</li>
