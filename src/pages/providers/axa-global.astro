---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'plans-and-coverage', text: 'Plans and Coverage', level: 2 },
  { id: 'pricing', text: 'Pricing', level: 2 },
  { id: 'pros-and-cons', text: 'Pros and Cons', level: 2 },
  { id: 'claims-and-service', text: 'Claims and Service', level: 2 },
  { id: 'who-its-for', text: 'Who It\'s For', level: 2 },
  { id: 'alternatives', text: 'Alternatives to Consider', level: 2 },
];

const relatedLinks = [
  { title: 'Allianz Care Review', href: '/providers/allianz-care' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
  { title: 'Cigna Global Review', href: '/providers/cigna-global' },
  { title: 'AXA in France', href: '/countries/france/insurance/axa-global' },
  { title: 'AXA in Germany', href: '/countries/germany/insurance/axa-global' },
  { title: 'AXA in the UK', href: '/countries/uk/insurance/axa-global' },
];

const planColumns = [
  { key: 'plan', header: 'Plan' },
  { key: 'coverage', header: 'Coverage' },
  { key: 'annualMax', header: 'Annual Maximum' },
  { key: 'bestFor', header: 'Best For' },
];

const planRows = [
  { plan: 'Essential', coverage: 'Inpatient + Emergency', annualMax: '€1M', bestFor: 'Major medical only' },
  { plan: 'Comfort', coverage: 'Essential + Outpatient', annualMax: '€2M', bestFor: 'Comprehensive care' },
  { plan: 'Excellence', coverage: 'Comfort + Enhanced', annualMax: '€3M', bestFor: 'Premium coverage' },
  { plan: 'Exclusive', coverage: 'Maximum benefits', annualMax: 'Unlimited', bestFor: 'Top-tier coverage' },
];

const coverageColumns = [
  { key: 'benefit', header: 'Benefit' },
  { key: 'essential', header: 'Essential' },
  { key: 'comfort', header: 'Comfort' },
  { key: 'excellence', header: 'Excellence' },
];

const coverageRows = [
  { benefit: 'Hospitalization', essential: 'Full', comfort: 'Full', excellence: 'Full' },
  { benefit: 'Outpatient', essential: 'Not included', comfort: 'Full', excellence: 'Full' },
  { benefit: 'Dental', essential: 'Not included', comfort: 'Basic', excellence: 'Comprehensive' },
  { benefit: 'Vision', essential: 'Not included', comfort: 'Basic', excellence: 'Full' },
  { benefit: 'Maternity', essential: 'Emergency only', comfort: 'Normal delivery', excellence: 'Full + complications' },
  { benefit: 'Mental Health', essential: 'Crisis only', comfort: 'Limited', excellence: 'Full parity' },
  { benefit: 'Wellness', essential: 'Not included', comfort: 'Basic', excellence: 'Comprehensive' },
];
---

<PageShell
  title="AXA Global Healthcare Review"
  description="In-depth review of AXA Global Healthcare international health insurance. Coverage, pricing, pros and cons for expats in Europe and worldwide."
  headline="AXA Global Healthcare Review"
  subheadline="French insurance giant with worldwide reach. Strong in Europe and Asia, with flexible plans for expats and global professionals."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get an AXA Quote"
  ctaButtonHref="/best/expat-health-insurance"
>
  <h2 id="overview">Overview</h2>
  <p>
    AXA is one of the world's largest insurance companies, headquartered in Paris with operations in 50+ countries. AXA Global Healthcare is their international health insurance division, serving expats, global nomads, and internationally mobile professionals.
  </p>
  <p>
    With deep roots in Europe and strong presence in Asia, AXA Global Healthcare is particularly well-suited for expats in these regions. Their French headquarters also makes them a natural choice for expats moving to France or other EU countries.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Quick Facts</h3>
    <ul class="space-y-2 text-neutral-600">
      <li><strong>Parent Company:</strong> AXA Group (France)</li>
      <li><strong>Headquarters:</strong> Paris, France</li>
      <li><strong>Countries Covered:</strong> 190+</li>
      <li><strong>Network Providers:</strong> 1.6 million+ worldwide</li>
      <li><strong>Regulation:</strong> EU-regulated (French ACPR)</li>
      <li><strong>Plan Types:</strong> Essential, Comfort, Excellence, Exclusive</li>
    </ul>
  </div>

  <CTABox
    title="Get a Personalized Quote"
    description="See what AXA Global Healthcare would cost for your situation."
    buttonText="Get Quote"
    buttonHref="/best/expat-health-insurance"
    variant="highlight"
  />

  <h2 id="plans-and-coverage">Plans and Coverage</h2>
  <p>
    AXA Global Healthcare offers four main plan tiers, each building on the previous with additional benefits and higher limits.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Coverage by Plan Tier</h3>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={coverageColumns} rows={coverageRows} />
  </div>

  <h3>Core Coverage (All Plans)</h3>
  <ul>
    <li>Hospital accommodation and treatment</li>
    <li>Surgery and surgical fees</li>
    <li>Intensive care</li>
    <li>Cancer treatment (chemotherapy, radiotherapy)</li>
    <li>Emergency medical evacuation</li>
    <li>Repatriation of remains</li>
    <li>24/7 emergency assistance</li>
  </ul>

  <h3>Optional Modules</h3>
  <p>
    AXA allows you to customize coverage with add-on modules:
  </p>
  <ul>
    <li><strong>Outpatient:</strong> Doctor visits, diagnostics, prescriptions</li>
    <li><strong>Dental:</strong> Preventive, restorative, and major dental work</li>
    <li><strong>Vision:</strong> Eye exams, glasses, contact lenses</li>
    <li><strong>Maternity:</strong> Prenatal, delivery, postnatal care</li>
    <li><strong>Wellness:</strong> Health screenings, vaccinations, check-ups</li>
  </ul>

  <h3>Area of Coverage Options</h3>
  <p>
    AXA offers multiple coverage zones that affect pricing:
  </p>
  <ul>
    <li><strong>Worldwide excluding USA:</strong> Most affordable option</li>
    <li><strong>Worldwide including USA:</strong> Full global coverage</li>
    <li><strong>Europe only:</strong> Available for EU-focused expats</li>
    <li><strong>Regional:</strong> Asia-Pacific, Middle East, Americas options</li>
  </ul>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-2">EU Regulatory Advantage</h3>
    <p class="text-blue-800">
      As a French-regulated insurer, AXA Global Healthcare operates under EU Solvency II regulations. This provides strong consumer protections and may simplify visa applications for EU countries that prefer locally-regulated insurers.
    </p>
  </div>

  <h2 id="pricing">Pricing</h2>
  <p>
    AXA Global Healthcare pricing depends on your age, plan tier, coverage area, and deductible. European pricing is generally competitive with Allianz Care.
  </p>
  <p>
    <strong>Estimated monthly premiums (worldwide excluding USA):</strong>
  </p>
  <ul>
    <li>Age 30, Comfort: €150-200/month</li>
    <li>Age 40, Comfort: €200-280/month</li>
    <li>Age 50, Comfort: €300-400/month</li>
    <li>Age 60, Comfort: €450-600/month</li>
  </ul>
  <p>
    <strong>Adding USA coverage</strong> increases premiums by approximately 40-50%.
  </p>
  <p>
    <strong>Deductible options:</strong> €0, €150, €500, €1,000, €2,500, €5,000. Higher deductibles can reduce premiums by 20-40%.
  </p>

  <h3>Family Pricing</h3>
  <p>
    AXA offers family plans with discounts for couples and children:
  </p>
  <ul>
    <li>Children often covered at reduced rates or free (varies by plan)</li>
    <li>Family deductibles may be shared</li>
    <li>Maternity coverage applies to family plans</li>
  </ul>

  <CTABox
    title="See Your Actual Price"
    description="Get a quote based on your age, location, and coverage needs."
    buttonText="Get a Quote"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="pros-and-cons">Pros and Cons</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Pros</h3>
      <ul class="space-y-2 text-green-800">
        <li>Strong European presence and network</li>
        <li>EU-regulated (consumer protections)</li>
        <li>Flexible modular plan design</li>
        <li>Good for France and EU visa applications</li>
        <li>Competitive European pricing</li>
        <li>Large global network (1.6M+ providers)</li>
        <li>Multilingual support (French, English, Spanish, more)</li>
        <li>Established brand with financial stability</li>
      </ul>
    </div>
    <div class="bg-red-50 border border-red-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-red-900 mb-3">Cons</h3>
      <ul class="space-y-2 text-red-800">
        <li>Less competitive for US coverage needs</li>
        <li>Pre-existing conditions may be excluded</li>
        <li>Maternity has waiting periods (10-12 months)</li>
        <li>Mental health coverage limited on lower tiers</li>
        <li>Claims processing can be slower than competitors</li>
        <li>Less brand recognition in Americas</li>
        <li>App and digital tools not best-in-class</li>
      </ul>
    </div>
  </div>

  <h2 id="claims-and-service">Claims and Service</h2>

  <h3>Filing Claims</h3>
  <p>
    AXA Global Healthcare offers multiple claims submission options:
  </p>
  <ul>
    <li><strong>Online Portal:</strong> MyHealth member portal</li>
    <li><strong>Mobile App:</strong> Photo submission and tracking</li>
    <li><strong>Direct Billing:</strong> At network hospitals</li>
    <li><strong>Email:</strong> claims@axa-health.com</li>
  </ul>
  <p>
    Claims processing typically takes 7-14 business days. Direct billing at network facilities eliminates the need for claims in many cases.
  </p>

  <h3>Customer Service</h3>
  <p>
    AXA provides 24/7 customer support with assistance in multiple languages:
  </p>
  <ul>
    <li>English, French, Spanish, German, Italian</li>
    <li>Arabic and Mandarin for regional offices</li>
    <li>Phone, email, and online chat options</li>
    <li>Dedicated case managers for complex claims</li>
  </ul>

  <h3>Global Assistance</h3>
  <p>
    AXA's global assistance services include:
  </p>
  <ul>
    <li>Medical evacuation coordination</li>
    <li>Hospital admission assistance</li>
    <li>Second medical opinion services</li>
    <li>Travel assistance and security alerts</li>
  </ul>

  <h2 id="who-its-for">Who It's For</h2>
  <p>
    AXA Global Healthcare is a strong choice if you:
  </p>
  <ul>
    <li>Live in or are moving to Europe</li>
    <li>Need coverage for France or EU visa applications</li>
    <li>Prefer an EU-regulated insurer</li>
    <li>Want flexible modular coverage options</li>
    <li>Value a French/European insurance approach</li>
    <li>Travel frequently within Europe and Asia</li>
    <li>Work for a European company with international assignments</li>
  </ul>
  <p>
    It may not be ideal if you:
  </p>
  <ul>
    <li>Need extensive US coverage (Aetna or GeoBlue may be better)</li>
    <li>Prioritize best-in-class digital tools</li>
    <li>Have significant pre-existing conditions</li>
    <li>Want the fastest claims processing</li>
  </ul>

  <h2 id="alternatives">Alternatives to Consider</h2>
  <p>
    Depending on your needs, consider these alternatives:
  </p>
  <ul>
    <li><strong>Allianz Care:</strong> Similar EU-based option, often slightly cheaper, good high-deductible options. <a href="/providers/allianz-care">Read our review</a></li>
    <li><strong>BUPA Global:</strong> Premium option with better mental health coverage. <a href="/providers/bupa-global">Read our review</a></li>
    <li><strong>Cigna Global:</strong> Larger global network, strong customer service. <a href="/providers/cigna-global">Read our review</a></li>
    <li><strong>Aetna International:</strong> Better for US coverage needs. <a href="/providers/aetna-international">Read our review</a></li>
  </ul>

  <CTABox
    title="Ready to Compare?"
    description="See how AXA Global Healthcare compares for your situation."
    buttonText="Compare Plans"
    buttonHref="/best/expat-health-insurance"
    variant="highlight"
  />

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
    <p class="text-sm text-neutral-600">
      <strong>Disclaimer:</strong> This review is for informational purposes only. Plan details, pricing, and availability change. We are not affiliated with AXA Global Healthcare and are not insurance brokers. Verify all information directly with AXA before purchasing.
    </p>
  </div>
</PageShell>
