---
import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'quick-assessment', text: 'Quick Assessment', level: 2 },
  { id: 'plans-coverage', text: 'Plans and Coverage', level: 2 },
  { id: 'pricing-analysis', text: 'Pricing Analysis', level: 2 },
  { id: 'claims-experience', text: 'Claims Experience', level: 2 },
  { id: 'customer-service', text: 'Customer Service', level: 2 },
  { id: 'pros-cons', text: 'Pros and Cons', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-its-for', text: 'Who It\'s For', level: 2 },
  { id: 'how-it-compares', text: 'How It Compares', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'GeoBlue vs Aetna', href: '/compare/aetna-international-vs-geoblue' },
  { title: 'GeoBlue vs Cigna', href: '/compare/geoblue-vs-cigna-global' },
  { title: 'Best US Expat Insurance', href: '/best/us-expat-insurance' },
  { title: 'Insurance for Americans', href: '/insurance-for/americans' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
];

const planColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'essential', header: 'Voyager Essential' },
  { key: 'choice', header: 'Voyager Choice' },
  { key: 'excel', header: 'Voyager Excel' },
];

const planRows = [
  { feature: 'Annual Maximum', essential: '$1M', choice: '$2.5M', excel: '$5M' },
  { feature: 'Deductible Options', essential: '$250-$2,500', choice: '$0-$5,000', excel: '$0-$5,000' },
  { feature: 'Inpatient Hospital', essential: 'Full coverage', choice: 'Full coverage', excel: 'Full coverage' },
  { feature: 'Outpatient Care', essential: 'Limited', choice: 'Full coverage', excel: 'Full coverage' },
  { feature: 'Mental Health', essential: 'Crisis only', choice: 'Included', excel: 'Enhanced' },
  { feature: 'Maternity', essential: 'Not included', choice: 'Optional add-on', excel: 'Included' },
  { feature: 'Dental', essential: 'Not included', choice: 'Optional add-on', excel: 'Included' },
  { feature: 'Vision', essential: 'Not included', choice: 'Optional add-on', excel: 'Included' },
  { feature: 'Medical Evacuation', essential: 'Up to $500K', choice: 'Up to $500K', excel: 'Up to $500K' },
  { feature: 'US Network', essential: 'Full BCBS', choice: 'Full BCBS', excel: 'Full BCBS' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'essential', header: 'Voyager Essential' },
  { key: 'choice', header: 'Voyager Choice' },
  { key: 'excel', header: 'Voyager Excel' },
];

const pricingRows = [
  { profile: 'Age 30, $500 deductible', essential: '$200-240/mo', choice: '$280-340/mo', excel: '$380-460/mo' },
  { profile: 'Age 40, $1,000 deductible', essential: '$280-340/mo', choice: '$380-460/mo', excel: '$520-620/mo' },
  { profile: 'Age 50, $1,000 deductible', essential: '$380-460/mo', choice: '$520-620/mo', excel: '$700-840/mo' },
  { profile: 'Age 60, $2,500 deductible', essential: '$480-580/mo', choice: '$680-820/mo', excel: '$920-1,100/mo' },
  { profile: 'Family of 4 (adults 35/35)', essential: '$720-860/mo', choice: '$980-1,180/mo', excel: '$1,340-1,600/mo' },
];

const bcbsColumns = [
  { key: 'aspect', header: 'US Coverage Aspect' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'competitors', header: 'Most Competitors' },
];

const bcbsRows = [
  { aspect: 'US Network', geoblue: 'Full Blue Cross Blue Shield network', competitors: 'Limited or separate network' },
  { aspect: 'Provider Recognition', geoblue: '100M+ Americans use BCBS—familiar to providers', competitors: 'Less recognized internationally' },
  { aspect: 'Direct Billing', geoblue: 'Yes, at all BCBS hospitals', competitors: 'Often requires reimbursement' },
  { aspect: 'Pricing Model', geoblue: 'US included in base price', competitors: 'US coverage costs 40-60% extra' },
  { aspect: 'Network Size (US)', geoblue: '1.7M+ providers', competitors: 'Varies significantly' },
  { aspect: 'Repatriation Continuity', geoblue: 'Seamless transition to US care', competitors: 'May need new plan' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Claims Aspect' },
  { key: 'details', header: 'GeoBlue' },
];

const claimsRows = [
  { aspect: 'Submission Methods', details: 'Mobile app (photo), online portal, direct billing' },
  { aspect: 'Processing Time', details: '7-14 business days; faster for BCBS claims' },
  { aspect: 'Direct Billing', details: 'All BCBS US hospitals, 1.7M+ international providers' },
  { aspect: 'Pre-authorization', details: 'Required for planned hospitalization' },
  { aspect: 'Reimbursement', details: 'Direct deposit or check' },
  { aspect: 'US Claims', details: 'Process through existing BCBS infrastructure' },
];

const competitorColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'geoblue', header: 'GeoBlue' },
  { key: 'competitor', header: 'Key Difference' },
];

const competitorRows = [
  { aspect: 'US Network', geoblue: 'Full BCBS network', competitor: 'Best BCBS access available' },
  { aspect: 'Target Market', geoblue: 'US citizens only', competitor: 'Not available to non-Americans' },
  { aspect: 'Brand Familiarity', geoblue: 'High (100M+ use BCBS)', competitor: 'Trusted name for Americans' },
  { aspect: 'Pricing (with US)', geoblue: 'Competitive', competitor: 'Similar to Aetna with US included' },
  { aspect: 'International Network', geoblue: '1.7M+ providers', competitor: 'Comparable to Aetna/Cigna' },
  { aspect: 'Pre-existing Conditions', geoblue: '2-year lookback exclusion', competitor: 'Standard underwriting' },
];
---

<PageShell
  title="GeoBlue Review 2024: Comprehensive Analysis for US Expats"
  description="In-depth GeoBlue review covering plans, pricing, BCBS network access, and real scenarios. Find out if GeoBlue is right for American expats abroad."
  headline="GeoBlue International Health Insurance Review"
  subheadline="Blue Cross Blue Shield's international arm. The familiar US network, now worldwide—ideal for Americans who want healthcare continuity abroad. Here's our honest assessment."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a GeoBlue Quote"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/lifestyle/pre-existing-conditions.png"
>
  <h2 id="overview">Overview</h2>
  <p>
    GeoBlue is the international health insurance brand of Blue Cross Blue Shield, the largest health insurance network in the United States. For Americans moving abroad, GeoBlue offers something uniquely valuable: continuity with the Blue Cross network you already know.
  </p>
  <p>
    When you return to the US—whether for visits, emergencies, or eventual repatriation—your GeoBlue plan connects to the same Blue Cross network used by over 100 million Americans. No learning curve, no surprise networks, no coverage gaps.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Quick Facts</h3>
    <ul class="space-y-2 text-neutral-600">
      <li><strong>Parent Company:</strong> Blue Cross Blue Shield Association</li>
      <li><strong>Headquarters:</strong> King of Prussia, Pennsylvania, USA</li>
      <li><strong>Countries Covered:</strong> 190+</li>
      <li><strong>US Network:</strong> Full Blue Cross Blue Shield network (1.7M+ providers)</li>
      <li><strong>International Providers:</strong> 1.7 million+ contracted providers</li>
      <li><strong>Plan Types:</strong> Voyager (expat), Trekker (travel)</li>
      <li><strong>Eligibility:</strong> US citizens and permanent residents only</li>
      <li><strong>Medical Evacuation:</strong> Up to $500,000</li>
    </ul>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="text-blue-800 text-sm">
      <strong>The BCBS Advantage:</strong> GeoBlue isn't just another international insurer—it's BCBS for expats. When you return to the US, your doctors recognize BCBS, hospitals accept direct billing, and you benefit from BCBS-negotiated rates. For Americans planning to maintain US ties, this continuity is valuable.
    </p>
  </div>

  <CTABox
    title="Get a Personalized Quote"
    description="See what GeoBlue would cost for your specific situation."
    buttonText="Get Quote"
    buttonHref="/go/cigna-global"
    variant="highlight"
  />

  <h2 id="quick-assessment">Quick Assessment: Is GeoBlue Right for You?</h2>
  <p>
    Before diving into details, here's a quick framework to assess whether GeoBlue fits your needs.
  </p>

  <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-green-900 mb-3">GeoBlue is likely a great fit if you:</h3>
    <ul class="space-y-2 text-green-800">
      <li>Are a US citizen or permanent resident</li>
      <li>Want Blue Cross Blue Shield network continuity</li>
      <li>Return to the US frequently for family or business</li>
      <li>Have family or doctors in the US you want to keep seeing</li>
      <li>Plan to eventually repatriate to the US</li>
      <li>Value brand familiarity and trust</li>
      <li>Work for a US company with international assignment</li>
    </ul>
  </div>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-amber-900 mb-3">Consider alternatives if you:</h3>
    <ul class="space-y-2 text-amber-800">
      <li>Are not a US citizen or permanent resident (you can't purchase)</li>
      <li>Don't need US coverage (other plans may be cheaper)</li>
      <li>Have significant pre-existing conditions (2-year lookback)</li>
      <li>Want the absolute lowest premiums available</li>
      <li>Are moving abroad permanently with no US ties</li>
      <li>Need extensive mental health coverage (BUPA better)</li>
    </ul>
  </div>

  <h2 id="plans-coverage">Plans and Coverage</h2>
  <p>
    GeoBlue offers two product lines: Voyager plans for long-term expats (6+ months) and Trekker plans for shorter trips. Most expats will want a Voyager plan.
  </p>

  <h3>Voyager Plans Comparison</h3>
  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={planColumns} rows={planRows} />
  </div>

  <h3>Voyager Essential</h3>
  <p>
    Budget option focused on major medical events. $1 million annual maximum with limited outpatient coverage. Mental health is crisis-only. Best for healthy individuals who want catastrophic protection while paying out-of-pocket for routine care.
  </p>

  <h3>Voyager Choice</h3>
  <p>
    The sweet spot for most US expats. $2.5 million annual maximum with full outpatient coverage. Mental health, prescriptions, and telehealth included. Maternity, dental, and vision available as add-ons. This is GeoBlue's most popular plan.
  </p>

  <h3>Voyager Excel</h3>
  <p>
    Premium coverage with $5 million annual maximum. Everything in Choice plus maternity, dental, and vision included by default. Enhanced mental health coverage and higher per-condition limits. For those who want comprehensive coverage without add-on complexity.
  </p>

  <h3>The Blue Cross Blue Shield Advantage</h3>
  <p>
    GeoBlue's connection to Blue Cross Blue Shield provides unique benefits for US expats:
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={bcbsColumns} rows={bcbsRows} />
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="text-blue-800 text-sm">
      <strong>Real Impact:</strong> When you walk into a US hospital with a GeoBlue card, they see "Blue Cross." No explaining what international insurance is, no concerns about payment, no reimbursement hassle. The card works like the BCBS card 100 million Americans carry. That recognition has real value.
    </p>
  </div>

  <h3>International Coverage</h3>
  <p>
    Outside the US, GeoBlue maintains contracts with 1.7 million+ providers in 190 countries:
  </p>
  <ul>
    <li>Direct billing at major international hospitals</li>
    <li>Mobile app shows nearby providers with real-time availability</li>
    <li>24/7 assistance for provider referrals</li>
    <li>Medical translation services</li>
  </ul>

  <h3>Trekker Plans (Travel Medical)</h3>
  <p>
    Trekker plans are travel medical insurance for trips lasting 5 days to 1 year. They're designed for travelers, not long-term expats:
  </p>
  <ul>
    <li>Lower premiums than Voyager</li>
    <li>Coverage for emergencies and unexpected illness</li>
    <li>Not designed for ongoing healthcare needs</li>
    <li>Good for gap coverage between plans</li>
  </ul>

  <h3>Pre-existing Conditions</h3>
  <p>
    GeoBlue uses a 2-year lookback period for pre-existing conditions:
  </p>
  <ul>
    <li>Conditions with symptoms, treatment, or advice in the past 2 years may be excluded</li>
    <li>Standard underwriting approach—not as flexible as Allianz moratorium</li>
    <li>Exclusions are determined at application</li>
    <li>Some conditions may be covered with limitations or waiting periods</li>
  </ul>

  <h2 id="pricing-analysis">Pricing Analysis</h2>
  <p>
    GeoBlue pricing varies by age, plan tier, and deductible. US coverage is included in all plans (not an add-on), which affects baseline pricing but provides value for those who need it.
  </p>

  <h3>Estimated Monthly Premiums (Including US Coverage)</h3>
  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={pricingColumns} rows={pricingRows} />
  </div>

  <p>
    <strong>Note:</strong> These are estimates including US coverage. Since US is included by default, there's no "excluding US" option to reduce premiums.
  </p>

  <h3>Deductible Impact</h3>
  <p>
    Higher deductibles reduce premiums significantly:
  </p>
  <ul>
    <li><strong>$0 deductible:</strong> Base premium (Choice/Excel only)</li>
    <li><strong>$250 deductible:</strong> ~5-10% savings</li>
    <li><strong>$500 deductible:</strong> ~10-15% savings</li>
    <li><strong>$1,000 deductible:</strong> ~15-20% savings</li>
    <li><strong>$2,500 deductible:</strong> ~20-25% savings</li>
    <li><strong>$5,000 deductible:</strong> ~25-30% savings (Choice/Excel only)</li>
  </ul>

  <h3>5-Year Cost Projection</h3>
  <p>
    For a 40-year-old on Voyager Choice with $1,000 deductible:
  </p>
  <ul>
    <li><strong>Year 1:</strong> ~$5,040 ($420/month)</li>
    <li><strong>Year 2:</strong> ~$5,290 (5% increase)</li>
    <li><strong>Year 3:</strong> ~$5,555 (age + inflation)</li>
    <li><strong>Year 4:</strong> ~$5,830</li>
    <li><strong>Year 5:</strong> ~$6,120</li>
    <li><strong>5-Year Total:</strong> ~$27,835</li>
  </ul>
  <p>
    Budget for 5-8% annual increases due to age and medical inflation.
  </p>

  <CTABox
    title="See Your Actual Price"
    description="Get a quote based on your age, plan choice, and deductible preference."
    buttonText="Get a Quote"
    buttonHref="/go/cigna-global"
  />

  <h2 id="claims-experience">Claims Experience</h2>
  <p>
    GeoBlue's claims process benefits from BCBS infrastructure, particularly for US-based claims which process through existing systems.
  </p>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={claimsColumns} rows={claimsRows} />
  </div>

  <h3>Direct Billing Network</h3>
  <p>
    GeoBlue's direct billing is strongest in the US:
  </p>
  <ul>
    <li><strong>US:</strong> All BCBS network hospitals accept direct billing</li>
    <li><strong>International:</strong> 1.7M+ contracted providers with many offering direct billing</li>
    <li><strong>Process:</strong> Show your GeoBlue card, hospital bills GeoBlue directly</li>
    <li><strong>Benefit:</strong> No large out-of-pocket while waiting for reimbursement</li>
  </ul>

  <h3>Claims Processing Timeline</h3>
  <ul>
    <li><strong>US BCBS claims:</strong> 7-10 business days (uses existing infrastructure)</li>
    <li><strong>International claims:</strong> 10-14 business days</li>
    <li><strong>Complex claims:</strong> Up to 30 days</li>
    <li><strong>Reimbursement:</strong> Direct deposit or check</li>
  </ul>

  <h3>Mobile App Features</h3>
  <p>
    The GeoBlue mobile app is well-regarded:
  </p>
  <ul>
    <li>Nearby provider search with maps and availability</li>
    <li>Claims submission with photo capture</li>
    <li>Digital ID cards</li>
    <li>Coverage details and benefits summary</li>
    <li>Emergency contact one-touch calling</li>
    <li>Real-time claims tracking</li>
  </ul>

  <h2 id="customer-service">Customer Service</h2>
  <p>
    GeoBlue provides 24/7 customer support with multilingual assistance and access to BCBS resources.
  </p>

  <h3>Support Channels</h3>
  <ul>
    <li><strong>Phone:</strong> 24/7 hotline with multilingual support</li>
    <li><strong>Email:</strong> Customer service inquiries</li>
    <li><strong>Mobile App:</strong> In-app support and chat</li>
    <li><strong>Online Portal:</strong> Full policy management</li>
  </ul>

  <h3>Services Included</h3>
  <ul>
    <li>Provider referrals and appointment scheduling</li>
    <li>Pre-authorization assistance</li>
    <li>Claims status inquiries</li>
    <li>Emergency coordination</li>
    <li>Medical translation services</li>
    <li>Telehealth consultations</li>
  </ul>

  <h3>Medical Evacuation</h3>
  <p>
    GeoBlue provides up to $500,000 for medical evacuation—one of the higher limits in the industry:
  </p>
  <ul>
    <li>Emergency evacuation to nearest appropriate facility</li>
    <li>Medical repatriation to the US when stable</li>
    <li>Transportation of family member to bedside</li>
    <li>Return of remains</li>
  </ul>

  <h2 id="pros-cons">Pros and Cons</h2>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Pros</h3>
      <ul class="space-y-2 text-green-800">
        <li>Full Blue Cross Blue Shield US network access</li>
        <li>US coverage included (not a costly add-on)</li>
        <li>Familiar network for Americans (100M+ users)</li>
        <li>Strong mobile app with provider finder</li>
        <li>High evacuation coverage ($500K)</li>
        <li>Telehealth included</li>
        <li>Direct billing at BCBS hospitals</li>
        <li>1.7M+ international providers</li>
        <li>Good for repatriation planning</li>
        <li>Strong brand recognition with US providers</li>
      </ul>
    </div>
    <div class="bg-red-50 border border-red-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-red-900 mb-3">Cons</h3>
      <ul class="space-y-2 text-red-800">
        <li>Only available to US citizens/residents</li>
        <li>Higher premiums than some competitors</li>
        <li>Pre-existing conditions excluded (2-year lookback)</li>
        <li>Maternity requires upgrade or add-on</li>
        <li>Mental health limited on Essential</li>
        <li>Must maintain US address/ties</li>
        <li>No "excluding US" option to save money</li>
        <li>Not competitive for non-US expats (can't buy)</li>
      </ul>
    </div>
  </div>

  <h2 id="scenarios">Real-World Scenarios</h2>
  <p>
    Here's how GeoBlue performs in common US expat situations:
  </p>

  <div class="space-y-6 my-8">
    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 1: Annual Specialist Visit in the US</h3>
      <p class="text-neutral-600 mb-3">Expat in Costa Rica returns to the US annually for cardiology checkup with long-time doctor in Miami.</p>
      <p class="text-green-700 font-medium">Outcome: Doctor accepts GeoBlue immediately—recognizes Blue Cross. Direct billing, no reimbursement hassle. Total out-of-pocket: $50 copay. Expat maintains relationship with trusted specialist seamlessly.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 2: Emergency Surgery Abroad</h3>
      <p class="text-neutral-600 mb-3">55-year-old in Portugal needs emergency appendectomy. Taken to local hospital.</p>
      <p class="text-green-700 font-medium">Outcome: GeoBlue coordinates with hospital for direct billing. No out-of-pocket for €12,000 surgery beyond deductible. 24/7 assistance arranges follow-up care. International network functions well for emergencies.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 3: Pre-existing Condition Application</h3>
      <p class="text-neutral-600 mb-3">48-year-old with Type 2 diabetes (diagnosed 3 years ago) applies for Voyager Choice.</p>
      <p class="text-amber-700 font-medium">Outcome: Diabetes excluded under 2-year lookback rule. All diabetes-related care (insulin, monitoring, complications) not covered. Member must pay for diabetes management out-of-pocket or through separate coverage. Other conditions covered normally.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 4: Repatriation for Cancer Treatment</h3>
      <p class="text-neutral-600 mb-3">Expat in Mexico diagnosed with cancer wants treatment at MD Anderson in Houston.</p>
      <p class="text-green-700 font-medium">Outcome: GeoBlue covers treatment at MD Anderson through BCBS network. Direct billing, negotiated rates, no international coordination hassle. Seamless transition between countries for care. Total covered: $180,000+ in treatment.</p>
    </div>

    <div class="border border-neutral-200 rounded-lg p-6">
      <h3 class="font-semibold text-neutral-900 mb-2">Scenario 5: Comparison Shopping—GeoBlue vs Aetna</h3>
      <p class="text-neutral-600 mb-3">American expat comparing GeoBlue Voyager Choice ($400/month) vs Aetna Pioneer Prime ($380/month) for living in Spain with frequent US visits.</p>
      <p class="text-amber-700 font-medium">Outcome: Similar pricing and coverage. GeoBlue offers BCBS network familiarity; Aetna offers Aetna domestic network. Both include US coverage. Choice comes down to network preference and which brand you trust. Functionally equivalent for most expats.</p>
    </div>
  </div>

  <h2 id="who-its-for">Who It's For</h2>

  <h3>Ideal GeoBlue Members</h3>
  <ul>
    <li><strong>US citizens abroad:</strong> The BCBS network is the primary value proposition</li>
    <li><strong>Frequent US visitors:</strong> Those who return to the US regularly for family or healthcare</li>
    <li><strong>Future repatriates:</strong> Planning to move back to the US eventually</li>
    <li><strong>US medical continuity:</strong> Want to keep US doctors and specialists</li>
    <li><strong>Corporate assignees:</strong> Working for US companies abroad</li>
    <li><strong>Brand-conscious Americans:</strong> Trust BCBS and want familiar coverage</li>
  </ul>

  <h3>Better Alternatives Exist If You:</h3>
  <ul>
    <li><strong>Are not American:</strong> You can't purchase GeoBlue</li>
    <li><strong>Don't need US coverage:</strong> Allianz or IMG may be cheaper</li>
    <li><strong>Have pre-existing conditions:</strong> Allianz moratorium may be more favorable</li>
    <li><strong>Want lowest price:</strong> IMG or SafetyWing offer budget options</li>
    <li><strong>Need mental health parity:</strong> BUPA offers unlimited coverage</li>
    <li><strong>Want Aetna network:</strong> Aetna International may be better</li>
  </ul>

  <h2 id="how-it-compares">How It Compares</h2>

  <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
    <ComparisonTable columns={competitorColumns} rows={competitorRows} />
  </div>

  <h3>GeoBlue vs Aetna International</h3>
  <p>
    Both target US expats with integrated US networks. GeoBlue offers BCBS access; Aetna offers Aetna domestic network. Similar pricing and coverage. Choose based on which network your preferred US providers accept.
  </p>
  <p><a href="/compare/aetna-international-vs-geoblue">See full GeoBlue vs Aetna comparison →</a></p>

  <h3>GeoBlue vs Cigna Global</h3>
  <p>
    Cigna has a larger international network and is available to non-Americans. GeoBlue has better US network integration (BCBS). Choose Cigna for international focus; GeoBlue for US focus.
  </p>
  <p><a href="/compare/geoblue-vs-cigna-global">See full GeoBlue vs Cigna comparison →</a></p>

  <h3>GeoBlue vs Allianz Care</h3>
  <p>
    Allianz is available to anyone (not US-only) and offers moratorium underwriting. GeoBlue offers BCBS network. Choose Allianz for pre-existing conditions or if you're not American; GeoBlue for BCBS access.
  </p>

  <h2 id="faq">Frequently Asked Questions</h2>

  <div class="space-y-6 my-8">
    <div class="border-b border-neutral-200 pb-4">
      <h3 class="font-semibold text-neutral-900 mb-2">Can non-US citizens purchase GeoBlue?</h3>
      <p class="text-neutral-600">No. GeoBlue is exclusively for US citizens and permanent residents. If you're not American, you cannot purchase GeoBlue plans. Consider Cigna Global, Allianz Care, or other international options instead.</p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="font-semibold text-neutral-900 mb-2">How does GeoBlue's BCBS network compare to Aetna's network?</h3>
      <p class="text-neutral-600">Both are large US networks. BCBS is the largest health insurance network in the US (100M+ members), while Aetna has 1.7M+ providers. Both offer comprehensive US coverage. The difference is which network your preferred doctors accept. Many accept both.</p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="font-semibold text-neutral-900 mb-2">Can I exclude US coverage to save money?</h3>
      <p class="text-neutral-600">No. Unlike Cigna or Allianz, GeoBlue includes US coverage in all plans by default. There's no "excluding US" option. If you don't need US coverage, Allianz or IMG may offer better value.</p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="font-semibold text-neutral-900 mb-2">What's the difference between Voyager and Trekker plans?</h3>
      <p class="text-neutral-600">Voyager plans are comprehensive health insurance for expats living abroad 6+ months. Trekker plans are travel medical insurance for trips lasting 5 days to 1 year. Most long-term expats need Voyager; Trekker is for shorter trips or gap coverage.</p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="font-semibold text-neutral-900 mb-2">How does GeoBlue handle pre-existing conditions?</h3>
      <p class="text-neutral-600">GeoBlue uses a 2-year lookback. Any condition you've had symptoms, treatment, or advice for in the past 2 years may be excluded. This is standard underwriting—not as favorable as Allianz's moratorium option.</p>
    </div>

    <div class="border-b border-neutral-200 pb-4">
      <h3 class="font-semibold text-neutral-900 mb-2">Do I need to maintain a US address?</h3>
      <p class="text-neutral-600">GeoBlue is designed for US citizens maintaining ties to the US. While you don't need to live in the US, you should have US citizenship or permanent residency and some connection to the US (address, bank account, etc.).</p>
    </div>
  </div>

  <h2 id="verdict">Our Verdict</h2>
  <p>
    <strong>GeoBlue is the best choice for US expats who want seamless Blue Cross Blue Shield network access.</strong> The BCBS connection provides real value—brand recognition at US hospitals, direct billing, negotiated rates, and continuity with the network 100 million Americans use.
  </p>
  <p>
    However, GeoBlue is only for Americans, and the mandatory US coverage means you can't reduce premiums by excluding it. If you're not American, don't need US coverage, or have pre-existing conditions, other insurers offer better value.
  </p>
  <p>
    <strong>Bottom line:</strong> For US citizens maintaining ties to America, GeoBlue offers unmatched BCBS integration. For everyone else, shop around.
  </p>

