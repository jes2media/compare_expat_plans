import PageShell from '../../components/PageShell.astro';
import CTABox from '../../components/CTABox.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const tocItems = [
  { id: 'overview', text: 'Overview', level: 2 },
  { id: 'quick-assessment', text: 'Quick Assessment', level: 2 },
  { id: 'plans-coverage', text: 'Plans and Coverage', level: 2 },
  { id: 'pricing-analysis', text: 'Pricing Analysis', level: 2 },
  { id: 'claims-experience', text: 'Claims Experience', level: 2 },
  { id: 'customer-service', text: 'Customer Service', level: 2 },
  { id: 'pros-cons', text: 'Pros and Cons', level: 2 },
  { id: 'scenarios', text: 'Real-World Scenarios', level: 2 },
  { id: 'who-its-for', text: 'Who It\'s For', level: 2 },
  { id: 'how-it-compares', text: 'How It Compares', level: 2 },
  { id: 'faq', text: 'FAQ', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const relatedLinks = [
  { title: 'Cigna vs Allianz', href: '/compare/cigna-global-vs-allianz-care' },
  { title: 'Cigna vs BUPA', href: '/compare/bupa-global-vs-cigna-global' },
  { title: 'Cigna vs Aetna', href: '/compare/cigna-global-vs-aetna-international' },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
  { title: 'Best for Families', href: '/best/family-expat-insurance' },
];

const planColumns = [
  { key: 'feature', header: 'Feature' },
  { key: 'silver', header: 'Silver' },
  { key: 'gold', header: 'Gold' },
  { key: 'platinum', header: 'Platinum' },
];

const planRows = [
  { feature: 'Inpatient Hospital', silver: 'Full coverage', gold: 'Full coverage', platinum: 'Full coverage' },
  { feature: 'Day Patient', silver: 'Full coverage', gold: 'Full coverage', platinum: 'Full coverage' },
  { feature: 'Outpatient Care', silver: 'Not included', gold: 'Full coverage', platinum: 'Full coverage' },
  { feature: 'Mental Health', silver: 'Inpatient only', gold: 'In + Outpatient', platinum: 'Enhanced coverage' },
  { feature: 'Maternity', silver: 'Optional add-on', gold: 'Optional add-on', platinum: 'Optional add-on' },
  { feature: 'Dental', silver: 'Optional add-on', gold: 'Optional add-on', platinum: 'Optional add-on' },
  { feature: 'Vision', silver: 'Optional add-on', gold: 'Optional add-on', platinum: 'Optional add-on' },
  { feature: 'Wellness', silver: 'Not included', gold: 'Basic', platinum: 'Comprehensive' },
  { feature: 'Annual Maximum', silver: 'Unlimited', gold: 'Unlimited', platinum: 'Unlimited' },
  { feature: 'Deductible Options', silver: '$0–$10,000', gold: '$0–$10,000', platinum: '$0–$5,000' },
];

const pricingColumns = [
  { key: 'profile', header: 'Profile' },
  { key: 'silver', header: 'Silver' },
  { key: 'gold', header: 'Gold' },
  { key: 'platinum', header: 'Platinum' },
];

const pricingRows = [
  { profile: 'Age 30, $0 deductible', silver: '$90–120/mo', gold: '$140–180/mo', platinum: '$200–260/mo' },
  { profile: 'Age 30, $2,500 deductible', silver: '$60–80/mo', gold: '$100–130/mo', platinum: '$150–190/mo' },
  { profile: 'Age 40, $0 deductible', silver: '$130–170/mo', gold: '$190–250/mo', platinum: '$280–350/mo' },
  { profile: 'Age 40, $2,500 deductible', silver: '$90–120/mo', gold: '$140–180/mo', platinum: '$210–260/mo' },
  { profile: 'Age 50, $0 deductible', silver: '$200–260/mo', gold: '$280–360/mo', platinum: '$400–500/mo' },
  { profile: 'Age 50, $2,500 deductible', silver: '$150–190/mo', gold: '$210–270/mo', platinum: '$300–380/mo' },
];

const usColumns = [
  { key: 'aspect', header: 'US Coverage Aspect' },
  { key: 'withUS', header: 'With US Coverage' },
  { key: 'withoutUS', header: 'Without US Coverage' },
];

const usRows = [
  { aspect: 'Premium Impact', withUS: '+40–60% higher', withoutUS: 'Base rate' },
  { aspect: 'US Network Access', withUS: 'Full Cigna US network', withoutUS: 'Emergency only' },
  { aspect: 'US Prescriptions', withUS: 'Covered at US pharmacies', withoutUS: 'Not covered' },
  { aspect: 'US Specialists', withUS: 'In-network access', withoutUS: 'Not covered' },
  { aspect: 'Best For', withUS: 'US expats returning often', withoutUS: 'Non-US expats' },
];

const claimsColumns = [
  { key: 'aspect', header: 'Claims Aspect' },
  { key: 'detail', header: 'Cigna Global' },
];

const claimsRows = [
  { aspect: 'Direct Billing Network', detail: '1.5M+ providers globally' },
  { aspect: 'Reimbursement Time', detail: '5–10 business days typical' },
  { aspect: 'Claims Submission', detail: 'Online portal, app, email, mail' },
  { aspect: 'Pre-Authorization', detail: 'Required for planned procedures' },
  { aspect: 'Emergency Protocol', detail: '24/7 emergency line, hospital coordination' },
  { aspect: 'Maximum Claim', detail: 'Unlimited (no per-claim cap)' },
];

const compareColumns = [
  { key: 'aspect', header: 'Aspect' },
  { key: 'cigna', header: 'Cigna Global' },
  { key: 'competitor', header: 'Key Competitors' },
];

const compareRows = [
  { aspect: 'Network Size', cigna: '1.5M+ providers', competitor: 'Allianz: 2M+ | BUPA: 1.7M+' },
  { aspect: 'Mental Health', cigna: 'Good (Gold/Platinum)', competitor: 'BUPA: Best | Allianz: Good' },
  { aspect: 'Maternity', cigna: 'Add-on, 10-mo wait', competitor: 'BUPA: $75K | Allianz: €30K' },
  { aspect: 'Pre-Existing', cigna: 'Moratorium', competitor: 'BUPA: Day-one possible' },
  { aspect: 'Pricing', cigna: 'Mid-range', competitor: 'IMG: Budget | BUPA: Premium' },
  { aspect: 'Customer Service', cigna: '24/7 multilingual', competitor: 'All major providers similar' },
];
---

<PageShell
  title="Cigna Global Review 2024: Comprehensive Analysis for Expats"
  description="In-depth Cigna Global review covering plans, pricing, claims experience, and real scenarios. Find out if Cigna is right for your expat health insurance needs."
  headline="Cigna Global International Health Insurance Review"
  subheadline="One of the most recognized names in expat insurance. But does recognition translate to value? Here's our honest assessment."
  tocItems={tocItems}
  relatedLinks={relatedLinks}
  ctaButtonText="Get a Cigna Global Quote"
  ctaButtonHref="/best/expat-health-insurance"
  heroImage="/images/lifestyle/pre-existing-conditions.png"
>
  <h2 id="overview">Overview</h2>
  <p>
    Cigna Global is the international health insurance arm of Cigna Corporation, a Fortune 500 company with over 180 years of history. They serve expats, globally mobile employees, and international organizations in 200+ countries, backed by a network of 1.5 million+ healthcare providers.
  </p>
  <p>
    Their reputation is built on comprehensive coverage, strong customer service, and a seamless experience for corporate assignees and families. However, that reputation comes with mid-to-premium pricing that may not suit budget-conscious expats.
  </p>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Company Snapshot</h3>
    <div class="grid md:grid-cols-2 gap-4">
      <ul class="space-y-2 text-neutral-600">
        <li><strong>Parent Company:</strong> Cigna Corporation (NYSE: CI)</li>
        <li><strong>Founded:</strong> 1982 (Cigna), 1792 (predecessor)</li>
        <li><strong>Headquarters:</strong> Bloomfield, CT, USA</li>
        <li><strong>Revenue:</strong> $180B+ (2023)</li>
      </ul>
      <ul class="space-y-2 text-neutral-600">
        <li><strong>Countries Covered:</strong> 200+</li>
        <li><strong>Network Providers:</strong> 1.5 million+</li>
        <li><strong>Plan Tiers:</strong> Silver, Gold, Platinum</li>
        <li><strong>AM Best Rating:</strong> A (Excellent)</li>
      </ul>
    </div>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
    <p class="font-semibold text-blue-800 mb-2">Financial Stability</p>
    <p class="text-blue-900 text-sm mb-0">
      Cigna Corporation is a Fortune 15 company with $180+ billion in annual revenue and an AM Best rating of A (Excellent). When you buy Cigna Global insurance, you're backed by one of the largest health services companies in the world. Claims will be paid.
    </p>
  </div>

  <h2 id="quick-assessment">Quick Assessment: Is Cigna Global Right for You?</h2>
  <p>
    Before diving into details, here's a quick framework to determine if Cigna Global fits your needs.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Cigna Global Is Strong For:</h3>
      <ul class="space-y-2 text-neutral-700 mb-0">
        <li>✓ Corporate assignees and their families</li>
        <li>✓ Those who value large provider networks</li>
        <li>✓ Expats wanting direct billing over reimbursement</li>
        <li>✓ Families needing comprehensive coverage</li>
        <li>✓ Those who prioritize customer service quality</li>
        <li>✓ US expats who need US coverage options</li>
        <li>✓ Long-term expats seeking stability</li>
      </ul>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Consider Alternatives If:</h3>
      <ul class="space-y-2 text-neutral-700 mb-0">
        <li>✗ Budget is your primary constraint</li>
        <li>✗ You need day-one pre-existing coverage</li>
        <li>✗ You want maternity without waiting periods</li>
        <li>✗ You're looking for the absolute lowest premiums</li>
        <li>✗ You prefer high-deductible catastrophic plans</li>
        <li>✗ You're a digital nomad who moves frequently</li>
        <li>✗ Mental health parity is essential (BUPA is better)</li>
      </ul>
    </div>
  </div>

  <CTABox
    title="Get Your Personalized Quote"
    description="See exactly what Cigna Global would cost for your age, location, and coverage needs."
    buttonText="Get a Quote"
    buttonHref="/best/expat-health-insurance"
    variant="highlight"
  />

  <h2 id="plans-coverage">Plans and Coverage</h2>
  <p>
    Cigna Global offers three plan tiers—Silver, Gold, and Platinum—each building on the previous with additional benefits. All plans include unlimited annual maximum coverage, which is increasingly rare in international health insurance.
  </p>

  <ComparisonTable columns={planColumns} rows={planRows} />

  <h3>Silver Plan: Major Medical</h3>
  <p>
    The Silver plan covers inpatient and day-patient treatment only. It's designed for those who want catastrophic coverage and are comfortable paying out-of-pocket for routine outpatient care.
  </p>
  <ul>
    <li><strong>Best for:</strong> Healthy individuals who rarely need outpatient care</li>
    <li><strong>Includes:</strong> Hospital stays, surgery, cancer treatment, emergency care, medical evacuation</li>
    <li><strong>Excludes:</strong> Doctor visits, prescriptions, lab work (unless admitted)</li>
    <li><strong>Deductible options:</strong> $0, $250, $500, $1,000, $2,500, $5,000, $10,000</li>
  </ul>

  <h3>Gold Plan: Comprehensive Coverage</h3>
  <p>
    The Gold plan adds full outpatient coverage to Silver, making it Cigna's most popular tier. This is what most expats think of as "full health insurance."
  </p>
  <ul>
    <li><strong>Best for:</strong> Expats who want comprehensive coverage without premium pricing</li>
    <li><strong>Adds to Silver:</strong> Doctor visits, specialist consultations, prescriptions, lab work, imaging, physical therapy</li>
    <li><strong>Mental health:</strong> Both inpatient and outpatient included</li>
    <li><strong>Deductible options:</strong> $0, $250, $500, $1,000, $2,500, $5,000, $10,000</li>
  </ul>

  <h3>Platinum Plan: Premium Benefits</h3>
  <p>
    Platinum adds enhanced benefits including better wellness coverage, higher limits on certain services, and additional perks. It's designed for those who want the best coverage Cigna offers.
  </p>
  <ul>
    <li><strong>Best for:</strong> Executives, families, or anyone wanting top-tier coverage</li>
    <li><strong>Adds to Gold:</strong> Enhanced wellness programs, higher therapy limits, additional preventive care</li>
    <li><strong>Deductible options:</strong> $0, $250, $500, $1,000, $2,500, $5,000 (no $10K option)</li>
  </ul>

  <h3>Optional Add-Ons</h3>
  <p>
    All Cigna Global plans can be customized with these add-ons:
  </p>
  <ul>
    <li><strong>Maternity:</strong> Pregnancy and childbirth coverage. 10-month waiting period. Costs vary by age and region—expect $50–150/month additional.</li>
    <li><strong>Dental:</strong> Preventive (cleanings, exams) and major (fillings, crowns, root canals). Usually 6-month waiting period for major work.</li>
    <li><strong>Vision:</strong> Eye exams, glasses, contacts. Typically $10–30/month additional.</li>
    <li><strong>International Health & Wellbeing:</strong> Wellness programs, health screenings, gym discounts.</li>
    <li><strong>US Coverage:</strong> Access to Cigna's US network. Significant premium increase (40–60%).</li>
  </ul>

  <div class="bg-amber-50 border border-amber-300 rounded-lg p-4 my-6">
    <p class="font-semibold text-amber-800 mb-2">Maternity Waiting Period</p>
    <p class="text-amber-900 text-sm mb-0">
      Cigna Global's 10-month maternity waiting period means you need to have the add-on in place before conception to ensure coverage for delivery. If you're planning a family, add maternity coverage early—you can't add it once pregnant.
    </p>
  </div>

  <h2 id="pricing-analysis">Pricing Analysis</h2>
  <p>
    Cigna Global sits in the mid-to-premium range of international health insurance. They're not the cheapest option, but they're not the most expensive either. Here's what to expect.
  </p>

  <ComparisonTable columns={pricingColumns} rows={pricingRows} />

  <p class="text-sm text-neutral-600 italic">*Prices exclude US coverage. Estimates based on worldwide excluding US coverage area. Actual quotes may vary.</p>

  <h3>What Affects Your Premium</h3>
  <ul>
    <li><strong>Age:</strong> Premiums increase with age. Expect roughly 50% increase per decade after 30.</li>
    <li><strong>Plan tier:</strong> Gold is typically 40–50% more than Silver. Platinum is 40–50% more than Gold.</li>
    <li><strong>Deductible:</strong> Choosing $2,500 over $0 deductible can reduce premiums by 25–35%.</li>
    <li><strong>Coverage area:</strong> Adding US coverage increases premiums by 40–60%.</li>
    <li><strong>Add-ons:</strong> Maternity, dental, and vision each add $30–150/month depending on specifics.</li>
  </ul>

  <h3>US Coverage: The Big Decision</h3>
  <p>
    For US citizens or expats who return to the US frequently, the US coverage decision significantly impacts both cost and value.
  </p>

  <ComparisonTable columns={usColumns} rows={usRows} />

  <p>
    <strong>Our take:</strong> If you're a US citizen returning home more than once a year, US coverage is usually worth the premium increase. If you rarely visit the US, skip it and save 40–60%.
  </p>

  <h3>How to Reduce Costs</h3>
  <ul>
    <li><strong>Choose a higher deductible:</strong> $2,500 or $5,000 deductible can save $50–100/month</li>
    <li><strong>Skip US coverage:</strong> If you don't need it, save 40–60% on premiums</li>
    <li><strong>Start with Silver:</strong> Add outpatient only if you'll actually use it</li>
    <li><strong>Skip optional add-ons:</strong> Dental and vision can be paid out-of-pocket for less</li>
    <li><strong>Pay annually:</strong> Some plans offer 5–10% discount for annual payment</li>
  </ul>

  <CTABox
    title="See Your Actual Price"
    description="Get a personalized quote based on your age, location, and coverage needs."
    buttonText="Get a Quote"
    buttonHref="/best/expat-health-insurance"
  />

  <h2 id="claims-experience">Claims Experience</h2>
  <p>
    Cigna Global's claims process benefits from their massive network and established infrastructure. Here's how it works in practice.
  </p>

  <ComparisonTable columns={claimsColumns} rows={claimsRows} />

  <h3>Direct Billing vs Reimbursement</h3>
  <p>
    Cigna Global emphasizes direct billing—meaning the hospital bills Cigna directly and you don't pay upfront (beyond your deductible/copay).
  </p>
  <ul>
    <li><strong>Network hospitals:</strong> Direct billing typically available. Show your Cigna card, Cigna pays the hospital.</li>
    <li><strong>Non-network providers:</strong> Pay upfront, submit claim for reimbursement.</li>
    <li><strong>Network size:</strong> 1.5M+ providers globally, with strongest coverage in major cities and expat hubs.</li>
  </ul>

  <h3>Claims Process</h3>
  <ol>
    <li><strong>For planned procedures:</strong> Call Cigna for pre-authorization. They'll confirm coverage and often arrange direct billing.</li>
    <li><strong>For emergencies:</strong> Get treatment, then call Cigna's 24/7 line. They'll coordinate with the hospital.</li>
    <li><strong>For reimbursement:</strong> Submit claims via online portal, app, or email. Include itemized bills and receipts.</li>
    <li><strong>Processing time:</strong> Typically 5–10 business days for straightforward claims.</li>
  </ol>

  <h3>What Users Report</h3>
  <p>
    Based on customer reviews and community feedback:
  </p>
  <ul>
    <li><strong>Positive:</strong> Direct billing works well at network hospitals, pre-authorization is straightforward, major claims handled smoothly</li>
    <li><strong>Mixed:</strong> Reimbursement can take longer than quoted, some back-and-forth on documentation</li>
    <li><strong>Negative:</strong> Occasional delays during peak periods, some denials require appeals</li>
  </ul>

  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 my-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-3">Claims Pro Tip</h3>
    <p class="text-neutral-600 mb-0">
      For any procedure over $1,000, call Cigna for pre-authorization before treatment. This confirms coverage, arranges direct billing when possible, and prevents surprise denials. The 24/7 line is there for this—use it.
    </p>
  </div>

  <h2 id="customer-service">Customer Service</h2>
  <p>
    Customer service is one of Cigna Global's strengths. They've invested in support infrastructure that most expats find responsive and helpful.
  </p>

  <h3>Support Channels</h3>
  <ul>
    <li><strong>24/7 phone line:</strong> Available in multiple languages for emergencies and general inquiries</li>
    <li><strong>Online portal:</strong> Submit claims, view benefits, find providers, download ID cards</li>
    <li><strong>Mobile app:</strong> Same functionality as portal, optimized for mobile</li>
    <li><strong>Email:</strong> For non-urgent inquiries, typically 24–48 hour response</li>
    <li><strong>Dedicated case managers:</strong> Assigned for complex medical situations or ongoing treatment</li>
  </ul>

  <h3>Languages Supported</h3>
  <p>
    Cigna Global offers support in multiple languages including English, Spanish, French, German, Mandarin, Cantonese, Japanese, Korean, and Arabic. Language availability may vary by time of day.
  </p>

  <h3>Provider Finder</h3>
  <p>
    Cigna's online provider directory helps you find network doctors and hospitals. It's reasonably accurate, though always call ahead to confirm a provider still accepts Cigna before your appointment.
  </p>

  <h2 id="pros-cons">Pros and Cons</h2>
  <p>
    Here's our honest assessment of Cigna Global's strengths and weaknesses.
  </p>

  <div class="grid md:grid-cols-2 gap-6 my-8">
    <div class="bg-green-50 border border-green-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-green-900 mb-3">Pros</h3>
      <ul class="space-y-3 text-green-800">
        <li><strong>Massive network:</strong> 1.5M+ providers means direct billing is often available</li>
        <li><strong>Financial stability:</strong> Fortune 15 company backing means claims will be paid</li>
        <li><strong>Unlimited maximum:</strong> No annual cap on coverage—rare in international insurance</li>
        <li><strong>Strong customer service:</strong> 24/7 multilingual support with dedicated case managers</li>
        <li><strong>Good for families:</strong> Comprehensive family plans with maternity options</li>
        <li><strong>US network access:</strong> Excellent for US expats who return frequently</li>
        <li><strong>Digital tools:</strong> Modern portal and app for claims and policy management</li>
      </ul>
    </div>
    <div class="bg-red-50 border border-red-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-red-900 mb-3">Cons</h3>
      <ul class="space-y-3 text-red-800">
        <li><strong>Mid-premium pricing:</strong> Not the cheapest option—budget expats have better choices</li>
        <li><strong>US coverage cost:</strong> Adding US increases premiums by 40–60%</li>
        <li><strong>Maternity waiting period:</strong> 10 months means you need to plan ahead</li>
        <li><strong>Pre-existing exclusions:</strong> Moratorium underwriting, not day-one coverage</li>
        <li><strong>Mental health not best-in-class:</strong> BUPA's mental health parity is superior</li>
        <li><strong>Reimbursement delays:</strong> Some users report slower than expected processing</li>
        <li><strong>Add-ons add up:</strong> Dental, vision, maternity significantly increase costs</li>
      </ul>
    </div>
  </div>

  <h2 id="scenarios">Real-World Scenarios</h2>
  <p>
    Let's see how Cigna Global performs in specific situations you might encounter.
  </p>

  <div class="space-y-6 my-8">
    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 1: Emergency Hospitalization in Singapore</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're living in Singapore when you experience severe chest pain. You're rushed to Mount Elizabeth Hospital (Cigna network) and need cardiac catheterization. Total bill: $45,000.</p>
      <p class="text-neutral-600 mb-2"><strong>Cigna Gold ($1,000 deductible):</strong> Mount Elizabeth is in-network. Cigna pre-authorizes the procedure, arranges direct billing. You pay $1,000 deductible. Cigna pays $44,000 directly to the hospital.</p>
      <p class="text-neutral-600 mb-0"><strong>Your experience:</strong> You focus on recovery while Cigna handles billing. No upfront payment beyond deductible. Follow-up cardiology covered as outpatient.</p>
      <p class="text-green-700 font-medium mt-2">This is where Cigna shines—major events at network hospitals with seamless direct billing.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 2: Routine Care in Portugal</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You're living in Lisbon and need a routine checkup, blood work, and a prescription refill. You visit a local doctor not in Cigna's network.</p>
      <p class="text-neutral-600 mb-2"><strong>Cigna Gold ($1,000 deductible):</strong> You pay the doctor €80 upfront. You haven't met your deductible yet, so this counts toward it. You submit the receipt through Cigna's app.</p>
      <p class="text-neutral-600 mb-0"><strong>Your experience:</strong> Since you haven't met your $1,000 deductible, you're paying out-of-pocket anyway. The visit is logged but not reimbursed until you hit $1,000 in covered expenses.</p>
      <p class="text-amber-700 font-medium mt-2">For routine care with a deductible, you're often paying out-of-pocket. Consider whether comprehensive coverage is worth it if you're healthy.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 3: Having a Baby in Spain</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You added maternity coverage 12 months ago. You're now delivering at a private hospital in Barcelona. Normal delivery with epidural: €7,000.</p>
      <p class="text-neutral-600 mb-2"><strong>Cigna Gold + Maternity:</strong> Maternity benefit covers delivery. You've met the 10-month waiting period. Cigna pre-authorizes and arranges direct billing with the hospital.</p>
      <p class="text-neutral-600 mb-0"><strong>Your experience:</strong> You pay your deductible, Cigna covers the rest. Prenatal visits were covered throughout pregnancy. Newborn is covered for 30 days automatically.</p>
      <p class="text-green-700 font-medium mt-2">Cigna's maternity works well if you plan ahead. The 10-month wait requires foresight, but coverage is comprehensive once active.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 4: Mental Health Support</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You've been struggling with anxiety for several months. You want to see a therapist and possibly get medication.</p>
      <p class="text-neutral-600 mb-2"><strong>Cigna Gold:</strong> Mental health outpatient is covered. You find a network therapist in your city. Weekly sessions at $150 each are covered after deductible, subject to any session limits in your plan.</p>
      <p class="text-neutral-600 mb-0"><strong>Your experience:</strong> Coverage is good but check your specific plan for session limits. Some Cigna Gold plans cap outpatient mental health at 20–30 sessions per year. Medication covered as prescription benefit.</p>
      <p class="text-amber-700 font-medium mt-2">Cigna's mental health coverage is good but not best-in-class. If mental health parity is essential, BUPA Global is the stronger choice.</p>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-neutral-900 mb-3">Scenario 5: Pre-Existing Condition (Diabetes)</h3>
      <p class="text-neutral-600 mb-2"><strong>Situation:</strong> You have Type 2 diabetes, well-controlled for 3 years. You need ongoing medication and quarterly monitoring.</p>
      <p class="text-neutral-600 mb-2"><strong>Cigna Gold (Moratorium Underwriting):</strong> With moratorium underwriting, your diabetes isn't covered initially. After 2 years of no treatment for diabetes, it could become covered. Until then, all diabetes-related expenses are out-of-pocket.</p>
      <p class="text-neutral-600 mb-0"><strong>Your experience:</strong> You're paying for insulin, test strips, and checkups yourself. This could be $200–400/month depending on your needs. After the moratorium period, coverage may kick in—but that's 2 years of out-of-pocket costs.</p>
      <p class="text-red-700 font-medium mt-2">For pre-existing conditions, Cigna's moratorium approach is limiting. BUPA Global offers potential day-one coverage through medical underwriting—worth considering if this is your situation.</p>
