---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';
import HowItWorks from '../components/HowItWorks.astro';
import LogoRibbon from '../components/LogoRibbon.astro';
import ContentCards from '../components/ContentCards.astro';
import Disclosure from '../components/Disclosure.astro';

const featuredCards = [
  {
    title: 'Best Expat Health Insurance',
    description: 'Our top picks for long-term international coverage.',
    href: '/best/expat-health-insurance',
    image: '/images/cards/best-expat-insurance.png',
  },
  {
    title: 'Cigna Global vs Allianz Care',
    description: 'See how these popular providers compare.',
    href: '/compare/cigna-global-vs-allianz-care',
    image: '/images/cards/compare-providers.png',
  },
  {
    title: 'Insurance for Digital Nomads',
    description: 'Coverage that works when you move often.',
    href: '/insurance-for/digital-nomads',
    image: '/images/cards/digital-nomads.png',
  },
];
---

<Layout title="Find the Right International Health Insurance" description="Compare international health insurance plans side by side. Get honest reviews, cost breakdowns, and recommendations for expats, digital nomads, and families moving abroad.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-neutral-50 to-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <h1 class="text-4xl lg:text-5xl font-bold text-neutral-900 mb-6">
            Find the Right Health Insurance for Living Abroad
          </h1>
          <p class="text-xl text-neutral-600 mb-8">
            Compare international health plans side by side. Get clear, honest info to help you choose coverage that fits your life and budget.
          </p>
          <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4 mb-6">
            <CTAButton href="/best/expat-health-insurance" size="lg">
              Find My Plan →
            </CTAButton>
            <CTAButton href="/guides/international-health-insurance-vs-travel" variant="secondary" size="lg">
              How to Choose
            </CTAButton>
          </div>
          <Disclosure />
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/pages/home-hero.png"
            alt="Compare international health insurance plans"
            class="w-full rounded-xl"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <HowItWorks />

  <!-- Logo Ribbon -->
  <LogoRibbon />

  <!-- Body Copy Section -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-bold text-neutral-900 text-center mb-8">
          Health Insurance That Travels With You
        </h2>
        <div class="space-y-6 text-neutral-600">
          <p>
            Moving abroad is exciting. But figuring out health insurance? That part can feel confusing. You have lots of questions: What plans cover me in multiple countries? How do deductibles work? What about my pre-existing conditions?
          </p>
          <p>
            We created this site to make things simpler. You get clear comparisons, honest pros and cons, and guides that explain everything in plain language. No hype, no pressure. Just the info you need to make a smart choice.
          </p>
          <p>
            Whether you are retiring in Portugal, working remotely from Thailand, or moving your family to Spain, we help you find coverage that fits your situation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Content Cards -->
  <section class="py-16 lg:py-20 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl lg:text-3xl font-bold text-neutral-900 text-center mb-4">
        Get Started
      </h2>
      <p class="text-center text-neutral-600 mb-10 max-w-2xl mx-auto">
        Not sure where to begin? These guides and comparisons are a great starting point.
      </p>
      <ContentCards cards={featuredCards} title="" />
    </div>
  </section>

  <!-- Secondary CTA Section -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-primary-600 rounded-2xl p-8 lg:p-12 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
          Ready to Find Your Plan?
        </h2>
        <p class="text-primary-100 mb-8 max-w-2xl mx-auto">
          Compare top international health insurance options and get a plan that works for your needs and budget.
        </p>
        <CTAButton href="/best/expat-health-insurance" variant="secondary" size="lg" class="bg-white text-primary-600 hover:bg-primary-50 border-white">
          See Top-Rated Plans →
        </CTAButton>
      </div>
    </div>
  </section>
</Layout>
