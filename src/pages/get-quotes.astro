---
import Layout from '../layouts/Layout.astro';

const providers = [
  {
    name: 'Cigna Global',
    slug: 'cigna-global',
    tag: 'Most Popular',
    tagColor: 'bg-primary-100 text-primary-800',
    description: 'Largest global network with 1.5M+ providers. Modular plans, 24/7 support.',
    priceRange: '$200-500/mo',
    bestFor: 'Global coverage, families, comprehensive needs',
  },
  {
    name: 'Bupa Global',
    slug: 'bupa-global',
    tag: 'Premium',
    tagColor: 'bg-purple-100 text-purple-800',
    description: 'Premium service with excellent claims support. Lifetime renewal guarantee.',
    priceRange: '$300-600/mo',
    bestFor: 'Premium coverage, retirees, long-term expats',
  },
  {
    name: 'Allianz Care',
    slug: 'allianz-care',
    tag: 'Best Value',
    tagColor: 'bg-green-100 text-green-800',
    description: 'German insurer with strong European network. Competitive pricing.',
    priceRange: '$150-400/mo',
    bestFor: 'Europe-based expats, value seekers',
  },
  {
    name: 'Aetna International',
    slug: 'aetna-international',
    tag: 'US Expats',
    tagColor: 'bg-blue-100 text-blue-800',
    description: 'CVS Health company with strong US integration. Good for Americas.',
    priceRange: '$250-550/mo',
    bestFor: 'US expats, Americas coverage',
  },
  {
    name: 'SafetyWing',
    slug: 'safetywing',
    tag: 'Budget',
    tagColor: 'bg-amber-100 text-amber-800',
    description: 'Subscription model designed for nomads. Cancel anytime.',
    priceRange: '$45-100/mo',
    bestFor: 'Digital nomads, young travelers, budget-conscious',
  },
  {
    name: 'IMG Global',
    slug: 'img-global',
    tag: 'Flexible',
    tagColor: 'bg-neutral-100 text-neutral-800',
    description: 'US-based with flexible plan options. Good customer service.',
    priceRange: '$100-350/mo',
    bestFor: 'Flexible needs, mid-range budget',
  },
];
---

<Layout
  title="Get Insurance Quotes | Compare Expat Plans"
  description="Get quotes from top international health insurance providers. Compare Cigna, Bupa, Allianz, and more."
>
  <section class="bg-gradient-to-b from-primary-50 to-white py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
        Get Insurance Quotes
      </h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Compare quotes from the world's leading international health insurance providers. Click any provider to get a personalized quote.
      </p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6">
        {providers.map((provider) => (
          <div class="border border-neutral-200 rounded-xl p-6 hover:border-primary-300 hover:shadow-md transition-all">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h2 class="text-xl font-semibold text-neutral-900">{provider.name}</h2>
                  <span class={`px-2 py-0.5 text-xs font-medium rounded ${provider.tagColor}`}>{provider.tag}</span>
                </div>
                <p class="text-neutral-600 mb-2">{provider.description}</p>
                <div class="flex flex-wrap gap-4 text-sm">
                  <span class="text-neutral-500"><strong class="text-neutral-700">{provider.priceRange}</strong></span>
                  <span class="text-neutral-500">Best for: {provider.bestFor}</span>
                </div>
              </div>
              <div class="flex flex-col gap-2 md:min-w-[160px]">
                <a
                  href={`/go/${provider.slug}`}
                  class="inline-block text-center bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 px-5 rounded-lg transition-colors no-underline"
                  style="color: white !important;"
                >
                  Get Quote
                </a>
                <a
                  href={`/providers/${provider.slug}`}
                  class="inline-block text-center text-primary-600 hover:text-primary-700 text-sm font-medium py-1"
                >
                  Read Review
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-50 border-t border-neutral-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl font-semibold text-neutral-900 mb-3">Not sure which to choose?</h2>
      <p class="text-neutral-600 mb-6">
        Use our comparison tools to see how providers stack up on coverage, pricing, and features.
      </p>
      <a
        href="/compare/"
        class="inline-block bg-neutral-800 hover:bg-neutral-900 text-white font-medium py-2.5 px-6 rounded-lg transition-colors no-underline"
        style="color: white !important;"
      >
        Compare All Providers
      </a>
    </div>
  </section>
</Layout>
