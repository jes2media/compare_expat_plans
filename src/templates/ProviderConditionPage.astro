    estimatedCost: 'Contact provider for quote',
    bestFor: 'Expats seeking international health coverage.',
    notIdealFor: 'Those with very specific requirements should compare options.',
    underwritingType: 'both',
    claimsProcess: 'Standard claims process via online portal or mobile app. Check with provider for specific timelines.',
    networkStrength: 'moderate',
    specialistAccess: 'Specialist access varies by region. Check provider directory for availability in your destination.',
    medicationCoverage: 'Prescription medications covered according to plan formulary. Check for specific medication coverage.',
    emergencyCoverage: 'Emergency care covered worldwide. Contact 24/7 helpline for assistance.',
    telehealth: true,
    directBilling: true
  };
}

const coverage = getCoverageData();

// Rating badge color
function getRatingColor(rating: string): string {
  switch (rating) {
    case 'excellent': return 'bg-green-100 text-green-800';
    case 'good': return 'bg-blue-100 text-blue-800';
    case 'moderate': return 'bg-yellow-100 text-yellow-800';
    case 'limited': return 'bg-red-100 text-red-800';
    default: return 'bg-gray-100 text-gray-800';
  }
}

// Generate FAQs
function getFAQs(): Array<{ question: string; answer: string }> {
  return [
    {
      question: `Does ${provider.name} cover ${condition.name.toLowerCase()} as a pre-existing condition?`,
      answer: coverage.preExistingPolicy
    },
    {
      question: `How long do I have to wait for ${condition.name.toLowerCase()} coverage with ${provider.name}?`,
      answer: coverage.waitingPeriod
    },
    {
      question: `What medications are covered for ${condition.name.toLowerCase()}?`,
      answer: `${provider.name} typically covers prescription medications for ${condition.name.toLowerCase()}, including maintenance medications after any applicable waiting period. Specific formulary details and whether brand-name vs generic is covered depends on your plan level.`
    },
    {
      question: `Can I see a specialist for ${condition.name.toLowerCase()} with ${provider.name}?`,
      answer: `Yes, ${provider.name} covers specialist consultations for ${condition.name.toLowerCase()}. Depending on your plan, you may need a referral from a general practitioner first, or you may have direct access to specialists.`
    },
    {
      question: `Is ${provider.name} a good choice if I have ${condition.name.toLowerCase()}?`,
      answer: `${coverage.bestFor} However, ${coverage.notIdealFor}`
    }
  ];
}

const faqs = getFAQs();

// Related cards
const relatedCards = [
  {
    title: `${provider.name} Review`,
    description: `Full review of ${provider.name} coverage, pricing, and who it's best for.`,
    href: provider.href,
    image: provider.logo,
  },
  {
    title: 'Pre-Existing Conditions Guide',
    description: 'How to get coverage for chronic conditions when moving abroad.',
    href: '/guides/pre-existing-conditions-abroad',
    image: '/images/guides/pre-existing-conditions-hero.png',
  },
  {
    title: 'Find English-Speaking Doctors',
    description: 'How to find doctors who speak your language anywhere in the world.',
    href: '/guides/find-english-speaking-doctors-abroad',
    image: '/images/guides/english-speaking-doctors-hero.png',
  },
];

// Sidebar links
const sidebarLinks = [
  { title: `${provider.name} Full Review`, href: provider.href },
  { title: 'Pre-Existing Conditions Guide', href: '/guides/pre-existing-conditions-abroad' },
  { title: 'Compare Insurance Providers', href: '/best/expat-health-insurance' },
  { title: 'How to Switch Insurance Abroad', href: '/guides/switching-insurance-abroad' },
];

// SEO
const title = `${provider.name} Coverage for ${condition.name} | Expat Insurance`;
const description = `How ${provider.name} covers ${condition.name.toLowerCase()} for expats. Waiting periods, coverage limits, costs, and whether it's right for your situation.`;
---

<Layout title={title} description={description} noindex={true}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-primary-50 to-white py-10 lg:py-14 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          {provider.logo && (
            <img src={provider.logo} alt={provider.name} class="h-10 w-auto" />
          )}
          <span class={`px-3 py-1 rounded-full text-sm font-medium ${getRatingColor(coverage.coverageRating)}`}>
            {coverage.coverageRating.charAt(0).toUpperCase() + coverage.coverageRating.slice(1)} Coverage
          </span>
        </div>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          {provider.name} Coverage for {condition.name}
        </h1>
        <p class="text-lg text-neutral-600 mb-6">
          {coverage.approach}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href={provider.href}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            View {provider.name} Plans
          </a>
          <a
            href="/guides/pre-existing-conditions-abroad"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            Pre-Existing Conditions Guide
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <article class="flex-1 min-w-0 prose prose-neutral max-w-none">

        <!-- Overview Section -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>
          <p class="text-neutral-700 mb-4">
            If you have {condition.name.toLowerCase()} and are considering {provider.name} for your expat health insurance,
            you're looking at one of the {coverage.coverageRating === 'excellent' ? 'strongest' : coverage.coverageRating === 'good' ? 'solid' : coverage.coverageRating === 'moderate' ? 'moderate' : 'more limited'} options on the market for this condition.
            Understanding exactly what's covered—and what's not—can save you thousands of dollars and significant stress down the road.
          </p>
          <p class="text-neutral-700 mb-4">
            {provider.name} {coverage.underwritingType === 'both' ? 'offers two underwriting paths: moratorium and full medical underwriting' : coverage.underwritingType === 'moratorium' ? 'uses moratorium underwriting' : coverage.underwritingType === 'full-medical' ? 'uses full medical underwriting' : 'has specific policies'} for pre-existing conditions like {condition.name.toLowerCase()}.
            This guide breaks down exactly how {provider.name} handles {condition.name.toLowerCase()} coverage, what you can expect to pay, and whether it's the right choice for your situation.
          </p>
        </section>

        <!-- Quick Summary Table -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Coverage at a Glance</h2>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse bg-white rounded-lg overflow-hidden border border-neutral-200">
              <tbody>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700 w-1/3">Coverage Rating</td>
                  <td class="px-4 py-3">
                    <span class={`px-2 py-1 rounded text-sm font-medium ${getRatingColor(coverage.coverageRating)}`}>
                      {coverage.coverageRating.charAt(0).toUpperCase() + coverage.coverageRating.slice(1)}
                    </span>
                  </td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Waiting Period</td>
                  <td class="px-4 py-3 text-neutral-700">{coverage.waitingPeriod}</td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Estimated Annual Cost</td>
                  <td class="px-4 py-3 text-neutral-700">{coverage.estimatedCost}</td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Network Strength</td>
                  <td class="px-4 py-3 text-neutral-700 capitalize">{coverage.networkStrength}</td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Direct Billing</td>
                  <td class="px-4 py-3 text-neutral-700">{coverage.directBilling ? 'Yes, at network hospitals' : 'Limited or not available'}</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Telehealth</td>
                  <td class="px-4 py-3 text-neutral-700">{coverage.telehealth ? 'Yes, included' : 'Not available'}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Pre-Existing Condition Policy -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Pre-Existing Condition Policy</h2>
          <p class="text-neutral-700 mb-4">
            How {provider.name} handles pre-existing {condition.name.toLowerCase()} is crucial to understand before you sign up.
            The wrong choice here could leave you paying out-of-pocket for all your {condition.name.toLowerCase()}-related care.
          </p>
          <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4">
            <p class="text-neutral-800">{coverage.preExistingPolicy}</p>
          </div>
          <p class="text-neutral-700">
            {coverage.underwritingType === 'both' ?
              `With ${provider.name}, you can choose between moratorium underwriting (simpler but requires a waiting period) or full medical underwriting (more complex but potentially immediate coverage). Most expats with well-controlled ${condition.name.toLowerCase()} opt for full medical underwriting to avoid the waiting period.` :
              coverage.underwritingType === 'none' ?
              `Be aware that ${provider.name} does not cover pre-existing conditions at all. If you have ${condition.name.toLowerCase()}, this provider is only suitable for covering new, unrelated conditions.` :
              `The ${coverage.underwritingType === 'moratorium' ? 'moratorium' : 'full medical underwriting'} approach means your coverage path is straightforward, though you should understand the implications before enrolling.`
            }
          </p>
        </section>

        <!-- What's Covered / Limited / Excluded -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Coverage Breakdown</h2>
          <p class="text-neutral-700 mb-6">
            Understanding the three tiers of coverage—what's fully covered, what has limits, and what's excluded entirely—helps you plan your healthcare budget and avoid surprises.
          </p>

          <div class="space-y-6">
            <!-- What's Covered -->
            <div class="bg-green-50 border border-green-200 rounded-lg p-6">
              <h3 class="font-semibold text-green-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Fully Covered
              </h3>
              <ul class="space-y-2">
                {coverage.whatsCovered.map((item) => (
                  <li class="text-neutral-700 flex items-start gap-2">
                    <span class="text-green-600 mt-1">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- What's Limited -->
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
              <h3 class="font-semibold text-yellow-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Coverage Limits Apply
              </h3>
              <ul class="space-y-2">
                {coverage.whatsLimited.map((item) => (
                  <li class="text-neutral-700 flex items-start gap-2">
                    <span class="text-yellow-600 mt-1">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- What's Excluded -->
            <div class="bg-red-50 border border-red-200 rounded-lg p-6">
              <h3 class="font-semibold text-red-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Not Covered
              </h3>
              <ul class="space-y-2">
                {coverage.whatsExcluded.map((item) => (
                  <li class="text-neutral-700 flex items-start gap-2">
                    <span class="text-red-600 mt-1">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>

        <!-- Specialist Access & Network -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Specialist Access & Network</h2>
          <p class="text-neutral-700 mb-4">
            For {condition.name.toLowerCase()}, having reliable access to specialists is essential.
            {provider.name}'s network strength is rated as <strong>{coverage.networkStrength}</strong>, which affects how easily you can find qualified doctors.
          </p>
          <p class="text-neutral-700 mb-4">{coverage.specialistAccess}</p>

          <div class="grid sm:grid-cols-2 gap-4 mt-6">
            <div class="bg-white border border-neutral-200 rounded-lg p-4">
              <h4 class="font-semibold text-neutral-900 mb-2">Direct Billing</h4>
              <p class="text-sm text-neutral-600">
                {coverage.directBilling ?
                  'Available at network hospitals. You won\'t need to pay upfront and file for reimbursement—the hospital bills the insurer directly.' :
                  'Limited availability. You may need to pay upfront and submit claims for reimbursement.'
                }
              </p>
            </div>
            <div class="bg-white border border-neutral-200 rounded-lg p-4">
              <h4 class="font-semibold text-neutral-900 mb-2">Telehealth</h4>
              <p class="text-sm text-neutral-600">
                {coverage.telehealth ?
                  'Virtual consultations included. Useful for routine follow-ups and prescription renewals when traveling.' :
                  'Not included in standard plans. You\'ll need in-person visits for all consultations.'
                }
              </p>
            </div>
          </div>
        </section>

        <!-- Medications -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Medication Coverage</h2>
          <p class="text-neutral-700 mb-4">
            Ongoing medication is often the biggest expense for {condition.name.toLowerCase()} management.
            Here's how {provider.name} handles prescription coverage.
          </p>
          <p class="text-neutral-700 mb-4">{coverage.medicationCoverage}</p>

          <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-5">
            <h4 class="font-semibold text-neutral-900 mb-3">Tips for Medication Coverage</h4>
            <ul class="space-y-2 text-sm text-neutral-700">
              <li class="flex items-start gap-2">
                <span class="text-primary-600 mt-1">→</span>
                Request a copy of the formulary before enrolling to verify your specific medications are covered
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary-600 mt-1">→</span>
                Ask about prior authorization requirements for any medications you take regularly
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary-600 mt-1">→</span>
                Check if mail-order pharmacy options are available for better pricing on maintenance medications
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary-600 mt-1">→</span>
                Understand the difference between generic and brand-name coverage in your plan
              </li>
            </ul>
          </div>
        </section>

        <!-- Claims Process -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Claims Process</h2>
          <p class="text-neutral-700 mb-4">
            How you get reimbursed—or avoid upfront payment altogether—matters when you're managing an ongoing condition.
            A smooth claims process reduces stress and ensures you're not out-of-pocket for long periods.
          </p>
          <p class="text-neutral-700 mb-4">{coverage.claimsProcess}</p>

          <div class="bg-white border border-neutral-200 rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-neutral-50 border-b border-neutral-200">
              <h4 class="font-semibold text-neutral-900">How to File a Claim</h4>
            </div>
            <ol class="divide-y divide-neutral-200">
              <li class="px-4 py-3 flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-medium">1</span>
                <span class="text-neutral-700">Keep all receipts, prescriptions, and medical reports from your visit</span>
              </li>
              <li class="px-4 py-3 flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-medium">2</span>
                <span class="text-neutral-700">Log into the {provider.name} member portal or mobile app</span>
              </li>
              <li class="px-4 py-3 flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-medium">3</span>
                <span class="text-neutral-700">Upload documentation and complete the claim form with diagnosis codes</span>
              </li>
              <li class="px-4 py-3 flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-medium">4</span>
                <span class="text-neutral-700">Track your claim status online and receive payment to your bank account</span>
              </li>
            </ol>
          </div>
        </section>

        <!-- Living with Condition Abroad -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Managing {condition.name} as an Expat</h2>
          <p class="text-neutral-700 mb-4">
            Beyond insurance coverage, successfully managing {condition.name.toLowerCase()} abroad requires planning.
            Here's what expats with this condition typically need to consider.
          </p>

          <h3 class="text-lg font-semibold text-neutral-900 mt-6 mb-3">Key Concerns for Expats</h3>
          <ul class="space-y-2 mb-6">
            {condition.expatConcerns.map((concern) => (
              <li class="text-neutral-700 flex items-start gap-2">
                <span class="text-neutral-400 mt-1">•</span>
                {concern}
              </li>
            ))}
          </ul>

          <h3 class="text-lg font-semibold text-neutral-900 mt-6 mb-3">What to Look For in Coverage</h3>
          <p class="text-neutral-700 mb-3">
            When evaluating {provider.name} or any insurer for {condition.name.toLowerCase()} coverage, prioritize these factors:
          </p>
          <ul class="space-y-2 mb-6">
            {condition.insuranceConsiderations.map((consideration) => (
              <li class="text-neutral-700 flex items-start gap-2">
                <span class="text-neutral-400 mt-1">•</span>
                {consideration}
              </li>
            ))}
          </ul>

          <h3 class="text-lg font-semibold text-neutral-900 mt-6 mb-3">Ongoing Management Needs</h3>
          <p class="text-neutral-700 mb-3">
            Budget and plan for these regular requirements:
          </p>
          <ul class="space-y-2">
            {condition.managementNeeds.map((need) => (
              <li class="text-neutral-700 flex items-start gap-2">
                <span class="text-neutral-400 mt-1">•</span>
                {need}
              </li>
            ))}
          </ul>
        </section>

        <!-- Who This Is For -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Is {provider.name} Right for You?</h2>
          <p class="text-neutral-700 mb-6">
            No insurer is perfect for everyone. Here's an honest assessment of who should—and shouldn't—consider {provider.name} for {condition.name.toLowerCase()} coverage.
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-green-50 border border-green-200 rounded-lg p-5">
              <h3 class="font-semibold text-green-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
                </svg>
                Best For
              </h3>
              <p class="text-neutral-700">{coverage.bestFor}</p>
            </div>
            <div class="bg-red-50 border border-red-200 rounded-lg p-5">
              <h3 class="font-semibold text-red-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.096c.5 0 .905-.405.905-.904 0-.715.211-1.413.608-2.008L17 13V4m-7 10h2m5-10h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5" />
                </svg>
                Not Ideal For
              </h3>
              <p class="text-neutral-700">{coverage.notIdealFor}</p>
            </div>
          </div>
        </section>

        <!-- FAQs -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-6">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <details class="group bg-white border border-neutral-200 rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer p-5 font-medium text-neutral-900">
                  {faq.question}
                  <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-neutral-700">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Bottom Line -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">The Bottom Line</h2>
          <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
            <p class="text-neutral-700 mb-4">
              {provider.name} offers <strong>{coverage.coverageRating}</strong> coverage for {condition.name.toLowerCase()}.
              {coverage.coverageRating === 'excellent' ?
                `It's one of the strongest options available for expats with this condition, though you'll pay a premium for that quality.` :
                coverage.coverageRating === 'good' ?
                `It's a solid choice that balances coverage quality with cost, suitable for most expats with well-managed ${condition.name.toLowerCase()}.` :
                coverage.coverageRating === 'moderate' ?
                `It provides basic coverage but may have gaps. Consider whether the limitations align with your specific needs.` :
                `It has significant limitations for ${condition.name.toLowerCase()} coverage. Most expats with this condition should consider other options.`
              }
            </p>
            <p class="text-neutral-700">
              Before enrolling, request a detailed quote that accounts for your {condition.name.toLowerCase()} history.
              Compare at least 2-3 providers to ensure you're getting the best combination of coverage and value for your specific situation.
            </p>
          </div>
        </section>

      </article>

      <StickySidebar
        ctaTitle={`${condition.name} Coverage`}
        ctaDescription={`Compare ${provider.name} with other providers for ${condition.name.toLowerCase()} coverage.`}
        ctaButtonText="Compare All Providers"
        ctaButtonHref="/best/expat-health-insurance"
        relatedLinks={sidebarLinks}
      />
    </div>

    <!-- Related Content -->
    <section class="mt-16 border-t border-neutral-200 pt-12">
