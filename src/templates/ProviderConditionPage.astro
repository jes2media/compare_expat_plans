/**
 * ProviderConditionPage.astro
 *
 * Template for provider × condition pages showing how specific insurers
 * handle coverage for particular medical conditions.
 *
 * Example: /providers/cigna-global/coverage/diabetes
 */

import Layout from '../layouts/Layout.astro';
import StickySidebar from '../components/StickySidebar.astro';
import ContentCards from '../components/ContentCards.astro';
import Disclosure from '../components/Disclosure.astro';
import type { Provider } from '../data/types';
import type { Condition } from '../data/conditions';

interface Props {
  provider: Provider;
  condition: Condition;
}

const { provider, condition } = Astro.props;

// Provider-specific coverage data for conditions
interface ProviderCoverageData {
  approach: string;
  coverageRating: 'excellent' | 'good' | 'moderate' | 'limited';
  waitingPeriod: string;
  preExistingPolicy: string;
  whatsCovered: string[];
  whatsLimited: string[];
  whatsExcluded: string[];
  estimatedCost: string;
  bestFor: string;
  notIdealFor: string;
  // Extended data for richer content
  underwritingType: 'moratorium' | 'full-medical' | 'both' | 'none';
  claimsProcess: string;
  networkStrength: 'excellent' | 'good' | 'moderate' | 'limited';
