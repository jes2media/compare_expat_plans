// Get coverage data for this provider and condition
function getCoverageData(): ProviderCoverageData {
  const providerData = providerCoverageMap[provider.slug];
  if (!providerData) {
    // Default data for providers not in the map
    return getDefaultCoverageData();
  }

  // Map condition type to coverage data type
  const coverageType = condition.type === 'mental-health' ? 'mental-health' : 'chronic';
  return providerData[coverageType] || getDefaultCoverageData();
}

