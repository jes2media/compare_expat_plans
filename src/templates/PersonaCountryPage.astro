      visaOptions.push({ name: 'Digital Nomad Visa (D8)', duration: '1-2 years', insuranceRequired: true, notes: 'Requires €3,040/month income. Full health insurance required.' });
      visaOptions.push({ name: 'D7 Passive Income Visa', duration: '2 years', insuranceRequired: true, notes: 'For remote workers with passive income.' });
    } else if (country.slug === 'thailand') {
      visaOptions.push({ name: 'Long-Term Resident (LTR) Visa', duration: '10 years', insuranceRequired: true, notes: 'Requires $80,000/year income or $1M in assets.' });
      visaOptions.push({ name: 'Tourist Visa Extensions', duration: '60-90 days', insuranceRequired: false, notes: 'Many nomads do visa runs, but technically not legal for working.' });
    } else if (country.slug === 'mexico') {
      visaOptions.push({ name: 'Temporary Resident Visa', duration: '1-4 years', insuranceRequired: false, notes: 'Requires proof of income ~$2,500/month. No insurance required but recommended.' });
      visaOptions.push({ name: 'Tourist Visa (FMM)', duration: '180 days', insuranceRequired: false, notes: 'Free, no income proof needed. Popular but technically for tourism only.' });
