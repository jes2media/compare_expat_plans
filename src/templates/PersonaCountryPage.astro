const recommendedProviders = getRecommendedProviders();

// Generate prose content for healthcare system section
function getHealthcareSystemProse(): string[] {
  const paragraphs: string[] = [];

  if (country.publicHealthcare) {
    paragraphs.push(
      `${country.name}'s public healthcare system, ${country.publicHealthcare.name}, provides coverage to ${country.publicHealthcare.access.toLowerCase()}. For ${persona.name.toLowerCase()}, understanding how this system works is important even if you plan to use private insurance, as it affects the overall healthcare landscape and your options in emergencies.`
    );
  }

  paragraphs.push(
    `Most ${persona.name.toLowerCase()} in ${country.name} opt for private health insurance rather than relying solely on public healthcare. Private insurance provides faster access to specialists, English-speaking doctors, and modern facilities. It also ensures you're not dependent on eligibility rules that may change or exclude non-residents.`
  );

  if (country.privateHealthcare) {
    paragraphs.push(
      `Private healthcare costs in ${country.name} typically run ${country.privateHealthcare.cost}. This is often comparable to or less than what you'd pay in the US or UK, while still providing excellent care. Many expats find the quality-to-cost ratio very favorable compared to their home countries.`
    );
  }

  return paragraphs;
}

// Generate prose for insurance selection
function getInsuranceSelectionProse(): string[] {
  const paragraphs: string[] = [];

  paragraphs.push(
    `Choosing the right health insurance as a ${persona.singular} in ${country.name} requires balancing coverage, cost, and your specific situation. Don't just look at the monthly premium—consider deductibles, coverage limits, network quality, and how the insurer handles claims. A cheap plan that denies claims or has poor customer service isn't actually saving you money.`
  );

  if (persona.slug === 'digital-nomads' || persona.slug === 'remote-workers') {
    paragraphs.push(
      `As someone who may travel or relocate, portability matters. Some insurance plans lock you into a single country or charge extra for coverage elsewhere. Look for plans with worldwide coverage or at least regional flexibility. Also verify that the policy doesn't require a fixed address—some traditional expat plans assume you're staying put.`
    );
  } else if (persona.slug === 'retirees' || persona.slug === 'seniors') {
    paragraphs.push(
      `At this stage of life, pre-existing condition coverage is likely your biggest concern. Be completely honest on applications—insurers can and do deny claims for undisclosed conditions. Look for plans with moratorium underwriting (conditions covered after a waiting period) or full medical underwriting (conditions evaluated upfront). The latter is often better if you want certainty.`
    );
  } else if (persona.slug === 'families') {
    paragraphs.push(
      `Family coverage requires thinking about everyone's needs. Children need pediatric care and vaccinations. If you're planning more children, maternity coverage has waiting periods—usually 10-12 months. Mental health coverage for teens is often overlooked but increasingly important. Make sure all family members are covered equally, not just the primary policyholder.`
    );
  } else {
    paragraphs.push(
      `Consider what you actually need versus what's nice to have. A higher deductible plan can significantly reduce premiums if you're generally healthy and just want catastrophic coverage. But if you have ongoing healthcare needs, a lower deductible with better outpatient coverage may be more cost-effective over the year.`
    );
  }

  paragraphs.push(
    `Don't overlook the claims process. Ask how claims are submitted, how long reimbursement takes, and whether direct billing is available at hospitals in ${country.name}. An insurer with a poor claims experience can turn a medical issue into a financial and administrative nightmare.`
  );

  return paragraphs;
}

// Generate prose for cost of living context
function getCostOfLivingProse(): string[] {
  const paragraphs: string[] = [];

  paragraphs.push(
    `Your total cost of living in ${country.name} will depend significantly on where you choose to live and your lifestyle expectations. The capital and tourist areas are typically more expensive, while secondary cities and rural areas offer better value. Many ${persona.name.toLowerCase()} find that moving slightly outside the most popular areas can cut costs by 20-30% without sacrificing quality of life.`
  );

  paragraphs.push(
    `Health insurance should be factored into your monthly budget from the start—it's not an optional expense when living abroad. Budget $100-300/month for decent international coverage, more if you're older or have pre-existing conditions. This is usually a small fraction of your total budget but provides enormous peace of mind and financial protection.`
  );

  return paragraphs;
}

// Generate prose for the location section
function getLocationProse(): string[] {
  const paragraphs: string[] = [];

  paragraphs.push(
    `Where you base yourself in ${country.name} affects not just your cost of living but also your healthcare access. Major cities have the best hospitals, most English-speaking doctors, and widest range of specialists. If you have ongoing medical needs, being within reasonable distance of quality healthcare facilities should factor into your location decision.`
  );

  paragraphs.push(
    `That said, many ${persona.name.toLowerCase()} prioritize lifestyle over healthcare proximity, especially if they're healthy. Smaller towns and beach communities offer a more relaxed pace, stronger sense of community, and lower costs. Just make sure your insurance includes coverage for medical evacuation if you're in a remote area—getting to a major hospital quickly can matter in emergencies.`
  );

  return paragraphs;
}

const healthcareProse = getHealthcareSystemProse();
const insuranceSelectionProse = getInsuranceSelectionProse();
const costProse = getCostOfLivingProse();
const locationProse = getLocationProse();

// FAQs
function getFAQs(): Array<{ question: string; answer: string }> {
  return [
    {
      question: `Do I need health insurance as a ${persona.singular} in ${country.name}?`,
      answer: country.insuranceRequired
        ? `Yes, ${country.name} requires health insurance for most visa types. ${country.requirementExplanation || 'Check specific requirements for your visa category.'}`
        : `While not always legally required, health insurance is strongly recommended for ${persona.name.toLowerCase()} in ${country.name}. ${country.requirementExplanation || 'Quality medical care abroad can be expensive without coverage.'}`
    },
    {
      question: `What type of insurance is best for ${persona.name.toLowerCase()} in ${country.name}?`,
      answer: `For ${persona.name.toLowerCase()} in ${country.name}, we recommend international health insurance with ${persona.keyNeeds.slice(0, 2).join(' and ').toLowerCase()}. Local insurance may be cheaper but often has limitations for non-citizens.`
    },
    {
      question: `How much does health insurance cost for ${persona.name.toLowerCase()} in ${country.name}?`,
      answer: `Health insurance for ${persona.name.toLowerCase()} in ${country.name} typically ranges from $80-400/month depending on age, coverage level, and pre-existing conditions. Budget plans start around $50/month while comprehensive coverage can exceed $500/month for older applicants.`
    },
    {
      question: `Can I use ${country.name}'s public healthcare system?`,
      answer: country.publicHealthcare
        ? `${country.name}'s public healthcare (${country.publicHealthcare.name}) is available to ${country.publicHealthcare.access}. ${country.publicHealthcare.notes || ''} Most expats supplement with private insurance for better access and shorter wait times.`
        : `Check local requirements for public healthcare access. Most ${persona.name.toLowerCase()} rely on private international insurance for comprehensive coverage.`
    },
    {
      question: `What visa do ${persona.name.toLowerCase()} typically use in ${country.name}?`,
      answer: data.visaOptions.length > 0
        ? `Common visa options for ${persona.name.toLowerCase()} in ${country.name} include: ${data.visaOptions.map(v => v.name).join(', ')}. ${data.visaOptions[0].notes}`
        : `Visa options vary. Check the ${country.name} embassy for current requirements for ${persona.name.toLowerCase()}.`
    },
  ];
}

