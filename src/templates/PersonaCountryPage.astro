---
/**
 * PersonaCountryPage.astro
 *
 * Template for persona × country pages showing insurance guidance
 * for specific audience types in specific countries.
 *
 * Example: /insurance-for/digital-nomads/in/spain
 */

import Layout from '../layouts/Layout.astro';
import StickySidebar from '../components/StickySidebar.astro';
import ContentCards from '../components/ContentCards.astro';
import Disclosure from '../components/Disclosure.astro';
import type { Country } from '../data/types';
import type { Persona } from '../data/personas';

interface Props {
  persona: Persona;
  country: Country;
}

const { persona, country } = Astro.props;

// Country-specific data for personas
interface PersonaCountryData {
  visaOptions: Array<{ name: string; duration: string; insuranceRequired: boolean; notes: string }>;
  monthlyBudget: { low: string; mid: string; high: string };
  popularAreas: string[];
  challenges: string[];
  advantages: string[];
  insuranceTips: string[];
  localResources: Array<{ name: string; description: string }>;
}

// Generate persona-specific content based on country data
