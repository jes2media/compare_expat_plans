      { name: 'Cigna Global', why: 'Comprehensive worldwide coverage, strong network', href: '/providers/cigna-global' },
      { name: 'IMG Global', why: 'Budget-friendly with good international coverage', href: '/providers/img-global' },
    ];
  } else if (persona.slug === 'retirees' || persona.slug === 'seniors') {
    return [
      { name: 'BUPA Global', why: 'Excellent for pre-existing conditions, high age limits', href: '/providers/bupa-global' },
      { name: 'Cigna Global', why: 'Comprehensive coverage, accepts older applicants', href: '/providers/cigna-global' },
      { name: 'Allianz Care', why: 'Good value with chronic condition coverage', href: '/providers/allianz-care' },
    ];
  } else if (persona.slug === 'families') {
    return [
      { name: 'Cigna Global', why: 'Excellent family plans with pediatric coverage', href: '/providers/cigna-global' },
      { name: 'BUPA Global', why: 'Comprehensive family coverage including maternity', href: '/providers/bupa-global' },
      { name: 'Allianz Care', why: 'Good value family plans with flexibility', href: '/providers/allianz-care' },
