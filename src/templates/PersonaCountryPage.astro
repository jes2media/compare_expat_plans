  },
  {
    title: 'Find English-Speaking Doctors',
    description: 'How to find doctors who speak your language abroad.',
    href: '/guides/find-english-speaking-doctors-abroad',
    image: '/images/guides/english-speaking-doctors-hero.png',
  },
];

// SEO
const title = `Health Insurance for ${persona.name} in ${country.name} | Expat Guide`;
const description = `Health insurance guide for ${persona.name.toLowerCase()} moving to ${country.name}. Visa requirements, costs, recommended providers, and tips.`;
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-primary-50 to-white py-10 lg:py-14 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-primary-600 mb-2">
          <a href={persona.href} class="hover:underline">{persona.name}</a>
          {' → '}
          <a href={`/countries/${country.slug}/insurance`} class="hover:underline">{country.name}</a>
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          Health Insurance for {persona.name} in {country.name}
        </h1>
        <p class="text-lg text-neutral-600 mb-6">
          {persona.description} Here's everything you need to know about getting the right health insurance coverage in {country.name}.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href={`/countries/${country.slug}/insurance`}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            Compare Insurance in {country.name}
          </a>
          <a
            href={persona.href}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            {persona.name} Guide
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <article class="flex-1 min-w-0 prose prose-neutral max-w-none">

        <!-- Overview -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Overview</h2>
          <p class="text-neutral-700 mb-4">
            {country.name} has become an increasingly popular destination for {persona.name.toLowerCase()}.
            {country.insuranceRequired
              ? `Health insurance is required for most visa types in ${country.name}, so understanding your options is essential before you move.`
              : `While health insurance isn't always mandatory in ${country.name}, it's strongly recommended for ${persona.name.toLowerCase()} to ensure access to quality healthcare.`
            }
          </p>
          <p class="text-neutral-700 mb-4">
            This guide covers visa options, insurance requirements, costs, and practical tips specifically for {persona.name.toLowerCase()} planning to live in {country.name}.
            Whether you're planning a short stay or a long-term move, getting the right health insurance is crucial for protecting yourself financially and ensuring access to quality care.
          </p>
          <p class="text-neutral-700 mb-4">
            The healthcare landscape for expats in {country.name} has evolved significantly in recent years.
            More providers now offer plans tailored to {persona.name.toLowerCase()}, with flexible terms and coverage that matches how people actually live and work abroad.
            Understanding these options—and their limitations—is the first step to making an informed decision.
          </p>
          <p class="text-neutral-700 mb-4">
            We've researched the insurance market, visa requirements, and real experiences of {persona.name.toLowerCase()} in {country.name} to create this guide.
            Our goal is to give you practical, honest information so you can choose the right coverage for your situation—not just sell you the most expensive plan.
          </p>
        </section>

        <!-- Quick Facts Table -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Quick Facts</h2>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse bg-white rounded-lg overflow-hidden border border-neutral-200">
              <tbody>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700 w-1/3">Insurance Required</td>
                  <td class="px-4 py-3 text-neutral-700">{country.insuranceRequired ? 'Yes, for most visas' : 'Not mandatory, but recommended'}</td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Monthly Budget ({persona.singular})</td>
                  <td class="px-4 py-3 text-neutral-700">{data.monthlyBudget.low} (basic) to {data.monthlyBudget.high} (comfortable)</td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Popular Areas</td>
                  <td class="px-4 py-3 text-neutral-700">{data.popularAreas.slice(0, 3).join(', ')}</td>
                </tr>
                <tr class="border-b border-neutral-200">
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Public Healthcare</td>
                  <td class="px-4 py-3 text-neutral-700">{country.publicHealthcare?.name || 'Varies'} - {country.publicHealthcare?.access || 'Check local requirements'}</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 bg-neutral-50 font-medium text-neutral-700">Private Insurance Cost</td>
                  <td class="px-4 py-3 text-neutral-700">{country.privateHealthcare?.cost || '$80-300/month'}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Healthcare System -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Healthcare in {country.name}</h2>
          {healthcareProse.map((paragraph) => (
            <p class="text-neutral-700 mb-4">{paragraph}</p>
          ))}
          <p class="text-neutral-700 mb-4">
            Emergency care is generally available to everyone regardless of insurance status, but you'll want coverage for the costs.
            Hospital stays, surgeries, and specialist treatments can quickly run into thousands of dollars without insurance.
            Even routine care adds up over time—doctor visits, prescriptions, lab tests, and preventive screenings.
          </p>
        </section>

        <!-- Visa Options -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Visa Options for {persona.name}</h2>
          <p class="text-neutral-700 mb-4">
            Understanding visa requirements is the first step to planning your move.
            Different visas have different insurance requirements, income thresholds, and renewal processes.
            Choosing the right visa affects not just your legal status but also your long-term options for staying in {country.name}.
          </p>
          <p class="text-neutral-700 mb-4">
            Many {persona.name.toLowerCase()} start with a tourist visa or visa-free entry while they explore.
            This is fine for a trial period, but if you plan to stay longer, you'll need a proper residence visa.
            Working on a tourist visa is illegal in most countries, even if you're working remotely for a foreign company—though enforcement varies.
          </p>
          <div class="space-y-4">
            {data.visaOptions.map((visa) => (
              <div class="bg-white border border-neutral-200 rounded-lg p-5">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-semibold text-neutral-900">{visa.name}</h3>
                  <span class={`px-2 py-1 rounded text-xs font-medium ${visa.insuranceRequired ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800'}`}>
                    {visa.insuranceRequired ? 'Insurance Required' : 'Insurance Optional'}
                  </span>
                </div>
                <p class="text-sm text-neutral-500 mb-2">Duration: {visa.duration}</p>
                <p class="text-neutral-700">{visa.notes}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Recommended Providers -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Recommended Insurance Providers</h2>
          <p class="text-neutral-700 mb-4">
            Based on the specific needs of {persona.name.toLowerCase()}, these providers offer the best combination of coverage, flexibility, and value for living in {country.name}.
            We've evaluated them on premium costs, coverage quality, claims experience, and how well they serve {persona.name.toLowerCase()} specifically.
          </p>
          <p class="text-neutral-700 mb-4">
            Keep in mind that the "best" provider depends on your individual circumstances.
            Someone with pre-existing conditions has different needs than someone who's young and healthy.
            Age, family status, and how long you plan to stay all affect which provider makes the most sense.
          </p>
          <div class="grid sm:grid-cols-3 gap-4">
            {recommendedProviders.map((provider, index) => (
              <a href={provider.href} class="block bg-white border border-neutral-200 rounded-lg p-5 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-6 h-6 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-medium">{index + 1}</span>
                  <h3 class="font-semibold text-neutral-900">{provider.name}</h3>
                </div>
                <p class="text-sm text-neutral-600">{provider.why}</p>
              </a>
            ))}
          </div>
        </section>

        <!-- Choosing Insurance Section -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">How to Choose the Right Insurance</h2>
          {insuranceSelectionProse.map((paragraph) => (
            <p class="text-neutral-700 mb-4">{paragraph}</p>
          ))}
        </section>

        <!-- Insurance Tips -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Insurance Tips for {persona.name}</h2>
          <p class="text-neutral-700 mb-4">
            {persona.name} have specific insurance needs that generic advice doesn't always address.
            Based on what works for {persona.name.toLowerCase()} in {country.name}, here are the key factors to prioritize when evaluating plans.
          </p>
          <p class="text-neutral-700 mb-4">
            These aren't just theoretical considerations—they're based on the actual experiences of {persona.name.toLowerCase()} who've dealt with claims, renewals, and the day-to-day reality of using insurance abroad.
            Getting these details right upfront saves significant headaches later.
          </p>
          <div class="bg-primary-50 border border-primary-200 rounded-lg p-6">
            <ul class="space-y-3">
              {data.insuranceTips.map((tip) => (
                <li class="flex items-start gap-3 text-neutral-700">
                  <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {tip}
                </li>
              ))}
            </ul>
          </div>
        </section>

        <!-- Advantages & Challenges -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Living in {country.name} as a {persona.singular}</h2>
          <p class="text-neutral-700 mb-4">
            Every destination has trade-offs. Here's an honest look at what {persona.name.toLowerCase()} can expect in {country.name}.
            Being realistic about both the positives and negatives helps you make a better decision and set appropriate expectations.
          </p>
          <p class="text-neutral-700 mb-4">
            The advantages below reflect what actually draws {persona.name.toLowerCase()} to {country.name}—not tourist brochure highlights, but the real reasons people stay long-term.
            Similarly, the challenges are the issues that catch people off guard if they don't plan for them.
          </p>
          <p class="text-neutral-700 mb-6">
            Neither list should be disqualifying on its own. Most {persona.name.toLowerCase()} find the advantages outweigh the challenges, especially once they've adapted to local life.
            But going in with open eyes helps you prepare for the adjustment period and build the support systems you'll need.
          </p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-green-50 border border-green-200 rounded-lg p-5">
              <h3 class="font-semibold text-green-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Advantages
              </h3>
              <ul class="space-y-2">
                {data.advantages.slice(0, 4).map((item) => (
                  <li class="text-neutral-700 text-sm flex items-start gap-2">
                    <span class="text-green-600 mt-1">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-5">
              <h3 class="font-semibold text-amber-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Challenges
              </h3>
              <ul class="space-y-2">
                {data.challenges.slice(0, 4).map((item) => (
                  <li class="text-neutral-700 text-sm flex items-start gap-2">
                    <span class="text-amber-600 mt-1">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>

        <!-- Cost of Living -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Cost of Living</h2>
          <p class="text-neutral-700 mb-4">
            Budget expectations for {persona.name.toLowerCase()} in {country.name} vary based on lifestyle and location.
            Here's a realistic breakdown based on what {persona.name.toLowerCase()} actually spend, not best-case scenarios.
          </p>
          {costProse.map((paragraph) => (
            <p class="text-neutral-700 mb-4">{paragraph}</p>
          ))}
          <div class="grid sm:grid-cols-3 gap-4">
            <div class="bg-white border border-neutral-200 rounded-lg p-5 text-center">
              <p class="text-sm text-neutral-500 mb-1">Budget</p>
              <p class="text-2xl font-bold text-neutral-900">{data.monthlyBudget.low}</p>
              <p class="text-xs text-neutral-500 mt-1">per month</p>
            </div>
            <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 text-center">
              <p class="text-sm text-neutral-500 mb-1">Comfortable</p>
              <p class="text-2xl font-bold text-primary-700">{data.monthlyBudget.mid}</p>
              <p class="text-xs text-neutral-500 mt-1">per month</p>
            </div>
            <div class="bg-white border border-neutral-200 rounded-lg p-5 text-center">
              <p class="text-sm text-neutral-500 mb-1">Premium</p>
              <p class="text-2xl font-bold text-neutral-900">{data.monthlyBudget.high}</p>
              <p class="text-xs text-neutral-500 mt-1">per month</p>
            </div>
          </div>
          <p class="text-sm text-neutral-500 mt-4">
            These estimates include housing, food, transportation, entertainment, and health insurance.
            Actual costs vary significantly by city and lifestyle.
          </p>
        </section>

        <!-- Popular Areas -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">Popular Areas for {persona.name}</h2>
          <p class="text-neutral-700 mb-4">
            Where you live in {country.name} affects healthcare access, cost of living, and community.
            These areas are popular with {persona.name.toLowerCase()} for good reasons—established expat communities, reliable infrastructure, and accessible services.
          </p>
          {locationProse.map((paragraph) => (
            <p class="text-neutral-700 mb-4">{paragraph}</p>
          ))}
          <p class="text-neutral-700 mb-4">
            Don't limit yourself to the most popular areas, though. Many {persona.name.toLowerCase()} find hidden gems—smaller towns or neighborhoods that offer better value and a more authentic experience.
            Visit before committing to a long-term lease, and consider starting in a popular area while you explore alternatives.
          </p>
          <div class="flex flex-wrap gap-2">
            {data.popularAreas.map((area) => (
              <span class="px-4 py-2 bg-neutral-100 text-neutral-700 rounded-lg text-sm">
                {area}
              </span>
            ))}
          </div>
        </section>

        <!-- FAQs -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-6">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <details class="group bg-white border border-neutral-200 rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer p-5 font-medium text-neutral-900">
                  {faq.question}
                  <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-neutral-700">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Bottom Line -->
        <section class="not-prose mb-10">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">The Bottom Line</h2>
          <p class="text-neutral-700 mb-4">
            Choosing to live in {country.name} as a {persona.singular} is a significant decision that requires careful planning.
            Health insurance is a crucial piece of that plan—not just to satisfy visa requirements, but to ensure you can access quality healthcare when you need it.
          </p>
          <p class="text-neutral-700 mb-4">
            The insurance market for {persona.name.toLowerCase()} has matured considerably. You have real options now, from budget-friendly plans to comprehensive coverage that rivals what you'd get at home.
            The key is matching your coverage to your actual needs, not just picking the cheapest option or the most expensive one.
          </p>
          <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
            <p class="text-neutral-700 mb-4">
              {country.name} is a {data.advantages.length > 3 ? 'great' : 'viable'} destination for {persona.name.toLowerCase()}.
              {country.insuranceRequired
                ? `Since health insurance is required for most visas, make sure you choose a plan that meets visa requirements while also providing comprehensive coverage.`
                : `While insurance isn't mandatory, investing in quality coverage protects you from potentially high medical costs and gives you peace of mind.`
              }
            </p>
            <p class="text-neutral-700 mb-4">
              We recommend comparing at least 2-3 providers before committing.
              Consider your specific needs—{persona.keyNeeds.slice(0, 2).join(' and ').toLowerCase()}—when evaluating plans.
            </p>
            <p class="text-neutral-700">
              Start your research now, even if your move is months away. Some insurers have waiting periods for certain coverages, and getting approved can take time.
              The earlier you have coverage sorted, the less stress you'll have as your move date approaches.
            </p>
          </div>
        </section>

      </article>

      <StickySidebar
        ctaTitle={`${persona.name} in ${country.name}`}
        ctaDescription={`Compare insurance options for ${persona.name.toLowerCase()} in ${country.name}.`}
        ctaButtonText="Compare Plans"
        ctaButtonHref={`/countries/${country.slug}/insurance`}
        relatedLinks={sidebarLinks}
      />
    </div>

    <!-- Related Content -->
    <section class="mt-16 border-t border-neutral-200 pt-12">
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Related Resources</h2>
      <ContentCards cards={relatedCards} columns={3} />
    </section>
  </div>
</Layout>
