---
/**
 * RegionalHub.astro
 *
 * Template for regional hub pages like /regions/southeast-asia
 * These pages link to all countries in a region and help with SEO for regional queries.
 *
 * STRUCTURE:
 * 1. HERO: Region headline + subheadline
 * 2. Key Highlights
 * 3. Featured Countries grid
 * 4. Best For / Considerations
 * 5. All Countries in Region
 * 6. Related Resources
 */

import Layout from '../layouts/Layout.astro';
import CTABox from '../components/CTABox.astro';
import AuthorBox from '../components/AuthorBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import StickySidebar from '../components/StickySidebar.astro';
import Disclosure from '../components/Disclosure.astro';

import type { Region } from '../data/regions';
import type { Country } from '../data/types';

interface CountryCard {
  slug: string;
  name: string;
  insuranceRequired: boolean;
  href: string;
}

interface Props {
  /** Region data */
  region: Region;
  /** Featured country details */
  featuredCountries: CountryCard[];
  /** All countries in region */
  allCountries: CountryCard[];
}

const { region, featuredCountries, allCountries } = Astro.props;

// Generate TOC items
const tocItems = [
  { id: 'highlights', text: 'Key Highlights', level: 2 },
  { id: 'featured-countries', text: 'Featured Countries', level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
  { id: 'considerations', text: 'Considerations', level: 2 },
  { id: 'all-countries', text: 'All Countries', level: 2 },
];

// Author info
const author = {
  name: 'John Spencer',
  bio: 'John Spencer is the founder of Compare Expat Plans, focusing on clear, neutral information to help people find health coverage abroad.',
  image: '/images/john-spencer.png',
};

// Sidebar links
const sidebarLinks = [
  { title: 'Best Expat Health Insurance', href: '/best/expat-health-insurance' },
  { title: 'Insurance for Digital Nomads', href: '/insurance-for/digital-nomads' },
  { title: 'Insurance for Retirees', href: '/insurance-for/retirees' },
  { title: 'All Countries', href: '/countries' },
];

// Breadcrumb schema
const siteUrl = "https://compareexpatplans.com";
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Regions", "item": `${siteUrl}/regions` },
    { "@type": "ListItem", "position": 3, "name": region.name },
  ],
};
---

<Layout title={region.metaTitle} description={region.metaDescription} ogType="article">
  <!-- Structured Data -->
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- HERO SECTION -->
  <section class="relative bg-gradient-to-b from-neutral-50 to-white py-10 lg:py-14 border-b border-neutral-200 overflow-hidden">
    {region.heroImage && (
      <div class="absolute inset-0 z-0">
        <img
          src={region.heroImage}
          alt=""
          class="w-full h-full object-cover opacity-30"
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-white"></div>
      </div>
    )}
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-primary-600 mb-2">
          <a href="/regions" class="hover:underline">Regions</a>
          {' → '}
          <span>{region.name}</span>
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          {region.headline}
        </h1>
        <p class="text-lg text-neutral-600 mb-6">
          {region.subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href="/best/expat-health-insurance"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            Compare Plans for {region.name}
          </a>
          <a
            href="#featured-countries"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            View Countries ↓
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <!-- Main Content -->
      <article class="flex-1 min-w-0">

        <!-- TOP META -->
        <div class="mb-8">
          <AuthorBox
            name={author.name}
            bio={author.bio}
            image={author.image}
          />
        </div>

        <!-- TOC (Mobile) -->
        <div class="lg:hidden mb-8">
          <TableOfContents items={tocItems} />
        </div>

        <!-- CONTENT -->
        <div class="prose prose-neutral max-w-none">

          <!-- Key Highlights -->
          <h2 id="highlights">Key Highlights: Health Insurance in {region.name}</h2>
          <ul>
            {region.highlights.map(highlight => (
              <li>{highlight}</li>
            ))}
          </ul>

          <CTABox
            title={`Moving to ${region.name}?`}
            description="Compare plans that work across the region."
            buttonText="Compare Plans →"
            buttonHref="/best/expat-health-insurance"
            variant="highlight"
            showDisclosure={false}
          />

          <!-- Featured Countries -->
          <h2 id="featured-countries">Featured Countries in {region.name}</h2>
          <p>
            These are the most popular destinations for expats in {region.name}. Click through for detailed coverage guides.
          </p>
        </div>

        <!-- Featured Country Cards -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 my-8">
          {featuredCountries.map(country => (
            <a
              href={country.href}
              class="block bg-white border border-neutral-200 rounded-lg p-5 hover:border-primary-300 hover:shadow-md transition-all"
            >
              <h3 class="font-semibold text-neutral-900 mb-2">{country.name}</h3>
              <p class="text-sm text-neutral-600">
                {country.insuranceRequired ? (
                  <span class="inline-flex items-center text-amber-700">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    Insurance required for visa
                  </span>
                ) : (
                  <span class="text-green-700">Insurance recommended</span>
                )}
              </p>
              <p class="text-sm text-primary-600 mt-2 font-medium">View guide →</p>
            </a>
          ))}
        </div>

        <div class="prose prose-neutral max-w-none">
          <!-- Best For -->
          <h2 id="best-for">Who {region.name} Is Best For</h2>
          <ul>
            {region.bestFor.map(item => (
              <li>{item}</li>
            ))}
          </ul>

          <!-- Considerations -->
          <h2 id="considerations">Considerations for {region.name}</h2>
          <ul>
            {region.considerations.map(item => (
              <li>{item}</li>
            ))}
          </ul>

          <CTABox
            title="Find the Right Coverage"
            description={`Compare plans that meet ${region.name} requirements.`}
            buttonText="Compare Plans"
            buttonHref="/best/expat-health-insurance"
            showDisclosure={false}
          />

          <!-- All Countries -->
          <h2 id="all-countries">All Countries in {region.name}</h2>
          <p>
            Complete list of countries in {region.name} with health insurance guides:
          </p>
        </div>

        <!-- All Countries Grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 my-8">
          {allCountries.map(country => (
            <a
              href={country.href}
              class="block bg-neutral-50 border border-neutral-200 rounded-lg px-4 py-3 hover:border-primary-300 hover:bg-white transition-all text-sm"
            >
              <span class="font-medium text-neutral-900">{country.name}</span>
              {country.insuranceRequired && (
                <span class="ml-1 text-amber-600" title="Insurance required">*</span>
              )}
            </a>
          ))}
        </div>

        <p class="text-sm text-neutral-500 mb-8">
          * Insurance required for visa/residence permit
        </p>

        <!-- Related Resources -->
        <div class="prose prose-neutral max-w-none">
          <h2>Related Resources</h2>
          <ul>
            <li><a href="/best/expat-health-insurance">Best Expat Health Insurance 2025</a></li>
            <li><a href="/insurance-for/digital-nomads">Insurance for Digital Nomads</a></li>
            <li><a href="/insurance-for/retirees">Insurance for Retirees Abroad</a></li>
            <li><a href="/guides/medical-evacuation">Understanding Medical Evacuation Coverage</a></li>
          </ul>
        </div>

        <!-- DISCLAIMER -->
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
          <p class="text-sm text-neutral-600">
            <strong>Disclaimer:</strong> This guide is for informational purposes only. Healthcare systems, insurance requirements, and visa rules change. We are not insurance brokers or licensed advisors. Verify all information with official sources before making decisions.
          </p>
        </div>
      </article>

      <!-- Sticky Sidebar (Desktop) -->
      <StickySidebar
        ctaTitle={`Coverage for ${region.name}`}
        ctaDescription="Compare plans across the region."
        ctaButtonText="Compare Plans →"
        ctaButtonHref="/best/expat-health-insurance"
        relatedLinks={sidebarLinks}
      />
    </div>
  </div>
</Layout>
