---
/**
 * CountryProviderPage.astro
 *
 * Reusable template for country-provider pages.
 * E.g., /countries/germany/insurance/cigna-global
 *
 * These pages help users understand how a specific provider
 * works in a specific country context.
 *
 * STRUCTURE:
 * 1. HERO: Provider + Country headline
 * 2. Overview: Why this provider for this country
 * 3. Best For / Not Ideal For
 * 4. Key Facts table
 * 5. How to Use in This Country
 * 6. Alternatives
 * 7. CTA
 */

import Layout from '../layouts/Layout.astro';
import CTABox from '../components/CTABox.astro';
import AuthorBox from '../components/AuthorBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import StickySidebar from '../components/StickySidebar.astro';
import Disclosure from '../components/Disclosure.astro';

import type { Country, Provider, ProviderInCountry } from '../data/types';

interface Props {
  /** Country data */
  country: Country;
  /** Provider data */
  provider: Provider;
  /** Country-specific provider info */
  providerInCountry: ProviderInCountry;
  /** Other providers available in this country (for alternatives) */
  alternativeProviders: Array<{
    name: string;
    slug: string;
    bestFor: string;
    href: string;
  }>;
}

const { country, provider, providerInCountry, alternativeProviders } = Astro.props;

// Generate TOC items
const tocItems = [
  { id: 'overview', text: `${provider.name} in ${country.name}`, level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
  { id: 'key-facts', text: 'Key Facts', level: 2 },
  { id: 'how-to-use', text: 'How to Use Your Coverage', level: 2 },
  { id: 'alternatives', text: 'Alternatives to Consider', level: 2 },
];

// Author info
const author = {
  name: 'John Spencer',
  bio: 'John Spencer is the founder of Compare Expat Plans, focusing on clear, neutral information to help people find health coverage abroad.',
  image: '/images/john-spencer.png',
};

// Sidebar links
const sidebarLinks = [
  { title: `Health Insurance in ${country.name}`, href: `/countries/${country.slug}/insurance` },
  { title: `${provider.name} Review`, href: provider.href },
  { title: 'Compare All Providers', href: '/best/expat-health-insurance' },
];

// Breadcrumb schema
const siteUrl = "https://compareexpatplans.com";
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Countries", "item": `${siteUrl}/countries` },
    { "@type": "ListItem", "position": 3, "name": country.name, "item": `${siteUrl}/countries/${country.slug}` },
    { "@type": "ListItem", "position": 4, "name": "Insurance", "item": `${siteUrl}/countries/${country.slug}/insurance` },
    { "@type": "ListItem", "position": 5, "name": provider.name },
  ],
};

const pageTitle = `${provider.name} Health Insurance in ${country.name} (2025 Guide)`;
const pageDescription = `Is ${provider.name} right for expats in ${country.name}? Coverage details, costs, network info, and how it compares to alternatives.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
  <!-- Structured Data -->
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- HERO SECTION -->
  <section class="relative bg-gradient-to-b from-neutral-50 to-white py-10 lg:py-14 border-b border-neutral-200 overflow-hidden">
    {country.heroImage && (
      <div class="absolute inset-0 z-0">
        <img
          src={country.heroImage}
          alt=""
          class="w-full h-full object-cover opacity-30"
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-white"></div>
      </div>
    )}
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-primary-600 mb-2">
          <a href={`/countries/${country.slug}/insurance`} class="hover:underline">
            {country.name} Insurance
          </a>
          {' → '}
          <span>{provider.name}</span>
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          {provider.name} Health Insurance in {country.name}
        </h1>
        <p class="text-lg text-neutral-600 mb-6">
          {provider.tagline}. Here's how it works for expats living in {country.name}.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href={provider.href}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            Get a {provider.name} Quote
          </a>
          <a
            href={`/countries/${country.slug}/insurance`}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            See All {country.name} Options
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <!-- Main Content -->
      <article class="flex-1 min-w-0">

        <!-- TOP META -->
        <div class="mb-8">
          <AuthorBox
            name={author.name}
            bio={author.bio}
            image={author.image}
          />
          <p class="text-sm text-neutral-500 mt-3">
            Last updated: {new Date(country.lastUpdated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </p>
        </div>

        <!-- TOC (Mobile) -->
        <div class="lg:hidden mb-8">
          <TableOfContents items={tocItems} />
        </div>

        <!-- CONTENT -->
        <div class="prose prose-neutral max-w-none">

          <!-- Overview -->
          <h2 id="overview">{provider.name} in {country.name}</h2>
          <p>
            {provider.name} is {provider.type === 'international' ? 'an international health insurance provider' : provider.type === 'local' ? 'a local health insurance provider' : 'a public healthcare option'} that offers coverage for expats in {country.name}.
            {provider.coverageStyle.includes('comprehensive') || provider.coverageStyle.includes('premium')
              ? ` With ${provider.coverageStyle.toLowerCase()} coverage, it's designed for expats who want thorough protection.`
              : ` With ${provider.coverageStyle.toLowerCase()} coverage, it provides a specific type of protection.`
            }
          </p>
          <p>
            {country.insuranceRequired
              ? `${country.name} requires health insurance for most visa types. ${provider.name} is widely accepted for visa applications.`
              : `While ${country.name} doesn't strictly require health insurance, private coverage like ${provider.name} gives you access to faster, higher-quality care.`
            }
          </p>

          <!-- Best For / Not Ideal For -->
          <h2 id="best-for">Who It's Best For</h2>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class="bg-green-50 border border-green-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-green-900 mb-3">Best For</h3>
              <p class="text-green-800">{providerInCountry.bestFor}</p>
            </div>
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-amber-900 mb-3">Not Ideal For</h3>
              <p class="text-amber-800">{providerInCountry.notIdealFor}</p>
            </div>
          </div>

          <!-- Key Facts -->
          <h2 id="key-facts">Key Facts</h2>

          <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden not-prose">
            <table class="w-full">
              <tbody class="divide-y divide-neutral-200">
                <tr>
                  <td class="px-4 py-3 font-medium text-neutral-900 bg-neutral-50 w-1/3">Provider Type</td>
                  <td class="px-4 py-3 text-neutral-600">{provider.type === 'international' ? 'International' : provider.type === 'local' ? 'Local/Regional' : 'Public'}</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 font-medium text-neutral-900 bg-neutral-50">Coverage Style</td>
                  <td class="px-4 py-3 text-neutral-600">{provider.coverageStyle}</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 font-medium text-neutral-900 bg-neutral-50">Includes US Coverage</td>
                  <td class="px-4 py-3 text-neutral-600">
                    {provider.includesUS ? (
                      <span class="text-green-600 font-medium">Yes (optional add-on for some plans)</span>
                    ) : (
                      <span class="text-neutral-500">No</span>
                    )}
                  </td>
                </tr>
                <tr>
                  <td class="px-4 py-3 font-medium text-neutral-900 bg-neutral-50">Notable Limitations</td>
                  <td class="px-4 py-3 text-neutral-600">{providerInCountry.notableLimitsOverride || provider.notableLimits}</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 font-medium text-neutral-900 bg-neutral-50">Visa Compliance ({country.name})</td>
                  <td class="px-4 py-3 text-neutral-600">
                    {provider.type === 'international'
                      ? 'Generally accepted—verify with consulate for specific visa type'
                      : provider.type === 'local'
                        ? 'Accepted for local requirements'
                        : 'N/A—public healthcare'
                    }
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <CTABox
            title={`Get a ${provider.name} Quote`}
            description={`See pricing for ${country.name}-based expats.`}
            buttonText="Get Quote"
            buttonHref={provider.href}
            variant="highlight"
            showDisclosure={false}
          />

          <!-- How to Use -->
          <h2 id="how-to-use">How to Use Your {provider.name} Coverage in {country.name}</h2>

          <h3>Finding Providers</h3>
          <p>
            {provider.type === 'international'
              ? `${provider.name} has a network of hospitals and clinics in ${country.name}. Use their online provider finder or mobile app to locate network providers in your area. Major cities typically have extensive options.`
              : provider.type === 'local'
                ? `As a local provider, ${provider.name} has an extensive network within ${country.name}. Check their website for the full list of participating hospitals and clinics.`
                : `Access is through public healthcare facilities in ${country.name}.`
            }
          </p>

          <h3>Direct Billing vs Reimbursement</h3>
          <ul>
            <li><strong>Network hospitals:</strong> Show your insurance card for direct billing—you pay only your deductible or copay.</li>
            <li><strong>Out-of-network:</strong> Pay upfront and submit claims for reimbursement (typically processed within 5-15 business days).</li>
          </ul>

          <h3>Emergency Care</h3>
          <p>
            In emergencies, go to the nearest hospital regardless of network status. Contact {provider.name} within 48 hours to coordinate coverage. Emergency care is typically covered at any facility.
          </p>

          <h3>Claims and Support</h3>
          <p>
            {provider.type === 'international'
              ? `${provider.name} offers 24/7 customer support in English. Claims can be submitted via their mobile app or online portal.`
              : `Contact ${provider.name} directly for claims support and questions about your coverage.`
            }
          </p>

          <!-- Alternatives -->
          <h2 id="alternatives">Alternatives to Consider</h2>
          <p>
            {provider.name} isn't the only option for expats in {country.name}. Here are other providers to compare:
          </p>

          <div class="grid md:grid-cols-2 gap-4 my-8 not-prose">
            {alternativeProviders.slice(0, 4).map(alt => (
              <a href={alt.href} class="block bg-white border border-neutral-200 rounded-lg p-5 hover:border-primary-300 hover:shadow-md transition-all">
                <h3 class="font-semibold text-neutral-900 mb-2">{alt.name}</h3>
                <p class="text-sm text-neutral-600">
                  <span class="text-green-700 font-medium">Best for:</span> {alt.bestFor}
                </p>
              </a>
            ))}
          </div>

          <p>
            <a href={`/countries/${country.slug}/insurance`}>See all insurance options for {country.name} →</a>
          </p>

          <CTABox
            title={`Compare ${provider.name} to Alternatives`}
            description={`Find the best fit for your situation in ${country.name}.`}
            buttonText="Compare Plans"
            buttonHref={`/countries/${country.slug}/insurance`}
            showDisclosure={false}
          />

        </div>

        <!-- DISCLAIMER -->
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
          <p class="text-sm text-neutral-600">
            <strong>Disclaimer:</strong> This guide is for informational purposes only. Coverage details, pricing, and network availability change. We are not insurance brokers or licensed advisors. Verify all information with {provider.name} and relevant authorities before making decisions.
          </p>
        </div>
      </article>

      <!-- Sticky Sidebar (Desktop) -->
      <StickySidebar
        ctaTitle={`${provider.name} in ${country.name}`}
        ctaDescription="Get a quote for your situation."
        ctaButtonText="Get Quote"
        ctaButtonHref={provider.href}
        relatedLinks={sidebarLinks}
      />
    </div>
  </div>
</Layout>
