---
/**
 * CountryProviderPage.astro
 *
 * Reusable template for country-provider pages.
 * E.g., /countries/germany/insurance/cigna-global
 *
 * ENHANCED with generated content sections for richer pages.
 */

import Layout from '../layouts/Layout.astro';
import CTABox from '../components/CTABox.astro';
import AuthorBox from '../components/AuthorBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import StickySidebar from '../components/StickySidebar.astro';
import Disclosure from '../components/Disclosure.astro';

import type { Country, Provider, ProviderInCountry } from '../data/types';

interface Props {
  country: Country;
  provider: Provider;
  providerInCountry: ProviderInCountry;
  alternativeProviders: Array<{
    name: string;
    slug: string;
    bestFor: string;
    href: string;
  }>;
}

const { country, provider, providerInCountry, alternativeProviders } = Astro.props;

// =====================
// HELPER FUNCTIONS FOR GENERATED CONTENT
// =====================

/**
 * Get quick stats for the provider in this country
 */
function getQuickStats(provider: Provider, country: Country): Array<{value: string; label: string}> {
  const stats: Array<{value: string; label: string}> = [];

  if (provider.type === 'international') {
    stats.push({ value: '200+', label: 'Countries covered' });
    stats.push({ value: '24/7', label: 'English support' });
    if (provider.includesUS) {
      stats.push({ value: 'Yes', label: 'US coverage available' });
    }
  } else if (provider.type === 'local') {
    stats.push({ value: country.name, label: 'Coverage area' });
    stats.push({ value: 'Local', label: 'Support language' });
  }

  // Add visa compliance stat
  if (country.insuranceRequired) {
    stats.push({ value: '✓', label: 'Visa compliant' });
  }

  return stats.slice(0, 4);
}

/**
 * Get visa compliance information
 */
function getVisaInfo(provider: Provider, country: Country): { compliant: boolean; details: string[]; tip: string } {
  const details: string[] = [];
  let tip = '';

  if (country.insuranceRequired) {
    if (provider.type === 'international') {
      details.push(`${provider.name} plans are generally accepted for ${country.name} visa applications`);
      details.push('Coverage must be valid for the entire visa duration');
      details.push('Request a visa compliance letter from your insurer');

      if (provider.slug === 'cigna-global' || provider.slug === 'allianz-care' || provider.slug === 'bupa-global') {
        tip = `${provider.name} provides visa compliance letters upon request. Choose a plan with outpatient coverage to meet most visa requirements.`;
      } else {
        tip = `Verify with the ${country.name} consulate that ${provider.name} meets their specific requirements before purchasing.`;
      }
    } else {
      details.push(`${provider.name} is accepted for local insurance requirements`);
      tip = 'Local insurers are typically accepted but may not cover you outside the country.';
    }
  } else {
    details.push(`${country.name} doesn't strictly require health insurance for most visa types`);
    details.push('However, private coverage is strongly recommended for quality care');
    tip = 'Even without a requirement, having coverage protects you from unexpected medical costs.';
  }

  return { compliant: country.insuranceRequired, details, tip };
}

/**
 * Get network and hospital information
 */
function getNetworkInfo(provider: Provider, country: Country): { description: string; features: string[]; considerations: string[] } {
  const features: string[] = [];
  const considerations: string[] = [];
  let description = '';

  if (provider.type === 'international') {
    description = `${provider.name} maintains a network of hospitals and clinics in ${country.name}. Major cities typically have multiple in-network options with direct billing available.`;
    features.push('Use online provider finder or mobile app to locate network providers');
    features.push('Direct billing available at major network hospitals');
    features.push('Can use any licensed provider with reimbursement option');
    features.push('24/7 assistance line can help locate nearby care');

    considerations.push('Network coverage is strongest in major cities and expat areas');
    considerations.push('Rural areas may require travel to larger cities or reimbursement claims');
    considerations.push('Verify specific hospitals are in-network before planned procedures');
  } else {
    description = `As a local provider, ${provider.name} has an extensive network within ${country.name}, often with more options than international insurers.`;
    features.push('Extensive local hospital and clinic network');
    features.push('Direct relationships with local providers');
    features.push('Often includes smaller clinics not covered by international plans');

    considerations.push('Coverage typically limited to within the country');
    considerations.push('May not cover care while traveling abroad');
  }

  return { description, features, considerations };
}

/**
 * Get pricing guidance based on country cost level
 */
function getPricingGuidance(provider: Provider, country: Country): { range: string; factors: string[]; savingsTips: string[] } {
  // Determine cost level from country's privateHealthcare cost field
  const costStr = country.privateHealthcare?.cost?.toLowerCase() || '';
  let costLevel: 'low' | 'medium' | 'high' = 'medium';

  if (costStr.includes('50') || costStr.includes('60') || costStr.includes('80')) {
    costLevel = 'low';
  } else if (costStr.includes('200') || costStr.includes('300') || costStr.includes('400') || costStr.includes('500')) {
    costLevel = 'high';
  }

  let range = '';
  const factors: string[] = [];
  const savingsTips: string[] = [];

  if (provider.type === 'international') {
    switch(costLevel) {
      case 'low':
        range = '$100-200/month for comprehensive coverage';
        savingsTips.push('Consider a higher deductible—routine care is affordable locally');
        savingsTips.push('Pay for minor care out of pocket and use insurance for major expenses');
        break;
      case 'high':
        range = '$200-400/month for comprehensive coverage';
        savingsTips.push('Higher deductible plans can significantly reduce premiums');
        savingsTips.push('Consider excluding US coverage if you don\'t need it (saves 30-40%)');
        break;
      default:
        range = '$150-300/month for comprehensive coverage';
        savingsTips.push('Balance deductible level with your expected usage');
    }

    factors.push('Age (premiums increase significantly after 50)');
    factors.push('Deductible amount ($0-$5,000+ options available)');
    factors.push('Coverage area (worldwide vs regional)');
    factors.push('US coverage inclusion (adds 30-50% to premium)');
    factors.push('Add-ons like dental, vision, maternity');
  } else {
    range = country.privateHealthcare?.cost || '$80-200/month';
    factors.push('Age and health status');
    factors.push('Coverage level selected');
    factors.push('Add-on benefits');
    savingsTips.push('Local plans often offer better value for in-country coverage');
  }

  return { range, factors, savingsTips };
}

/**
 * Get comparison with local options
 */
function getLocalComparison(provider: Provider, country: Country): Array<{factor: string; international: string; local: string}> {
  if (provider.type !== 'international') return [];

  return [
    { factor: 'Monthly Cost', international: 'Higher ($150-300+)', local: 'Lower ($60-150)' },
    { factor: 'Coverage Area', international: 'Worldwide', local: `${country.name} only` },
    { factor: 'Language Support', international: 'English 24/7', local: 'Often local language' },
    { factor: 'Network Size', international: 'Good in major cities', local: 'Very extensive locally' },
    { factor: 'If You Move Countries', international: 'Coverage continues', local: 'Must cancel and restart' },
    { factor: 'Claims Process', international: 'International standard', local: 'Local process' },
    { factor: 'Pre-existing Conditions', international: 'Underwriting required', local: 'Varies by insurer' },
  ];
}

/**
 * Get common scenarios for this provider in this country
 */
function getCommonScenarios(provider: Provider, country: Country): Array<{scenario: string; recommendation: string}> {
  const scenarios: Array<{scenario: string; recommendation: string}> = [];

  if (provider.type === 'international') {
    scenarios.push({
      scenario: 'Digital nomad staying 6-12 months',
      recommendation: `${provider.name} works well—coverage continues if you move to another country, and meets most visa requirements.`
    });
    scenarios.push({
      scenario: 'Retiree settling long-term',
      recommendation: `Consider whether you need worldwide coverage. If staying put, a local insurer might offer better value. ${provider.name} is better if you travel frequently.`
    });
    scenarios.push({
      scenario: 'Family with children',
      recommendation: `${provider.name} offers family plans with pediatric coverage. Check maternity benefits if planning more children (usually 10-12 month waiting period).`
    });
    scenarios.push({
      scenario: 'Remote worker traveling regularly',
      recommendation: `Ideal fit—${provider.name}'s worldwide coverage means you're protected whether in ${country.name} or traveling for work.`
    });
  } else {
    scenarios.push({
      scenario: 'Long-term resident (5+ years)',
      recommendation: `${provider.name} offers excellent value if you're committed to staying in ${country.name}. Best local network coverage.`
    });
    scenarios.push({
      scenario: 'Budget-conscious expat',
      recommendation: `Local coverage from ${provider.name} costs less than international plans while providing comprehensive in-country care.`
    });
  }

  return scenarios;
}

/**
 * Get FAQs for this provider in this country
 */
function getFAQs(provider: Provider, country: Country): Array<{question: string; answer: string}> {
  const faqs: Array<{question: string; answer: string}> = [];

  faqs.push({
    question: `Is ${provider.name} accepted for ${country.name} visa applications?`,
    answer: country.insuranceRequired
      ? `${provider.name} is generally accepted for ${country.name} visa applications. Request a visa compliance letter from the insurer confirming your coverage meets requirements. Always verify with the specific consulate handling your application.`
      : `${country.name} doesn't require health insurance for most visa types, so acceptance isn't typically an issue. However, having proof of coverage can strengthen your application.`
  });

  faqs.push({
    question: `Can I use any hospital in ${country.name} with ${provider.name}?`,
    answer: `You can receive care at any licensed medical facility in ${country.name}. Network hospitals offer direct billing (cashless treatment). For non-network providers, you pay upfront and submit a claim for reimbursement, typically processed within 5-15 business days.`
  });

  if (provider.type === 'international') {
    faqs.push({
      question: `What if I leave ${country.name}?`,
      answer: `Your ${provider.name} coverage continues wherever you go. Simply update your residence country with the insurer. This is a major advantage over local insurance, which typically ends when you leave.`
    });

    faqs.push({
      question: `How does ${provider.name} compare to local ${country.demonym} insurers?`,
      answer: `${provider.name} costs more but offers worldwide coverage, English support, and portability. Local insurers cost less with more extensive in-country networks. Choose ${provider.name} if you travel frequently or might relocate; choose local if you're staying long-term and want lower costs.`
    });
  }

  faqs.push({
    question: `How do I find doctors and hospitals?`,
    answer: provider.type === 'international'
      ? `Use ${provider.name}'s online provider finder or mobile app. You can search by location, specialty, and language. The 24/7 assistance line can also help locate care anywhere in ${country.name}.`
      : `${provider.name} provides a directory of participating providers on their website. As a local insurer, they typically have the most extensive network in ${country.name}.`
  });

  faqs.push({
    question: `What's not covered by ${provider.name}?`,
    answer: `Common exclusions include: pre-existing conditions (may be covered after waiting period or with loading), cosmetic procedures, experimental treatments, and injuries from extreme sports (may require add-on). Dental and vision are typically optional add-ons. Review your specific policy for complete exclusion list.`
  });

  return faqs;
}

// =====================
// GENERATE CONTENT
// =====================

const quickStats = getQuickStats(provider, country);
const visaInfo = getVisaInfo(provider, country);
const networkInfo = getNetworkInfo(provider, country);
const pricingGuidance = getPricingGuidance(provider, country);
const localComparison = getLocalComparison(provider, country);
const commonScenarios = getCommonScenarios(provider, country);
const faqs = getFAQs(provider, country);

// Generate TOC items
const tocItems = [
  { id: 'overview', text: `${provider.name} in ${country.name}`, level: 2 },
  { id: 'best-for', text: 'Who It\'s Best For', level: 2 },
  { id: 'visa-compliance', text: 'Visa & Requirements', level: 2 },
  { id: 'network', text: 'Network & Hospitals', level: 2 },
  { id: 'pricing', text: 'Pricing Guide', level: 2 },
  ...(localComparison.length > 0 ? [{ id: 'vs-local', text: 'vs Local Options', level: 2 }] : []),
  { id: 'scenarios', text: 'Common Scenarios', level: 2 },
  { id: 'how-to-use', text: 'Using Your Coverage', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
  { id: 'alternatives', text: 'Alternatives', level: 2 },
];

const author = {
  name: 'John Spencer',
  bio: 'John Spencer is the founder of Compare Expat Plans, focusing on clear, neutral information to help people find health coverage abroad.',
  image: '/images/john-spencer.png',
};

const sidebarLinks = [
  { title: `Health Insurance in ${country.name}`, href: `/countries/${country.slug}/insurance` },
  { title: `${provider.name} Review`, href: provider.href },
  { title: 'Compare All Providers', href: '/best/expat-health-insurance' },
];

const siteUrl = "https://compareexpatplans.com";
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Countries", "item": `${siteUrl}/countries` },
    { "@type": "ListItem", "position": 3, "name": country.name, "item": `${siteUrl}/countries/${country.slug}` },
    { "@type": "ListItem", "position": 4, "name": "Insurance", "item": `${siteUrl}/countries/${country.slug}/insurance` },
    { "@type": "ListItem", "position": 5, "name": provider.name },
  ],
};

const pageTitle = `${provider.name} Health Insurance in ${country.name} (2025 Guide)`;
const pageDescription = `Complete guide to ${provider.name} for expats in ${country.name}. Visa compliance, network coverage, pricing, and how it compares to local options.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article" noindex={true}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- HERO SECTION -->
  <section class="relative bg-gradient-to-b from-neutral-50 to-white py-10 lg:py-14 border-b border-neutral-200 overflow-hidden">
    {country.heroImage && (
      <div class="absolute inset-0 z-0">
        <img
          src={country.heroImage}
          alt=""
          class="w-full h-full object-cover opacity-30"
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-white"></div>
      </div>
    )}
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-primary-600 mb-2">
          <a href={`/countries/${country.slug}/insurance`} class="hover:underline">
            {country.name} Insurance
          </a>
          {' → '}
          <span>{provider.name}</span>
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          {provider.name} Health Insurance in {country.name}
        </h1>
        <p class="text-lg text-neutral-600 mb-6">
          {provider.tagline}. Here's everything you need to know about using {provider.name} as an expat in {country.name}.
        </p>

        <!-- Quick Stats -->
        {quickStats.length > 0 && (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
            {quickStats.map(stat => (
              <div class="bg-white/80 backdrop-blur border border-neutral-200 rounded-lg p-3 text-center">
                <p class="text-xl font-bold text-primary-600">{stat.value}</p>
                <p class="text-xs text-neutral-600">{stat.label}</p>
              </div>
            ))}
          </div>
        )}

        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href={provider.href}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            Get a {provider.name} Quote
          </a>
          <a
            href={`/countries/${country.slug}/insurance`}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            See All {country.name} Options
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <article class="flex-1 min-w-0">

        <!-- TOP META -->
        <div class="mb-8">
          <AuthorBox name={author.name} bio={author.bio} image={author.image} />
          <p class="text-sm text-neutral-500 mt-3">
            Last updated: {new Date(country.lastUpdated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </p>
        </div>

        <!-- TOC (Mobile) -->
        <div class="lg:hidden mb-8">
          <TableOfContents items={tocItems} />
        </div>

        <!-- CONTENT -->
        <div class="prose prose-neutral max-w-none">

          <!-- Overview -->
          <h2 id="overview">{provider.name} in {country.name}</h2>
          <p>
            {provider.name} is {provider.type === 'international' ? 'a major international health insurance provider' : provider.type === 'local' ? 'a local health insurance provider' : 'a public healthcare option'} serving expats in {country.name}.
            {provider.coverageStyle.includes('comprehensive') || provider.coverageStyle.includes('premium')
              ? ` With ${provider.coverageStyle.toLowerCase()} coverage, it offers thorough protection for expats who want peace of mind.`
              : ` With ${provider.coverageStyle.toLowerCase()} coverage, it provides targeted protection for specific needs.`
            }
          </p>
          <p>
            {provider.type === 'international'
              ? `The key advantage of ${provider.name} over local ${country.demonym} insurers is portability—if you leave ${country.name}, your coverage comes with you. For expats who travel frequently or aren't certain they'll stay long-term, this flexibility is valuable.`
              : `As a local provider, ${provider.name} often offers more extensive in-country networks and lower costs than international alternatives, making it a strong choice for expats committed to ${country.name}.`
            }
          </p>

          <!-- Best For / Not Ideal For -->
          <h2 id="best-for">Who It's Best For</h2>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class="bg-green-50 border border-green-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-green-900 mb-3">Best For</h3>
              <p class="text-green-800">{providerInCountry.bestFor}</p>
            </div>
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-amber-900 mb-3">Not Ideal For</h3>
              <p class="text-amber-800">{providerInCountry.notIdealFor}</p>
            </div>
          </div>

          <!-- Visa & Requirements -->
          <h2 id="visa-compliance">Visa & Insurance Requirements</h2>

          {visaInfo.compliant ? (
            <div class="bg-green-50 border-l-4 border-green-500 p-4 my-6 not-prose">
              <p class="font-medium text-green-900">
                {country.name} requires health insurance for most visa types
              </p>
            </div>
          ) : (
            <div class="bg-blue-50 border-l-4 border-blue-500 p-4 my-6 not-prose">
              <p class="font-medium text-blue-900">
                Health insurance is not mandatory but strongly recommended
              </p>
            </div>
          )}

          <ul>
            {visaInfo.details.map(detail => <li>{detail}</li>)}
          </ul>

          {visaInfo.tip && (
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-5 my-6 not-prose">
              <h4 class="font-semibold text-amber-900 mb-2">Visa Tip</h4>
              <p class="text-amber-800 text-sm">{visaInfo.tip}</p>
            </div>
          )}

          <!-- Network & Hospitals -->
          <h2 id="network">Network & Hospital Coverage</h2>
          <p>{networkInfo.description}</p>

          <h3>What You Get</h3>
          <ul>
            {networkInfo.features.map(feature => <li>{feature}</li>)}
          </ul>

          <h3>Things to Know</h3>
          <ul>
            {networkInfo.considerations.map(consideration => <li>{consideration}</li>)}
          </ul>

          <CTABox
            title={`Check ${provider.name}'s Network`}
            description={`Verify coverage in your specific ${country.name} location before purchasing.`}
            buttonText="View Provider Details"
            buttonHref={provider.href}
            variant="highlight"
            showDisclosure={false}
          />

          <!-- Pricing Guide -->
          <h2 id="pricing">Pricing Guide for {country.name}</h2>
          <p>
            <strong>Typical cost:</strong> {pricingGuidance.range}
          </p>

          <h3>Factors That Affect Your Premium</h3>
          <ul>
            {pricingGuidance.factors.map(factor => <li>{factor}</li>)}
          </ul>

          {pricingGuidance.savingsTips.length > 0 && (
            <>
              <h3>Ways to Save</h3>
              <ul>
                {pricingGuidance.savingsTips.map(tip => <li>{tip}</li>)}
              </ul>
            </>
          )}

          <!-- vs Local Options (only for international providers) -->
          {localComparison.length > 0 && (
            <>
              <h2 id="vs-local">{provider.name} vs Local {country.demonym} Insurers</h2>
              <p>
                How does {provider.name} compare to local insurance options in {country.name}? Here's the key differences:
              </p>

              <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden not-prose">
                <table class="w-full text-sm">
                  <thead class="bg-neutral-50">
                    <tr>
                      <th class="px-4 py-3 text-left font-semibold text-neutral-900">Factor</th>
                      <th class="px-4 py-3 text-left font-semibold text-neutral-900">{provider.name}</th>
                      <th class="px-4 py-3 text-left font-semibold text-neutral-900">Local Insurers</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-neutral-200">
                    {localComparison.map(row => (
                      <tr>
                        <td class="px-4 py-3 font-medium text-neutral-900">{row.factor}</td>
                        <td class="px-4 py-3 text-neutral-600">{row.international}</td>
                        <td class="px-4 py-3 text-neutral-600">{row.local}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <p>
                <strong>Bottom line:</strong> Choose {provider.name} if you travel frequently or might relocate. Choose a local insurer if you're settling in {country.name} long-term and want lower costs with the best local network.
              </p>
            </>
          )}

          <!-- Common Scenarios -->
          <h2 id="scenarios">Common Scenarios</h2>
          <p>Here's how {provider.name} works for different expat situations in {country.name}:</p>

          <div class="space-y-4 my-6 not-prose">
            {commonScenarios.map(item => (
              <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-5">
                <h4 class="font-semibold text-neutral-900 mb-2">{item.scenario}</h4>
                <p class="text-neutral-600 text-sm">{item.recommendation}</p>
              </div>
            ))}
          </div>

          <!-- How to Use -->
          <h2 id="how-to-use">Using Your {provider.name} Coverage in {country.name}</h2>

          <h3>Getting Care</h3>
          <ol>
            <li><strong>Find a provider</strong> — Use the online directory or app to locate in-network hospitals and doctors</li>
            <li><strong>Show your card</strong> — At network facilities, present your insurance card for direct billing</li>
            <li><strong>Pay your share</strong> — Only pay your deductible or copay (if any)</li>
          </ol>

          <h3>If You Use Out-of-Network Care</h3>
          <ol>
            <li>Pay the provider directly</li>
            <li>Get itemized receipts with diagnosis codes</li>
            <li>Submit claim via app or online portal</li>
            <li>Receive reimbursement in 5-15 business days</li>
          </ol>

          <h3>Emergency Care</h3>
          <p>
            In emergencies, go to the nearest hospital regardless of network status. Contact {provider.name} within 48 hours to coordinate coverage. Emergency care is covered at any facility.
          </p>

          <h3>Support</h3>
          <p>
            {provider.type === 'international'
              ? `${provider.name} offers 24/7 multilingual support. Claims can be submitted via mobile app, online portal, or email.`
              : `Contact ${provider.name} directly for claims support and questions about your coverage.`
            }
          </p>

          <!-- FAQs -->
          <h2 id="faqs">Frequently Asked Questions</h2>

          {faqs.map(faq => (
            <>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </>
          ))}

          <!-- Alternatives -->
          <h2 id="alternatives">Alternatives to Consider</h2>
          <p>
            {provider.name} isn't the only option for expats in {country.name}. Here are other providers to compare:
          </p>

          <div class="grid md:grid-cols-2 gap-4 my-8 not-prose">
            {alternativeProviders.slice(0, 4).map(alt => (
              <a href={alt.href} class="block bg-white border border-neutral-200 rounded-lg p-5 hover:border-primary-300 hover:shadow-md transition-all">
                <h3 class="font-semibold text-neutral-900 mb-2">{alt.name}</h3>
                <p class="text-sm text-neutral-600">
                  <span class="text-green-700 font-medium">Best for:</span> {alt.bestFor}
                </p>
              </a>
            ))}
          </div>

          <p>
            <a href={`/countries/${country.slug}/insurance`}>See all insurance options for {country.name} →</a>
          </p>

          <CTABox
            title={`Compare ${provider.name} to Alternatives`}
            description={`Find the best fit for your situation in ${country.name}.`}
            buttonText="Compare Plans"
            buttonHref={`/countries/${country.slug}/insurance`}
            showDisclosure={false}
          />

        </div>

        <!-- DISCLAIMER -->
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
          <p class="text-sm text-neutral-600">
            <strong>Disclaimer:</strong> This guide is for informational purposes only. Coverage details, pricing, and network availability change. We are not insurance brokers or licensed advisors. Verify all information with {provider.name} and relevant authorities before making decisions.
          </p>
        </div>
      </article>

      <!-- Sticky Sidebar (Desktop) -->
      <StickySidebar
        ctaTitle={`${provider.name} in ${country.name}`}
        ctaDescription="Get a personalized quote for your situation."
        ctaButtonText="Get Quote"
        ctaButtonHref={provider.href}
        relatedLinks={sidebarLinks}
      />
    </div>
  </div>
</Layout>
