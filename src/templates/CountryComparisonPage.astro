function getScenarios(a: Country, b: Country): Array<{ persona: string; recommendation: string; reasoning: string }> {
  const aCol = getCostOfLiving(a);
  const bCol = getCostOfLiving(b);
  const aClimate = getClimate(a);
  const bClimate = getClimate(b);

  const scenarios = [];

  // Digital Nomad scenario
  if (aCol.tier === 'low' || bCol.tier === 'low') {
    const cheaper = aCol.tier === 'low' ? a : b;
    const other = cheaper === a ? b : a;
    scenarios.push({
      persona: 'Digital Nomads',
      recommendation: cheaper.name,
      reasoning: `Lower cost of living (${getCostOfLiving(cheaper).total}/month) stretches your income further. ${other.name} costs more but may offer better infrastructure.`,
    });
  } else {
    scenarios.push({
      persona: 'Digital Nomads',
      recommendation: 'Either works',
      reasoning: `Both have similar costs. Consider visa requirements: ${a.name} ${a.insuranceRequired ? 'requires' : 'recommends'} insurance, ${b.name} ${b.insuranceRequired ? 'requires' : 'recommends'} insurance.`,
    });
  }

  // Retirees scenario
  const aHasRetirement = getVisaOptions(a).some(v => v.name.toLowerCase().includes('retire') || v.name.toLowerCase().includes('pension'));
  const bHasRetirement = getVisaOptions(b).some(v => v.name.toLowerCase().includes('retire') || v.name.toLowerCase().includes('pension'));

  if (aClimate.winter.includes('Mild') || aClimate.winter.includes('Warm')) {
    scenarios.push({
      persona: 'Retirees',
      recommendation: a.name,
      reasoning: `Milder winters (${aClimate.winter}), ${aHasRetirement ? 'dedicated retirement visa available' : 'various visa options'}. Healthcare: ${getHealthcareRating(a).rating}.`,
    });
  } else if (bClimate.winter.includes('Mild') || bClimate.winter.includes('Warm')) {
    scenarios.push({
      persona: 'Retirees',
      recommendation: b.name,
      reasoning: `Milder winters (${bClimate.winter}), ${bHasRetirement ? 'dedicated retirement visa available' : 'various visa options'}. Healthcare: ${getHealthcareRating(b).rating}.`,
    });
  } else {
    scenarios.push({
      persona: 'Retirees',
      recommendation: 'Consider climate preferences',
      reasoning: `${a.name} winters: ${aClimate.winter}. ${b.name} winters: ${bClimate.winter}. Both have healthcare options.`,
    });
  }

  // Families scenario
  const aRating = getHealthcareRating(a);
  const bRating = getHealthcareRating(b);
  if (aRating.rating === 'Excellent' || aRating.rating === 'Very Good') {
    scenarios.push({
      persona: 'Families with Children',
      recommendation: a.name,
      reasoning: `${aRating.rating} healthcare system. International schools available in ${getExpatHubs(a).slice(0, 2).join(', ')}.`,
    });
  } else if (bRating.rating === 'Excellent' || bRating.rating === 'Very Good') {
    scenarios.push({
      persona: 'Families with Children',
      recommendation: b.name,
      reasoning: `${bRating.rating} healthcare system. International schools available in ${getExpatHubs(b).slice(0, 2).join(', ')}.`,
    });
  }

  // Budget-conscious
  if (aCol.tier !== bCol.tier) {
    const cheaper = aCol.tier === 'low' ? a : (bCol.tier === 'low' ? b : (aCol.tier === 'medium' ? a : b));
    scenarios.push({
      persona: 'Budget-Conscious Expats',
      recommendation: cheaper.name,
      reasoning: `Monthly costs of ${getCostOfLiving(cheaper).total} are more affordable. Healthcare and insurance still accessible.`,
    });
  }

  return scenarios.slice(0, 4);
}

function getFAQs(a: Country, b: Country): Array<{ question: string; answer: string }> {
  return [
    {
      question: `Which is cheaper to live in, ${a.name} or ${b.name}?`,
      answer: `${a.name} costs approximately ${getCostOfLiving(a).total}/month while ${b.name} costs ${getCostOfLiving(b).total}/month. This includes rent, food, utilities, and basic expenses. Healthcare costs and insurance add ${a.privateHealthcare?.cost || '$100-300'} in ${a.name} and ${b.privateHealthcare?.cost || '$100-300'} in ${b.name}.`,
    },
    {
      question: `Do I need health insurance in ${a.name} and ${b.name}?`,
      answer: `${a.name}: ${a.insuranceRequired ? 'Yes, insurance is required for visa applications. ' : 'Not legally required but strongly recommended. '}${a.requirementExplanation || ''} ${b.name}: ${b.insuranceRequired ? 'Yes, insurance is required for visa applications. ' : 'Not legally required but strongly recommended. '}${b.requirementExplanation || ''}`,
    },
    {
      question: `Which has better healthcare, ${a.name} or ${b.name}?`,
      answer: `${a.name}: ${getHealthcareRating(a).rating} - ${getHealthcareRating(a).notes}. ${b.name}: ${getHealthcareRating(b).rating} - ${getHealthcareRating(b).notes}. Both countries have private healthcare options that accept international insurance.`,
    },
    {
      question: `What visas are available for ${a.name} vs ${b.name}?`,
      answer: `${a.name} offers: ${getVisaOptions(a).map(v => v.name).join(', ')}. ${b.name} offers: ${getVisaOptions(b).map(v => v.name).join(', ')}. Requirements and processing times vary—check official immigration websites.`,
    },
    {
      question: `Where do expats live in ${a.name} and ${b.name}?`,
      answer: `Popular expat areas in ${a.name}: ${getExpatHubs(a).join(', ')}. In ${b.name}: ${getExpatHubs(b).join(', ')}. These cities have established expat communities, international services, and English-speaking professionals.`,
    },
  ];
}

// =====================
// PAGE DATA
// =====================

const costA = getCostOfLiving(countryA);
const costB = getCostOfLiving(countryB);
const visasA = getVisaOptions(countryA);
const visasB = getVisaOptions(countryB);
const climateA = getClimate(countryA);
const climateB = getClimate(countryB);
const hubsA = getExpatHubs(countryA);
const hubsB = getExpatHubs(countryB);
const healthA = getHealthcareRating(countryA);
const healthB = getHealthcareRating(countryB);
const scenarios = getScenarios(countryA, countryB);
const faqs = getFAQs(countryA, countryB);

const pageTitle = `${countryA.name} vs ${countryB.name}: Which Is Better for Expats?`;
const pageDescription = `Compare ${countryA.name} and ${countryB.name} for expat life. Healthcare, cost of living, visas, insurance requirements, and which suits your lifestyle.`;

const tocItems = [
  { id: 'overview', text: 'Quick Comparison', level: 2 },
  { id: 'cost-of-living', text: 'Cost of Living', level: 2 },
  { id: 'healthcare', text: 'Healthcare Systems', level: 2 },
  { id: 'visas', text: 'Visa Options', level: 2 },
  { id: 'insurance', text: 'Insurance Requirements', level: 2 },
  { id: 'climate', text: 'Climate & Weather', level: 2 },
  { id: 'expat-life', text: 'Expat Life', level: 2 },
  { id: 'scenarios', text: 'Who Should Choose Which', level: 2 },
  { id: 'faqs', text: 'FAQs', level: 2 },
  { id: 'verdict', text: 'Our Verdict', level: 2 },
];

const author = {
  name: 'John Spencer',
  bio: 'John Spencer is the founder of Compare Expat Plans, helping expats find health coverage that works for their specific situations.',
  image: '/images/john-spencer.png',
};

const sidebarLinks = [
  { title: `Insurance in ${countryA.name}`, href: `/countries/${countryA.slug}/insurance` },
  { title: `Insurance in ${countryB.name}`, href: `/countries/${countryB.slug}/insurance` },
  { title: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
  { title: 'Pre-Existing Conditions', href: '/guides/pre-existing-conditions-abroad' },
];

// Quick comparison table
const quickComparisonRows = [
  { factor: 'Monthly Cost of Living', countryA: costA.total, countryB: costB.total },
  { factor: 'Healthcare Rating', countryA: healthA.rating, countryB: healthB.rating },
  { factor: 'Insurance Required', countryA: countryA.insuranceRequired ? 'Yes' : 'Recommended', countryB: countryB.insuranceRequired ? 'Yes' : 'Recommended' },
  { factor: 'Private Insurance Cost', countryA: countryA.privateHealthcare?.cost || 'Varies', countryB: countryB.privateHealthcare?.cost || 'Varies' },
  { factor: 'Primary Language', countryA: getLanguageNote(countryA).split('.')[0], countryB: getLanguageNote(countryB).split('.')[0] },
  { factor: 'Climate', countryA: climateA.type.split('/')[0], countryB: climateB.type.split('/')[0] },
];

// Related cards
const relatedCards = [
  {
    title: `Health Insurance in ${countryA.name}`,
    description: `Complete guide to ${countryA.demonym} healthcare and insurance.`,
    href: `/countries/${countryA.slug}/insurance`,
    image: countryA.heroImage || '/images/cards/health-insurance.png',
  },
  {
    title: `Health Insurance in ${countryB.name}`,
    description: `Complete guide to ${countryB.demonym} healthcare and insurance.`,
    href: `/countries/${countryB.slug}/insurance`,
    image: countryB.heroImage || '/images/cards/health-insurance.png',
  },
  {
    title: 'Best Expat Health Insurance',
    description: 'Compare top international insurance plans.',
    href: '/best/expat-health-insurance',
    image: '/images/cards/best-expat-insurance.png',
  },
];

// Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://compareexpatplans.com/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://compareexpatplans.com/compare" },
    { "@type": "ListItem", "position": 3, "name": `${countryA.name} vs ${countryB.name}` },
  ]
};
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- HERO -->
  <section class="relative bg-gradient-to-b from-primary-50 to-white py-10 lg:py-14 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-primary-600 mb-2">
          <a href="/compare" class="hover:underline">Compare</a>
          {' → '}
          <span>Countries</span>
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          {countryA.name} vs {countryB.name}: The Complete Expat Comparison
        </h1>
        <p class="text-lg text-neutral-600 mb-6">
          Thinking about moving abroad? Here's an honest comparison of {countryA.name} and {countryB.name} covering cost of living, healthcare, visas, insurance requirements, and daily expat life.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href={`/countries/${countryA.slug}/insurance`}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            {countryA.name} Insurance Guide
          </a>
          <a
            href={`/countries/${countryB.slug}/insurance`}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            {countryB.name} Insurance Guide
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <article class="flex-1 min-w-0">

        <div class="mb-8">
          <AuthorBox name={author.name} bio={author.bio} image={author.image} />
          <p class="text-sm text-neutral-500 mt-3">
            Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </p>
        </div>

        <div class="lg:hidden mb-8">
          <TableOfContents items={tocItems} />
        </div>

        <div class="prose prose-neutral max-w-none">

          <!-- Quick Overview -->
          <h2 id="overview">Quick Comparison: {countryA.name} vs {countryB.name}</h2>
          <p>
            Here's a side-by-side look at the key factors that matter most to expats. We'll dive deeper into each below.
          </p>

          <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden not-prose">
            <ComparisonTable
              columns={[
                { key: 'factor', header: 'Factor' },
                { key: 'countryA', header: countryA.name },
                { key: 'countryB', header: countryB.name },
              ]}
              rows={quickComparisonRows}
            />
          </div>

          <!-- Cost of Living -->
          <h2 id="cost-of-living">Cost of Living</h2>
          <p>
            Your budget will go further in some places than others. Here's what to expect for monthly expenses:
          </p>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class={`border rounded-lg p-6 ${costA.tier === 'low' ? 'bg-green-50 border-green-200' : costA.tier === 'high' ? 'bg-amber-50 border-amber-200' : 'bg-neutral-50 border-neutral-200'}`}>
              <h3 class="text-lg font-semibold text-neutral-900 mb-1">{countryA.name}</h3>
              <p class={`text-2xl font-bold mb-4 ${costA.tier === 'low' ? 'text-green-700' : costA.tier === 'high' ? 'text-amber-700' : 'text-neutral-700'}`}>{costA.total}/month</p>
              <ul class="space-y-2 text-sm text-neutral-600">
                <li><strong>Rent (1BR):</strong> {costA.rent}</li>
                <li><strong>Food:</strong> {costA.food}</li>
                <li><strong>Utilities:</strong> {costA.utilities}</li>
                <li><strong>Healthcare:</strong> {countryA.privateHealthcare?.cost || 'Varies'}</li>
              </ul>
            </div>
            <div class={`border rounded-lg p-6 ${costB.tier === 'low' ? 'bg-green-50 border-green-200' : costB.tier === 'high' ? 'bg-amber-50 border-amber-200' : 'bg-neutral-50 border-neutral-200'}`}>
              <h3 class="text-lg font-semibold text-neutral-900 mb-1">{countryB.name}</h3>
              <p class={`text-2xl font-bold mb-4 ${costB.tier === 'low' ? 'text-green-700' : costB.tier === 'high' ? 'text-amber-700' : 'text-neutral-700'}`}>{costB.total}/month</p>
              <ul class="space-y-2 text-sm text-neutral-600">
                <li><strong>Rent (1BR):</strong> {costB.rent}</li>
                <li><strong>Food:</strong> {costB.food}</li>
                <li><strong>Utilities:</strong> {costB.utilities}</li>
                <li><strong>Healthcare:</strong> {countryB.privateHealthcare?.cost || 'Varies'}</li>
              </ul>
            </div>
          </div>

          <p>
            {costA.tier === costB.tier
              ? `Both countries have similar cost of living. Your choice should depend more on lifestyle preferences and visa requirements.`
              : costA.tier === 'low'
                ? `${countryA.name} is significantly more affordable, making it attractive for digital nomads and retirees stretching their savings.`
                : `${countryB.name} offers lower costs, which can mean more financial freedom or the ability to save while living abroad.`
            }
          </p>

          <!-- Healthcare -->
          <h2 id="healthcare">Healthcare Systems</h2>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
              <div class="flex items-center gap-2 mb-3">
                <h3 class="text-lg font-semibold text-neutral-900">{countryA.name}</h3>
                <span class={`text-xs font-medium px-2 py-1 rounded ${healthA.rating === 'Excellent' ? 'bg-green-100 text-green-700' : healthA.rating === 'Very Good' ? 'bg-blue-100 text-blue-700' : 'bg-neutral-100 text-neutral-700'}`}>
                  {healthA.rating}
                </span>
              </div>
              <p class="text-sm text-neutral-600 mb-4">{healthA.notes}</p>
              <div class="border-t border-neutral-200 pt-4">
                <p class="text-xs font-medium text-neutral-500 mb-2">Public System</p>
                <p class="text-sm text-neutral-700"><strong>{countryA.publicHealthcare?.name}:</strong> {countryA.publicHealthcare?.access}</p>
              </div>
            </div>
            <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
              <div class="flex items-center gap-2 mb-3">
                <h3 class="text-lg font-semibold text-neutral-900">{countryB.name}</h3>
                <span class={`text-xs font-medium px-2 py-1 rounded ${healthB.rating === 'Excellent' ? 'bg-green-100 text-green-700' : healthB.rating === 'Very Good' ? 'bg-blue-100 text-blue-700' : 'bg-neutral-100 text-neutral-700'}`}>
                  {healthB.rating}
                </span>
              </div>
              <p class="text-sm text-neutral-600 mb-4">{healthB.notes}</p>
              <div class="border-t border-neutral-200 pt-4">
                <p class="text-xs font-medium text-neutral-500 mb-2">Public System</p>
                <p class="text-sm text-neutral-700"><strong>{countryB.publicHealthcare?.name}:</strong> {countryB.publicHealthcare?.access}</p>
              </div>
            </div>
          </div>

          <p>
            Both countries have private healthcare options that work with international insurance plans. Most expats use private care for faster service and English-speaking doctors, even if they qualify for public healthcare.
          </p>

          <!-- Visas -->
          <h2 id="visas">Visa Options</h2>
          <p>
            Your visa determines everything from how long you can stay to whether you can work. Here are the main options:
          </p>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
              <div class="bg-neutral-100 px-4 py-3 border-b border-neutral-200">
                <h3 class="font-semibold text-neutral-900">{countryA.name} Visas</h3>
              </div>
              <div class="divide-y divide-neutral-100">
                {visasA.map(visa => (
                  <div class="p-4">
                    <p class="font-medium text-neutral-900">{visa.name}</p>
                    <p class="text-sm text-neutral-500 mt-1">Duration: {visa.duration}</p>
                    <p class="text-sm text-neutral-600 mt-1">{visa.requirements}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
              <div class="bg-neutral-100 px-4 py-3 border-b border-neutral-200">
                <h3 class="font-semibold text-neutral-900">{countryB.name} Visas</h3>
              </div>
              <div class="divide-y divide-neutral-100">
                {visasB.map(visa => (
                  <div class="p-4">
                    <p class="font-medium text-neutral-900">{visa.name}</p>
                    <p class="text-sm text-neutral-500 mt-1">Duration: {visa.duration}</p>
                    <p class="text-sm text-neutral-600 mt-1">{visa.requirements}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Insurance Requirements -->
          <h2 id="insurance">Insurance Requirements</h2>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class={`border rounded-lg p-6 ${countryA.insuranceRequired ? 'bg-amber-50 border-amber-200' : 'bg-green-50 border-green-200'}`}>
              <h3 class="text-lg font-semibold text-neutral-900 mb-2">{countryA.name}</h3>
              <p class={`text-sm font-medium mb-3 ${countryA.insuranceRequired ? 'text-amber-700' : 'text-green-700'}`}>
                {countryA.insuranceRequired ? '⚠️ Insurance Required for Visas' : '✓ Insurance Recommended'}
              </p>
              <p class="text-sm text-neutral-600 mb-4">{countryA.requirementExplanation || 'Private health insurance recommended for all expats.'}</p>
              <p class="text-sm text-neutral-700"><strong>Typical cost:</strong> {countryA.privateHealthcare?.cost || 'Varies by age and coverage'}</p>
            </div>
            <div class={`border rounded-lg p-6 ${countryB.insuranceRequired ? 'bg-amber-50 border-amber-200' : 'bg-green-50 border-green-200'}`}>
              <h3 class="text-lg font-semibold text-neutral-900 mb-2">{countryB.name}</h3>
              <p class={`text-sm font-medium mb-3 ${countryB.insuranceRequired ? 'text-amber-700' : 'text-green-700'}`}>
                {countryB.insuranceRequired ? '⚠️ Insurance Required for Visas' : '✓ Insurance Recommended'}
              </p>
              <p class="text-sm text-neutral-600 mb-4">{countryB.requirementExplanation || 'Private health insurance recommended for all expats.'}</p>
              <p class="text-sm text-neutral-700"><strong>Typical cost:</strong> {countryB.privateHealthcare?.cost || 'Varies by age and coverage'}</p>
            </div>
          </div>

          <CTABox
            title="Compare Insurance for Both Countries"
            description="International plans work in both destinations. Get quotes to see your options."
            buttonText="Compare Plans"
            buttonHref="/best/expat-health-insurance"
            showDisclosure={false}
          />

          <!-- Climate -->
          <h2 id="climate">Climate & Weather</h2>
          <p>
            Weather affects everything from your wardrobe to your energy bills. Here's what to expect:
          </p>

          <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
            <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-neutral-900 mb-3">{countryA.name}</h3>
              <ul class="space-y-2 text-sm text-neutral-600">
                <li><strong>Climate type:</strong> {climateA.type}</li>
                <li><strong>Summer:</strong> {climateA.summer}</li>
                <li><strong>Winter:</strong> {climateA.winter}</li>
                <li><strong>Best time to visit:</strong> {climateA.bestTime}</li>
              </ul>
            </div>
            <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-neutral-900 mb-3">{countryB.name}</h3>
              <ul class="space-y-2 text-sm text-neutral-600">
                <li><strong>Climate type:</strong> {climateB.type}</li>
                <li><strong>Summer:</strong> {climateB.summer}</li>
                <li><strong>Winter:</strong> {climateB.winter}</li>
                <li><strong>Best time to visit:</strong> {climateB.bestTime}</li>
              </ul>
            </div>
          </div>

          <!-- Expat Life -->
          <h2 id="expat-life">Expat Life & Community</h2>

          <h3>{countryA.name}</h3>
          <p>
            <strong>Language:</strong> {getLanguageNote(countryA)}
          </p>
          <p>
            <strong>Popular expat cities:</strong> {hubsA.join(', ')}. These areas have established expat communities, international schools, English-speaking services, and coworking spaces.
          </p>

          <h3>{countryB.name}</h3>
          <p>
            <strong>Language:</strong> {getLanguageNote(countryB)}
          </p>
          <p>
            <strong>Popular expat cities:</strong> {hubsB.join(', ')}. You'll find other expats, international amenities, and communities here.
          </p>

          <!-- Scenarios -->
          <h2 id="scenarios">Who Should Choose Which?</h2>
          <p>
            Different situations call for different destinations. Here's our take:
          </p>

          <div class="space-y-4 my-8 not-prose">
            {scenarios.map(scenario => (
              <div class="border border-neutral-200 rounded-lg p-5">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="font-semibold text-neutral-900">{scenario.persona}</h3>
                  <span class="text-sm font-medium text-primary-600">{scenario.recommendation}</span>
                </div>
                <p class="text-sm text-neutral-600">{scenario.reasoning}</p>
              </div>
            ))}
          </div>

          <!-- FAQs -->
          <h2 id="faqs">Frequently Asked Questions</h2>

          <div class="space-y-6 my-8 not-prose">
            {faqs.map(faq => (
              <div class="border-b border-neutral-200 pb-6">
                <h3 class="text-lg font-semibold text-neutral-900 mb-2">{faq.question}</h3>
                <p class="text-neutral-600">{faq.answer}</p>
              </div>
            ))}
          </div>

          <!-- Verdict -->
          <h2 id="verdict">Our Verdict</h2>
          <p>
            There's no objectively "better" choice between {countryA.name} and {countryB.name}. The right answer depends on your priorities:
          </p>
          <ul>
            <li><strong>Budget:</strong> {costA.tier === 'low' || costB.tier === 'low' ? `${costA.tier === 'low' ? countryA.name : countryB.name} is more affordable` : 'Similar costs in both'}</li>
            <li><strong>Healthcare:</strong> {healthA.rating === 'Excellent' ? `${countryA.name} has excellent healthcare` : healthB.rating === 'Excellent' ? `${countryB.name} has excellent healthcare` : 'Both have adequate healthcare options'}</li>
            <li><strong>Visa ease:</strong> Compare specific visa requirements based on your nationality and situation</li>
            <li><strong>Climate:</strong> {climateA.type} vs {climateB.type}—personal preference matters</li>
          </ul>
          <p>
            <strong>Our recommendation:</strong> Visit both places before committing if possible. Short-term stays reveal things research can't—the pace of life, the culture, and whether you actually enjoy being there.
          </p>
          <p>
            Whichever you choose, get health insurance sorted early. International plans work in both countries, so you can even switch destinations later without changing coverage.
          </p>

          <!-- Closing CTA -->
          <CTABox
            title="Ready to Make Your Move?"
            description={`Compare insurance plans that work in both ${countryA.name} and ${countryB.name}.`}
            buttonText="Compare Insurance Plans"
            buttonHref="/best/expat-health-insurance"
            variant="highlight"
            showDisclosure={false}
          />

        </div>

        <!-- Related Cards -->
        <ContentCards
