function getCostOfLiving(country: Country) {
  return costOfLivingData[country.slug] || { rent: 'Varies', food: 'Varies', utilities: 'Varies', total: '$1,000-2,500', tier: 'medium' as const };
}

function getVisaOptions(country: Country) {
  return visaOptionsData[country.slug] || [
    { name: 'Tourist Visa', duration: '30-90 days', requirements: 'Passport, return ticket' },
    { name: 'Work Visa', duration: 'Varies', requirements: 'Job offer, sponsorship' },
  ];
}

function getClimate(country: Country) {
  return climateData[country.slug] || { type: 'Varies', summer: 'Warm', winter: 'Cool', bestTime: 'Spring/Fall' };
}

function getExpatHubs(country: Country) {
  return expatHubsData[country.slug] || ['Capital city', 'Major cities'];
}

