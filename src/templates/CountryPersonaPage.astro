// Helper function: Get insurance cost range
function getInsuranceCostRange(personaSlug: string): string {
  const ranges: Record<string, string> = {
    'digital-nomads': 'Travel medical: $45-100/month. Comprehensive: $150-300/month.',
    'retirees': 'Varies by age: $150-400/month at 55-65, $300-600+ at 65+.',
    'families': 'Family of 4: $300-600/month for comprehensive coverage.',
    'remote-workers': '$80-200/month depending on coverage level.',
    'students': '$45-120/month. Check for student-specific plans.',
    'freelancers': '$50-180/month. Higher deductibles reduce costs.',
    'seniors': '$200-600+/month at 65+. Increases with age.',
    'entrepreneurs': '$120-350/month for individual coverage.'
  };
  return ranges[personaSlug] || 'Varies based on age, coverage level, and pre-existing conditions.';
}

// Helper function: Get out-of-pocket range
function getOutOfPocketRange(countrySlug: string): string {
  const lowCost = ['thailand', 'mexico', 'vietnam', 'indonesia', 'colombia', 'argentina', 'ecuador', 'philippines', 'malaysia'];
  const medCost = ['spain', 'portugal', 'italy', 'costa-rica', 'panama', 'brazil', 'south-korea'];
  if (lowCost.includes(countrySlug)) {
    return 'Doctor visits: $20-60. Hospital stays: $50-200/night private. Very affordable for routine care.';
  } else if (medCost.includes(countrySlug)) {
    return 'Doctor visits: $50-100. Hospital stays: $150-400/night private. Moderate costs.';
  }
  return 'Doctor visits: $100-200. Hospital stays: $400-1000+/night private. Budget accordingly.';
}

// Helper function: Get persona FAQs
function getPersonaFAQs(personaSlug: string, countryName: string): Array<{question: string; answer: string}> {
  const faqs: Record<string, Array<{question: string; answer: string}>> = {
    'digital-nomads': [
      { question: `Can I get insurance while already in ${countryName}?`, answer: 'Yes. Most travel medical providers (SafetyWing, IMG, World Nomads) allow you to purchase while abroad. There may be a short waiting period (24-72 hours) before coverage starts.' },
      { question: 'Is travel medical insurance enough?', answer: 'For healthy nomads, travel medical covers emergencies and hospitalization. It doesn\'t cover routine care, pre-existing conditions, or dental. If you have ongoing health needs, consider comprehensive coverage.' },
      { question: 'What if I move to another country?', answer: 'Travel medical and international health plans typically cover you in 180+ countries. You don\'t need to change plans when moving. Just verify your new destination is included.' }
    ],
    'retirees': [
      { question: 'Will my pre-existing conditions be covered?', answer: 'Most international plans exclude pre-existing conditions initially but may cover them after a waiting period (usually 12-24 months). Some providers like BUPA Global handle pre-existing conditions better than others.' },
      { question: `Is there an age limit for getting insurance in ${countryName}?`, answer: 'Age limits vary by provider. Cigna Global and Allianz accept older applicants. BUPA Global and some local insurers accept applicants up to 80+. Premiums increase with age.' },
      { question: 'Do I need insurance for my visa?', answer: `Check specific visa requirements for ${countryName}. Retirement and long-stay visas often require proof of health coverage meeting minimum requirements.` }
    ],
    'families': [
      { question: 'Are children covered from birth?', answer: 'Most comprehensive plans cover newborns from birth if the mother has maternity coverage. Verify this before enrolling, especially if planning a pregnancy abroad.' },
      { question: 'Is maternity covered?', answer: 'Maternity requires specific coverage and usually has a 10-12 month waiting period. You cannot enroll while pregnant and expect coverage. Plan ahead.' },
      { question: 'What about vaccinations for kids?', answer: 'Most comprehensive plans cover routine childhood vaccinations. Travel medical plans typically do not. Check your policy for specifics.' }
    ],
    'students': [
      { question: 'Does this meet university requirements?', answer: 'Requirements vary by institution. Some accept international plans, others require local coverage or their own group plan. Check with your university before enrolling.' },
      { question: 'Am I covered during holidays?', answer: 'Most student plans cover you during school breaks and travel. Verify coverage for trips to other countries if you plan to travel.' }
    ],
    'seniors': [
      { question: 'Will I be rejected for my age?', answer: 'Some insurers have age limits, but many major providers accept applicants 70+. Expect higher premiums and potentially more exclusions. Compare carefully.' },
      { question: 'How much will premiums increase each year?', answer: 'Premiums typically increase 5-15% annually with age. Some plans cap increases. Budget for rising costs or consider plans with more predictable pricing.' }
    ]
  };
  return faqs[personaSlug] || [
    { question: `Do I need health insurance in ${countryName}?`, answer: 'While not always legally required, health insurance is strongly recommended. A serious illness or accident can cost tens of thousands of dollars without coverage.' },
    { question: 'Local vs international insurance?', answer: `Local plans are often cheaper but only work in ${countryName}. International plans cost more but provide global coverage and portability if you relocate.` }
  ];
}

// Helper function: Get day-to-day healthcare reality
function getDayToDayReality(countrySlug: string, personaSlug: string, countryName: string): string[] {
  const lowCostCountries = ['thailand', 'mexico', 'vietnam', 'indonesia', 'colombia', 'argentina', 'ecuador', 'philippines', 'malaysia', 'india', 'peru', 'bulgaria', 'serbia', 'albania', 'dominican-republic', 'belize'];
  const medCostCountries = ['spain', 'portugal', 'italy', 'costa-rica', 'panama', 'brazil', 'south-korea', 'czech-republic', 'croatia', 'hungary', 'poland', 'greece', 'taiwan', 'chile', 'curacao', 'jamaica'];
  const highCostCountries = ['france', 'germany', 'uk', 'uae', 'singapore', 'australia', 'canada', 'japan', 'switzerland', 'netherlands', 'ireland', 'sweden', 'norway', 'denmark', 'hong-kong', 'cayman-islands', 'bermuda', 'bahamas', 'barbados'];

  const isLowCost = lowCostCountries.includes(countrySlug);
  const isHighCost = highCostCountries.includes(countrySlug);

  const baseReality: string[] = [];

  // Cost-based paragraphs
  if (isLowCost) {
    baseReality.push(`In ${countryName}, routine healthcare is affordable enough that many expats pay out of pocket for minor issues. A typical doctor visit at a private clinic runs $20-60, and even specialist consultations rarely exceed $100. This means you can realistically use insurance primarily for emergencies and major procedures while handling everyday healthcare with cash.`);
    baseReality.push(`Pharmacies in ${countryName} often sell medications without prescriptions that would require one back home. Common antibiotics, pain relievers, and other medications are available over the counter at a fraction of US or European prices. This can be convenient, but consult a doctor for anything serious.`);
  } else if (isHighCost) {
    baseReality.push(`Healthcare costs in ${countryName} are significant—comparable to or higher than what you'd pay in the US or Western Europe. A routine doctor visit can cost $100-200, specialist appointments $200-400, and hospital stays can quickly reach thousands per night. Comprehensive insurance isn't optional here; it's essential.`);
    baseReality.push(`The upside of higher costs is generally excellent quality. Hospitals are well-equipped, English is commonly spoken in medical settings, and you can expect standards similar to what you'd find in major Western cities. But budget accordingly—even with insurance, deductibles and co-pays add up.`);
  } else {
    baseReality.push(`${countryName} offers a middle ground on healthcare costs. Doctor visits typically run $50-100, hospital stays $150-400 per night at private facilities. This is affordable enough that minor issues won't break the bank, but a serious illness or injury without insurance could still cost you thousands.`);
    baseReality.push(`Quality of care in ${countryName} is generally good in major cities, though it can vary in rural areas. Private hospitals typically offer shorter wait times and more English-speaking staff, while public options may be cheaper but involve longer waits.`);
  }

  // Persona-specific paragraphs
  const personaParagraphs: Record<string, string> = {
    'digital-nomads': `As a nomad, you'll likely rely on telemedicine for minor issues and local clinics for anything that needs in-person attention. Build relationships with a local clinic or doctor early—having someone who knows your history makes healthcare abroad much smoother. Many nomads keep a basic medical kit with common medications rather than visiting a doctor for every minor ailment.`,
    'retirees': `For retirees, establishing a relationship with a local primary care physician is crucial. You'll want someone who can manage ongoing conditions, coordinate with specialists, and understand your medical history. Ask other expats for recommendations—word of mouth is often the best way to find English-speaking doctors who work well with internationals.`,
    'families': `With children, you'll need to know where the nearest pediatric care is available. In ${countryName}, private hospitals typically have pediatric departments, but quality varies. Establish a relationship with a pediatrician early, ensure your children's vaccination records are translated and accessible, and know the fastest route to emergency care from your home.`,
    'remote-workers': `Remote workers often have the flexibility to schedule medical appointments during work breaks. Take advantage of this—don't let work deadlines cause you to postpone healthcare. Many clinics in expat-friendly areas offer evening or weekend hours specifically for working professionals.`,
    'students': `Student health services at your university are usually your first stop for minor issues. They're often free or low-cost and understand the specific needs of international students. For anything beyond their scope, they can refer you to appropriate specialists. Keep your insurance card and university health center information easily accessible.`,
    'freelancers': `As a freelancer, sick days directly impact your income. This makes preventive care especially important—regular checkups, staying on top of vaccinations, and addressing health issues early before they become bigger problems. Consider this when choosing your insurance: a plan that covers routine care might pay for itself by keeping you healthy and productive.`,
    'seniors': `Managing medications abroad requires planning. Before you move, get a detailed letter from your doctor listing all your medications with generic names (brand names vary by country). Some medications may not be available in ${countryName}, requiring alternatives or international shipping. Research pharmacy options and medication availability before you arrive.`,
    'entrepreneurs': `Running a business while managing your health abroad requires efficiency. Consider executive health plans that include annual comprehensive checkups—catching issues early is both good for your health and your business continuity. Many international plans offer priority appointments and dedicated support lines that minimize time away from work.`
  };

  if (personaParagraphs[personaSlug]) {
    baseReality.push(personaParagraphs[personaSlug]);
  }

  return baseReality;
}

// Helper function: Get common mistakes
function getCommonMistakes(personaSlug: string, countryName: string): Array<{mistake: string; reality: string}> {
  const commonMistakes: Record<string, Array<{mistake: string; reality: string}>> = {
    'digital-nomads': [
      { mistake: 'Relying solely on travel insurance for long stays', reality: 'Travel insurance is designed for trips, not living abroad. After 3-6 months, you need proper international health insurance. Travel policies may also deny claims if they determine you\'re "residing" rather than "traveling."' },
      { mistake: 'Assuming you can buy insurance after getting sick', reality: 'Insurance doesn\'t work retroactively. Pre-existing conditions are excluded, and you can\'t buy coverage for an injury that already happened. Get insured before you need it.' },
      { mistake: 'Choosing the cheapest plan without reading exclusions', reality: 'A $40/month plan that excludes most things isn\'t actually saving you money. Read what\'s covered. Mental health, adventure sports, and chronic conditions are commonly excluded in budget plans.' }
    ],
    'retirees': [
      { mistake: 'Assuming Medicare works internationally', reality: 'Medicare doesn\'t cover you outside the US except in very limited border-crossing emergencies. You need separate international coverage.' },
      { mistake: 'Waiting until health issues arise to get coverage', reality: 'Pre-existing conditions are much harder to cover once you have them. Get comprehensive insurance while you\'re still healthy—it\'s both easier and cheaper.' },
      { mistake: 'Not budgeting for premium increases', reality: 'Premiums increase every year as you age. A plan that costs $300/month at 60 might cost $600/month at 70. Factor this into your long-term retirement budget.' }
    ],
    'families': [
      { mistake: 'Assuming maternity coverage is automatic', reality: 'Maternity coverage must be specifically included and has waiting periods (usually 10-12 months). You cannot get pregnant and then buy coverage. Plan pregnancies around your insurance timeline.' },
      { mistake: 'Not verifying pediatric coverage specifics', reality: 'Not all plans cover well-child visits, vaccinations, or routine pediatric care. These aren\'t emergencies, so travel medical plans typically exclude them. Verify before enrolling.' },
      { mistake: 'Forgetting to cover all family members', reality: 'Each person needs to be specifically listed on the policy. Newborns need to be added within a specific window (usually 30 days). Don\'t assume coverage extends automatically.' }
    ],
    'students': [
      { mistake: 'Relying on parents\' insurance internationally', reality: 'Many domestic insurance plans have limited or no international coverage. Even if covered, the network and claims process may be impractical from abroad. Get dedicated international coverage.' },
      { mistake: 'Choosing insurance without checking university requirements', reality: 'Many universities have specific insurance requirements. Buying the wrong plan means paying twice—once for the plan that doesn\'t qualify and again for compliant coverage.' },
      { mistake: 'Ignoring mental health coverage', reality: 'Studying abroad is stressful. Mental health issues are common among international students. Ensure your plan covers counseling and psychiatric care—many basic plans don\'t.' }
    ],
    'seniors': [
      { mistake: 'Assuming all providers accept older applicants', reality: 'Many insurers have age limits (65, 70, or 75). Others accept older applicants but at very high premiums or with significant exclusions. Research age policies before applying.' },
      { mistake: 'Not disclosing pre-existing conditions', reality: 'Failing to disclose conditions can void your entire policy when you need it most. Be honest on applications—there are providers who work with pre-existing conditions.' },
      { mistake: 'Choosing high deductibles to save on premiums', reality: 'A $5,000 deductible might save $100/month but costs you $5,000 before insurance pays anything. At senior ages, you\'re more likely to use healthcare. Balance premium savings against likely usage.' }
    ],
    'freelancers': [
      { mistake: 'Going uninsured to save money', reality: 'One emergency room visit can cost more than years of insurance premiums. The math almost never works in favor of going uninsured, especially abroad where you can\'t fall back on family support.' },
      { mistake: 'Letting coverage lapse during slow income periods', reality: 'Insurance gaps are dangerous. If you get sick while uninsured, it becomes a pre-existing condition when you re-enroll. Maintain continuous coverage even during lean months.' },
      { mistake: 'Not claiming tax deductions', reality: 'In many countries, self-employed individuals can deduct health insurance premiums. Check local tax laws—this effectively reduces your insurance cost.' }
    ],
    'remote-workers': [
      { mistake: 'Assuming employer insurance covers you abroad', reality: 'Most employer health plans have limited or no international coverage. Some may cover emergencies but not routine care. Verify exactly what your employer plan covers before relying on it.' },
      { mistake: 'Not coordinating with employer benefits', reality: 'If your employer offers a health stipend or international coverage option, use it. Don\'t pay out of pocket for something your employer would cover.' },
      { mistake: 'Ignoring visa insurance requirements', reality: `${countryName} may require specific insurance for your visa. Employer coverage or travel insurance may not meet visa requirements. Verify before applying.` }
    ],
    'entrepreneurs': [
      { mistake: 'Prioritizing business insurance over personal health insurance', reality: 'Your business depends on your health. A serious illness without coverage can bankrupt both you and your business. Health insurance is a business expense, not a personal luxury.' },
      { mistake: 'Not considering key person coverage', reality: 'If you\'re essential to your business, consider coverage that includes business interruption or key person elements. Your health directly affects business continuity.' },
      { mistake: 'Forgetting coverage during business travel', reality: 'If your base plan covers only your residence country, business trips may leave you exposed. Ensure your plan covers you during travel to other countries.' }
    ]
  };

  return commonMistakes[personaSlug] || [
    { mistake: 'Waiting until arrival to think about insurance', reality: 'Research and purchase insurance before you leave. Some plans have waiting periods, and buying coverage is easier before you\'re already abroad.' },
    { mistake: 'Not understanding what\'s excluded', reality: 'Every insurance plan has exclusions. Read the policy document, not just the marketing materials. Common exclusions include pre-existing conditions, mental health, dental, and high-risk activities.' },
    { mistake: 'Assuming all international insurance is the same', reality: 'Coverage varies dramatically between providers. A comprehensive plan from one insurer may cost twice as much as a basic plan from another—but also covers twice as much. Compare carefully.' }
  ];
}

