// Helper function: Get insurance buying tips
function getInsuranceBuyingTips(personaSlug: string): string[] {
  const baseTips = [
    'Get quotes from at least 3 providers before deciding—prices vary significantly for similar coverage',
    'Read the policy document (not just the brochure) to understand exclusions',
    'Check provider reviews from actual expats, not just star ratings',
    'Verify the claims process: how long does reimbursement take? Is direct billing available?',
    'Understand the difference between travel medical insurance and international health insurance'
  ];

  const personaTips: Record<string, string[]> = {
    'digital-nomads': [
      'Consider monthly payment plans if you want flexibility to change or cancel',
      'Verify there\'s no "home country" restriction that limits coverage in your passport country',
      'Look for plans with telemedicine—essential when you\'re in remote areas or new cities'
    ],
    'retirees': [
      'Ask about pre-existing condition coverage: waiting periods, moratorium vs. full medical underwriting',
      'Verify there\'s no maximum age for renewal—you don\'t want to be dropped at 75',
      'Consider the insurer\'s financial stability—you want them around for the long term'
    ],
    'families': [
      'Compare family vs. individual pricing—sometimes separate policies are cheaper',
      'Verify maternity coverage terms if more children are possible',
      'Check pediatric coverage for well-child visits, vaccinations, and routine care'
    ],
    'students': [
      'Check if your university offers a group plan—often cheaper than individual coverage',
      'Verify mental health coverage, including counseling and psychiatric care',
      'Look for plans specifically designed for students—they often have better pricing'
    ],
    'seniors': [
      'Don\'t just compare premiums—compare what\'s actually covered for your conditions',
      'Ask about premium increase caps or lifetime rate guarantees',
      'Consider plans with care coordination services for managing complex health needs'
    ],
    'freelancers': [
      'Look for monthly payment options that don\'t penalize you vs. annual payments',
      'Consider higher deductibles to reduce premiums—but ensure you can cover the deductible',
      'Check if premiums are tax-deductible as a business expense in your situation'
    ],
    'remote-workers': [
      'Coordinate with any employer coverage to avoid paying for duplicate protection',
      'Verify coverage meets visa requirements—employer plans often don\'t',
      'Consider plans that include coverage for trips back to your home country'
    ],
    'entrepreneurs': [
      'Look into group plans if you have employees—may offer better rates than individual coverage',
      'Consider executive health plans that include comprehensive annual checkups',
      'Factor insurance into your business budget as a operational cost, not personal expense'
    ]
  };

  return [...baseTips, ...(personaTips[personaSlug] || [])];
}

// Generate TOC items
const tocItems = [
  { id: 'overview', text: `${personaName} in ${countryName}`, level: 2 },
  { id: 'key-considerations', text: 'Key Considerations', level: 2 },
  { id: 'visa-requirements', text: 'Visa & Insurance Requirements', level: 2 },
  { id: 'recommended-plans', text: 'Recommended Plans', level: 2 },
  { id: 'healthcare', text: 'Healthcare Access', level: 2 },
  { id: 'day-to-day', text: 'Day-to-Day Healthcare Reality', level: 2 },
  { id: 'buying-tips', text: 'Insurance Buying Tips', level: 2 },
  { id: 'mistakes', text: 'Common Mistakes to Avoid', level: 2 },
  { id: 'costs', text: 'Expected Costs', level: 2 },
  { id: 'checklist', text: 'Before You Go', level: 2 },
  { id: 'faqs', text: 'Common Questions', level: 2 },
];

// Author info
const author = {
  name: 'John Spencer',
  bio: 'John Spencer is the founder of Compare Expat Plans, focusing on clear, neutral information to help people find health coverage abroad.',
  image: '/images/john-spencer.png',
};

// Sidebar links
const sidebarLinks = [
  ...(region ? [{ title: `More in ${region.name}`, href: `/regions/${region.slug}` }] : []),
  { title: `${countryName} Insurance Guide`, href: `/countries/${country.slug}/insurance` },
  { title: `Insurance for ${personaName}`, href: persona.href },
  { title: 'Compare All Plans', href: '/best/expat-health-insurance' },
];

// Add provider links
recommendedProviders.slice(0, 2).forEach(p => {
  if (p) {
    sidebarLinks.push({
      title: `${p.name} in ${countryName}`,
      href: `/countries/${country.slug}/insurance/${p.slug}`
    });
  }
});

// Meta
const pageTitle = `Health Insurance for ${personaName} in ${countryName} (2025 Guide)`;
const pageDescription = `Find the best health insurance for ${personaName.toLowerCase()} living in ${countryName}. ${entry.keyConsiderations[0]}`;

// Breadcrumb schema
const siteUrl = "https://compareexpatplans.com";
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Countries", "item": `${siteUrl}/countries` },
    { "@type": "ListItem", "position": 3, "name": countryName, "item": `${siteUrl}/countries/${country.slug}/insurance` },
    { "@type": "ListItem", "position": 4, "name": `For ${personaName}` },
  ],
};

// Provider table data
const providerColumns = [
  { key: 'provider', header: 'Provider' },
  { key: 'type', header: 'Type' },
  { key: 'bestFor', header: 'Best For' },
  { key: 'price', header: 'From' },
];

const providerRows = recommendedProviders.map(p => ({
  provider: p?.name || '',
  type: p?.type || 'International',
  bestFor: getProviderBestFor(p?.slug || '', persona.slug),
  price: p?.startingPrice || 'Varies',
}));

// Hero image - try country-specific, fall back to default
const heroImage = country.heroImage || '/images/countries/default-hero-bg.png';

// Pre-compute content
const countryIntro = getCountryIntro(country.slug, persona.slug);
const insuranceRequirementSummary = getInsuranceRequirementSummary(country.slug, persona.slug);
const healthcareAdvice = getHealthcareAdvice(persona.slug);
const insuranceCostRange = getInsuranceCostRange(persona.slug);
const outOfPocketRange = getOutOfPocketRange(country.slug);
const faqs = getPersonaFAQs(persona.slug, countryName);
const dayToDayReality = getDayToDayReality(country.slug, persona.slug, countryName);
const commonMistakes = getCommonMistakes(persona.slug, countryName);
const beforeYouGoChecklist = getBeforeYouGoChecklist(persona.slug, countryName);
const buyingTips = getInsuranceBuyingTips(persona.slug);
---

<Layout title={pageTitle} description={pageDescription} ogType="article" noindex={true}>
  <!-- Structured Data -->
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- HERO SECTION -->
  <section
    class="relative py-10 lg:py-14 border-b border-neutral-200"
    style={`background: linear-gradient(to bottom, rgba(255,255,255,0.85), rgba(255,255,255,0.95)), url('${heroImage}'); background-size: cover; background-position: center;`}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-primary-600 mb-2">
          <a href={`/countries/${country.slug}/insurance`} class="hover:underline">{countryName}</a>
          {' → '}
          <span>For {personaName}</span>
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4">
          Health Insurance for {personaName} in {countryName}
        </h1>

        <p class="text-lg text-neutral-600 mb-6">
          Everything you need to know about health coverage as a {personaSingular} living in {countryName}—visa requirements, recommended providers, and what to expect.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <a
            href="/best/expat-health-insurance"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
            style="color: white;"
          >
            Compare Plans for {personaName}
          </a>
          <a
            href={`/countries/${country.slug}/insurance`}
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-primary-600 hover:text-primary-700 border border-primary-200 rounded-lg transition-colors bg-white"
          >
            Full {countryName} Guide
          </a>
        </div>
        <Disclosure />
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="flex gap-12">
      <!-- Main Content -->
      <article class="flex-1 min-w-0">

        <!-- TOP META -->
        <div class="mb-8">
          <AuthorBox
            name={author.name}
            bio={author.bio}
            image={author.image}
          />
        </div>

        <!-- TOC (Mobile) -->
        <div class="lg:hidden mb-8">
          <TableOfContents items={tocItems} />
        </div>

        <!-- CONTENT -->
        <div class="prose prose-neutral max-w-none">

          <h2 id="overview">{personaName} in {countryName}</h2>

          <p>
            {countryName} is {countryIntro}.
            As a {personaSingular}, your insurance needs focus on {persona.keyNeeds.slice(0, 2).join(' and ').toLowerCase()}.
          </p>

          <p>
            This guide covers everything you need to know about getting covered in {countryName}—from visa requirements to the best providers for your situation.
          </p>

          <!-- Key Considerations -->
          <h2 id="key-considerations">Key Considerations for {personaName}</h2>

          <div class="bg-primary-50 border border-primary-200 rounded-lg p-6 my-6 not-prose">
            <h3 class="text-lg font-semibold text-primary-900 mb-3">What to Know</h3>
            <ul class="space-y-2">
              {entry.keyConsiderations.map(consideration => (
                <li class="flex items-start gap-2 text-primary-800">
                  <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>{consideration}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Visa Requirements -->
          <h2 id="visa-requirements">Visa & Insurance Requirements</h2>

          <p>
            {entry.visaNotes}
          </p>

          <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 my-6 not-prose">
            <h3 class="text-lg font-semibold text-amber-900 mb-2">Insurance Requirement Summary</h3>
            <p class="text-amber-800 text-sm">
              {insuranceRequirementSummary}
            </p>
          </div>

          <p>
            Even if insurance isn't legally required for your visa type, having coverage protects you from potentially catastrophic medical bills.
            A hospital stay in {countryName} can cost thousands to tens of thousands of dollars without insurance.
          </p>

          <CTABox
            title={`Coverage for ${personaName} in ${countryName}`}
            description="Compare plans that fit your needs and budget."
            buttonText="Compare Plans"
            buttonHref="/best/expat-health-insurance"
            variant="highlight"
            showDisclosure={false}
          />

          <!-- Recommended Plans -->
          <h2 id="recommended-plans">Recommended Plans for {personaName}</h2>

          <p>
            Based on your needs as a {personaSingular}, here are the best insurance options for {countryName}:
          </p>
        </div>

        <!-- Provider Table -->
        <div class="my-8 border border-neutral-200 rounded-lg overflow-hidden">
          <ComparisonTable columns={providerColumns} rows={providerRows} />
        </div>

        <div class="prose prose-neutral max-w-none">
          {recommendedProviders.slice(0, 3).map((provider) => (
            <div class="mb-6">
              <h3>{provider?.name}</h3>
              <p>
                {getProviderDescription(provider?.slug || '', persona.slug)}
              </p>
              <p>
                <a href={`/countries/${country.slug}/insurance/${provider?.slug}`}>
                  {provider?.name} in {countryName} →
                </a>
              </p>
            </div>
          ))}

          <!-- Healthcare Access -->
          <h2 id="healthcare">Healthcare Access for {personaName}</h2>

          <p>
            {entry.healthcareNotes}
          </p>

          <p>
            {healthcareAdvice}
          </p>

          <!-- Day-to-Day Healthcare Reality -->
          <h2 id="day-to-day">Day-to-Day Healthcare Reality</h2>

          {dayToDayReality.map(paragraph => (
            <p>{paragraph}</p>
          ))}

          <!-- Insurance Buying Tips -->
          <h2 id="buying-tips">Insurance Buying Tips for {personaName}</h2>

          <p>
            Finding the right insurance takes research. Here's what to focus on as a {personaSingular} looking for coverage in {countryName}:
          </p>

          <ul>
            {buyingTips.map(tip => (
              <li>{tip}</li>
            ))}
          </ul>

          <!-- Common Mistakes -->
          <h2 id="mistakes">Common Mistakes to Avoid</h2>

          <p>
            We've seen these mistakes repeatedly from {personaName.toLowerCase()} getting insurance abroad. Learn from others' experiences:
          </p>

          {commonMistakes.map(item => (
            <div class="bg-red-50 border-l-4 border-red-400 p-4 my-4 not-prose">
              <p class="font-semibold text-red-800 mb-1">{item.mistake}</p>
              <p class="text-red-700 text-sm">{item.reality}</p>
            </div>
          ))}

          <!-- Costs -->
          <h2 id="costs">Expected Costs</h2>

          <p>
            {entry.costNotes}
          </p>

          <div class="grid md:grid-cols-2 gap-4 my-6 not-prose">
            <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-5">
              <h4 class="font-semibold text-neutral-900 mb-2">Insurance Costs</h4>
              <p class="text-sm text-neutral-600">
                {insuranceCostRange}
              </p>
            </div>
            <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-5">
              <h4 class="font-semibold text-neutral-900 mb-2">Out-of-Pocket Care</h4>
              <p class="text-sm text-neutral-600">
                {outOfPocketRange}
              </p>
            </div>
          </div>

          <!-- Before You Go Checklist -->
          <h2 id="checklist">Before You Go: {personaName} Checklist</h2>

          <p>
            Don't wait until you arrive in {countryName} to sort out healthcare. Complete these steps before you leave:
          </p>

          <div class="bg-green-50 border border-green-200 rounded-lg p-6 my-6 not-prose">
            <h3 class="text-lg font-semibold text-green-900 mb-4">Pre-Departure Checklist</h3>
            <ul class="space-y-3">
              {beforeYouGoChecklist.map(item => (
                <li class="flex items-start gap-3 text-green-800">
                  <span class="w-5 h-5 rounded border-2 border-green-400 flex-shrink-0 mt-0.5"></span>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <CTABox
            title="Ready to Get Covered?"
            description={`Compare plans suited for ${personaName.toLowerCase()} in ${countryName}.`}
            buttonText="Compare Plans Now"
            buttonHref="/best/expat-health-insurance"
            variant="highlight"
            showDisclosure={false}
          />

          <!-- FAQs -->
          <h2 id="faqs">Common Questions</h2>

          {faqs.map(faq => (
            <div class="mb-6">
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </div>
          ))}

          <CTABox
            title={`Find Coverage in ${countryName}`}
            description={`Compare the best options for ${personaName.toLowerCase()}.`}
            buttonText="Compare Plans"
            buttonHref="/best/expat-health-insurance"
            variant="highlight"
            showDisclosure={false}
          />
        </div>

        <!-- Related Pages -->
        <div class="mt-10 pt-8 border-t border-neutral-200">
          <h3 class="text-lg font-semibold text-neutral-900 mb-4">Related Guides</h3>
          <div class="grid md:grid-cols-2 gap-4">
            <a
              href={`/countries/${country.slug}/insurance`}
              class="block bg-white border border-neutral-200 rounded-lg p-4 hover:border-primary-300 hover:shadow-md transition-all"
            >
              <h4 class="font-semibold text-neutral-900">{countryName} Insurance Guide</h4>
              <p class="text-sm text-primary-600 mt-1">Full overview →</p>
            </a>
            <a
              href={persona.href}
              class="block bg-white border border-neutral-200 rounded-lg p-4 hover:border-primary-300 hover:shadow-md transition-all"
            >
              <h4 class="font-semibold text-neutral-900">Insurance for {personaName}</h4>
              <p class="text-sm text-primary-600 mt-1">General guide →</p>
            </a>
          </div>
        </div>

        <!-- DISCLAIMER -->
        <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-6 mt-8">
          <p class="text-sm text-neutral-600">
            <strong>Disclaimer:</strong> This guide is for informational purposes only. Visa requirements, insurance rules, and healthcare systems change. We are not immigration consultants or insurance brokers. Verify all requirements with official sources and insurers before making decisions.
          </p>
        </div>
      </article>

      <!-- Sticky Sidebar (Desktop) -->
      <StickySidebar
        ctaTitle={`${personaName} in ${countryName}`}
        ctaDescription="Find the right coverage for your needs."
        ctaButtonText="Compare Plans"
        ctaButtonHref="/best/expat-health-insurance"
        relatedLinks={sidebarLinks}
      />
    </div>
  </div>
</Layout>
