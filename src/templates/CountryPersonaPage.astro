---
/**
 * CountryPersonaPage.astro
 *
 * Template for country-persona pages like /countries/thailand/insurance/for-digital-nomads
 * These pages help users understand insurance options for their specific situation in a specific country.
 */

import Layout from '../layouts/Layout.astro';
import CTABox from '../components/CTABox.astro';
import AuthorBox from '../components/AuthorBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import StickySidebar from '../components/StickySidebar.astro';
import Disclosure from '../components/Disclosure.astro';
import ComparisonTable from '../components/ComparisonTable.astro';

import type { Country } from '../data/types';
import type { Persona } from '../data/personas';
import type { CountryPersonaEntry } from '../data/countryPersonaMatrix';
import { getProviderBySlug } from '../data/providers';
import { getRegionForCountry } from '../data/regions';

interface Props {
  country: Country;
  persona: Persona;
  entry: CountryPersonaEntry;
}

const { country, persona, entry } = Astro.props;

// Format country name properly
const countryName = country.name;
const personaName = persona.name;
const personaSingular = persona.singular;

// Get provider details for recommendations
const recommendedProviders = entry.recommendedProviders
  .map(slug => getProviderBySlug(slug))
  .filter(Boolean)
  .slice(0, 4);

// Get region for country
const region = getRegionForCountry(country.slug);

