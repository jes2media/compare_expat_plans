    'thailand-retirees': 'O-A and O-X retirement visas require TGIA-approved insurance with specific coverage minimums.',
    'thailand-seniors': 'Retirement visas require approved insurance. Some providers don\'t accept applicants over 70.',
    'spain-digital-nomads': 'Digital Nomad Visa requires health insurance with full coverage in Spain.',
    'portugal-digital-nomads': 'Digital Nomad Visa requires health insurance coverage.',
    'uae-all': 'Health insurance is mandatory in the UAE for all residents.'
  };
  const key = `${countrySlug}-${personaSlug}`;
