---
interface Card {
  title: string;
  description: string;
  href: string;
  image?: string;
}

interface Props {
  title?: string;
  cards: Card[];
}

const { title = 'Related Resources', cards } = Astro.props;
---

<section class="py-12">
  <h2 class="text-xl font-bold text-neutral-900 mb-6">{title}</h2>
  <div class="grid md:grid-cols-3 gap-6">
    {cards.map((card) => (
      <a
        href={card.href}
        class="group bg-white border border-neutral-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow"
      >
        <div class="aspect-video bg-neutral-100 relative overflow-hidden">
          {card.image ? (
            <img
              src={card.image}
              alt={card.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <svg class="w-12 h-12 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
          )}
        </div>
        <div class="p-5">
          <h3 class="font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors mb-2">
            {card.title}
          </h3>
          <p class="text-sm text-neutral-600 line-clamp-2">{card.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>
