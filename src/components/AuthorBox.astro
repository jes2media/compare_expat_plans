---
interface Props {
  name: string;
  bio: string;
  image?: string;
}

const { name, bio, image } = Astro.props;
---

<div class="flex items-start gap-4 p-4 bg-neutral-50 rounded-lg border border-neutral-200">
  <div class="flex-shrink-0">
    <div class="w-16 h-16 rounded-full bg-neutral-200 overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={name}
          class="w-full h-full object-cover"
          style="object-position: center 35%;"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-neutral-400">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
          </svg>
        </div>
      )}
    </div>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-xs text-neutral-500 uppercase tracking-wide mb-1">Written by</p>
    <p class="font-medium text-neutral-900">{name}</p>
    <p class="text-sm text-neutral-600 mt-1">{bio}</p>
  </div>
</div>
