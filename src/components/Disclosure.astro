---
interface Props {
  variant?: 'inline' | 'block';
}

const { variant = 'inline' } = Astro.props;
---

{variant === 'inline' ? (
  <p class="text-xs text-neutral-500">
    We may earn a commission when you apply through our links. This does not affect our recommendations.
  </p>
) : (
  <div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4">
    <p class="text-xs text-neutral-600">
      <strong class="font-medium">Disclosure:</strong> We may receive compensation when you click on links and apply for insurance.
      This helps support our site. Our recommendations are based on research, not compensation.
      We are not insurance brokers, agents, or licensed advisors.
    </p>
  </div>
)}
