---
const footerLinks = {
  compare: {
    title: 'Compare',
    links: [
      { label: 'All Comparisons', href: '/compare' },
      { label: 'Cigna vs Allianz', href: '/compare/cigna-global-vs-allianz-care' },
      { label: 'Best Expat Insurance', href: '/best/expat-health-insurance' },
    ],
  },
  providers: {
    title: 'Insurance Providers',
    links: [
      { label: 'Cigna Global', href: '/providers/cigna-global' },
      { label: 'Allianz Care', href: '/providers/allianz-care' },
      { label: 'Aetna International', href: '/providers/aetna-international' },
      { label: 'All Providers', href: '/providers' },
    ],
  },
  resources: {
    title: 'Resources',
    links: [
      { label: 'Country Guides', href: '/countries' },
      { label: 'Insurance For', href: '/insurance-for' },
      { label: 'How-To Guides', href: '/guides' },
    ],
  },
  company: {
    title: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Contact', href: '/contact' },
      { label: 'Affiliate Disclosure', href: '/affiliate-disclosure' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Use', href: '/terms' },
    ],
  },
};

const currentYear = new Date().getFullYear();
---

<footer class="bg-neutral-900 text-neutral-300" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Top Section: Branding -->
    <div class="mb-10">
      <a href="/" class="flex items-center gap-2 text-white hover:text-white mb-3" aria-label="Compare Expat Plans - Home">
        <svg class="w-8 h-8" viewBox="0 0 32 32" aria-hidden="true">
          <path d="M16 2 L4 7 L4 14 C4 22 9 28 16 30 C23 28 28 22 28 14 L28 7 Z" fill="#3b82f6"/>
          <path d="M13 16 L15 18 L20 12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <span class="text-xl font-semibold text-white" aria-hidden="true">Compare Expat Plans</span>
      </a>
      <p class="text-sm text-neutral-400 max-w-md">
        Helping expats, digital nomads, and global citizens find the right international health insurance.
      </p>
    </div>

    <!-- Footer Links Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      {Object.values(footerLinks).map((section) => (
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wide mb-4">
            {section.title}
          </h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-neutral-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="border-t border-neutral-800 mt-12 pt-8">
      <!-- Disclaimer -->
      <div class="space-y-3 text-xs text-neutral-400">
        <p>
          <strong class="text-neutral-400">Affiliate Disclosure:</strong> We may earn a commission when you apply for insurance through links on this site. This helps support our work and does not affect our recommendations or the price you pay.
        </p>
        <p>
          This website provides general information about international health insurance options. The content is for informational purposes only and does not constitute medical, legal, or financial advice. We are not licensed insurance brokers or agents. Always verify coverage details directly with insurance providers before making decisions.
        </p>
      </div>

      <!-- Copyright -->
      <p class="mt-6 text-sm text-neutral-400">
        &copy; {currentYear} Compare Expat Plans. All rights reserved.
      </p>
    </div>
  </div>
</footer>
