---
import Layout from '../layouts/Layout.astro';
import TableOfContents from './TableOfContents.astro';

interface TocItem {
  id: string;
  text: string;
  level: number;
}

interface Props {
  title: string;
  description?: string;
  headline: string;
  subheadline?: string;
  lastUpdated: string;
  tocItems?: TocItem[];
  author?: {
    name: string;
    bio: string;
    image?: string;
  };
}

const {
  title,
  description,
  headline,
  subheadline,
  lastUpdated,
  tocItems = [],
  author = {
    name: 'John Spencer',
    bio: 'John Spencer is the founder of Compare Expat Plans, where he focuses on helping people compare health plans for life abroad.',
    image: '/images/john-spencer.png',
  },
} = Astro.props;

const siteUrl = "https://compareexpatplans.com";
const currentUrl = Astro.url.pathname;

// Auto-generate breadcrumbs
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Research Reports', url: '/research-reports' },
  { name: headline },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    ...(item.url && { "item": `${siteUrl}${item.url}` }),
  })),
};
---

<Layout title={title} description={description} ogType="article">
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Hero Section - Clean, minimal -->
  <section class="bg-white border-b border-neutral-100 py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-neutral-500">
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">/</span>}
              {crumb.url ? (
                <a href={crumb.url} class="hover:text-neutral-900">{crumb.name}</a>
              ) : (
                <span class="text-neutral-700">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <!-- Badge -->
      <span class="inline-block px-3 py-1 text-xs font-medium bg-blue-50 text-blue-700 rounded-full mb-4">
        Research Report
      </span>

      <h1 class="text-3xl lg:text-4xl font-bold text-neutral-900 mb-4 leading-tight">
        {headline}
      </h1>

      {subheadline && (
        <p class="text-lg text-neutral-600 mb-6 max-w-3xl">
          {subheadline}
        </p>
      )}

      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Last updated: {lastUpdated}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          By {author.name}
        </span>
      </div>
    </div>
  </section>

  <!-- Main Content Area -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="flex gap-16">
      <!-- Main Content -->
      <article class="flex-1 min-w-0 max-w-4xl">
        <!-- Author Box (compact) -->
        <div class="flex items-center gap-4 p-4 bg-neutral-50 rounded-lg mb-10">
          {author.image && (
            <img
              src={author.image}
              alt={author.name}
              class="w-12 h-12 rounded-full object-cover"
              loading="lazy"
            />
          )}
          <div>
            <p class="font-medium text-neutral-900">{author.name}</p>
            <p class="text-sm text-neutral-600">{author.bio}</p>
          </div>
        </div>

        <!-- Table of Contents (Mobile) -->
        {tocItems.length > 0 && (
          <div class="lg:hidden mb-10">
            <TableOfContents items={tocItems} />
          </div>
        )}

        <!-- Page Content Slot -->
        <div class="prose prose-neutral max-w-none prose-headings:scroll-mt-20 prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4 prose-p:text-neutral-700 prose-li:text-neutral-700">
          <slot />
        </div>
      </article>

      <!-- Sticky Sidebar (Desktop) - Minimal for research reports -->
      {tocItems.length > 0 && (
        <aside class="hidden lg:block w-64 flex-shrink-0">
          <div class="sticky top-24">
            <TableOfContents items={tocItems} />
          </div>
        </aside>
      )}
    </div>
  </div>
</Layout>
