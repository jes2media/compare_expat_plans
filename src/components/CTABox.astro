---
import CTAButton from './CTAButton.astro';
import Disclosure from './Disclosure.astro';

interface Props {
  title: string;
  description?: string;
  buttonText: string;
  buttonHref: string;
  variant?: 'default' | 'highlight';
  showDisclosure?: boolean;
}

const {
  title,
  description,
  buttonText,
  buttonHref,
  variant = 'default',
  showDisclosure = true,
} = Astro.props;

const variants = {
  default: 'bg-neutral-50 border border-neutral-200',
  highlight: 'bg-primary-50 border border-primary-200',
};
---

<div class:list={['rounded-xl p-6 lg:p-8', variants[variant]]}>
  <h3 class="text-lg font-semibold text-neutral-900 mb-2">{title}</h3>
  {description && (
    <p class="text-neutral-600 mb-4">{description}</p>
  )}
  <CTAButton href={buttonHref} size="lg" class="w-full sm:w-auto">
    {buttonText}
  </CTAButton>
  {showDisclosure && (
    <div class="mt-4">
      <Disclosure />
    </div>
  )}
</div>
